@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ABSOFF_Parametro a ns1:Parametro ;
    rdfs:label "ABSOFF" ;
    ns1:textoExtracto "desplazamiento 'ABSOFF'"@es ;
    ns1:valor "ABSOFF" .

ns1:ACCEL_Parametro a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:textoExtracto "ACCEL = (3/2)·G00FEED/(60·t)"@es ;
    ns1:valor "ACCEL" .

ns1:ACCJERK_Parametro a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:textoExtracto "ACCJERK = 3·ACCEL/t"@es ;
    ns1:valor "ACCJERK" .

ns1:ADVINPOSC1 a ns1:Parametro ;
    rdfs:label "ADVINPOSC1" ;
    ns1:identificador "ADVINPOSC1" ;
    ns1:monitoreaParametro ns1:SenalAvancePosicion ;
    ns1:textoExtracto "ADVINPOSC1 (también se puede programar como ADVINPOS)" .

ns1:ADVINPOSC2 a ns1:Parametro ;
    rdfs:label "ADVINPOSC2" ;
    ns1:identificador "ADVINPOSC2" ;
    ns1:monitoreaParametro ns1:SenalAvancePosicion ;
    ns1:textoExtracto "ADVINPOSC2" .

ns1:ADVINPOSC3 a ns1:Parametro ;
    rdfs:label "ADVINPOSC3" ;
    ns1:identificador "ADVINPOSC3" ;
    ns1:monitoreaParametro ns1:SenalAvancePosicion ;
    ns1:textoExtracto "ADVINPOSC3" .

ns1:ADVINPOSC4 a ns1:Parametro ;
    rdfs:label "ADVINPOSC4" ;
    ns1:identificador "ADVINPOSC4" ;
    ns1:monitoreaParametro ns1:SenalAvancePosicion ;
    ns1:textoExtracto "ADVINPOSC4" .

ns1:ANAOUTTYPE a ns1:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ns1:monitoreaParametro ns1:ANAOUTID ;
    ns1:textoExtracto "Tipo de salida analógica asociada al eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto CAN." ;
    ns1:valor "Remoto CAN" .

ns1:AccionDetencionEmergencia a ns1:AccionProhibida ;
    rdfs:label "Detención de emergencia por _EMERGEN" ;
    ns1:activaAlarma ns1:SistemaCNC ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=0), el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente. [...] Mientras la marca _EMERGEN está a (=0) el canal del CNC prohíbe la ejecución de programas y aborta cualquier intento de movimiento de los ejes o de cabezal." .

ns1:AccionDetencionPrograma a ns1:AccionProhibida ;
    rdfs:label "Detención de programa por _STOP" ;
    ns1:activaAlarma ns1:SistemaCNC ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene la ejecución del programa pieza." .

ns1:AccionProhibida_ActivacionDirectaErrorCNC a ns1:AccionProhibida ;
    rdfs:label "Activación directa de marcas de error en el CNC sin entradas exteriores"@es ;
    ns1:mitigaRiesgo ns1:Alarma_ErrorPLC ;
    ns1:textoExtracto "Se aconseja utilizar entradas exteriores para activar y desactivar las marcas de error, evitando que el CNC reciba dicho error en cada nuevo ciclo de PLC."@es .

ns1:AccionProhibida_DetachMasterSinExportar a ns1:AccionProhibida ;
    rdfs:label "Detach master sin exportar configuración" ;
    ns1:textoExtracto "Procedimiento en capturas para 'Attach master' (acoplar el máster y detectar recursos por nodo) y 'Detach master' previo a exportar." .

ns1:AccionProhibida_LatcheoYPalpadoSimultaneo a ns1:AccionProhibida ;
    rdfs:label "Ejecutar latcheo de cotas y palpado G100 simultáneamente" ;
    ns1:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:AccionProhibida_MovimientoSinSeleccionPalpador_01 a ns1:AccionProhibida ;
    rdfs:label "Movimiento de palpación sin activar palpador"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_RupturaPalpador_01 ;
    ns1:textoExtracto "Si se realiza un movimiento de palpación sin activar el palpador, éste no enviará ninguna señal al CNC cuando haga contacto. Esta circunstancia puede ocasionar la ruptura del palpador."@es .

ns1:AccionProhibida_ReanudarOperacionSobreTemperatura a ns1:AccionProhibida ;
    rdfs:label "Reanudar operación con temperatura ambiente > 65 ºC" ;
    ns1:textoExtracto "El CNC no permitirá reanudar [la ejecución] tras una interrupción, una inspección de herramienta, etc. [si temperatura > 65 ºC]." .

ns1:Accion_AparcarCabezal a ns1:AccionProhibida ;
    rdfs:label "Aparcar cabezal"@es ;
    ns1:textoExtracto "El CNC no permitirá aparcar un cabezal en los siguientes casos..."@es .

ns1:Accion_AparcarEje a ns1:AccionProhibida ;
    rdfs:label "Aparcar eje"@es ;
    ns1:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos..."@es .

ns1:Accion_AparcarEjes a ns1:AccionProhibida ;
    rdfs:label "Aparcar ejes A B"@es ;
    ns1:solucionaFallo ns1:ErrorCNC_EjesAusentes ;
    ns1:textoExtracto "Cuando se trabaja con el cabezal normal los ejes A B no están presentes, y el CNC mostrará error porque los tiene en cuenta (reguladores, sistemas de captación, etc.). Para evitar esto, será necesario aparcar los ejes A B."@es .

ns1:Accion_CNCRD_LecturaCNC a ns1:AccionProhibida ;
    rdfs:label "CNCRD (Lectura de variables CNC)" ;
    ns1:identificador "CNCRD" ;
    ns1:textoExtracto "Lectura (CNCRD) [...] de las variables del CNC." .

ns1:Accion_CNCWR_EscrituraCNC a ns1:AccionProhibida ;
    rdfs:label "CNCWR (Escritura de variables CNC)" ;
    ns1:identificador "CNCWR" ;
    ns1:textoExtracto "Escritura (CNCWR) [...] de las variables del CNC." .

ns1:Accion_ERA_BorrarGrupoRecursos a ns1:AccionProhibida ;
    rdfs:label "ERA (Borrar grupo de recursos)" ;
    ns1:identificador "ERA" ;
    ns1:textoExtracto "ERA Borra un grupo de recursos. Permite borrar o inicializar un grupo de recursos del mismo tipo. [...] Si se borra un grupo de I, O, M, MSG, ERR o R, el PLC les asigna el valor 0." .

ns1:Accion_PAR_ParidadRegistro a ns1:AccionProhibida ;
    rdfs:label "PAR (Paridad de un registro)" ;
    ns1:identificador "PAR" ;
    ns1:textoExtracto "PAR Paridad de un registro. Analiza el tipo de paridad de un registro. Si el registro tiene paridad PAR, esta instrucción asignará un 1 a la marca, mensaje o error seleccionado, y si tiene paridad IMPAR, le asignará un 0." .

ns1:ActualizacionSoftware_1_4 a ns1:TareaMantenimiento ;
    rdfs:label "Actualización de software del CNC"@es ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:requiereMantenimiento ns1:CNC_FagorAutomation ;
    ns1:textoExtracto "Las actualizaciones se deben realizar con el software suministrado por Fagor Automation. [...] Para actualizar el software, cerrar todos los programas que estén en marcha, incluido el CNC. [...] Introduzca el pendrive de Fagor en el puerto USB y ejecute el programa setup8070_Vxx_xx_xx.exe"@es .

ns1:ActualizacionSoftware_V2 a ns1:Sistema ;
    rdfs:label "Actualización de software a VERSION_2"@es ;
    ns1:identificador "VERSION_2" ;
    ns1:textoExtracto "Incluir: <GeometryObject name=\"VERSION_2\"> </GeometryObject>"@es ;
    ns1:tieneComponente ns1:Conexion_SYS_Tool1_C1,
        ns1:Conexion_SYS_Tool1_C2,
        ns1:Conexion_SYS_Tool1_C3,
        ns1:Herramienta_SYS_Tool1,
        ns1:Herramienta_SYS_Tool2,
        ns1:Herramienta_SYS_Tool3,
        ns1:Herramienta_SYS_Tool4 .

ns1:AlarmaError24499 a ns1:Alarma ;
    rdfs:label "ERROR 24499 – EtherCAT: Error in slave"@es ;
    ns1:activaAlarma ns1:InterfazDiagnosisEtherCAT ;
    ns1:identificador "24499" ;
    ns1:textoExtracto "Captura de alarma 'ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic' en la HMI del CNC, con barra roja, código y botones de navegación. Resalta el identificador del error y la indicación de consultar diagnosis."@es .

ns1:AlarmaErrorSeguimiento a ns1:Alarma ;
    rdfs:label "Alarma por error de seguimiento"@es ;
    ns1:activaAlarma ns1:GraficoBandaErrorSeguimiento ;
    ns1:textoExtracto "Fuera de la banda se indica 'ERROR', visualizando el criterio de aceptación"@es .

ns1:AlarmaLimiteSoftware a ns1:Alarma ;
    rdfs:label "Alarma por límite de software alcanzado"@es ;
    ns1:activaAlarma ns1:LimitesSoftwareCNC ;
    ns1:textoExtracto "Cuando un eje alcanza los límites de software, el CNC detiene la ejecución y muestra el error correspondiente."@es .

ns1:Alarma_GapActivo a ns1:Alarma ;
    rdfs:label "Marca de salida del gap (GAPMIN/GAPMAX)" ;
    ns1:monitoreaParametro ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN ;
    ns1:textoExtracto "Esta marca permanece activa hasta iniciar la ejecución de un programa. [...] ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa" .

ns1:Alarma_OutOfTol a ns1:Alarma ;
    rdfs:label "OUTOFTOL (Fuera de tolerancia del gap)" ;
    ns1:monitoreaParametro ns1:Parametro_GAPTOL ;
    ns1:textoExtracto "El PLC activa esta marca para indicar que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa" .

ns1:AlmacenAsincrono a ns1:ComponenteMecanico ;
    rdfs:label "Almacén asíncrono"@es ;
    ns1:textoExtracto "Almacén asíncrono. Brazo cambiador de movimientos independientes que puede moverse durante el mecanizado."@es .

ns1:AlmacenAsincrono_BrazoCambiador a ns1:Sistema ;
    rdfs:label "Almacén asíncrono con brazo cambiador"@es ;
    ns1:compuestoPor ns1:AlmacenHerramientas_Asincrono,
        ns1:BrazoCambiador_AlmacenAsincrono ;
    ns1:controla ns1:ProcesoCambioHerramienta_M06 ;
    ns1:textoExtracto "Los almacenes asíncronos tienen el almacén alejado del cabezal y el cambio se realiza con ayuda del brazo cambiador. La mayoría de los movimientos se pueden efectuar durante el mecanizado de la pieza, minimizando tiempos."@es .

ns1:AlmacenCiclico a ns1:Sistema ;
    rdfs:label "Almacén Cíclico"@es ;
    ns1:textoExtracto "Un almacén cíclico necesita una orden de cambio de herramienta M06 después de buscar una herramienta y antes de buscar la siguiente."@es .

ns1:AlmacenEjemplo_7.2 a ns1:Sistema ;
    rdfs:label "Almacén de herramientas (ejemplo de 10 posiciones)" ;
    ns1:documentadoEn ns1:TablaAlmacenes_7.2 ;
    ns1:textoExtracto "Ejemplo: Se dispone de 10 herramientas y un almacén de 10 posiciones." ;
    ns1:tieneComponente ns1:Herramienta_T1,
        ns1:Herramienta_T2,
        ns1:Herramienta_T3,
        ns1:Herramienta_T4,
        ns1:Herramienta_T5,
        ns1:Herramienta_T6,
        ns1:Herramienta_T7 .

ns1:AlmacenHerramientas_7.5 a ns1:Sistema ;
    rdfs:label "Sistema de almacenamiento de herramientas"@es ;
    ns1:textoExtracto "Carga y descarga de herramientas del almacén. En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática."@es ;
    ns1:tieneComponente ns1:CabezalHerramientas_7.5,
        ns1:PinzasBrazoCambiador_7.5,
        ns1:SoftkeysAlmacen_7.5,
        ns1:TablaAlmacen_7.5 .

ns1:AlmacenHerramientas_894 a ns1:Sistema ;
    rdfs:label "Almacén no-random de herramientas"@es ;
    ns1:documentadoEn ns1:EjemploFuncionamientoCNC_894 ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número"@es .

ns1:AlmacenNoCiclico a ns1:Sistema ;
    rdfs:label "Almacén No-Cíclico"@es ;
    ns1:textoExtracto "Un almacén no-cíclico permite realizar varias búsquedas de herramienta seguidas, sin efectuar necesariamente el cambio de herramienta."@es .

ns1:AlmacenNoRandom a ns1:Sistema ;
    rdfs:label "Almacén No-Random"@es ;
    ns1:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición."@es .

ns1:AlmacenRandom a ns1:Sistema ;
    rdfs:label "Almacén Random"@es ;
    ns1:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición."@es .

ns1:AlmacenSinBrazoCambiador_7_8 a ns1:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador"@es ;
    ns1:textoExtracto "En un almacén síncrono sin brazo cambiador el almacén debe desplazarse hasta el cabezal para efectuar el cambio. [...] Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, etc.)."@es ;
    ns1:tieneComponente ns1:AlmacenHerramientas_7_8,
        ns1:CNC_AlmacenSinBrazoCambiador,
        ns1:Gestor_AlmacenSinBrazoCambiador,
        ns1:PLC_AlmacenSinBrazoCambiador .

ns1:AlmacenSincronoConBrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Almacén síncrono con brazo cambiador"@es ;
    ns1:textoExtracto "Almacén síncrono con brazo cambiador (1 ó 2 pinzas). El brazo cambiador no puede moverse durante el mecanizado de la pieza."@es .

ns1:AlmacenSincronoSinBrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Almacén síncrono sin brazo cambiador"@es ;
    ns1:textoExtracto "Almacén síncrono sin brazo cambiador."@es .

ns1:AlmacenSincrono_Brazo1Pinza a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador de 1 pinza"@es ;
    ns1:compuestoPor ns1:AlmacenHerramientas_ProximoCabezal,
        ns1:BrazoCambiador_1Pinza ;
    ns1:controla ns1:CambioHerramienta_Proceso ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza."@es .

ns1:AlmacenSincrono_Brazo2Pinzas a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador de 2 pinzas"@es ;
    ns1:compuestoPor ns1:AlmacenHerramientas_ProximoCabezal,
        ns1:BrazoCambiador_2Pinzas ;
    ns1:controla ns1:CambioHerramienta_Proceso ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza."@es .

ns1:Almacen_867 a ns1:Sistema ;
    rdfs:label "Almacén de herramientas"@es ;
    ns1:textoExtracto "un almacén sólo puede estar involucrado en un proceso de cambio de herramienta. Si desde un canal se quiere coger o dejar una herramienta en un almacén que ya está en un proceso de cambio, el gestor esperará a que acabe el proceso en curso antes de atender la nueva solicitud."@es .

ns1:AnalisisTrayectoriaHSC a ns1:DiagnosticoFallo ;
    rdfs:label "Análisis de trayectoria en modo HSC" ;
    ns1:monitoreaParametro ns1:VGFREAL ;
    ns1:textoExtracto "Analizar las diferentes variables de los ejes en la zona conflictiva, para determinar si hay un error en la trayectoria teórica, en el lazo de control o en la captación." .

ns1:Aplicacion_FGUIM a ns1:Sistema ;
    rdfs:label "FGUIM" ;
    ns1:habilitadoPor ns1:Parametro_APPLICATION ;
    ns1:textoExtracto "Ejecutar una aplicación externa, por ejemplo el FGUIM. [...] ..\\Fagor\\Release\\Fguim.exe" .

ns1:Aplicacion_LantekExpertInside a ns1:Sistema ;
    rdfs:label "Lantek Expert Inside" ;
    ns1:habilitadoPor ns1:Parametro_APPLICATION ;
    ns1:textoExtracto "En un modelo láser, se recomienda utilizar la esta tecla para abrir la aplicación \"Lantek Expert Inside\" para el nesting; C:\\Lantek\\Expert\\Expert.exe." .

ns1:AplicacionesExternas_46 a ns1:Sistema ;
    rdfs:label "Aplicaciones externas"@es ;
    ns1:documentadoEn ns1:CarpetaMTB_46 ;
    ns1:textoExtracto "incorporación de aplicaciones externas"@es .

ns1:ArchivoCompensacionVolumetrica a ns1:Componente ;
    rdfs:label "Archivo de compensación volumétrica (CSV)"@es ;
    ns1:monitoreaParametro ns1:Parametro_INCHES,
        ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv)."@es .

ns1:ArchivoConfig_MillA a ns1:InterfazUsuario ;
    rdfs:label "Mill A@table B,C@spindle.xca" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesRotativos_19_1 ;
    ns1:identificador "MillA_tableBC_spindle" ;
    ns1:textoExtracto "Mill A@table B,C@spindle.xca" .

ns1:ArchivoConfig_MillB a ns1:InterfazUsuario ;
    rdfs:label "Mill B@table A,C@spindle.xca" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesRotativos_19_1 ;
    ns1:identificador "MillB_tableAC_spindle" ;
    ns1:textoExtracto "Mill B@table A,C@spindle.xca" .

ns1:ArchivoConfig_MillC a ns1:InterfazUsuario ;
    rdfs:label "Mill C@table A,B@spindle.xca" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesRotativos_19_1 ;
    ns1:identificador "MillC_tableAB_spindle" ;
    ns1:textoExtracto "Mill C@table A,B@spindle.xca" .

ns1:ArchivoConfiguracionCNC a ns1:InterfazUsuario ;
    rdfs:label "Archivo de configuración EtherCAT para CNC"@es ;
    ns1:documentadoEn ns1:Tarea_CopiarArchivoConfiguracionCNC ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "archivo xml [...] renombrarlo como \"fagor_ethercatConfFile.xml\""@es .

ns1:ArchivoConfiguracion_1362 a ns1:Parametro ;
    rdfs:label "Archivo de configuración ETG Standard (*.xml)"@es ;
    ns1:textoExtracto "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es ;
    ns1:valor "*.xml" .

ns1:ArchivoDEF a ns1:Sistema ;
    rdfs:label "Archivo *.def"@es ;
    ns1:documentadoEn ns1:ManualMaquina ;
    ns1:textoExtracto "archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca)"@es .

ns1:ArchivoDEF_Ejemplo a ns1:InterfazUsuario ;
    rdfs:label "Archivo DEF de configuración de ejes" ;
    ns1:documentadoEn ns1:ArchivoXCA_Mill_A_tableB_C_spindle ;
    ns1:identificador "*.def" ;
    ns1:textoExtracto "En la carpeta de cada máquina hay un archivo def de ejemplo. Si se van a copiar a otra carpeta, hay que copiar ambos archivos (xca y def)." .

ns1:ArchivoLeva a ns1:InterfazUsuario ;
    rdfs:label "Archivo de leva" ;
    ns1:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC" .

ns1:ArchivoRutado_1376 a ns1:InterfazUsuario ;
    rdfs:label "Archivo de rutado (*.xml)"@es ;
    ns1:identificador "*.xml" ;
    ns1:textoExtracto "archivo de rutado [...] extensión *.xml"@es .

ns1:ArchivoXCA a ns1:Sistema ;
    rdfs:label "Archivo *.xca"@es ;
    ns1:documentadoEn ns1:ManualMaquina ;
    ns1:textoExtracto "archivo xca [...] define si los gráficos trabajan con cotas de la base o de la punta de la herramienta"@es .

ns1:Archivo_MComments a ns1:InterfazUsuario ;
    rdfs:label "MComments.txt" ;
    ns1:textoExtracto "Los comentarios se guardan en el archivo MComments.txt y se puede tener un archivo por cada idioma. Estos archivos se guardan en la carpeta ..\\MTB\\Data\\Lang."@es .

ns1:Archivo_VCOMPFILE a ns1:Parametro ;
    rdfs:label "Archivo de compensación volumétrica (VCOMPFILE)"@es ;
    ns1:identificador "VCOMPFILE[tbl]" ;
    ns1:textoExtracto "Archivo con los datos de la compensación volumétrica. Unidades: -. | R(*) | R | R |"@es .

ns1:Archivo_cncError_txt a ns1:InterfazUsuario ;
    rdfs:label "cncError.txt" ;
    ns1:identificador "cncError.txt" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\LANG está el archivo cncError.txt que contiene los mensajes y errores del fabricante en los distintos idiomas." .

ns1:Archivo_fagor_ethercatConfFile_xml a ns1:Consumible ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:requiereConsumible ns1:Software_KPA_EtherCAT_Studio ;
    ns1:textoExtracto "Copiar el archivo creado por \"KPA EtherCAT Studio\" como fagor_ethercatConfFile.xml."@es .

ns1:Archivo_mensajes_PLC a ns1:InterfazUsuario ;
    rdfs:label "Archivo de mensajes y errores del PLC" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas." .

ns1:Archivo_resourceRouterConf_xml a ns1:Consumible ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:requiereConsumible ns1:Software_Fagor_EtherCAT_Mapper ;
    ns1:textoExtracto "Copiar el archivo creado por \"Fagor EtherCAT Mapper\" como resourceRouterConf.xml."@es .

ns1:Archivo_scripts_MMC a ns1:InterfazUsuario ;
    rdfs:label "Archivo de textos de scripts MMC" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\LANG está el archivo que contiene los textos utilizados por los scripts." .

ns1:AtributoCOMMENT a ns1:Parametro ;
    rdfs:label "Atributo COMMENT (descripción OEM)"@es ;
    ns1:textoExtracto """\r
COMMENT Descripción del parámetro OEM. [...] Los comentarios se guardan en el archivo MTBComments.txt.\r
"""@es .

ns1:AtributoINCHES a ns1:Parametro ;
    rdfs:label "Atributo INCHES (afectación por cambio de unidades)"@es ;
    ns1:textoExtracto """\r
INCHES El parámetro se ve afectado por el cambio de unidades. Valores posibles: Sí / No. Valor por defecto: Sí.\r
"""@es ;
    ns1:valor "Sí" .

ns1:AtributoMODE a ns1:Parametro ;
    rdfs:label "Atributo MODE (modo de acceso al parámetro)"@es ;
    ns1:textoExtracto """\r
MODE Modo de acceso al parámetro desde su variable. Valores posibles: Lectura / Escritura. Valor por defecto: Lectura.\r
"""@es ;
    ns1:valor "Lectura" .

ns1:AvisoControlSincronizado a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de control PLC en cabezales sincronizados" ;
    ns1:mitigaRiesgo ns1:CabezalesSistema ;
    ns1:textoExtracto "Si se intenta controlar un cabezal sincronizado (tanto maestro como esclavo) mediante PLCCNTL, se mostrará un aviso indicando que no es posible." .

ns1:AvisoErrorLimiteRecorrido a ns1:AvisoSeguridad ;
    rdfs:label "Error de límite de recorrido" ;
    ns1:mitigaRiesgo ns1:SenalLIMITNEG,
        ns1:SenalLIMITPOS ;
    ns1:textoExtracto "visualizando en la pantalla el error correspondiente"@es .

ns1:AvisoLicenciaModulos a ns1:AvisoSeguridad ;
    rdfs:label "Error de licencia durante la detección de módulos"@es ;
    ns1:textoExtracto "Error de licencia durante la detección de modulos. Ignorar este aviso."@es .

ns1:AvisoLicencia_Basica a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de licencia Básica"@es ;
    ns1:ilustradoEn ns1:Interfaz_KPA_EtherCAT_Studio ;
    ns1:textoExtracto "advertencia de licencia durante la detección de módulos, indicada como ignorables con la licencia 'Básica'"@es .

ns1:AvisoLicencia_NoLicenseFound a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: No license found"@es ;
    ns1:ilustradoEn ns1:Interfaz_KPA_EtherCAT_Studio ;
    ns1:textoExtracto "aviso de 'No license found' al arrancar, con botón 'Browse' para seleccionar la unidad USB del dongle"@es .

ns1:AvisoRetraceActivo a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de retrace activo" ;
    ns1:textoExtracto "el CNC mostrará un aviso indicando que se debe desactivar esta marca para continuar con la ejecución del programa." .

ns1:AvisoSeguridadModoSetup a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad en modo SETUP" ;
    ns1:textoExtracto "En esta situación el CNC no dispone de garantía Fagor. Transcurrido un determinado tiempo, con el siguiente reset, el CNC vuelve a mostrar el mensaje." .

ns1:AvisoSeguridad_DMC_Desactivacion a ns1:AvisoSeguridad ;
    ns1:mitigaRiesgo ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Las siguientes acciones relacionadas con la herramienta desactivan el DMC: Cambiar la herramienta. Cambiar el corrector. Ejecutar una M6. Cambiar alguna de las características del corrector que afecten al consumo de potencia del cabezal."@es .

ns1:AvisoSeguridad_DMC_Incompatibilidad a ns1:AvisoSeguridad ;
    ns1:mitigaRiesgo ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "El DMC es incompatible con algunos tipos de operaciones, como roscados, taladrados, etc. Además, el DMC se desactivará automáticamente si la herramienta activa no es de tipo 'Fresado' o 'Planeado'."@es .

ns1:AvisoSeguridad_DeshabilitacionFLWEMONITOR a ns1:AvisoSeguridad ;
    rdfs:label "Deshabilitación de monitorización de error de seguimiento" ;
    ns1:mitigaRiesgo ns1:ErrorSeguimiento ;
    ns1:textoExtracto "Si se desactiva esta vigilancia, el CNC muestra en el encendido un mensaje indicando que dicha seguridad está deshabilitada. Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada." .

ns1:AvisoSeguridad_FWAITLIM a ns1:AvisoSeguridad ;
    rdfs:label "FWAITLIM" ;
    ns1:identificador "FWAITLIM" ;
    ns1:mitigaRiesgo ns1:Parametro_FOLLOW_WAITINLIMIT ;
    ns1:textoExtracto "El PLC activa esta marca cuando detiene la ejecución del programa por un #FOLLOW[WAITINLIMIT], para que la cota programada entre dentro de los límites (modelo láser)." .

ns1:AvisoSeguridad_FaltaConfiguracion a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de configuración incompleta"@es ;
    ns1:mitigaRiesgo ns1:ModoOperacion_USER ;
    ns1:textoExtracto "el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar. En esta situación el CNC no dispone de garantía Fagor."@es .

ns1:AvisoSeguridad_LimitacionesMechatrolink a ns1:AvisoSeguridad ;
    rdfs:label "Limitaciones de configuración del bus Mechatrolink" ;
    ns1:textoExtracto "• El CNC no realiza ningún proceso de homogeneización de parámetros con los reguladores Mechatrolink. La parametrización y ajuste de los reguladores deberá hacerse con ayuda de herramientas externas proporcionadas por el fabricante del regulador, a través del interface del propio dispositivo o escribiendo los parámetros desde los modos DDSSetup y Tuning del CNC. • No se permite segunda captación, por lo que no es posible la mezcla de captaciones (parámetro FBMIXTIME) ni el cambio de captación (parámetro FBACKSRC). Tampoco se permite ninguna configuración similar a semi-Sercos. • No se permiten ejes o cabezales tándem. • No se permite aparcar ejes o cabezales. • No está disponible el bode. • No se permite el cambio de gama. • No se permite inicializar la cota. • El cambio dinámico de feed forward, AC forward y Kv dependerá de los dispositivos conectados en el bus." .

ns1:AvisoSeguridad_LimiteDinamico a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Límite dinámico de aceleración combinada"@es ;
    ns1:mitigaRiesgo ns1:Parametro_IPOACCP ;
    ns1:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina."@es .

ns1:AvisoSeguridad_MarcaAUTOMAT a ns1:AvisoSeguridad ;
    rdfs:label "Marca AUTOMAT" ;
    ns1:identificador "AUTOMAT" ;
    ns1:ilustradoEn ns1:InterfazUsuario_Se_alesConsulta ;
    ns1:textoExtracto "se activan las marcas AUTOMAT y SBOUT" .

ns1:AvisoSeguridad_MarcaMANUAL a ns1:AvisoSeguridad ;
    rdfs:label "Marca MANUAL" ;
    ns1:identificador "MANUAL" ;
    ns1:ilustradoEn ns1:InterfazUsuario_Se_alesConsulta ;
    ns1:textoExtracto "se activan las marcas MANUAL y SBOUT" .

ns1:AvisoSeguridad_MarcaSBOUT a ns1:AvisoSeguridad ;
    rdfs:label "Marca SBOUT" ;
    ns1:identificador "SBOUT" ;
    ns1:ilustradoEn ns1:InterfazUsuario_Se_alesConsulta ;
    ns1:textoExtracto "se activan las marcas AUTOMAT y SBOUT" .

ns1:AvisoSeguridad_ModificacionConfiguracion a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modificación de configuración CNC" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_CopiaSeguridadConfiguracionCNC ;
    ns1:textoExtracto "Si se selecciona el apagado normal y el CNC detecta que se ha modificado la configuración de la máquina, avisará de esta circunstancia y preguntará si se desea guardar una copia de seguridad de la configuración de la máquina." .

ns1:AvisoSeguridad_ModoAdministrador a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de Modo No Protegido (Administrador)" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Administrador ;
    ns1:textoExtracto "indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido." .

ns1:AvisoSeguridad_ModoSetup a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de Modo No Protegido (Setup)" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Setup ;
    ns1:textoExtracto "indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido." .

ns1:AvisoSeguridad_Sobretemperatura a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de sobretemperatura" ;
    ns1:mitigaRiesgo ns1:Sistema_Se_alesConsultaCNC ;
    ns1:textoExtracto "restringir la operativa del CNC en caso de sobretemperatura. Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo. Apagar el equipo para evitar daños." .

ns1:AvisoSeguridad_WarningSimbolos a ns1:AvisoSeguridad ;
    rdfs:label "Warning de símbolos excedidos" ;
    ns1:mitigaRiesgo ns1:Sistema_PLC ;
    ns1:textoExtracto "Los símbolos que superen este límite [200] serán ignorados y el CNC mostrará el warning correspondiente." .

ns1:AvisoSeguridad_WarningValidacionEje a ns1:AvisoSeguridad ;
    rdfs:label "Warning de validación de parámetros del eje" ;
    ns1:textoExtracto "En caso contrario se mostrará un warning al validar los parámetros del eje, en el que se informa del máximo avance que se puede alcanzar." .

ns1:AvisoSobretemperatura a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de sobretemperatura (OVERTEMP)"@es ;
    ns1:activaAlarma ns1:AlarmaSobretemperatura ;
    ns1:textoExtracto "Recuadro de advertencia con icono triangular y texto sobre sobretemperatura (OVERTEMP). El bloque enfatiza que, si la marca se activa, existe riesgo para el equipo; el formato enmarcado y el símbolo de peligro aportan jerarquía visual y urgen a limitar la operativa del CNC hasta restablecer la temperatura."@es .

ns1:Aviso_CompatibilidadSoftwareV2 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso sobre compatibilidad de marcas y registros en OPENPCS REMOTO V2.00+"@es ;
    ns1:documentadoEn ns1:Pagina_761 ;
    ns1:textoExtracto "Recuadro informativo con icono 'i' (aviso) sobre compatibilidad de marcas y registros con versiones anteriores del software; enfatiza que, desde V2.00, las señales sin referencia explícita pasan a referirse al primer canal o almacén."@es .

ns1:Aviso_DMC_3103 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3103" ;
    ns1:activaAlarma ns1:DMC_ModoOperacion ;
    ns1:identificador "3103" ;
    ns1:textoExtracto "Si el DMC detecta una situación de este tipo, muestra el aviso 3103." .

ns1:Aviso_FalloPalpador a ns1:AvisoSeguridad ;
    rdfs:label "Riesgo de ruptura del palpador por falta de activación"@es ;
    ns1:mitigaRiesgo ns1:CalibracionPalpador ;
    ns1:textoExtracto "Si se realiza un movimiento de palpación sin activar el palpador, éste no enviará ninguna señal al CNC cuando haga contacto. Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:Aviso_InsuficienteLOOPTIME_CANopen a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de LOOPTIME insuficiente (CANopen)" ;
    ns1:textoExtracto "En el arranque del CNC se realiza adicionalmente una estimación del tiempo necesario, mostrando el correspondiente aviso en caso de ser insuficiente" .

ns1:Aviso_SeguridadSoftwareCNC a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad por manipulación del software CNC" ;
    ns1:mitigaRiesgo ns1:Accion_ModificacionSoftwareCNC ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC y que hayan sido motivados por una manipulación del software." .

ns1:AvisosPantalla a ns1:AvisoSeguridad ;
    rdfs:label "Avisos en pantalla" ;
    ns1:textoExtracto "En el arranque de la aplicación, ya sea en modo setup o en modo usuario, el CNC puede mostrar avisos en pantalla cuya causa debe ser solucionada por el fabricante durante la puesta a punto." .

