    rdfs:label "CLK800" ;
    ns1:documentadoEn ns1:Tabla_RecursosPLC_703 ;
    ns1:identificador "CLK800" ;
    ns1:textoExtracto "CLK800 | 800 ms" ;
    ns1:valor "800 ms"^^xsd:string .

ns1:Parametro_1c78e01ec5 a ns1:Parametro ;
    rdfs:label "MNEMONIC" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Mnemónico del bloque lógico."@es .

ns1:Parametro_1d3cb69b59 a ns1:Parametro ;
    rdfs:label "INCJOGDIST2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST2" ;
    ns1:textoExtracto "INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch."@es ;
    ns1:valor "0.0100 mm o grados / 0.00039370 inch" .

ns1:Parametro_1d45785189 a ns1:Parametro ;
    ns1:identificador "SFUN2" ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Estos registros hacen referencia al número de cabezal; son independientes del canal en el que se encuentra el cabezal. Cada uno de los registros indica el valor de una de las funciones S programadas. Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en un bloque se encuentran programadas las funciones S1000 y S1=550, el CNC pasará al PLC la siguiente información. | SFUN1 | SFUN2 | SFUN3 | SFUN4 | | --- | --- | --- | --- | | 1000 | 550 | $FFFFFFFF | $FFFFFFFF |" ;
    ns1:valor "550" .

ns1:Parametro_1ddeef96a2 a ns1:Parametro ;
    rdfs:label "DATA" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Tabla para definir los valores de compensación."@es .

ns1:Parametro_1ea0dbbc2d a ns1:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ns1:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicaría el parámetro TRANSDELAY (aproximadamente la suma de TRANSDELAY y ACFWFACTOR en un ajuste analógico o Sercos velocidad)." ;
    ns1:valor "> TRANSDELAY" .

ns1:Parametro_1ec9630740 a ns1:Parametro ;
    ns1:identificador "TMOPERATION = 5" ;
    ns1:textoExtracto "como TMOPERATION=5"@es .

