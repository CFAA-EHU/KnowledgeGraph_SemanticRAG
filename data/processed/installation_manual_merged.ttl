ns1:Instruccion_CPS a ns1:InterfazUsuario ;
    rdfs:label "Instrucción CPS (Comparación entre operandos)" ;
    ns1:identificador "CPS" ;
    ns1:textoExtracto "La instrucción CPS permite realizar comparaciones entre dos operandos, comprobando si el primer operando es mayor (GT), mayor o igual (GE), igual (EQ), distinto (NE), menor o igual (LE) o menor (LT) que el segundo. [...] El formato de programación es: T1ꞏꞏ512 GT CPS T1ꞏꞏ512 C1ꞏꞏ256 GE C1ꞏꞏ256 R1ꞏꞏ1024 EQ R1ꞏꞏ1024 R CNC-PLC NE R CNC-PLC LT" .

ns1:InterfazOpenPCS_ParametrizacionPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de parametrización del PLC remoto en OpenPCS"@es ;
    ns1:textoExtracto "Captura del interfaz de parametrización del PLC remoto: tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor) y efectos RUN/STOP/PLCREADY, junto a panel de opciones del CNC (IEC-61131) y botones aplicados. Se muestra también un cuadro con ruta de proyecto/plantilla de hardware."@es .

ns1:InterfazUsuario_BarraDeslizanteModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Barra deslizante de override dinámico (modo automático)" ;
    ns1:ilustradoEn ns1:ModoOperacion_Automatico ;
    ns1:textoExtracto "La pantalla del modo automático ofrece una barra deslizante que permite variar la dinámica definida por programa para un mecanizado." .

ns1:InterfazUsuario_CNC_CorreccionArco a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC para corrección del centro del arco" ;
    ns1:monitoreaParametro ns1:Parametro_0132277a06,
        ns1:Parametro_2fe4e553db ;
    ns1:textoExtracto "El CNC mostrará el error correspondiente cuando la diferencia entre ambos radios sea mayor que CIRINERR y mayor que —CIRINFACT x Radio—." .

ns1:InterfazUsuario_Configurador a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del configurador (ventana izquierda)"@es ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Scan configuration' [...] seleccionar la opción 'Upload detected Module Ident list' [...] seleccionar la opción 'Attach master' [...] seleccionar la opción 'Detach master'."@es .

ns1:InterfazUsuario_ConfiguradorTopologiaBus a ns1:InterfazUsuario ;
    rdfs:label "Configurador de topología del bus (modo offline)"@es ;
    ns1:identificador "20.1.5_ModoOffline_ConfiguradorTopologia" ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Append Slave'. El configurador muestra los dispositivos disponibles. [...] Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es .

ns1:InterfazUsuario_EntradasSalidas a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de entradas/salidas y recursos lógicos"@es ;
    ns1:textoExtracto "Testean el estado de los recursos y devuelven su estado lógico. • Entradas (I1-I1024) • Salidas (O1-O1024) • Entradas locales (LI1-LI16) • Salidas locales (LO1-LO8) • Marcas (M1-M8192) • Mensajes (MSG1-MSG1024) • Errores (ERR1-ERR1024) • Relojes (CLK) • Registros (R1-R1024) • Bit de registros (B0-B31 R1-R1024) • Estado de los temporizadores (T1-T512) • Estado de los contadores (C1-C256) • Marcas de comunicación CNC-PLC."@es ;
    ns1:tieneComponente ns1:Entrada_I12,
        ns1:Tecla_START .

ns1:InterfazUsuario_JogPanel a ns1:InterfazUsuario ;
