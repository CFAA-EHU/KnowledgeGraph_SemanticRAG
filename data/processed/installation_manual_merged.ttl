    ns1:identificador "PLCCNTL" ;
    ns1:monitoreaParametro ns1:PLCControlCabezal ;
    ns1:textoExtracto "El PLC [...] activa la marca PLCCNTL para indicar que el cabezal está controlado por el PLC. Una vez finalizado hay que poner PLCCNTL a (=0) [...]."@es ;
