ns1:Parametro_HWFBACKAL a ns1:Parametro ;
    rdfs:label "HWFBACKAL",
        "Parámetro HWFBACKAL" ;
    ns1:activaAlarma ns1:Alarma_Hardware_Captacion ;
    ns1:habilitadoPor ns1:Alarma_CaptacionHardware ;
    ns1:identificador "(V.)[ch].MPA.HWFBACKAL[set].xn",
        "V.[ch].MPA.HWFBACKAL[set].xn" ;
    ns1:textoExtracto "HWFBACKAL Habilitar la alarma hardware (pin de alarma) de la captación local. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.HWFBACKAL[set].xn",
        "Variable asociada: (V.)[ch].MPA.HWFBACKAL[set].xn. Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." ;
    ns1:valor "Sí / No" .

ns1:Parametro_I0CODDI1_1077 a ns1:Parametro ;
    rdfs:label "I0CODDI1" ;
    ns1:identificador "I0CODDI1" ;
    ns1:textoExtracto "Paso entre señales de I0 fijas"@es ;
    ns1:valor "debe ser igual en ambos ejes"@es .

ns1:Parametro_I0CODDI2_1077 a ns1:Parametro ;
    rdfs:label "I0CODDI2" ;
    ns1:identificador "I0CODDI2" ;
    ns1:textoExtracto "Paso entre señales de I0 variables"@es ;
    ns1:valor "debe ser igual en ambos ejes"@es .

ns1:Parametro_I0TYPE_1077 a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Tipo de I0"@es ;
    ns1:valor "debe ser igual en ambos ejes"@es .

ns1:Parametro_I0TYPE_1104 a ns1:Parametro ;
    rdfs:label "I0TYPE (tipo de I0)"@es ;
    ns1:monitoreaParametro ns1:SistemaEjesGantry_1104 ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes el mismo."@es ;
    ns1:valor "mismo_en_ambos_ejes"@es .

ns1:Parametro_I0TYPE_69 a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes no codificado o en ambos ejes codificado (creciente o decreciente)."@es .

ns1:Parametro_I2 a ns1:Parametro ;
    rdfs:label "Entrada I2"@es ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)."@es .

ns1:Parametro_I23 a ns1:Parametro ;
    rdfs:label "I23" ;
    ns1:identificador "I23" ;
    ns1:textoExtracto "DFU I23" .

ns1:Parametro_I8 a ns1:Parametro ;
    rdfs:label "Entrada I8"@es ;
    ns1:identificador "I8" ;
    ns1:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios."@es .

ns1:Parametro_ICORNER a ns1:Parametro ;
    rdfs:label "ICORNER (Tipo de arista)" ;
    ns1:identificador "(V.)[ch].MPG.ICORNER" ;
    ns1:textoExtracto "ICORNER Tipo de arista (G5/G7/G50) por defecto. Valores posibles: G50 / G5 / G7. Valor por defecto: G50. Variable asociada: (V.)[ch].MPG.ICORNER Este parámetro indica el tipo de arista que asume el CNC por defecto. Se dispone de tres tipos de aristas a saber, arista viva (G7), arista matada (G5) y arista semimatada (G50)." ;
    ns1:valor "G50" .

ns1:Parametro_ID_Mechatrolink a ns1:Parametro ;
    rdfs:label "ID (Mechatrolink)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosDRV_Mechatrolink ;
    ns1:textoExtracto "Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo."@es .

ns1:Parametro_ID_Sercos a ns1:Parametro ;
    rdfs:label "ID (Sercos)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosDRV_Sercos ;
    ns1:textoExtracto "Identificador ID Sercos de la variable a consultar en el regulador."@es .

ns1:Parametro_IFEED a ns1:Parametro ;
    rdfs:label "IFEED (Tipo de avance por defecto)" ;
    ns1:identificador "G94/G95" ;
    ns1:textoExtracto "Este parámetro indica el tipo de avance que asume el CNC por defecto. • Con G94 el avance se asume en mm/min, grados/min o inch/min. • Con G95 el avance se asume en mm/rev, grados/rev o inch/rev." ;
    ns1:valor "G94" .

ns1:Parametro_IMOVE a ns1:Parametro ;
    rdfs:label "IMOVE",
        "IMOVE (tipo de movimiento por defecto)"@es ;
    ns1:documentadoEn ns1:Pagina_126,
        ns1:Tabla_PlanosTrabajo_205 ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No.",
        """\r
IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01.\r
Este parámetro indica el tipo de movimiento, G0 o G1, que asume el CNC por defecto (en el arranque, tras un reset o M30).\r
"""@es ;
    ns1:valor "G0/G1",
        "G01"^^xsd:string .

ns1:Parametro_IMOVEMACH a ns1:Parametro ;
