    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA1··TDATA12 Dimensiones del cabezal."@es .

ns1:Parametro_TDATA31 a ns1:Parametro ;
    rdfs:label "TDATA31 (cinemática tipo 52)"@es,
        "TDATA31 (sistema de coordenadas pieza: 0=paralelo a máquina, 1=gira con pieza)"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicaVectorial_Tipo52,
        ns1:Tabla_Cinematica_52 ;
    ns1:identificador "TDATA31" ;
    ns1:monitoreaParametro ns1:Sistema_CinematicaMesa_Tipo51 ;
    ns1:textoExtracto "TDATA31 | -TDATA4",
        "TDATA31 | -TDATA4"@es,
        "TDATA31, TDATA 31(+)"@es,
        "TDATA31=0/1 [...] si el sistema gira con la pieza o permanece paralelo al de máquina"@es ;
    ns1:valor "-TDATA4",
        "0"^^xsd:string,
        "1"^^xsd:string .

