        ns1:Parametro_VGPATHFEED ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición. Incluye sumadores/compensadores (COMP, DELTA), consignas (POSCMD, FTEO), señales de retroalimentación (POSNC), y rutas para salidas analógicas y buses (Sercos Vel./Pos.)."@es ;
    ns1:tieneComponente ns1:Componente_COMP,
        ns1:Componente_DELTA,
        ns1:Componente_FILTER,
        ns1:Componente_INTERPOLATOR,
