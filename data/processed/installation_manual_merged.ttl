    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "0" ;
    ns1:textoExtracto "No hay que hacer nada."@es .

ns1:ModoOperacion_TM1 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=1 (Brazo → Cabezal)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "1" ;
