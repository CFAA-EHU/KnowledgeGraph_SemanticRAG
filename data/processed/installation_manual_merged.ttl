        ns1:param_TCOMPLIM_62,
        ns1:param_TINTIME_62,
        ns1:param_TORQMODE_62,
        ns1:param_TPROGAIN_62 .

ns1:marca_XFERINH a ns1:Parametro ;
    rdfs:label "Marca _XFERINH" ;
    ns1:identificador "_XFERINH" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes: _XFERINH (también se puede programar como _XFERINHC1)." .

ns1:modcomp_289 a ns1:Parametro ;
    rdfs:label "MODCOMP (Compensación de módulo)" ;
    ns1:identificador "V.[ch].MPA.MODCOMP.xn" ;
    ns1:monitoreaParametro ns1:moder_289,
        ns1:modnrot_289 ;
    ns1:textoExtracto "MODCOMP Compensación de módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No (sin compensación)." ;
    ns1:valor "Sí / No" .

ns1:modo_CaptacionAbsolutaTotal a ns1:ModoOperacion ;
    rdfs:label "Captación absoluta total" ;
    ns1:monitoreaParametro ns1:parametro_ABSFEEDBACK,
        ns1:se_al_REFPOIN_axis ;
    ns1:textoExtracto "Captación absoluta total (parámetro ABSFEEDBACK=Sí). La marca REFPOIN(axis) siempre está activa (=1). No es necesaria la búsqueda de referencia." .

ns1:modo_CaptacionAbsolutaUnaVuelta a ns1:ModoOperacion ;
    rdfs:label "Captación absoluta en una vuelta" ;
    ns1:monitoreaParametro ns1:se_al_REFPOIN_axis ;
    ns1:textoExtracto "Captación absoluta en una vuelta. El CNC activa (=1) la marca REFPOIN(axis) en el arranque si en la" .

ns1:modo_edicion_simulacion a ns1:ModoOperacion ;
    rdfs:label "Edición-Simulación" ;
    ns1:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ns1:movimiento_eje_independiente a ns1:ModoOperacion ;
    rdfs:label "Movimiento de eje independiente" ;
    ns1:textoExtracto "Esta marca siempre afecta a los movimientos de eje independiente programados desde el CNC; los programados desde el PLC dependen del parámetro XFITOIND." .

ns1:movimiento_jog a ns1:ModoOperacion ;
    rdfs:label "Movimiento en jog" ;
    ns1:textoExtracto "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto." .

ns1:param_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" .

ns1:param_PITCH a ns1:Parametro ;
    rdfs:label "PITCH" ;
    ns1:identificador "PITCH" ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" .

ns1:param_SINMAGNI a ns1:Parametro ;
    rdfs:label "SINMAGNI" ;
    ns1:identificador "SINMAGNI" ;
    ns1:textoExtracto "SINMAGNI Factor de multiplicación para la señal de captación senoidal. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ns1:valor "0-255" .

ns1:parametro_XFITOIND a ns1:Parametro ;
    rdfs:label "Parámetro XFITOIND" ;
    ns1:identificador "XFITOIND" ;
    ns1:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND." .

ns1:proceso_correccion_cota a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de diferencia de cota (ejes gantry)" ;
    ns1:habilitadoPor ns1:marca_REFPOIN ;
    ns1:monitoreaParametro ns1:marca_DIFFCOMP,
        ns1:marca_SERVOON ;
    ns1:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo..." .

ns1:se_al_AUXEND a ns1:Parametro ;
    rdfs:label "AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "Se denomina AUXEND a la señal de sincronización que el PLC envía al CNC indicando que ha terminado la ejecución de las funciones auxiliares –M–, –S–, –T–." .

ns1:se_al_ENABLE_axis a ns1:Parametro ;
    rdfs:label "ENABLE(axis)" ;
    ns1:textoExtracto "la señal ENABLE(axis) se mantiene a (=1)" ;
    ns1:valor "1" .

ns1:se_al_FEEDHOLD a ns1:Parametro ;
    rdfs:label "FEEDHOLD" ;
    ns1:textoExtracto "marca _FEEDHOL=0" ;
    ns1:valor "0" .

ns1:se_al_HSTROBE a ns1:Parametro ;
    rdfs:label "HSTROBE" ;
    ns1:identificador "HSTROBE" ;
    ns1:textoExtracto "Para las funciones –H– (que no necesitan sincronización) este parámetro [MINAENDW] indica la duración de la señal HSTROBE." .

ns1:se_al_MSTROBE a ns1:Parametro ;
    rdfs:label "MSTROBE" ;
    ns1:identificador "MSTROBE" ;
    ns1:textoExtracto "Para las funciones –M– que no necesitan sincronización, este parámetro [MINAENDW] indica la duración de la señal MSTROBE." .

ns1:se_al_STOP a ns1:InterfazUsuario ;
    rdfs:label "Señal _STOP" ;
    ns1:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

ns1:tarea_lubricacion_ejes a ns1:TareaMantenimiento ;
    rdfs:label "Lubricación de ejes" ;
    ns1:controla ns1:se_al_LUBR,
        ns1:se_al_LUBRENA,
        ns1:se_al_LUBROK ;
    ns1:requiereMantenimiento ns1:parametro_DISTLUBRI ;
    ns1:textoExtracto "Para que el PLC efectúe la lubricación de ejes y engranajes se deben utilizar las entradas y salidas lógicas del CNC LUBR(axis), LUBRENA(axis) y LUBROK(axis)." .

ns1:tecla_STOP_CNC a ns1:InterfazUsuario ;
    rdfs:label "Tecla [STOP] del CNC" ;
    ns1:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC." .

ns1:variable_MPA_DISTLUBRI a ns1:Parametro ;
    rdfs:label "MPA.DISTLUBRI[set].xn" ;
    ns1:identificador "MPA.DISTLUBRI[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DISTLUBRI[set].xn" .

ns1:volcomp_111 a ns1:Parametro ;
    rdfs:label "VOLCOMP (Tablas de compensación volumétrica)"@es ;
    ns1:identificador "VOLCOMP" ;
    ns1:monitoreaParametro ns1:tabla_volcomp_config_111 ;
    ns1:textoExtracto "VOLCOMP Tablas de compensación volumétrica. Este parámetro muestra las tablas de compensación volumétrica. Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)."@es .

ns1:ACCELG0 a ns1:Parametro ;
    rdfs:label "ACCELG0 (Aceleración trapezoidal en G0)" ;
    ns1:identificador "ACCELG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Aceleración: ACCELG0" .

ns1:ACCJERKG0 a ns1:Parametro ;
    rdfs:label "ACCJERKG0 (Jerk de aceleración en G0)" ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de aceleración: ACCJERKG0" .

ns1:ACForward_264 a ns1:Parametro ;
    rdfs:label "AC-Forward" ;
    ns1:textoExtracto "El [...] AC-Forward lo aplica el CNC."@es .

ns1:ADVCUTOFF a ns1:Parametro ;
    rdfs:label "ADVCUTOFF" ;
    ns1:identificador "ADVCUTOFF" ;
    ns1:textoExtracto "ADVCUTOFF [...] El CNC activa esta marca (cambio de 0 a 1) durante la ejecución de microjoints, cuando el láser alcanza la distancia G.ADVCUTOFFW o el tiempo G.ADVCUTOFFT antes del #CUTTING OFF." .

ns1:AccionApagadoEquipo a ns1:AccionProhibida ;
    rdfs:label "Apagado obligatorio del equipo por sobretemperatura" ;
    ns1:textoExtracto "Apagar el equipo para evitar" .

ns1:AccionDetencionCabezal a ns1:AccionProhibida ;
    rdfs:label "Detención del cabezal por desajuste de parámetros"@es ;
    ns1:textoExtracto "definir las acciones a realizar cuando ambos set de parámetros no coincidan, como detener el cabezal o la ejecución del programa pieza."@es .

ns1:AccionGuardarProyecto_1363 a ns1:AccionProhibida ;
    rdfs:label "Guardar proyecto"@es ;
    ns1:identificador "*.ecsn" ;
    ns1:textoExtracto "El proyecto se puede guardar aunque no esté finalizado. En una sesión posterior, se puede recuperar la configuración guardada y continuar a partir de ese punto. Para guardar el proyecto, seleccionar la opción File > Save. Guardar el proyecto con cualquier nombre (extensión *.ecsn)."@es .

ns1:Accion_CNCRD a ns1:AccionProhibida ;
    rdfs:label "CNCRD (Lectura de variables CNC)" ;
    ns1:identificador "CNCRD" ;
    ns1:textoExtracto "CNCRD [...] Permiten la lectura (CNCRD) de las variables internas del CNC, siendo su formato de programación: CNCRD (Variable, Registro, Marca)" .

ns1:Accion_CNCWR a ns1:AccionProhibida ;
    rdfs:label "CNCWR (Escritura de variables CNC)" ;
    ns1:identificador "CNCWR" ;
    ns1:textoExtracto "CNCWR [...] Permiten la escritura (CNCWR) de las variables internas del CNC, siendo su formato de programación: CNCWR (Registro, Variable, Marca)" .

ns1:Accion_DesactivarDMC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar DMC"@es ;
    ns1:textoExtracto "desactivar DMC"@es .

ns1:Accion_GuardarProyecto_1377 a ns1:AccionProhibida ;
    rdfs:label "Guardar proyecto (incompleto)"@es ;
    ns1:identificador "Generate project"@es ;
    ns1:textoExtracto "El proyecto se puede guardar aunque no esté finalizado. En una sesión posterior, se puede recuperar la configuración guardada y continuar a partir de ese punto."@es .

ns1:Accion_ModificacionSoftwareCNC a ns1:AccionProhibida ;
    rdfs:label "Modificación no autorizada del software CNC" ;
    ns1:textoExtracto "No se debe reinstalar ni modificar el software del CNC sin consentimiento expreso de Fagor Automation." .

ns1:Accion_ReactivarDMC a ns1:TareaMantenimiento ;
    rdfs:label "Re-activar DMC"@es ;
    ns1:textoExtracto "re-activar DMC"@es .

ns1:Accion_RepetirAprendizaje a ns1:TareaMantenimiento ;
    rdfs:label "Repetir fase de aprendizaje (DMC)"@es ;
    ns1:textoExtracto "repetir fase de aprendizaje"@es .

ns1:Accion_Reset_Canal1 a ns1:AccionProhibida ;
    rdfs:label "Reset canal 1" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Accion_Reset_Canal2 a ns1:AccionProhibida ;
    rdfs:label "Reset canal 2" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Accion_Reset_Canal3 a ns1:AccionProhibida ;
    rdfs:label "Reset canal 3" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Accion_Reset_Canal4 a ns1:AccionProhibida ;
    rdfs:label "Reset canal 4" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Actuador_SalidaAnalogica a ns1:Actuador ;
    rdfs:label "Salida analógica [n]"@es ;
    ns1:textoExtracto "Tensión en voltios de la salida [n]."@es .

ns1:AlarmaAntiembalamiento a ns1:Alarma ;
    rdfs:label "Alarma de protección antiembalamiento" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "protección antiembalamiento" .

ns1:AlarmaCaptacionLocal1 a ns1:Alarma ;
    rdfs:label "Alarma de captación de entrada local 1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente. Si el PLC desactiva una de estas marcas (cambio de 1 a 0), habilita las alarmas de captación." .

ns1:AlarmaCaptacionLocal2 a ns1:Alarma ;
    rdfs:label "Alarma de captación de entrada local 2" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente. Si el PLC desactiva una de estas marcas (cambio de 1 a 0), habilita las alarmas de captación." .

ns1:AlarmaSubrutinaFaltante a ns1:Alarma ;
    rdfs:label "Alarma por subrutina no definida" ;
    ns1:textoExtracto "mostrará un error cada vez que se intente ejecutar un programa pieza"@es .

ns1:Alarma_Captacion a ns1:Alarma ;
    rdfs:label "Alarma de captación" ;
    ns1:textoExtracto "Esta alarma pretende discernir la desconexión o ruptura de alguno de los cables de la captación para señales tanto TTL diferenciales como senoidales. Cuando se produce una alarma de captación, el PLC desactiva la marca REFPOIN." .

ns1:Alarma_CicloPalpador a ns1:Alarma ;
    rdfs:label "Alarma de error en ciclo de palpador" ;
    ns1:textoExtracto "de un ciclo de palpador (o incluso fuera de éste), detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel '0')." .

ns1:Alarma_EntradaCaptacion1_1260 a ns1:Alarma ;
    rdfs:label "Alarma de entrada de captación 1 (IDN Sercos 33348)"@es ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "33348" ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1."@es .

ns1:Alarma_EntradaCaptacion2_1260 a ns1:Alarma ;
    rdfs:label "Alarma de entrada de captación 2 (IDN Sercos 33349)"@es ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "33349" ;
    ns1:textoExtracto "IDN Sercos 33349 para la entrada de captación 2."@es .

ns1:Alarma_EntradaCaptacion3_1260 a ns1:Alarma ;
    rdfs:label "Alarma de entrada de captación 3 (IDN Sercos 33350)"@es ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "33350" ;
    ns1:textoExtracto "IDN Sercos 33350 para la entrada de captación 3."@es .

ns1:Alarma_EntradaCaptacion4_1260 a ns1:Alarma ;
    rdfs:label "Alarma de entrada de captación 4 (IDN Sercos 33351)"@es ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "33351" ;
    ns1:textoExtracto "IDN Sercos 33351 para la entrada de captación 4."@es .

ns1:Alarma_ErrorPLC a ns1:Alarma ;
    rdfs:label "Alarma de error de PLC con código ERR"@es ;
    ns1:activaAlarma ns1:InterfazUsuario_VisualizacionErroresPLC ;
    ns1:textoExtracto "Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado."@es .

ns1:Alarma_Hardware_Captacion a ns1:Alarma ;
    rdfs:label "Alarma hardware de captación local" ;
    ns1:textoExtracto "Alarma hardware (pin de alarma) de la captación local. Parámetro válido en los siguientes casos: Ejes y cabezales analógicos con contajes locales. Ejes y cabezales Sercos velocidad con captación externa con contajes locales." .

ns1:Alarma_ProteccionAntiembalamiento a ns1:Alarma ;
    rdfs:label "Alarma de protección antiembalamiento"@es ;
    ns1:habilitadoPor ns1:Parametro_TENDENCY ;
    ns1:textoExtracto "Protección frente al embalamiento. [...] Si se desactiva esta alarma, el CNC muestra en el encendido un mensaje indicando que dicha seguridad está deshabilitada."@es .

ns1:AlmacenHerramientasTorreta a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas tipo torreta" ;
    ns1:textoExtracto "En un almacén tipo torreta, se recomienda que la rutina asociada a T incluya la función M06." .

ns1:AlmacenHerramientas_7_11_2 a ns1:Sistema ;
    rdfs:label "Almacén de herramientas del cabezal y brazo"@es ;
    ns1:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén."@es ;
    ns1:tieneComponente ns1:Herramienta_Brazo,
        ns1:Herramienta_Cabezal .

ns1:AlmacenHerramientas_Random a ns1:Sistema ;
    rdfs:label "Almacén de herramientas (tipo random)" ;
    ns1:textoExtracto "almacén es random y la herramienta es especial" .

ns1:Almacen_Generico a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas (genérico)"@es ;
    ns1:identificador "1-4"^^xsd:string ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro almacenes y cada uno de ellos podrá ser de un tipo diferente. Cada almacén tiene sus propios parámetros de configuración [...] Un almacén no está asociado a ningún canal ni cabezal en particular; es decir, un almacén podrá ser compartido por varios canales."@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaCambioParalelo .

ns1:Almacen_Herramientas a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es .

ns1:Almacenamiento_CompactFlash a ns1:ComponenteElectrico ;
    rdfs:label "Compact Flash"@es ;
    ns1:identificador "Compact Flash" ;
    ns1:textoExtracto "El CNC que usted ha adquirido puede disponer de compact flash únicamente o de compact flash más disco duro. Para instalar cualquier software, el CNC debe disponer de espacio suficiente en la compact flash."@es .

ns1:Almacenamiento_DiscoDuro a ns1:ComponenteElectrico ;
    rdfs:label "Disco duro"@es ;
    ns1:identificador "Disco duro" ;
    ns1:textoExtracto "El CNC que usted ha adquirido puede disponer de compact flash únicamente o de compact flash más disco duro."@es .

ns1:ArchivoBAT_CNC8070L a ns1:Componente ;
    rdfs:label "Archivo BAT (ej. CNC8070L.bat)"@es ;
    ns1:identificador "CNC8070L.bat" ;
    ns1:textoExtracto "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat). En este archivo bat, añadir la línea 'start c:\\Lantek\\Expert\\Expert.exe'."@es .

ns1:ArchivoCompensacionCSV a ns1:Tabla ;
    rdfs:label "Archivo de compensación volumétrica (CSV)" ;
    ns1:identificador "fichero CSV de compensación" ;
    ns1:textoExtracto "Si el CNC tiene activa la compensación volumétrica media o grande (opción de software), también permitirá definir una compensación volumétrica básica si el fichero tiene extensión csv." .

ns1:ArchivoConfig_AppsINI a ns1:Componente ;
    rdfs:label "Archivo Apps.ini (configuración Lantek)"@es ;
    ns1:identificador "Apps.ini" ;
    ns1:textoExtracto "En el archivo ..\\MTB\\MMC\\Config\\Apps.ini añadir la línea 'Lantek=c:\\Lantek\\Expert\\Expert.exe'."@es .

ns1:ArchivoConfiguracionXCA_1349 a ns1:Parametro ;
    rdfs:label "Archivo de configuración máquina (xca) para ejes rotativos"@es ;
    ns1:detalladoEnEsquema ns1:ConfiguracionEjesRotativos_1349 ;
    ns1:identificador "xca" ;
    ns1:textoExtracto "archivo xca [...] están los archivos de configuración para máquinas con plato divisor"@es ;
    ns1:valor "../Fagor/Grafdata/Machines/Mill" .

ns1:ArchivoENI_1372 a ns1:InterfazUsuario ;
    rdfs:label "Archivo ENI (configuración)"@es ;
    ns1:identificador "ENI" ;
    ns1:textoExtracto "Cargar el archivo ENI creado con el configurador."@es .

ns1:Archivo_plc_pdef_h a ns1:InterfazUsuario ;
    rdfs:label "Archivo de cabecera plc_pdef.h con definiciones de símbolos PLC" ;
    ns1:documentadoEn ns1:Directiva_PDEF ;
    ns1:identificador "plc_pdef.h" ;
    ns1:textoExtracto "genera el archivo plc_pdef.h con los #define de todos los símbolos definidos en el programa PLC. El archivo se guarda en la carpeta ..\\MTB\\PLC\\Project." .

ns1:ArchivosAyudaCNC a ns1:Componente ;
    rdfs:label "Archivos de ayuda del CNC" ;
    ns1:documentadoEn ns1:SetupHelp_Vxx_xx_exe ;
    ns1:textoExtracto "Fagor entrega el CNC con los archivos de ayuda instalados en inglés." .

ns1:AtajoTeclado_ALTF4 a ns1:Componente ;
    rdfs:label "[ALT]+[F4]"@es ;
    ns1:identificador "ALT+F4" ;
    ns1:textoExtracto "Apagar el CNC."@es .

ns1:AtajoTeclado_ALTS a ns1:Componente ;
    rdfs:label "[ALT]+[S]"@es ;
    ns1:identificador "ALT+S" ;
    ns1:textoExtracto "Ventana de sincronización de canales."@es .

ns1:AtajoTeclado_ALTW a ns1:Componente ;
    rdfs:label "[ALT]+[W]"@es ;
    ns1:identificador "ALT+W" ;
    ns1:textoExtracto "Mostrar / ocultar la ventana de errores y warnings."@es .

ns1:AtajoTeclado_CTRLO a ns1:Componente ;
    rdfs:label "[CTRL]+[O]"@es ;
    ns1:identificador "CTRL+O" ;
    ns1:textoExtracto "Minimizar/Maximizar el CNC."@es .

ns1:AtajoTeclado_CTRLW a ns1:Componente ;
    rdfs:label "[CTRL]+[W]"@es ;
    ns1:identificador "CTRL+W" ;
    ns1:textoExtracto "Apagar el CNC."@es .

ns1:AvanceMecanizado a ns1:ModoOperacion ;
    rdfs:label "Avance de mecanizado" ;
    ns1:textoExtracto "Máximo avance de mecanizado del eje." .

ns1:AvanceMecanizado_1251 a ns1:Parametro ;
    rdfs:label "Avance de mecanizado" ;
    ns1:textoExtracto "El avance se controla mediante el conmutador del panel de mando." ;
    ns1:valor "Controlado por conmutador o volante de avance"@es .

ns1:Aviso3103_1338 a ns1:AvisoSeguridad ;
    ns1:identificador "3103" ;
    ns1:textoExtracto "muestra el aviso 3103"@es .

ns1:AvisoColision_3101_1339 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3101 (Colisión detectada)"@es ;
    ns1:identificador "3101" ;
    ns1:textoExtracto "Si la potencia instantánea supera la potencia objetivo en un rango prefijado, el CNC considera que ha habido un colisión. En este caso, el CNC muestra el aviso 3101, detiene el avance de los ejes manteniendo el giro del cabezal."@es .

ns1:AvisoHerramientaDesgastada_3100_1339 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3100 (Herramienta desgastada)"@es ;
    ns1:identificador "3100" ;
    ns1:textoExtracto "Si el DMC detecta un consumo de potencia excesivo durante cierto tiempo, considera que la herramienta está desgastada o deteriorada y muestra el aviso 3100 sin detener la ejecución."@es .

ns1:AvisoModoNoSeguro a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modo no seguro",
        "Aviso de palpador en modo no seguro",
        "Aviso de palpador en modo no seguro"@es ;
    ns1:mitigaRiesgo ns1:ModoSeguroPalpador,
        ns1:ModoSetup ;
    ns1:textoExtracto "En el arranque de la aplicación aparecerá un aviso indicando que se está trabajando en un modo no seguro.",
        "para avisar, si están desactivadas, que el palpador está en modo no seguro.",
        "para avisar, si están desactivadas, que el palpador está en modo no seguro"@es .

ns1:AvisoSeguridad_ControlColisiones a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de control de colisiones" ;
    ns1:textoExtracto "Si el PLC activa esta marca (cambio de 0 a 1), desactiva la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ns1:AvisoSeguridad_DMCPWRPEAK a ns1:AvisoSeguridad ;
    rdfs:label "Warning por pico de potencia (DMCPWRPEAK)"@es ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "el CNC muestra un warning, detiene los ejes manteniendo el giro de cabezal y activa la marca DMCPWRPEAK."@es .

ns1:AvisoSeguridad_Error3753 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753 (Diferencia de referencia)" ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "Si MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753. Con este error, el usuario decide la validez de la cota. • Si la posición de la máquina coincide con el campo 'Valor actual' del error, la cota es válida. [...] • Si la posición de la máquina coincide con el campo 'Valor esperado', la cota no es válida." .

ns1:AvisoSeguridad_InhibicionTeclas a ns1:AvisoSeguridad ;
    rdfs:label "Comportamiento del CNC al inhibir teclas de feed override/speed override" ;
    ns1:textoExtracto "En caso de seleccionar una de las posiciones inhibidas del feed override, el CNC tomará el valor de la posición inferior permitida. Si se inhiben todas, se tomará 0 %. [...] Si se inhiben todas las posiciones, el CNC mantiene el valor activo." .

ns1:AvisoSeguridad_LimiteSoftwareExcedido a ns1:AvisoSeguridad ;
    rdfs:label "Límite de software excedido" ;
    ns1:textoExtracto "facilita llevar la herramienta de nuevo a una zona permitida, en caso de que ésta haya superado los límites de software o haya invadido una zona prohibida" .

ns1:AvisoSeguridad_RupturaPalpador_01 a ns1:AvisoSeguridad ;
    rdfs:label "Riesgo de ruptura del palpador por falta de activación"@es ;
    ns1:textoExtracto "Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:AvisoSeguridad_Solapamiento_I33 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de solapamiento en entrada I33"@es ;
    ns1:identificador "I33" ;
    ns1:textoExtracto "se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento"@es .

ns1:AvisoSeguridad_WarningPotenciaDMC a ns1:AvisoSeguridad ;
    rdfs:label "Warning de potencia en DMC" ;
    ns1:textoExtracto "el CNC muestra un warning, detiene los ejes manteniendo el giro de cabezal y activa la marca DMCPWRPEAK" .

ns1:AvisoVolanteActivo a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje de volante de avance activo" ;
    ns1:textoExtracto "Si está activo el volante de avance, mostrar un mensaje." .

ns1:Aviso_W169 a ns1:AvisoSeguridad ;
    rdfs:label "Warning W169 (sobretemperatura)" ;
    ns1:identificador "W169" ;
    ns1:textoExtracto "El CNC activa esta marca y muestra el warning W169 avisando de esta circunstancia [temperatura > 60 ºC]." .

ns1:BACKUPSDIR a ns1:Componente ;
    rdfs:label "BACKUPSDIR" ;
    ns1:textoExtracto "Backup de las instalaciones previas. Cada vez que el usuario instala una versión nueva completa, el instalador guarda en esta carpeta una copia de la instalación anterior." .

ns1:BLKSEARCH a ns1:Parametro ;
    rdfs:label "BLKSEARCH" ;
    ns1:identificador "BLKSEARCH" ;
    ns1:textoExtracto "BLKSEARCH. Hay una marca para cada canal." .

ns1:BarraConfiguracion_1368_B a ns1:Componente ;
    rdfs:label "Barra de configuración por defecto"@es ;
    ns1:textoExtracto "B. Barra de configuración por defecto para el mapeo de recursos."@es .

ns1:BarraEstadoGeneral a ns1:InterfazUsuario ;
    rdfs:label "Barra general de estado"@es ;
    ns1:textoExtracto "El CNC muestra en la barra general de estado el nombre de la subrutina"@es .

ns1:BarraIconos_1368_A a ns1:Componente ;
    rdfs:label "Barra de iconos y nombre del archivo ENI"@es ;
    ns1:textoExtracto "A. Barra de iconos y nombre del archivo ENI cargado."@es .

ns1:Bloque_24DI_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 24 DI (RIOW, I104)" ;
    ns1:identificador "I104" ;
    ns1:textoExtracto "dos bloques (24 [...] entradas) iniciados en direcciones altas (I104)" .

ns1:Bloque_40DI_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 40 DI (RIOW, I200)" ;
    ns1:identificador "I200" ;
    ns1:textoExtracto "dos bloques ([...] 40 entradas) iniciados en [...] (I200)" .

ns1:Bloque_48DI_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 48 DI (Nodo RIOR, I97)" ;
    ns1:identificador "I97" ;
    ns1:textoExtracto "bloque de 48 entradas [...] con inicio en I97" .

ns1:BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN" ;
    ns1:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. Desde el punto de vista del bus CAN, el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema" ;
    ns1:tieneComponente ns1:ModuloPRG_PLC .

ns1:BusCAN_CNC a ns1:Sistema ;
    rdfs:label "Bus CAN del CNC"@es ;
    ns1:compuestoPor ns1:NodosRemotos_BusCAN ;
    ns1:textoExtracto "Actualización de los nodos remotos del bus CAN. En cada arranque del CNC se verifica la compatibilidad de las versiones de los nodos remotos detectados en el bus CAN"@es .

ns1:BusquedaCero_264 a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de cero" ;
    ns1:controla ns1:CNC_264 ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC. La búsqueda de cero se realiza sin parar el cabezal, si previamente se encontraba girando."@es .

ns1:BusquedaReferenciaEjes a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia máquina (ejes y cabezales)"@es ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "Si alguno de los ejes del grupo programado no dispone de micro, el eje espera a que los demás lleguen a sus micros, y una vez ocurrido esto, buscará su I0 al avance REFFEED2 dentro del orden que le toque. Si ninguno de los ejes del grupo programado dispone de micro, se empieza directamente a buscar cero a REFFEED2 con el eje de menor número lógico y una vez acabado éste se sigue con los demás."@es .

ns1:BusquedaReferenciaM_quina a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:ejecutadoPor ns1:Personal_OperadorCNC ;
    ns1:requiereMantenimiento ns1:SistemaCNC ;
    ns1:textoExtracto "La búsqueda de referencia es la operación mediante la cual se realiza la sincronización del sistema. Esta operación es necesaria cuando el CNC pierde la posición del origen (por ejemplo, apagando la máquina)."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_BusquedaReferencia .

ns1:BusquedaReferencia_EjeX a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina del eje X" ;
    ns1:textoExtracto "El CNC realiza una búsqueda de referencia máquina del eje X." .

ns1:CH1TOSPDL a ns1:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "CH1TOSPDL Hay una marca para cada almacén. [...] El PLC debe poner" .

ns1:CH1TOSPDLMZ1 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ns1:identificador "CH1TOSPDLMZ1" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" .

ns1:CH1TOSPDLMZ2 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ2" ;
    ns1:identificador "CH1TOSPDLMZ2" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "CH1TOSPDLMZ2" .

ns1:CH1TOSPDLMZ3 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ3" ;
    ns1:identificador "CH1TOSPDLMZ3" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "CH1TOSPDLMZ3" .

ns1:CH1TOSPDLMZ4 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ4" ;
    ns1:identificador "CH1TOSPDLMZ4" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "CH1TOSPDLMZ4" .

ns1:CNC_264 a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:monitoreaParametro ns1:ACForward_264,
        ns1:CompensacionHolgura_264,
        ns1:ErrorSeguimiento_264,
        ns1:FeedForward_264 ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC. [...] El error de seguimiento y la compensación de holgura se calculan en el CNC. El feed forward y AC-Forward lo aplica el CNC."@es .

ns1:CNC_Address0 a ns1:InterfazUsuario ;
    rdfs:label "CNC (Address=0)" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "iconos del CNC (Address=0)" .

ns1:CNC_ControlVelocidad a ns1:Sistema ;
    rdfs:label "Sistema de control de velocidad del CNC"@es ;
    ns1:monitoreaParametro ns1:SLIMITACSPDL,
        ns1:SLIMITACSPDL2,
        ns1:SLIMITACSPDL3,
        ns1:SLIMITACSPDL4,
        ns1:SLIMITACSPDL5,
        ns1:SLIMITACSPDL6 ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado"@es .

ns1:CNC_FagorAutomation a ns1:Maquina ;
    rdfs:label "CNC (Fagor Automation)"@es ;
    ns1:textoExtracto "Actualización del software. Para actualizar el software, cerrar todos los programas que estén en marcha, incluido el CNC. [...] Al comenzar el proceso, el CNC ofrece la posibilidad de realizar la instalación partiendo de cero"@es ;
    ns1:tieneComponente ns1:BusCAN_CNC,
        ns1:InterfazUSB_CNC,
        ns1:NodosRemotos_BusCAN .

ns1:CNC_GamasTrabajo a ns1:Sistema ;
    rdfs:label "CNC (gestión de gamas de trabajo)" ;
    ns1:controla ns1:Parametro_SetGamas ;
    ns1:textoExtracto "el CNC pone la gama que indica el PLC; si no indica ninguna, el CNC arranca sin gama. Tras un reset, el CNC pone la gama que indica el PLC; si no indica ninguna, el CNC se queda como está" .

ns1:CNC_Leapfrog a ns1:Sistema ;
    rdfs:label "CNC Leapfrog" ;
    ns1:identificador "v6.20" ;
    ns1:textoExtracto "Leapfrog. A partir de la versión v6.20" .

ns1:CNC_ModoSETUP a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP (puesta a punto, CNC)"@es ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea fst se cargan en la memoria RAM durante la preparación de bloques."@es .

ns1:CNC_ModoUSER a ns1:ModoOperacion ;
    rdfs:label "Modo USER (CNC)"@es ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es .

ns1:CNC_PanelMando1 a ns1:InterfazUsuario ;
    rdfs:label "CNC (Primer panel de mando del sistema)"@es ;
    ns1:identificador "CNC" ;
    ns1:textoExtracto "CNC | Primer panel de mando del sistema."@es .

ns1:CNC_Q7_A_Master a ns1:ComponenteElectrico ;
    rdfs:label "CNC (master del bus EtherCAT)"@es ;
    ns1:controla ns1:BusEtherCAT_Q7_A,
        ns1:NodosEtherCAT_Q7_A ;
    ns1:textoExtracto "El CNC es el elemento máster del bus, y el resto de recursos estará repartido por nodos (hasta 32)."@es .

ns1:CNC_SistemaControl a ns1:Sistema ;
    rdfs:label "CNC (Sistema de control numérico)",
        "Sistema CNC" ;
    ns1:controla ns1:Cabezal_Generico,
        ns1:LimiteSoftwareEje ;
    ns1:mitigaRiesgo ns1:ZonaProhibidaEje ;
    ns1:monitoreaParametro ns1:Parametro_AUTOGEAR ;
    ns1:textoExtracto "el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente. Tras finalizar la sincronización de la función M en el PLC (señal AUXEND), el CNC comienza a enviar consigna a dicho cabezal",
        "el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado. El CNC aplica siempre los límites de recorrido" .

ns1:COMPID a ns1:Parametro ;
    rdfs:label "COMPID" ;
    ns1:identificador "COMPID" ;
    ns1:textoExtracto "parámetro COMPID [...] Cada cinemática tiene una compensación asociada" .

ns1:CONFIGURATION a ns1:Componente ;
    rdfs:label "CONFIGURATION" ;
    ns1:textoExtracto "Carpetas MTB del sistema. Esta carpeta contiene las diferentes carpetas MTB del sistema; MTB_T para el torno y MTB_M para fresadora. En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente de CONFIGURATION a MTB." .

ns1:CabezalAngular_TYPE6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular TYPE=6" ;
    ns1:identificador "TYPE=6" ;
    ns1:textoExtracto "Dimensiones a calcular en un cabezal angular YZ (TYPE=6)." ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7 .

ns1:CabezalCNC_Generico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal CNC" ;
    ns1:textoExtracto "Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales." .

ns1:CabezalHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramienta"@es ;
    ns1:textoExtracto """\r
LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.\r
LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."""@es .

ns1:CabezalHerramientas_7.5 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramientas"@es ;
    ns1:textoExtracto "La carga del almacén se hace llevando las herramientas, una a una, desde tierra al almacén pasando por el cabezal."@es,
        "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén."@es .

ns1:CabezalLogico_4_86 a ns1:Componente ;
    rdfs:label "Cabezal lógico 4" ;
