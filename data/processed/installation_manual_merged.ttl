    rdfs:label "Configuración geométrica (GEOCONFIG)"@es ;
    ns1:textoExtracto "GEOCONFIG = Plano"@es ;
    ns1:valor "Plano" .

ns1:ConfiguracionGraficosEjesRotativos_19_1 a ns1:InterfazUsuario ;
