    ns1:monitoreaParametro ns1:Sensor_9107246f20 ;
    ns1:textoExtracto "Cambiar el signo de la señal del sensor. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_1b084b7e72 a ns1:Parametro ;
    rdfs:label "G0MODAL" ;
    ns1:textoExtracto "Aunque la función G0 esté definida como no-modal, con IMOVE=G0 el CNC asume la función G0 en el arranque, tras un reset o M30." ;
    ns1:valor "No" .

ns1:Parametro_1c1e2e6bc7 a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:textoExtracto "en el parámetro COUNTERID hay que indicar cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador." .

