ns1:Parametro_PRESSURE a ns1:Parametro ;
    rdfs:label "Unidades de presión" ;
    ns1:identificador "V.MPG.PRESSURE" ;
    ns1:textoExtracto "PRESSURE Unidades de presión por defecto. Valores posibles: Bar / Psi. Valor por defecto: Bar. Variable asociada: (V.)MPG.PRESSURE Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset." ;
    ns1:valor "Bar" .

ns1:Parametro_PROBEDELAY a ns1:Parametro ;
    rdfs:label "PROBEDELAY",
        "PROBEDELAY (Retardo de señal del palpador 1)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:monitoreaParametro ns1:Sensor_Palpador1,
        ns1:Sistema_CNC ;
    ns1:textoExtracto "PROBEDELAY Retardo de la señal de palpador 1. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo).",
        "Retardo de la señal de palpador. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo). Variable asociada: (V.)[ch].MPA.PROBEDELAY.xn",
        "PROBEDELAY | Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es ;
    ns1:valor "0" .

