ns1:Esquema_Solucion_TDATA5 a ns1:Esquema ;
    rdfs:label "Esquema de solución para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_95137c6bdd ;
    ns1:textoExtracto "Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|; la figura asocia gráficamente la variación de lectura con el desfase geométrico del eje herramienta."@es .

ns1:Esquema_TDATA2 a ns1:Esquema ;
    rdfs:label "Diagramas para TDATA2 (posiciones de referencia)"@es ;
    ns1:ilustradoEn ns1:Parametro_0c1f628ac1 ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3). Se representan los palpados, las lecturas ΔX y la combinación con TDATA5 para calcular TDATA2, con flechas de giro y ejes X-Z."@es .

ns1:Esquema_TDATA5 a ns1:Esquema ;
    rdfs:label "Esquema 'Segundo contacto' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_95137c6bdd ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX. El gráfico indica la obtención de TDATA5 = 0,5·|ΔX| mediante cotas sobre el eje X."@es .

ns1:Esquema_TDATA6_1y2 a ns1:Esquema ;
    rdfs:label "Secuencia 'Primer y segundo contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_12a35f6dff ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2). Se muestran lecturas Xa y la preselección para centrar X=0 en el eje del cilindro. Flechas indican los giros del eje B y los desplazamientos en X."@es .

ns1:Esquema_TDATA6_3y4 a ns1:Esquema ;
    rdfs:label "Secuencia 'Tercer y cuarto contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_12a35f6dff ;
