ns1:Ejemplo_CDW_20 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3 asignada a CDW 20"@es ;
    ns1:identificador "CDW 20" ;
    ns1:textoExtracto "I3 = CDW 20. Cada vez que se produce un flanco de subida en I3 se decrementa la cuenta del contador C20."@es .

ns1:Ejemplo_CPL_Flancos a ns1:AccionProhibida ;
    rdfs:label "Ejemplo CPL con flancos de señal" ;
    ns1:identificador "CPL B12R35" ;
    ns1:textoExtracto "DFU I8 OR DFD M22 = CPL B12R35. Cada vez que se detecte un flanco de subida en la entrada I8 o un flanco de bajada en la marca M22, el PLC complementará el estado del bit 12 del registro R35." .

ns1:Ejemplo_CUP_10 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I2 asignada a CUP 10"@es ;
    ns1:identificador "CUP 10" ;
    ns1:textoExtracto "I2 = CUP 10. Cada vez que se produce un flanco de subida en I2 se incrementa la cuenta del contador C10."@es .

ns1:Ejemplo_RES_Logica a ns1:AccionProhibida ;
    rdfs:label "Ejemplo RES con lógica condicional" ;
    ns1:identificador "RES M55/M65" ;
    ns1:textoExtracto "I12 OR NOT I22 = RES M55 = NOT RES M65. Cuando la expresión lógica tenga como resultado un \"1\", el PLC asigna M55=0 y no modifica M65. Si la expresión lógica tiene como resultado un \"0\", el PLC no modifica M55 y asigna M65=0." .

ns1:Ejemplo_SET_Temporizador a ns1:AccionProhibida ;
    rdfs:label "Ejemplo SET con temporizador T2" ;
    ns1:identificador "SET B0R100" ;
    ns1:textoExtracto "CPS T2 EQ 100 = SET B0R100. Cuando la cuenta (tiempo) del temporizador T2 sea igual a 100, se activará (se pondrá a \"1\") el bit 0 del registro R100." .

ns1:Empresa_Fagor a ns1:Empresa ;
    rdfs:label "Fagor" ;
    ns1:textoExtracto "subrutina [...] suministrada por Fagor"@en .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Cualquier malfuncionamiento de equipo, derivado de la instalación de software de terceros, exime a Fagor Automation de cualquier responsabilidad."@es .

ns1:EncoderLinealFagorFox a ns1:Sensor ;
