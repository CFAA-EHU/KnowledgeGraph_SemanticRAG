    ns1:valor "1" .

ns1:Parametro_RETMFUNC a ns1:Parametro ;
    rdfs:label "Parámetro RETMFUNC" ;
    ns1:identificador "RETMFUNC" ;
    ns1:textoExtracto "RETMFUNC Tratamiento de las funciones M con la función retrace. Valores posibles: Ignorar / Cancelar. Valor por defecto: Ignorar. Variable asociada: (V.)[ch].MPG.RETMFUNC Este parámetro establece el comportamiento de la función retrace cuando se ejecutan funciones M." ;
    ns1:valor "Ignorar" .

ns1:Parametro_RETRACAC a ns1:Parametro ;
    rdfs:label "Parámetro RETRACAC" ;
    ns1:identificador "RETRACAC" ;
    ns1:textoExtracto "RETRACAC Permitir habilitar la función retrace. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.RETRACAC Este parámetro indica si se permite utilizar la función retrace en el CNC." ;
    ns1:valor "No" .

ns1:Parametro_ROUNDTYPE a ns1:Parametro ;
    rdfs:label "ROUNDTYPE (Tipo de redondeo en G5)" ;
    ns1:identificador "(V.)[ch].MPG.ROUNDTYPE" ;
    ns1:textoExtracto "ROUNDTYPE Tipo de redondeo en G5 por defecto. Valores posibles: Error cordal / %Avance. Valor por defecto: Error cordal. Variable asociada: (V.)[ch].MPG.ROUNDTYPE Este parámetro indica el tipo de redondeo que se aplica por defecto cuando se trabaja en arista matada." ;
    ns1:valor "Error cordal" .

