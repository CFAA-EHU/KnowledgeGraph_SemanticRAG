ns1:FicheroAyudaTextoSubrutina a ns1:Componente ;
    rdfs:label "Fichero de ayuda de texto (.txt) para subrutinas"@es ;
    ns1:textoExtracto "Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)."@es,
