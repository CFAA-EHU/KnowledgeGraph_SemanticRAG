    ns1:identificador "RESTMEM" ;
    ns1:monitoreaParametro ns1:Param_EstadoEmergenciaGestor ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas."@es .

ns1:ROPARMAX a ns1:Parametro ;
    rdfs:label "ROPARMAX" ;
