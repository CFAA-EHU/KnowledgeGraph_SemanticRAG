ns1:Param_REFVALUE a ns1:Parametro ;
    rdfs:label "Cota inicial del eje Hirth (REFVALUE)" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "El parámetro REFVALUE será tomado como cota inicial para los sucesivos incrementos." .

ns1:Param_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
