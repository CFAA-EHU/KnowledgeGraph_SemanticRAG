ns1:ConfiguracionEjes_Plano_Torno1Canal3Ejes1Cabezal a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo plano (G18 ZX) para torno con 1 canal, 3 ejes y 1 cabezal"@es ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "Con una configuración de ejes tipo plano, siempre está activo el plano G18; en este caso el plano ZX. Las funciones G17 y G19 no son válidas."@es .

ns1:DiagramaTemporalReset a ns1:Esquema ;
    rdfs:label "Diagrama temporal del proceso de reset"@es ;
    ns1:ilustradoEn ns1:Pagina_665 ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW,
        ns1:Senal_RESETIN,
        ns1:Senal_RESETOUT ;
    ns1:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT. La línea de tiempo (t) indica cuatro hitos numerados: activación de RESETIN, tiempo para asumir condiciones iniciales, activación de RESETOUT y final de reset, tras lo cual se ejecuta la subrutina PROGRAM_RESET."@es .

