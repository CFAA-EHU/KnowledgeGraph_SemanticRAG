ns1:Parametro_TDATA17 a ns1:Parametro ;
    rdfs:label "TDATA17",
        "TDATA17"@es,
        "TDATA17 (Posición de reposo del eje longitudinal)"@es,
        "TDATA17: Posición de reposo del eje rotativo secundario"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo1_16,
        ns1:Tabla_RedefinicionCinematicaVectorial_293_308 ;
    ns1:identificador "TDATA17" ;
    ns1:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario del cabezal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0.",
        "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0.",
        "TDATA17 | TDATA8",
        "Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0."@es,
        "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)."@es,
        "TDATA17 | TDATA8"@es,
        "TDATA17 | TDATA9"@es,
        "| TDATA17 | TDATA9 |"@es ;
    ns1:valor 0.0,
        "0",
        "TDATA8",
        "TDATA9",
        "TDATA9"^^xsd:string,
        "TDATA8"@es,
        "±99999.9999°"@es .

