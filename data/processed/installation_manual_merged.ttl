    ns1:textoExtracto "DIGITAL INPUT [...] X1 [...] IIIINNNS 1234567" .

ns1:EntradasDigitales_Azul_749_751 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (bloque azul)" ;
    ns1:identificador "azul" ;
    ns1:textoExtracto "Color azul. Entradas digitales." .

ns1:EntradasDigitales_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (EtherCAT)" ;
    ns1:identificador "1024" ;
    ns1:textoExtracto "Entradas digitales. | 1024" .

ns1:EntradasFisicas1A256 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas físicas 1 a 256"@es ;
    ns1:identificador "1-256" ;
    ns1:textoExtracto "si en los módulos remotos están numeradas las entradas 1 a 256"@es .

ns1:EntradasLocales_LI1_LI16 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas locales LI1-LI16" ;
    ns1:identificador "LI1-LI16" ;
    ns1:textoExtracto "Entradas locales (LI1-LI16) [...] Las unidades centrales ICU y MCU disponen de 8 entradas digitales [...] Se denominan entradas locales porque se encuentran en la unidad central." .

ns1:EntradasLogicasCNC a ns1:InterfazUsuario ;
    rdfs:label "Entradas lógicas del CNC (modificables por PLC)"@es ;
    ns1:textoExtracto "El CNC dispone además de una serie de entradas y salidas lógicas para el intercambio de información interna con las marcas y registros del PLC. [...] Las entradas lógicas del CNC o señales modificables por PLC se agrupan en: Señales modificables generales, de los ejes, de los cabezales, del interpolador independiente, del gestor de herramientas, del laser y de las teclas."@es .

ns1:EntradasPt100_EtherCAT a ns1:Sensor ;
    rdfs:label "Entradas para sondas Pt100 (EtherCAT)" ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Entradas analógicas para sondas de temperatura Pt100. | 10" .

ns1:EntradasSalidasAPiezaG00 a ns1:Parametro ;
    rdfs:label "Entradas/salidas a pieza (G00)"@es ;
    ns1:textoExtracto "detección de G00, entradas/salidas a pieza"@es .

ns1:EntradasSalidasDigitales a ns1:ComponenteElectrico ;
    rdfs:label "Entradas y salidas digitales" ;
    ns1:textoExtracto "Número total y frecuencia de cambio de las entradas y salidas digitales." ;
    ns1:tieneFrecuencia ns1:Frecuencia_CambioDigital .

ns1:Entradas_I14_a_I21 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas (I14-I21) en código BCD"@es ;
    ns1:identificador "I14-I21" ;
    ns1:textoExtracto "las 8 entradas I14 y siguientes en código BCD"@es .

ns1:Entradas_I1_I1024 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas I1-I1024" ;
    ns1:identificador "I1-I1024" ;
    ns1:textoExtracto "Entradas (I1-I1024) [...] Las entradas son elementos que proporcionan información al PLC de las señales que se reciben del exterior." .

ns1:EnviarAlPLCMPLC_ed6535f75f a ns1:Parametro ;
    rdfs:label "Enviar al PLC (MPLC)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque." .

ns1:Error23102ErrorDelSistemaDeCompensacionVolumetricaCompensacionDesactivada a ns1:AvisoSeguridad ;
    rdfs:label "Error 23102: Error del sistema de compensación volumétrica; compensación desactivada" ;
    ns1:identificador "23102" ;
    ns1:textoExtracto "23102 'Error del sistema de compensación volumétrica; compensación desactivada' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un error interno en el cálculo de la compensación volumétrica, y ha anulado los valores de la compensación. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error23103NoSePuedeActivarLaMarcaVOLCOMPSinUnaTablaValidada a ns1:AvisoSeguridad ;
    rdfs:label "Error 23103: No se puede activar la marca VOLCOMP sin una tabla validada" ;
    ns1:identificador "23103" ;
    ns1:textoExtracto "23103 'No se puede activar la marca VOLCOMP sin una tabla validada' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no está definida de forma correcta y por lo tanto no es posible la compensación de la máquina. SOLUCIÓN Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)." .

ns1:Error23104NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes a ns1:AvisoSeguridad ;
    rdfs:label "Error 23104: No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes" ;
    ns1:identificador "23104" ;
    ns1:textoExtracto "23104 'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes' DETECCIÓN Durante la ejecución." .

ns1:Error2431DMCONAvanceMinimoAvanceMaximo a ns1:AvisoSeguridad ;
    rdfs:label "Error 2431: #DMC ON - Avance mínimo > avance máximo" ;
    ns1:identificador "2431" ;
    ns1:textoExtracto "2431 #DMC ON: OVRMIN debe ser menor que OVRMAX. DETECCIÓN Durante la ejecución. CAUSA En la función #DMC, el avance mínimo es mayor que el avance máximo. SOLUCIÓN El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ns1:Error24499_52c386526e a ns1:AvisoSeguridad ;
    rdfs:label "Error 24499" ;
    ns1:identificador "24499" ;
    ns1:mitigaRiesgo ns1:ModoDiagnosis_EtherCAT ;
    ns1:textoExtracto "Error 24499. Error genérico de EtherCAT. El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." .

ns1:Error3753 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753"@es ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "mostrará el error 3753. Con este error, el usuario decide la validez de la cota."@es .

ns1:Error3753DiferenciaDeCota a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753 (Diferencia de cota)" ;
    ns1:textoExtracto "Si MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753. Con este error, el usuario decide la validez de la cota. • Si la posición de la máquina coincide con el campo 'Valor actual' del error, la cota es válida. [...] • Si la posición de la máquina coincide con el campo 'Valor esperado', la cota no es válida." .

ns1:ErrorDePosicionEnSentidoNegativoNEGERROR a ns1:Parametro ;
    rdfs:label "Error de posición en sentido negativo (NEGERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.NEGERROR" ;
    ns1:textoExtracto "Error en sentido negativo. Parámetro válido para ejes lineales, rotativos y cabezales. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.NEGERROR[pt].xn"@es ;
    ns1:valor "0" .

ns1:ErrorDePosicionEnSentidoPositivoPOSERROR a ns1:Parametro ;
    rdfs:label "Error de posición en sentido positivo (POSERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.POSERROR" ;
    ns1:textoExtracto "Este parámetro indica el error cuando el eje se desplaza en sentido positivo. Si no se ha definido la tabla con compensación bidireccional, este error también se aplicará a los desplazamientos en sentido negativo. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.POSERROR[pt].xn"@es ;
    ns1:valor "0" .

ns1:ErrorDelSistemaDeCompensacionVolumetrica a ns1:AvisoSeguridad ;
    rdfs:label "Error del sistema de compensación volumétrica"@es ;
    ns1:identificador "23102" ;
    ns1:solucionaFallo ns1:FalloCompensacionVolumetrica ;
    ns1:textoExtracto "23102 'Error del sistema de compensación volumétrica;"@es .

ns1:ErrorE9332_EjesSercos a ns1:AvisoSeguridad ;
    rdfs:label "Error E9332: Incompatibilidad en parámetros de ejes Sercos"@es ;
    ns1:identificador "E9332" ;
    ns1:textoExtracto "Error E9332 por cada eje Sercos con captación externa. Este error indica que los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles."@es .

ns1:ErrorEjeBloqueado a ns1:AvisoSeguridad ;
    rdfs:label "Error 'eje bloqueado'" ;
    ns1:textoExtracto "Para evitar errores del tipo 'eje bloqueado'..." .

ns1:ErrorEjeBloqueado_c7c0f1a301 a ns1:AvisoSeguridad ;
    rdfs:label "Error 'eje bloqueado'" ;
    ns1:textoExtracto "el CNC muestra el error 'eje bloqueado'. [...] puede dar error de eje bloqueado en el empalme de bloques" .

ns1:ErrorEjecucionCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error por subrutina no definida en CNC"@es ;
    ns1:mitigaRiesgo ns1:SubrutinaFinProgramaPieza,
        ns1:SubrutinaInicioProgramaPieza ;
    ns1:textoExtracto "el CNC mostrará un error cada vez que se intente ejecutar un programa pieza"@es .

ns1:ErrorMaximoDePosicionMAXERROR_20b687ea5d a ns1:Parametro ;
    rdfs:label "Error máximo de posición (MAXERROR)" ;
    ns1:identificador "MPA.MAXERROR" ;
    ns1:textoExtracto "MAXERROR Error de posición. [...] Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." ;
    ns1:valor "0.1000 mm / 0.00394 inch / 0.1000 grados"^^xsd:string .

ns1:ErrorPar_Tandem a ns1:Parametro ;
    rdfs:label "Error de par entre motores (T.err)"@es ;
    ns1:documentadoEn ns1:Tabla_Tandem ;
    ns1:textoExtracto "T.err Error de par entre motores. T.err = (–T.mst + T.slv + PRELOAD)"@es .

ns1:ErrorPorRecursoDuplicado a ns1:AvisoSeguridad ;
    rdfs:label "Error por recurso duplicado" ;
    ns1:identificador "I33" ;
    ns1:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." .

ns1:ErrorPosicion a ns1:Parametro ;
    ns1:identificador "POSERROR n" ;
    ns1:textoExtracto "error asociado 'POSERROR n'" .

ns1:ErrorSeguimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento" ;
    ns1:monitoreaParametro ns1:Parametro_8c8832d44e ;
    ns1:textoExtracto "Se denomina error de seguimiento a la diferencia entre la posición teórica y real del eje." .

ns1:ErrorSeguimientoEje a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento del eje" ;
    ns1:mitigaRiesgo ns1:Se_alENABLE_Eje ;
    ns1:textoExtracto "Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de seguimiento." .

ns1:ErrorSimultaneidadG100 a ns1:AvisoSeguridad ;
    rdfs:label "Error por simultaneidad con G100"@es ;
    ns1:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error."@es .

ns1:ErrorSolapamientoCiclo a ns1:DiagnosticoFallo ;
    rdfs:label "Error de solapamiento de ciclo en CAN"@es ;
    ns1:solucionaFallo ns1:Parametro_e71834e406 ;
    ns1:textoExtracto "errores varios de solapamiento de ciclo y timeout en lecturas cíclicas de CAN."@es .

ns1:Error_23101 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23101 'Error en el análisis del fichero de definición de la compensación volumétrica'" ;
    ns1:identificador "23101" ;
    ns1:solucionaFallo ns1:Parametro_60ddb30d7f ;
    ns1:textoExtracto "23101 'Error en el análisis del fichero de definición de la compensación volumétrica' [...] CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados." .

ns1:Error_2427 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2427: Sintaxis incorrecta en #DMC ON" ;
    ns1:identificador "2427" ;
    ns1:monitoreaParametro ns1:Parametro_031bad53e6,
        ns1:Parametro_08700bb791,
        ns1:Parametro_52d5fe188e,
        ns1:Parametro_60f6f2b436,
        ns1:Parametro_bce2094683 ;
    ns1:textoExtracto "2427 #DMC ON [<PWRSP value><,OVRMIN value><,OVRMAX value><,FZMIN value><,FZMAX value>] [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2428 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2428: Sintaxis incorrecta en #DMC OFF" ;
    ns1:identificador "2428" ;
    ns1:textoExtracto "2428 #DMC OFF [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2429 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2429: Parámetro DMC fuera de rango" ;
    ns1:identificador "2429" ;
    ns1:monitoreaParametro ns1:Parametro_c7b795e946 ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango [...] CAUSA Algún comando de la sentencia #DMC tiene un valor no válido." .

ns1:Error_3103_PotenciaObjetivoInsuficiente a ns1:AvisoSeguridad ;
    rdfs:label "Error 3103: Potencia objetivo insuficiente para el funcionamiento correcto con DMC"@es ;
    ns1:identificador "3103" ;
    ns1:mitigaRiesgo ns1:Solucion_3103_RevisarPotenciaObjetivo ;
    ns1:textoExtracto "3103 Potencia objetivo insuficiente para el funcionamiento correcto con DMC. DETECCIÓN Durante la ejecución. CAUSA Los valores de la potencia en vacío y la potencia objetivo durante el mecanizado son similares. Es posible que el DMC no pueda distinguir con exactitud las entradas y salidas de la pieza."@es .

ns1:Error_9347 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9347 'Eje repetido en VOLCOMP'" ;
    ns1:identificador "9347" ;
    ns1:solucionaFallo ns1:Parametro_17804cd144,
        ns1:Parametro_3054486db6 ;
    ns1:textoExtracto "9347 'Eje repetido en VOLCOMP' [...] CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

ns1:Error_ColisionHerramientaPieza a ns1:AvisoSeguridad ;
    rdfs:label "Error: Potencia instantánea superada (TV51) - Posible colisión herramienta-pieza"@es ;
    ns1:mitigaRiesgo ns1:Solucion_ColisionHerramienta_Inspeccion ;
    ns1:textoExtracto "CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado. Esto puede indicar que la herramienta ha colisionado con la pieza, por lo que el CNC detiene los ejes manteniendo el giro del cabezal."@es .

ns1:Esquema1 a ns1:Esquema ;
    ns1:ilustradoEn ns1:Figura1 ;
    ns1:textoExtracto "Captura doble: barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible') y vista de árbol que despliega esclavos y módulos mostrando sus recursos; indicadores 'Starts/Offset' para numeración y opción 'Ver esclavos'."@es .

ns1:Esquema1552 a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Entity2458 ;
    ns1:textoExtracto "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento. Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento), con ejes dibujados y símbolos (+) que fijan el sentido positivo." .

ns1:Esquema2 a ns1:Esquema ;
    ns1:ilustradoEn ns1:Figura2 ;
    ns1:textoExtracto "Vista en bloques del bus con leyenda cromática: azul (entradas digitales), morado (salidas digitales), rojo/gris (mapeos a/desde registros PLC), verde/amarillo (AI/AO Fagor). La captura muestra tarjetas alineadas por cabecera, con numeración visible y separación por módulos."@es .

ns1:Esquema3 a ns1:Esquema ;
    ns1:ilustradoEn ns1:Figura3 ;
    ns1:textoExtracto "Cuadro de propiedades de un módulo en vista de bloques para redefinir el número inicial de sus recursos, numerándose el resto de forma correlativa. Se observan campos editables y previsualización del bloque afectado."@es .

ns1:Esquema3D_LimitesTorno a ns1:Esquema ;
    rdfs:label "Esquema 3D de límites físicos/software del torno" ;
    ns1:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z" .

ns1:EsquemaConexion_1501 a ns1:Esquema ;
    rdfs:label "Esquema de conexión para posicionamiento de herramienta (stdPlug@A1 → stdSocket@home)"@es ;
    ns1:ilustradoEn ns1:Entity737738 ;
    ns1:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>"@es .

ns1:EsquemaCronogramaReferenciado a ns1:Esquema ;
    rdfs:label "Cronograma de señales durante búsqueda de referencia (Mechatrolink)" ;
    ns1:textoExtracto "Cronograma de señales durante la búsqueda: perfiles de velocidad (REFFEED1) y aproximaciones, pulsos de micro y de I0; se indican fases 1–4" .

ns1:EsquemaDeCinematicaTYPE21 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=21" ;
    ns1:detalladoEnEsquema ns1:EsquemaDeCinematicaTYPE21 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=21 con ejes X-Y-Z y rotaciones C/A/B. Presenta el orden de ejes (1º-3º), componentes TDATA (1, 2, 3, 4, 5, 7, 8, 9, 12) y flechas de sentido; organiza jerárquicamente dirección y posición de cada giro." .

ns1:EsquemaDeCinematicaTYPE22 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=22" ;
    ns1:detalladoEnEsquema ns1:EsquemaDeCinematicaTYPE22 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=22 con ejes X-Y-Z y rotación C/B. Se especifican TDATA (2, 5, 7, 8, 11) y el orden 1º-3º; las anotaciones (+/−) establecen polaridad y sentido del giro respecto a los ejes lineales." .

ns1:EsquemaDeCinematicaTYPE23 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=23" ;
    ns1:detalladoEnEsquema ns1:EsquemaDeCinematicaTYPE23 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=23 (A/B/C con X-Y-Z). Diagramas con TDATA 1–13 y 21–23 que representan posiciones, offsets y sentidos de giro; incluye numeración de ejes 1º-3º y convenciones de signo." .

ns1:EsquemaDeCinematicaTYPE24 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=24" ;
    ns1:detalladoEnEsquema ns1:EsquemaDeCinematicaTYPE24 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=24 (A/B/C con X-Y-Z). Muestra vectores asociados a TDATA (2, 4, 5, 8) y la correspondencia entre traslaciones/giros con indicación de orden y sentido." .

ns1:EsquemaDeDimensionesTDATA123567 a ns1:Esquema ;
    rdfs:label "Esquema de dimensiones TDATA (1,2,3,5,6,7)"@es ;
    ns1:identificador "TDATA" ;
    ns1:textoExtracto "Esquema de dimensiones TDATA (1,2,3,5,6,7) sobre ejes X-Y-Z y rotaciones B/C, con signos positivos indicados. Muestra relaciones espaciales entre nariz de husillo, ejes rotativos y eje de herramienta para parametrizar la cinemática TYPE=6."@es .

ns1:EsquemaDeGestionMultiejePag584 a ns1:Esquema ;
    rdfs:label "Esquema de gestión multieje (pág. 584)"@es ;
    ns1:textoExtracto "Esquema con dos motores y dos husillos independientes conectados a un mismo módulo de regulador."@es .

ns1:EsquemaDeSenalesPARKUNPARKSeccion62 a ns1:Esquema ;
    rdfs:label "Esquema de señales PARK/UNPARK (Sección 6.2)"@es ;
    ns1:ilustradoEn ns1:SistemaCNC_Seccion6_2 ;
    ns1:textoExtracto "Park/Unpark desde el CNC. [...] El CNC utiliza las señales PARK y UNPARK para informar al PLC."@es .

ns1:EsquemaDelSistemaMultiejeEjemplo2 a ns1:Esquema ;
    rdfs:label "Esquema del sistema multieje (Ejemplo 2)" ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2; ambos ejes usan captación directa a módulos remotos diferentes (1 y 2). Se representan los bloques de regulador, bus CAN y contadoras." .

ns1:EsquemaEjeTandem a ns1:Esquema ;
    rdfs:label "Esquema mecánico de eje tándem (Master-Slave)" ;
    ns1:textoExtracto "Dibujo lineal, con jerarquía simple (motores arriba, transmisión abajo) para explicar la arquitectura y requisitos de configuración." .

ns1:EsquemaFresadoraGantry a ns1:Esquema ;
    rdfs:label "Esquema de fresadora puente con ejes gantry (X-U, Z-W)" ;
    ns1:textoExtracto "Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." .

ns1:EsquemaNomenclaturaEjes a ns1:Esquema ;
    rdfs:label "Norma DIN 66217 para nomenclatura de ejes" ;
    ns1:detalladoEnEsquema ns1:VisualizacionCotasEjesRotativos ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "Ilustración conceptual de la norma DIN 66217 para nomenclatura de ejes: dibujos con triedro XYZ y flechas que indican ejes principales (X, Y, Z), auxiliares paralelos (U, V, W) y rotativos (A, B, C) alrededor de X, Y, Z respectivamente. La gráfica sitúa los ejes respecto al plano de trabajo y el eje perpendicular, ayudando a identificar la función de cada eje en la máquina." .

ns1:EsquemaPosicionamiento_17_1 a ns1:Esquema ;
