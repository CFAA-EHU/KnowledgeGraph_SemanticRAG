    rdfs:label "A.GAPCOMP.Z" ;
    ns1:identificador "A.GAPCOMP.Z" ;
    ns1:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" .

ns1:Parametro_GAPINPOSW a ns1:Parametro ;
    rdfs:label "GAPINPOSW" ;
    ns1:textoExtracto "El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW)."@es .

ns1:Parametro_GAPSENSORCH a ns1:Parametro ;
    rdfs:label "GAPSENSORCH" ;
