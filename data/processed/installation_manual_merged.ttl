ns1:Sistema_HSC a ns1:Sistema ;
    rdfs:label "Sistema de control HSC" ;
    ns1:textoExtracto "efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC" ;
    ns1:tieneComponente ns1:Parametro_FILTER .

ns1:Sistema_InterfazUsuario a ns1:InterfazUsuario ;
    rdfs:label "Sistema de interfaces de usuario (paneles de jog y grupos remotos)"@es ;
    ns1:compuestoPor ns1:GrupoRemoto_1,
        ns1:GrupoRemoto_2,
        ns1:GrupoRemoto_3 ;
    ns1:textoExtracto "Se dispone de una marca para cada teclado o panel de jog. La marca PANELOFF1 deshabilita el primero del bus, la marca PANELOFF2 el segundo y así sucesivamente. Se admite PANELOFF o PANELOFF1 para el primer panel de jog."@es ;
    ns1:tieneComponente ns1:PanelJog_1,
        ns1:PanelJog_2 .

ns1:Sistema_Jog a ns1:Sistema ;
    rdfs:label "Sistema de paneles de jog" ;
    ns1:textoExtracto "Al habilitar un teclado (marca PANELOFF) y cada vez que hay un cambio en un teclado (pulsar una tecla, modificar un conmutador, etc), el canal asume el estado de las teclas y la posición de los conmutadores del nuevo teclado como los valores activos." ;
    ns1:tieneComponente ns1:Conmutador_FeedOverride,
        ns1:Tecla_RESET,
        ns1:Teclado_PANELOFF,
        ns1:Teclas_ModoTrabajo .

ns1:Sistema_MonitorizacionErrorSeguimiento a ns1:Sistema ;
    ns1:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

ns1:Sistema_OPENPCS_Remoto a ns1:Sistema ;
    rdfs:label "Sistema OPENPCS Remoto" ;
    ns1:detalladoEnEsquema ns1:EsquemaBus_OPENPCS ;
    ns1:textoExtracto "Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5), dispuestos en un esquema lineal del bus." ;
    ns1:tieneComponente ns1:CNC_Address0,
        ns1:JogPanel_Address2,
        ns1:JogPanel_Address5,
        ns1:ModuloES_Address1,
        ns1:ModuloES_Address3,
        ns1:ModuloES_Address4 .

ns1:Sistema_Override a ns1:Sistema ;
    rdfs:label "Sistema de control de override para optimización de potencia"@es ;
    ns1:detalladoEnEsquema ns1:Figura_18_4_4_Osciloscopio ;
    ns1:textoExtracto "Control del override para optimizar la potencia."@es .

ns1:Sistema_RCS_S a ns1:Sistema ;
    rdfs:label "Sistema RCS-S (contadora Sercos)" ;
    ns1:detalladoEnEsquema ns1:Manual_ModoManual ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "Volantes conectados a través de los módulos RCS-S (contadora Sercos). Los volantes se numeran de 1 a 32.",
        "módulo RCS-S"@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_ContadoraSercos,
        ns1:ComponenteElectrico_EntradaLocal .

ns1:Sistema_ReferenciadoEjes a ns1:Sistema ;
    rdfs:label "Sistema de referenciado de ejes (marca REFPOIN)" ;
