    ns1:monitoreaParametro ns1:SensorGap ;
    ns1:textoExtracto "GAPGAIN Ganancia proporcional a aplicar en GAPCTRL. Valores posibles: De 0.0000 a 100.0000. Valor por defecto: 0.2. Variable asociada: (V.)MPG.GAPGAIN Ganancia proporcional aplicada a la señal del sensor, en posición." ;
    ns1:valor "0.2"^^xsd:float .

ns1:GestionMultieje_11_4 a ns1:ModoOperacion ;
    rdfs:label "Gestión multieje (CNC)" ;
    ns1:textoExtracto "Si la captación externa es local o remota, el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; [...] Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje." .

ns1:GestorAlmacen a ns1:Sistema ;
    rdfs:label "Gestor del almacén",
        "Gestor del almacén (MZWAIT)"@es ;
    ns1:identificador "MZWAIT" ;
    ns1:monitoreaParametro ns1:ParametroMZWAIT ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén.",
        "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén."@es .

ns1:GestorHerramientas_869 a ns1:InterfazUsuario ;
    rdfs:label "Gestor de herramientas"@es ;
    ns1:textoExtracto "El PLC [...] debe informar al gestor de las acciones efectuadas para que actualice su información. Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros."@es .

ns1:GraficosSTD a ns1:InterfazUsuario ;
