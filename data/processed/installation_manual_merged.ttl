ns1:CNC_Multicanal a ns1:Sistema ;
    rdfs:label "Sistema CNC con opción multicabezal y canales" ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro canales y cada canal puede ejecutar un programa pieza en paralelo con los demás. [...] Esto significa que, debido a que algunas funciones se generan automáticamente, se puede llegar a superar el máximo de siete funciones auxiliares por bloque." ;
    ns1:tieneComponente ns1:CanalCNC_1,
        ns1:CanalCNC_2,
        ns1:CanalCNC_3,
        ns1:CanalCNC_4 .

