    ns1:textoExtracto "TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra." .

ns1:OperacionTM8 a ns1:TareaMantenimiento ;
    rdfs:label "Operación TM8: Dejar herramienta del cabezal en tierra y coger herramienta de tierra",
        "Intercambio de herramienta (TMOPERATION=8)"@es ;
    ns1:activaAlarma ns1:MarcaGRTOSPDL,
        ns1:MarcaSPDLTOGR ;
    ns1:ejecutadoPor ns1:Pinza1 ;
    ns1:habilitadoPor ns1:MarcaGRTOSPDL,
        ns1:MarcaSPDLTOGR ;
    ns1:identificador "TM8",
        "TMOPERATION=8" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL.",
        "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL.",
        "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es .

ns1:OperacionTM9 a ns1:TareaMantenimiento ;
    rdfs:label "Operación TM9: Coger herramienta de tierra y llevarla al almacén pasando por el cabezal" ;
    ns1:ejecutadoPor ns1:Pinza1 ;
    ns1:habilitadoPor ns1:MarcaGRTOSPDL,
        ns1:MarcaSPDLTOCH1,
        ns1:MarcaSPDLTOMZ ;
    ns1:identificador "TM9",
        "TMOPERATION=9" ;
    ns1:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ.",
        "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:Operacion_Almacen_6 a ns1:TareaMantenimiento ;
    rdfs:label "Operación 6: Cambio de herramienta a herramienta de tierra" ;
