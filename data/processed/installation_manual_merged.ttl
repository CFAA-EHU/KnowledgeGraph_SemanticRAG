    ns1:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es .

ns1:CabezalLaser a ns1:Componente ;
    rdfs:label "Cabezal láser"@es ;
    ns1:textoExtracto "En el modelo láser, la entrada de captación del cabezal será 0 ya que no hay captación real."@es .

ns1:CabezalSercos_S a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Sercos S"@es ;
    ns1:documentadoEn ns1:Sistema_ContadoresYEjes_1261 ;
    ns1:textoExtracto "1 cabezal Sercos S"@es .

ns1:Cabezal_5 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 5"@es ;
    ns1:textoExtracto "SPDLEREV5"@es .

ns1:Cabezal_6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 6"@es ;
    ns1:textoExtracto "SPDLEREV6"@es .

ns1:Cabezal_S2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S2"@es ;
    ns1:documentadoEn ns1:SistemaFresadora_3Canales_9Ejes_2Cabezales ;
    ns1:identificador "S2",
        "SPDLNAME 2" ;
    ns1:textoExtracto "1 cabezal (S2)"@es,
        "SPDLNAME 2 | S2 | Número lógico ꞏ11ꞏ. | Cabezal con índice ꞏ2ꞏ."@es ;
