    ns1:textoExtracto "PLCTYPE Tipo de PLC. Valores posibles: IEC / IEC+Fagor / Fagor. Valor por defecto: IEC. Variable asociada: (V.)MPG.PLCTYPE" ;
    ns1:valor "IEC"^^xsd:string .

ns1:Parametro_47dd44e411 a ns1:Parametro ;
    rdfs:label "DRIVEID" ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:textoExtracto "Dirección del regulador."@es .

ns1:Parametro_48bc6ddeea a ns1:Parametro ;
    rdfs:label "ACTIVEMATERIALON" ;
