    ns1:textoExtracto "USERKEYBD8DEF n" .

ns1:Tabla_USERKEYDEF a ns1:Tabla ;
    rdfs:label "Tabla USERKEYDEF" ;
    ns1:identificador "USERKEYDEF" ;
    ns1:textoExtracto "Tablas para configurar las teclas de usuario como teclas de jog. [...] Hay disponible una tabla para cada teclado de jog." .

ns1:Tabla_ValoresAlmacen a ns1:Tabla ;
    rdfs:label "Tabla de valores de operaciones del almacén"@es ;
    ns1:ilustradoEn ns1:Pagina_517_519 ;
    ns1:textoExtracto """\r
| Valor | Significado |\r
| --- | --- |\r
| 0 | No hay que hacer nada. |\r
| # | Posición en el almacén. |\r
| -4 | Herramienta de tierra. """@es .

ns1:Tabla_ValoresTeclasJog a ns1:Tabla ;
    rdfs:label "Tabla de valores para configuración de teclas de jog" ;
    ns1:documentadoEn ns1:InterfazUsuario_TeclasJog ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | 1-, 2-, 3-, .. 10- / 1+, 2+, 3+, .. 10+ | Teclas para definir el eje y el sentido de desplazamiento. [...] R | Tecla de rápido." .

ns1:Tabla_VelocidadesCANopen a ns1:Tabla ;
    rdfs:label "Tabla de velocidades del bus CANopen según longitud" ;
    ns1:ilustradoEn ns1:Pagina_71 ;
    ns1:textoExtracto "| Longitud (m) | 20 | 40 | 100 | 500 | --- | --- | --- | --- | Velocidad (kHz) | 1000 | 800 | 500 | 250 |" .

ns1:Tabla_XFITOIND a ns1:Tabla ;
    rdfs:label "Tabla de valores del parámetro XFITOIND",
        "Tabla de configuración XFITOIND"@es ;
    ns1:documentadoEn ns1:Pagina_457 ;
    ns1:identificador "XFITOIND" ;
    ns1:textoExtracto "| XFITOIND | Significado. | --- | --- | Sí | El CNC primero evalúa el transfer inhibit del canal (marca _XFERINH) y a continuación el particular del eje (marca _IXFERINH(axis)). | No | El CNC sólo evalúa el transfer inhibit particular del eje (marca _IXFERINH(axis)).",
        """\r
| XFITOIND | Significado. |\r
| --- | --- |\r
| Sí | La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC. |\r
| No | La marca _XFERINH no afecta a los movimientos de eje independiente programados desde el PLC; sí afecta a los programados desde el CNC. """@es .

ns1:TareaActualizacionXCA a ns1:TareaMantenimiento ;
    rdfs:label "Actualización manual de archivos xca"@es ;
    ns1:detalladoEnEsquema ns1:DirectivaActualizacionXCA ;
    ns1:requiereConsumible ns1:ArchivoXCA_V2 ;
    ns1:textoExtracto "copiar manualmente los nuevos archivos xca"@es .

ns1:TareaConfiguracionTeclasJog a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de teclas JOG y USERKEYS" ;
    ns1:documentadoEn ns1:ManualOpenPCS ;
    ns1:ejecutadoPor ns1:Personal_Operador ;
    ns1:textoExtracto "Configurar las teclas de usuario como teclas de jog (ejes 1…10 con signos ± y tecla R)." .

ns1:TareaEngraseEjes a ns1:TareaMantenimiento ;
    rdfs:label "Engrase de ejes" ;
    ns1:requiereConsumible ns1:LubricanteEjes ;
    ns1:textoExtracto "engrase de los ejes. [...] se debe engrasar el eje" .

ns1:TareaMantenimiento_ActivacionDEADaxis a ns1:TareaMantenimiento ;
    rdfs:label "Activación de DEAD(axis) para ejes muertos" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_ErrorEjeBloqueado ;
    ns1:textoExtracto "el PLC debe activar la marca DEAD(axis) para que el CNC no aplique el empalme de bloques en estos ejes muertos" .

ns1:TareaMantenimiento_ActualizacionSoftware a ns1:TareaMantenimiento ;
    rdfs:label "Actualización del software desde versiones anteriores" ;
    ns1:documentadoEn ns1:Manual_Seccion1_4_1 ;
    ns1:textoExtracto "Actualización del software desde versiones anteriores." .

ns1:TareaMantenimiento_AjusteDWELL a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del parámetro DWELL" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_ErrorEjeBloqueado ;
    ns1:textoExtracto "se debe asignar al parámetro máquina DWELL un valor superior al tiempo entre 2 scan de PLC para que el eje no dé el error de 'eje bloqueado'" .

ns1:TareaMantenimiento_CambioHerramientaAutomatico_Caso1 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta: Almacén → Cabezal (Caso 1)" ;
    ns1:textoExtracto "$CASE 1 ; Coger una herramienta del almacén y ponerla en el cabezal. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ns1:TareaMantenimiento_CambioHerramientaCombinado_Caso5 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio combinado: Cabezal → Almacén + Almacén → Cabezal (Caso 5)" ;
    ns1:textoExtracto "$CASE 5 ; Dejar la herramienta del cabezal en el almacén, y coger otra del almacén. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:TareaMantenimiento_ColocacionHerramientaTierra_Caso3 a ns1:TareaMantenimiento ;
    rdfs:label "Colocación de herramienta de tierra en cabezal (Caso 3)" ;
    ns1:textoExtracto "$CASE 3 ; Colocar la herramienta de tierra en el cabezal. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ns1:TareaMantenimiento_CopiaSeguridadConfiguracionCNC a ns1:TareaMantenimiento ;
    rdfs:label "Copia de seguridad de configuración CNC" ;
    ns1:requiereMantenimiento ns1:Maquina_CNC ;
    ns1:textoExtracto "guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido" .

ns1:TareaMantenimiento_DetectarModulos a ns1:TareaMantenimiento ;
    rdfs:label "Detección de módulos en bus MDP"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_ConfiguradorMDP ;
    ns1:textoExtracto "Para detectar las cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Scan configuration'. [...] Para detectar los recursos de cada nodo, [...] seleccionar la opción 'Attach master'. [...] Un paso previo para exportar la configuración es desaclopar el máster del bus."@es .

ns1:TareaMantenimiento_DevolucionHerramientaAutomatica_Caso2 a ns1:TareaMantenimiento ;
    rdfs:label "Devolución de herramienta: Cabezal → Almacén (Caso 2)" ;
    ns1:textoExtracto "$CASE 2 ; Dejar la herramienta del cabezal en el almacén. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." .

ns1:TareaMantenimiento_DevolucionHerramientaTierra_Caso4 a ns1:TareaMantenimiento ;
    rdfs:label "Devolución de herramienta a tierra (Caso 4)" ;
    ns1:textoExtracto "$CASE 4 ; Dejar la herramienta del cabezal en tierra. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:TareaMantenimiento_TransporteHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Transporte de herramienta entre brazo/cabezal/almacén"@es ;
    ns1:textoExtracto "Operaciones de cogida, colocación o intercambio de herramientas entre brazo, cabezal, almacén o tierra."@es .

ns1:TareaMantenimiento_ValidacionParametrosSercos a ns1:TareaMantenimiento ;
    rdfs:label "Validación de parámetros Sercos" ;
    ns1:textoExtracto "Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos." ;
    ns1:tieneFrecuencia ns1:Frecuencia_CambioParametroSercos .

ns1:Tarea_CopiarArchivoConfiguracionCNC a ns1:TareaMantenimiento ;
