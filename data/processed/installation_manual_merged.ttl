ns1:Parametro_103498ec62 a ns1:Parametro ;
    rdfs:label "CANMODE" ;
    ns1:identificador "V.MPG.CANMODE" ;
    ns1:textoExtracto "CANMODE Tipo de bus CAN. Valores posibles: CANfagor / CANopen. Valor por defecto: CANopen." ;
    ns1:valor "CANopen"^^xsd:string .

ns1:Parametro_105fa89070 a ns1:Parametro ;
    rdfs:label "KEEPPOS"@es ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:identificador "KEEPPOS" ;
    ns1:textoExtracto "KEEPPOS n: El eje desactivado mantiene su cota independientemente del eje activo."@es .

ns1:Parametro_10fd402f0c a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "relaciones ACCEL y ACCJERK con G00FEED" .

ns1:Parametro_1152274c70 a ns1:Parametro ;
    rdfs:label "HSCFILTFREQ"@es ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPaginas621622 ;
    ns1:identificador "HSCFILTFREQ MPG" ;
    ns1:textoExtracto "Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR. Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado."@es .

ns1:Parametro_11a57736de a ns1:Parametro ;
    rdfs:label "COLLISIONOFF" ;
    ns1:identificador "COLLISIONOFF" ;
    ns1:textoExtracto "Hay una marca para cada canal. COLLISIONOFF permite deshabilitar detección de colisiones por canal" .

ns1:Parametro_11ba1f559f a ns1:Parametro ;
    rdfs:label "PROBERANGE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "PROBERANGE" ;
    ns1:textoExtracto "PROBERANGE [...] Distancia máxima de frenado. [...] Valores posibles (1): De 0 a 99999.9999 mm. [...] Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado. [...] Este parámetro fija la máxima distancia de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)." ;
    ns1:valor "1.0000 mm (defecto)" .

