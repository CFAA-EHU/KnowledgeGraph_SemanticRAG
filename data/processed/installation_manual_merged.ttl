    ns1:identificador "MSG1-MSG1024" ;
    ns1:textoExtracto "Mensajes (MSG1-MSG1024). Al activarlas (=1) muestran un mensaje en la pantalla del CNC. Los textos asociados a los mensajes deben estar previamente definidos en la tabla de mensajes y errores del PLC."@es .

ns1:MenuOpcionesDMC a ns1:InterfazUsuario ;
    rdfs:label "Menú desplegable de opciones del DMC"@es ;
