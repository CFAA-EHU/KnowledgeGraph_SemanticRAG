ns1:SistemaCANopen_1400 a ns1:Sistema ;
    rdfs:label "Sistema de bus CANopen para I/O digitales"@es ;
    ns1:monitoreaParametro ns1:Parametro_c3ca39f2b8 ;
    ns1:textoExtracto "el CNC numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus. Cuando el bus es CANopen, el CNC permite dividir los nodos de I/Os digitales en bloques lógicos (módulos virtuales), y a continuación, establecer la numeración de las I/Os de cada bloque lógico asignando un índice base a la primera de ellas."@es ;
    ns1:tieneComponente ns1:NodoRIO5_1400,
        ns1:NodoRIOR_1400,
        ns1:NodoRIOW_1400,
        ns1:NodoTerceros_1400 .

