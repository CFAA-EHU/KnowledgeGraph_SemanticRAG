ns1:Parametro_MANACCP a ns1:Parametro ;
    rdfs:label "MANACCP" ;
    ns1:documentadoEn ns1:Tabla_ParametrosManual ;
    ns1:identificador "(V.)[ch].MPA.MANACCP.xn",
        "MANACCP" ;
    ns1:monitoreaParametro ns1:ModoOperacion_ManualSuperpuesto_G201 ;
    ns1:textoExtracto "MANACCP. Máximo porcentaje aceleración manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20.",
        "Máximo porcentaje de aceleración manual en G201."@es ;
    ns1:valor "20" .

ns1:Parametro_MANACFGAIN a ns1:Parametro ;
    rdfs:label "MANACFGAIN" ;
    ns1:monitoreaParametro ns1:Parametro_ACFWFACTOR ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con AC-forward; parámetro ACFWFACTOR.",
        "MANACFGAIN Porcentaje de AC-Forward en manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0.",
        "Variable asociada: (V.)[ch].MPA.MANACFGAIN[set].xn" ;
    ns1:valor 0 .

ns1:Parametro_MANAGEMENT a ns1:Parametro ;
    rdfs:label "MANAGEMENT" ;
    ns1:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén." .

ns1:Parametro_MANNEGSW a ns1:Parametro ;
    rdfs:label "MANNEGSW",
        "Recorrido negativo máximo con G201 (MANNEGSW)",
        "MANNEGSW (Máximo recorrido negativo con G201)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosManual ;
    ns1:identificador "(V.)[ch].MPA.MANNEGSW.xn",
        "MANNEGSW" ;
    ns1:monitoreaParametro ns1:ModoOperacion_ManualSuperpuesto_G201 ;
    ns1:textoExtracto "MANNEGSW Máximo recorrido negativo con G201. Parámetro válido para ejes lineales, rotativos y cabezales.",
        "MANNEGSW. Parámetro incluido en la tabla MANUAL. Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos.",
        "Consultar el parámetro máquina de ejes MANNEGSW. MANNEGSW Máximo recorrido negativo con G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: -99999.9999 mm / -3937.00787 inch / -99999.9999 grados."@es,
        "Máximo recorrido negativo con G201."@es ;
    ns1:valor "99999.9999",
        "De 0 a 100",
        "-99999.9999 mm / -3937.00787 inch / -99999.9999 grados"@es .

ns1:Parametro_MANPOSSW a ns1:Parametro ;
    rdfs:label "MANPOSSW",
        "Recorrido positivo máximo con G201 (MANPOSSW)" ;
    ns1:identificador "MANPOSSW" ;
    ns1:textoExtracto "MANPOSSW Máximo recorrido positivo con G201. [...] Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 99999.9999 mm / 3937.00787 inch / 99999.9999 grados.",
        "Máximo recorrido positivo con G201."@es ;
    ns1:valor "99999.9999" .

ns1:Parametro_MASTERAXIS a ns1:Parametro ;
    rdfs:label "MASTERAXIS" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MASTERAXIS",
        "MPG.MASTERAXIS[nb]" ;
    ns1:textoExtracto "MASTERAXIS Eje gantry. Eje maestro o principal. Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.MASTERAXIS[nb] Parámetro incluido en la tabla GANTRY. Este parámetro establece cuál es el eje maestro del eje gantry.",
        "Eje maestro o principal."@es .

