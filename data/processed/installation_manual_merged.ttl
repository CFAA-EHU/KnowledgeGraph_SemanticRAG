ns1:Parametro_PLANECANCEL a ns1:Parametro ;
    rdfs:label "PLANECANCEL" ;
    ns1:identificador "PLANECANCEL" ;
    ns1:textoExtracto "PLANECANCEL Asumir IPLANE como plano activo tras M30/RESET o mantener el activo. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.PLANECANCEL Este parámetro define cuál es el plano activo tras ejecutar M02, M30 o reset." ;
    ns1:valor "Sí" .

ns1:Parametro_PLCDATASIZE a ns1:Parametro ;
