    ns1:detalladoEnEsquema ns1:Esquema_LazosVariables_633 ;
    ns1:monitoreaParametro ns1:Parametro_XFERINH ;
    ns1:textoExtracto "INDEPENDENT (V.)A.INDPOS.xn INTERPOLATOR (V.)A.ITPOS.xn [...] COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada.",
