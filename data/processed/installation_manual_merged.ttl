    ns1:textoExtracto "Si las condiciones del mecanizado cambian (por ejemplo, por el desgaste de la herramienta), el avance programado puede no ser ya el adecuado"@es .

ns1:Riesgo_Sobretemperatura a ns1:AccionProhibida ;
    rdfs:label "Operativa restringida por sobretemperatura" ;
    ns1:textoExtracto "restringir la operativa del CNC en caso de sobretemperatura." .

ns1:RotacionRegistro_RL1 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a izquierdas tipo 1 (RL1)" ;
    ns1:identificador "RL1" ;
    ns1:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. El valor del último bit desaparece." .

ns1:RotacionRegistro_RL2 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a izquierdas tipo 2 (RL2)" ;
    ns1:identificador "RL2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RotacionRegistro_RR1 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a derechas tipo 1 (RR1)" ;
    ns1:identificador "RR1" ;
    ns1:textoExtracto "Rotación de registros. [...] Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. El valor del último bit desaparece. [...] RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:RotacionRegistro_RR2 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a derechas tipo 2 (RR2)" ;
    ns1:identificador "RR2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RuletaIdentificacion_1388 a ns1:ComponenteMecanico ;
    rdfs:label "Ruleta de identificación física (Sercos ID)" ;
    ns1:textoExtracto "Cada contadora deberá identificarse físicamente por una numeración (Sercos ID), a través de la ruleta que incorpora en su frontal. Dicho identificador deberá ser único en el anillo, siguiendo un criterio de numeración correlativo de 1 a n y sin huecos (siendo n el número total de nodos Sercos, considerando tanto reguladores como contadoras)."^^rdfs:Literal .

