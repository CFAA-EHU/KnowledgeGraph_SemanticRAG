    ns1:textoExtracto "Render 3D que representa el plano de trabajo ZC (ejes Z–C) con una herramienta frontal. Se enfatiza la rotación del eje C y la traslación sobre Z para operaciones de fresado/posicionamiento angular, diferenciando el plano respecto al caso XC."@es .

ns1:PosicionAlmacen a ns1:Parametro ;
    rdfs:label "Posición en el almacén"@es ;
    ns1:identificador "#" ;
    ns1:textoExtracto "# => Posición en el almacén"@es .

ns1:PosicionAlmacen_TAKEPOS a ns1:Parametro ;
    rdfs:label "Posición de recogida en almacén (TAKEPOS)"@es ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta."@es .

ns1:PosicionTierra_LEAVEPOS a ns1:Parametro ;
    rdfs:label "Posición de herramienta en tierra (LEAVEPOS=-4)"@es ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS=-4 Herramienta de tierra."@es ;
    ns1:valor "-4" .

ns1:PostprocesadorFagor a ns1:Componente ;
    rdfs:label "Postprocesador Fagor" ;
    ns1:compuestoPor ns1:LantekExpertInside ;
    ns1:textoExtracto "El postprocesador Fagor integrado creará el programa pieza para el CNC."@es .

ns1:PotenciaEnVacio a ns1:Parametro ;
    rdfs:label "No load power" ;
    ns1:documentadoEn ns1:TablaInfoDMC ;
    ns1:textoExtracto "No load power (potencia en vacío). 2.96 %" ;
    ns1:valor "2.96" .

ns1:PotenciaObjetivoAprendida a ns1:Parametro ;
    rdfs:label "PowerSetPoint" ;
    ns1:documentadoEn ns1:TablaInfoDMC ;
    ns1:textoExtracto "PowerSetPoint (potencia objetivo aprendida). 34.73 %" ;
    ns1:valor "34.73" .

ns1:PotenciaObjetivo_1339 a ns1:Parametro ;
    rdfs:label "Potencia objetivo"@es ;
    ns1:textoExtracto "Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío."@es ;
    ns1:valor "20%"^^xsd:string .

ns1:PrecargaTandem a ns1:Parametro ;
    rdfs:label "Precarga del eje tándem"@es ;
    ns1:textoExtracto "Par previo aplicado a ambos ejes del tándem en sentidos opuestos."@es ;
    ns1:valor "Par previo (sentidos opuestos)"@es .

ns1:ProcedimientoMedicionCabezalAngular_17_2 a ns1:TareaMantenimiento ;
    rdfs:label "Procedimiento de medición con reloj comparador para cabezal angular YZ 45°"@es ;
    ns1:ilustradoEn ns1:EsquemaPosicionamiento_17_2 ;
    ns1:requiereConsumible ns1:CilindroReferencia_17_2 ;
    ns1:requiereMantenimiento ns1:Parametro_TDATA1_17_2 ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de un cabezal angular YZ de 45º (el mismo que el del ejemplo anterior), parámetro TYPE con valor ꞏ6ꞏ. [...] Cómo utilizar el reloj comparador. Cuando sea necesario tocar un cilindro con un reloj comparador, el contacto se debe realizar sobre la línea exterior del cilindro."@es .

ns1:ProcedimientoSeleccionLicencia a ns1:TareaMantenimiento ;
    rdfs:label "Selección manual de unidad de licencia"@es ;
    ns1:solucionaFallo ns1:FalloLicenciaNoEncontrada ;
    ns1:textoExtracto "Pulsar el botón 'Browse' para seleccionar la unidad donde está conectado el pendrive y volver a pulsar el botón 'Ok'."@es .

ns1:Procedimiento_CalculoTDATA2 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA2 con reloj comparador" ;
    ns1:monitoreaParametro ns1:Param_DeltaX ;
    ns1:requiereMantenimiento ns1:Param_TDATA2 ;
    ns1:textoExtracto """\r
    1. Mantener preselección anterior (B=0°, C=0°).\r
    2. Retirar reloj, girar B a 180° y C a 0°.\r
    3. Tocar en punto 2 y apuntar cota CNC (ΔX).\r
    """ .

ns1:Procedimiento_CalculoTDATA5 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA5 con reloj comparador" ;
    ns1:monitoreaParametro ns1:Param_DeltaX ;
    ns1:requiereMantenimiento ns1:Param_TDATA5 ;
    ns1:textoExtracto """\r
    1. Posicionar ejes rotativos B y C en 0°.\r
    2. Colocar reloj en dirección X y tocar cilindro (punto 1).\r
    3. Preseleccionar X=0.\r
    4. Retirar reloj, girar C a 180°, y tocar en punto 2.\r
    5. Apuntar cota CNC (ΔX).\r
    """ .

ns1:ProcesoAjusteTandem_1072 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de ajuste del tándem"@es ;
    ns1:ejecutadoPor ns1:Personal_Tecnico_1072 ;
    ns1:requiereMantenimiento ns1:MaquinaTandem_1072 ;
    ns1:textoExtracto "Pasos a seguir en el ajuste. 1 Mover los dos ejes independientemente [...] 3 Repetir el proceso con el segundo eje"@es .

ns1:ProcesoAjusteTandem_1073 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de ajuste del tándem"@es ;
    ns1:monitoreaParametro ns1:Parametro_ACFGAIN_1073,
        ns1:Parametro_PRELOAD_1073,
        ns1:Parametro_TORQDIST_1073 ;
    ns1:requiereMantenimiento ns1:SistemaTandem_1073 ;
    ns1:textoExtracto "En caso de que los motores sean diferentes, deben ajustarse los ejes de tal manera que la respuesta dinámica sea la misma o similar. [...] Para finalizar, reajustar el lazo de velocidad en ambos motores con el método utilizado normalmente."@es .

ns1:ProcesoCalibracionCabezalAngular_1309 a ns1:TareaMantenimiento ;
    rdfs:label "Calibración del cabezal angular con reloj comparador"@es ;
    ns1:ejecutadoPor ns1:PersonalTecnico_1309 ;
    ns1:requiereMantenimiento ns1:SistemaCNC_1309 ;
    ns1:textoExtracto "Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal. [...] Apuntar la cota que aparece en el CNC (Y)."@es .

ns1:ProcesoCalibracionCabezalAngular_17_1 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de calibración del cabezal angular (17.1)" ;
    ns1:identificador "17.1" ;
    ns1:requiereMantenimiento ns1:SistemaCNC_17_1 ;
    ns1:textoExtracto "B=0º C=0º Z X X=D+2R Segunda palpación. Con el eje rotativo C posicionado en 0º y B en -90º realizar un movimiento de palpación sobre X'. la primera cara X. Anotar la cota que aparece en el CNC, denominada en el dibujo  Tercera palpación. Con el eje rotativo C posicionado en 0º y B en 90º realizar un movimiento de palpación sobre X. la segunda cara X. Anotar la cota que aparece en el CNC, denominada en el dibujo  B=-90º B=90º C=0º C=0º 2 1 2 1 Z X Cálculos matemáticos. Con el cambio de posición respecto al centro de giro ꞏ1ꞏ, el único dato desconocido tras ambos palpaciones es TDATA6. B=0º 1 C=0º TDATA6 cos45 . 2 B=-90º B=90º R C=0º C=0º 2 1 2 1 L D Z TDATA1 TDATA6 cos45 . X" .

ns1:ProcesoCierreSetup a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de cierre del modo SETUP" ;
    ns1:requiereMantenimiento ns1:Contrase_aAcceso ;
    ns1:textoExtracto "Al cerrar la aplicación, el CNC pregunta si se ha finalizado la puesta a punto. • Si se selecciona sí, y existen passwords, el CNC hace la copia de seguridad y pasa a modo USER (proceso correcto). • Si se selecciona sí, y no hay passwords, el CNC saca un mensaje de aviso y no cierra la aplicación." .

ns1:ProcesoParkUnparkPLC a ns1:ModoOperacion ;
    rdfs:label "Proceso de Park/Unpark gestionado desde PLC" ;
    ns1:controla ns1:Se_alPARKEDB ;
    ns1:habilitadoPor ns1:SensorPresenciaEjeB ;
    ns1:textoExtracto "La maniobra de aparcar/desaparcar ejes gestionada desde el programa de PLC se controla mediante la señal PARKED. [...] El CNC utiliza las señales lógicas PARK y UNPARK para informar al PLC que los procesos correspondientes de aparcar o desaparcar se encuentran en ejecución." .

ns1:ProcesoSimulacionTecla a ns1:ModoOperacion ;
    rdfs:label "Proceso de simulación de tecla con mayúsculas"@es ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "545-546" ;
            ns1:textoExtracto "Sección 8.4 Simular el teclado desde el PLC."@es ] ;
    ns1:requiereMantenimiento ns1:ComandoCNCWR_requiereMantenimiento ;
    ns1:textoExtracto "1 Enviar el código asociado a pulsar la tecla [SHIFT]. 2 Enviar el código asociado a pulsar la tecla de la letra. 3 Enviar el código asociado a soltar la tecla [SHIFT]. 4 Enviar el código asociado a soltar la tecla de la letra."@es .

ns1:ProcesoValidacion_CodigoMTB a ns1:Sistema ;
    rdfs:label "Proceso de validación de código para carpeta MTB" ;
    ns1:controla ns1:Carpeta_MTB ;
    ns1:textoExtracto "En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB." .

ns1:Proceso_CalculoTDATA1 a ns1:TareaMantenimiento ;
    rdfs:label "Procedimiento de cálculo de TDATA1 mediante palpación"@es ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1 ;
    ns1:requiereMantenimiento ns1:Sistema_CabezalAngular ;
    ns1:textoExtracto "Primera palpación. Con los ejes rotativos B y C posicionados en 0º realizar un movimiento de palpación sobre la cara Z y preseleccionar la cota Z=0. Segunda palpación. Con el eje rotativo B posicionado en 0º y el eje C en 180º realizar un movimiento de palpación sobre la misma cara. Anotar la cota que aparece en el CNC, denominada en el dibujo Z."@es .

ns1:Proceso_CambioEje a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de cambio de eje/cabezal" ;
    ns1:requiereMantenimiento ns1:Regulador_Ejes ;
    ns1:textoExtracto "El proceso de cambio de un eje o cabezal debe contemplar las siguientes aspectos (suponiendo que el eje X está activo y eje X1 aparcado): 1 Aparcar el eje X. 2 Verificar que el eje X está aparcado. 3 Conmutar al eje X1 (SWITCHX1=1). 4 En caso necesario, escribir los parámetros en el regulador. 5 Cambiar el set y/o la gama en el regulador. 6 Verificar que el cambio de set y/o gama ha terminado. 7 Habilitar el eje X1." .

ns1:Proceso_CambioGama a ns1:ModoOperacion ;
    rdfs:label "Cambio de gama" ;
    ns1:monitoreaParametro ns1:Senal_AUXEND,
        ns1:Senal_GEAR1,
        ns1:Senal_GEAR2,
        ns1:Senal_M1002,
        ns1:Senal_MFUN1,
        ns1:Senal_MSTROBE ;
    ns1:textoExtracto "Comienza el cambio y se lo indica al CNC con AUXEND a (=0). [...] Durante el cambio se le indica al CNC que se deja la gama 1 y que se selecciona la gama 2." .

ns1:Proceso_EscaneoOnline_BusEtherCAT a ns1:TareaMantenimiento ;
    rdfs:label "Escaneo online del bus EtherCAT"@es ;
    ns1:documentadoEn ns1:Interfaz_KPA_EtherCAT_Studio ;
    ns1:textoExtracto "Secuencia de capturas para el escaneo online del bus: selección del adaptador Ethernet, comando contextual 'Scan configuration' sobre el máster que descubre cabeceras, y pestaña 'MDP modules' con acción 'Upload detected Module Ident list'. Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados."@es .

ns1:Proceso_ProteccionCarpetas a ns1:TareaMantenimiento ;
    rdfs:label "Protección/desprotección de carpetas y archivos"@es ;
    ns1:ejecutadoPor ns1:ModoTrabajo_Administrador ;
    ns1:requiereMantenimiento ns1:Interfaz_DiskMonitor ;
    ns1:textoExtracto "permiten proteger o desproteger cualquier carpeta o archivo del sistema que no sea clave para el correcto funcionamiento del control"@es .

ns1:Proceso_ReinicioPorCambioModo a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio del equipo por cambio de modo de trabajo"@es ;
    ns1:textoExtracto "Este proceso implica reiniciar el equipo"@es .

ns1:Proceso_ResetCNC a ns1:ModoOperacion ;
    rdfs:label "Proceso de reset del canal CNC" ;
    ns1:ejecutadoPor ns1:Tecla_RESET ;
    ns1:habilitadoPor ns1:Se_al_RESETIN ;
    ns1:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel" .

ns1:ProgramaFagorEtherCATMapper a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:identificador "Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "Este fichero también lo utiliza el programa \"Fagor EtherCAT Mapper\" para conocer los recursos disponibles en el bus." .

ns1:ProgramaPLC a ns1:Parametro ;
    rdfs:label "Programa PLC"@es ;
    ns1:textoExtracto "por ejemplo, el programa PLC, los parámetros máquina, etc."@es .

ns1:ProgramaPLC_46 a ns1:ComponenteElectrico ;
    rdfs:label "Programa PLC"@es ;
    ns1:documentadoEn ns1:CarpetaMTB_46 ;
    ns1:textoExtracto "el programa PLC"@es .

ns1:ProgramaPLC_614 a ns1:Sistema ;
    rdfs:label "Programa PLC con ficheros en mnemónicos, C y contactos"@es ;
    ns1:compuestoPor ns1:FicheroC_614,
        ns1:FicheroContactos_614,
        ns1:FicheroMnemotecnicos_614,
        ns1:SubrutinaSUMA_614 ;
    ns1:identificador "MTB\\PLC\\PROJECT" ;
    ns1:textoExtracto "El programa de PLC puede combinar varios ficheros en lenguaje de mnemónicos (extensión 'plc'), varios ficheros en lenguaje C (extensión 'c') y un fichero en lenguaje de contactos (extensión 'ld')."@es .

ns1:ProgramaPLC_CNC a ns1:Componente ;
    rdfs:label "Programa PLC del CNC"@es ;
    ns1:textoExtracto "se mantiene la configuración de los [...] programa PLC [...] copia de seguridad de [...] el programa PLC"@es .

ns1:ProgramaPiezaCNC a ns1:Parametro ;
    rdfs:label "Programa pieza CNC" ;
    ns1:monitoreaParametro ns1:LantekExpertInside ;
    ns1:textoExtracto "generar un programa pieza en lenguaje Fagor"@es .

ns1:ProposicionLogica_Ejemplo1 a ns1:Parametro ;
    rdfs:label "Expresión lógica: I32 AND I36 AND M111 = O25"@es ;
    ns1:textoExtracto "I32 AND I36 AND M111 = O25"@es ;
    ns1:valor "I32 AND I36 AND M111 = O25" .

ns1:ProposicionLogica_Ejemplo2 a ns1:Parametro ;
    rdfs:label "Expresión lógica multilineal sin carácter de partición"@es ;
    ns1:textoExtracto """I32 AND I36 AND M111
= O25"""@es ;
    ns1:valor """I32 AND I36 AND M111
= O25""" .

ns1:ProposicionLogica_Ejemplo3 a ns1:Parametro ;
    rdfs:label "Expresión lógica multilineal con saltos de línea"@es ;
    ns1:textoExtracto """I32
AND I36
AND M111
= O25"""@es ;
    ns1:valor """I32
AND I36
AND M111
= O25""" .

ns1:ProposicionLogica_Ejemplo4 a ns1:Parametro ;
    rdfs:label "Expresión lógica multilineal con carácter \"\\\""@es ;
    ns1:textoExtracto """I32\\
AND I36\\
AND M111
= O25"""@es ;
    ns1:valor """I32\\
AND I36\\
AND M111
= O25""" .

ns1:PulsadorActivacionVolante_1251 a ns1:ComponenteElectrico ;
    rdfs:label "Pulsador de activación del volante de avance" ;
    ns1:textoExtracto "Habitualmente esta prestación se activa y desactiva mediante un pulsador externo o una tecla configurada a tal efecto." .

ns1:PulsadorVolante_807 a ns1:InterfazUsuario ;
    rdfs:label "Pulsador de volante"@es ;
    ns1:textoExtracto "Esta marca está orientada a los volantes con pulsador."@es .

ns1:PuntoCambioBrazo a ns1:ModoOperacion ;
    rdfs:label "Punto de cambio del brazo" ;
    ns1:textoExtracto "SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio." .

ns1:PuntoCeroPieza_1096 a ns1:Parametro ;
    rdfs:label "Cero pieza (OW)"@es ;
