    ns1:monitoreaParametro ns1:ParametroSANALOG_Frecuencia ;
    ns1:textoExtracto "Cabezal Mechatrolink. La consigna en SANALOG vendrá expresada en centésimas de hercio." .

ns1:CabezalNormal a ns1:ComponenteMecanico ;
