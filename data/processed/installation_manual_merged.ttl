    ns1:documentadoEn ns1:TablaTecnologica_Piercing ;
    ns1:identificador "Piercing.fst" ;
    ns1:textoExtracto "Esta subrutina debe estar definida en el parámetro general PIERCING (por defecto Piercing.fst) y estará guardada en la carpeta ..\\Mtb\\Sub. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC.",
        "la subrutina Piercing.fst (o la asociada al proceso de piercing) realiza un serie de operaciones con las variables asociadas a las tablas tecnológicas" .

ns1:Subrutina_RupturaSecuencia_443 a ns1:Sistema ;
    rdfs:label "Subrutina de ruptura de secuencia (4.4.3)"@es ;
    ns1:identificador "4.4.3" ;
    ns1:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0). [...] Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina."@es .

ns1:Subrutina_SPD_GMCHG a ns1:ModoOperacion,
        ns1:TareaMantenimiento ;
    rdfs:label "SUB_SPD_GMCHG (Cambio manual de cabezal)"@es,
        "SUB_SPD_GMCHG (Llevar cabezal a punto de cambio manual)"@es,
        "Subrutina SPD_GMCHG"@es,
        "Subrutina SPD_GMCHG (Cambio manual)"@es,
        "Subrutina SPD_GMCHG (Posicionar cabezal para cambio manual)"@es,
        "Subrutina SPD_GMCHG: Llevar cabezal al punto de cambio manual"@es ;
    ns1:ejecutadoPor ns1:RutinaM06 ;
    ns1:habilitadoPor ns1:PuntoCambioManual ;
    ns1:identificador "SUB_SPD_GMCHG" ;
    ns1:textoExtracto "%L SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. G1 Z_ F_ ; Desplazar el cabezal."@es,
        "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es,
        "RET %L SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es .

ns1:Subrutina_SPD_TO_CH2 a ns1:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_CH2 (Coger herramienta con pinza 2)"@es ;
    ns1:identificador "SUB_SPD_TO_CH2" ;
    ns1:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2."@es .

ns1:Subrutina_SPD_TO_MZ a ns1:ModoOperacion,
