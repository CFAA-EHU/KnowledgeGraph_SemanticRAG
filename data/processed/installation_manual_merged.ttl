    ns1:textoExtracto "Cuando el CNC trabaja en cualquier modo de arista matada (G05, G50 o HSC), puede dar error de eje bloqueado en el empalme de bloques" .

ns1:ModoOperacion_AvanceMaximoDiente a ns1:ModoOperacion ;
