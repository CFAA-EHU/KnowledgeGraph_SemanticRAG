ns1:EstructuraModular_PLC a ns1:Sistema ;
    rdfs:label "Estructura modular del programa de PLC"@es ;
    ns1:compuestoPor ns1:ModuloEjecucionPeriodica_PLC,
        ns1:ModuloPrimerCiclo_PLC,
        ns1:ModuloPrincipal_PLC ;
    ns1:textoExtracto "El programa PLC puede estar formado por los siguientes módulos. Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE) y finalizar con la proposición directiva END."@es .

ns1:Etiqueta_L12 a ns1:Parametro ;
    rdfs:label "Etiqueta L12" ;
    ns1:identificador "L12" ;
    ns1:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios." .

ns1:Etiqueta_L123 a ns1:Parametro ;
    rdfs:label "Etiqueta L123" ;
    ns1:identificador "L123" ;
    ns1:textoExtracto "JMP L123 Si la etiqueta se definió como L123." .

ns1:Etiqueta_L234 a ns1:Parametro ;
    rdfs:label "Etiqueta L234" ;
    ns1:identificador "L234" ;
    ns1:textoExtracto "CAL L234 Si se definió como L234." .

ns1:Etiqueta_L5 a ns1:Parametro ;
    rdfs:label "Etiqueta L5" ;
    ns1:identificador "L5" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." .

ns1:Etiqueta_L_ASA2 a ns1:Parametro ;
    rdfs:label "Etiqueta L_ASA2" ;
    ns1:identificador "L_ASA2" ;
    ns1:textoExtracto "JMP L_ASA2 Si la etiqueta se definió como L_ASA2." .

ns1:ExcesoPorcentualDePotenciaDMC a ns1:Parametro ;
    rdfs:label "Exceso porcentual de potencia DMC"@es ;
    ns1:identificador "V.[ch].MPG.DMCPEAKSIZE" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE. Exceso porcentual de potencia, sobre la potencia nominal, para monitorizar los picos de potencia en el DMC."@es ;
    ns1:valor 20 .

ns1:ExportRouterFile a ns1:AccionProhibida ;
    rdfs:label "Export router file" ;
    ns1:ejecutadoPor ns1:Programa ;
    ns1:textoExtracto "Tres acciones ilustradas en capturas de la vista en bloques: (a) 'Export router file' para generar el XML de rutado, (b) 'Generate project' para guardar proyecto *.fem, (c) renombrar y copiar 'resourceRouterConf.xml' a ../Mtb/Data del CNC."@es .

ns1:ExportarArchivoRutado_20_2_7 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de rutado"@es ;
    ns1:identificador "20.2.7" ;
    ns1:textoExtracto "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ns1:ExportarConfiguracionDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Exportar configuración del bus"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_Configurador ;
    ns1:requiereMantenimiento ns1:DeteccionDeModulosEnElBus ;
    ns1:textoExtracto "Un paso previo para exportar la configuración es desaclopar el máster del bus. Para ello, [...] seleccionar la opción 'Detach master'."@es .

ns1:ExportarConfiguracion_1511 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de configuración del máster"@es ;
    ns1:ejecutadoPor ns1:PersonalOperador_1511 ;
    ns1:requiereMantenimiento ns1:SistemaTopologia_1511 ;
    ns1:textoExtracto "Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Export' y 'Export Master Configuration ETG Standard'. Este es el archivo que se debe copiar al CNC."@es .

ns1:FASTFACTORMPG a ns1:Parametro ;
    rdfs:label "FASTFACTOR MPG"@es ;
    ns1:identificador "FASTFACTOR_MPG" ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el"@es .

ns1:FASTFACTORMPG_011b3dd1c9 a ns1:Parametro ;
    rdfs:label "FASTFACTOR MPG" ;
    ns1:identificador "FASTFACTOR MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de avance que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST. Este parámetro indica el valor por defecto; desde el programa pieza se podrá modificar este valor." .

ns1:FASTFILTFREQMPG a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ MPG" ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPag621622 ;
    ns1:identificador "FASTFILTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Este parámetro activa un filtro \"paso bajo\" automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas. Este parámetro introduce un desfase constante, independiente de las frecuencias."@es .

ns1:FBACKDIFFMaximaDiferenciaEntreCaptaciones_bdde406098 a ns1:Parametro ;
    rdfs:label "FBACKDIFF (Máxima diferencia entre captaciones)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:monitoreaParametro ns1:SistemaCaptacionDoble ;
    ns1:textoExtracto "FBACKDIFF Máxima diferencia entre captaciones. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador Sercos posición. Valores posibles: Entre ±99999.9999 mm o grados / entre ±3937.00787 inch. Valor por defecto: 0 (no hay vigilancia). Variable asociada: (V.)[ch].MPA.FBACKDIFF.xn Parámetro incluido en la tabla SERCOSDATA."@es ;
    ns1:valor "0" .

ns1:FBACKSRCCambioDeCaptacion a ns1:Parametro ;
    rdfs:label "FBACKSRC (cambio de captación)" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Tampoco se permite el cambio de captación (parámetro FBACKSRC)." .

ns1:FBMIXTIMEConstanteDeTiempoParaCaptacionMixta_e24044afef a ns1:Parametro ;
    rdfs:label "FBMIXTIME (Constante de tiempo para captación mixta)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:monitoreaParametro ns1:SistemaCaptacionDoble ;
    ns1:textoExtracto "FBMIXTIME Constante de tiempo para la captación mixta. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 3200.0 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.FBMIXTIME.xn Parámetro incluido en la tabla SERCOSDATA."@es ;
    ns1:valor "0" .

ns1:FBMIXTIMEMezclaDeCaptaciones a ns1:Parametro ;
    rdfs:label "FBMIXTIME (mezcla de captaciones)" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "No se permite segunda captación, por lo que no es posible la mezcla de captaciones (parámetro FBMIXTIME)." .

ns1:FCASControlDeColisiones a ns1:Parametro ;
    rdfs:label "FCAS (control de colisiones)" ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ns1:FEDYNFACFactorDinamico_8a1ac97b85 a ns1:Parametro ;
    rdfs:label "FEDYNFAC (factor dinámico)" ;
    ns1:ilustradoEn ns1:Figura_BandaErrorSeguimiento ;
    ns1:textoExtracto "límites proporcionales a F (pendiente ±%FEDYNFAC)" .

ns1:FEEDNDAvanceProgramadoEnTodosLosEjes_46d1be174f a ns1:Parametro ;
    rdfs:label "FEEDND Avance programado en todos los ejes"@es ;
    ns1:textoExtracto "FEEDND Aplicar el avance programado a todos los ejes del canal. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FEEDND Este parámetro indica si el avance programado se aplica a todos los ejes del canal o sólo a los ejes principales."@es ;
    ns1:valor "No" .

ns1:FGUIMProgramaDePersonalizacionDelCNC a ns1:Herramienta ;
    rdfs:label "FGUIM (Programa de personalización del CNC)"@es ;
    ns1:documentadoEn ns1:Manual_CNC8070 ;
    ns1:identificador "FGUIM" ;
    ns1:textoExtracto "El fabricante también puede personalizar el aspecto del CNC mediante el programa de personalización FGUIM."@es .

ns1:FINALSUBCHN a ns1:Parametro ;
    rdfs:label "FINALSUB CHN" ;
    ns1:identificador "FINALSUB CHN" ;
    ns1:monitoreaParametro ns1:Subrutina_Finalsub_fst ;
    ns1:textoExtracto "FINALSUB CHN | Subrutina asociada al comando #FINALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:FRAPIDENEje_4182880c04 a ns1:Parametro ;
    rdfs:label "FRAPIDEN (eje)"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:textoExtracto "FRAPIDEN (eje)"@es ;
    ns1:valor 6000 .

ns1:FREE a ns1:Sensor ;
    rdfs:label "FREE" ;
    ns1:textoExtracto "FREE Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. FREEC1 FREEC2 FREEC3 FREEC4 El canal del CNC pone esta señal a (=1) para indicar al PLC que está listo para aceptar un nuevo bloque, enviado mediante el comando CNCEX." .

ns1:FREQRESMPG a ns1:Parametro ;
    rdfs:label "FREQRES MPG" ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPag621622 ;
    ns1:identificador "FREQRES MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_CONTERROR ;
    ns1:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR."@es .

ns1:FSMOOTHFREQMPG a ns1:Parametro ;
    rdfs:label "FSMOOTHFREQ MPG" ;
    ns1:identificador "FSMOOTHFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para el modo HSC FAST. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada." .

ns1:FTIMELIMMPG a ns1:Parametro ;
    rdfs:label "FTIMELIM MPG" ;
    ns1:identificador "FTIMELIM MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo. Si se programa con valor 0, el CNC no realiza la interpolación del avance y por tanto la ejecución es más rápida. Al aumentar el valor de este parámetro, aumenta el tiempo máximo permitido de ejecución total; por ejemplo, un valor de 200% o 300% permitirá hasta el doble o triple de tiempo de ejecución en el tramo interpolado." .

ns1:FZMAXAvanceMaximoEnDMC_e0df84e9ed a ns1:Parametro ;
    rdfs:label "FZMAX (Avance máximo en DMC)"@es ;
    ns1:monitoreaParametro ns1:DynamicMillingControlDMC_d3a9d7e9e3 ;
    ns1:textoExtracto "FZMAX{feed}"@es .

ns1:FZMAXAvanceMaximoPorDienteEnDMC a ns1:Parametro ;
    rdfs:label "FZMAX (avance máximo por diente en DMC)"@es ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC. • Opcional; si no se programa o FZMIN > FZMAX, el CNC no vigila el avance máximo por diente. • Valores: 0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente."@es ;
    ns1:valor "0 — 99999.9999 mm/diente" .

ns1:FZMINAvanceMinimoEnDMC_16eb08b8b6 a ns1:Parametro ;
    rdfs:label "FZMIN (Avance mínimo en DMC)"@es ;
    ns1:monitoreaParametro ns1:DynamicMillingControlDMC_d3a9d7e9e3 ;
    ns1:textoExtracto "FZMIN{feed}"@es .

ns1:FactorDeConversionMAADecimiliamperios a ns1:Parametro ;
    rdfs:label "Factor de conversión (mA a decimiliamperios)" ;
    ns1:textoExtracto "Factor = 200 / 32767 = 0,0061035 (para devolver el valor en decimiliamperios)" ;
    ns1:valor "0.0061035" .

ns1:FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:documentadoEn <http://www.fagorautomation.com/en/downloads/> ;
    ns1:textoExtracto "disponible en la zona de descargas del sitio web corporativo de Fagor Automation." .

ns1:FagorEtherCATMapper1 a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper 1" ;
    ns1:textoExtracto "Vista general del 'Fagor EtherCAT Mapper': captura con (A) barra de iconos y nombre del ENI cargado, (B) barra de configuración por defecto (fichas de entradas/salidas y registros), (C) validación 'Overlapped', (D) topología en árbol, y (E) topología en bloques. Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." .

ns1:FagorSuministraLaSubrutinaSubProbeToolBeginFstAsociadaALaEntradaDePalpador1 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Fagor suministra la subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1" .

ns1:Fagor_EtherCAT_Mapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:documentadoEn ns1:Manual_Q7_A ;
    ns1:identificador "Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "Este fichero también lo utiliza el programa \"Fagor EtherCAT Mapper\" para conocer los recursos disponibles en el bus." .

ns1:Fase_AprendizajeDMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje DMC" ;
    ns1:requiereMantenimiento ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "repetir la fase de aprendizaje [...] Durante la fase de aprendizaje, el DMC no cuenta como tiempo de aprendizaje el tiempo que dure la causa de desactivación." .

ns1:Fase_EjecucionVacio a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución en vacío" ;
    ns1:requiereMantenimiento ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Durante la ejecución en vacío, el DMC se desactiva, pero seguirá detectando las entradas a la pieza." .

ns1:FeedForward a ns1:Parametro ;
    rdfs:label "Feed forward" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual; es decir, los parámetros FFGAIN y MANFFGAIN deberían ser iguales." ;
    ns1:valor "FeedForward" .

ns1:FeedForward_f810ce85d2 a ns1:Parametro ;
    rdfs:label "Feed forward"@es ;
    ns1:textoExtracto "El feed forward [...] lo aplica el CNC."@es .

ns1:FeedOverride a ns1:Parametro ;
    rdfs:label "Feed override" ;
    ns1:monitoreaParametro ns1:KEYBD21 ;
    ns1:textoExtracto "Selector del feed override (KEYBD2_1 a KEYBD2_8)." .

ns1:Feedback_CaptacionEje a ns1:Parametro ;
    rdfs:label "Feedback de captación del eje (interna/externamente)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "Feedback: Indica si la escritura del parámetro en el drive está condicionada por el tipo de captación del eje, interna o externa."@es .

ns1:FguimHerramientaDePersonalizacionDePantallas a ns1:Herramienta ;
    rdfs:label "Fguim (herramienta de personalización de pantallas)"@es ;
    ns1:textoExtracto "archivos modificados mediante la herramienta de personalización de pantallas (Fguim)."@es .

ns1:FicheroCSV_Compensacion a ns1:InterfazUsuario ;
    rdfs:label "Fichero CSV de compensación volumétrica" ;
    ns1:identificador "CSV_VOLCOMP" ;
    ns1:textoExtracto "Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos." .

ns1:FicheroCompensacionVolumetrica a ns1:Consumible ;
    rdfs:label "Fichero de compensación volumétrica" ;
    ns1:textoExtracto "El fichero de definición de la compensación volumétrica no contiene los datos adecuados. [...] El fichero no es del tipo csv." .

ns1:FicheroDatosCompensacion a ns1:InterfazUsuario ;
    rdfs:label "Fichero de datos de compensación" ;
    ns1:requiereMantenimiento ns1:CompensacionVolumetrica_Basica,
        ns1:CompensacionVolumetrica_Grande,
        ns1:CompensacionVolumetrica_Media ;
    ns1:textoExtracto "El OEM debe seleccionar el fichero que contiene los datos de la compensación." .

ns1:FicheroImportacion_117 a ns1:InterfazUsuario ;
    rdfs:label "Fichero de texto para importación de tablas"@es ;
    ns1:textoExtracto "adaptar el formato de un fichero de texto en el que esté guardado el resultado de la medición y posteriormente importarlo."@es .

ns1:Fichero_ENI a ns1:Componente ;
    rdfs:label "Fichero ENI (fagor_ethercatConfFile.xml)" ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "El configurador de la topología genera el fichero ENI que contiene la información de los dispositivos EtherCAT conectados al CNC. Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"fagor_ethercatConfFile.xml\"." .

ns1:Fichero_pcall_txt a ns1:InterfazUsuario ;
    rdfs:label "Fichero pcall.txt"@es ;
    ns1:identificador "pcall.txt" ;
    ns1:textoExtracto "la lista pcall.txt mostrará los nombres de subrutinas contenidos en ambos"@es .

ns1:Fichero_resourceRouterConf_xml a ns1:Sistema ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:documentadoEn ns1:Pagina_748 ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:textoExtracto "Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"resourceRouterConf.xml\"." .

ns1:Figura_AvanceVsErrorSeguimiento a ns1:Figura ;
    rdfs:label "Gráfico de avance real vs. error de seguimiento"@es ;
    ns1:ilustradoEn ns1:GananciaProporcionalPROGAIN ;
    ns1:textoExtracto "gráfico con fondo cuadriculado que muestra 'Actual Feed' (avance real) y 'Following Error (E)' (error de seguimiento) durante una maniobra de aceleración y parada."@es .

ns1:Figura_ConvencionManosTDATA38 a ns1:Figura ;
    rdfs:label "Ilustración de convención de mano derecha para TDATA38" ;
    ns1:ilustradoEn ns1:ConvencionDeGiroDelEjeRotativoPrincipalDeLaMesaTDATA38 ;
    ns1:textoExtracto "Ilustraciones de mano con ejes para sentido de giro del eje rotativo principal de la mesa (TDATA38), reforzando la convención de la mano derecha para signos y direcciones." .

ns1:Figura_DiagramaRTCP a ns1:Figura ;
    rdfs:label "Diagrama comparativo de origen RTCP (cero máquina vs. cero pieza)" ;
    ns1:ilustradoEn ns1:DefinicionVectorialDeCinematicasCabezalMesaTipo52 ;
    ns1:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero máquina (C=0°) frente a cero pieza (C'=0°). Se muestran sistemas X-Y y X'-Y', marcando equivalencias X=X', Y=Y' en cada caso." .

ns1:Figura_HisteresisInversion a ns1:Figura ;
    rdfs:label "Diagrama temporal de histéresis REVEHYST"@es ;
    ns1:ilustradoEn ns1:HisteresisDeInversionREVEHYST ;
    ns1:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. Se marcan con flechas los instantes de inversión de consigna (1), el umbral REVEHYST que habilita la compensación de holgura (2) y la cancelación de la compensación (3)."@es .

ns1:Figura_RespuestaMaquina a ns1:Figura ;
    rdfs:label "Gráfico de respuesta de máquina (amplitud vs. frecuencia)"@es ;
    ns1:ilustradoEn ns1:AmplitudBaseAo,
        ns1:FrecuenciaDeResonanciaFr,
        ns1:Parametro_1c8fe3af19,
        ns1:SobrepasamientoEnResonanciaAr ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr), acompañado de la fórmula SHARE=100(Ar–Ao)/Ar."@es .

ns1:Figura_Tarjetas8DI a ns1:Figura ;
    rdfs:label "Tarjetas 8DI agrupadas en módulos" ;
    ns1:ilustradoEn ns1:Nodo_RIO5,
        ns1:Nodo_RIOW ;
    ns1:textoExtracto "Se muestran múltiples tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8), velocidades y dirección." .

ns1:Figura_TransformacionEjeInclinado a ns1:Figura ;
    rdfs:label "Esquema de transformación angular en torno (eje X' inclinado)" ;
    ns1:ilustradoEn ns1:TransformacionAngularDeEjeInclinadoEnTorno ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad" .

ns1:FiltroDeSuavizadoDeTrayectoria a ns1:Parametro ;
    rdfs:label "Filtro de suavizado de trayectoria"@es ;
    ns1:identificador "FiltroSuavizado" ;
    ns1:textoExtracto "Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado. Este parámetro introduce un desfase no constante, dependiente de las frecuencias."@es .

ns1:FiltroDelSensorGAP a ns1:Parametro ;
    rdfs:label "Filtro del sensor GAP"@es ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER."@es .

ns1:FiltroDesfaseNoConstante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro con desfase no constante" ;
    ns1:textoExtracto "tipo de filtro introduce un desfase no constante, dependiente de las frecuencias. Este desfase puede provocar que la trayectoria se modifique si no se ejecuta al mismo avance, como por ejemplo, al cambiar el porcentaje de avance o al ir y volver por la misma trayectoria." .

ns1:FiltroPasoBajoFAGOR a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ns1:monitoreaParametro ns1:ORDEROrdenDelFiltro ;
    ns1:textoExtracto "El filtro \"paso bajo FAGOR\" introduce un desfase constante, independiente de la frecuencia. Este tipo de filtro necesita mayor orden para tener el mismo nivel de filtrado." .

ns1:FiltrosDeSuavizadoDeTrayectoria a ns1:Parametro ;
    rdfs:label "Filtros de suavizado de trayectoria" ;
    ns1:textoExtracto "la activación de filtros para suavizar la trayectoria es innecesaria. Al no tener filtros, la pieza tendrá más precisión ya que la trayectoria pasa por los puntos programados." .

ns1:FinDeTratamientoDeBloqueUnico a ns1:AccionProhibida ;
    rdfs:label "Fin de tratamiento de bloque único" ;
    ns1:textoExtracto "#DSBLK ; Fin de tratamiento de bloque único." .

ns1:FormatoArchivo_ECSN a ns1:Parametro ;
    rdfs:label "Formato *.ecsn"@es ;
    ns1:textoExtracto "Guardar el proyecto con cualquier nombre (extensión *.ecsn)"@es ;
    ns1:valor "*.ecsn" .

ns1:FormatoDeDatosSSI a ns1:Parametro ;
    rdfs:label "Formato de datos SSI"@es ;
    ns1:documentadoEn ns1:Tabla_FormatoDatosSSI ;
    ns1:textoExtracto "Los datos llegan en formato binario o Gray Code según valor 0 o 1."@es ;
    ns1:valor 0 .

ns1:FrecuenciaCentralFREQUENCY_7e9d666f55 a ns1:Parametro ;
    rdfs:label "Frecuencia central (FREQUENCY)"@es ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es ;
    ns1:valor "FREQUENCY" .

ns1:FrecuenciaCentral_Notch a ns1:Frecuencia ;
    rdfs:label "Frecuencia central del filtro notch"@es ;
    ns1:monitoreaParametro ns1:Filtro_Notch_Antirresonante ;
    ns1:textoExtracto "frecuencia central (FREQUENCY)"@es ;
    ns1:valor "FREQUENCY" .

ns1:FrecuenciaCorte_PasoBajo a ns1:Frecuencia ;
    rdfs:label "Frecuencia de corte (–3 dB) del filtro paso bajo"@es ;
    ns1:monitoreaParametro ns1:Filtro_PasoBajo ;
    ns1:textoExtracto "caída a partir de la frecuencia de corte 'FREQUENCY', con marca de –3 dB (0,707·Ao)"@es ;
    ns1:valor "FREQUENCY" .

ns1:FrecuenciaDeResonancia a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia"@es ;
    ns1:monitoreaParametro ns1:FiltroPasoBajo_404 ;
    ns1:textoExtracto "frecuencia"@es .

ns1:FrecuenciaDeSuavizadoEnInterpolacionFSMOOTHFREQ_ea04203bca a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en interpolación (FSMOOTHFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST,
        ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "FSMOOTHFREQ Frecuencia de suavizado en la interpolación (modo FAST y SURFACE). Valores posibles: De 0 a 500.0000. Valor por defecto: 20. [...] fija la frecuencia de suavizado en la interpolación de trayectorias para los modos HSC FAST y SURFACE." ;
    ns1:valor "20.0"^^xsd:float .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacionDeTrayectorias a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación de trayectorias" ;
    ns1:identificador "MPG.SMOOTHFREQ" ;
    ns1:mitigaRiesgo ns1:ModoHSC ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada." .

ns1:FrecuenciaDelFiltroDeEjesSURFFILTFREQ_3405b615dc a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de ejes (SURFFILTFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "SURFFILTFREQ Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." ;
    ns1:valor "25.0"^^xsd:float .

ns1:FrecuenciaDelFiltroEnElModoCONTERROR a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro en el modo CONTERROR" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:mitigaRiesgo ns1:ModoHSC ;
    ns1:textoExtracto "Este parámetro fija la frecuencia del filtro en el modo CONTERROR. Este parámetro es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado, que es el perfil de aceleración por defecto para el modo HSC CONTERROR." .

ns1:FrecuenciaDelFiltroFASTFILTFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro (FASTFILTFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "FASTFILTFREQ Frecuencia del filtro (modo FAST). Valores posibles: De 0 a 500.0000. Valor por defecto: 17. [...] activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST." ;
    ns1:valor "17.0"^^xsd:float .

ns1:Frecuencia_8ms a ns1:Frecuencia ;
    rdfs:label "Frecuencia de ejecución (8 ms)" ;
    ns1:textoExtracto "con un periodo de muestreo LOOPTIME = 4 ms y una periodicidad PRGFREQ = 2, el programa de PLC se ejecutará cada 4 x 2 = 8 ms" ;
    ns1:tieneFrecuencia ns1:Sistema_PLC ;
    ns1:valor "8 ms" .

ns1:Frecuencia_Suavizado a ns1:Frecuencia ;
    rdfs:label "Frecuencia de suavizado" ;
    ns1:textoExtracto "Al activar la frecuencia de suavizado se generan perfiles de velocidad y aceleración más suaves, pero aumenta el tiempo de ejecución." .

ns1:FrequencyFrecuenciaDeCorte a ns1:Parametro ;
    rdfs:label "Frequency (Frecuencia de corte)" ;
    ns1:documentadoEn ns1:Tabla_GAPSENSORFILTER ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "FREQUENCY Frecuencia de corte. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 30.0000 Hz. Variable asociada: (V.)MPG.FREQUENCY" ;
    ns1:valor "30.0000" .

