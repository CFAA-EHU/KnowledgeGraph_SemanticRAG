ns1:Parametro_TDATA50 a ns1:Parametro ;
    rdfs:label "TDATA50 (Origen para RTCP)"@es ;
    ns1:identificador "TDATA50" ;
    ns1:textoExtracto "TDATA50 | A elegir.",
        "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA40."@es ;
    ns1:valor "0",
