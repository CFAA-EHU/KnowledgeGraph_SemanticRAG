    rdfs:label "AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "AUXEND [...] Hay una marca para cada canal." .

ns1:Parametro_2d27f3155b a ns1:Parametro ;
    rdfs:label "MANACFGAIN" ;
    ns1:identificador "(V.)[ch].MPA.MANACFGAIN[set].xn" ;
    ns1:solucionaFallo ns1:ErrorSeguimiento_Aceleracion ;
    ns1:textoExtracto "MANACFGAIN Porcentaje de AC-Forward en manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0." ;
    ns1:valor "0-120%",
        "0"^^ns1:default .

ns1:Parametro_2d5e80da47 a ns1:Parametro ;
    rdfs:label "Parámetro de entrada Variable (HBH3/HBH4)" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 siempre tendrá valor ꞏ1ꞏ." ;
    ns1:valor "1" .

ns1:Parametro_2d72adcabf a ns1:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ns1:identificador "SSIPACKFORMAT" ;
    ns1:textoExtracto "Orden en el que los datos son enviados por el encoder. Si primero nos va llegar la cota, el CRC o la alarma y que orden hay entre ellos. Si hay bits de start programados, se considera que siempre van a recibirse los primeros." .

ns1:Parametro_2d9a296519 a ns1:Parametro ;
    rdfs:label "LFEED" ;
    ns1:documentadoEn ns1:Tabla_248_CondicionesDefectoCanal ;
    ns1:identificador "LFEED" ;
    ns1:monitoreaParametro ns1:Sistema_ControlMovimiento ;
    ns1:textoExtracto "LFEED Velocidad de cambio de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales."@es ;
    ns1:valor "0 a 100000.0000 rpm",
        "0 a 200000.0000 mm/min",
        "0 a 36000000.0000 grados/min",
        "0 a 7874.01575 inch/min" .

ns1:Parametro_2e031ef682 a ns1:Parametro ;
    ns1:identificador "Vector2553" ;
    ns1:textoExtracto "vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección)"@en .

ns1:Parametro_2e2d99f03e a ns1:Parametro ;
    rdfs:label "BAKANOUT" ;
    ns1:textoExtracto "cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto. Cuando se define un impulso adicional de consigna también hay que definir los parámetros BAKTIME, ACTBAKAN y PEAKDISP." ;
    ns1:valor "- (negativo)" .

ns1:Parametro_2e46680eb2 a ns1:Parametro ;
