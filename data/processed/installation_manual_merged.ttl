    ns1:identificador "$1D (pulsar) / $9D (soltar)" ;
    ns1:textoExtracto "Control (CTRL)."@es .

ns1:Tecla_ESC a ns1:InterfazUsuario ;
    rdfs:label "Tecla [ESC]" ;
    ns1:textoExtracto "En cada componente, la tecla [ESC] primero sube de menú hasta alcanzar el menú principal del componente." .

ns1:Tecla_NEXT a ns1:InterfazUsuario ;
    rdfs:label "Tecla NEXT" ;
    ns1:textoExtracto "Configuración del teclado (tecla [NEXT])."@es ;
    ns1:tieneComponente ns1:Menu_Configuracion_NEXT .

ns1:Tecla_Retroceso a ns1:Componente ;
    rdfs:label "Tecla Retroceso (Backspace)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosTecla_Espanol ;
    ns1:identificador "$0E (pulsar) / $8E (soltar)" ;
    ns1:textoExtracto "Retroceso (backspace)."@es .

ns1:Tecla_USER13 a ns1:ComponenteElectrico,
        ns1:InterfazUsuario ;
    rdfs:label "Tecla USER13",
        "Tecla USER13 (desactivación emergencia)"@es ;
    ns1:controla ns1:SenalEmergencia_TMINEM ;
    ns1:identificador "USER13" ;
    ns1:solucionaFallo ns1:EmergenciaGestor ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia.",
        "Si se pulsa la tecla USER13 se quita la emergencia."@es .

ns1:TecladoJogSimulado a ns1:InterfazUsuario ;
    rdfs:label "Teclado de JOG simulado" ;
    ns1:habilitadoPor ns1:SIMJOGPANEL ;
    ns1:textoExtracto "Se denomina Teclado de JOG simulado a una ventana que se superpone a la pantalla del CNC y que permite simular las teclas de JOG y las teclas de acceso a los modos de trabajo." .

ns1:TecladoKEYBD1CH a ns1:InterfazUsuario ;
    rdfs:label "Configuración teclado KEYBD1CH" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales. [...] KEYBD1CH" .

ns1:TecladoKEYBD8CH a ns1:InterfazUsuario ;
    rdfs:label "Configuración teclado KEYBD8CH" ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "Estos registros podrán asociar un panel de jog a un canal en concreto. [...] KEYBD8CH" .

ns1:Teclado_LCD_10K_Ejemplo6 a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K (Ejemplo 6: Jog + USERKEYS)" ;
    ns1:ilustradoEn ns1:Esquema_JogKeys_USERKEYS ;
    ns1:textoExtracto "Diagrama mixto con bloque 'JOGKEYS' (X+, Y+, R, X−, Y−) y bloque 'USERKEYS' (4, 5, +, −). Muestra una estrategia híbrida donde las teclas de usuario asumen funciones de jog para ejes adicionales y sentidos, integrándose con las teclas de jog nativas." .

ns1:TeclasIluminablesKEYLED a ns1:ComponenteElectrico ;
    rdfs:label "Teclas con iluminación KEYLED2/KEYLEDHBLS"@es ;
    ns1:textoExtracto "grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS"@es ;
    ns1:tieneComponente ns1:ModuloOP_PANEL_H_E .

ns1:TeclasUsuario_JOGKEYS a ns1:InterfazUsuario ;
    rdfs:label "Teclas de usuario (JOGKEYS) 1-16" ;
    ns1:documentadoEn ns1:Manual_OPENPCS_15_4 ;
    ns1:ilustradoEn ns1:EsquemaJOGKEYS ;
    ns1:textoExtracto "Esquema compacto de 'Teclas de usuario' tratadas como teclas de jog. Se representa una banda de teclas numeradas (1, 2, …, 15, 16) bajo la leyenda 'JOGKEYS'." .

ns1:Temporizador_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador (genérico)"@es ;
    ns1:textoExtracto "Todos los temporizadores disponen de la salida de estado T y de las entradas TEN, TRS, TG1, TG2, TG3 y TG4. También es posible consultar en cualquier momento el tiempo t que lleva transcurrido desde que se activó el temporizador."@es ;
    ns1:tieneComponente ns1:Entrada_TEN,
        ns1:Entrada_TG1,
        ns1:Entrada_TG2,
        ns1:Entrada_TG3,
        ns1:Entrada_TG4,
        ns1:Entrada_TRS,
        ns1:SalidaEstado_T .

ns1:Temporizador_T123 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T123" ;
    ns1:identificador "T123" ;
    ns1:monitoreaParametro ns1:Marca_M100 ;
    ns1:textoExtracto "T123 coincide con la salida de estado [...] Su representación T123 coincide con la salida de estado pero se utilizan en instrucciones de tipo distinto." .

ns1:Temporizador_T20 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T20" ;
    ns1:identificador "T20" ;
    ns1:textoExtracto "Activa el temporizador T20 en modo monoestable (TG1) con una constante de tiempo de 100 ms." ;
    ns1:tieneFrecuencia ns1:ModoOperacion_TG1 .

ns1:Temporizador_T22 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T22" ;
    ns1:identificador "T22" ;
    ns1:monitoreaParametro ns1:Registro_R200 ;
    ns1:textoExtracto "Activa el temporizador T22 en modo de retardo a la conexión (TG2) con la constante de tiempo que fija el valor del registro R200, en ms." ;
    ns1:tieneFrecuencia ns1:ModoOperacion_TG2 .

ns1:Temporizador_T4 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T4"@es ;
    ns1:identificador "T4" ;
    ns1:textoExtracto "entrada de arranque TG1 del temporizador T4"@es .

