    ns1:valor "1...1017" .

ns1:Directiva_RET_738 a ns1:Directiva ;
    rdfs:label "Directiva RET"@es ;
    ns1:identificador "RET" ;
    ns1:textoExtracto "RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es '0', será ignorada por el PLC."@es .

