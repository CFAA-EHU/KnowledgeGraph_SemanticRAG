ns1:CalibracionPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Calibración del palpador"@es ;
    ns1:textoExtracto "el palpador debe estar correctamente calibrado"@es .

ns1:Comando_CAM_ON a ns1:InterfazUsuario ;
    rdfs:label "CAM ON"@es ;
    ns1:habilitadoPor ns1:LevaElectronica_Archivo ;
    ns1:identificador "#CAM ON (CNC) / CAM ON (PLC)"@es ;
    ns1:textoExtracto "para activarla, utilizar la sentencia #CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)"@es .

ns1:CompensacionVolumetrica_1 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica 1 (VOLCOMP1)"@es ;
    ns1:identificador "VOLCOMP1" ;
    ns1:textoExtracto "primera compensación volumétrica (parámetro VOLCOMP1)"@es .

ns1:CompensacionVolumetrica_2 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica 2 (VOLCOMP2)"@es ;
    ns1:identificador "VOLCOMP2" ;
    ns1:textoExtracto "segunda compensación volumétrica"@es .

ns1:CompensacionVolumetrica_Grande a ns1:ModoOperacion,
        ns1:Parametro ;
    rdfs:label "Compensación volumétrica grande" ;
    ns1:identificador "Compensación volumétrica grande" ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande.",
        "• Volumen a compensar más de 10 m³ (grande). • Esta compensación corrige los 21 componentes del error geométrico (traslación, rotación y cuadratura). • Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. • El OEM sólo debe definir en los parámetros máquina los ejes a compensar y seleccionar el fichero que contiene los datos de la calibración. • La compensación media y grande son más precisas que la básica, pero son más lentas de calibrar." .

ns1:CompensacionVolumetrica_Media a ns1:ModoOperacion,
        ns1:Parametro ;
    rdfs:label "Compensación volumétrica media" ;
    ns1:identificador "Compensación volumétrica media" ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande.",
        "• Volumen a compensar hasta 10 m³ (media). • Esta compensación corrige los 21 componentes del error geométrico (traslación, rotación y cuadratura). • Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. • El OEM sólo debe definir en los parámetros máquina los ejes a compensar y seleccionar el fichero que contiene los datos de la calibración. • La compensación media y grande son más precisas que la básica, pero son más lentas de calibrar." .

ns1:ComponenteCaptacionMotor a ns1:Sensor ;
    rdfs:label "Sensor de captación interna (motor)"@es ;
    ns1:textoExtracto "captación interna (captación motor)"@es .

ns1:ComponenteMecanico_CilindroPatron a ns1:ComponenteMecanico ;
    rdfs:label "Cilindro patrón"@es ;
    ns1:textoExtracto "cilindro patrón montado en el cabezal"@es .

ns1:ComponenteMecanico_Husillo a ns1:ComponenteMecanico ;
    rdfs:label "Husillo (eje con posible holgura)"@es,
        "Husillo del cabezal angular"@es ;
    ns1:textoExtracto "Normalmente ocurre en ejes con encoder y en máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)."@es,
        "husillo"@es .

ns1:Componente_EjeB a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo B",
        "Eje rotativo B"@es ;
    ns1:identificador "B" ;
    ns1:textoExtracto "Eje B posicionable en 0° o 180° para cálculos con reloj comparador.",
        "eje rotativo B"@es .

ns1:Componente_EntradaCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación de eje analógico" ;
    ns1:textoExtracto "Configurar la entrada de captación del eje. Las entradas de captación para un eje analógico podrán estar situadas en los módulos remotos, en un regulador Sercos o de forma local en la propia unidad central." .

ns1:Componente_SensorEncoderCaptacionExterna a ns1:Sensor ;
    rdfs:label "Encoder de captación externa" ;
    ns1:textoExtracto "Número de impulsos del encoder (captación externa). Si se emplea un reductor en el eje se deberá tener en cuenta todo el conjunto al definir el número de impulsos por vuelta." .

ns1:Comunicacion_PLC_Gestor_7_3_2 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-Gestor (Sección 7.3.2)"@es ;
    ns1:identificador "7.3.2" ;
    ns1:textoExtracto "El PLC utiliza las siguientes marcas para informar al gestor de las operaciones que ha realizado. [...] Tras finalizar cada una de ellas debe informar al gestor, activando unas marcas, de que la acción ha finalizado."@es .

ns1:ConfiguracionEjes_1043 a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo plano (G18)"@es ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "Con una configuración de ejes tipo plano, siempre está activo el plano G18; en este caso el plano ZX. Las funciones G17 y G19 no son válidas."@es .

ns1:ConfiguracionEjes_Torno2Canales4Ejes2Cabezales a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes para torno con 2 canales, 4 ejes y 2 cabezales" ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ y ꞏ2ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas. Cómo sólo hay dos ejes, la función G20 no tiene sentido." .

ns1:ConfiguradorTopologiaKPA_EtherCAT_Studio a ns1:Sistema ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:identificador "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Fagor suministra bajo licencia el configurador \"KPA EtherCAT Studio\" (de Koening-pa GmbH), que puede funcionar tanto en modo online como offline; en ambos casos es necesaria la licencia." .

ns1:ConsignaAnalogica a ns1:Parametro ;
    ns1:textoExtracto "La consigna para un eje analógico se puede tomar desde una salida analógica de los módulos remotos, de un regulador Sercos o de una contadora Sercos." .

ns1:Contrase_aAcceso a ns1:Parametro ;
    rdfs:label "Contraseña de acceso" ;
    ns1:textoExtracto "Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .

ns1:ControlGapLaser a ns1:ModoOperacion ;
    rdfs:label "Control del gap láser"@es ;
    ns1:identificador "#GAPCTRL" ;
    ns1:textoExtracto "Una vez detectada la pieza, el CNC mantendrá el gap definido, incluso si detecta la pieza justo al ejecutar #GAPCTRL, sin empezar a bajar. Durante el movimiento de aproximación, el CNC permite detener el movimiento (señales _STOP o _FEEDHOL). En este caso el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento."@es .

ns1:DIN66217 a ns1:Directiva ;
    rdfs:label "DIN 66217",
        "Norma DIN 66217" ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." .

ns1:DMCPEAKSIZE a ns1:Parametro ;
    rdfs:label "DMCPEAKSIZE" ;
    ns1:identificador "(V.)[ch].MPG.DMCPEAKSIZE",
        "DMCPEAKSIZE" ;
    ns1:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %.",
        "porcentaje definido en el parámetro DMCPEAKSIZE" ;
    ns1:valor "20" .

ns1:DMC_ControlDinamicoMecanizado a ns1:ModoOperacion ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)"@es ;
    ns1:identificador "DMC" ;
    ns1:monitoreaParametro ns1:PotenciaCorte_Parametro ;
    ns1:textoExtracto "El DMC (control dinámico del mecanizado) adapta el avance durante el mecanizado para mantener la potencia de corte lo más cercana posible a las condiciones idóneas de mecanizado. [...] Esta función se puede aplicar a operaciones de desbaste y acabado, pero será en operaciones de desbaste donde esta función aporte mayores beneficios en tiempo de mecanizado y vida de herramienta."@es .

ns1:DMC_ModoOperacion_1327 a ns1:ModoOperacion ;
    rdfs:label "DMC (Dynamic Machining Control)"@es ;
    ns1:textoExtracto """\r
    de herramienta, el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey "Aprendizaje DMC".\r
    Comportamiento del DMC tras ser desactivado. Las trayectorias en G0, parada de ejes con [STOP] y la softkey "Set DMC off" desactivan temporalmente DMC.\r
    """@es .

ns1:DialogoFinalizacionPuestaPunto a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de finalización de puesta a punto" ;
    ns1:controla ns1:ModoUsuario ;
    ns1:textoExtracto "el CNC muestra un segundo diálogo preguntando si se ha finalizado con la puesta a punto. Con la opción 'NO', la próxima vez que se encienda el equipo volverá a arrancar en el modo setup. Con la opción 'SÍ', el CNC hace una copia de seguridad de la carpeta MTB y la próxima vez que se encienda el equipo arrancará en modo usuario." .

ns1:Directiva_EXTERN a ns1:Directiva ;
    rdfs:label "Directiva EXTERN",
        "EXTERN",
        "Directiva EXTERN (Subrutina externa)"@es ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa.",
        "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt. La directiva EXTERN permite definir dichas subrutinas una a una.",
        "La directiva EXTERN permite definir dichas subrutinas una a una. Se define con EXTERN seguido de un espacio y del nombre de la subrutina, hasta 24 caracteres.",
        "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt."@es .

ns1:EjeA1_1093 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A1"@es ;
    ns1:compuestoPor ns1:SensorFeedback_1093_A1 ;
    ns1:identificador "A1" ;
    ns1:monitoreaParametro ns1:ParametroVelocidad_1093_A1 ;
    ns1:textoExtracto "Eje A1: La captación externa (directa) está conectada a los módulos remotos."@es .

ns1:EjeA2_1093 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A2"@es ;
    ns1:compuestoPor ns1:SensorFeedback_1093_A2 ;
    ns1:identificador "A2" ;
    ns1:monitoreaParametro ns1:ParametroVelocidad_1093_A2 ;
    ns1:textoExtracto "Eje A2: La captación externa (directa) está conectada a los módulos remotos."@es .

ns1:EjeAnalogico_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico X",
        "Eje analógico X"@es ;
    ns1:documentadoEn ns1:Sistema_ContadoresYEjes_1261 ;
    ns1:identificador "Eje_X" ;
    ns1:textoExtracto "bloques para ejes analógicos (X, Y, Z)",
        "3 ejes analógicos X Y Z"@es .

ns1:EjeAnalogico_Y a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico Y",
        "Eje analógico Y"@es ;
