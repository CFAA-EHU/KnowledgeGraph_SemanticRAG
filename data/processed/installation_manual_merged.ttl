ns1:CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "en un proceso de cambio de herramienta" .

ns1:CancelacionDelErrorPorFaltaDeSenalDelSensor a ns1:Parametro ;
    rdfs:label "Cancelación del error por falta de señal del sensor" ;
