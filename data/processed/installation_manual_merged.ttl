ns1:Esquema_21_21_1 a ns1:Esquema ;
    ns1:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2. Se representan dos configuraciones espaciales con ejes X-Y-Z, flechas de giro y etiquetas TDATA1–16 para posiciones, direcciones y reposo/sentido del eje principal." ;
    ns1:tieneComponente ns1:Etiqueta_TDATA1_16,
        ns1:Vector_T1,
        ns1:Vector_T2,
        ns1:Vector_V1,
        ns1:Vector_V2 .

ns1:Esquema_21_21_2 a ns1:Esquema ;
    ns1:textoExtracto "Vista detallada de los vectores T1/T2 y V1/V2 con componentes TDATA1–6 y TDATA11–16. Se marcan con signos (+/−) las proyecciones sobre cada eje y se indica la relación geométrica entre los dos ejes rotativos de la mesa." ;
    ns1:tieneComponente ns1:Componente_TDATA11_16,
        ns1:Componente_TDATA1_6,
        ns1:Vector_T1,
        ns1:Vector_T2,
        ns1:Vector_V1,
        ns1:Vector_V2 .

ns1:Esquema_21_21_3 a ns1:Esquema ;
    ns1:textoExtracto "Ilustración de mano y ejes para sentido de giro, complementada por dos diagramas circulares comparativos que muestran el origen RTCP respecto a cero máquina (C=0°) frente a cero pieza (C'=0°). Incluye ejes X-Y y referencias X'-Y'." ;
    ns1:tieneComponente ns1:Diagrama_RTCP,
        ns1:Eje_X_Prima_Y_Prima,
        ns1:Eje_X_Y .

ns1:Esquema_21_21_4 a ns1:Esquema ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1). Se dibujan X', Z' y la orientación B-30°, explicando si el sistema gira con la pieza o permanece paralelo al de máquina." ;
    ns1:tieneComponente ns1:Diagrama_RTCP,
        ns1:Eje_B,
        ns1:Eje_X_Prima,
        ns1:Eje_Z_Prima .

ns1:Esquema_3b6dcc96b2 a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Esquema_410fa7154d ;
    ns1:documentadoEn ns1:Manual_d3da7b3452 ;
    ns1:identificador "Esquema1559" ;
    ns1:textoExtracto "Esquema de 'Numeración mediante parámetros máquina': dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos. El diagrama enfatiza asignación por índices múltiples de 16+1 y cómo se distribuyen las entradas/salidas a partir de dichos índices." .

ns1:Esquema_96a3837f5f a ns1:Esquema ;
    ns1:identificador "SUB_M6.nc" ;
    ns1:textoExtracto "# SUB_M6.nc" .

ns1:Esquema_9caeeb8a07 a ns1:Esquema ;
    ns1:identificador "USERKEYS" ;
    ns1:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15. Indican la disposición y orden de teclas genéricas y de jog, útil para interpretar la correspondencia física-lógica de los bits en KEYBD y los efectos de selectores/overrides." .

ns1:Esquema_BusOpenPCS a ns1:Esquema ;
    rdfs:label "Esquema lineal del bus OpenPCS"@es ;
    ns1:ilustradoEn ns1:Interfaz_OpenPCS ;
    ns1:textoExtracto "Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5), dispuestos en un esquema lineal del bus. Incluye una relación 'Address → Elemento → Número de orden' que clarifica la jerarquía y la asociación física en el bus."@es .

ns1:Esquema_Combinado_TDATA1 a ns1:Esquema ;
    rdfs:label "Esquema combinado para cálculo de TDATA1"@es ;
    ns1:ilustradoEn ns1:Parametro_6b82dfa908 ;
