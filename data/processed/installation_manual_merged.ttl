    ns1:monitoreaParametro ns1:MotorEsclavo_67,
        ns1:MotorMaestro_67 ;
    ns1:textoExtracto "T.err Error de par entre motores... T.err = (–T.mst + T.slv + PRELOAD)" .

ns1:Parametro_UNIDIR_PosNeg a ns1:Parametro ;
    rdfs:label "UNIDIR (unidireccional positivo/negativo)" ;
    ns1:textoExtracto "UNIDIR | Positivo / Negativo." ;
    ns1:valor "Positivo/Negativo" .

ns1:Parametro_VALUE_504 a ns1:Parametro ;
    rdfs:label "VALUE (parámetro base)"@es ;
    ns1:identificador "VALUE" ;
    ns1:textoExtracto "Valor del parámetro. [...] el fabricante determina el valor del parámetro"@es .

ns1:Parametro_VCOMPAXIS a ns1:Parametro ;
