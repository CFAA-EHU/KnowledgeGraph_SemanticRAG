ns1:VariableR101 a ns1:Parametro ;
    rdfs:label "Variable R101" ;
    ns1:identificador "R101" ;
    ns1:textoExtracto "Ejemplos con R100=1234 y R101=100." .

ns1:VariableR102 a ns1:Parametro ;
    rdfs:label "Variable R102" ;
    ns1:identificador "R102" ;
    ns1:textoExtracto "= ADS R100 R101 R102 ; R102 = 1234 + 100 = 1334" .

ns1:VariableR103 a ns1:Parametro ;
    rdfs:label "Variable R103" ;
    ns1:identificador "R103" ;
    ns1:textoExtracto "= SBS R100 R101 R103 ; R103 = 1234 - 100 = 1134" .

ns1:VariableR104 a ns1:Parametro ;
    rdfs:label "Variable R104" ;
    ns1:identificador "R104" ;
    ns1:textoExtracto "= MLS R100 R101 R104 ; R104 = 1234 x 100 = 123400" .

ns1:VariableR105 a ns1:Parametro ;
    rdfs:label "Variable R105" ;
    ns1:identificador "R105" ;
    ns1:textoExtracto "= DVS R100 R101 R105 ; R105 = 1234 : 100 = 12" .

ns1:VariableR106 a ns1:Parametro ;
    rdfs:label "Variable R106" ;
    ns1:identificador "R106" ;
    ns1:textoExtracto "= MDS R100 R101 R106 ; R106 = 1234 MOD 100 = 34" .

ns1:VariableR112 a ns1:Parametro ;
    rdfs:label "Variable R112" ;
    ns1:identificador "R112" ;
    ns1:textoExtracto "= ADS 1563 R101 R112 ; R112 = 1563 + 100 = 1663" .

ns1:VariableR113 a ns1:Parametro ;
    rdfs:label "Variable R113" ;
    ns1:identificador "R113" ;
    ns1:textoExtracto "= SBS R100 1010 R113 ; R113 = 1234 - 1010 = 224" .

ns1:VariableR114 a ns1:Parametro ;
    rdfs:label "Variable R114" ;
    ns1:identificador "R114" ;
    ns1:textoExtracto "= MLS 1563 100 R114 ; R114 = 1563 x 100 = 156300" .

ns1:VariableR115 a ns1:Parametro ;
