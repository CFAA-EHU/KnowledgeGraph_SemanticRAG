        "Subrutina asociada al final del ciclo de calibración de herramienta" .

ns1:SubrutinasFST_Fabricante a ns1:InterfazUsuario ;
    rdfs:label "Subrutinas fst de fabricante (OEM)"@es ;
    ns1:habilitadoPor ns1:CNC_ModoSETUP,
        ns1:CNC_ModoUSER ;
    ns1:identificador "*.fst (OEM)" ;
    ns1:textoExtracto "Subrutinas con extensión fst guardadas en la carpeta ..mtb/sub. Con el CNC en modo USER, las rutinas OEM cuya extensión sea fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es .

ns1:SubrutinasFST_Usuario a ns1:InterfazUsuario ;
    rdfs:label "Subrutinas fst de usuario"@es ;
    ns1:identificador "*.fst (usuario)" ;
    ns1:textoExtracto "Subrutinas con extensión fst que no están guardadas en la carpeta ..mtb/sub. Las rutinas de usuario cuya extensión sea fst, se cargan en la memoria RAM durante la preparación de bloques."@es .

ns1:SubrutinasFabricante a ns1:InterfazUsuario ;
    rdfs:label "Subrutinas del fabricante" ;
    ns1:textoExtracto "Las subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." .

ns1:SubrutinasOEM_G180_G189_G380_G399 a ns1:Sistema ;
    rdfs:label "Subrutinas OEM asociadas a funciones G180-G189 / G380-G399" ;
    ns1:textoExtracto "hasta 30 subrutinas por canal y asociarlas a las funciones G180 a G189 y G380 a G399, de manera que cuando un canal ejecute una de estas funciones, ejecutará la subrutina que tiene asociada." ;
    ns1:tieneComponente ns1:FuncionG399 .

ns1:SubrutinasUsuario a ns1:Sistema ;
