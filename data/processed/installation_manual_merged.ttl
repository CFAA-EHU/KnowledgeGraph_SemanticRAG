ns1:Sistema_CinematicasOEM a ns1:Sistema ;
    rdfs:label "Cinemáticas OEM (tipos 100 a 105)" ;
    ns1:textoExtracto "En las cinemáticas OEM hay que indicar el número de parámetros, variables auxiliares y datos de propósito general que se utilizan." ;
    ns1:tieneComponente ns1:Parametro_AUXCTE_SIZE,
        ns1:Parametro_KINDATA_SIZE,
        ns1:Parametro_NKINAX,
        ns1:Parametro_PARAM_D_SIZE,
        ns1:Parametro_PARAM_I_SIZE,
        ns1:Parametro_TDATA1_100,
        ns1:Parametro_TDATA_I1_100 .

ns1:Sistema_CinematicasPersonalizables a ns1:Sistema ;
    rdfs:label "Sistema de cinemáticas personalizables" ;
    ns1:textoExtracto "El fabricante puede personalizar hasta 6 cinemáticas distintas para una misma máquina. [...] Además de estas cinemáticas, el OEM puede integrar 6 cinemáticas adicionales."@es ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC_ConfiguracionCinematica .

ns1:Sistema_CompensacionCinematica a ns1:Sistema ;
    rdfs:label "Sistema de compensación cinemática" ;
    ns1:textoExtracto "Cada cinemática tiene una compensación asociada (parámetro COMPID). KINCOMP1 está asociado a COMPID 1, KINCOMP2 a COMPID2 y así sucesivamente." ;
    ns1:tieneComponente ns1:Parametro_COMPID .

ns1:Sistema_CompensacionHusillo a ns1:Sistema ;
    rdfs:label "Sistema de compensación de husillo" ;
    ns1:detalladoEnEsquema ns1:Tabla_LSCRWDATA_DATA ;
    ns1:textoExtracto "Compensación de husillo" ;
    ns1:tieneComponente ns1:Parametro_LSCRWDATA_BIDIR,
        ns1:Parametro_LSCRWDATA_NPOINTS,
        ns1:Parametro_LSCRWDATA_REFNEED,
        ns1:Parametro_LSCRWDATA_TYPLSCRW .

ns1:Sistema_CompensacionModulo a ns1:Sistema ;
    rdfs:label "Sistema de compensación de módulo (ejes rotativos)"@es ;
    ns1:textoExtracto "Estos parámetros indican, cuando la resolución del eje no es exacta, la compensación que se debe aplicar para obtener un contaje exacto. El CNC aplica la compensación de módulo a lo largo de toda la vuelta."@es ;
    ns1:tieneComponente ns1:Parametro_MODERR,
        ns1:Parametro_MODNROT .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es,
        "Sistema de compensación volumétrica (PLC-CNC)"@es ;
    ns1:compuestoPor ns1:Se_al_VOLCOMP1,
        ns1:Se_al_VOLCOMP2,
        ns1:Se_al_VOLCOMP3,
        ns1:Se_al_VOLCOMP4 ;
    ns1:controla ns1:CompensacionVolumetrica_1,
        ns1:CompensacionVolumetrica_2,
        ns1:CompensacionVolumetrica_3,
        ns1:CompensacionVolumetrica_4 ;
    ns1:detalladoEnEsquema ns1:Esquema_CompensacionVolumetrica ;
    ns1:documentadoEn ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada. La compensación volumétrica permanece activa tras un reset, error o fin de programa (M30)"@es,
        "Ilustración isométrica de un centro de mecanizado con un volumen cúbico transparente sobre la mesa que contiene una nube de puntos azules. El cubo representa el volumen de trabajo a compensar y los puntos son nodos de medida/interpolación. Se aprecian ejes cartesianos implícitos y la relación del volumen con los elementos de la máquina (mesa, columna y husillo), enfatizando la idea de corrección espacial de errores geométricos en todo el recorrido."@es ;
    ns1:tieneComponente ns1:Maquina_CentroMecanizado .

ns1:Sistema_CompensacionVolumetricaBasica a ns1:Sistema ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:textoExtracto "Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande." ;
    ns1:tieneComponente ns1:Parametro_INIPOSAX1,
        ns1:Parametro_INIPOSAX2,
        ns1:Parametro_INIPOSAX3,
        ns1:Parametro_VCOMPFILE .

ns1:Sistema_ComunicacionCNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC para transferencia de funciones auxiliares",
        "Sistema de comunicación CNC-PLC"@es ;
    ns1:documentadoEn ns1:Tabla_SenalesConsultaGenerales_6_1 ;
    ns1:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla. El CNC espera la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC.",
        "el CNC pasará al PLC la siguiente información"@es ;
    ns1:tieneComponente ns1:EntradaLogica_AUXEND,
        ns1:Parametro_MFUN1C1,
        ns1:Parametro_MFUN1C2,
        ns1:Parametro_MFUN2C1,
        ns1:Parametro_MFUN2C2,
        ns1:Parametro_MFUN3C1_a_MFUN7C1,
        ns1:Parametro_MFUN3C2_a_MFUN7C2,
        ns1:SalidaLogica_SSTROBE .

ns1:Sistema_ComunicacionGestorPLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación Gestor-PLC"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ComunicacionGestorPLC_731 ;
    ns1:textoExtracto "Comunicación Gestor → PLC (sección 7.3.1)."@es,
        "El gestor utiliza los siguientes registros y marcas para informar al PLC de las operaciones que debe realizar."@es ;
    ns1:tieneComponente ns1:Marca_TMOPSTROBE_C1,
        ns1:Marca_TMOPSTROBE_C2,
        ns1:Marca_TMOPSTROBE_C3,
        ns1:Marca_TMOPSTROBE_C4,
        ns1:Registro_LEAVEPOS,
        ns1:Registro_LEAVEPOS_MZ1,
        ns1:Registro_LEAVEPOS_MZ2,
        ns1:Registro_LEAVEPOS_MZ3,
        ns1:Registro_LEAVEPOS_MZ4,
        ns1:Registro_MZID,
        ns1:Registro_MZID_C1,
        ns1:Registro_MZID_C2,
        ns1:Registro_MZID_C3,
        ns1:Registro_MZID_C4,
        ns1:Registro_NEXTPOS,
        ns1:Registro_NEXTPOS_MZ1,
        ns1:Registro_NEXTPOS_MZ2,
        ns1:Registro_NEXTPOS_MZ3,
        ns1:Registro_NEXTPOS_MZ4,
        ns1:Registro_TAKEPOS,
        ns1:Registro_TAKEPOS_MZ1,
        ns1:Registro_TAKEPOS_MZ2,
        ns1:Registro_TAKEPOS_MZ3,
        ns1:Registro_TAKEPOS_MZ4,
        ns1:Registro_TMOPERATION,
        ns1:Registro_TMOPERATION_C1,
        ns1:Registro_TMOPERATION_C2,
        ns1:Registro_TMOPERATION_C3,
        ns1:Registro_TMOPERATION_C4,
        ns1:Registro_TMOPSTROBE .

ns1:Sistema_ComunicacionRS485 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación RS485" ;
    ns1:textoExtracto "En la RS485, el CNC controla la recepción y transmisión de datos con la misma señal, de manera que durante la transmisión está deshabilitada la recepción. Para asegurar una comunicación correcta, es necesario un retardo de 8 ms desde que el CNC deja de transmitir y está preparado para recibir datos." ;
    ns1:tieneComponente ns1:Parametro_RetardoRS485 .

ns1:Sistema_ComunicacionSSI_FagorLA a ns1:Sistema ;
    rdfs:label "Sistema de comunicación SSI para regla absoluta Fagor LA" ;
    ns1:detalladoEnEsquema ns1:Tabla_FrecuenciasMaximasSSI ;
    ns1:textoExtracto "Ejemplo para regla absoluta Fagor (Fagor LA). Ejemplo de parametrización para la conexión de la regla absoluta Fagor LA, configurada con los parámetros por defecto con los que sale de fábrica." ;
    ns1:tieneComponente ns1:Parametro_SSIALARMBITS,
        ns1:Parametro_SSIALARMLEVEL,
        ns1:Parametro_SSICLKFREQ,
        ns1:Parametro_SSICRCBITS,
        ns1:Parametro_SSIDATALENGTH,
        ns1:Parametro_SSIDATAMODE,
        ns1:Parametro_SSIPACKFORMAT,
        ns1:Parametro_SSISTARTBITS .

ns1:Sistema_Comunicacion_CNC_PLC a ns1:Sistema ;
    rdfs:label "Marcas de comunicación CNC-PLC" ;
    ns1:textoExtracto "Marcas de comunicación CNC-PLC" ;
    ns1:tieneComponente ns1:Instruccion_DFD,
        ns1:Instruccion_DFU .

ns1:Sistema_ConfiguracionEjeUnidireccional a ns1:Sistema ;
    rdfs:label "Configuración de eje rotativo unidireccional" ;
    ns1:monitoreaParametro ns1:Parametro_UNIDIR_PosNeg ;
    ns1:textoExtracto "Eje rotativo unidireccional. Este tipo de eje rotativo sólo se desplaza en un sentido, el que tiene predeterminado." ;
    ns1:tieneComponente ns1:Parametro_UNIDIR_PosNeg .

ns1:Sistema_ConfiguracionEjes a ns1:Sistema ;
    rdfs:label "Sistema de configuración de parámetros de ejes" ;
    ns1:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas" ;
    ns1:tieneComponente ns1:Parametro_Eje_Avance,
        ns1:Parametro_PotenciaLaser,
        ns1:Parametro_VelocidadCabezal .

ns1:Sistema_ConfiguracionMovimientoPalpador a ns1:Sistema ;
    rdfs:label "Configuración del movimiento con palpador" ;
    ns1:textoExtracto "Configuración del movimiento con palpador. Parámetros válidos para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_PROBEAXIS,
        ns1:Parametro_PROBEFEED,
        ns1:Parametro_PROBERANGE .

ns1:Sistema_ConmutacionCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de conmutación de captación (FBACKSEL)"@es ;
    ns1:controla ns1:ComponenteElectrico_CaptacionDirecta,
        ns1:ComponenteElectrico_CaptacionMotor ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "Cuando el tipo de captación es interna+externa, desde el PLC se puede conmutar entre ambas captaciones con la marca FBACKSEL(axis)."@es .

ns1:Sistema_ControlCNC_CAN a ns1:Sistema ;
    rdfs:label "Sistema CNC con módulos remotos CAN (RIOR)" ;
    ns1:textoExtracto "cadena 'CNC – RIOR – CAN – GAP SENSOR'" ;
    ns1:tieneComponente ns1:ComponenteElectrico_PinesAI1_CAN,
        ns1:Sensor_GapLaser .

ns1:Sistema_ControlCNC_Sercos a ns1:Sistema ;
    rdfs:label "Sistema CNC con regulador Sercos" ;
    ns1:textoExtracto "bloques 'CNC', 'DRIVE' y 'SERCOS'" ;
    ns1:tieneComponente ns1:ComponenteElectrico_BornesX7_AI1,
        ns1:Sensor_GapLaser .

ns1:Sistema_ControlCabezal a ns1:Sistema ;
    rdfs:label "Sistema de control del cabezal",
        "Sistema de control de cabezales (M3/M4, M19)"@es ;
    ns1:monitoreaParametro ns1:Parametro_M19SPDLEREV,
        ns1:Parametro_SPDLEREV_M19,
        ns1:Parametro_SPDLSTOP,
        ns1:Parametro_SREVM05,
        ns1:Parametro_STEPOVR ;
    ns1:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1.",
        "La marca SPDLEREV siempre afecta a los cabezales en lazo abierto (M3/M4), independientemente de lo definido en este parámetro."@es .

ns1:Sistema_ControlCabezales a ns1:Sistema ;
    rdfs:label "Sistema de control de cabezales" ;
    ns1:textoExtracto "Se dispone de una señal para cada cabezal. [...] Estas señales se utilizan con cabezal analógico, Sercos en posición, Sercos en velocidad y Mechatrolink." ;
    ns1:tieneComponente ns1:Senal_PLCCNTL1,
        ns1:Senal_PLCCNTL2,
        ns1:Senal_PLCCNTL3,
        ns1:Senal_PLCCNTL4,
        ns1:Senal_PLCCNTL5,
        ns1:Senal_PLCCNTL6,
        ns1:Senal_SANALOG1,
        ns1:Senal_SANALOG2,
        ns1:Senal_SANALOG3,
        ns1:Senal_SANALOG4,
        ns1:Senal_SANALOG5,
        ns1:Senal_SANALOG6 .

ns1:Sistema_ControlEje a ns1:Sistema ;
    rdfs:label "Sistema de control de eje" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento_epsilon,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_MANFFGAIN,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "El parámetro define la parte de la consigna (analog output) que es proporcional al avance programado (programmed feedrate); el resto de la consigna será proporcional al error de seguimiento \"\"." .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales",
        "Sistema de control de error de seguimiento de ejes",
        "Sistema de control de límites de software de ejes"@es ;
    ns1:controla ns1:Maquina_CNC,
        ns1:Motor_Eje ;
    ns1:detalladoEnEsquema ns1:Tabla_LimitesSoftwareEjes ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_DECJERK,
        ns1:Parametro_ESTDELAY,
        ns1:Parametro_FLWEMONITOR,
        ns1:Parametro_INPOMAX,
        ns1:Parametro_LIMITNEG,
        ns1:Parametro_LIMITPOS,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_SOFTLIMIT ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR=Lineal. Este parámetro permite definir un retardo en la estimación del error de seguimiento de forma que el teórico (1) se aproxime al real (2) y evitar mensajes de error no deseados.",
        "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar.",
        "Los límites de software se pueden fijar mediante los parámetros máquina, mediante las funciones G198/G199 o mediante variables. [...] Las zonas de trabajo se pueden fijar mediante las funciones G120, G121, G122, G123.",
        "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado.",
        "El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo."@es ;
    ns1:tieneComponente ns1:Parametro_ACCJERK,
        ns1:Parametro_DECJERK,
        ns1:Senal_DRENA,
        ns1:Senal_LUBRENA,
        ns1:Senal_LUBROK,
        ns1:Senal_PARK,
        ns1:Senal_PARKED,
        ns1:Senal_SPENA,
        ns1:Senal_UNPARK .

ns1:Sistema_ControlMaquina a ns1:Sistema ;
    rdfs:label "Sistema de control de la máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_AjusteGanancias_SercosPosicion ;
    ns1:textoExtracto "el tiempo de respuesta del sistema es un valor (normalmente desconocido) que depende de las inercias de la máquina y del ajuste del regulador"@es .

ns1:Sistema_ControlPLC_7_11_1 a ns1:Sistema ;
    rdfs:label "Sistema de control PLC para operaciones de cambio de herramienta" ;
