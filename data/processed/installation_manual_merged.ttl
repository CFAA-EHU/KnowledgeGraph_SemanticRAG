        ns1:Parametro_SPDLEREV_1062,
        ns1:Parametro_SPENA_1062 .

ns1:ConfiguracionTorno_1024_Canal1 a ns1:Sistema ;
    rdfs:label "Configuración de torno con 1 canal, 3 ejes (X, Z, Y) y 1 cabezal (S) en plano G18" ;
    ns1:identificador "Canal 1 (G18)" ;
    ns1:textoExtracto "Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | NCHANNEL = 1 | GEOCONFIG = Plano | NAXIS = 3 | CHNAXIS = 3 | NSPDL = 1 | CHNSPDL = 1 | IPLANE = G18" ;
