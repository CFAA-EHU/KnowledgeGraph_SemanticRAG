ns1:Tabla_ParametrosHSC_1150 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros HSC (páginas 621-622)"@es ;
    ns1:documentadoEn ns1:Pagina_621_622 ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| --- | --- | --- |\r
| HSCDEFAULMODE MPG |  | Modo por defecto al programar #HSC ON. |\r
| FEEDAVRG MPG |  | Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos... |\r
| SMOOTHFREQ MPG |  | Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias... |\r
| CORNER MPG |  | Este parámetro indica el ángulo máximo entre dos trayectorias... |\r
| HSCFILTFREQ MPG |  | Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR..."""@es .

ns1:Tabla_RedefinicionCinematicaTipo50_Tipo5 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia entre parámetros de cinemática vectorial (tipo 50) y cinemática tipo 5" ;
    ns1:textoExtracto """\r
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 5. |\r
| --- | --- |\r
| TYPE | 50 |\r
| TDATA1 | TDATA2 |\r
| TDATA2 | TDATA14 |\r
| TDATA3 | TDATA15 |\r
| TDATA4 | 1 |\r
| TDATA5 | 0 |\r
| TDATA6 | 0 |\r
| TDATA7 | TDATA8 |\r
| TDATA8 | TDATA10 |\r
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |\r
| TDATA11 | TDATA5*COS(TDATA7) |\r
| TDATA12 | TDATA3 |\r
| TDATA13 | TDATA5*SIN(TDATA7) |\r
| TDATA14 | COS(TDATA7) |\r
| TDATA15 | 0 |\r
| TDATA16 | SIN(TDATA7) |\r
| TDATA17 | TDATA9 |\r
| TDATA18 | TDATA11 |\r
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |\r
| TDATA21 | 0 |\r
| TDATA22 | TDATA6 |\r
| TDATA23 | TDATA1 |\r
| TDATA24 | 0 |\r
| TDATA25 | 0 |\r
| TDATA26 | 1 |\r
""" .

