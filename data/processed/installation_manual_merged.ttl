    ns1:textoExtracto "M106 Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2."@es .

ns1:TareaMantenimiento_ProgramacionCNC a ns1:TareaMantenimiento ;
