ns1:THREADC4 a ns1:Parametro ;
    rdfs:label "THREADC4" ;
    ns1:identificador "THREADC4" ;
    ns1:textoExtracto "THREADC4 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)." .

ns1:TMINEM a ns1:Sensor ;
    rdfs:label "TMINEM (Indicación de emergencia)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEM" ;
    ns1:monitoreaParametro ns1:Param_EstadoEmergenciaGestor ;
    ns1:textoExtracto """\r
    El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas.\r
    Para generar una emergencia del gestor desde el PLC, se debe:\r
    (1) Activar la emergencia. DFU (condición de error) = SET SETTMEM\r
    (2) Asegurarse que se ha producido la emergencia antes de cancelarla. TMINEM AND DFU (condición de quitar) = SET RESTMEM\r
    """@es .

ns1:TMP a ns1:Componente ;
    rdfs:label "TMP" ;
    ns1:textoExtracto "Archivos temporales. El CNC utiliza esta carpeta para guardar los archivos temporales que genera durante su funcionamiento. El CNC borra el contenido de esta carpeta cada vez que arranca." .

ns1:TablaAlmacenHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de almacén de herramientas"@es ;
    ns1:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén."@es .

ns1:TablaAlmacen_7.5 a ns1:InterfazUsuario ;
    rdfs:label "Tabla de control del almacén"@es ;
    ns1:textoExtracto "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén."@es .

ns1:TablaAlmacenes_7.2 a ns1:Tabla ;
    rdfs:label "Tabla de almacenes (Sección 7.2)" ;
    ns1:textoExtracto "Se dispone de una tabla para cada almacén. En cada una de las tablas se muestra qué herramienta hay en cada posición del almacén y en cada una de las pinzas del brazo cambiador (si se dispone de él)." .

ns1:TablaAsignacionTeclasJog_1243 a ns1:Tabla ;
    rdfs:label "Tabla de relación entre módulo hardware y teclas de usuario (JOG-PANEL)"@es ;
    ns1:textoExtracto "La relación entre estos parámetros y las teclas de usuario es la siguiente. | Módulo hardware. | Teclas de usuario. | | --- | --- | | JOG-PANEL | 1 2 15 16 | GKEYS | O | J |"@es .

ns1:TablaComunicacionPLC_Gestor a ns1:Tabla ;
    rdfs:label "Tabla de mnemónicos de comunicación PLC-Gestor (Almacenes 1-4)"@es ;
    ns1:ilustradoEn ns1:Pagina_474_475 ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes. [...] El significado de las marcas y registros es el siguiente."@es .

ns1:TablaEjesGantry_69 a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionCNC ;
    ns1:textoExtracto "GANTRY Tabla de ejes gantry. Este parámetro muestra la tabla para definir los ejes gantry del sistema."@es .

ns1:TablaEjesTandem a ns1:Tabla ;
    rdfs:label "Tabla de ejes o cabezales tándem"@es ;
    ns1:identificador "TANDEM" ;
    ns1:textoExtracto "TANDEM Tabla de ejes o cabezales tándem. Este parámetro muestra la tabla para definir las parejas tándem del sistema."@es .

ns1:TablaFuncionesG a ns1:Tabla ;
    rdfs:label "Tabla de funciones G para configuración de ejes" ;
    ns1:detalladoEnEsquema ns1:FuncionG17,
        ns1:FuncionG18,
        ns1:FuncionG19,
        ns1:FuncionG20 ;
    ns1:textoExtracto "| Función. | Significado. | --- | --- | G17 | No cambia de plano y muestra un warning avisando de ello. | G18 | No produce ningún efecto (salvo que esté activa la función G20). | G19 | No cambia de plano y muestra un warning avisando de ello. | G20 | Se permite si no altera el plano principal; es decir, sólo se puede usar para cambiar el eje longitudinal." .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones 'M'",
        "Tabla de funciones M (parámetros máquina)" ;
    ns1:documentadoEn ns1:ManualCNC,
        ns1:ManualMaquina ;
    ns1:textoExtracto "2.8.1 Tabla de funciones M. Las funciones M se pueden enviar y/o sincronizar antes o después del movimiento.",
        "Se recomienda tener personalizada esta función en la tabla de funciones 'M' de forma que ejecute la subrutina correspondiente al cambiador de herramientas instalado en la máquina." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas",
        "Tabla de herramientas y almacenes"@es ;
    ns1:documentadoEn ns1:Manual_Seccion1_4_1 ;
    ns1:textoExtracto "la orientación de la herramienta, definida en la tabla de herramientas",
        "Definir la tabla de herramientas y de los almacenes."@es .

ns1:TablaHerramientas_V200 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas y almacén (V2.00)"@es ;
    ns1:identificador "V2.00" ;
    ns1:textoExtracto "Tabla de herramientas y almacén. Debido a las mejoras introducidas en las tablas de herramientas y datos del almacén en la versión V2.00, la actualización de estas tablas se debe realizar manualmente. Antes de actualizar el software, guardar los datos de estas tablas en formato ASCII y una vez finalizada la instalación, cargar los datos en las tablas. Ambas operaciones se realizan desde la tabla de herramientas y almacén, mediante las softkeys 'Salvar' y 'Cargar'."@es .

ns1:TablaMensajesErroresPLC a ns1:Tabla ;
    rdfs:label "Tabla de mensajes y errores del PLC"@es ;
    ns1:identificador "MSG1-1024/ERR1-1024" ;
    ns1:textoExtracto "En el PLC hay una tabla de mensajes y errores en la que se puede asociar a cada mensaje o error lo siguiente: • Un número (campo ID). • Un texto (campo \"Mensaje\"). • Un archivo de información adicional (campo \"Archivo asociado\"), que podrá ser un fichero del tipo bmp, txt, jpg, gif, htm, html ó avi. • Si al activarse un error o mensaje, se debe mostrar directamente el fichero de ayuda adicional (campo \"Mostrar\" seleccionado) o sólo el texto del mensaje o error. • En el caso de los errores, si estos abren o no el relé de emergencia de la unidad central."@es .

ns1:TablaOperacionesPLC_TM a ns1:Tabla ;
    rdfs:label "Tabla de operaciones válidas entre TM y PLC (pág. 503-504)"@es ;
    ns1:identificador "7.9.1" ;
    ns1:textoExtracto """\r
| TM => PLC |  |  | PLC => TM |\r
| --- | --- | --- | --- |\r
| TMOPERATION | TAKEPOS | LEAVEPOS |  |\r
| 1 | # | 0 | MZTOCH1 + CH1TOSPDL |\r
| 2 | 0 | # | SPDLTOCH1 + CH1TOMZ |\r
| 3 | 0 | 0 | GRTOSPDL |\r
| 4 | 0 | 0 | SPDLTOGR |\r
| 5 | # | # | SPDLTOCH1 + CH1TOMZ + MZTOCH1 + CH1TOSPDL |\r
| 6 | -4 | # | SPDLTOCH1 + (CH1TOMZ & GRTOSPDL) |\r
| 7 | # | -4 | (SPDLTOGR & MZTOCH1) + CH1TOSPDL |\r
| 8 | 0 | 0 | SPDLTOGR + GRTOSPDL |\r
| 9 | -4 | # | GRTOSPDL + SPDLTOCH1 + CH1TOMZ |\r
| 10 | # | -4 | MZTOCH1 + CH1TOSPDL + SPDLTOGR |\r
| 11 | 0 | 0 | MZROT |\r
| 13 | # | 0 | MZROT + MZROT |\r
| 14 | # | # | SPDLTOCH1 + CH1TOMZ + MZTOCH1 + CH1TOSPDL |\r
"""@es .

ns1:TablaParametrosEjes_1077 a ns1:Tabla ;
    rdfs:label "Parámetros máquina para ejes compartidos"@es ;
    ns1:documentadoEn ns1:ConfiguracionEjesCompartidos_1077 ;
    ns1:textoExtracto "| Parámetro | Significado | --- | --- | ABSFEEDBACK | Tipo de captación. | SINMAGNI | Factor multiplicador de la señal sinusoidal. | I0TYPE | Tipo de I0. | REFPULSE | Flanco de la señal de I0. | ABSOFF | Offset del captador respecto a I0. | EXTMULT | Factor multiplicador externo. | I0CODDI1 | Paso entre señales de I0 fijas. | I0CODDI2 | Paso entre señales de I0 variables."@es .

ns1:TablaParametrosEnDat_462 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros EnDat"@es ;
