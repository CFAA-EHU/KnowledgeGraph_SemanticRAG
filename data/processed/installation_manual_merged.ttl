    ns1:textoExtracto "Se referencia mediante la letra T seguida del número de temporizador que se desea referenciar, por ejemplo T1, T25, T102, etc." .

ns1:T1M6 a ns1:TareaMantenimiento ;
    ns1:identificador "T1 M6" ;
    ns1:textoExtracto "ejecuta la instrucción T1 M6" .

ns1:T20 a ns1:Sensor ;
    rdfs:label "T20" ;
    ns1:textoExtracto "Activa el temporizador T20 en modo monoestable (TG1) con una constante de tiempo de 100 ms." .

ns1:T22 a ns1:Sensor ;
    rdfs:label "T22" ;
    ns1:textoExtracto "Activa el temporizador T22 en modo de retardo a la conexión (TG2) con la constante de tiempo que fija el valor del registro R200, en ms." .

ns1:TAKEPOSEsteRegistroTomaraValor0SiEsUnPosicionamientoAbsolutoYValor1SiEsUnPosicionamientoRelativo a ns1:Parametro ;
    ns1:textoExtracto "TAKEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ns1:TAKEPOSPosicionDelAlmacenParaCogerLaHerramienta a ns1:Parametro ;
    ns1:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ns1:TAKEPOSPosicionQueOcupaLaHerramienta a ns1:Parametro ;
    ns1:textoExtracto "TAKEPOS=# Posición que ocupa la herramienta" .

ns1:TAKEPOS_Valor a ns1:Parametro ;
    rdfs:label "#" ;
    ns1:textoExtracto "# | Posición en el almacén." .

ns1:TCAMON a ns1:ModoOperacion ;
    rdfs:label "TCAM ON" ;
    ns1:documentadoEn ns1:ManualLevaElectronicaEspecifico ;
    ns1:identificador "TCAM ON" ;
    ns1:monitoreaParametro ns1:MasterOTIME,
        ns1:MasterOff,
        ns1:Parametro_6a5b9b5860,
        ns1:Parametro_ac57d71b6c,
        ns1:Parametro_acaad792e8,
        ns1:RangeMaster,
        ns1:RangeSlave,
        ns1:SlaveOff ;
    ns1:textoExtracto "activar la leva electrónica con las cotas teóricas (TCAM ON)" .

ns1:TD a ns1:PiezaRecambio ;
    rdfs:label "T%D" ;
    ns1:textoExtracto "Insertar herramienta T%D y pulsar MARCHA" .

