    rdfs:label "INCYCLEC3" ;
    ns1:identificador "INCYCLEC3" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoCanalC3 ;
    ns1:textoExtracto "INCYCLEC3" .

ns1:Sensor_INCYCLEC4 a ns1:Sensor ;
    rdfs:label "INCYCLEC4" ;
    ns1:identificador "INCYCLEC4" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoCanalC4 ;
    ns1:textoExtracto "INCYCLEC4" .

ns1:Sensor_MicroEjeMaestro a ns1:Sensor ;
    rdfs:label "Micro del eje maestro" ;
    ns1:textoExtracto "pulse su micro" .

ns1:Sensor_PT100_1 a ns1:Sensor ;
    ns1:textoExtracto "sonda correspondiente (parámetro PT100 n)" .

ns1:Sensor_PT100_20 a ns1:Sensor ;
    ns1:textoExtracto "sonda correspondiente (parámetro PT100 n)" .

ns1:Sensor_Palpador_706 a ns1:Sensor ;
    rdfs:label "Palpador del cabezal angular" ;
    ns1:textoExtracto "necesidad de conocer radio y longitud de la bola del palpador" .

ns1:Sensor_PosicionMotor a ns1:Sensor ;
    rdfs:label "Sensor de posición del motor" ;
    ns1:textoExtracto "captación motor" .

ns1:Sentencia_ANGAX_ON a ns1:Parametro ;
    rdfs:label "#ANGAX ON" ;
    ns1:identificador "#ANGAX ON" ;
    ns1:textoExtracto "la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON"@es .

ns1:Sentencia_SERVO_ON a ns1:Parametro ;
    rdfs:label "#SERVO ON" ;
    ns1:identificador "#SERVO ON" ;
    ns1:textoExtracto "cuando un cabezal pasa a lazo cerrado mediante la sentencia #SERVO ON." .

ns1:Sentencia_TOOL_AX a ns1:Parametro ;
    rdfs:label "#TOOL AX" ;
    ns1:textoExtracto "sentencia #TOOL AX"@es ;
    ns1:valor "#TOOL AX" .

ns1:SetupHelp_Vxx_xx_exe a ns1:InterfazUsuario ;
    rdfs:label "SetupHelp_Vxx.xx.exe" ;
    ns1:identificador "SetupHelp_Vxx.xx.exe" ;
    ns1:textoExtracto "Se puede cambiar el idioma de la ayuda con el programa SetupHelp_Vxx.xx.exe (donde Vxx_xx es el nombre de la versión), disponible en la zona de descargas del sitio web corporativo de Fagor Automation." .

ns1:SimboloParentesis a ns1:Componente ;
    rdfs:label "Símbolos paréntesis ( )" ;
    ns1:textoExtracto "Abrir y cerrar paréntesis. Permiten clarificar y seleccionar el orden en que se produce la evaluación de la expresión lógica. ( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = O7" .

ns1:SimboloSaltoLinea a ns1:Componente ;
    rdfs:label "Símbolo salto de línea (\\)" ;
    ns1:textoExtracto "Salto de línea. Permite escribir una expresión lógica en 2 o más líneas diferentes. Se puede programar: DFU MSTROBE \\ AND CPS MFUN* EQ 3 = M1003" .

ns1:SistemaAyudaSubrutinas_1234 a ns1:Sistema ;
    rdfs:label "Sistema de ayuda para subrutinas CNC"@es ;
    ns1:identificador "V1.60 (8060)",
        "V5.60 (8065)" ;
    ns1:textoExtracto "Users\\Session\\Help\\{idioma} ..\\Mtb\\Sub\\Help\\{idioma}..          \\Users\\Help\\{idioma}.          En versiones anteriores a la V1.60 (8060) y V5.60 (8065), el CNC primero buscaba los archivos de ayuda a las carpetas de fabricante y a continuación en las carpetas de usuario.          A partir de estas versiones, el criterio es el contrario."@es .

ns1:SistemaCNC_1309 a ns1:Sistema ;
    rdfs:label "Sistema CNC del cabezal angular"@es ;
    ns1:textoExtracto "cota que aparece en el CNC (Y)"@es ;
    ns1:tieneComponente ns1:EjeRotativoC_1309,
        ns1:ParametroY_1309,
        ns1:ParametroZ_1309 .

ns1:SistemaCNC_17_1 a ns1:Sistema ;
    rdfs:label "Sistema CNC para cabezal angular" ;
    ns1:monitoreaParametro ns1:ParametroDeltaX_17_1,
        ns1:ParametroTDATA1_17_1,
        ns1:ParametroTDATA6_17_1 ;
    ns1:textoExtracto "Anotar la cota que aparece en el CNC, denominada en el dibujo " .

ns1:SistemaCNC_Multicanal a ns1:Sistema ;
    rdfs:label "Sistema CNC multicanal" ;
    ns1:textoExtracto "El CNC puede disponer de un único canal de ejecución (sistema monocanal) o de varios (sistema multicanal). Cada canal constituye un entorno de trabajo diferente que puede actuar sobre una parte o sobre la totalidad del sistema CNC." ;
    ns1:tieneComponente ns1:CanalCNC_Generico .

ns1:SistemaCambioAutomaticoHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de cambio automático de herramientas",
        "Sistema de cambio automático de herramientas"@es ;
    ns1:controla ns1:ParametroEjecucion ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático. [...] M6 ; Orden al gestor para comenzar el cambio de herramienta.",
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ns1:tieneComponente ns1:AlmacenHerramientas,
        ns1:CabezalM06,
        ns1:Pinza1,
        ns1:Pinza2 .

ns1:SistemaCambioHerramienta a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramienta",
        "Sistema de cambio automático de herramienta"@es ;
    ns1:compuestoPor ns1:AlmacenHerramientasTorreta ;
    ns1:controla ns1:FuncionM06,
        ns1:SenalTCHANGEOK ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc).",
        """\r
LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
LL SUB_ARM_BACK ; Retirar el brazo cambiador.\r
LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.\r
LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.\r
LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta."""@es ;
    ns1:tieneComponente ns1:AlmacenHerramientas,
        ns1:BrazoCambiador,
        ns1:CabezalHerramienta,
        ns1:Pinza1,
        ns1:Pinza2 .

ns1:SistemaCambioHerramienta_Torreta a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramienta (almacén tipo torreta)"@es ;
    ns1:textoExtracto "En un almacén tipo torreta, se recomienda que la rutina asociada a T incluya la función M06. Cuando el CNC selecciona una herramienta, la rutina asociada a T ejecuta la función M06 (cambio de herramienta)."@es .

ns1:SistemaCambioHerramientas_952 a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (no-random)"@es ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y las herramientas T7, T8 y T9 son de tierra."@es ;
    ns1:tieneComponente ns1:Herramienta_T7_952,
        ns1:Herramienta_T8_952,
        ns1:Herramienta_T9_952 .

ns1:SistemaCinematico_Tipo52 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática vectorial tipo 52"@es ;
    ns1:identificador "TYPE 52" ;
    ns1:textoExtracto "TYPE | 52"@es ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA16,
        ns1:Parametro_TDATA17,
        ns1:Parametro_TDATA18,
        ns1:Parametro_TDATA19,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA21,
        ns1:Parametro_TDATA22,
        ns1:Parametro_TDATA23,
        ns1:Parametro_TDATA24,
        ns1:Parametro_TDATA25,
        ns1:Parametro_TDATA26,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 .

ns1:SistemaCompensacionCruzada a ns1:Sistema ;
    rdfs:label "Sistema de compensación cruzada MOVAXIS-COMPAXIS" ;
    ns1:compuestoPor ns1:EjeCompAxis,
        ns1:EjeMovAxis ;
    ns1:textoExtracto "un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)" .

ns1:SistemaCompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica",
        "Sistema de compensación volumétrica"@es ;
    ns1:activaAlarma ns1:Error23102,
        ns1:Error23103,
        ns1:Error23104 ;
    ns1:compuestoPor ns1:ParametrosMaquina_CompensacionVolumetrica ;
    ns1:documentadoEn ns1:ArchivoCompensacionCSV ;
    ns1:monitoreaParametro ns1:ParametroNPOINTSAX1,
        ns1:ParametroNPOINTSAX2,
        ns1:ParametroNPOINTSAX3 ;
    ns1:textoExtracto "La compensación volumétrica corrige en gran medida estos errores geométricos, mejorando así la precisión de los posicionamientos.",
        "compensación volumétrica básica"@es,
        "sistema de compensación volumétrica"@es ;
    ns1:tieneComponente ns1:CompensacionVolumetrica_Basica,
        ns1:CompensacionVolumetrica_Grande,
        ns1:CompensacionVolumetrica_Media .

ns1:SistemaComunicacionGestorPLC_7_7 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación gestor-PLC (fase única)"@es ;
    ns1:controla ns1:AlmacenTipoTorreta_7_7 ;
    ns1:textoExtracto "la comunicación entre el gestor y el PLC se configura para que se realice en una única fase, con la ejecución de la función T."@es .

ns1:SistemaControlCNC_1072 a ns1:Sistema ;
    rdfs:label "Sistema CNC de control de la máquina tándem"@es ;
    ns1:controla ns1:Motor_EjeEsclavo_1072,
        ns1:Motor_EjeMaestro_1072 ;
    ns1:textoExtracto "el CNC debe generar consignas de posición sin componentes frecuenciales superiores a la frecuencia de resonancia"@es .

ns1:SistemaControlCNC_13_3_4 a ns1:Sistema ;
    rdfs:label "Sistema de control CNC (Sección 13.3.4)" ;
    ns1:textoExtracto "El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)." .

ns1:SistemaControlColisiones a ns1:Sistema ;
    rdfs:label "Sistema de control de colisiones" ;
    ns1:textoExtracto "la opción FCAS (control de colisiones)." .

ns1:SistemaControlEjes_693 a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes para latcheo" ;
    ns1:textoExtracto "LATCH1DONE(axis) LATCH2DONE(axis) El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." ;
    ns1:tieneComponente ns1:InterpoladorEjes_693,
        ns1:PLC_693,
        ns1:PalpadorLatcheo_693,
        ns1:VariableLATCH1_693,
        ns1:VariableLATCH2_693 .

ns1:SistemaCorreccionGantry a ns1:Sistema ;
    rdfs:label "Sistema de corrección gantry" ;
    ns1:controla ns1:ComponenteEjeEsclavo ;
    ns1:monitoreaParametro ns1:Parametro_REFFEED2 ;
    ns1:textoExtracto "DIFFCOMP(axis) [...] corrige la diferencia de cota entre el eje maestro y esclavo. [...] El proceso sólo se puede interrumpir con reset. La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección" .

ns1:SistemaDeSubrutinasCNC_1178 a ns1:Sistema ;
    rdfs:label "Sistema de subrutinas del CNC"@es ;
    ns1:compuestoPor ns1:SubrutinaBusquedaReferencia_1178,
        ns1:SubrutinaCambioHerramienta_1178 ;
    ns1:textoExtracto "serie de subrutinas que, en función de la configuración de la máquina, deben estar definidas"@es .

ns1:SistemaEjeTandem a ns1:Sistema ;
    rdfs:label "Sistema de eje tándem con configuración Master-Slave" ;
    ns1:compuestoPor ns1:ComponenteMecanico_Cremallera,
        ns1:MotorMasterTandem,
        ns1:MotorSlaveTandem ;
    ns1:textoExtracto "Dibujo lineal, con jerarquía simple (motores arriba, transmisión abajo) para explicar la arquitectura y requisitos de configuración." .

ns1:SistemaEjesFresadora a ns1:ComponenteMecanico ;
    rdfs:label "Sistema de ejes triedro (XYZ) para fresadora"@es ;
    ns1:compuestoPor ns1:EjeX_Fresadora,
        ns1:EjeY_Fresadora,
        ns1:EjeZ_Fresadora ;
    ns1:textoExtracto "máquina con tres ejes (X+, Y+, Z+), propia de fresadora. [...] base para programar trayectorias en 3D."@es .

ns1:SistemaEjesNoPerpendiculares_ZX a ns1:Sistema ;
    rdfs:label "Sistema de ejes no perpendiculares (Z-X')"@es ;
    ns1:compuestoPor ns1:EjeX,
        ns1:EjeZ ;
    ns1:textoExtracto "Un caso típico es el eje X de torno que [...] no forma 90º con el eje Z, sino que tiene otro valor. X [...] Eje angular. Z [...] Eje ortogonal."@es,
        "ejes reales no perpendiculares (Z-X')"@es .

ns1:SistemaEjesTorno a ns1:ComponenteMecanico ;
    rdfs:label "Sistema de ejes plano (ZX) para torno"@es ;
    ns1:compuestoPor ns1:EjeX_Torno,
        ns1:EjeZ_Torno ;
    ns1:textoExtracto "máquina con dos ejes principales (Z+ y X+) representados; el plano de trabajo habitual es G18 (ZX)."@es .

ns1:SistemaEjes_Canal1 a ns1:Sistema ;
    rdfs:label "Configuración de ejes y cabezales del canal 1"@es ;
    ns1:detalladoEnEsquema ns1:TablaConfiguracionEjes ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ1ꞏ."@es ;
    ns1:tieneComponente ns1:Cabezal_S1,
        ns1:Eje_X,
        ns1:Eje_Y,
        ns1:Eje_Z .

ns1:SistemaFCAS a ns1:Sistema ;
    rdfs:label "FCAS (control de colisiones)"@es ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "nuevo FCAS (control de colisiones)"@es .

ns1:SistemaFresadoraPuente a ns1:Sistema ;
    rdfs:label "Sistema de fresadora puente con configuración gantry" ;
    ns1:compuestoPor ns1:EjeGantry_XU,
        ns1:EjeGantry_ZW ;
    ns1:textoExtracto "La jerarquía visual distingue la estructura (bancada y pórtico) del conjunto móvil (cabezal), destacando la necesidad de sincronía maestro–esclavo en cada pareja de ejes." .

ns1:SistemaGantryEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes gantry" ;
    ns1:textoExtracto "GANTRYOFF(axis) Esta marca hace referencia al eje esclavo del gantry. Si el PLC activa esta marca (cambio de 0 a 1), el CNC desacopla el eje gantry y permite mover sólo el eje maestro." .

ns1:SistemaGestionPLC_493 a ns1:Sistema ;
    rdfs:label "Sistema gestor PLC (pág. 493)"@es ;
    ns1:textoExtracto "los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es .

ns1:SistemaLatcheoCotas a ns1:Sistema ;
    rdfs:label "Sistema de latcheo de cotas" ;
    ns1:compuestoPor ns1:InterpoladorIndependiente ;
    ns1:textoExtracto "Todos los procesos de latcheo activos que estén asignados a un mismo palpador, se desactivan al producirse un evento de latch sobre cualquiera de ellos.",
        "latcheo de cotas"@es ;
    ns1:tieneComponente ns1:Eje_X,
        ns1:Eje_Y,
        ns1:G100,
        ns1:G101,
        ns1:G102,
        ns1:Palpador_1,
        ns1:Palpador_2 .

ns1:SistemaLevasElectronicas a ns1:Sistema ;
    rdfs:label "Sistema de levas electrónicas"@es ;
    ns1:compuestoPor ns1:EditorLevasElectronicas ;
    ns1:textoExtracto "Este parámetro establece el número de levas electrónicas del sistema."@es .

ns1:SistemaLubricacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de lubricación de ejes" ;
    ns1:requiereMantenimiento ns1:TareaEngraseEjes ;
    ns1:textoExtracto "LUBR(axis) se deben utilizar para el engrase de los ejes. [...] Con LUBRENA a (=1) el CNC actúa del siguiente modo: [...] El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1)" ;
    ns1:tieneComponente ns1:ComponenteLubricacionEje .

ns1:SistemaMultieje_1093 a ns1:Sistema ;
    rdfs:label "Sistema multieje con dos ejes y un único motor"@es ;
    ns1:detalladoEnEsquema ns1:EsquemaConfiguracion_1093 ;
    ns1:textoExtracto "Ejemplo 2. Sistema con dos ejes y sólo un motor. El sistema tiene las siguientes características: Un único regulador controla dos ejes con el mismo motor. Cada eje utiliza un tipo de captación diferente."@es ;
    ns1:tieneComponente ns1:EjeA1_1093,
        ns1:EjeA2_1093,
        ns1:Motor_1093,
        ns1:Regulador_1093 .

ns1:SistemaMultieje_Ejemplo2 a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes y un único motor (Ejemplo 2)" ;
    ns1:compuestoPor ns1:ModuloRemoto_1,
        ns1:ModuloRemoto_2 ;
    ns1:detalladoEnEsquema ns1:Esquema_ReguladorBusCAN_Ejemplo2 ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2; ambos ejes usan captación directa a módulos remotos diferentes (1 y 2)." ;
    ns1:tieneComponente ns1:Eje_A1,
        ns1:Eje_A2,
        ns1:Motor_Ejemplo2 .

ns1:SistemaOperativo_Windows7 a ns1:Componente ;
    rdfs:label "Windows 7"@es ;
    ns1:identificador "Windows 7" ;
    ns1:textoExtracto "PC industrial equipado con sistema operativo Windows 7"@es .

ns1:SistemaOperativo_WindowsXP_Embedded a ns1:Componente ;
    rdfs:label "Windows XP Embedded"@es ;
    ns1:identificador "Windows XP Embedded" ;
    ns1:textoExtracto "PC industrial equipado con sistema operativo Windows XP Embedded"@es .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema de anillo Sercos" ;
    ns1:textoExtracto "Durante la inicialización del anillo Sercos, en el arranque del CNC y en la validación de los parámetros máquina de los ejes y cabezales, el CNC actualiza en los reguladores el valor de los parámetros necesarios para asegurar su equivalencia." .

ns1:SistemaTandem_1073 a ns1:Sistema ;
    rdfs:label "Sistema de tándem con dos motores"@es ;
    ns1:controla ns1:Parametro_PRELOAD_1073,
        ns1:Parametro_TORQDIST_1073 ;
    ns1:textoExtracto "Habilitar el tándem con ambos motores. [...] Asegurarse de que no hay golpes y que cada motor realiza el par que le corresponde, según los parámetros 'TORQDIST' y 'PRELOAD'."@es ;
    ns1:tieneComponente ns1:MotorTandem_1_1073,
        ns1:MotorTandem_2_1073 .

ns1:SistemaTandem_67 a ns1:Sistema ;
    rdfs:label "Sistema de configuración tándem para motores" ;
    ns1:textoExtracto "los dos motores... Este parámetro hace referencia al motor maestro." ;
    ns1:tieneComponente ns1:MotorEsclavo_67,
        ns1:MotorMaestro_67,
        ns1:Parametro_Ki_67,
        ns1:Parametro_Kp_67,
        ns1:Parametro_Smax_67,
        ns1:Parametro_TCOMPLIM_67,
        ns1:Parametro_TINTTIME_67,
        ns1:Parametro_Terr_67,
        ns1:Parametro_Tnom_67 .

ns1:SistemaTemperaturaCNC a ns1:Sensor ;
    rdfs:label "Sensor de temperatura del CNC" ;
    ns1:textoExtracto "riesgo de sobretemperatura" .

ns1:Sistema_AnilloSercos a ns1:Sistema ;
    rdfs:label "Anillo Sercos" ;
    ns1:controla ns1:Maquina_ConHolgura ;
    ns1:textoExtracto "Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos.",
        "cuando se inicializa el anillo Sercos" ;
    ns1:tieneComponente ns1:Sensor_CaptacionMotor .

ns1:Sistema_ArchivosInformacionAdicional a ns1:Sistema ;
    rdfs:label "Sistema de archivos de información adicional para errores y mensajes del PLC"@es ;
    ns1:documentadoEn ns1:Pagina_403_404 ;
    ns1:textoExtracto "Los mensajes y errores de PLC pueden mostrar un archivo de información adicional en formato texto. El PLC permite agrupar varios o todos estos archivos en un sólo archivo."@es .

ns1:Sistema_BusEtherCAT a ns1:Sistema ;
    rdfs:label "Bus EtherCAT (topología configurable)"@es ;
    ns1:detalladoEnEsquema ns1:Interfaz_KPA_EtherCAT_Studio ;
    ns1:textoExtracto "Configurar la topología del bus"@es .

ns1:Sistema_BusMDP a ns1:Sistema ;
    rdfs:label "Bus MDP con topología máster-nodo"@es ;
    ns1:compuestoPor ns1:Componente_MasterMDP ;
    ns1:monitoreaParametro ns1:Parametro_ModulosConectados ;
    ns1:textoExtracto "máster de la topología [...] cabeceras detectadas [...] módulos detectados en cada nodo."@es .

ns1:Sistema_CNC8070_V3.15 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070 (versión V3.15)" ;
    ns1:identificador "V3.15" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta, hay que poner en el parámetro ABSOFF el valor que tiene el regulador en PP177 ó PP178" ;
    ns1:tieneComponente ns1:Parametro_ABSOFF .

ns1:Sistema_CNC8070_V3.20 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070 (versión V3.20)" ;
    ns1:identificador "V3.20" ;
    ns1:textoExtracto "A partir de la versión V3.20, cuando instalamos el software por primera vez, no aparece ninguna carpeta MTB en la carpeta CNC8070. En la nueva carpeta CONFIGURATION, el CNC dispone de una carpeta MTB diferente para cada tipo de software instalado" .

ns1:Sistema_CNC8070_V4.00 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070 (versión V4.00)" ;
    ns1:activaAlarma ns1:Error_E9332 ;
    ns1:identificador "V4.00" ;
    ns1:textoExtracto "Al instalar la versión V4.00 no se garantiza que el CNC mantenga los orígenes activos ni el estado de las marcas de sincronización. Ejes Sercos. Durante la actualización desde una versión V3.00 o posterior, el CNC mostrará un error E9332 por cada eje Sercos con captación externa" .

ns1:Sistema_Cabezal_Desplazamiento a ns1:Sistema ;
    rdfs:label "Sistema de desplazamiento del cabezal"@es ;
    ns1:compuestoPor ns1:Parametro_Velocidad_Desplazamiento ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal."@es .

ns1:Sistema_CalibracionMesaRotativa a ns1:Sistema ;
    rdfs:label "Sistema de calibración de mesa rotativa" ;
    ns1:textoExtracto "Procedimiento para preselección de origen en X (A=90°, B=-90°) y cálculo de parámetros mediante palpación en ejes X/Z." ;
    ns1:tieneComponente ns1:Parametro_DeltaY1,
        ns1:Parametro_DeltaY2,
        ns1:Parametro_DeltaZ1,
        ns1:Parametro_DeltaZ2,
        ns1:Parametro_Pz,
        ns1:Parametro_RadioCilindro,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_X1,
        ns1:Parametro_Z .

ns1:Sistema_CaptacionExterna a ns1:Sistema ;
    rdfs:label "Sistema de captación externa",
        "Captación externa (directa) del eje"@es ;
    ns1:monitoreaParametro ns1:Parametro_FBACKDIFF,
        ns1:Parametro_FBACKSEL ;
    ns1:textoExtracto "si utiliza captación externa se toma de la captación directa",
        "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota"@es .

ns1:Sistema_CaptacionInterna a ns1:Sistema ;
    rdfs:label "Sistema de captación interna" ;
    ns1:monitoreaParametro ns1:Parametro_FBACKSEL ;
    ns1:textoExtracto "Si se utiliza captación interna, el valor de la posición se toma de la captación motor" .

ns1:Sistema_CaptacionMixta a ns1:Sistema ;
    rdfs:label "Sistema de captación interna+externa" ;
    ns1:compuestoPor ns1:Sistema_CaptacionExterna,
        ns1:Sistema_CaptacionInterna ;
    ns1:monitoreaParametro ns1:Parametro_FBACKDIFF,
        ns1:Parametro_FBACKSEL ;
    ns1:textoExtracto "Cuando el tipo de captación es interna+externa, desde el PLC se puede conmutar entre ambas captaciones con la marca FBACKSEL(axis)" .

ns1:Sistema_CompensacionEjeEsclavo a ns1:Sistema ;
    rdfs:label "Sistema de compensación con eje esclavo" ;
    ns1:controla ns1:Parametro_LASERFOLLOW ;
    ns1:textoExtracto "Para la compensación se utiliza un eje esclavo que sigue a los ejes principales."@es .

ns1:Sistema_ConfiguracionEjeRotativo a ns1:Sistema ;
    rdfs:label "Configuración de eje rotativo (módulo)",
        "Configuración de eje rotativo en CNC" ;
    ns1:monitoreaParametro ns1:Parametro_AXISMODE,
        ns1:Parametro_AXISTYPE,
        ns1:Parametro_LIMIT_Negative,
        ns1:Parametro_LIMIT_Positive,
        ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR ;
    ns1:textoExtracto "Configuración de los parámetros máquina. Los parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje; no hay límites de recorrido.",
        "El CNC admite diferentes formas de configurar un eje rotativo, en función de como va a realizar los desplazamientos. Así el CNC puede tener ejes rotativos con límites de recorrido, por ejemplo entre 0º y 180º (eje rotativo linearlike); ejes que siempre se desplacen en el mismo sentido (eje rotativo unidireccional); ejes que elijan el camino más corto (eje rotativo de posicionamiento)." ;
    ns1:tieneComponente ns1:Parametro_AXISMODE,
        ns1:Parametro_AXISMODE_Linearlike,
        ns1:Parametro_AXISTYPE,
        ns1:Parametro_LIMIT_Negative,
        ns1:Parametro_LIMIT_Positive,
        ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODLOWLIM_SinFuncion,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_MODUPLIM_SinFuncion,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_SHORTESTWAY_SinFuncion,
        ns1:Parametro_UNIDIR,
        ns1:Parametro_UNIDIR_SinFuncion .

ns1:Sistema_ControlAceleracion a ns1:Sistema ;
    rdfs:label "Sistema de control de aceleración"@es ;
    ns1:textoExtracto "mejoran la respuesta del sistema en los cambios de aceleración"@es .

ns1:Sistema_ControlAvance a ns1:Sistema ;
    rdfs:label "Sistema de control de avance (feedrate)"@es ;
    ns1:textoExtracto "Programmed FFGAIN Feedrate"@es .

ns1:Sistema_ControlPosicion a ns1:Sistema ;
    rdfs:label "Sistema de control de posición"@es ;
    ns1:textoExtracto "Actual position"@es .

ns1:Sistema_Ejes a ns1:Sistema ;
    rdfs:label "Sistema de ejes" ;
    ns1:textoExtracto "Un canal podrá tener asociado inicialmente uno, varios o ninguno de los ejes definidos en el sistema." ;
    ns1:tieneComponente ns1:Parametro_NAXIS .

ns1:Sistema_EntradasCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de entradas de captación" ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en los módulos remotos, en la captación libre de un regulador Sercos, en una contadora Sercos o en las entradas de captación locales de la unidad central." ;
    ns1:tieneComponente ns1:ContadoraSercos_RCS_S .

ns1:Sistema_EntradasSalidasLocales a ns1:Sistema ;
    rdfs:label "Sistema de E/S locales LI/O1-LI/O8" ;
    ns1:controla ns1:Parametro_NLOCOUT ;
    ns1:monitoreaParametro ns1:Parametro_EXPSCHK ;
    ns1:textoExtracto "La unidad central dispone de un conjunto de 8 señales digitales locales, identificadas como LI/O1 a LI/O8, que pueden configurarse tanto de entrada como de salida." ;
    ns1:tieneComponente ns1:ComponenteElectrico_LIO1,
        ns1:ComponenteElectrico_LIO2,
        ns1:ComponenteElectrico_LIO3,
        ns1:ComponenteElectrico_LIO4,
        ns1:ComponenteElectrico_LIO5,
        ns1:ComponenteElectrico_LIO6,
        ns1:ComponenteElectrico_LIO7,
        ns1:ComponenteElectrico_LIO8 .

ns1:Sistema_GestorHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas",
        "Gestor de herramientas"@es,
        "Gestor de herramientas en estado de emergencia"@es,
        "Sistema de gestión de herramientas (PLC)"@es ;
    ns1:controla ns1:Parametro_TMOPERATION ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:monitoreaParametro ns1:Parametro_VTM_MZMODE,
        ns1:Registro_MZPOSMZ1,
        ns1:Senal_TCHANGEOKMZ1 ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén. [...] Utilizar con almacén asíncrono o síncrono con brazo. [...] Utilizar con almacén que permite herramientas de tierra.",
        "Señales modificables del gestor de herramientas.",
        "El gestor se puede poner en estado de emergencia si se produce una anomalía (el PLC ha ejecutado una acción equivocada, cambio no finalizado, etc) o si el PLC activa la emergencia."@es,
        "Operaciones válidas del gestor de herramientas para este almacén."@es,
        "Señales modificables del gestor de herramientas"@es,
        "el gestor actualiza la tabla de almacén. [...] el gestor comprueba si hay alguna herramienta en el cabezal [...] comunica al PLC la operación a efectuar"@es ;
    ns1:tieneComponente ns1:Herramienta_T7,
