ns1:AceleracionLineal a ns1:Parametro ;
    rdfs:label "Aceleración lineal"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La peor respuesta se consigue con la aceleración lineal."@es .

ns1:AceleracionSenoCuadrado a ns1:Parametro ;
    rdfs:label "Aceleración seno cuadrado"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La aceleración seno cuadrado es una mejora a la aceleración trapezoidal, que suaviza el jerk para que los desplazamientos sean más suaves y sufra menos la mecánica del eje."@es .

ns1:AceleracionTrapezoidal a ns1:Parametro ;
    rdfs:label "Aceleración trapezoidal"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La aceleración trapezoidal permite programar rampas con objeto de suavizar los cambios de aceleración y deceleración."@es .

