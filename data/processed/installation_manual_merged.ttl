    rdfs:label "Repetir fase de aprendizaje del DMC"@es ;
    ns1:documentadoEn ns1:Pagina_730_731 ;
    ns1:textoExtracto "Opciones del DMC (menú desplegable): Repetir la fase de aprendizaje del DMC."@es .

ns1:Tarea_AparcarEje a ns1:TareaMantenimiento ;
