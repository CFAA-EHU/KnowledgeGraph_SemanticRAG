ns1:TablaRedefinicionCinematica1_16 a ns1:Tabla ;
    rdfs:label "Tabla para redefinir cinemáticas tipo 1..16 como vectoriales"@es ;
    ns1:documentadoEn ns1:ManualBroaching ;
    ns1:identificador "2.9.12" ;
    ns1:textoExtracto """\r
TDATA11 | TDATA2\r
TDATA12 | TDATA6*SIN(TDATA7)\r
TDATA13 | TDATA6*COS(TDATA7)\r
TDATA14 | 0\r
TDATA15 | SIN(TDATA7)\r
TDATA16 | COS(TDATA7)\r
TDATA17 | TDATA9\r
TDATA18 | TDATA11\r
TDATA19 | 0, si TDATA12=0 o TDATA12=1\r
         | 1, si TDATA12=2 o TDATA12=3.\r
TDATA21 | TDATA5\r
TDATA22 | 0\r
TDATA23 | TDATA1\r
TDATA24 | 0\r
TDATA25 | 0\r
TDATA26 | 1\r
"""@es ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA17,
        ns1:Parametro_TDATA18,
        ns1:Parametro_TDATA19,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA21,
        ns1:Parametro_TDATA26,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA9 .

