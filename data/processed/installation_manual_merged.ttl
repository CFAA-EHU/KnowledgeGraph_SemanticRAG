ns1:Tabla_12_1_5_Variables_MPG a ns1:Tabla ;
    rdfs:label "Tabla de variables MPG accesibles desde PRG, PLC e INT"@es ;
    ns1:documentadoEn ns1:Pagina_611_612 ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es .

ns1:Tabla_CodigosTecla_Espanol a ns1:Tabla ;
    rdfs:label "Tabla de códigos de tecla para distribución 'Español (España)'"@es ;
    ns1:identificador "8.5.1 Scan codes. Distribución de teclado 'Español (España)'" ;
    ns1:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT], de la siguiente manera; para el tercer carácter, utilizar el código correspondiente a la tecla [ALT GR]."@es .

ns1:Tabla_ParametrosCompensacionVolumetrica_1123 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de compensación volumétrica (Pág. 607)"@es ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| --- | --- | --- |\r
| VOLCOMP MPG |  | Este parámetro muestra las tablas de compensación volumétrica. |\r
| VMOVAXIS1 MPG, VMOVAXIS2, VMOVAXIS3 |  | Ejes que al moverse generan variaciones... definen el volumen a compensar. |\r
| NPOINTSAX1 MPG, NPOINTSAX2, NPOINTSAX3 |  | Número de puntos que definen el volumen a compensar en cada eje... |\r
| INIPOSAX1 MPG, INIPOSAX2, INIPOSAX3 |  | Posición inicial de la compensación volumétrica básica para el MOVAXIS. |\r
| INCREAX1 MPG, INCREAX2, INCREAX3 |  | Intervalo entre puntos para el eje MOVAXIS... |\r
| VCOMPAXIS1 MPG, VCOMPAXIS2, VCOMPAXIS3 |  | Estos parámetros definen los ejes a compensar mediante la compensación volumétrica... """ .

