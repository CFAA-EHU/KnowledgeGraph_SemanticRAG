ns1:Tabla_CompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tablas de compensación cruzada" ;
    ns1:documentadoEn ns1:Manual_Operacion ;
    ns1:textoExtracto "Este parámetro muestra las tablas de compensación cruzada. La compensación cruzada se utiliza cuando dependiendo del desplazamiento de un eje, otro eje sufre variaciones de posición." .

ns1:Tabla_ComunicacionPLC_Gestor_732 a ns1:Tabla ;
    rdfs:label "Tabla de marcas/registros para comunicación PLC --> Gestor (Sección 7.3.2)"@es ;
    ns1:textoExtracto """\r
| Marcas / Registros. | Significado. |\r
| --- | --- |\r
| MZTOCH1 | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1. |\r
| CH1TOSPDL | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal. |\r
| SPDLTOCH1 | Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1. |\r
| SPDLTOCH2 | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2. |\r
| CH1TOMZ | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén.\r
""" .

ns1:Tabla_ConfiguracionEjesCanal3 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales del canal 3"@es ;
    ns1:documentadoEn ns1:Pagina_561 ;
    ns1:textoExtracto """\r
| CHAXISNAME | Valor. | Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHAXISNAME 1 | X1 | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ4ꞏ. |\r
| CHAXISNAME 2 | Y1 | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ5ꞏ. |\r
| CHAXISNAME 3 | Z1 | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ6ꞏ. |\r
| CHAXISNAME 3 | W | Eje con índice ꞏ4ꞏ. | Número lógico ꞏ7ꞏ.\r
\r
| CHSPDLNAME | Valor. | Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHSPDLNAME 1 | S2 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ11ꞏ.\r
"""@es .

