    ns1:documentadoEn ns1:Tabla_MANUAL,
        ns1:Tabla_Manual ;
    ns1:identificador "(V.)[ch].MPA.MAXMANFEED.xn",
        "MAXMANFEED" ;
    ns1:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED.",
        "Este parámetro define el avance máximo para los desplazamientos en jog continuo en modo manual.",
        "MAXMANFEED: 120 mm/min.",
        "Modo de trabajo manual. Avance máximo en modo jog continuo.",
        "Avance máximo en modo jog continuo."@es,
        "MAXMANFEED Avance máximo en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales. [...]"@es ;
    ns1:valor "10000.0000 mm/min / 393.70079 inch/min / 10000.0000 grados/min",
        "120 mm/min" .

ns1:Parametro_PEAKDISP a ns1:Parametro ;
    rdfs:label "PEAKDISP",
        "Parámetro PEAKDISP"@es ;
    ns1:identificador "MPA.PEAKDISP[set].xn",
        "PEAKDISP" ;
    ns1:textoExtracto "El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica, a la que el CNC corta el pico de inversión en dicho eje (impulso adicional de consigna).",
        "La captación indica la distancia parámetros PEAKDISP. Posición teórica. movimiento (PEAKDISP).",
        "La duración de esta consigna adicional depende de los parámetros BAKTIME y PEAKDISP.",
        "PEAKDISP: Distancia de corte del pico de holgura. [...] Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados.",
        "Parámetro válido para regulador analógico y Sercos. [...] El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica"@es ;
    ns1:valor 0.0,
        "0-99999.9999 mm / 0-3937.00787 inch / 0-99999.9999 grados",
        "0.0050"^^xsd:string,
        "[rev/min]" .

ns1:Parametro_PRBDI1 a ns1:Parametro ;
    rdfs:label "PRBDI1",
        "Parámetro de palpador/entrada digital 1 (PRBDI1)",
        "Parámetro PRBDI1 (entrada digital para latcheo)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "MPG.PRBDI1",
        "PRBDI1" ;
    ns1:monitoreaParametro ns1:ProcesoLatcheoEje,
        ns1:Sistema_LatcheoCota ;
    ns1:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1",
        "El palpador 1 será el asignado al parámetro PRBDI1 y el palpador 2 será el asignado al parámetro PRBDI2. En vez de un palpador, también se puede utilizar como evento una entrada digital física o de una entrada lógica. En este caso, la entrada a utilizar también deberá estar definida en los parámetros PRBDI1 o PRBDI2.",
        "El palpador 1 será el asignado al parámetro PRBDI1.",
        "PRBDI1 Número de entrada asociada al palpador 1. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado). Variable asociada: (V.)MPG.PRBDI1",
        "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es,
        "Número de entrada asociada al palpador 1."@es ;
    ns1:valor "0" .

ns1:Parametro_PRBDI2 a ns1:Parametro ;
    rdfs:label "PRBDI2",
