ns1:PLC_780 a ns1:Actuador ;
    rdfs:label "PLC"@es ;
    ns1:identificador "PLC"@es ;
    ns1:textoExtracto "Si el PLC activa la"@es .

ns1:PLC_869 a ns1:Actuador ;
    rdfs:label "PLC"@es ;
    ns1:controla ns1:AlmacenHerramientas_869 ;
    ns1:textoExtracto "El PLC, que es el encargado de controlar dichos movimientos, debe informar al gestor de las acciones efectuadas para que actualice su información."@es .

ns1:PLC_ControlCNC a ns1:Sistema ;
    rdfs:label "PLC de control CNC" ;
    ns1:controla ns1:Senal_EMERGEN,
        ns1:Senal_FEEDHOL,
        ns1:Senal_STOP ;
    ns1:monitoreaParametro ns1:Senal_CNCREADY,
        ns1:Senal_FHOUT,
        ns1:Senal_START ;
    ns1:textoExtracto "El PLC tiene acceso a determinada información interna del CNC. Hay señales del CNC (marcas y registros) que pueden ser consultadas y otras que pueden ser modificadas por el PLC."@es .

ns1:PLC_ControlCabezal a ns1:Sistema ;
    rdfs:label "PLC (control de cabezal)" ;
    ns1:controla ns1:Cabezal_ModoAnalogico,
        ns1:Cabezal_SercosPosicion,
        ns1:Cabezal_SercosVelocidad ;
    ns1:monitoreaParametro ns1:Parametro_PLCCNTL,
        ns1:Parametro_SANALOG ;
    ns1:textoExtracto "Cuando el PLC pone la marca PLCCNTL a (=1), el cabezal decelera con rampa hasta detenerse y pasa a estar controlado por el PLC." .

ns1:PLC_ControlCabezales a ns1:Sistema ;
    rdfs:label "PLC de control de cabezales" ;
    ns1:controla ns1:CNC_SistemaControl ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn [...] Cuando el PLC activa una de estas marcas, el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente." .

ns1:PLC_Controlador a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:controla ns1:FuncionM11,
        ns1:FuncionM12,
        ns1:FuncionM13,
        ns1:FuncionM14 ;
    ns1:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12. Se envía la función M14 al PLC.",
        "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12. Se envía la función M14 al PLC. Se espera a que el PLC ejecute las funciones M13 y M14." .

ns1:PLC_GrupoMultieje a ns1:Sistema ;
    rdfs:label "PLC para gestión de grupos multieje" ;
    ns1:controla ns1:Regulador_Ejes ;
    ns1:monitoreaParametro ns1:Parametro_GV21,
        ns1:Parametro_GV25 ;
    ns1:textoExtracto "Los grupos multieje se gestionan desde el PLC, para lo cual dispone de la siguiente marca." ;
    ns1:tieneComponente ns1:Se_al_SWITCH_axis .

ns1:PLC_InterfazTeclado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclado del PLC"@es ;
    ns1:ilustradoEn ns1:Tabla_DistribucionesTeclado ;
    ns1:textoExtracto "La distribución del teclado controla los caracteres que aparecen en la pantalla cuando se pulsan las teclas. Para que los caracteres de la pantalla coincidan con las teclas, en el sistema operativo hay que seleccionar la distribución de teclado adecuada. Los código de tecla (scan codes) también dependen de la distribución de teclado seleccionada."@es ;
    ns1:tieneComponente ns1:Teclado_EspanolEspana,
        ns1:Teclado_InglesEEUU .

ns1:PLC_Jog a ns1:Actuador ;
    rdfs:label "PLC de gestión de paneles de jog" ;
    ns1:controla ns1:Sistema_Jog ;
    ns1:textoExtracto "la maniobra del PLC debe incluir las restricciones adecuadas para evitar cambios bruscos en el avance debidas a posiciones diferentes del conmutador del feed override en los diferentes teclados. También se recomienda gestionar las teclas de usuario mediante sus flancos de subida y bajada, para evitar la posible activación de dispositivos al cambiar de teclado." .

ns1:PLC_ManiobraGapRetiro a ns1:Sistema ;
    rdfs:label "PLC Gap Retraction Maneuver" ;
    ns1:identificador "TG1 333" ;
    ns1:textoExtracto "DFU {conditions} AND NOT M666 AND NOT INCYCLE = RES ENABLEGAP = RES ENABLELEAP = SET IRESETZ = TG1 333 12 ; Tiempo de espera, 12 milisegundos. T333 = M666 DFD M666 = RES IRESETZ = MOVE ABS (Z, 513000,50000000,NULL) DFDB B10KEYLED1 = SET ENABLEGAP = SET ENABLELEAP" ;
    ns1:tieneComponente ns1:Interfaz_B10KEYLED1,
        ns1:Senal_M666,
        ns1:Temporizador_T333 .

ns1:PLC_MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "Marca PLC TCHANGEOK (continuación de ejecución)" ;
    ns1:controla ns1:RutinaM06_Caso5 ;
    ns1:identificador "M[1100]" ;
    ns1:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." ;
    ns1:valor "1" .

ns1:PLC_Multieje a ns1:Actuador ;
    rdfs:label "PLC de control multieje" ;
    ns1:controla ns1:Marca_DRENA,
        ns1:Marca_ENABLE,
        ns1:Marca_SERVOON,
        ns1:Marca_SPENA,
        ns1:Marca_SWITCH ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:PLC_RecursosProgramacion a ns1:Sistema ;
    rdfs:label "Recursos de programación del PLC"@es ;
    ns1:compuestoPor ns1:PLC_Contadores,
        ns1:PLC_Entradas,
        ns1:PLC_Marcas,
        ns1:PLC_MarcasCNC,
        ns1:PLC_MarcasErrores,
        ns1:PLC_MarcasMensajes,
        ns1:PLC_Registros,
        ns1:PLC_Relojes,
        ns1:PLC_Salidas,
        ns1:PLC_Temporizadores ;
    ns1:textoExtracto "Recursos disponibles en el PLC. Entradas (I1ꞏꞏI1024) Salidas (O1ꞏꞏO1024) Marcas (M1ꞏꞏM8192) Marcas de mensajes (MSG1ꞏꞏMSG1024) Marcas de errores (ERR1ꞏꞏERR1024) Relojes (CLK) Marcas CNC-PLC Temporizadores (T1ꞏꞏT512) Contadores (C1ꞏꞏC256) Registros (R1ꞏꞏR1024) Registros CNC-PLC"@es .

ns1:PLC_Recursos_EntradasSalidas a ns1:Sistema ;
    rdfs:label "Recursos de E/S del PLC"@es ;
    ns1:textoExtracto "El PLC dispone de los siguientes recursos. • Entradas (I1-I1024) y salidas (O1-O1024). [...] Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico."@es ;
    ns1:tieneComponente ns1:PLC_EntradasLocales,
        ns1:PLC_Entradas_Globales,
        ns1:PLC_SalidasLocales,
        ns1:PLC_Salidas_Globales .

ns1:PLC_Recursos_Memoria a ns1:Sistema ;
    rdfs:label "Recursos de memoria y temporización del PLC"@es ;
    ns1:textoExtracto "Marcas (M1-M8192). [...] Mensajes (MSG1-MSG1024). [...] Errores (ERR1-ERR1024). [...] Relojes (CLK). [...] Registros (R1-R1024). [...] Temporizadores (T1-T512). [...] Contadores (C1-C256)."@es ;
    ns1:tieneComponente ns1:PLC_Contadores,
        ns1:PLC_Errores,
        ns1:PLC_Marcas,
        ns1:PLC_Mensajes,
        ns1:PLC_Registros,
        ns1:PLC_Relojes,
        ns1:PLC_Temporizadores .

