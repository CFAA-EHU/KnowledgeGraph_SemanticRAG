ns1:Esquema_ConexionadoSensorGap_CAN a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap vía CAN (RIOR)" ;
    ns1:detalladoEnEsquema ns1:EntradaAnalogicaEnModuloRIORAI1AI1,
        ns1:ModuloRemotoRIORCAN ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR'" .

ns1:Esquema_ConfigEjesPlanoTorno a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo plano (torno)"@es ;
    ns1:ilustradoEn ns1:Pagina_8070749fe5 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo plano (torno)': máquina con dos ejes principales (Z+ y X+) representados; el plano de trabajo habitual es G18 (ZX). La vista ayuda a interpretar qué ejes forman abscisas/ordenadas y cómo afecta al mecanizado y a la definición del eje longitudinal."@es .

ns1:Esquema_ConfigEjesTriedroFresadora a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo triedro (fresadora)"@es ;
    ns1:ilustradoEn ns1:Pagina_8070749fe5 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo triedro': máquina con tres ejes (X+, Y+, Z+), propia de fresadora. Sirve para visualizar el triedro cartesiano y los planos G17/G18/G19 según el orden de ejes del canal, base para programar trayectorias en 3D."@es .

ns1:Esquema_GAPTONEG_No a ns1:Esquema ;
    rdfs:label "Esquema GAPTONEG = No (eje Z invertido)"@es ;
    ns1:ilustradoEn ns1:CabezalLaser,
        ns1:Param_GAPTONEG ;
    ns1:textoExtracto "Esquema 'GAPTONEG = No': representa un eje Z invertido (Z+ hacia abajo). El movimiento para lograr el gap se realiza en sentido positivo."@es .

ns1:Esquema_GAPTONEG_Si a ns1:Esquema ;
    rdfs:label "Esquema GAPTONEG = Sí (eje Z estándar)"@es ;
    ns1:ilustradoEn ns1:CabezalLaser,
        ns1:Param_GAPTONEG ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)."@es .

ns1:Esquema_GapControlLoop a ns1:Esquema ;
    rdfs:label "Diagrama funcional del lazo de control del gap"@es ;
    ns1:detalladoEnEsquema ns1:Filtro_Cutoff,
        ns1:Param_GAP_PGAIN,
        ns1:Sensor_d0921a2cdd ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: la realimentación del sensor (GAP SENSOR FEEDBACK) entra a un bucle de posición (POSITION LOOP) con ganancia proporcional de gap (GAP P-GAIN) y un filtro de corte (CUTOFF FILTER)."@es .

ns1:Esquema_GapSensorGraph a ns1:Esquema ;
    rdfs:label "Gráfico del sensor de gap (señal vs. offset)"@es ;
    ns1:ilustradoEn ns1:Param_GAPDISTLIMIT,
        ns1:Param_GAPSENSOROFFSET,
        ns1:Param_GAPVOLTLIMIT ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical). Representa la señal del sensor (SENSOR SIGNAL) frente al offset aplicado (GAPSENSOROFFSET), el límite de voltaje (GAPVOLTLIMIT) y el límite de distancia (GAPDISTLIMIT)."@es .

ns1:Esquema_Interconexion_Sercos_RCS_AXD a ns1:Esquema ;
    rdfs:label "Esquema de interconexión Sercos con nodos RCS-S y AXD"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_Sercos_RCS_AXD ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4). Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C)."@es .

ns1:Esquema_NumeracionIOs a ns1:Esquema ;
    rdfs:label "Ejemplo de numeración de I/Os mediante parámetros máquina" ;
    ns1:ilustradoEn ns1:Nodo_RIO5,
        ns1:Nodo_RIOR,
        ns1:Nodo_RIOW ;
    ns1:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ns1:Esquema_Osciloscopio_DMC a ns1:Esquema ;
    rdfs:label "Captura del osciloscopio del DMC"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "Captura del osciloscopio. Osciloscopio. A Control del override para optimizar la potencia. B Mecanizado en G00. C Entrada a la pieza."@es .

ns1:Esquema_PrimeraPalpacion_TDATA5 a ns1:Esquema ;
    rdfs:label "Diagrama 'Primera palpación' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_95137c6bdd ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara X próxima al origen y preselección X=0; se señalan ejes X-Z y posición ①."@es .

ns1:Esquema_PrimeraPalpacion_TDATA6 a ns1:Esquema ;
    rdfs:label "Diagrama 'Primera palpación' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_12a35f6dff ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R."@es .

ns1:Esquema_RIO5_Grupo1 a ns1:Esquema ;
    rdfs:label "Esquema del Grupo 1 RIO5 (24ED/16SD)"@es ;
    ns1:detalladoEnEsquema ns1:Modulo_RIO5_Grupo1 ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único."@es .

ns1:Esquema_RotacionRegistros_RL1_RR1 a ns1:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 1 (RL1/RR1)"@es ;
    ns1:ilustradoEn ns1:Pagina_925bd29fe9 ;
    ns1:textoExtracto "flechas muestran el desplazamiento de bits y la entrada/salida de '0' por el extremo opuesto, indicando la pérdida del bit expulsado. Se visualiza la dirección de giro y la estructura de 32 bits del registro."@es .

ns1:Esquema_RotacionRegistros_RL2_RR2 a ns1:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 2 (RL2/RR2)"@es ;
    ns1:ilustradoEn ns1:Pagina_47f27b8b0f ;
    ns1:textoExtracto "rotación circular donde el bit desplazado reingresa por el extremo contrario, preservando el conjunto de 32 bits. Se ilustran, con flechas, los ciclos de rotación y la conservación de información."@es .

ns1:Esquema_TransferenciaBits_MOV a ns1:Esquema ;
    rdfs:label "Esquema de transferencia de bits en =MOV con conversión Bin↔BCD"@es ;
    ns1:ilustradoEn ns1:Pagina_925bd29fe9 ;
    ns1:textoExtracto "se representan bloques INPUT/OUTPUT con bits indexados (S1…S8/…S16) y su mapeo hacia salidas, indicando anchuras (4, 8, …, 32 bits) y códigos de origen/destino. La gráfica ilustra la conversión y el direccionamiento de grupos de bits."@es .

ns1:Esquema_cfabc38383 a ns1:Esquema ;
    ns1:identificador "JOGKEYS" ;
    ns1:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15. Indican la disposición y orden de teclas genéricas y de jog, útil para interpretar la correspondencia física-lógica de los bits en KEYBD y los efectos de selectores/overrides." .

ns1:EstadoCanal_Ejecucion a ns1:ModoOperacion ;
    rdfs:label "Estado 'En ejecución' del canal" ;
    ns1:textoExtracto "El CNC admitirá las funciones M aunque el canal esté en ejecución (ejecutando un programa, moviendo algún eje en jog, etc)" .

ns1:EstadoCanal_Error a ns1:ModoOperacion ;
    rdfs:label "Estado 'En error' del canal" ;
    ns1:textoExtracto "siempre que el status del canal sea distinto de 'En error'" .

ns1:EstadoCanal_NoReady a ns1:ModoOperacion ;
    rdfs:label "Estado 'No ready' del canal" ;
    ns1:textoExtracto "siempre que el status del canal sea distinto de [...] 'No ready'" .

ns1:EstadoDelCNCR220 a ns1:Parametro ;
    rdfs:label "Estado del CNC (R220)" ;
