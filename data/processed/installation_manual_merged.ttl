ns1:EntradaCPR_Contador a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CPR (preselección de contador)"@es ;
    ns1:identificador "CPR" ;
    ns1:monitoreaParametro ns1:ValorDePreseleccionDelContador ;
    ns1:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es .

ns1:EntradaCaptacionInterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación interna (motor)" ;
    ns1:textoExtracto "captación interna (motor) y la captación externa (directa) de un eje estén en reguladores diferentes" .

ns1:EntradaContaje_Local a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje local" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota, el eje sólo podrá operar en modo Sercos velocidad." .

ns1:EntradaContaje_Remota a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje remota" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota, el eje sólo podrá operar en modo Sercos velocidad." .

ns1:EntradaDeCaptacionModeloLaser a ns1:Parametro ;
