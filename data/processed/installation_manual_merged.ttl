ns1:Palpador_CNC_01 a ns1:Sensor ;
    rdfs:label "Palpador para cabezal angular YZ"@es ;
    ns1:monitoreaParametro ns1:Parametro_Dimension_Cabezal_YZ_01 ;
    ns1:textoExtracto "El CNC puede tener configurados dos palpadores. Antes de efectuar cualquier movimiento con el palpador, el CNC debe conocer cuál es el palpador activo [...] Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:Palpador_Evento a ns1:Sensor ;
    rdfs:label "Palpador para latcheo de cota"@es ;
    ns1:controla ns1:Sistema_LatcheoCota ;
    ns1:textoExtracto "La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador [...] Si el evento seleccionado es un palpador y al activar el comando TOUCHPROBE el palpador ya ha alcanzado su nivel lógico, la cota latcheada será la del momento de activación del comando."@es .

