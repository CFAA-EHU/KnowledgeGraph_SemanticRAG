    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es,
        "LIMIT+ | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es,
        "LIMIT- | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es,
        "Los parámetros LIMIT+ y LIMIT- no tienen significado. [...] Hay límites de recorrido fijados por LIMIT+ y LIMIT-."@es,
        "Límites inferiores de software."@es,
        "Límites superiores de software."@es .

ns1:Parametro_LIMITNEG a ns1:Parametro ;
