        ns1:Marca_CUTTINGONC2,
        ns1:Marca_CUTTINGONC3,
        ns1:Marca_CUTTINGONC4,
        ns1:Marca_TREJECTC1,
        ns1:Marca_TREJECTC2,
        ns1:Marca_TREJECTC3,
        ns1:Marca_TREJECTC4,
        ns1:Marca_TWORNOUTC1,
        ns1:Marca_TWORNOUTC2,
        ns1:Marca_TWORNOUTC3,
        ns1:Marca_TWORNOUTC4 .

ns1:Tabla_ParametrosHSC_1175 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del modo HSC (páginas 630-632)"@es ;
    ns1:textoExtracto """\r
| Variable. | Significado. |\r
| --- | --- |\r
| V.A.IPOPOS.xn | Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza. |\r
| V.A.ADDMANOF.xn | Distancia movida con G201. |\r
| V.A.INDPOS.xn | Cota teórica del interpolador independiente. |\r
| V.A.FILTERIN.xn | Cota teórica del interpolador antes del filtro. |\r
| V.A.FILTEROUT.xn | Cota teórica del interpolador después del filtro. |\r
| V.A.LOOPTPOS.xn | Cota teórica a la entrada del lazo de posición. |\r
| V.A.LOOPPOS.xn | Cota real a la entrada del lazo de posición. |\r
| V.A.TFEED.xn | Valor instantáneo teórico de la velocidad a la entrada del lazo de posición. |\r
| V.A.FEED.xn | Valor instantáneo real de la velocidad a la entrada del lazo de posición. |\r
| V.A.POSCMD.xn | Consigna de posición para Sercos. |\r
| V.A.FTEO.xn | Consigna de velocidad para Sercos (en rpm). |\r
| V.A.POSNC.xn | Feedback de posición. """@es .

