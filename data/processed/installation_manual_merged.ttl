ns1:EntradaLocal1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación local 1 (LCOUNTALARMOFF1)" ;
    ns1:identificador "LCOUNTALARMOFF1" ;
    ns1:textoExtracto "Estas marcas están referidas a las entradas de captación local 1 (LCOUNTALARMOFF1) y 2 (LCOUNTALARMOFF2)." .

