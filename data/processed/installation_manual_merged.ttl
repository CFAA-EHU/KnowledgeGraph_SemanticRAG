ns1:Tabla_ConfiguracionCanales1142 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales por canal"@es ;
    ns1:textoExtracto """\r
| Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ.\r
| CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.\r
| CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ3ꞏ.\r
\r
| CHSPDLNAME | Valor. | Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ10ꞏ.\r
""" .

ns1:Tabla_ConfiguracionEjes1145 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (CHAXISNAME/CHSPDLNAME)" ;
    ns1:textoExtracto """\r
| CHAXISNAME | Valor | Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ. |\r
| CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.\r
\r
| CHSPDLNAME | Valor | Índice en el canal. | Orden lógico. |\r
| --- | --- | --- | --- |\r
| CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ.\r
""" .

ns1:Tabla_DRIVEVAR a ns1:Tabla ;
    rdfs:label "Tabla DRIVEVAR",
        "Tabla DRIVEVAR"@es ;
