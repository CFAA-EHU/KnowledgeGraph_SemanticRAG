ns1:Parametro_dbe3be27d2 a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:monitoreaParametro ns1:Sistema_ReguladorEje ;
    ns1:textoExtracto "el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma." .

ns1:Parametro_dbea586a84 a ns1:Parametro ;
    rdfs:label "PRGABORT" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1), el canal del CNC aborta la ejecución del programa en curso pero sin afectar al cabezal; el resto de la historia se inicializa."@es ;
    ns1:valor "1" .

ns1:Parametro_dc1179fa6d a ns1:Parametro ;
    rdfs:label "LACC1",
        "LACC2" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" .

ns1:Parametro_dc17d51551 a ns1:Parametro ;
    rdfs:label "INCHES",
        "Parámetro INCHES (Cambio de unidades)"@es ;
    ns1:identificador "INCHES" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto """\r
INCHES El parámetro se ve afectado por el cambio de unidades. Valores posibles: Sí / No. Valor por defecto: Sí."""@es ;
    ns1:valor "Sí",
        "Unidad de medida (milímetros/pulgadas)"@es .

ns1:Parametro_dc269fb609 a ns1:Parametro ;
    ns1:identificador "SFUN3" ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Estos registros hacen referencia al número de cabezal; son independientes del canal en el que se encuentra el cabezal. Cada uno de los registros indica el valor de una de las funciones S programadas. Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en un bloque se encuentran programadas las funciones S1000 y S1=550, el CNC pasará al PLC la siguiente información. | SFUN1 | SFUN2 | SFUN3 | SFUN4 | | --- | --- | --- | --- | | 1000 | 550 | $FFFFFFFF | $FFFFFFFF |" ;
    ns1:valor "$FFFFFFFF" .

ns1:Parametro_dc39adda7a a ns1:Parametro ;
    rdfs:label "Parámetro máquina FBACKSRC"@es ;
    ns1:textoExtracto "Consultar el parámetro máquina FBACKSRC. [...] El CNC pone esta marca a (=1) para indicar que se está trabajando con la captación externa (captación directa)."@es ;
    ns1:valor "1 (captación externa), 0 (captación interna)" .

ns1:Parametro_dcd540a52b a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G174" ;
    ns1:textoExtracto "tras fijar la cota máquina (G174)"@es .

