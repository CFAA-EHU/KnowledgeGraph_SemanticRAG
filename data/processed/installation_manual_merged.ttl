ns1:SistemaSincronizacionCabezales a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales" ;
    ns1:identificador "SYNCHRON" ;
    ns1:textoExtracto "SYNCHRON Hay una marca para cada cabezal. Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6 Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema de configuración tándem de motores",
        "Sistema tándem",
        "Sistema tándem (motores maestro-esclavo)",
        "Sistema de parejas tándem"@es,
        "Sistema tándem"@es ;
    ns1:compuestoPor ns1:AccionamientoElectrico1,
        ns1:AccionamientoElectrico2,
        ns1:EjeEsclavoTandem,
        ns1:EjeMaestroTandem ;
    ns1:documentadoEn ns1:TablaEjesTandem,
        ns1:Tabla_TANDEM ;
    ns1:monitoreaParametro ns1:Parametro_ParTandem_Maestro,
        ns1:Parametro_PreloadTandem ;
    ns1:textoExtracto "Configuración de un sistema tándem... Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem.",
        "En un sistema tándem, sólo se referencia el eje maestro; la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro.",
        "La precarga es el par previo que se aplica, en sentidos opuestos, a ambos motores del tándem para establecer una tracción entre ellos con el fin de eliminar la holgura cuando el tándem se encuentra en reposo. [...] La aplicación del valor de precarga implica necesariamente la unión mecánica entre los motores maestro y esclavo que forman el tándem.",
        "Configuración de un sistema tándem."@es,
        "Las parejas tándem del sistema..."@es,
        "Un eje tándem consiste en dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)."@es ;
    ns1:tieneComponente ns1:AccionamientoElectrico1,
        ns1:AccionamientoElectrico2,
        ns1:ComponenteMecanico_MotorEsclavo,
        ns1:ComponenteMecanico_MotorMaestro,
        ns1:MotorMaestro,
        ns1:Motor_Esclavo,
        ns1:Motor_Maestro,
        ns1:ParametrosMaquina_ConfiguracionTandem .

ns1:SistemaTandemEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes en tándem" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente. [...] Aunque el tándem esté desacoplado, desde el punto de vista de programación, visualización, etc el tándem está activo." .

