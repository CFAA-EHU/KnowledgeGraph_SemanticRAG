ns1:ManiobraAparcarEje a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para aparcar un eje o cabezal desde el CNC"@es ;
    ns1:controla ns1:SenalPARK,
        ns1:SenalPARKED ;
    ns1:identificador "#PARK" ;
    ns1:requiereMantenimiento ns1:SistemaControlAparcado ;
    ns1:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC. 1 Cuando se ejecuta la sentencia de programación #PARK el CNC comprueba si se puede aparcar el eje requerido. En caso afirmativo, el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente. En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA). Además, el CNC envía al regulador el comando para aparcar el eje."@es .

ns1:ManiobraDesaparcarEje a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para desaparcar un eje o cabezal desde el CNC"@es ;
    ns1:controla ns1:SenalPARKED,
        ns1:SenalUNPARK ;
    ns1:identificador "#UNPARK" ;
    ns1:requiereMantenimiento ns1:SistemaControlAparcado ;
    ns1:textoExtracto "Maniobra para desaparcar un eje o cabezal desde el CNC. 4 Cuando se ejecuta la sentencia de programación #UNPARK el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente. En el caso de ejes digitales el CNC envía al regulador el comando para desaparcar el eje."@es .

ns1:ManualCNC_Seccion14_19 a ns1:Pagina ;
    rdfs:label "Sección 14.19: Subrutinas de usuario (G8000-G8999)" ;
    ns1:identificador "14.19" ;
    ns1:textoExtracto "El CNC permite al usuario definir hasta 1000 subrutinas, comunes a todos los canales, y que estarán asociadas a las funciones G8000 a G8999." .

ns1:ManualEspecificoEditorLevas a ns1:Manual ;
    rdfs:label "Manual específico del editor de levas"@es ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico."@es .

ns1:ManualOpenPCS a ns1:Manual ;
