ns1:Parametro_G2G3MODAL a ns1:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ns1:textoExtracto "G2G3MODAL: La programación en G2/G3 se mantiene modal. Valores posibles: Sí / No. Valor por defecto: Sí.",
        "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63. / Las funciones G02 y G03 no son modales; hay que programarlas en cada bloque de interpolación circular." ;
    ns1:valor "Sí/No" .

ns1:Parametro_G94 a ns1:Parametro ;
