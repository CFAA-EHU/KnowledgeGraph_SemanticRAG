ns1:Tabla_ConfiguracionCinematicas a ns1:Tabla ;
    rdfs:label "Tabla de configuración de cinemáticas (TYPE 41-52)",
        "Tabla de configuración de cinemáticas"@es ;
    ns1:ilustradoEn ns1:Pagina_251_255 ;
    ns1:textoExtracto """\r
TYPE | Tipo de cinemática.\r
---\r
TYPE = 1 | Cabezal ortogonal o esférico YX.\r
TYPE = 2 | Cabezal ortogonal o esférico ZX.\r
TYPE = 3 | Cabezal ortogonal o esférico XY.\r
TYPE = 4 | Cabezal ortogonal o esférico ZY.\r
TYPE = 5 | Cabezal angular XZ.\r
TYPE = 6 | Cabezal angular YZ.\r
TYPE = 7 | Cabezal angular ZX.\r
TYPE = 8 | Cabezal angular ZY.\r
TYPE = 9 | Mesa rotativa AB.\r
TYPE = 10 | Mesa rotativa AC.\r
TYPE = 11 | Mesa rotativa BA.\r
TYPE = 12 | Mesa rotativa BC.\r
TYPE = 13 | Cabezal - mesa AB.\r
TYPE = 14 | Cabezal - mesa AC.\r
TYPE = 15 | Cabezal - mesa BA.\r
TYPE = 16 | Cabezal - mesa BC.\r
TYPE = 17 | Cabezal ortogonal de tres ejes rotativos ABA.\r
TYPE = 18 | Cabezal ortogonal de tres ejes rotativos ACA.\r
TYPE = 19 | Cabezal ortogonal de tres ejes rotativos ACB.\r
TYPE = 20 | Cabezal ortogonal de tres ejes rotativos BAB.\r
TYPE = 21 | Cabezal ortogonal de tres ejes rotativos BCA.\r
TYPE = 22 | Cabezal ortogonal de tres ejes rotativos BCB.\r
TYPE = 23 | Cabezal ortogonal de tres ejes rotativos CAB.\r
TYPE = 24 | Cabezal ortogonal de tres ejes rotativos CBA.\r
TYPE = 41 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES.\r
TYPE = 42 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = NO.\r
TYPE = 43 | Eje C. Mecanizado en la superficie cilíndrica.""",
        "TYPE = 41 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES. [...] TYPE = 52 | Definición vectorial de cinemáticas de cabezal–mesa." .

