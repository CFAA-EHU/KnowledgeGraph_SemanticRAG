ns1:InterfazValidacionParametros_43 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de validación de parámetros CNC"@es ;
    ns1:monitoreaParametro ns1:ParametrosMaquina_43 ;
    ns1:textoExtracto "Modo de validación del parámetro. Este icono puede aparecer junto al nombre del parámetro e indica que es necesario rearrancar el CNC para que el parámetro asuma el nuevo valor. Los parámetros que no aparecen acompañados de este icono pueden asumir el nuevo valor solo con pulsar la softkey 'Validar'"@es .

ns1:Interfaz_KPA_EtherCAT_Studio a ns1:InterfazUsuario ;
