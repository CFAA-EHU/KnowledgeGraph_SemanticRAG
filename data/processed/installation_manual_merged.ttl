ns1:Sistema_ModulosRIO a ns1:Sistema ;
    rdfs:label "Sistema de módulos RIO5 y RIOR",
        "Sistema de módulos RIO5 y RIOR para entradas PT100" ;
    ns1:detalladoEnEsquema ns1:Tabla_AsignacionEntradasAnalogicas,
        ns1:Tabla_EntradasPT100 ;
    ns1:textoExtracto "Ejemplo. En un sistema con un módulo RIO5 (nodo 1) y un RIOR (nodo 2), el CNC identifica las entradas analógicas de la siguiente manera. • (address = 1) RIO5 - Entradas analógicas: 1..4; Entradas PT100: 5..6 • (address = 2) RIOR - Entradas analógicas: 7..8; Entradas PT100: 9..10",
        "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6). Los módulos RIOR tienen 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." ;
    ns1:tieneComponente ns1:Modulo_RIO5,
        ns1:Modulo_RIO5_Nodo1,
        ns1:Modulo_RIOR,
        ns1:Modulo_RIOR_Nodo2 .

ns1:Sistema_ModulosRemotosCAN a ns1:Sistema ;
    rdfs:label "Módulos remotos CAN" ;
    ns1:textoExtracto "Entrada analógica de los módulos remotos CAN. En este caso, este parámetro indica el número de la salida analógica que se utiliza para la consigna. Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos." ;
    ns1:tieneComponente ns1:Sensor_ControlGap .

ns1:Sistema_ModulosRemotosCANfagor a ns1:Sistema ;
    rdfs:label "Módulos remotos CANfagor" ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los módulos remotos CANfagor." ;
    ns1:tieneComponente ns1:Parametro_ANAOUTID .

ns1:Sistema_MonitorizacionColisiones a ns1:Sistema ;
