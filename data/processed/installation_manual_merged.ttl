ns1:Cabezal_S_1048 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S (SPDLNAME 1)"@es ;
    ns1:identificador "SPDLNAME 1" ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ7ꞏ. | Cabezal con índice ꞏ1ꞏ."@es ;
    ns1:valor "S" .

ns1:Cabezal_SercosPosicion a ns1:Componente ;
    rdfs:label "Cabezal Sercos (modo posición)" ;
    ns1:controla ns1:Parametro_SANALOG ;
    ns1:textoExtracto "Cabezal Sercos en posición. La consigna en SANALOG vendrá expresada en diezmilésima de grado" .

ns1:Cabezal_SercosVelocidad a ns1:Componente ;
    rdfs:label "Cabezal Sercos (modo velocidad)" ;
    ns1:controla ns1:Parametro_SANALOG ;
    ns1:textoExtracto "Cabezal Sercos en velocidad. La consigna en SANALOG vendrá expresada en diezmilésima de rpm" .

ns1:CabezalesSistema a ns1:Sistema ;
    rdfs:label "Sistema de cabezales controlados" ;
    ns1:controla ns1:ParametroSANALOG_Frecuencia,
        ns1:ParametroSANALOG_Posicion,
        ns1:ParametroSANALOG_Velocidad ;
    ns1:textoExtracto "Cabezal Sercos en velocidad... Cabezal Mechatrolink... sincronización de cabezales..." ;
    ns1:tieneComponente ns1:CabezalMechatrolink,
        ns1:CabezalSercosPosicion,
        ns1:CabezalSercosVelocidad .

ns1:CalibracionSensorGap a ns1:TareaMantenimiento ;
    rdfs:label "Calibración del sensor de gap" ;
    ns1:textoExtracto "Para conseguir un seguimiento correcto del sensor, se recomienda que la señal del sensor esté calibrada con el máximo número de puntos posible." .

ns1:Canal1_2Ejes_1Cabezal_Plano a ns1:ComponenteMecanico ;
    rdfs:label "Canal 1: 2 ejes y 1 cabezal (configuración tipo plano)"@es ;
    ns1:identificador "Canal 1" ;
    ns1:textoExtracto "Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es .

ns1:Canal2_2Ejes_1Cabezal_Plano a ns1:ComponenteMecanico ;
    rdfs:label "Canal 2: 2 ejes y 1 cabezal (configuración tipo plano)"@es ;
    ns1:identificador "Canal 2" ;
    ns1:textoExtracto "Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es .

ns1:Canal3_2Ejes_0Cabezales a ns1:ComponenteMecanico ;
    rdfs:label "Canal 3: 2 ejes y ningún cabezal"@es ;
    ns1:identificador "Canal 3" ;
    ns1:textoExtracto "Canal 3: 2 ejes y ningún cabezal."@es .

ns1:CanalCNC_Generico a ns1:Componente ;
    rdfs:label "Canal CNC" ;
    ns1:controla ns1:CabezalCNC_Generico,
        ns1:EjeCNC_Generico ;
    ns1:textoExtracto "Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales. También es posible configurar un canal sin asignarle ejes ni cabezales inicialmente." .

ns1:CanalINT1 a ns1:ComponenteElectrico ;
    rdfs:label "Canal INT1" ;
    ns1:controla ns1:SubrutinaINT1SUB ;
    ns1:identificador "INT1" ;
    ns1:textoExtracto "INT1C1 (también se puede programar como INT1) INT1C2 INT1C3 INT1C4" .

ns1:CanalINT4 a ns1:ComponenteElectrico ;
    rdfs:label "Canal INT4" ;
    ns1:controla ns1:SubrutinaINT4SUB ;
    ns1:identificador "INT4" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de INT1; para el resto de marcas es equivalente" .

ns1:Canal_4 a ns1:Componente ;
    rdfs:label "Canal 4" ;
    ns1:identificador "4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" .

ns1:Canal_CNC_Principal a ns1:Componente ;
    rdfs:label "Canal CNC principal"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "el primer canal o canal principal"@es .

ns1:Capitulo_5 a ns1:Capitulo ;
    rdfs:label "Funciones auxiliares –M–" ;
    ns1:detalladoEnEsquema ns1:Esquema_Transferencia_M ;
    ns1:identificador "5" ;
    ns1:textoExtracto "5.1 Funciones auxiliares –M–." .

ns1:Capitulo_ParametrosMaquina a ns1:Capitulo ;
    rdfs:label "Capítulo de Parámetros Máquina"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "2.2" ;
    ns1:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC."@es .

ns1:CarpetaCNC8070 a ns1:InterfazUsuario ;
    rdfs:label "Carpeta CNC8070" ;
    ns1:identificador "C:\\CNC8070" ;
    ns1:textoExtracto "los archivos necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\\CNC8070 y sus correspondientes subcarpetas." .

ns1:CarpetaConfiguracion a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\CONFIGURATION (almacén de configuraciones)" ;
    ns1:identificador "..\\CONFIGURATION" ;
    ns1:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 [...] Si cambiamos el código de validación, el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION" .

ns1:Carpeta_DRIVE a ns1:Sistema ;
    rdfs:label "Carpeta DRIVE" ;
    ns1:identificador "DRIVE" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al modo DDSSETUP." .

ns1:Carpeta_HELP a ns1:InterfazUsuario ;
    rdfs:label "Carpeta HELP"@es ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\HELP están los archivos de ayuda asociados a las subrutinas globales definidas por el usuario y el archivo pcall.txt que contiene la lista de subrutinas del usuario."@es .

ns1:Carpeta_MTB a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB (Personalización del CNC)" ;
    ns1:documentadoEn ns1:CNC8070_Software ;
    ns1:textoExtracto "Tanto en un CNC como en un PC (simulador), el fabricante dispone de la carpeta ..\\MTB para que pueda guardar las modificaciones que realiza en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, etc." .

ns1:Carpeta_MtbSub a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Mtb\\Sub" ;
    ns1:textoExtracto "el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen." .

ns1:Carpeta_POCKET a ns1:InterfazUsuario ;
    rdfs:label "Carpeta POCKET"@es ;
    ns1:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles, asociados a los ciclos del editor."@es .

ns1:Carpeta_PRG a ns1:InterfazUsuario ;
    rdfs:label "Carpeta PRG"@es ;
    ns1:textoExtracto "Esta carpeta contiene los programas pieza creados por el usuario, que podrá crear nuevas subcarpetas y guardar así los programas de una forma más ordenada. La subcarpeta ..\\PRG_8055_TO_8070 contiene los programas traducidos al lenguaje 8070, que proceden de archivos en formato 8055."@es ;
    ns1:tieneComponente ns1:Subcarpeta_PRG_8055_TO_8070 .

ns1:Carpeta_PROFILE a ns1:InterfazUsuario ;
    rdfs:label "Carpeta PROFILE"@es ;
    ns1:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles."@es .

ns1:Carpeta_REPORTS a ns1:InterfazUsuario ;
    rdfs:label "Carpeta REPORTS"@es ;
    ns1:identificador "bmp",
        "prn" ;
    ns1:textoExtracto "Esta carpeta contiene los archivos (formato bmp) que genera el CNC cuando imprime un gráfico a un archivo y los informes (formato prn) generados desde el modo diagnosis."@es .

