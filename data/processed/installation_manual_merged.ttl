ns1:Senal_GAPCOLLISIONMODE a ns1:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:monitoreaParametro ns1:Sensor_d264e19494 ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION. Si el PLC activa la marca GAPCOLLISION, el CNC mostrará o no un error según lo definido en este parámetro." .

ns1:Senal_GEAR1_4 a ns1:Parametro ;
    rdfs:label "Señales GEAR1 a GEAR4"@es ;
    ns1:controla ns1:Cabezal_Generico ;
    ns1:monitoreaParametro ns1:ConsignaResidual_SANALOG ;
    ns1:textoExtracto "En el ejemplo de las señales GEAR1 a GEAR4 se detalla cómo detectar y efectuar el cambio de gama. Aquí se muestra la forma de controlar la oscilación del cabezal durante el cambio de gama."@es .

ns1:Senal_INPOSGAP a ns1:Parametro ;
    rdfs:label "INPOSGAP" ;
    ns1:documentadoEn ns1:TablaDeSenalesLogicasDelPLC1626 ;
    ns1:identificador "INPOSGAP" ;
    ns1:monitoreaParametro ns1:GAPMINGAPMAX ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX. Si el gap sobrepasa el rango definido en los parámetros GAPMIN-GAPMAX, el CNC desactiva la marca INPOSGAP y detiene el movimiento de los ejes." .

ns1:Senal_INTOL a ns1:Parametro ;
    rdfs:label "INTOL" ;
    ns1:documentadoEn ns1:TablaDeSenalesLogicasDelPLC1626 ;
    ns1:identificador "INTOL" ;
    ns1:monitoreaParametro ns1:Parametro_9306311404 ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado. Si el eje sobrepasa la tolerancia definida en el parámetro GAPTOL, el CNC desactiva la marca INTOL." .

ns1:Senal_LASERON a ns1:InterfazUsuario ;
    rdfs:label "LASERON" ;
    ns1:identificador "LASERON" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el láser está encendido." .

ns1:Senal_LASERREADY a ns1:InterfazUsuario ;
    rdfs:label "LASERREADY" ;
