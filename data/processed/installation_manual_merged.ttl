    rdfs:label "Tecla USER12"@es ;
    ns1:controla ns1:AlarmaEmergencia ;
    ns1:identificador "USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia."@es .

ns1:TeclaUSER13 a ns1:InterfazUsuario ;
    rdfs:label "Tecla USER13"@es ;
    ns1:controla ns1:AlarmaEmergencia ;
    ns1:identificador "USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia."@es .

