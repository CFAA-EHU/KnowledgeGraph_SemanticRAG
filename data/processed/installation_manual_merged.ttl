    ns1:monitoreaParametro ns1:Sensor_Palpador2,
        ns1:Sistema_CNC ;
    ns1:textoExtracto "Retardo de la señal de palpador 2. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo). Variable asociada: (V.)[ch].MPA.PROBEDELAY2.xn",
        "PROBEDELAY2 | Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es ;
    ns1:valor "0" .

