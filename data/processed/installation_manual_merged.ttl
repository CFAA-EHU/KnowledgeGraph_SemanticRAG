    rdfs:label "PT100 n" ;
    ns1:identificador "PT100_n" ;
    ns1:textoExtracto "PT100 n | Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32 (por defecto; 0)." ;
    ns1:valor "0..32" .

ns1:Parametro_SANALOG a ns1:Parametro ;
    rdfs:label "SANALOG" ;
    ns1:textoExtracto "El registro SANALOG fija la consigna de cabezal que se desea aplicar" .

ns1:Parametro_T a ns1:Parametro ;
    rdfs:label "Estado T (salida del temporizador)",
        "Estado del temporizador (T)"@es,
        "Parámetro T (estado del temporizador)"@es,
        "T (estado lógico del temporizador)"@es ;
    ns1:identificador "T" ;
    ns1:ilustradoEn ns1:Esquema_Temporizador_TEN,
        ns1:Esquema_Temporizador_TRS ;
    ns1:monitoreaParametro ns1:ModoOperacion_TemporizadorMonoestable_TG1 ;
    ns1:textoExtracto "T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene.",
        "La salida de estado del temporizador (T) cambia de estado (T=1) [...] La salida de estado (T) cambia (T=0)"@es,
        "estado lógico T (alto mientras la temporización está activa)"@es,
        "la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t a partir del valor 0. [...] desactivándose la salida de estado del temporizador (T=0)."@es,
        "salida de estado del temporizador toma el valor T=1 [...] desactivándose la salida de estado del temporizador (T=0)"@es ;
    ns1:valor "0",
        "0/1",
        "1",
        "0"@es,
        "1"@es .

ns1:Parametro_TDATA a ns1:Parametro ;
