ns1:FiltroPrecarga_1178 a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de precarga (eje tándem)"@es ;
    ns1:textoExtracto "Filtro de precarga. Filtro de primer orden cuyo fin es evitar la entrada de escalones de par al configurar la precarga."@es .

ns1:Filtro_Cutoff a ns1:ComponenteElectrico ;
