        "MAXCOUPE Eje gantry. Máxima diferencia permitida entre el error de seguimiento de ambos ejes. Valores posibles (1): De 0.0001 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0.0001 a 99999.9999 grados. Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado." ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grado" .

ns1:Parametro_MAXDIFF a ns1:Parametro ;
    rdfs:label "MAXDIFF",
        "Parámetro MAXDIFF(axis)" ;
    ns1:identificador "MAXDIFF(axis)",
        "MPG.MAXDIFF[nb]" ;
