ns1:PLC_11_4 a ns1:InterfazUsuario ;
    rdfs:label "PLC (control lógico programable para gestión de ejes)" ;
    ns1:controla ns1:ReguladorMultieje_11_4 ;
    ns1:habilitadoPor ns1:Marca_ENABLE_11_4,
        ns1:Marca_SWITCH_11_4 ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador." .

ns1:PLC_1251 a ns1:Sistema ;
    rdfs:label "PLC de control" ;
    ns1:controla ns1:ConmutadorFeedOverride_1251,
        ns1:VolanteAvance_1251 ;
    ns1:monitoreaParametro ns1:VariableImpulsosVolante_1251 ;
    ns1:textoExtracto "La gestión del volante de avance se debe realizar desde el PLC. [...] La maniobra del PLC debe contemplar los siguientes elementos: [...] Fijar desde el PLC el feed override en función de los impulsos de volante." .

ns1:PLC_1268 a ns1:Sistema ;
    rdfs:label "PLC con gestión de bus CANopen"@es ;
    ns1:identificador "1...1024" ;
    ns1:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus."@es .

ns1:PLC_140 a ns1:Sistema ;
    rdfs:label "PLC (Controlador Lógico Programable)"@es ;
    ns1:textoExtracto "el PLC considera entradas lógicas a aquellas entradas que no existen como físicas"@es ;
