ns1:Parametro_DRV_Mechatrolink a ns1:Parametro ;
    rdfs:label "Variables DRV (Mechatrolink)" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables y/o parámetros de los servos. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura."@es ;
    ns1:valor "solo lectura (variables); lectura/escritura (parámetros)"@es .

ns1:Parametro_DRV_Sercos a ns1:Parametro ;
    rdfs:label "Variables DRV (Sercos)" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables del regulador. El acceso a las variables podrá ser solo lectura o de lectura y escritura."@es ;
    ns1:valor "lectura/escritura"@es .

ns1:Parametro_DSYNCPOSW a ns1:Parametro ;
    rdfs:label "DSYNCPOSW",
        "Ventana de sincronización en posición (DSYNCPOSW)",
        "DSYNCPOSW (Margen de posición en sincronización)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:monitoreaParametro ns1:Sistema_CNC,
        ns1:Variable_MPA_DSYNCPOSW ;
    ns1:textoExtracto "DSYNCPOSW Ventana de sincronización en posición. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta.",
        "valor por defecto se define en el parámetro máquina DSYNCPOSW",
        "DSYNCPOSW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta."@es ;
    ns1:valor "0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min",
        "máximo error en posición permitido" .

ns1:Parametro_DSYNCVELW a ns1:Parametro ;
    rdfs:label "DSYNCVELW",
        "DSYNCVELW (Margen de velocidad en sincronización)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "V.[ch].MPA.DSYNCVELW.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "DSYNCVELW Ventana de sincronización en velocidad. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta.",
        "DSYNCVELW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta."@es ;
    ns1:valor "100 mm/min / 3.937 inch/min / 3600 grados/min / 10 rpm" .

ns1:Parametro_DeltaX_Prima a ns1:Parametro ;
    rdfs:label "ΔX′" ;
    ns1:identificador "DeltaX_Prima" ;
    ns1:textoExtracto "Lectura de desplazamiento en la primera palpación de la cara X (B=−90°)"@es .

