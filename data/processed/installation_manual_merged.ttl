    ns1:textoExtracto "Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." .

ns1:Param_SPDLTIME a ns1:Parametro ;
    rdfs:label "SPDLTIME" ;
    ns1:identificador "(V.)[ch].MPA.SPDLTIME.xn" ;
    ns1:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa.",
        "SPDLTIME Tiempo estimado para una función S. [...] Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ns1:valor "0-1000000 ms" .

