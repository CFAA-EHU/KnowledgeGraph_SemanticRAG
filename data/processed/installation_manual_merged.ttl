    ns1:identificador "V.G.PRBST2" ;
    ns1:textoExtracto "$IF [V.G.PRBST2==1] #WARNING[\"PROBE2 SIGNAL TOUCHING\"]"@en .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ" ;
    ns1:documentadoEn ns1:Tabla_13_3_4_VariablesLimitacionAvance ;
    ns1:identificador "PREPFREQ" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:solucionaFallo ns1:Parametro_DROPRATE,
        ns1:Parametro_PERFRATE ;
    ns1:textoExtracto "se puede aumentar el parámetro PREPFREQ para que aumente el suministro de bloques",
        "PREPFREQ Número máximo de bloques a preparar por ciclo. Valores posibles: De 1 a 8. Valor por defecto: 1."@es,
        "Parámetro que puede aumentarse para mejorar el suministro de bloques, siempre que el sistema vaya holgado de tiempo (aproximadamente el 50% del tiempo de ciclo)."@es ;
    ns1:valor 1,
        "Frecuencia de preparación de bloques" .

ns1:Parametro_PREPTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.PREPTIMERATE",
        "PREPTIMERATE (Porcentaje de tiempo de ciclo en preparación de bloques)"@es ;
    ns1:documentadoEn ns1:Tabla_1157_TiempoCicloCanal ;
    ns1:identificador "V.G.PREPTIMERATE",
        "V.[ch].G.PREPTIMERATE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "| V.G.PREPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques.",
        "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques. Esta variable sirve para evaluar la carga en la preparación de la trayectoria y saber si es posible aumentar el parámetro PREPFREQ. Unidades: %."@es ;
    ns1:valor "Porcentaje del tiempo de ciclo para preparación de bloques",
        "%"@es .

ns1:Parametro_PROBE a ns1:Parametro ;
    rdfs:label "PROBE" ;
    ns1:identificador "MPG.PROBE" ;
    ns1:textoExtracto "PROBE [...] Este parámetro indica si se dispone de algún palpador en la máquina. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_PROBE1ACTIVE a ns1:Parametro ;
    rdfs:label "PROBE1ACTIVE" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." ;
    ns1:valor "activo/inactivo" .

ns1:Parametro_PROBE1ENA a ns1:Parametro ;
    rdfs:label "PROBE1ENA" ;
    ns1:identificador "PROBE1ENA" ;
    ns1:textoExtracto "PROBE1ENA; PROBE1 is enabled confirmation signal to CNC. If not used in PLC, it is actived by default."@en ;
    ns1:valor "1" .

ns1:Parametro_PROBE1MONIT a ns1:Parametro ;
    rdfs:label "PROBE1MONIT" ;
    ns1:identificador "PROBE1MONIT" ;
    ns1:textoExtracto "PROBE1MONIT; It activates PROBE1 in SAFE mode. If probe is actived in no G100/3 motion, CNC will stop motion and shows an error. If not used in PLC, it is actived by default."@en ;
    ns1:valor "0" .

ns1:Parametro_PROBE2ACTIVE a ns1:Parametro ;
    rdfs:label "PROBE2ACTIVE" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." ;
    ns1:valor "activo/inactivo" .

ns1:Parametro_PROBE2ENA a ns1:Parametro ;
    rdfs:label "PROBE2ENA" ;
    ns1:identificador "V.PLC.PROBE2ENA" ;
    ns1:textoExtracto "PROBE2ENA; PROBE 2 is enabled confirmation signal to CNC. If not used in PLC, it is actived by default."@en ;
    ns1:valor "1" .

ns1:Parametro_PROBE2MONIT a ns1:Parametro ;
    rdfs:label "PROBE2MONIT" ;
    ns1:identificador "V.PLC.PROBE2MONIT" ;
    ns1:textoExtracto "PROBE2MONIT; It activates PROBE2 in SAFE mode. If probe is actived in no G100/3 motion, CNC will stop motion and shows an error. If not used in PLC, it is actived by default."@en ;
    ns1:valor "0" .

ns1:Parametro_PROBEAXIS a ns1:Parametro ;
    rdfs:label "PROBEAXIS" ;
    ns1:identificador "(V.)[ch].MPA.PROBEAXIS.xn" ;
    ns1:textoExtracto "PROBEAXIS [...] Este parámetro indica si el eje es participante en movimiento con palpador (G100)." ;
    ns1:valor "Sí / No" .

ns1:Parametro_PROBEDATA a ns1:Parametro ;
    rdfs:label "PROBEDATA" ;
    ns1:monitoreaParametro ns1:Tabla_PosicionPalpador ;
    ns1:textoExtracto "PROBEDATA Parámetros del palpador relativos al canal. Este parámetro muestra la tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal, según el parámetro CHAXISNAME.",
        "PROBEDATA [...] Este parámetro muestra la tabla de parámetros necesarios para configurar el palpador." .

ns1:Parametro_PROBEFEED a ns1:Parametro ;
    rdfs:label "PROBEFEED",
        "PROBEFEED (Avance máximo de palpado)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "(V.)[ch].MPA.PROBEFEED.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "PROBEFEED [...] El valor de este parámetro debe ser inferior que el avance necesario para frenar en el espacio definido en PROBERANGE con los valores de aceleración y de jerk del eje.",
        "Si PROBEFEED se define con valor 0, el CNC calcula y utiliza el valor máximo que puede tener este parámetro.",
        "PROBEFEED | Avance máximo de palpado."@es ;
    ns1:valor "0" .

ns1:Parametro_PROBERANGE a ns1:Parametro ;
    rdfs:label "PROBERANGE",
        "PROBERANGE (Distancia máxima de frenado del palpador)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "(V.)[ch].MPA.PROBERANGE.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "PROBERANGE [...] Este parámetro fija la máxima distancia de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc).",
        "PROBERANGE | Distancia máxima de frenado del palpador. Este parámetro fija la distancia máxima de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)."@es ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grado" .

ns1:Parametro_PROBETYPE1 a ns1:Parametro ;
    rdfs:label "PROBETYPE1" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "MPG.PROBETYPE1",
        "PROBETYPE1" ;
    ns1:textoExtracto "PROBETYPE1 Tipo de palpador 1. Valores posibles: Remoto / Local / Gap (sólo modelo láser). Valor por defecto: Remoto. Variable asociada: (V.)MPG.PROBETYPE1",
        "Tipo de palpador 1."@es ;
    ns1:valor "Remoto" .

ns1:Parametro_PROBETYPE2 a ns1:Parametro ;
    rdfs:label "PROBETYPE2" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "MPG.PROBETYPE2",
        "PROBETYPE2" ;
    ns1:textoExtracto "PROBETYPE2 Tipo de palpador 2. Valores posibles: Remoto / Local / Gap (sólo modelo láser). Valor por defecto: Remoto. Variable asociada: (V.)MPG.PROBETYPE2",
        "Tipo de palpador 2."@es ;
    ns1:valor "Remoto" .

ns1:Parametro_PT100OFF1 a ns1:Parametro ;
    rdfs:label "PT100OFF1" ;
    ns1:identificador "PT100OFF1" ;
    ns1:monitoreaParametro ns1:Sensor_PT100_1 ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)." .

ns1:Parametro_PT100OFF20 a ns1:Parametro ;
    rdfs:label "PT100OFF20" ;
    ns1:identificador "PT100OFF20" ;
    ns1:monitoreaParametro ns1:Sensor_PT100_20 ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)." .

ns1:Parametro_PT100_EntradasActivas a ns1:Parametro ;
    rdfs:label "Tabla de entradas PT100 activas" ;
    ns1:identificador "MPG.PT100[nb]" ;
    ns1:textoExtracto "PT100 Tabla de entradas PT100 activas. Este parámetro muestra la lista de entradas PT100 activas en el bus CAN. PT100 n Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32. Valor por defecto: 0 (no se desea activar la entrada PT100)." ;
    ns1:valor "0" .

ns1:Parametro_PWRCTRLACT a ns1:Parametro ;
    rdfs:label "PWRCTRLACT" ;
    ns1:identificador "(V.)MPG.PWRCTRLACT" ;
    ns1:textoExtracto "PWRCTRLACT Gestionar la potencia en función del avance real. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PWRCTRLACT El CNC permite controlar la potencia, del láser o del duty del PWM, en función del avance. Este parámetro define qué avance debe usar el CNC para gestionar la potencia." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_PWRCTRLCANCEL a ns1:Parametro ;
    rdfs:label "PWRCTRLCANCEL" ;
    ns1:identificador "(V.)MPG.PWRCTRLCANCEL" ;
    ns1:textoExtracto "PWRCTRLCANCEL Cancelar el control de potencia con reset/M2/M30. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PWRCTRLCANCEL Este parámetro indica si el CNC cancela el control de potencia tras ejecutar M02, M30 o después de un reset." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_PWRSP a ns1:Parametro ;
    rdfs:label "PWRSP (Potencia objetivo)",
        "Potencia objetivo (PWRSP)" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "PWRSP{power} Potencia objetivo o potencia de corte idónea, definida como porcentaje de la potencia nominal del cabezal.",
        "comando PWRSP [...] el DMC la determina mediante una fase de aprendizaje si no se programa." ;
    ns1:valor "0 — 100 %" .

ns1:Parametro_ParTandem_Maestro a ns1:Parametro ;
    rdfs:label "Parámetro de porcentaje de par para motor maestro en sistema tándem" ;
    ns1:textoExtracto "Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem. El parámetro indica qué porcentaje debe dar el motor maestro." ;
    ns1:valor "50%"^^xsd:string .

ns1:Parametro_Par_Distribuido a ns1:Parametro ;
    rdfs:label "Par distribuido (torque) en eje maestro/esclavo"@es ;
    ns1:textoExtracto "el reparto de par se invierte respecto a la aceleración [...] distribución de par."@es .

ns1:Parametro_ParametrosGamasEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros de las gamas del eje maestro" ;
    ns1:textoExtracto "El CNC envía los parámetros de las gamas del eje maestro a los parámetros de las primeras gamas del regulador." .

ns1:Parametro_ParametrosGeneralesEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros generales del eje maestro" ;
    ns1:textoExtracto "El CNC envía los parámetros generales del eje maestro a los parámetros generales del regulador." .

ns1:Parametro_ParametrosPrimerSetEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros del primer set del eje maestro" ;
    ns1:textoExtracto "El CNC envía los parámetros del set por defecto del eje maestro (set definido en el parámetro DEFAULTSET) a los parámetros generales o del primer set del regulador, según corresponda." .

