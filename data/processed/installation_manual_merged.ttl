ns1:Tabla_RedefinicionCinematica_16_a_52 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 16 → tipo 52"@es ;
    ns1:documentadoEn ns1:Manual_Seccion_2.9.12 ;
    ns1:textoExtracto "Adaptar una cinemática tipo 16 a una cinemática tipo 52."@es .

ns1:Tabla_RedefinicionCinematica_52_13 a ns1:Tabla ;
    rdfs:label "Tabla de adaptación de cinemática tipo 13 a tipo 52"@es ;
    ns1:textoExtracto "Adaptar una cinemática tipo 13 a una cinemática tipo 52."@es .

ns1:Tabla_SERCOUNTID a ns1:Tabla ;
    rdfs:label "Tabla SERCOUNTID"@es ;
    ns1:documentadoEn ns1:Pagina_675 ;
    ns1:textoExtracto "La tabla SERCOUNTID de los parámetros máquina generales, nos permite enlazar la numeración lógica de las contadoras Sercos (1..8) con la numeración física determinada por la ruleta de cada nodo"@es .

ns1:Tabla_ScanCodes_InglesUS a ns1:Tabla ;
    rdfs:label "Tabla de scan codes para distribución de teclado Inglés (Estados Unidos)"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_Teclado ;
    ns1:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT]."@es .

ns1:Tabla_SenalesPLC_699 a ns1:Tabla ;
    rdfs:label "Tabla de señales del PLC (página 699)" ;
    ns1:documentadoEn ns1:Pagina_699 ;
    ns1:textoExtracto "| Señales del PLC. | Significado. | --- | --- | GAPCOLLISIONMODE | El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC..." .

ns1:Tabla_Significado_ALIGNC a ns1:Tabla ;
    rdfs:label "Significado de ALIGNC" ;
    ns1:ilustradoEn ns1:Parametro_ALIGNC ;
    ns1:textoExtracto "| ALIGNC | Significado. | --- | --- | Sí. | (1)Mecanizado hasta el centro. (2)Girar 180° el eje C. (3)Continuar el mecanizado retrocediendo la herramienta. | No. | " .

ns1:Tabla_SubrutinasCicloCalibracion a ns1:Tabla ;
    rdfs:label "Subrutinas asociadas al ciclo de calibración de herramienta" ;
    ns1:documentadoEn ns1:Subrutina_Sub_Probe_Tool_Begin_fst,
        ns1:Subrutina_Sub_Probe_Tool_End_fst ;
    ns1:textoExtracto "| Nombre. | Significado. | --- | --- | Sub_Probe_Tool_Begin.fst | Subrutina asociada al inicio del ciclo de calibración de herramienta. | Sub_Probe_Tool_End.fst | Subrutina asociada al final del ciclo de calibración de herramienta. |" .

ns1:Tabla_SubrutinasOEM a ns1:Tabla ;
    rdfs:label "Tabla de subrutinas OEM suministradas por Fagor" ;
    ns1:documentadoEn ns1:Subrutina_G500,
        ns1:Subrutina_G501 ;
    ns1:textoExtracto "Subrutinas suministradas por Fagor. | Subrutina. | Significado. | --- | --- | G500 | Anulación de HSC. | G501 | Activación de HSC para operaciones de desbaste."@es .

ns1:Tabla_TDATA12_Significado a ns1:Tabla ;
    rdfs:label "Significado de valores TDATA12" ;
    ns1:documentadoEn ns1:Parametro_TDATA12 ;
    ns1:textoExtracto "0: Los dos ejes son servocontrolados. 1: Eje principal manual y eje secundario servocontrolado. 2: Eje principal servocontrolado y eje secundario manual. 3: Los dos ejes son manuales." .

ns1:Tabla_TiemposEjecucion a ns1:Tabla ;
    rdfs:label "Tiempos de ejecución de funciones (H, D, T, S, M)" ;
    ns1:documentadoEn ns1:Pagina_83 ;
    ns1:textoExtracto "el tiempo estimado para el proceso de determinadas funciones. Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez." .

ns1:Tabla_TiposCaptacion a ns1:Tabla ;
    rdfs:label "Tipos de captación y entradas asociadas"@es ;
    ns1:documentadoEn ns1:Pagina_586_588 ;
    ns1:textoExtracto "| Tipo de captación. | Número de la entrada de captación del eje. | [...] Entrada de captación en los módulos remotos CANfagor. | [...] Entrada de captación en los reguladores Sercos. | [...] Entrada de captación local. |"@es .

ns1:Tabla_TiposCinematicas a ns1:Tabla ;
    rdfs:label "Tipos de cinemáticas" ;
    ns1:textoExtracto "De los 106 tipos posibles de cinemáticas, los 100 primeros son para las cinemáticas predefinidas de Fagor y los 6 tipos restantes son para las cinemáticas que el fabricante integre en el CNC." .

ns1:Tabla_ValoresPWMOUTPUT a ns1:Tabla ;
    rdfs:label "Tabla de valores PWMOUTPUT" ;
    ns1:textoExtracto "| PWMOUTPUT | Significado. | --- | --- | 0 | No hay PWM. | 1 | Salida local 1 (pin LI/O1). | 2 | Salida local 2 (pin LI/O2)." .

ns1:Tabla_ValoresPWRCTRLACT a ns1:Tabla ;
    ns1:documentadoEn ns1:Parametro_PWRCTRLACT ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Sí. | El CNC gestiona la potencia en función del avance real (variable (V.)A.FEED.xn). | No | El CNC gestiona la potencia en función del avance teórico (variable (V.)A.TFEED.xn)." .

ns1:Tabla_ValoresPWRCTRLCANCEL a ns1:Tabla ;
    ns1:documentadoEn ns1:Parametro_PWRCTRLCANCEL ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Sí. | El CNC cancela el control de potencia. Un error en el canal cancela el control de potencia. Si un error desactiva el control de potencia, éste no se reactiva cuando el error desaparece. Es necesario volver a programarlo por programa o por PLC. | No | El CNC no cancela el control de potencia. Un error en el canal no cancela el control de potencia; éste mantiene su estado previo. En el inicio de la ejecución, tras un reset y al entrar en inspección de herramienta, el CNC sincroniza la preparación de bloques con la ejecución." .

ns1:Tabla_Valores_AXDELAY a ns1:Tabla ;
    rdfs:label "Tabla de valores del parámetro AXDELAY" ;
    ns1:documentadoEn ns1:AXDELAY ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Estándar. | Para regulación Fagor, donde no es necesaria ninguna compensación de retardo. El CNC compensa automáticamente las diferencias de retardo entre los reguladores de los ejes del canal. | 0. | El CNC no aplica compensación de retardo en el regulador. | 1 a 127. | Ciclos de retardo en el regulador. El CNC compensa automáticamente las diferencias de retardo entre los reguladores de los ejes del canal." .

ns1:Tabla_VariablesLimitacionAvance_13_3_4 a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a la limitación en el avance (Pág. 625-626)" ;
    ns1:detalladoEnEsquema ns1:Variable_PARLIMC_13_3_4 ;
    ns1:documentadoEn ns1:Pagina_625_626 ;
    ns1:textoExtracto """\r
    | Variables. | PRG | PLC | INT |\r
    | --- | --- | --- | --- |\r
    | (V.)[ch].G.PARLIMC\r
    Causa que limita el avance en la esquina, en el bloque en ejecución. La variable devuelve uno de los siguientes valores. [1] El avance máximo del eje. [4] La aceleración en la esquina (parámetro CORNERACC). [5] El jerk en la esquina (parámetro CORNERJERK). [8] El error cordal en la esquina (modo CONTERROR). [9] Geometría de la esquina (modo FAST). Unidades: -.\r
    """ .

ns1:Tabla_XFITOIND_Significado a ns1:Tabla ;
    rdfs:label "Significado de XFITOIND" ;
    ns1:textoExtracto "| XFITOIND | Significado. | --- | --- | Sí | La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC. | No | La marca _XFERINH no afecta a los movimientos de eje independiente programados desde el PLC; sí afecta a los programados desde el CNC." .

ns1:TareaBusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia del eje maestro" ;
    ns1:ejecutadoPor ns1:SistemaTandemEjes ;
    ns1:textoExtracto "El CNC podrá ejecutar una búsqueda de referencia del eje maestro, y al finalizar la búsqueda, el CNC también inicializará la cota del esclavo (con la cota del maestro)." .

ns1:TareaCambioOverrideRoscado a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado"@es ;
    ns1:monitoreaParametro ns1:OverrideCabezalRoscado ;
    ns1:textoExtracto "Cambio del override del cabezal durante el roscado. [...] No se recomienda modificar el override en roscas donde la penetración se realice por flanco."@es .

ns1:TareaMantenimiento_AccesoNesting a ns1:TareaMantenimiento ;
    rdfs:label "Acceso a la aplicación de nesting"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_CNC_Nesting ;
    ns1:textoExtracto "Para pasar del CNC a la aplicación de nesting: • Si sólo está abierta la aplicación de nesting y el CNC, las teclas [CTRL]+[W] cambian alternativamente de una o otra. • La tecla [CUSTOM] accede al software de nesting (si lo OEM lo ha configurado así)."@es .

ns1:TareaMantenimiento_AgregarCabeceras a ns1:TareaMantenimiento ;
    rdfs:label "Añadir cabeceras al bus"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_ConfiguradorTopologiaBus ;
    ns1:textoExtracto "Para añadir cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"."@es .

ns1:TareaMantenimiento_AjusteHSC a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del modo HSC" ;
    ns1:requiereMantenimiento ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

ns1:TareaMantenimiento_BusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia del eje"@es ;
    ns1:ejecutadoPor ns1:Sistema_CNC ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico"@es .

ns1:TareaMantenimiento_CalculoTDATA6 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA6" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA6,
        ns1:Parametro_Xa,
        ns1:Parametro_Xb ;
    ns1:requiereMantenimiento ns1:Sistema_CabezalAngular ;
    ns1:textoExtracto "Cálculo del parámetro TDATA6. Primer y segundo contacto." .

ns1:TareaMantenimiento_CalibracionEjeA a ns1:TareaMantenimiento ;
    rdfs:label "Procedimiento de calibración del eje A (método de palpación)"@es ;
    ns1:documentadoEn ns1:Figura_EsquemaPosiciones ;
    ns1:requiereMantenimiento ns1:Sistema_MesaRotativa ;
    ns1:textoExtracto "1 Posicionar los ejes rotativos A y B en -90º. 2 Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 1. Anotar Y1. [...] Segunda posición. 1 Posicionar el eje rotativo A en 90º y el eje B en -90º. 2 Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 3. Anotar Y2."@es .

ns1:TareaMantenimiento_CalibracionPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de calibración de palpador #PROBE 2" ;
    ns1:monitoreaParametro ns1:Parametro_P299 ;
    ns1:requiereMantenimiento ns1:Sensor_Palpador1,
        ns1:Sensor_Palpador2 ;
    ns1:textoExtracto "Para la personalización de este parámetro se puede utilizar el ciclo de calibración de palpador #PROBE 2." .

ns1:TareaMantenimiento_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta en cabezal"@es ;
    ns1:requiereMantenimiento ns1:Sistema_GestorHerramientas ;
    ns1:textoExtracto "maniobra necesaria para realizar el cambio. Tras descargar la herramienta el gestor actualiza la tabla de almacén. [...] Tras colocar la herramienta en el cabezal el gestor actualiza la tabla de almacén."@es .

ns1:TareaMantenimiento_DesactivarDMC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar DMC"@es ;
    ns1:documentadoEn ns1:Pagina_730_731 ;
    ns1:textoExtracto "Opciones del DMC (menú desplegable): Desactivar el DMC."@es .

ns1:TareaMantenimiento_EngrasadoEjes a ns1:TareaMantenimiento ;
    rdfs:label "Engrasado de ejes/cabezales" ;
    ns1:requiereMantenimiento ns1:Parametro_DISTLUBRI,
        ns1:Parametro_LUBR_axis ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente debe ser engrasado." .

ns1:TareaMantenimiento_ExportarConfiguracionMaster a ns1:TareaMantenimiento ;
    rdfs:label "Exportar configuración maestra EtherCAT" ;
    ns1:documentadoEn ns1:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus ;
    ns1:textoExtracto "(Arriba) Diálogo de exportación 'Export → Export Master Configuration ETG Standard' para generar el XML de configuración." .

ns1:TareaMantenimiento_GuardarProyectoECSN a ns1:TareaMantenimiento ;
    rdfs:label "Guardar proyecto *.ecsn" ;
    ns1:documentadoEn ns1:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus ;
    ns1:textoExtracto "(abajo) opción 'File → Save' para guardar proyecto *.ecsn. Se observan rutas de archivo, nombres propuestos y botones de confirmación." .

ns1:TareaMantenimiento_M101 a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar posición TAKEPOS y coger herramienta con pinza 1"@es ;
    ns1:ejecutadoPor ns1:Personal_OperarioPLC ;
    ns1:identificador "M101" ;
    ns1:monitoreaParametro ns1:Parametro_TAKEPOS ;
    ns1:requiereMantenimiento ns1:ComponenteMecanico_Pinza1,
        ns1:Herramienta_Generica,
        ns1:Pinza1 ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1."@es .

