ns1:Interfaz_JOG_PANEL a ns1:InterfazUsuario ;
    rdfs:label "Teclado JOG-PANEL"@es ;
    ns1:textoExtracto "Ejemplo 1: Teclado JOG-PANEL. [...] Personalización de las teclas de jog. En una máquina con los ejes X, Y, U, V definidos como AXISNAME 1, 2, 3, 4 se desea desplazar los ejes X, Y con las teclas del mismo nombre, el eje U con las del 4º y el V con las del 5º."@es .

ns1:Interfaz_LCD_10K a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K"@es ;
    ns1:textoExtracto "Ejemplo 4: Teclado LCD-10K. [...] Ejemplo 5: Teclado LCD-10K. [...] Ejemplo 6: Teclado LCD-10K."@es .

ns1:Interfaz_LantekExpertInside a ns1:InterfazUsuario ;
    rdfs:label "Lantek Expert Inside - Área de trabajo" ;
    ns1:textoExtracto "Captura de interfaz de Lantek Expert Inside mostrando el área principal de trabajo con lista de piezas y opciones de importación (DXF/DWG/paramétricas). Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa." .

ns1:Interfaz_Latcheo a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de variables de latcheo (PLC/programa)"@es ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. [...] Variable de lectura y escritura desde el programa, PLC e interfaz."@es ;
    ns1:tieneComponente ns1:Variable_ACCUDIST,
        ns1:Variable_LATCH1,
        ns1:Variable_LATCH2 .

ns1:Interfaz_MessagesAndErrors a ns1:InterfazUsuario ;
    rdfs:label "Interfaz MESSAGES AND ERRORS"@es ;
    ns1:ilustradoEn ns1:Figura_VisualizacionErroresPLC ;
    ns1:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc."@es .

ns1:Interfaz_OPENPCS_Remoto_InstaladorHelp a ns1:InterfazUsuario ;
    rdfs:label "Interfaz OPENPCS Remoto - Instalador de ayuda" ;
    ns1:identificador "SetupHelp_Vxx.xx.exe" ;
    ns1:textoExtracto "Se aprecian campos de búsqueda/filtrado y el listado donde figura 'CNC Help Language Changer'. La imagen contextualiza el procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados." .

ns1:Interfaz_STOP a ns1:InterfazUsuario ;
    rdfs:label "Tecla STOP"@es ;
    ns1:identificador "ESTOP" ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP."@es .

ns1:InterpoladorIndependiente_780 a ns1:ComponenteElectrico ;
    rdfs:label "Interpolador independiente"@es ;
    ns1:identificador "Interpolador independiente"@es ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso."@es .

ns1:KPA_EtherCAT_Studio a ns1:Sistema ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Ejecutar el programa \"Studio\" para iniciar el configurador \"KPA EtherCAT Studio\"." .

ns1:LCD_10K a ns1:InterfazUsuario ;
    rdfs:label "LCD-10K" ;
    ns1:ilustradoEn ns1:EsquemaTeclasJog ;
    ns1:textoExtracto "Conjunto de tres diagramas de paneles (dos 'OP-PANEL' y un 'LCD-10K')." ;
    ns1:tieneComponente ns1:BloqueUSERKEYS .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "Registro LEAVEPOS"@es ;
    ns1:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es .

ns1:LIMITminus a ns1:Parametro ;
    rdfs:label "LIMIT- (Límite de software negativo)" ;
    ns1:identificador "MPA.NEGLIMIT.xn" ;
    ns1:textoExtracto "LIMIT- Límite de software negativo. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: -99999.9999 mm / -3937.00787 inch / -99999.9999 grados." ;
    ns1:valor "-99999.9999 mm / -3937.00787 inch / -99999.9999 grados" .

ns1:LIMITplus a ns1:Parametro ;
    rdfs:label "LIMIT+ (Límite de software positivo)" ;
    ns1:identificador "MPA.POSLIMIT.xn" ;
    ns1:textoExtracto "LIMIT+ Límite de software positivo. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 99999.9999 mm / 3937.00787 inch / 99999.9999 grados." ;
    ns1:valor "99999.9999 mm / 3937.00787 inch / 99999.9999 grados" .

ns1:LSCRWCOMP_InterfazUsuario a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de compensación de husillo (LSCRWCOMP)"@es ;
    ns1:textoExtracto "LSCRWCOMP DATA | POSITION | Posición del eje. | POSERROR | Error a compensar en los desplazamientos en sentido positivo. | NEGERROR | Error a compensar en los desplazamientos en sentido negativo."@es ;
    ns1:tieneComponente ns1:LSCRWCOMP_NEGERROR_Parametro,
        ns1:LSCRWCOMP_POSERROR_Parametro,
        ns1:LSCRWCOMP_POSITION_Parametro .

ns1:L_mparaTeclaUSER12 a ns1:InterfazUsuario ;
    rdfs:label "Lámpara de la tecla USER12"@es ;
    ns1:identificador "B11KEYLED1" ;
    ns1:monitoreaParametro ns1:Se_alEmergenciaGestor ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia."@es .

ns1:LamparaTecla_USER12 a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:monitoreaParametro ns1:SenalEmergencia_TMINEM ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:LevaElectronica a ns1:Componente ;
    rdfs:label "Leva electrónica" ;
    ns1:textoExtracto "ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva" ;
    ns1:tieneComponente ns1:PerfilLeva .

ns1:LibreriaMatematica_614 a ns1:Componente ;
    rdfs:label "Librería matemática (trigonométrica, logarítmica)"@es ;
    ns1:textoExtracto "La programación en lenguaje C dispone de una librería matemática (trigonométrica, logarítmica, etc.)."@es .

ns1:LicenciaBasicaFagor a ns1:Sistema ;
    rdfs:label "Licencia Básica (Fagor)"@es ;
    ns1:identificador "Básica" ;
    ns1:textoExtracto "Fagor suministra la licencia 'Básica', que permite configurar el bus. Algunas opciones del configurador no estarán disponibles con esta licencia."@es .

ns1:LicenciaPendrive_KPA_EtherCAT_Studio a ns1:ElementoSeguridad ;
    rdfs:label "Licencia vinculada a pendrive para KPA EtherCAT Studio" ;
    ns1:habilitadoPor ns1:ConfiguradorTopologiaKPA_EtherCAT_Studio ;
    ns1:textoExtracto "Fagor entrega un pendrive con el instalador y la licencia del configurador \"KPA EtherCAT Studio\". Esta licencia está vinculada al pendrive; el usuario podrá tener el configurador instalado en varios equipos, pero necesitará conectar el pendrive para utilizarlo." .

ns1:LimiteInferior_Z1_EjeX a ns1:Parametro ;
    rdfs:label "Límite inferior Zona 1 (Eje X, 0 mm)"@es ;
    ns1:identificador "A.ZONELOWLIM[1].X" ;
    ns1:textoExtracto "MOV 0 R1 = CNCWR(R1, A.ZONELOWLIM[1].X, M1)"@es ;
    ns1:valor 0 .

ns1:LimiteSuperior_Z1_Eje1_Canal2 a ns1:Parametro ;
    rdfs:label "Límite superior Zona 1 (Eje 1, Canal 2)"@es ;
    ns1:identificador "A.ZONEUPLIM[1].1" ;
    ns1:textoExtracto "[2].A.ZONEUPLIM[1].1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ. Zona 1."@es .

ns1:LimiteSuperior_Z1_Eje4 a ns1:Parametro ;
    rdfs:label "Límite superior Zona 1 (Eje lógico 4)"@es ;
    ns1:identificador "A.ZONEUPLIM[1].4" ;
    ns1:textoExtracto "A.ZONEUPLIM[1].4 | Eje con número lógico ꞏ4ꞏ. Zona 1."@es .

ns1:LimiteSuperior_Z1_EjeX a ns1:Parametro ;
    rdfs:label "Límite superior Zona 1 (Eje X, 100 mm)"@es ;
    ns1:identificador "A.ZONEUPLIM[1].X" ;
    ns1:textoExtracto "MOV 1000000 R1 = CNCWR(R1, A.ZONEUPLIM[1].X, M1)"@es ;
    ns1:valor 1000000 .

ns1:LimiteSuperior_Z1_EjeZ a ns1:Parametro ;
    rdfs:label "Límite superior Zona 1 (Eje Z)"@es ;
    ns1:identificador "A.ZONEUPLIM[1].Z" ;
    ns1:textoExtracto "A.ZONEUPLIM[1].Z | Eje Z. Zona 1."@es .

ns1:LimitesFisicosEjes a ns1:Parametro ;
    rdfs:label "Límites físicos de los ejes (FL)"@es ;
    ns1:identificador "FL" ;
    ns1:textoExtracto "FL Límites físicos."@es .

ns1:ListaSubrutinas_pcall a ns1:InterfazUsuario ;
    rdfs:label "Lista pcall.txt" ;
    ns1:identificador "pcall.txt" ;
    ns1:textoExtracto "la lista pcall.txt mostrará los nombres de subrutinas contenidos en ambos" .

ns1:ListaValoresPredeterminados_43 a ns1:Tabla ;
    rdfs:label "Tabla de valores predeterminados para parámetros máquina"@es ;
