    ns1:documentadoEn ns1:Pagina_124_130 ;
    ns1:textoExtracto "PLANECANCEL | Significado... [fragmento tabular]" .

ns1:Tabla_2419_significadoRapiden a ns1:Tabla ;
    rdfs:label "Tabla 2.4.19 - Significado de RAPIDEN"@es ;
    ns1:documentadoEn ns1:ModoOperacion_avanceRapidoAutomatico ;
    ns1:textoExtracto """\r
| RAPIDEN | Significado. |\r
| --- | --- |\r
| Deshabilitado. | El avance rápido no está disponible para el modo automático. |\r
| EXRAPID o tecla rápido. | Para activar el avance rápido sólo es necesario activar la marca EXRAPID de PLC o pulsar la tecla "rápido" del panel de jog. |\r
| EXRAPID y tecla rápido. | Para activar el avance rápido hay que activar la marca EXRAPID de PLC y pulsar la tecla "rápido" del panel de jog. |\r
        """@es .

