    ns1:textoExtracto "Cálculo de dimensiones con reloj comparador en cabezal angular (ejes B y C).",
        "Cálculo de las dimensiones con ayuda de un reloj",
        "el eje Y. [...] cabezales rotativos [...] B=0º C=0º [...] B=0º C=180º"@es ;
