    ns1:requiereMantenimiento ns1:InterfazUsuario_ComandosProgramacion ;
    ns1:textoExtracto "Ejecución de bloques CNC mediante comandos como CNCEX, CAM ON, MOVE ABS, FOLLOW ON, etc."@es .

ns1:TareaMantenimiento_ReinicioCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio del CNC tras corrección de referencia" ;
    ns1:requiereMantenimiento ns1:AvisoSeguridad_Error3753 ;
    ns1:textoExtracto "ejecutar una G174 en MDI con el valor esperado. A continuación, el usuario deberá reiniciar el CNC para asumir la cota correctamente." .

