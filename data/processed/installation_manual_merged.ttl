        ns1:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS,
        ns1:Tabla_ValoresTAKEPOS_LEAVEPOS,
        ns1:Tabla_Valores_TAKEPOS_LEAVEPOS ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta.",
        "LEAVEPOS=# Posición para dejar la herramienta",
        "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es,
        "LEAVEPOS [...] tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo"@es,
        "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es,
        "LEAVEPOS=-4 Herramienta de tierra."@es,
        "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores."@es,
