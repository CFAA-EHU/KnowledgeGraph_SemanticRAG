ns1:InterfazUsuario_ConfiguradorTopologiaBus a ns1:InterfazUsuario ;
    rdfs:label "Configurador de topología del bus (modo offline)"@es ;
    ns1:identificador "Modo offline - Construcción manual de topología" ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"... Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es .

ns1:InterfazUsuario_EditorCNC8070 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de editor CNC8070"@es ;
    ns1:identificador "CNC8070_Editor" ;
    ns1:textoExtracto "El editor permite tener en un archivo de texto (txt) una lista subrutinas que se mostrará durante la edición del programa pieza, cada vez que se edite una sentencia #PCALL ó #MCALL. El editor muestra la lista de subrutinas durante la edición, tras el espacio en blanco o tabulador posterior las sentencias #PCALL o #MCALL."@es .

ns1:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de topología EtherCAT (OpenPCS Remoto)" ;
    ns1:textoExtracto "Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados. [...] Flechas destacan los comandos de menú contextual.",
        "Modo offline en dos pasos ilustrados: (1) 'Append Slave' para añadir cabeceras desde el catálogo, (2) arrastrar módulos desde 'MDP modules' (derecha) a la topología (izquierda). Flechas curvas indican el 'drag & drop' y se ven tarjetas de módulo con nombre y tipo." .

ns1:InterfazUsuario_OpenPCSRemoto_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración EtherCAT en OpenPCS Remoto" ;
    ns1:ilustradoEn ns1:Figura_EsquemaBloquesEtherCAT ;
    ns1:textoExtracto "barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible') y vista de árbol que despliega esclavos y módulos mostrando sus recursos; indicadores 'Starts/Offset' para numeración y opción 'Ver esclavos'." .

