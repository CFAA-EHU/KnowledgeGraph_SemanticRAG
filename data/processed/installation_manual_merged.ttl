        ns1:Softkey_RepetirFaseAprendizajeDMC .

ns1:MenuPrincipal a ns1:InterfazUsuario ;
    ns1:textoExtracto "Abrir la aplicación e ir al menú principal. En el botón general, seleccionar uno de los idiomas." .

ns1:MesaRotativa_AB_TYPE9 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa rotativa AB (TYPE=9)"@es ;
    ns1:identificador "TYPE=9" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de una mesa rotativa AB con un rango de movimientos del eje A -90º a 90º y del eje B de 0º a -90º; parámetro TYPE con valor ꞏ9ꞏ. [...] Dimensiones a calcular en una mesa rotativa AB (TYPE=9)."@es ;
    ns1:tieneComponente ns1:EjeRotativo_Primario_AB,
        ns1:EjeRotativo_Secundario_AB .

ns1:MesaTipo51 a ns1:Sistema ;
