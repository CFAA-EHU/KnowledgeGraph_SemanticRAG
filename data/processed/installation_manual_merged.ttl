        "Búsqueda de referencia manual, desde el modo manual. [...] Búsqueda de referencia automática, desde el modo manual."@es,
        "MODO DE TRABAJO MANUAL. VOLANTES."@es,
        "Modo de trabajo manual"@es,
        "movimientos en jog desde el modo manual"@es ;
    ns1:tieneComponente ns1:Parametro_COUNTERID,
