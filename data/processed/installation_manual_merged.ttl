ns1:Esquema_MallaVolumetrica_3D a ns1:Esquema ;
    rdfs:label "Esquema de malla volumétrica 3D"@es ;
    ns1:ilustradoEn ns1:Tabla_CompensacionVolumetrica_Basica ;
    ns1:textoExtracto "Diagrama 3D de una malla de puntos dentro de un triedro X-Y-Z con números (1…12) que indican el orden de recorrido de las mediciones. Se muestra la posición inicial sobre cada eje (INIPOSAX1/2/3), incrementos entre puntos (INCREAX1/2/3) y la distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3, con flechas que marcan la secuencia de avance primero en X, luego en Y y finalmente en Z."@es .

ns1:InstruccionesProgramacionCNC_4_6 a ns1:InterfazUsuario ;
    rdfs:label "Instrucciones de programación CNC (Sección 4.6)"@es ;
    ns1:identificador "4.6" ;
    ns1:textoExtracto """\r
    NOT Invierte el resultado de la consulta.\r
    AND Función lógica "Y". OR Función lógica "O". XOR Función lógica "O Exclusivo". \\\r
    ( ) Instrucción de consulta de valor 1.\r
    Instrucciones de acción:\r
    • Instrucciones de acción binarias de asignación: = I, = O, = M, = MSG, = ERR, = TEN, = TRS, = TGn, = CUP, = CDW, = CEN, = CPR, = B\r
    • Instrucciones de acción binarias condicionadas: = SET, = RES, = CPL\r
    • Instrucciones de ruptura de secuencia: = JMP, = CAL, = RET\r
    • Instrucciones aritméticas: = MOV, = NGU, = NGS, = ADS, = SBS, = MLS, = DVS, = MDS\r
    """@es .

