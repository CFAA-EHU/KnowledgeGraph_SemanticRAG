ns1:TablaRecursosBusEtherCAT_Q7_A a ns1:Tabla ;
    rdfs:label "Tabla de recursos disponibles en el bus EtherCAT (Q7-A)"@es ;
    ns1:detalladoEnEsquema ns1:BusEtherCAT_Q7_A ;
    ns1:textoExtracto "Recursos disponibles en el bus. | Recursos del bus. | Total en el bus. | --- | --- | Entradas digitales. | 1024 | Salidas digitales. | 1024 | Entradas analógicas de propósito general. | 40 | Salidas analógicas de propósito general. | 40 | Entradas analógicas para sondas de temperatura Pt100. | 10"@es .

