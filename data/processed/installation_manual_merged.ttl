    ns1:documentadoEn ns1:Tabla_SubrutinasControlNumerico ;
    ns1:identificador "OEMSUB(G380)-OEMSUB(G399)" ;
    ns1:textoExtracto "Nombre: Parámetro general OEMSUB(G380) a OEMSUB(G399). Canales: Subrutina por canal."@es .

ns1:Parametro_OEMSUB_G380_G399 a ns1:Parametro ;
    rdfs:label "OEMSUB (G380-G399)" ;
    ns1:identificador "OEMSUB (G380-G399)" ;
    ns1:textoExtracto "OEMSUB (G380) CHN [...] OEMSUB (G399) | Subrutinas asociadas a las funciones G380 a G399."@es .

ns1:Parametro_OEM_Descripcion a ns1:Parametro ;
    rdfs:label "Descripción del parámetro OEM"@es ;
    ns1:identificador "OEM" ;
    ns1:textoExtracto "Este campo ofrece la posibilidad de asociar una pequeña descripción al parámetro. Este campo es informativo; no es utilizado por el CNC."@es .

ns1:Parametro_OP1 a ns1:Parametro ;
    rdfs:label "Parámetro OP1 del regulador" ;
    ns1:identificador "OP1" ;
    ns1:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ns1:valor "0" .

ns1:Parametro_OP2 a ns1:Parametro ;
    rdfs:label "Parámetro OP2 del regulador" ;
    ns1:identificador "OP2" ;
    ns1:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ns1:valor "0" .

ns1:Parametro_OPTIMIZE a ns1:Parametro ;
    rdfs:label "OPTIMIZE (Optimización de la gestión)"@es ;
    ns1:documentadoEn ns1:Tabla_GestionAlmacen ;
    ns1:identificador "TM.MZOPTIMIZED[mz]" ;
    ns1:textoExtracto "OPTIMIZE Optimización de la gestión. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZOPTIMIZED[mz]"@es ;
    ns1:valor "Sí" .

ns1:Parametro_OPTION a ns1:Parametro ;
    rdfs:label "OPTION" ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:textoExtracto "OPTION Activar las opciones del regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink. Valores posibles: De $00000000 a $0000FFFF. Valor por defecto: $00000000.",
        "Activar las opciones del regulador."@es ;
    ns1:valor "$00000000" .

ns1:Parametro_OUTPUTREV a ns1:Parametro ;
    rdfs:label "OUTPUTREV" ;
    ns1:identificador "OUTPUTREV" ;
    ns1:textoExtracto "Vueltas eje máquina. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:Parametro_OUTPUTREV2 a ns1:Parametro ;
    rdfs:label "OUTPUTREV2" ;
    ns1:identificador "OUTPUTREV2" ;
    ns1:monitoreaParametro ns1:Maquina_EjeCaptacionExterna ;
    ns1:textoExtracto "Vueltas eje máquina (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:Parametro_OVRFILTER a ns1:Parametro ;
    rdfs:label "OVRFILTER" ;
    ns1:identificador "OVRFILTER" ;
    ns1:monitoreaParametro ns1:OverrideCNC ;
    ns1:textoExtracto "OVRFILTER Tiempo para hacer efectivo el cambio de override. [...] Valor por defecto: 0. [...] Este parámetro actúa como filtro para hacer efectivo el cambio de override."@es ;
