ns1:MarcaRESETOUT a ns1:Parametro ;
    rdfs:label "RESETOUT" ;
    ns1:identificador "RESETOUT" ;
    ns1:monitoreaParametro ns1:ProcesoResetCNC ;
    ns1:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW." ;
    ns1:valor "1" .

ns1:MarcaReloj_0 a ns1:Parametro ;
