    ns1:identificador "G.DMCACTPWR" ;
    ns1:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ns1:valor "Porcentaje"^^xsd:string .

ns1:Parametro_G_DMCOVR a ns1:Parametro ;
