    ns1:monitoreaParametro ns1:Figura_2.4.8_CondicionesPorDefecto_Canal ;
    ns1:textoExtracto "gráficas de [...] aceleración (a)"@es .

ns1:Parametro_AceleracionLineal a ns1:Parametro ;
    rdfs:label "Aceleración lineal" ;
    ns1:textoExtracto "La peor respuesta se consigue con la aceleración lineal. [...] Los desplazamientos más rápidos se consiguen con la aceleración lineal." .

ns1:Parametro_AceleracionSenoCuadrado a ns1:Parametro ;
    rdfs:label "Aceleración seno cuadrado" ;
    ns1:textoExtracto "La aceleración seno cuadrado es una mejora a la aceleración trapezoidal, que suaviza el jerk para que los desplazamientos sean más suaves y sufra menos la mecánica del eje. [...] Con la aceleración seno cuadrado se obtiene la mejor respuesta del sistema, los desplazamientos son más suaves y sufre menos la mecánica del eje." .

ns1:Parametro_AceleracionTrapezoidal a ns1:Parametro ;
    rdfs:label "Aceleración trapezoidal" ;
    ns1:textoExtracto "La aceleración trapezoidal permite programar rampas con objeto de suavizar los cambios de aceleración y deceleración." .

ns1:Parametro_AmplitudBase_Ao a ns1:Parametro ;
    rdfs:label "Amplitud base (Ao)"@es ;
    ns1:identificador "Ao" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es .

ns1:Parametro_AmplitudPosicion a ns1:Parametro ;
    rdfs:label "Amplitud de posición"@es ;
    ns1:monitoreaParametro ns1:Orden_CompensacionHolgura_BAKANOUT ;
    ns1:textoExtracto "Amplitud del parametriza de posición"@es .

ns1:Parametro_AnchoBandaNotch a ns1:Parametro ;
    rdfs:label "Ancho de banda efectivo del notch"@es ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ns1:Parametro_AntesAntes a ns1:Parametro ;
    rdfs:label "Antes - Antes (sincronización función M)"@es ;
    ns1:documentadoEn ns1:TablaFuncionesM_491 ;
    ns1:textoExtracto "La función M se envía al PLC y se sincroniza antes del movimiento."@es ;
    ns1:valor "Antes - Antes" .

ns1:Parametro_AntesDespues a ns1:Parametro ;
    rdfs:label "Antes - Después (sincronización función M)"@es ;
    ns1:documentadoEn ns1:TablaFuncionesM_491 ;
    ns1:textoExtracto "La función M se envía al PLC antes del movimiento y se sincroniza después."@es ;
    ns1:valor "Antes - Después" .

ns1:Parametro_AvanceMaximoPLC a ns1:Parametro ;
    rdfs:label "Avance máximo fijado por PLC"@es ;
    ns1:textoExtracto "ni tampoco al avance máximo fijado por PLC (variable"@es .

ns1:Parametro_AvancePorDiente a ns1:Parametro ;
    rdfs:label "Avance por diente",
        "Avance por diente (FZMIN/FZMAX)"@es ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion,
        ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "C Avance por diente. Los límites de la barra de consumo son los valores programados en la sentencia #DMCON (comandos FZMIN y FZMAX)."@es,
        "El avance modificado con el override respeta el avance por diente mínimo y máximo fijado para la herramienta. Para que el CNC pueda vigilar el avance por diente, hay que definir el número de dientes de la herramienta en la tabla de herramientas."@es .

ns1:Parametro_AvanceRapido a ns1:Parametro ;
    rdfs:label "Parámetro de avance rápido"@es ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Si el parámetro se define con valor ꞏ0ꞏ, no se limita el avance. Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados."@es .

