    ns1:textoExtracto "El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales." ;
    ns1:tieneComponente ns1:MPGDIMODADDRNb .

ns1:SistemaCANopen_146 a ns1:Sistema ;
    rdfs:label "Sistema de numeración de salidas digitales (bus CANopen)"@es ;
