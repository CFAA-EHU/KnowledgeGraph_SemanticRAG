ns1:EntradaDigital a ns1:Sensor ;
    rdfs:label "Entrada digital" ;
    ns1:textoExtracto "En vez de un palpador, también se puede utilizar como evento una entrada digital física o de una entrada lógica." .

ns1:EntradaFisica_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada física I2"@es ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2. [...] Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1."@es .

ns1:EntradaI10 a ns1:Parametro ;
    rdfs:label "Entrada I10" ;
    ns1:identificador "I10" ;
    ns1:monitoreaParametro ns1:SalidasO5AO12 ;
    ns1:textoExtracto "I10 = ERA O5 12. Si la entrada I10 vale '1' el PLC asignará el valor 0 a las salidas O5 a O12, ambas inclusive." .

ns1:EntradaI15 a ns1:Parametro ;
    rdfs:label "Entrada I15" ;
    ns1:identificador "I15" ;
    ns1:monitoreaParametro ns1:Registro_R123 ;
    ns1:textoExtracto "I15 = PAR R123 M222. Si la entrada I15 vale '1' el PLC analiza el registro R123 y asignará un '1' a la marca M222 si tiene paridad PAR o un '0' si tiene paridad IMPAR." .

ns1:EntradaI23 a ns1:Parametro ;
    rdfs:label "Entrada I23" ;
    ns1:identificador "I23" ;
    ns1:monitoreaParametro ns1:Contadores_C15_C18 ;
    ns1:textoExtracto "I23 = ERA C15 18. Si la entrada I23 vale '1' el PLC preseleccionará a 0 los contadores C15 a C18, ambos inclusive." .

ns1:EntradaLogica_PLC a ns1:ComponenteElectrico ;
    rdfs:label "Entrada lógica del PLC"@es ;
    ns1:textoExtracto "el PLC considera entradas lógicas a aquellas entradas que no existen como físicas"@es .

ns1:EntradaPT100AI3Nodo2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI3 (nodo 2)" ;
    ns1:identificador "AI3 (address = 2)" ;
    ns1:textoExtracto "Entrada PT100 (AI3) en módulo RIOR (nodo 2)." .

ns1:EntradaPieza a ns1:Parametro ;
    rdfs:label "Entrada a la pieza" ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Si la herramienta está entrando en la pieza, el DMC se desactivará cuando termine la entrada. [...] seguirá detectando las entradas a la pieza." .

ns1:Entrada_AI5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI5" ;
    ns1:identificador "AI5" ;
    ns1:textoExtracto "Entrada PT100 (AI5) en módulo RIO5." .

ns1:Entrada_AI6 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI6" ;
    ns1:identificador "AI6" ;
    ns1:textoExtracto "Entrada PT100 (AI6) en módulo RIO5." .

ns1:Entrada_CEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CEN (enable)" ;
    ns1:controla ns1:Entrada_CDW,
        ns1:Entrada_CUP ;
    ns1:identificador "CEN" ;
    ns1:textoExtracto "(CEN) Entrada de enable. Permite detener la cuenta interna del contador. [...] Para poder modificar la cuenta interna (CUP y CDW) la entrada CEN debe estar a (=1). Con CEN a (=0) se detiene la cuenta del contador y no se hace caso a las entradas CUP y CDW."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Entrada_CPR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CPR (preselección)" ;
    ns1:identificador "CPR" ;
    ns1:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta. El contador se preselecciona con el valor indicado cuando se produce un flanco de subida en la entrada CPR."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Entrada_I15 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I15" ;
    ns1:controla ns1:NGUR11024 ;
    ns1:identificador "I15" ;
    ns1:textoExtracto "I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

ns1:Entrada_I16 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I16" ;
    ns1:controla ns1:NGSR11024 ;
    ns1:identificador "I16" ;
    ns1:textoExtracto "I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:Entrada_I2 a ns1:Parametro ;
    rdfs:label "Entrada I2" ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." ;
    ns1:valor "1" .

ns1:Entrada_I22 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I22" ;
    ns1:identificador "I22" ;
    ns1:textoExtracto "I12 OR NOT I22 = RES M55" .

ns1:Entrada_I23 a ns1:Parametro ;
    rdfs:label "Entrada I23" ;
    ns1:identificador "I23" ;
    ns1:textoExtracto "(I12 AND I23) OR M54 = O6" .

ns1:Entrada_I3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3",
        "Entrada I3 (Reset T10)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "Por defecto y cada vez que se activa un temporizador el PLC pone esta entrada a (=0). I3 = TRS 10. La entrada I3 controla la entrada de reset del temporizador T10." .

ns1:Entrada_I8 a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "Entrada I8" ;
    ns1:identificador "I8" ;
    ns1:textoExtracto "DFU I8 OR DFD M22 = CPL B12R35" ;
    ns1:valor "1" .

ns1:EnviarElBrazoCambiadorAlAlmacen a ns1:Componente ;
