ns1:Comando_M30 a ns1:Parametro ;
    rdfs:label "Comando M30" ;
    ns1:identificador "M30" ;
    ns1:textoExtracto "Si la subrutina finaliza con M30, también finaliza la ejecución del programa" .

ns1:Comando_MFUN a ns1:InterfazUsuario ;
    rdfs:label "Comando MFUN*" ;
    ns1:monitoreaParametro ns1:Parametro_M30 ;
    ns1:textoExtracto "Comando MFUN*. Analizar si una función ha sido programada en el bloque. Para poder conocer si una determinada función M se encuentra programada en el bloque en ejecución, se puede utilizar uno de los siguientes métodos: • Analizar todos los registros MFUN uno a uno, hasta encontrar dicha función M o hasta que uno de ellos tenga el valor $FFFFFFFF. • Utilizar el comando MFUN* que permite analizar todos los registros a la vez. Ejemplo para detectar M30. Si se ha programado devolverá un \"1\"; un \"0\" en caso contrario. CPS MFUN* EQ 30 = ..." .

ns1:Comando_MOVEABS a ns1:InterfazUsuario ;
    rdfs:label "Comando MOVEABS (movimiento absoluto)"@es ;
    ns1:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente [...] El comando MOVEABS se ejecuta directamente en el interpolador"@es .

ns1:Comando_MOVEADD a ns1:InterfazUsuario ;
    rdfs:label "Comando MOVEADD (movimiento incremental)"@es ;
    ns1:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente [...] Los comandos MOVE* se ejecutan directamente en el interpolador"@es .

ns1:Comando_MOVEINF a ns1:InterfazUsuario ;
    rdfs:label "Comando MOVEINF (movimiento infinito)"@es ;
