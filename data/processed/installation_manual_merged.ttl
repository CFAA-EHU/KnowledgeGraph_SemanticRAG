    ns1:controla ns1:ConfiguracionEntradasPT100_15_6 ;
    ns1:textoExtracto "Las entradas PT100 se activan desde los parámetro máquina. Para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal), el PLC dispone de las siguientes marcas."@es ;
    ns1:tieneComponente ns1:SondaPT100_1,
        ns1:SondaPT100_2,
        ns1:SondaPT100_3 .

