    rdfs:label "Canales" ;
    ns1:textoExtracto "Canales. El menú muestra la lista de canales disponibles."@es ;
    ns1:valor "Canales" .

ns1:Opcion_Componentes a ns1:Parametro ;
    rdfs:label "Componentes" ;
    ns1:textoExtracto "Componentes. El menú muestra los componentes o modos de trabajo del CNC."@es ;
