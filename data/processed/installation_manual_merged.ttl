ns1:Parametro_ConfiguracionVolantes a ns1:Parametro ;
    rdfs:label "Parámetro de configuración de volantes"@es ;
    ns1:identificador "2.7.1_ConfiguracionVolantes" ;
    ns1:textoExtracto "Para definir un volante individual, definir el nombre del eje al que está asociado. Para definir un volante general, no asignar ningún valor al parámetro, dejarlo en blanco. Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir."@es .

ns1:Parametro_DIMODADDR a ns1:Parametro ;
    rdfs:label "DIMODADDR",
        "Parámetro MPG.DIMODADDR[nb]"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1265,
        ns1:Tabla_ParametrosRIOR ;
    ns1:identificador "(V.)MPG.DIMODADDR",
        "DIMODADDR",
        "MPG.DIMODADDR[nb]" ;
    ns1:monitoreaParametro ns1:Nodo_RIOW_2 ;
    ns1:textoExtracto "DIMODADDR Direcciones base de los bloques lógicos de entradas digitales. Este parámetro muestra la tabla para personalizar los bloques lógicos de entradas digitales.",
        "DIMODADDR Tabla de módulos de entradas digitales. Este parámetro muestra la lista de módulos de entradas digitales conectados en el mismo bus CAN.",
        "DIMODADDR | - - - | Ver tabla inferior.",
        "Direcciones base de los bloques lógicos de entradas digitales."@es,
        "Este parámetro establece el índice base a partir del cual se numeran las entradas digitales del bloque lógico. Los valores del índice base deben cumplir con la fórmula '8n + 1' (es decir, 1, 9, 17, 25 ...)."@es ;
    ns1:valor "8n + 1 (ej. 1, 9, 17, 25...)"@es .

ns1:Parametro_DMCPWRHOLD a ns1:Parametro ;
    rdfs:label "DMCPWRHOLD" ;
    ns1:identificador "DMCPWRHOLD" ;
    ns1:textoExtracto "Si todos los valores de la potencia leídos durante 2 segundos exceden la potencia a alcanzar multiplicada por este factor, el CNC muestra un warning y activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." .

ns1:Parametro_DMCSPDL a ns1:Parametro ;
