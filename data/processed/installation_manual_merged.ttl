    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de mesa que tenga como máximo dos ejes rotativos. Definición vectorial de la cinemáticas."@es ;
    ns1:tieneComponente ns1:EjeRotativo1,
        ns1:EjeRotativo2 .

ns1:MicroInterrupter a ns1:Sensor ;
    rdfs:label "Micro (interruptor de referencia)" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "hasta encontrar cada uno su micro. [...] Los ejes esperan sobre el micro hasta que todos los ejes implicados en la búsqueda encuentren el micro." .

ns1:ModoAcceso_Avanzado a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso avanzado (preconfigurado)" ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoAcceso_Basico a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso básico (preconfigurado)" ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoAcceso_Intermedio a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso intermedio (preconfigurado)" ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoAutomatico_1185 a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:habilitadoPor ns1:TeclaSTART_1185 ;
    ns1:identificador "ModoAutomatico" ;
    ns1:textoExtracto "desde el modo automático, para iniciar la ejecución del programa entero"@es .

ns1:ModoDMC a ns1:ModoOperacion ;
