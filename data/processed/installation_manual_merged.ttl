    ns1:textoExtracto "Gestión multieje" ;
    ns1:tieneComponente ns1:Componente_MotorMultieje .

ns1:ModoOperacion_NoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo no-HSC" ;
    ns1:habilitadoPor ns1:Parametro_SLOPETYPE ;
    ns1:identificador "G7/G50/G5" ;
    ns1:textoExtracto "Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Lineal. Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Trapezoidal. Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Seno cuadrado." .

ns1:ModoOperacion_OnlineBusScan a ns1:ModoOperacion ;
