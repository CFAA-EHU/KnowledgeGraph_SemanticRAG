ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "Desalineamiento de la herramienta sobre el eje C (TDATA6)",
        "TDATA6",
        "TDATA6 (Componente vector dirección eje Z)",
        "TDATA6 (componente Z de V1)",
        "TDATA6 (desalineamiento)",
        "Parámetro TDATA6 (descentramiento)"@es,
        "Parámetro TDATA6 (distancia eje herramienta - eje secundario, eje Y)"@es,
        "Radio de zona inaccesible por desalineamiento (TDATA6)"@es,
        "TDATA6"@es,
        "TDATA6 (distancia 2º a 1º centro de giro, eje Y)"@es ;
    ns1:documentadoEn ns1:Esquema_17.1_TDATA6_PrimeraPalpacion,
        ns1:Pagina_265_269,
        ns1:TablaParametrosTDATA,
        ns1:Tabla_17_2_CalculoDimensionesCabezalAngular,
        ns1:Tabla_RedefinicionCinematicaTipo1_16,
        ns1:Tabla_RedefinicionCinematicaVectorial_293_308 ;
    ns1:identificador "TDATA6" ;
    ns1:monitoreaParametro ns1:Esquema_PalpacionTDATA6,
        ns1:Parametro_D,
        ns1:Parametro_R ;
    ns1:textoExtracto "Cálculo del parámetro TDATA6 [...] medir la pieza, cuya dimensión será la cota indicada en el CNC menos el diámetro de la bola del palpador.",
        "Cálculo del parámetro TDATA6.",
        "Se representan offsets TDATA6 (desalineamiento)",
        "TDATA 6(+)",
        "TDATA12 | TDATA6*SIN(TDATA7)",
        "TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)",
        "TDATA6 = (ΔX + ΔX' – D – 2L – 2TDATA1) / (2·cos45)",
        "TDATA6 Componente del vector dirección del eje rotativo principal (eje Z).",
        "TDATA6 Desalineamiento de la herramienta sobre el eje C. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Este parámetro permite corregir el desalineamiento de la herramienta. Una herramienta está desalineada si cuando se sitúa en cota cero y no coincide con el eje de giro del eje.",
        "TDATA6 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Z.",
        "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y.",
        "TDATA6 | 0",
        "TDATA6 | Dimensión a calcular.",
        "V1 (TDATA4, TDATA5, TDATA6)",
        "X = D + 2R",
        "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es,
        "Cálculo mediante secuencias simétricas: lecturas Xa (puntos 1-2) y Xb (puntos 3-4), con B=±90° y preselección X=0 en eje del cilindro."@es,
        "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado."@es,
        "Parámetro calculado mediante TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°)"@es,
        "TDATA13 | TDATA6*COS(TDATA7)"@es,
        "TDATA6 = 2·(X – TDATA1)"@es,
        "TDATA6 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje Y."@es,
        "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y."@es,
        "TDATA6 | 1"@es,
        "cálculo TDATA6 = 2·XM − TDATA1"@es,
        "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es,
        "ubicación del eje de mesa (TDATA4–TDATA6)"@es,
        "| TDATA6 | 1 |"@es ;
    ns1:valor 1,
        "0",
        "1",
        "2·XM − TDATA1",
        "DATA 6",
        "TDATA6",
        "X = D + 2R"^^xsd:string,
        "desplazamiento herramienta vs. eje secundario",
        "distancia (eje Z): eje rotativo mesa ↔ referencia máquina",
        "distancia (eje Y)"@es,
        "radio de zona inaccesible"@es .

