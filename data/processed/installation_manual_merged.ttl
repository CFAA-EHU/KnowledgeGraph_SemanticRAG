ns1:Tabla_Se_alesConsultaGenerales_6_1 a ns1:Tabla ;
    rdfs:label "Tabla de asignación de funciones H en canales CNC"@es ;
    ns1:textoExtracto """\r
    Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en el primer canal se encuentran programadas las funciones H10 y H20 y en el segundo canal las funciones H30 y H40, el CNC pasará al PLC la siguiente información.\r
    | HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 |\r
    | --- | --- | --- |\r
    | 10 | 20 | $FFFFFFFF |\r
    | HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 |\r
    | --- | --- | --- |\r
    | 30 | 40 | $FFFFFFFF |\r
    """ .

ns1:Tabla_Se_alesPLC_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla de señales PLC para compensación volumétrica"@es,
        "Tabla de señales de PLC para compensación volumétrica"@es ;
    ns1:textoExtracto """\r
| Señal de PLC. |  | Significado. |\r
| --- | --- | --- |\r
| VOLCOMP1 PLC_M |  | Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)...\r
""" .

ns1:Tabla_TDATA12 a ns1:Tabla ;
    rdfs:label "Tabla de modos de control de cinemática del cabezal (TDATA12)" ;
