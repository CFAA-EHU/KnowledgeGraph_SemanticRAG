    ns1:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada [...] V.S.EXECUTION = 1 ; Ejecución" ;
    ns1:valor "0,1" .

ns1:EstadoDeEnableDelTemporizador a ns1:Parametro ;
    rdfs:label "Estado de enable del temporizador"@es ;
    ns1:textoExtracto "si se pone la entrada TEN a (=0) el PLC detiene la temporización, siendo necesario poner la entrada TEN a (=1) para que dicha temporización continúe"@es ;
    ns1:valor 0,
        1 .

ns1:EstadoDelCircuitoDePotencia a ns1:Parametro ;
    rdfs:label "Estado del circuito de potencia" ;
    ns1:textoExtracto "Si el PLC desactiva la señal DRENA (drive enable), el circuito de potencia del dispositivo se apaga y el motor queda sin par." .

ns1:EstadoDelTemporizadorT a ns1:Parametro ;
    rdfs:label "Estado del temporizador (T)"@es ;
    ns1:textoExtracto "la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t a partir del valor 0. [...] desactivándose la salida de estado del temporizador (T=0)."@es ;
    ns1:valor "0",
        "1" .

ns1:EstadoDesaparcado a ns1:Parametro ;
    rdfs:label "Estado desaparcado" ;
    ns1:textoExtracto "tras desaparcar el eje las señales de habilitación del eje se deben poner a (=1)." ;
    ns1:valor "1" .

ns1:EstadoPLC a ns1:Parametro ;
    rdfs:label "Estado del PLC (marcha/parada)" ;
    ns1:textoExtracto "marca que indica si el PLC está en marcha (=1) o parado (=0)" ;
    ns1:valor 0,
        1 .

ns1:EstadoSincronizacionCNC a ns1:Parametro ;
    rdfs:label "Estado de sincronización CNC-PLC" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." ;
    ns1:valor "1" .

ns1:EstadoSistemaOperativoCNC a ns1:Parametro ;
    rdfs:label "Estado del sistema operativo CNC" ;
    ns1:textoExtracto "Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema." ;
    ns1:valor "0",
        "1" .

