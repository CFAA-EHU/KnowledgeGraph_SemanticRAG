ns1:Sistema_CompensacionHolgura a ns1:Sistema ;
    rdfs:label "Sistema de compensación de holgura",
        "Sistema de compensación de holgura con impulso adicional de consigna",
        "Sistema de compensación de holgura con impulso adicional"@es ;
    ns1:monitoreaParametro ns1:Parametro_REVEHYST ;
    ns1:textoExtracto "En los ejes analógicos, cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto.",
        "compensación de holgura. [...] el CNC lanzará la compensación. Tras aplicar una compensación, el CNC tomará la siguiente orden de invertir como nueva referencia para evaluar la variación de la posición y establecer cuándo se alcanza nuevamente el valor dado en el parámetro REVEHYST y volver a compensar.",
        "compensación de holgura con impulso adicional de consigna [...] Inversión de la consigna de posición. 2 Límite definido en REVEHYST. Inicio de la compensación de holgura. 3 Cancelación de la compensación de holgura"@es ;
    ns1:tieneComponente ns1:Componente_EjeVisualizador,
        ns1:Parametro_ACTBAKAN,
        ns1:Parametro_BAKANOUT,
        ns1:Parametro_BAKTIME,
        ns1:Parametro_PEAKDISP .

ns1:Sistema_ComunicacionPLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-cinemáticas" ;
