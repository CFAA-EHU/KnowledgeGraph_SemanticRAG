ns1:PuntoReferenciaPortaherramientas a ns1:ComponenteMecanico ;
    rdfs:label "Punto de referencia del portaherramientas"@es ;
    ns1:textoExtracto "X [...] T Punto de referencia del portaherramientas. [...] Si se programa una posición en la que el punto de referencia del portaherramientas sale de los límites de software, el CNC detiene la ejecución y muestra el error correspondiente."@es .

ns1:PuntoReferencia_I0 a ns1:Componente ;
    rdfs:label "I0 (punto de referencia codificado)" ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados",
        "encuentra el I0" .

ns1:PuntoReferencia_OT a ns1:Parametro ;
    rdfs:label "OT" ;
    ns1:textoExtracto "OT: Punto de referencia de las herramientas." .

ns1:Punto_T_Portaherramientas a ns1:ComponenteMecanico ;
    rdfs:label "Punto T (portaherramientas)" ;
    ns1:textoExtracto "el punto T (portaherramientas) se relaciona con OM" .

ns1:QWERTYOFF a ns1:Parametro ;
    rdfs:label "QWERTYOFF (deshabilitación teclado alfanumérico)" ;
    ns1:identificador "QWERTYOFF" ;
    ns1:textoExtracto "A partir de esta versión, la nueva marca QWERTYOFF deshabilita la parte alfanumérica y la marca PANELOFF sólo deshabilita el panel de jog." .

ns1:RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto RCS-S" ;
    ns1:identificador "RCS-S" ;
    ns1:textoExtracto "El módulo \"RCS-S\" permite disponer de un número adicional de entradas de contaje y salidas analógicas (I/Os remotas). Estos módulos se conectan a la unidad central a través del bus Sercos-II, siendo un nodo más dentro del bus." .

ns1:REFFEED1_264 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "el cabezal decelera hasta REFFEED1"@es .

ns1:REFTIME a ns1:Parametro ;
    rdfs:label "REFTIME" ;
    ns1:identificador "REFTIME" ;
    ns1:textoExtracto "Consultar el parámetro máquina general TTIME.",
        "REFTIME Tiempo estimado para la búsqueda de cero. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ns1:valor 0 .

ns1:RETRACE a ns1:Parametro ;
