ns1:TopesMecanicosEjes a ns1:ComponenteMecanico ;
    rdfs:label "Topes mecánicos de los ejes"@es ;
    ns1:textoExtracto "Los carros alcanzan los topes cuando el punto de referencia del portaherramientas se sitúa en los límites físicos. FL Límites físicos."@es .

ns1:Torno_3Canales_6Ejes_2Cabezales a ns1:Maquina ;
    rdfs:label "Torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ns1:compuestoPor ns1:Canal_1,
        ns1:Canal_2,
        ns1:Canal_3 ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales ;
    ns1:textoExtracto "plano. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S). Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1). Canal ꞏ3ꞏ. 2 ejes (U V)"@es ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Cabezal_S1,
        ns1:Eje_U,
        ns1:Eje_V,
        ns1:Eje_X,
        ns1:Eje_X1,
        ns1:Eje_Z,
        ns1:Eje_Z1 .

ns1:Torno_3Canales_6Ejes_2Cabezales_ConfiguracionCanal3 a ns1:Sistema ;
    rdfs:label "Configuración de ejes y cabezales del canal 3 (torno 3 canales, 6 ejes, 2 cabezales)"@es ;
    ns1:identificador "Canal 3"@es ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ3ꞏ."@es ;
    ns1:tieneComponente ns1:Cabezal_S1_Canal3,
        ns1:Eje_X1_Canal3,
        ns1:Eje_Z1_Canal3 .

ns1:Torno_ConfiguracionTriedro_1041 a ns1:Maquina ;
    rdfs:label "Torno con 1 canal, 3 ejes y 1 cabezal (configuración triedro)"@es ;
    ns1:controla ns1:Parametro_IPLANE_1041 ;
    ns1:identificador "Configuración tipo triedro (G18 por defecto)"@es ;
    ns1:textoExtracto "Torno con 1 canal, 3 ejes y 1 cabezal. Configuración de ejes tipo triedro."@es ;
    ns1:tieneComponente ns1:Cabezal_Indice1_1041 .

ns1:TransformacionAngularEjeInclinado a ns1:ModoOperacion ;
    rdfs:label "Transformación angular de eje inclinado"@es ;
    ns1:controla ns1:SistemaEjesNoPerpendiculares_ZX ;
    ns1:habilitadoPor ns1:Sentencia_ANGAX_ON ;
    ns1:textoExtracto "La transformación angular de eje inclinado permite programar desplazamientos en coordenadas cartesianas y ejecutarlos en un plano no cartesiano; es decir, en un plano donde los ejes no están a 90º entre ellos."@es,
        "Para poder programar en el sistema cartesiano (Z-X), hay que activar una transformación angular de eje inclinado que convierta los movimientos a los ejes reales no perpendiculares (Z-X')."@es,
        "Un caso típico es el eje X de torno que por motivos de robustez no forma 90º con el eje Z, sino que tiene otro valor."@es .

ns1:Transformacion_T4 a ns1:Parametro ;
    rdfs:label "Transformación T4"@es ;
