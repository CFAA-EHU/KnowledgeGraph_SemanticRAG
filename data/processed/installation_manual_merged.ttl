        "MPG.DIFFCOMP[nb]" ;
    ns1:monitoreaParametro ns1:Sistema_Gantry ;
    ns1:textoExtracto "Parámetro incluido en la tabla GANTRY. Este parámetro habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina.",
        "el parámetro DIFFCOMP habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina",
        "si el parámetro DIFFCOMP está a 'Sí', el CNC corregirá la diferencia de cota al habilitar el eje" ;
    ns1:valor false .

ns1:Parametro_DMCPWRPEAK a ns1:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "el CNC [...] activa la marca DMCPWRPEAK. Este parámetro permite detectar un pico de potencia, que puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc.",
        "DMCPWRPEAK. Hay una marca para cada canal."@es .

ns1:Parametro_DOMODADDR a ns1:Parametro ;
    rdfs:label "DOMODADDR",
        "Parámetro MPG.DOMODADDR[nb]" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1267,
        ns1:Tabla_ParametrosDOMOD ;
    ns1:identificador "DOMODADDR",
        "MPG.DOMODADDR[nb]" ;
    ns1:textoExtracto "DOMODADDR Direcciones base de los bloques lógicos de salidas digitales. Este parámetro muestra la tabla para personalizar los bloques lógicos de salidas digitales.",
        "DOMODADDR | - - - | Ver tabla inferior.",
        "Este parámetro establece el índice base a partir del cual se numeran las salidas digitales del bloque lógico. Los valores del índice base deben cumplir con la fórmula '8n + 1' (es decir, 1, 9, 17, 25 ...). Variable asociada: (V.)MPG.DOMODADDR[nb]",
        "Direcciones base de los bloques lógicos de salidas digitales."@es ;
    ns1:valor "8n + 1 (ej. 1, 9, 17, 25...)" .

ns1:Parametro_DROPRATE a ns1:Parametro ;
    rdfs:label "(V.)[ch].G.DROPRATE",
        "V.G.DROPRATE" ;
    ns1:documentadoEn ns1:Tabla_13_3_4_VariablesLimitacionAvance ;
    ns1:identificador "DROPRATE",
        "V.G.DROPRATE" ;
    ns1:monitoreaParametro ns1:Parametro_PERFRATE ;
    ns1:textoExtracto "V.G.DROPRATE Un valor menor que 100 indica que el CNC podría aumentar el avance si tuviera más bloques.",
        "Porcentaje de reducción del avance máximo alcanzable. [...] Esta variable debe devolver un valor próximo a 100; si el valor es inferior al 100 %, es posible que el CNC pueda aumentar el avance si tuviera más bloques."@es ;
    ns1:valor "100.0"^^xsd:float,
        "Indicador de capacidad de aumento de avance" .

