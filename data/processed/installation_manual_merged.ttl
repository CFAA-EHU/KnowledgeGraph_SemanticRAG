ns1:ParametrizacionCANopen a ns1:Parametro ;
    rdfs:label "Parametrización de entradas digitales (bus CANopen)"@es ;
    ns1:documentadoEn ns1:ManualCANopen ;
    ns1:textoExtracto """\r
    La configuración debe cumplir los siguientes requisitos. Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus.\r
    • Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir.\r
    • Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar.\r
    • El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales.\r
    • El número de I/Os de un bloque lógico no puede ser cero, y debe ser un múltiplo de 8.\r
    • Los valores del índice base deben cumplir con la fórmula "8n + 1" (es decir, 1, 9, 17, 25 ...).\r
    • Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024)."""@es ;
    ns1:valor "NODE: 1-126; BLOCK: 1-64; ADDRESS: 1-1017 (fórmula 8n+1)"@es .

ns1:Parametrizacion_AltaACCEL_BajoACCJERK a ns1:Parametro ;
    rdfs:label "Configuración: ACCEL máxima y ACCJERK mínimo"@es ;
    ns1:monitoreaParametro ns1:G00FEED_Parametro ;
    ns1:textoExtracto "ACCEL máxima y ACCJERK mínimo"@es .

ns1:Parametrizacion_BajaACCEL_AltoACCJERK a ns1:Parametro ;
    rdfs:label "Configuración: ACCEL menor y ACCJERK mayor"@es ;
    ns1:monitoreaParametro ns1:G00FEED_Parametro ;
    ns1:textoExtracto "ACCEL menor y ACCJERK mayor, que acorta el tiempo hasta aceleración máxima y mantiene más tiempo la meseta"@es .

ns1:ParametroADDRESS a ns1:Parametro ;
    rdfs:label "ADDRESS (Dirección base del bloque lógico)"@es ;
    ns1:documentadoEn ns1:ManualCANopen ;
    ns1:textoExtracto "ADDRESS: Dirección base del bloque lógico. Valores posibles: De 1 a 1017. Valor por defecto: El primer valor válido."@es ;
    ns1:valor "1-1017 (fórmula 8n+1)"@es .

ns1:ParametroAutoGear a ns1:Parametro ;
    rdfs:label "Parámetro AUTOGEAR" ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "sin generar un cambio de gama aunque éste sea automático (parámetro AUTOGEAR)" .

ns1:ParametroBLOCK a ns1:Parametro ;
    rdfs:label "BLOCK (Número de bloque lógico)"@es ;
    ns1:documentadoEn ns1:ManualCANopen ;
    ns1:textoExtracto "BLOCK: Número de bloque lógico. Valores posibles: De 1 a 64. Valor por defecto: 0."@es ;
    ns1:valor "1-64 (defecto: 0)"@es .

ns1:ParametroCAXIS a ns1:Parametro ;
    rdfs:label "CAXIS"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesTornoB,
