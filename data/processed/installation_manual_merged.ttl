        ns1:InterfazUsuario ;
    rdfs:label "Marca DINDISTYPEC1" ;
    ns1:identificador "DINDISTYPEC1" ;
    ns1:textoExtracto "DINDISTYPEC1 [...] Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo.",
        "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" .

