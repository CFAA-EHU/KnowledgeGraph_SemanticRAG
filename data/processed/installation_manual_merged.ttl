    ns1:ilustradoEn ns1:Pagina_271 ;
    ns1:textoExtracto "Ilustración del cabezal ortogonal con tres ejes de giro (principal, secundario, terciario). Acompañada de la enumeración TDATA1…TDATA12, el gráfico identifica la nariz del mandrino, los centros de giro 1º–3º y las distancias entre centros y eje de herramienta, con indicación del signo positivo en cada eje."@es .

ns1:Esquema_CaminoMasCorto a ns1:Esquema ;
    rdfs:label "Esquema de posicionamiento por camino más corto (SHORTESTWAY = Sí)"@es ;
