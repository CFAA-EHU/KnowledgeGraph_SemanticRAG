ns1:FuncionesM_H_S a ns1:Sistema,
        ns1:Tabla ;
    rdfs:label "Sistema de transferencia de funciones M, H y S"@es ;
    ns1:textoExtracto "La transferencia de las funciones M y H se realiza por canal. La transferencia de las funciones S no depende del canal. Al ejecutarse un bloque que contiene las funciones M, H, S se pasa la siguiente información al PLC."@es ;
    ns1:tieneComponente ns1:FuncionesH,
        ns1:FuncionesM,
        ns1:FuncionesS,
        ns1:Parametro_MINAENDW,
        ns1:Registro_HFUN1_a_HFUN7,
        ns1:Registro_MFUN1_a_MFUN7,
        ns1:Registro_SFUN1_a_SFUN4,
        ns1:Senal_AUXEND,
        ns1:Senal_HSTROBE,
        ns1:Senal_MSTROBE,
        ns1:Senal_SSTROBE .

