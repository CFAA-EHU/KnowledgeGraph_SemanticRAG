ns1:OperacionesAlmacen_7_11_2 a ns1:Sistema ;
    rdfs:label "Operaciones del almacén (Sección 7.11.2)"@es ;
    ns1:identificador "7.11.2" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuáles de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación."@es ;
    ns1:tieneComponente ns1:Senal_LEAVEPOS,
        ns1:Senal_MZID,
        ns1:Senal_NEXTPOS,
        ns1:Senal_TAKEPOS .

ns1:OperacionesAlmacen_7_8_2 a ns1:Sistema ;
    rdfs:label "Operaciones del almacén (7.8.2)" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." ;
    ns1:tieneComponente ns1:Senal_LEAVEPOS,
        ns1:Senal_MZID,
        ns1:Senal_NEXTPOS,
        ns1:Senal_TAKEPOS .

ns1:OperacionesAlmacen_7_9_2 a ns1:Sistema ;
    rdfs:label "Operaciones del almacén (Sección 7.9.2)" ;
    ns1:identificador "7.9.2" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." ;
    ns1:tieneComponente ns1:Senal_LEAVEPOS,
        ns1:Senal_MZID,
        ns1:Senal_NEXTPOS,
        ns1:Senal_TAKEPOS .

ns1:OperacionesPLC_7_11_1 a ns1:ModoOperacion ;
    rdfs:label "Operaciones válidas y marcas que activa el PLC"@es ;
    ns1:identificador "7.11.1" ;
    ns1:textoExtracto "El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es .

