ns1:Sistema_EjeGantry a ns1:Sistema ;
    rdfs:label "Sistema de eje gantry (maestro-esclavo)"@es ;
    ns1:compuestoPor ns1:MPGDIFFCOMPNb,
        ns1:Parametro_0b5c5fb32d,
        ns1:Parametro_c9c7cd8c30 ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:textoExtracto "En ejes con captación absoluta, si el parámetro DIFFCOMP está a 'Sí', el CNC corregirá la diferencia de cota al habilitar el eje (flanco de subida de la marca SERVOxnON del eje maestro o del esclavo)."@es .

ns1:Sistema_EjeVirtualHerramienta a ns1:Sistema ;
    rdfs:label "Eje virtual de la herramienta" ;
    ns1:habilitadoPor ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_InspeccionHerramienta,
        ns1:ModoOperacion_Manual,
        ns1:ModoOperacion_ReposicionEjes ;
    ns1:monitoreaParametro ns1:Parametro_5b484fcf65,
        ns1:Parametro_e149e45825 ;
    ns1:textoExtracto "El eje virtual de la herramienta debe ser un eje lineal, pertenecer al canal y no puede ser parte del triedro principal cuando se encuentra activo. Al ser un eje del canal, es posible moverlo como cualquier otro eje en los distintos modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:Sistema_EjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes en gantry" ;
    ns1:controla ns1:ModoOperacion_GantryDesacoplado ;
    ns1:textoExtracto "el CNC desacopla el eje gantry y permite mover sólo el eje maestro. [...] permite corregir la posición de los ejes cuando estos se han cruzado y no se pueden recuperar automáticamente." ;
    ns1:tieneComponente ns1:EjeEsclavoGantry_f5fff02584,
        ns1:EjeMaestroGantry_5ce2fb2f8d .

ns1:Sistema_EjesLineales a ns1:Sistema ;
    rdfs:label "Ejes lineales" ;
    ns1:textoExtracto "Parámetro valido para ejes lineales y rotativos."@es ;
    ns1:tieneComponente ns1:Parametro_4aebb17916 .

ns1:Sistema_EjesTandem a ns1:Sistema ;
    rdfs:label "Sistema de ejes en tándem" ;
    ns1:controla ns1:ModoOperacion_TandemDesacoplado ;
    ns1:textoExtracto "El eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente. [...] El CNC visualiza las cotas del eje maestro, no permite programar sobre el eje esclavo y no se podrá aparcar ninguno de los ejes." ;
    ns1:tieneComponente ns1:EjeEsclavoTandem,
        ns1:EjeMaestroTandem .

ns1:Sistema_EjesXZ a ns1:Sistema ;
    rdfs:label "Sistema de ejes X-Z"@es ;
    ns1:compuestoPor ns1:DiagramaPrimeraPalpacionC0B90 ;
    ns1:textoExtracto "sistema de ejes X-Z"@es .

ns1:Sistema_EntradasCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de entradas de captación" ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosCaptacionEje ;
    ns1:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador. [...] entradas de captación locales de la unidad central." ;
