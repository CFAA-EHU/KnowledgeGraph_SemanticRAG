ns1:Operacion_Almacen_7_10_2 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de intercambio de herramientas en almacén (7.10.2)" ;
    ns1:controla ns1:Marca_CH1TOSPDL,
        ns1:Marca_CH2TOMZ,
        ns1:Marca_MZTOCH1 ;
    ns1:ejecutadoPor ns1:Pinza_1,
        ns1:Pinza_2 ;
    ns1:requiereMantenimiento ns1:Herramienta_Tierra ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2."@es ;
    ns1:tieneComponente ns1:Almacen_Herramientas .

ns1:Operacion_CambioHerramientaEntreAlmacenes_959 a ns1:ModoOperacion ;
