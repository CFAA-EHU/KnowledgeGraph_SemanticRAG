ns1:InterfazUsuario_ModoMDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:textoExtracto "La sentencia #RENAME permite renombrar los ejes y cabezales desde el programa pieza o el modo MDI/MDA." .

ns1:InterfazUsuario_ModoManual a ns1:InterfazUsuario ;
