ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "S" ;
    ns1:textoExtracto "la S"@es,
        "la que corresponde a la S"@es .

ns1:Parametro_SAI_FACTOR a ns1:Parametro ;
    rdfs:label "Factor de conversión (FACTOR)"@es ;
    ns1:documentadoEn ns1:Tabla_SAI ;
    ns1:identificador "MPG.FACTOR" ;
    ns1:textoExtracto "FACTOR Factor de conversión. Valores posibles: Entre ±999999999.999999999. Valor por defecto: 0.0061035. Variable asociada: (V.)MPG.FACTOR[n] El factor indica la resolución del convertidor A/D de la entrada analógica; es decir, representa el incremento de valor analógico por cada unidad de convertidor."@es ;
    ns1:valor "0.0061035"^^xsd:float .

ns1:Parametro_SANALOG_1062 a ns1:Parametro ;
    rdfs:label "SANALOG" ;
    ns1:identificador "SANALOG" ;
    ns1:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro."@es .

ns1:Parametro_SERCOSDATA a ns1:Parametro ;
    rdfs:label "SERCOSDATA" ;
    ns1:identificador "SERCOSDATA" ;
    ns1:textoExtracto "SERCOSDATA Datos del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." .

ns1:Parametro_SERIALNUMBER_458 a ns1:Parametro ;
    rdfs:label "SERIALNUMBER" ;
    ns1:identificador "SERIALNUMBER" ;
    ns1:textoExtracto "Número de serie del encóder." .

ns1:Parametro_SETTMEMZ1 a ns1:Parametro ;
    rdfs:label "SETTMEMZ1 (activación emergencia almacén 1)"@es ;
    ns1:identificador "SETTMEMZ1" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "SETTMEMZ1 (también se puede programar como SETTMEM) [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ns1:valor "1" .

ns1:Parametro_SETTMEMZ2 a ns1:Parametro ;
    rdfs:label "SETTMEMZ2 (activación emergencia almacén 2)"@es ;
    ns1:identificador "SETTMEMZ2" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "SETTMEMZ2 [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ns1:valor "1" .

ns1:Parametro_SETTMEMZ3 a ns1:Parametro ;
    rdfs:label "SETTMEMZ3 (activación emergencia almacén 3)"@es ;
    ns1:identificador "SETTMEMZ3" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "SETTMEMZ3 [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ns1:valor "1" .

ns1:Parametro_SETTMEMZ4 a ns1:Parametro ;
    rdfs:label "SETTMEMZ4 (activación emergencia almacén 4)"@es ;
    ns1:identificador "SETTMEMZ4" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "SETTMEMZ4 [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ns1:valor "1" .

ns1:Parametro_SFORMAT a ns1:Parametro ;
    rdfs:label "Formato de visualización de S programada (SFORMAT)" ;
    ns1:textoExtracto "Formato de visualización de la S programada. Valor por defecto: 5.1. Este parámetro establece el formato numérico (enteros y decimales) para visualizar la velocidad." ;
    ns1:valor "5.1" .

ns1:Parametro_SHARE a ns1:Parametro ;
    rdfs:label "SHARE"@es ;
    ns1:identificador "SHARE" ;
    ns1:textoExtracto "acompañado de la fórmula SHARE=100(Ar–Ao)/Ar. Visualiza cómo ajustar el porcentaje de señal que atraviesa el filtro para contrarrestar la resonancia observada."@es .

ns1:Parametro_SHORTESTWAY_SinFuncion a ns1:Parametro ;
    rdfs:label "SHORTESTWAY (Sin función para eje linearlike)" ;
    ns1:textoExtracto "SHORTESTWAY | Sin función." ;
    ns1:valor "Sin función" .

ns1:Parametro_SIZE a ns1:Parametro ;
    rdfs:label "SIZE (Número de levas electrónicas)"@es ;
    ns1:monitoreaParametro ns1:SistemaLevasElectronicas ;
    ns1:textoExtracto "SIZE Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0. Parámetro incluido en la tabla CAMTABLE. Este parámetro establece el número de levas electrónicas del sistema."@es ;
    ns1:valor "0-16" .

ns1:Parametro_SIZE_MTBPAR a ns1:Parametro ;
    rdfs:label "SIZE (Número de parámetros del fabricante)" ;
    ns1:documentadoEn ns1:TablaParametrosFabricante_MTBPAR ;
    ns1:identificador "MTB.SIZE" ;
    ns1:textoExtracto "SIZE Número de parámetros del fabricante. Valores posibles: De 0 a 1000. Valor por defecto: 0. Variable asociada: (V.)MTB.SIZE Este parámetro establece el número de parámetros de fabricante que se van a utilizar." ;
    ns1:valor "0" .

ns1:Parametro_SLAVEAXIS a ns1:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MPG.SLAVEAXIS[nb]",
        "SLAVEAXIS" ;
    ns1:textoExtracto "SLAVEAXIS Eje gantry. Eje esclavo. Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.SLAVEAXIS[nb] Parámetro incluido en la tabla GANTRY. Este parámetro establece cuál es el eje esclavo del eje gantry.",
        "Eje esclavo."@es .

ns1:Parametro_SLAVEAXIS_1061 a ns1:Parametro ;
    rdfs:label "SLAVEAXIS"@es ;
    ns1:documentadoEn ns1:Tabla_TANDEM_1061 ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "parámetro máquina [...] SLAVEAXIS, dentro de la tabla TANDEM"@es .

ns1:Parametro_SOFTLIMIT a ns1:Parametro ;
    rdfs:label "(V.)[ch].G.SOFTLIMIT" ;
    ns1:documentadoEn ns1:Tabla_LimitesSoftwareEjes ;
    ns1:textoExtracto "Límites de software alcanzados. El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo."@es .

ns1:Parametro_SPDLEREV_1062 a ns1:Parametro ;
    rdfs:label "SPDLEREV" ;
    ns1:identificador "SPDLEREV" ;
    ns1:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro."@es .

ns1:Parametro_SPDLEREV_M19 a ns1:Parametro ;
    rdfs:label "Parámetro SPDLEREV para cabezales en M19"@es ;
    ns1:identificador "(V.)[ch].MPA.M19SPDLEREV.xn" ;
    ns1:textoExtracto "Este parámetro define si la marca SPDLEREV del PLC (invertir el sentido de giro) también afecta a los cabezales en M19."@es ;
    ns1:valor "No" .

ns1:Parametro_SPDLNAME_1061 a ns1:Parametro ;
    rdfs:label "SPDLNAME"@es ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "los cabezales en el parámetro SPDLNAME"@es .

ns1:Parametro_SPDLSTOP a ns1:Parametro ;
    rdfs:label "Parámetro SPDLSTOP",
        "Parada de cabezal (SPDLSTOP)"@es ;
    ns1:identificador "(V.)[ch].MPA.SPDLSTOP.xn" ;
    ns1:textoExtracto "Las funciones M2, M30, un error o un reset paran el cabezal. [...] Este parámetro indica si el cabezal se detiene cuando se ejecuta M02, M30, se realiza un reset o se produce un error; en caso contrario se hará necesario programar la función M5.",
        "Las funciones M2, M30, un error o un reset paran el cabezal."@es ;
    ns1:valor "Sí/No" .

ns1:Parametro_SPENA_1062 a ns1:Parametro ;
    rdfs:label "SPENA(axis)"@es ;
    ns1:identificador "SPENA(axis)" ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) [...] de los cabezales maestro y esclavo simultáneamente."@es .

ns1:Parametro_SREVM05 a ns1:Parametro ;
    rdfs:label "Parámetro SREVM05" ;
    ns1:identificador "(V.)[ch].MPA.SREVM05.xn" ;
    ns1:textoExtracto "Con G84 es necesario parar el cabezal para invertir el sentido de giro. [...] Este parámetro indica si en ciclo de roscado con macho es necesario parar el cabezal (con M5) en las inversiones de sentido de giro." ;
    ns1:valor "Sí/No" .

ns1:Parametro_SSICLKFREQ a ns1:Parametro ;
    rdfs:label "SSICLKFREQ" ;
    ns1:identificador "SSICLKFREQ" ;
    ns1:textoExtracto "SSICLKFREQ = 1 / T = 400. | 400 kHz.",
        "SSICLKFREQ Frecuencia para la comunicación SSI. Valores posibles: De 59 a 7500 kHz. Valor por defecto: 150 kHz." ;
    ns1:valor "400" .

ns1:Parametro_SSICRCTYPE a ns1:Parametro ;
    rdfs:label "SSICRCTYPE",
        "SSICRCTYPE (Tipo de CRC)"@es ;
    ns1:identificador "SSICRCTYPE" ;
    ns1:textoExtracto "Tipo de cálculo a realizar cuando el encoder transmita información adicional a la cota para realizar algún tipo de comprobación de coherencia en los datos.",
        "SSICRCTYPE Tipo de CRC. Valores posibles: No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN. Valor por defecto: No calcular CRC."@es ;
    ns1:valor "No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN"@es .

ns1:Parametro_SSIOPERATION a ns1:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ns1:identificador "SSIOPERATION" ;
    ns1:textoExtracto "SSIOPERATION Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SSIOPRATION[set].xn",
        "Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1." ;
    ns1:valor "0-1" .

ns1:Parametro_SSITYPE a ns1:Parametro ;
    rdfs:label "SSITYPE" ;
    ns1:identificador "V.[ch].MPA.SSITYPE[set].xn" ;
    ns1:textoExtracto "SSITYPE Tipo de captación SSI conectada a la captación correspondiente. Valores posibles: SSITYPE Fagor / Usuario G / Usuario. Valor por defecto: Usuario." ;
    ns1:valor "Usuario"^^xsd:string .

ns1:Parametro_STORAGE a ns1:Parametro ;
    rdfs:label "STORAGE" ;
    ns1:textoExtracto "STORAGE Parámetros relacionados con el almacenamiento." .

ns1:Parametro_SWTDELAY a ns1:Parametro ;
    rdfs:label "SWTDELAY" ;
    ns1:identificador "MPG.SWTDELAY" ;
    ns1:textoExtracto "Retardo del dispositivo asociado a la conmutación sincronizada. Valores posibles: De 0 a 100 ms. Valor por defecto: 0 ms. Variable asociada: (V.)MPG.SWTDELAY" ;
    ns1:valor "0 ms" .

ns1:Parametro_SWTOUTPUT a ns1:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ns1:identificador "MPG.SWTOUTPUT" ;
    ns1:textoExtracto "La salida para el PWM y para la conmutación sincronizada puede ser la misma y se pueden usar a la vez (mismo valor en los parámetros SWTOUTPUT y PWMOUTPUT).",
        "Salida digital local asociada a la conmutación sincronizada. Valores posibles: De 0 a NLOCOUT (Número de salidas digitales locales). Valor por defecto: 0. Variable asociada: (V.)MPG.SWTOUTPUT" ;
    ns1:valor "0" .

ns1:Parametro_SYNCCANCEL a ns1:Parametro ;
    rdfs:label "SYNCCANCEL" ;
    ns1:identificador "MPG.SYNCCANCEL" ;
    ns1:textoExtracto "SYNCCANCEL Cancelar la sincronización de cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SYNCCANCEL" ;
    ns1:valor "Sí" .

ns1:Parametro_SYNCHTYPE a ns1:Parametro ;
    rdfs:label "SYNCHTYPE" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:identificador "SYNCHTYPE" ;
    ns1:textoExtracto "SYNCHTYPE Tipo de sincronización. Valores posibles: Sin sincronización / Antes-Antes / Antes-Después / Después-Después. Valor por defecto: Antes-Antes." ;
    ns1:valor "Antes-Antes" .

ns1:Parametro_SYNSPEED a ns1:Parametro ;
    rdfs:label "Parámetro SYNSPEED" ;
    ns1:identificador "SYNSPEED" ;
    ns1:textoExtracto "Si se supera el valor definido en este parámetro, la señal SYNSPEED se pone a nivel lógico bajo" .

ns1:Parametro_SYSMENUMODE a ns1:Parametro ;
    rdfs:label "SYSMENUMODE" ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Comportamiento del menú de sistema. Valores posibles: Volátil / Fijo. Valor por defecto: Volátil." ;
    ns1:valor "Volátil" .

ns1:Parametro_SZERO a ns1:Parametro ;
    rdfs:label "SZERO (Velocidad cero para cabezal)" ;
    ns1:identificador "(V.)[ch].MPA.SZERO[set].xn" ;
    ns1:textoExtracto "SZERO Velocidad que se considera cero. Parámetro válido para cabezales. [...] Este parámetro indica por debajo de qué valor se considera que el cabezal está parado." ;
    ns1:valor "0-100000 rpm" .

ns1:Parametro_SalidasDigitales_Bus a ns1:Parametro ;
    rdfs:label "Parámetro de salidas digitales (bus)"@es ;
    ns1:textoExtracto "Salidas digitales. Primera = 21 Offset = 50 Offset = 100 Offset = 100"@es ;
    ns1:valor "Primera: 21 ; Offset: 50, 100, 100"@es .

ns1:Parametro_SentidoDesplazamiento_1242 a ns1:Parametro ;
    rdfs:label "Parámetro de sentido de desplazamiento"@es ;
    ns1:textoExtracto "El parámetro se define con uno de los valores '+' y '-', para indicar el sentido de desplazamiento."@es ;
    ns1:valor "[+, -]"@es .

ns1:Parametro_SercosVelocidadCaptacion a ns1:Parametro ;
    rdfs:label "Parámetro Sercos velocidad con captación interna+externa con contajes locales"@es ;
    ns1:activaAlarma ns1:Alarma_CaptacionHardware ;
    ns1:identificador "Sercos velocidad con captación interna+externa" ;
    ns1:textoExtracto "Sercos velocidad con captación interna+externa con contajes locales. Este parámetro habilita la alarma de captación por hardware"@es .

ns1:Parametro_SetGamas a ns1:Parametro ;
