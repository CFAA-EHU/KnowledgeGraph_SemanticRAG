    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "incrementos entre puntos (INCREAX1/2/3)"@es .

ns1:Parametro_d7fa9ed427 a ns1:Parametro ;
    rdfs:label "TENDENCY" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "TENDENCY" ;
    ns1:textoExtracto "Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva. Se aconseja activarlo durante la puesta a punto de la máquina."@es .

ns1:Parametro_d82f25a7ce a ns1:Parametro ;
    rdfs:label "Función G17",
        "Función G17 (Plano X-Y)"@es,
        "Función G17 (plano X-Y)"@es ;
