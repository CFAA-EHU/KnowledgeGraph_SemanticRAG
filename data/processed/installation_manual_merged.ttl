ns1:Parametro_fedc155c04 a ns1:Parametro ;
    rdfs:label "Marca OVRCANC4" ;
    ns1:identificador "OVRCANC4" ;
    ns1:monitoreaParametro ns1:ModoOverride100 ;
    ns1:textoExtracto "OVRCANC4. Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." .

ns1:Parametro_fee78dfaa2 a ns1:Parametro ;
