ns1:TablaDeEquivalenciaCinematicaTipo50VectorialTipo7 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 (vectorial) ↔ tipo 7"@es ;
    ns1:textoExtracto """\r
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 7. |\r
| TYPE | 50 |\r
| TDATA1 | TDATA13 |\r
| TDATA2 | TDATA14 |\r
| TDATA3 | TDATA4 |\r
| TDATA4 | 0 |\r
| TDATA5 | 0 |\r
| TDATA6 | 1 |\r
| TDATA7 | TDATA8 |\r
| TDATA8 | TDATA10 |\r
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |\r
| TDATA11 | TDATA5*SIN(TDATA7) |\r
| TDATA12 | TDATA3 |\r
| TDATA13 | TDATA5*COS(TDATA7) |\r
| TDATA14 | SIN(TDATA7) |\r
| TDATA15 | 0 |\r
| TDATA16 | COS(TDATA7) |\r
| TDATA17 | TDATA9 |\r
| TDATA18 | TDATA11 |\r
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |\r
| TDATA21 | 0 |\r
| TDATA22 | TDATA6 |\r
| TDATA23 | TDATA1 |\r
| TDATA24 | 0 |\r
| TDATA25 | 0 |\r
| TDATA26 | 1 |\r
"""@es .

