    ns1:requiereMantenimiento ns1:AlmacenHerramientas ;
    ns1:textoExtracto "%L SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén. M110 ; Función auxiliar para ejecutar acción."@es,
        "LL SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén."@es .

ns1:Subrutina_SUB_ARM_TO_MZ a ns1:TareaMantenimiento ;
    rdfs:label "SUB_ARM_TO_MZ"@es ;
    ns1:identificador "SUB_ARM_TO_MZ" ;
    ns1:textoExtracto "%L SUB_ARM_TO_MZ ; Llevar el brazo cambiador al almacén."@es .

ns1:Subrutina_SUB_MZ_ROT a ns1:TareaMantenimiento ;
    rdfs:label "SUB_MZ_ROT (Orientación de torreta)"@es ;
    ns1:textoExtracto "LL SUB_MZ_ROT ; Orientar la torreta."@es .

ns1:Subrutina_SUB_MZ_TO_CH1 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_MZ_TO_CH1" ;
    ns1:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ns1:Subrutina_SUB_MZ_TO_SPD a ns1:ModoOperacion,
        ns1:TareaMantenimiento ;
    rdfs:label "SUB_MZ_TO_SPD (Traslado de almacén a cabezal)"@es,
        "SUB_MZ_TO_SPD: Transferir herramienta del almacén al cabezal"@es ;
    ns1:ejecutadoPor ns1:SistemaCambioHerramientas ;
    ns1:textoExtracto "LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal."@es,
        "LL SUB_MZ_TO_SPD ; [Asumir herramienta activa o poner herramienta del almacén en el cabezal]."@es .

ns1:Subrutina_Sub_Probe_Tool_Begin_fst a ns1:Componente ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Al iniciar la ejecución, el ciclo primero ejecuta la subrutina Sub_Probe_Tool_Begin.fst",
        "Fagor suministra la subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1",
        "subrutina asociada al inicio del ciclo de calibración de herramienta" .

ns1:Subrutina_Sub_Probe_Tool_End_fst a ns1:Componente ;
