ns1:EntradaDeRosca a ns1:Parametro ;
    rdfs:label "Entrada de rosca"@es ;
    ns1:textoExtracto "el CNC respeta [...] la entrada de la rosca"@es .

ns1:EntradaDelPIDelEjeMaestroDelTandemTPIIN a ns1:Parametro ;
