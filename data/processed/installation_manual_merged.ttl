ns1:OpenPCS_AccesoSettings a ns1:Componente ;
    rdfs:label "Acceso a Settings"@es ;
    ns1:textoExtracto "Se destaca el acceso a \"Settings\""@es .

ns1:OperacionOrientarDosAlmacenes a ns1:TareaMantenimiento ;
    rdfs:label "Orientar dos almacenes (TMOPERATION=13)"@es ;
    ns1:controla ns1:MarcaMZROT ;
    ns1:identificador "TMOPERATION=13" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado. Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no."@es .

ns1:OperacionTM1 a ns1:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén y ponerla en cabezal (TMOPERATION=1)",
        "Coger herramienta del almacén y ponerla en el cabezal",
        "Coger herramienta del brazo y ponerla en el cabezal (TMOPERATION=1)" ;
    ns1:controla ns1:MarcaCH1TOSPDL,
        ns1:MarcaMZTOCH1 ;
    ns1:ejecutadoPor ns1:Pinza1 ;
    ns1:identificador "TMOPERATION=1" ;
    ns1:requiereMantenimiento ns1:Pinza1 ;
    ns1:textoExtracto "TMOPERATION = 1 Coger una herramienta del almacén y ponerla en el cabezal.",
        "TMOPERATION = 1 Coger una herramienta del almacén y ponerla en el cabezal. TAKEPOS=# Posición del almacén para coger la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL.",
        "TMOPERATION = 1 Coger una herramienta del brazo y ponerla en el cabezal. TAKEPOS=-1 Herramienta en el brazo cambiador. La secuencia de esta operación es la siguiente. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1. 1 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:OperacionTM2 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en el almacén",
        "Dejar herramienta del cabezal en el almacén (TMOPERATION=2)" ;
    ns1:controla ns1:MarcaCH1TOMZ,
        ns1:MarcaCH2TOMZ,
        ns1:MarcaSPDLTOCH1,
        ns1:MarcaSPDLTOCH2 ;
    ns1:ejecutadoPor ns1:Pinza1,
        ns1:Pinza2 ;
    ns1:identificador "TMOPERATION=2" ;
    ns1:requiereMantenimiento ns1:Pinza2 ;
    ns1:textoExtracto "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén.",
        "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1. 2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ.",
        "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. 3 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK, si se desea, para que continúe la ejecución del programa. 4 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:OperacionTM3 a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en el cabezal",
        "Poner herramienta de tierra en el cabezal (TMOPERATION=3)",
        "Poner en el cabezal una herramienta de tierra (TMOPERATION=3)"@es ;
    ns1:activaAlarma ns1:MarcaGRTOSPDL ;
    ns1:controla ns1:MarcaGRTOSPDL ;
    ns1:identificador "TMOPERATION=3" ;
    ns1:textoExtracto "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra.",
        "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca GRTOSPDL.",
        "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca GRTOSPDL."@es .

ns1:OperacionTM4 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en tierra",
        "Dejar herramienta del cabezal en tierra (TMOPERATION=4)",
        "Dejar la herramienta del cabezal en tierra (TMOPERATION=4)"@es ;
    ns1:activaAlarma ns1:MarcaSPDLTOGR ;
    ns1:controla ns1:MarcaSPDLTOGR ;
    ns1:identificador "TMOPERATION=4" ;
    ns1:textoExtracto "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra.",
        "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca SPDLTOGR.",
        "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca SPDLTOGR."@es .

ns1:OperacionTM5 a ns1:TareaMantenimiento ;
    rdfs:label "Intercambiar herramienta entre cabezal y almacén",
        "Intercambiar herramienta entre cabezal y almacén (TMOPERATION=5)",
        "Intercambio herramienta cabezal-almacén-brazo (TMOPERATION=5)" ;
    ns1:controla ns1:MarcaCH1TOMZ,
        ns1:MarcaCH2TOMZ,
        ns1:MarcaMZTOCH1,
        ns1:MarcaSPDLTOCH1,
        ns1:MarcaSPDLTOCH2 ;
    ns1:ejecutadoPor ns1:Pinza1 ;
    ns1:identificador "TMOPERATION=5" ;
    ns1:requiereMantenimiento ns1:Pinza1,
        ns1:Pinza2 ;
    ns1:textoExtracto "TMOPERATION = 5 Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son del mismo almacén. TAKEPOS=-1 Herramienta en el brazo cambiador. LEAVEPOS=# Posición del almacén para dejar la herramienta. En esta operación, el gestor admite dos secuencias.",
        "TMOPERATION = 5 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén.",
        "TMOPERATION = 5 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1. 2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ. 3 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:Operacion_CambioHerramienta_CabezalATierra a ns1:ModoOperacion ;
    rdfs:label "Cambio de herramienta (cabezal → tierra)" ;
    ns1:identificador "TMOPERATION_4" ;
    ns1:textoExtracto "TMOPERATION=4. El PLC ha llevado la herramienta desde el cabezal a tierra" .

ns1:Operacion_CambioHerramienta_TierraACabezal a ns1:ModoOperacion ;
    rdfs:label "Cambio de herramienta (tierra → cabezal)" ;
    ns1:identificador "TMOPERATION_3" ;
    ns1:textoExtracto "TMOPERATION=3. El PLC ha llevado la herramienta desde tierra al cabezal" .

ns1:OperadorLogico_AND a ns1:Componente,
        ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Operador AND",
        "Operador AND"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "AND Función lógica \"Y\". I4 AND I5 = O6 La salida O6 estará activa cuando ambas entradas (I4, I5) estén activas.",
        "AND Función lógica \"Y\"."@es .

ns1:OperadorLogico_NOT a ns1:Componente,
        ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Operador NOT",
        "Operador NOT"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "NOT Invierte el resultado de la consulta. NOT I2 = O3 La salida O3 estará activa cuando no lo esté la entrada I2.",
        "NOT Invierte el resultado de la consulta."@es .

ns1:OperadorLogico_OR a ns1:Componente,
        ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Operador OR",
        "Operador OR"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "OR Función lógica \"O\". I7 OR I8 = O9 La salida O9 estará activa cuando una de las entradas (o ambas) estén activas.",
        "OR Función lógica \"O\"."@es .

ns1:OperadorLogico_XOR a ns1:Componente,
        ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Operador XOR",
        "Operador XOR"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "XOR Función lógica \"O Exclusivo\". I10 XOR I11 = O12 La salida O12 estará activa cuando las entradas I10 y I11 tengan niveles lógicos distintos.",
        "XOR Función lógica \"O Exclusivo\"."@es .

ns1:Operando_Registro_R14 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R14"@es ;
    ns1:identificador "R14" ;
    ns1:textoExtracto "CPS C12 GT R14 = M100 [...] el valor del registro R14"@es .

ns1:Operando_Temporizador_C12 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador C12"@es ;
    ns1:identificador "C12" ;
    ns1:textoExtracto "CPS C12 GT R14 = M100 [...] Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14"@es .

ns1:Operando_Temporizador_T2 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T2"@es ;
    ns1:identificador "T2" ;
    ns1:textoExtracto "CPS T2 EQ 100 = TG1 5 2000 [...] Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100"@es .

ns1:Operando_Temporizador_T5 a ns1:ComponenteElectrico ;
