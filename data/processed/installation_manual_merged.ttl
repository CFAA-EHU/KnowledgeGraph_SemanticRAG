    ns1:textoExtracto "RETRACE [...] Si el PLC quita automáticamente la marca RETRACE con la marca RETRAEND, el CNC continua con la ejecución normal del programa." ;
    ns1:valor "0 (inactivo), 1 (retrace activo)" .

ns1:RETRAEND a ns1:Parametro ;
