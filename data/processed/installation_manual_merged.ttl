        "Número de ejes/cabezales por grupo" .

ns1:Parametro_MULNGROUP a ns1:Parametro ;
    rdfs:label "MULNGROUP" ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:textoExtracto "MULNGROUP Número de grupos multieje en el sistema. Valores posibles: De 0 a 16. Valor por defecto: 0.",
        "Número de grupos multieje en el sistema." ;
    ns1:valor "0-16"^^xsd:string,
        "Número de grupos multieje" .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "NAXIS" ;
    ns1:identificador "NAXIS" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "NAXIS Número de ejes que gobierna el CNC. Valores posibles: De 1 a 32. Valor por defecto: 3.",
        "Número de ejes del sistema.",
        "el número de ejes asignados al canal no puede ser mayor que el número de ejes del sistema, definido en el parámetro NAXIS." ;
    ns1:valor 3 .

ns1:Parametro_NDOMOD a ns1:Parametro ;
    rdfs:label "NDOMOD" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1267,
        ns1:Tabla_ParametrosDOMOD ;
    ns1:identificador "(V.)MPG.NDOMOD",
        "MPG.NDOMOD",
        "NDOMOD" ;
    ns1:textoExtracto "NDOMOD Número de bloques lógicos de salidas digitales. Valores posibles: De 0 a 42. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDOMOD Este parámetro indica la cantidad de bloques lógicos en los que se dividen los módulos de salidas digitales conectados en el bus CANopen.",
        "NDOMOD Número total de módulos de salidas digitales. Valores posibles: De 0 a 64. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDOMOD Este parámetro indica la cantidad de módulos de salidas digitales conectados en el bus CAN.",
        "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico.",
        "Número de bloques lógicos de salidas digitales. Valores posibles: De 0 a 42 (por defecto; 0)."@es ;
    ns1:valor 0,
        "0",
        "0..42",
        "2" .

ns1:Parametro_NKEYBD a ns1:Parametro ;
    rdfs:label "NKEYBD",
        "NKEYBD"@es,
        "NKEYBD (Número de paneles de jog)"@es,
        "Parámetro NKEYBD"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosJog ;
    ns1:identificador "NKEYBD",
        "V.MPG.NKEYBD" ;
    ns1:textoExtracto "NKEYBD Número de paneles de jog. Valores posibles: De 1 a 8. Valor por defecto: 1.",
        "El parámetro NKEYBD establece el número de paneles de jog del sistema."@es,
        "NKEYBD | 2 | Número de paneles de jog"@es,
        "el CNC define el parámetro NKEYBD con valor 1 (valor por defecto) y sólo habilita el primer teclado"@es ;
    ns1:valor "1",
        "1-8",
        "2",
        "Número de paneles de jog"@es .

ns1:Parametro_NRETBLK a ns1:Parametro ;
    rdfs:label "NRETBLK",
        "Parámetro NRETBLK" ;
    ns1:identificador "NRETBLK" ;
    ns1:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK.",
        "NRETBLK Máximo número de bloques permitidos para la función retrace. Valores posibles: De 0 a 300. Valor por defecto: 75. Variable asociada: (V.)[ch].MPG.NRETBLK Este parámetro establece el máximo número de bloques que se pueden retroceder con la función retrace." ;
    ns1:valor "75" .

ns1:Parametro_NSPDL a ns1:Parametro ;
    rdfs:label "NSPDL" ;
    ns1:identificador "MPG.NSPDL",
        "NSPDL" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "NSPDL Número de cabezales que gobierna el CNC. Valores posibles: De 0 a 6. Valor por defecto: 1.",
        "Número de cabezales del sistema.",
        "la suma de ejes y cabezales será como máximo 32. Por ejemplo, un sistema con 6 cabezales podrá tener 26 ejes (NSPDL=6 NAXIS=26).",
        "número de cabezales del sistema, definido en el parámetro NSPDL" ;
    ns1:valor 0,
        "1" .

ns1:Parametro_OVRMAX a ns1:Parametro ;
    rdfs:label "OVRMAX (Máximo override permitido)",
        "Parámetro OVRMAX (override máximo en DMC)" ;
    ns1:textoExtracto "OVRMAX{%} Máximo override permitido para el DMC. • Valores: 100 — 255 %.",
        "OVRMIN debe ser menor que OVRMAX. [...] override máximo" ;
