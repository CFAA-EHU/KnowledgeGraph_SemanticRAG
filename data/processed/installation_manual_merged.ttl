    ns1:textoExtracto "CLK100 | 100 ms" ;
    ns1:valor "100 ms"^^xsd:string .

ns1:Parametro_3fb4e1150e a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED2 (avance post-referencia)"@es ;
    ns1:identificador "V.[ch].MPA.REFFEED2[set].xn" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "invierte el sentido a REFFEED2 y, tras despulsar el micro, continúa al avance indicado en REFFEED2"@es ;
    ns1:valor "100.0000" .

ns1:Parametro_3ff35644cc a ns1:Parametro ;
    rdfs:label "Marca RESETINC2" ;
    ns1:identificador "RESETINC2" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC2. Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Parametro_4030689cfa a ns1:Parametro ;
    rdfs:label "GROUND" ;
    ns1:identificador "GROUND" ;
    ns1:textoExtracto "GROUND Se permiten herramientas de tierra (carga manual). Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZGROUND[mz] Se denominan herramientas de tierra a las que no están situadas en el almacén." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_405f12387a a ns1:Parametro ;
    rdfs:label "Parámetro I3" ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "IMA I3" .

ns1:Parametro_42f62ceec2 a ns1:Parametro ;
    rdfs:label "MAXDIFREF" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_MAXDIFREF ;
    ns1:textoExtracto "MAXDIFREF Máxima diferencia de posición permitida para considerar que no es necesario volver a referenciar. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0.0200 mm / 0.00079 inch / 0.0200 grados" .

ns1:Parametro_432986f5c7 a ns1:Parametro ;
    rdfs:label "Marca RESETINC1 (RESETIN)" ;
    ns1:identificador "RESETINC1" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC1 (también se puede programar como RESETIN). Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Parametro_433acbcd7e a ns1:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ns1:monitoreaParametro ns1:Tabla_OperacionesPLC ;
    ns1:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es .

ns1:Parametro_437612742f a ns1:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ns1:identificador "(V.)[ch].MPG.SURFFILTFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." ;
    ns1:valor "25" .

ns1:Parametro_43e5cb97c2 a ns1:Parametro ;
    rdfs:label "SPDLTOCH1" ;
    ns1:textoExtracto "activar la marca SPDLTOCH1" .

ns1:Parametro_44ca52156e a ns1:Parametro ;
    rdfs:label "TDATA19" ;
    ns1:documentadoEn ns1:Tabla_Cinematica_2_9_12 ;
    ns1:textoExtracto "TDATA19 | 0, si TDATA12=0 o TDATA12=1 | 1, si TDATA12=2 o TDATA12=3."@es .

ns1:Parametro_45298a5d87 a ns1:Parametro ;
    rdfs:label "TAPPINGC1" ;
    ns1:identificador "TAPPINGC1" ;
    ns1:monitoreaParametro ns1:CicloFijoRoscadoMacho ;
    ns1:textoExtracto "TAPPINGC1 (también se puede programar como TAPPING) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho." .

ns1:Parametro_45537d370a a ns1:Parametro ;
    rdfs:label "SYSHMENU" ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:identificador "SYSHMENU" ;
    ns1:textoExtracto "Consultar el parámetro SYSHMENU. SYSVMENU Menú de sistema vertical."@es ;
    ns1:valor "Deshabilitado"^^xsd:string .

ns1:Parametro_45e35579a5 a ns1:Parametro ;
    rdfs:label "TDATA12" ;
    ns1:documentadoEn ns1:Tabla_Cinematica_2_9_12 ;
    ns1:textoExtracto "TDATA12 | TDATA6*SIN(TDATA7)"@es .

ns1:Parametro_4686984fa5 a ns1:Parametro ;
    rdfs:label "Parámetro MPA.MANACCP (porcentaje aceleración manual)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "MPA.MANACCP" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20. Variable asociada: (V.)[ch].MPA.MANACCP.xn" ;
    ns1:valor "20" .

ns1:Parametro_46f346a70c a ns1:Parametro ;
    rdfs:label "Parámetro CHAXISNAME 3" ;
