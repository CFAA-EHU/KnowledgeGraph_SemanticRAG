ns1:Parametro_TDATA51 a ns1:Parametro ;
    rdfs:label "TDATA51",
        "Configuración RTCP (TDATA51)"@es,
        "Parámetro TDATA51"@es,
        "TDATA51 (Rotación de sistema de coordenadas pieza)"@es ;
    ns1:documentadoEn ns1:Manual_OpenPCS_SeccionParametrosMaquina,
        ns1:Tabla_RedefinicionCinematicas_TDATA51 ;
    ns1:identificador "TDATA51" ;
    ns1:monitoreaParametro ns1:ModoOperacion_RTCP ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella. / Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina.",
        "TDATA51 = 0 / TDATA51 = 1",
        "TDATA51 | A elegir.",
        "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1."@es,
        "TDATA51"@es,
        "TDATA51 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ns1:valor "0",
        "0, 1",
        "0/1",
        "A elegir" .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "MPG.TPROGAIN[nb]",
