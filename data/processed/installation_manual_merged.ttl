    ns1:detalladoEnEsquema ns1:ComunicacionGestorPLC_869 ;
    ns1:textoExtracto "Ver '7.3 Comunicación entre el gestor y el PLC.' en la página 472."@es .

ns1:Manual_ConfiguracionPalpador a ns1:Manual ;
    ns1:textoExtracto "El PLC considera entradas lógicas a aquellas entradas que no existen como físicas; por ejemplo, si en los módulos remotos están numeradas las entradas 1 a 256, el PLC considera entradas lógicas de la 257 a la 1024. Dos palpadores remotos no podrán estar conectados al mismo módulo si van estar implicados en procesos de palpado simultáneos."@es .

ns1:Manual_Fagor a ns1:Manual ;
    rdfs:label "Manual de subrutinas Fagor" ;
    ns1:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM." .

ns1:Manual_OPENPCS_15_4 a ns1:Manual ;
    rdfs:label "Sección 15.4: Módulo remoto RCS-S" ;
    ns1:textoExtracto "Sección: 15.4 Módulo remoto RCS-S." .

ns1:Manual_ReguladorSercos a ns1:Manual ;
    rdfs:label "Manual del regulador Sercos"@es ;
    ns1:textoExtracto "Consultar el manual del regulador para obtener más información."@es .

ns1:Manual_Subrutinas a ns1:Manual ;
