ns1:PotenciaEnVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío"@es ;
    ns1:textoExtracto "20 % de la potencia en vacío"@es .

ns1:PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo"@es ;
    ns1:monitoreaParametro ns1:ModoOperacion_fc3dfb09a6 ;
    ns1:textoExtracto "La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío"@es ;
    ns1:valor ">=20% de potencia en vacío"@es .

ns1:PotenciaObjetivoAprendidaLEARNEDPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo aprendida (LEARNEDPWRSP)"@es ;
    ns1:documentadoEn ns1:TablaDeResumenDeVariablesDMCPaginas725726 ;
    ns1:identificador "[ch].G.LEARNEDPWRSP" ;
    ns1:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje de potencia nominal" .

ns1:PotenciaObjetivoDMCDMCPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo DMC (DMCPWRSP)"@es ;
    ns1:documentadoEn ns1:TablaDeResumenDeVariablesDMCPaginas725726 ;
    ns1:identificador "[ch].G.DMCPWRSP" ;
    ns1:textoExtracto "Potencia objetivo, definida como porcentaje de la potencia nominal del cabezal. Valor programado en el comando PWRSP de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje de potencia nominal" .

ns1:PotenciaObjetivoDMC_b9c5c7495f a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)"@es ;
    ns1:textoExtracto "revisar el valor de la potencia objetivo. [...] Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza."@es ;
    ns1:valor "20%"^^xsd:string .

ns1:PotenciaObjetivoDMC_c7edbab5db a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)" ;
    ns1:textoExtracto "calcula la potencia objetivo ('potencia consumida' – 'potencia en vacío')." ;
    ns1:valor "potencia consumida – potencia en vacío" .

ns1:PotenciaObjetivoPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo (PWRSP)" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "comando PWRSP" .

ns1:PotenciaObjetivo_DMC a ns1:Parametro ;
    rdfs:label "Potencia objetivo del DMC"@es ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "potencia objetivo obtenida en la fase de aprendizaje [...] la potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío"@es ;
    ns1:valor ">=20% de la potencia en vacío"@es .

ns1:PotenciaVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío" ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada o está midiendo la potencia en vacío, el DMC se desactiva cuando acabe de medir la potencia en vacío." .

ns1:PowerSetPointPotenciaObjetivoAprendida a ns1:Parametro ;
