ns1:Marca_PLCCNTL a ns1:Parametro ;
    rdfs:label "PLCCNTL (control PLC)"@es ;
    ns1:monitoreaParametro ns1:SistemaControlCabezales ;
    ns1:textoExtracto "activa la marca PLCCNTL para indicar que el cabezal está controlado por el PLC [...] poner PLCCNTL a (=0)"@es .

ns1:Marca_PLC_TCHANGEOK a ns1:AvisoSeguridad ;
    rdfs:label "Marca TCHANGEOK"@es ;
    ns1:documentadoEn ns1:Tabla_ValoresTAKEPOS_LEAVEPOS ;
    ns1:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es .

ns1:Marca_REFPOIN_axis a ns1:Parametro ;
    rdfs:label "REFPOIN(axis)" ;
    ns1:textoExtracto "La marca REFPOIN(axis) siempre está activa (=1). No es necesaria la búsqueda de referencia. Captación absoluta en una vuelta."@es ;
    ns1:valor "1" .

ns1:Marca_RESETOUT a ns1:Componente ;
    rdfs:label "Marca RESETOUT (canal genérico)" ;
    ns1:identificador "RESETOUT" ;
    ns1:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:Marca_RESETOUTC1 a ns1:Componente,
        ns1:ComponenteElectrico ;
    rdfs:label "Marca RESETOUT Canal 1",
        "Marca RESETOUTC1" ;
    ns1:identificador "RESETOUTC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)",
        "RESETOUTC1 (también se puede programar como RESETOUT)" .

ns1:Marca_RESETOUTC2 a ns1:Componente ;
    rdfs:label "Marca RESETOUT Canal 2" ;
    ns1:identificador "RESETOUTC2" ;
    ns1:textoExtracto "RESETOUTC2" .

ns1:Marca_RESETOUTC3 a ns1:Componente ;
    rdfs:label "Marca RESETOUT Canal 3" ;
    ns1:identificador "RESETOUTC3" ;
    ns1:textoExtracto "RESETOUTC3" .

ns1:Marca_RESETOUTC4 a ns1:Componente ;
    rdfs:label "Marca RESETOUT Canal 4" ;
    ns1:identificador "RESETOUTC4" ;
    ns1:textoExtracto "RESETOUTC4" .

ns1:Marca_SPDLEREV a ns1:Parametro ;
    rdfs:label "SPDLEREV (inversión giro cabezal)"@es ;
    ns1:monitoreaParametro ns1:SistemaControlCabezales ;
    ns1:textoExtracto "Cuando el PLC pone esta marca a (=1), el CNC invierte el sentido de giro del cabezal"@es .

ns1:Marca_SPDLTOCH1 a ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "SPDLTOCH1",
        "Marca SPDLTOCH1"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor_732 ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "SPDLTOCH1 (Almacén 1-4: SPDLTOCH1MZ1, SPDLTOCH1MZ2, SPDLTOCH1MZ3, SPDLTOCH1MZ4)"@es,
        "Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1."@es,
        "activar la marca SPDLTOCH1"@es ;
    ns1:valor "1" .

ns1:Marca_SPDLTOCH2_958 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SPDLTOCH2"@es ;
    ns1:documentadoEn ns1:SistemaMarcas_958 ;
    ns1:textoExtracto "activar la marca SPDLTOCH2"@es .

ns1:Marca_SPDLTOMZ a ns1:Parametro ;
    rdfs:label "Marca SPDLTOMZ",
        "SPDLTOMZ" ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor ;
    ns1:identificador "SPDLTOMZ" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal al almacén.",
        "SPDLTOMZ (Almacén 1-4: SPDLTOMZ1, SPDLTOMZ2, SPDLTOMZ3, SPDLTOMZ4)"@es,
        "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén."@es ;
    ns1:valor "1" .

ns1:Marca_SSTROBE_802 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SSTROBE" ;
    ns1:identificador "SSTROBE" ;
    ns1:textoExtracto "El canal del CNC [...] activa la marca MSTROBE o SSTROBE para que comience la ejecución."@es .

ns1:Marca_STOP a ns1:Componente ;
    rdfs:label "Marca _STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "Si el PLC ha puesto la marca \"_STOP\" a (=0), para reanudar la ejecución el PLC debe poner las marcas \"_STOP\" y \"CYSTART\" a (=1)." .

ns1:Marca_SWITCH_11_4 a ns1:Parametro ;
    rdfs:label "SWITCH (señal de selección de eje)" ;
    ns1:identificador "SWITCH" ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:Marca_TIMERON_802 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TIMERON" ;
    ns1:identificador "TIMERON" ;
    ns1:textoExtracto "El CNC dispone de un contador de tiempo de libre disposición. [...] Su cuenta está en segundos y se habilita y deshabilita con esta marca. Estará habilitado (contando) con TIMERON a (=1)."@es .

ns1:Marca_TMOPSTROBEC1 a ns1:Parametro ;
