ns1:Esquema_SegundaPalpacion_TDATA1 a ns1:Esquema ;
    rdfs:label "Diagrama 'Segunda palpación' para TDATA1"@es ;
    ns1:ilustradoEn ns1:Parametro_6b82dfa908 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, repetición sobre misma cara con lectura ΔZ; se remarca el cambio de orientación del cabezal respecto al centro de giro ②."@es .

ns1:Esquema_SegundaPalpacion_TDATA5 a ns1:Esquema ;
    rdfs:label "Diagrama 'Segunda palpación' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_95137c6bdd ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, contacto sobre misma cara con lectura ΔX, resaltando el giro alrededor de 2 y el desplazamiento resultante."@es .

ns1:Esquema_SentidoGiroUnico_UNIDIR a ns1:Esquema ;
