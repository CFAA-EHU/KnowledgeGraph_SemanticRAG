    rdfs:label "..\\USERS",
        "USERS" ;
    ns1:textoExtracto "Los programas pieza deben guardarse en la carpeta ..\\USERS;" .

ns1:CarpetaUsers a ns1:ElementoSeguridad,
        ns1:Sistema ;
    rdfs:label "Carpeta USERS",
        "Carpeta Users" ;
    ns1:textoExtracto "El programa SetupHelp_Vxx.xx.exe instala la ayuda en la carpeta ..\\Users\\Help." ;
    ns1:tieneComponente ns1:CarpetaHelp,
        ns1:CarpetaPocket,
        ns1:CarpetaPrg,
        ns1:CarpetaProfile,
        ns1:CarpetaReports,
        ns1:CarpetaSub .

ns1:CarpetaUsuario a ns1:Componente ;
