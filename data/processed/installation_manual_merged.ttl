ns1:Se_alConsultaEjesCNC a ns1:InterfazUsuario ;
    rdfs:label "Señales de consulta de ejes y cabezales (CNC)" ;
    ns1:identificador "6.2" ;
    ns1:textoExtracto "El CNC pone esta marca a (=0) para indicar que se está trabajando con la captación interna (captación motor). [...] TANGACT(axis) El CNC pone esta marca a (=1) para indicar que el control tangencial se encuentra activo en el eje. [...] LOPEN(axis) El CNC activa esta marca para indicar al PLC que" .

ns1:Se_alPARKEDB a ns1:Parametro ;
    rdfs:label "Señal PARKEDB",
        "Señal PARKEDB (estado de aparcado del eje B)" ;
    ns1:identificador "PARKEDB" ;
    ns1:textoExtracto "SET PARKEDB [...] RES PARKEDB",
        "el eje está desaparcado (RES PARKEDB). [...] La maniobra de aparcar/desaparcar ejes gestionada desde el programa de PLC se controla mediante la señal PARKED." ;
    ns1:valor "PARKEDB",
        "RES PARKEDB" .

ns1:Se_al_CYSTART a ns1:ComponenteElectrico,
        ns1:InterfazUsuario ;
    rdfs:label "Señal CYSTART",
        "Señal CYSTART (inicio de ejecución)"@es ;
    ns1:identificador "CYSTART" ;
    ns1:textoExtracto "Las señales _EMERGEN, _STOP, _FEEDHOL, _XFERINH y CYSTART deben estar definidas en el programa de PLC. [...] el PLC debe activar la marca CYSTART.",
        "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. CYSTARTC1 (también se puede programar como CYSTART) [...] el PLC debe activar la marca CYSTART para que comience la ejecución del programa."@es .

ns1:Seccion6_11_SenalesLogicasModificablesLaser a ns1:Capitulo ;
    rdfs:label "Señales lógicas modificables; láser"@es ;
    ns1:documentadoEn ns1:Pagina455_456 ;
    ns1:textoExtracto "Señales lógicas modificables; láser. [...] Por ejemplo, el corte de chapas más largas que el recorrido de la mesa, en un único programa, se realiza en varias etapas [...] Al final de cada etapa, hay que refrescar el Cut_View para que muestre la nueva sección a cortar."@es .

