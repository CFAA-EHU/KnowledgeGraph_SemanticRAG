ns1:CarpetaBACKUPSDIR a ns1:Componente ;
    rdfs:label "BACKUPSDIR" ;
    ns1:textoExtracto "Backup de las instalaciones previas. Cada vez que el usuario instala una versión nueva completa, el instalador guarda en esta carpeta una copia de la instalación anterior." .

ns1:CarpetaCONFIGURATION a ns1:Componente ;
    rdfs:label "CONFIGURATION" ;
    ns1:textoExtracto "Esta carpeta contiene las diferentes carpetas MTB del sistema; MTB_T para el torno y MTB_M para fresadora. En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente de CONFIGURATION a MTB." .

ns1:CarpetaDIAGNOSIS a ns1:Componente ;
