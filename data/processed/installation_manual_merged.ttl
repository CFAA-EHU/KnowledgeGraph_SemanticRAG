ns1:InicializacionInmediata a ns1:Parametro ;
    rdfs:label "Inicialización inmediata" ;
    ns1:textoExtracto "Diagrama del efecto de TRS en modo monoestable: un flanco de subida en TRS, tanto durante como después de la temporización, provoca la inicialización inmediata (T=0 y t=0), quedando el temporizador a la espera de nueva activación por TG1." .

ns1:InicializadorDelTemporizador a ns1:Parametro ;
    rdfs:label "Inicializador del temporizador" ;
    ns1:textoExtracto "un flanco de subida en TRS inicializa el temporizador (T=0, t=0) y exige una nueva activación por TG3 para reiniciar la secuencia." .

ns1:InspeccionDeHerramienta_8468e95cdb a ns1:AccionProhibida ;
