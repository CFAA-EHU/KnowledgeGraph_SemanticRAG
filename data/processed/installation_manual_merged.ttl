ns1:Subrutina_Probe_Tool_Begin a ns1:InterfazUsuario,
        ns1:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:controla ns1:Sonda_Probe1 ;
    ns1:documentadoEn ns1:Pagina_637_EjecucionSubrutinasRAM ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es Sub_Probe_Tool_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC.",
        "Ejemplo de subrutina Sub_Probe_Tool_Begin.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ; Activate PROBE1 Hardware by PLC output. ; Check PROBE is READY with PLC Input from Probe Hardware. # MSG[\"WAIT FOR ENABLING PROBE1\"] #WAIT FOR[V.PLC.PROBE1ENA==1] ; Select PROBE1 input for using in Probing. # SELECT PROBE[1] #FLUSH $IF [V.G.PRBST1==1] #WARNING[\"PROBE1 SIGNAL TOUCHING\"] M0 $ENDIF ; Check probe in safe mode feature is actived. $IF [V.PLC.PROBE1MONIT==0] #MSG[\"PROBE NOT IN SAFE MODE\"] $ENDIF #RETDSBLK"@en .

ns1:Subrutina_Probe_Tool_End a ns1:InterfazUsuario,
        ns1:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ns1:controla ns1:Sonda_Probe1 ;
    ns1:documentadoEn ns1:Pagina_637_EjecucionSubrutinasRAM ;
    ns1:identificador "Sub_Probe_Tool_End.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es [...] Sub_Probe_Tool_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub.",
        "Ejemplo de subrutina Sub_Probe_Tool_End.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ;Deactivate PROBE1 Hardware by PLC output #RETDSBLK"@en .

ns1:Subrutina_REFPSUB_G74 a ns1:Parametro ;
    rdfs:label "REFPSUB (G74)"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFabricante ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "REFPSUB (G74) Subrutina asociada a la función G74. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.REFPSUB La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas. Indicando los ejes y el orden en que se efectúa la búsqueda o programando sólo G74 (sin ejes)."@es ;
    ns1:valor "Cualquier texto de hasta 64 caracteres"@es .

ns1:Subrutina_Sub_Probe_Piece_Begin_fst a ns1:Componente ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ns1:identificador "Sub_Probe_Piece_Begin.fst" ;
    ns1:textoExtracto "subrutina asociada a la entrada de palpador 2" .

ns1:Subrutina_Sub_Probe_Tool_Begin a ns1:Componente,
        ns1:Sistema ;
    rdfs:label "Sub_Probe_Tool_Begin.fst",
        "Subrutina Sub_Probe_Tool_Begin.fst",
        "Subrutina Sub_Probe_Tool_Begin.fst"@es ;
    ns1:controla ns1:MarcasPROBE1MONIT_PROBE2MONIT ;
    ns1:documentadoEn ns1:Manual_CicloMedicion ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:requiereMantenimiento ns1:Sistema_Palpador ;
    ns1:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst",
        "Fagor suministra la subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1",
        "Se recomienda que OEM gestione ambas marcas desde la subrutina Sub_Probe_Tool_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro."@es .

ns1:Subrutina_TOOLSUB a ns1:Parametro ;
    rdfs:label "TOOLSUB"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFabricante ;
    ns1:identificador "TOOLSUB" ;
    ns1:textoExtracto "TOOLSUB Subrutina asociada a la función T. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.TOOLSUB Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)."@es ;
    ns1:valor "Cualquier texto de hasta 64 caracteres"@es .

ns1:SubrutinasCNC_1178 a ns1:Sistema ;
    rdfs:label "Sistema de subrutinas del CNC"@es ;
    ns1:textoExtracto "El CNC dispone de una serie de subrutinas que, en función de la configuración de la máquina, deben estar definidas (subrutina asociada al cambio de herramienta, a la búsqueda de referencia, etc)."@es .

ns1:SubrutinasInterrupcion_1213 a ns1:Sistema ;
