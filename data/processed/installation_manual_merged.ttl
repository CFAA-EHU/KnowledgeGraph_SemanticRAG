ns1:Filtro_Notch_Antirresonante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro notch (banda eliminada) para frecuencias de resonancia"@es ;
    ns1:controla ns1:SistemaCoordenadas_Torno ;
    ns1:identificador "Notch" ;
    ns1:textoExtracto "Curva de magnitud con una hendidura estrecha entre f1 y f2 que suprime la frecuencia de resonancia dentro de la banda pasante. Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ns1:Filtro_PasoBajo a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo para resonancias"@es ;
    ns1:controla ns1:SistemaCoordenadas_Torno ;
    ns1:identificador "PasoBajo" ;
    ns1:textoExtracto "Curva de magnitud típica de un filtro paso bajo: respuesta plana (Ao) y caída a partir de la frecuencia de corte 'FREQUENCY', con marca de –3 dB (0,707·Ao). El gráfico explica el efecto de limitar banda para suavizar movimientos y evitar resonancias altas."@es .

ns1:FlechaAzul1_794f6a16eb a ns1:AvisoSeguridad ;
    rdfs:label "Flecha azul 1" ;
    ns1:textoExtracto "Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados." .

