ns1:OperacionLogica_AND a ns1:AccionProhibida ;
    rdfs:label "Operación lógica AND" ;
    ns1:identificador "AND" ;
    ns1:textoExtracto "AND R1/1024 R1/1024 R1/1024 [...] Ejemplos con R200 = B1001 0010 y R201 = B0100 0101. () = AND R200 R201 R202 ; R202 = B0" .

ns1:OperacionLogica_OR a ns1:AccionProhibida ;
    rdfs:label "Operación lógica OR" ;
    ns1:identificador "OR" ;
    ns1:textoExtracto "OR R CNC-PLC R CNC-PLC R CNC-PLC [...] () = OR R200 R201 R203 ; R203 = B11010111" .

ns1:OperacionLogica_XOR a ns1:AccionProhibida ;
