ns1:ConfiguracionDelGrupoMultiejeGROUP1 a ns1:Sistema ;
    rdfs:label "Configuración del grupo multieje (GROUP_1)"@es ;
    ns1:identificador "GROUP_1" ;
    ns1:textoExtracto """\r
    Configuración del grupo multieje. | MULTIAXIS | GROUP_1 |\r
