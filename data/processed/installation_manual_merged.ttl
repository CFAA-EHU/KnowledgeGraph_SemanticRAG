    ns1:identificador "DMCPEAKSIZE" ;
    ns1:monitoreaParametro ns1:PotenciaDMC ;
    ns1:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %. Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE" ;
    ns1:valor "20" .

ns1:Parametro_1674fac4c1 a ns1:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "el CNC permite habilitar la mezcla de captaciones; parámetro FBMIXTIME"@es .

ns1:Parametro_167ca9e876 a ns1:Parametro ;
    rdfs:label "WARNCOUPE" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MPG.WARNCOUPE[nb]" ;
    ns1:textoExtracto "WARNCOUPE Eje gantry. Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning. Valores posibles (1): De 0.0001 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0.0001 a 99999.9999 grados. Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado. Este parámetro establece la máxima diferencia permitida entre los errores de seguimiento de ambos ejes antes de mostrar un warning." ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grado" .

ns1:Parametro_1750f2139f a ns1:Parametro ;
    rdfs:label "Parámetro de dirección de ejes X-Y-Z según DIN 66217"@es ;
    ns1:identificador "DIN_66217_EJES_XYZ" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha."@es ;
    ns1:valor "0" .

ns1:Parametro_17683e73dc a ns1:Parametro ;
    rdfs:label "CLK1600" ;
    ns1:documentadoEn ns1:Tabla_RecursosPLC_703 ;
    ns1:identificador "CLK1600" ;
    ns1:textoExtracto "CLK1600 | 1.6 s" ;
    ns1:valor "1.6 s"^^xsd:string .

ns1:Parametro_17fedc5ecc a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:textoExtracto "La segunda fila corresponde al punto ... hasta completar todos los puntos del X (parámetro NPOINTSAX1)." .

ns1:Parametro_1815820d3c a ns1:Parametro ;
    rdfs:label "CURVJERK" ;
    ns1:textoExtracto "CURVJERK Jerk máximo permitido en curvatura. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 1E+009 mm/s³." .

ns1:Parametro_187a8ca053 a ns1:Parametro ;
    rdfs:label "PROBETYPE2" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "PROBETYPE2" ;
    ns1:textoExtracto "Tipo de palpador 2."@es .

ns1:Parametro_1893173d15 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaDeSubrutinasOEMYDeUsuarioPaginas635636 ;
    ns1:identificador "CUTTINGOFF" ;
    ns1:textoExtracto "Nombre: Parámetro general CUTTINGOFF. Canales: Subrutina por canal." .

ns1:Parametro_18aab3854c a ns1:Parametro ;
    rdfs:label "Parámetro RETMFUNC" ;
    ns1:identificador "RETMFUNC" ;
    ns1:textoExtracto "Tratamiento de las funciones M con la función retrace. Valores posibles: Ignorar / Cancelar. Valor por defecto: Ignorar. Variable asociada: (V.)[ch].MPG.RETMFUNC Este parámetro establece el comportamiento de la función retrace cuando se ejecutan funciones M." ;
    ns1:valor "Ignorar" .

ns1:Parametro_18ce159876 a ns1:Parametro ;
    rdfs:label "MMCWDG" ;
    ns1:monitoreaParametro ns1:SistemaOperativoCNC ;
    ns1:textoExtracto "MMCWDG. Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." ;
    ns1:valor "0",
        "1" .

ns1:Parametro_19817f8224 a ns1:Parametro ;
    rdfs:label "G100",
        "G103" ;
    ns1:textoExtracto "Al ejecutar un comando G100 o G103, el CNC dará error si el palpador activo no tiene su marca habilitada" .

ns1:Parametro_1aaec34f71 a ns1:Parametro ;
    rdfs:label "función T" ;
    ns1:textoExtracto "la ejecución de la función T" .

ns1:Parametro_1add5bdfe9 a ns1:Parametro ;
    rdfs:label "GAPSENSORCH" ;
