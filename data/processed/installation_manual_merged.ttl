ns1:Parametro_SMOOTHFREQ a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ",
        "Frecuencia de suavizado (SMOOTHFREQ)"@es,
        "SMOOTHFREQ (frecuencia de suavizado)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC,
        ns1:Tabla_ParametrosHSC_1150 ;
    ns1:identificador "(V.)[ch].MPG.SMOOTHFREQ",
        "SMOOTHFREQ",
        "SMOOTHFREQ MPG",
        "V.[ch].MPG.SMOOTHFREQ" ;
    ns1:textoExtracto "SMOOTHFREQ Frecuencia de suavizado en la interpolación. Valores posibles: De 0 a 500.0000. Valor por defecto: 0 (no está activa). Variable asociada: (V.)[ch].MPG.SMOOTHFREQ Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias.",
        "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada."@es,
        "Frecuencia de suavizado en la interpolación."@es,
        "aplicar la frecuencia de suavizado en la interpolación de la trayectoria (parámetro SMOOTHFREQ)"@es ;
    ns1:valor 0.0,
        "0" .

ns1:Parametro_SOFTFREQ a ns1:Parametro ;
    rdfs:label "SOFTFREQ" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "(V.)[ch].MPG.SOFTFREQ",
        "SOFTFREQ" ;
    ns1:textoExtracto "SOFTFREQ Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz. Variable asociada: (V.)[ch].MPG.SOFTFREQ Este parámetro permite suavizar el perfil de velocidad en modo HSC SURFACE, lo que permite mejorar el tiempo y la calidad superficial del mecanizado.",
        "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal."@es ;
    ns1:valor "25 Hz" .

