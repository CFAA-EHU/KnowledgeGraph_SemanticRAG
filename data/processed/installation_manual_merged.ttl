    ns1:monitoreaParametro ns1:FragmentoCodigo_6_8_1 ;
    ns1:textoExtracto "Ejemplos con R100=1234",
        "R100",
        "RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200.",
        "El comando CNCRD guarda el código de la tecla en el registro R100."@es,
        "MOV 0 R100 [...] Inicializa el contador a 0 tras el encendido"@es ;
    ns1:valor "0",
        "1234" .

