    ns1:textoExtracto "Eje con regla Fagor de paso 20 µm"@es,
        "Eje con regla Fagor de paso 20 µm."@es .

ns1:Componente_TemporizadoresPLC a ns1:ComponenteElectrico ;
    ns1:documentadoEn ns1:Tabla_RecursosPLC_624 ;
    ns1:identificador "T1-T512" ;
    ns1:textoExtracto "Temporizadores (T1-T512). Son elementos capaces de mantener su salida al mismo nivel lógico durante un determinado tiempo (constante de tiempo), pasado el cual, su salida cambia de estado. Se representan mediante la letra T, seguida del número de temporizador que se desea referenciar, desde T1 hasta T512." .

ns1:ComunicacionGestorPLC_872 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación entre gestor de herramientas y PLC"@es ;
    ns1:compuestoPor ns1:FaseFuncionM06_872,
        ns1:FaseFuncionT_872 ;
    ns1:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros. [...] La comunicación entre el gestor y el PLC se realiza en 2 fases; cuando se ejecuta la función T y cuando se ejecuta la función M06."@es ;
    ns1:tieneComponente ns1:AlmacenHerramientas_872,
        ns1:BrazoCambiador_872,
        ns1:MarcasRegistrosLegacy_872 .

ns1:Condicion_EjecucionSimulada a ns1:Parametro ;
    rdfs:label "Condición de ejecución simulada (V.S.EXECUTION)"@es ;
    ns1:identificador "V.S.EXECUTION" ;
    ns1:textoExtracto "$IF [[[V.G.FULLSTATUS & 255]<9] | [[V.G.FULLSTATUS & 255]>13]] $IF [[V.G.CNCAUTSTATUS & 4096] | [V.G.CNCAUTSTATUS & 8192]] V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G."@es ;
    ns1:valor "0" .

ns1:Condicion_HabilitacionEje a ns1:Parametro ;
    rdfs:label "Señal de habilitación de eje/cabezal"@es ;
    ns1:textoExtracto "Para poder aparcar un eje o cabezal, sus señales de habilitación tienen que estar (=0)."@es ;
    ns1:valor "0" .

