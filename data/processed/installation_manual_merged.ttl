ns1:Senal_FeedHold a ns1:AvisoSeguridad ;
    rdfs:label "Feed-hold" ;
    ns1:mitigaRiesgo ns1:Senal_REVOK ;
    ns1:textoExtracto "La señal REVOK se puede utilizar para gestionar la señal Feed-hold y evitar el mecanizado con revoluciones inferiores y superiores a las deseadas." .

ns1:Senal_INHIBIT a ns1:Parametro ;
    rdfs:label "INHIBIT" ;
    ns1:textoExtracto "no se tienen en cuenta las señales INHIBIT [...] durante el roscado" .

ns1:Senal_INPOSI a ns1:InterfazUsuario ;
    rdfs:label "Señal INPOSI (en posición)" ;
    ns1:identificador "INPOSI" ;
