        ns1:Parametro_db5f50cd24 ;
    ns1:textoExtracto "definido en este parámetro se cambia la aceleración de LACC1G0 a LACC2G0. Durante la fase de deceleración, cuando se alcanza el avance definido en este parámetro se cambia la aceleración de LACC2G0 a LACC1G0."@es ;
    ns1:valor "1000.0000 mm/s² / 39.37008 inch/s² / 1000.0000 grados/s²"^^xsd:string,
        "aceleración inicial en movimientos G0"@es .

ns1:Parametro_dbff9b6f05 a ns1:Parametro ;
    rdfs:label "CUTTING" ;
