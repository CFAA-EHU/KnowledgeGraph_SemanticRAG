    ns1:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores.",
        "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas",
        "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores."@es,
        "señales LEAVEPOS"@es .

ns1:Senal_MSTROBE a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "MSTROBE" ;
    ns1:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42 y pone la marca MSTROBE",
        "activa la marca MSTROBE para que el PLC las ejecute.",
        "El CNC activa la salida lógica general MSTROBE para indicar al PLC que debe ejecutarlas [funciones M]. Esta marca se mantiene a (=1) durante el tiempo indicado en el parámetro MINAENDW."@es .

ns1:Senal_MZID a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "MZID",
        "Señal MZID",
        "Señal MZID"@es ;
