    ns1:textoExtracto "| TDATA26 | 1 |"@es ;
    ns1:valor "1" .

ns1:Parametro_340c6ceb5b a ns1:Parametro ;
    rdfs:label "NORBWIDTH"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Anchura de banda normalizada."@es .

ns1:Parametro_3423c5172e a ns1:Parametro ;
    rdfs:label "Parámetro SP5 de GEAR1" ;
    ns1:identificador "GEAR1SP5" ;
    ns1:textoExtracto "GEAR1SP5" .

ns1:Parametro_34c03174bf a ns1:Parametro ;
    rdfs:label "IPOTIMERATE"@es ;
    ns1:documentadoEn ns1:Tabla_AnalisisTiempoCiclo_1283 ;
    ns1:identificador "V.[ch].G.IPOTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal. Esta variable sirve para evaluar la sobrecarga en el algoritmo de generación de trayectoria y en el algoritmo de suavizado. Unidades: %."@es ;
    ns1:valor "%" .

ns1:Parametro_3571c01dc6 a ns1:Parametro ;
    rdfs:label "CHTYPE" ;
    ns1:identificador "V.[ch].MPG.CHTYPE" ;
    ns1:textoExtracto "Tipo de canal. Valores posibles: CNC / PLC / CNC+PLC. Valor por defecto: CNC. Variable asociada: (V.)[ch].MPG.CHTYPE" ;
    ns1:valor "CNC" .

ns1:Parametro_35ca5fe076 a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "Tipo de entrada de captación del eje." .

ns1:Parametro_36089c0056 a ns1:Parametro ;
    rdfs:label "TDATA13" ;
    ns1:documentadoEn ns1:TablaDeEquivalenciaEntreParametrosDeCinematicaTipo50YTipo4_df21b027cb ;
    ns1:textoExtracto "| TDATA13 | 0 |"@es ;
    ns1:valor "0" .

ns1:Parametro_366fa1fb61 a ns1:Parametro ;
    rdfs:label "GAP" ;
    ns1:identificador "GAP" ;
    ns1:textoExtracto "<GAP{gap}> Opcional (por defecto, el último valor programado). Distancia (gap) a mantener respecto de la superficie. Unidades: Milímetros o pulgadas." ;
    ns1:valor "Distancia a mantener respecto de la superficie" .

ns1:Parametro_36e014c99f a ns1:Parametro ;
    rdfs:label "Xb" ;
