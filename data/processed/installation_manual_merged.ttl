ns1:Sistema_AjusteGanancias a ns1:Sistema ;
    rdfs:label "Sistema de ajuste de ganancias AC-forward"@es ;
    ns1:identificador "AC-forward" ;
    ns1:textoExtracto "Ajuste apropiado. Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro). Picos invertidos; ajuste inapropiado. Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)."@es .

ns1:Sistema_CANopen a ns1:Sistema ;
    rdfs:label "Bus CANopen",
        "Sistema de numeración de salidas digitales (bus CANopen)",
        "Sistema de configuración CANopen para entradas/salidas digitales"@es ;
    ns1:documentadoEn ns1:Pagina_680_681 ;
    ns1:textoExtracto "La configuración debe cumplir los siguientes requisitos. Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las salidas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus. • Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir. • Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar. • El máximo número de bloques lógicos en el nodo será 64, tanto para entradas como para salidas digitales. • El número de I/Os de un bloque lógico no puede ser cero, y debe ser un múltiplo de 8 • Los valores del índice base deben cumplir con la fórmula '8n + 1' (es decir, 1, 9, 17, 25 ...). • Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024)."@es ;
    ns1:tieneComponente ns1:ModuloRIO5,
        ns1:ModuloRIOR,
        ns1:ModuloRIOW,
        ns1:Modulo_RIO5,
        ns1:Modulo_RIOR,
        ns1:Modulo_RIOW,
        ns1:NumeroDeSalidasDigitalesDelBloqueLogicoNDO .

ns1:Sistema_CompensacionHolgura a ns1:Sistema ;
    rdfs:label "Sistema de compensación de holgura con impulso adicional",
        "Sistema de compensación de holgura con impulso adicional de consigna",
        "Sistema de compensación de holgura por pico de inversión" ;
    ns1:monitoreaParametro ns1:Parametro_0cf9a7246b,
        ns1:Parametro_f7b4732ed5 ;
    ns1:textoExtracto "compensación de holgura con impulso adicional de consigna [...] Inversión de la consigna de posición. 2 Límite definido en REVEHYST. Inicio de la compensación de holgura. 3 Cancelación de la compensación de holgura"@es ;
    ns1:tieneComponente ns1:EjeDefinidoComoVisualizador,
        ns1:Parametro_009d5c5bd3,
        ns1:Parametro_0cf9a7246b,
        ns1:Parametro_29cbfa3b9a,
