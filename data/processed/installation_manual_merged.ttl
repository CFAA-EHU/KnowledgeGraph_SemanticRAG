ns1:TablaCompensacionCruzada_104 a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada (CROSSCOMP)"@es ;
    ns1:textoExtracto """\r
| CROSSCOMP |  |\r
| --- | --- |\r
| MOVAXIS | Eje que al moverse genera variaciones (maestro). |\r
| COMPAXIS | Eje que sufre variaciones (compensado). |\r
| NPCROSS | Número de puntos de la tabla. |\r
| TYPCROSS | Método de compensación. |\r
| BIDIR | Compensación bidireccional. |\r
| REFNEED | Búsqueda de referencia necesaria para compensar. |\r
| DATA | Tabla para definir los valores de compensación.\r
"""@es ;
    ns1:tieneComponente ns1:Parametro_BIDIR_104,
        ns1:Parametro_COMPAXIS_104,
        ns1:Parametro_DATA_104,
        ns1:Parametro_MOVAXIS_104,
        ns1:Parametro_NPCROSS_104,
        ns1:Parametro_REFNEED_104,
        ns1:Parametro_TYPCROSS_104 .

