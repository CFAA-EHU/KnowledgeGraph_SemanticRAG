    ns1:textoExtracto "Sección: Parámetros máquina del modo manual – 2.7.2 Configurar las teclas de jog | 2.7.3 Configurar las teclas de usuario como teclas de jog." .

ns1:Manual_19_1 a ns1:Pagina ;
    rdfs:label "Sección 19.1: Configurar los gráficos para los ciclos de ejes rotativos"@es ;
    ns1:identificador "19.1" ;
    ns1:textoExtracto "GRÁFICOS HD. - 19 19. - 19.1 Configurar los gráficos para los ciclos de ejes rotativos"@es .

