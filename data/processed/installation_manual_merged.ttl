    ns1:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:RegistroPLC_KEYBD1 a ns1:InterfazUsuario ;
    rdfs:label "KEYBD1" ;
    ns1:identificador "KEYBD1" ;
    ns1:textoExtracto "KEYBD1 / KEYBD2 | Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado" .

ns1:RegistroPLC_KEYBD1_1 a ns1:InterfazUsuario ;
    rdfs:label "KEYBD1_1" ;
    ns1:identificador "KEYBD1_1" ;
    ns1:textoExtracto "KEYBD1_1 / KEYBD2_1 | Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando" .

ns1:RegistroPLC_KEYBD2 a ns1:InterfazUsuario ;
    rdfs:label "KEYBD2" ;
    ns1:identificador "KEYBD2" ;
    ns1:textoExtracto "KEYBD1 / KEYBD2 | Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado" .

ns1:RegistroPLC_KEYBD2_1 a ns1:InterfazUsuario ;
    rdfs:label "KEYBD2_1" ;
