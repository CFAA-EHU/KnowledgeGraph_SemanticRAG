ns1:Parametro_HSCDEFAULTMODE a ns1:Parametro ;
    rdfs:label "HSCDEFAULTMODE",
        "Parámetro HSCDEFAULTMODE"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "(V.)[ch].MPG.HSCDEFAULTMODE",
        "HSCDEFAULTMODE" ;
    ns1:textoExtracto "HSCDEFAULTMODE Modo por defecto al programar #HSC ON. Valores posibles: SURFACE / CONTERROR / FAST. Valor por defecto: SURFACE. Variable asociada: (V.)[ch].MPG.HSCDEFAULTMODE Modo por defecto para activar el mecanizado HSC.",
        "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE, donde Fagor ofrece el modo SURFACE como modo por defecto."@es,
        "Modo por defecto al programar #HSC ON."@es ;
    ns1:valor "SURFACE" .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "HSCFILTFREQ",
        "Frecuencia del filtro (HSCFILTFREQ)"@es,
        "HSCFILTFREQ (frecuencia de filtro en modo HSC)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC,
        ns1:Tabla_ParametrosHSC_1150 ;
    ns1:identificador "HSCFILTFREQ",
        "HSCFILTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoHSC_CONTERROR,
        ns1:ModoOperacion_CONTERROR ;
    ns1:textoExtracto "HSCFILTFREQ Frecuencia del filtro (modo CONTERROR). Valores posibles: De 0 a 500.0000. Valor por defecto: 40. [...] Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR.",
        "parámetro HSCFILTFREQ para el modo CONTERROR",
        "Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR. Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado."@es,
        "Frecuencia del filtro (modo CONTERROR)."@es,
        "parámetro HSCFILTFREQ para el modo CONTERROR"@es ;
    ns1:valor "40" .

