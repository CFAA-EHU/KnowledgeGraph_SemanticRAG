    ns1:textoExtracto "Dibujo con posiciones de ejes A/B (0°, -90°) y puntos de palpación (1, 2, 3)." .

ns1:Figura_ReglaManoDerechaEjeC a ns1:Figura ;
    rdfs:label "Regla de la mano derecha aplicada al eje C" ;
    ns1:ilustradoEn ns1:Pagina_276 ;
    ns1:textoExtracto "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10)" .

ns1:Figura_ReglaManoDerechaXYZ a ns1:Figura ;
    rdfs:label "Regla de la mano derecha para ejes X-Y-Z" ;
    ns1:ilustradoEn ns1:Pagina_274 ;
    ns1:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos. Tres bocetos de mano señalan dirección positiva del eje lineal (pulgar) y giro asociado (curvatura de dedos)" .

ns1:Figura_RejillaTeclasJog a ns1:Figura ;
