ns1:TablaDeParametrosDeCompensacionVolumetricaSeccion1221 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de compensación volumétrica (Sección 12.2.1)"@es ;
    ns1:documentadoEn ns1:Pagina_613 ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| --- | --- | --- |\r
| VOLCOMP MPG |  | Este parámetro muestra las tablas de compensación volumétrica. |\r
| VCOMPAXIS1 MPG, VCOMPAXIS2, VCOMPAXIS3 |  | Estos parámetros definen los ejes a compensar mediante la compensación volumétrica... |\r
| VCOMPFILE MPG |  | Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC...""" .

ns1:TablaDeParametrosDeConfiguracionHSCPag621622 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (pág. 621-622)"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionHSC ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| --- | --- | --- |\r
| FASTFILTFREQ MPG |  | Este parámetro activa un filtro "paso bajo" automático para todos los ejes del canal durante la ejecución en modo HSC FAST...\r
| FREQRES MPG |  | Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna...\r
| SOFTFREQ MPG |  | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal...\r
| HSCROUND MPG |  | Valor por defecto del error máximo de la trayectoria en HSC...\r
| SURFFILFREQ MPG |  | Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE..."""@es .

ns1:TablaDeParametrosDeConfiguracionHSCPaginas621622 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (páginas 621-622)"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionHSC ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| --- | --- | --- |\r
| HSCDEFAULMODE MPG |  | Modo por defecto al programar #HSC ON. |\r
| FEEDAVRG MPG |  | Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques... |\r
| SMOOTHFREQ MPG |  | Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias... |\r
| CORNER MPG |  | Este parámetro indica el ángulo máximo entre dos trayectorias... |\r
| HSCFILTFREQ MPG |  | Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR..."""@es .

