ns1:Senal_AUXEND a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "AUXEND" ;
    ns1:textoExtracto "Comienza el cambio y se lo indica al CNC con AUXEND a (=0). [...] Una vez que ha finalizado el cambio de gama quita el indicativo (M1002) y se lo indica al CNC con AUXEND a (=1).",
        "se activan las señales SSTROBE o MSTROBE correspondientes pero se espera a una única señal AUXEND para dar por finalizadas todas ellas.",
        "El CNC esperará [...] la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC."@es ;
    ns1:valor "0",
        "1" .

ns1:Senal_LEAVEPOS a ns1:ComponenteElectrico,
