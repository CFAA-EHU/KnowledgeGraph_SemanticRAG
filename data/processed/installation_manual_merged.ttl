    rdfs:label "Sistema Sercos (Nodos 4 y 5)" ;
    ns1:monitoreaParametro ns1:ParametrizacionSercos_1262 ;
    ns1:textoExtracto "NODO 4: Cabezal S Sercos E21B NODO 5: Eje U (segunda captación) E21C" ;
