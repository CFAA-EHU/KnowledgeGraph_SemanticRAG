ns1:BrazoCambiador a ns1:Actuador,
        ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador",
        "Brazo cambiador de herramientas",
        "brazo cambiador",
        "Brazo cambiador"@es,
        "Brazo cambiador de herramientas"@es ;
    ns1:identificador "BrazoCambiador" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. [...] TAKEPOS=-1 Herramienta en el brazo cambiador.",
        "Llevar el brazo cambiador al punto de cambio. [...] Retirar el brazo cambiador. [...] Comenzar el envío del brazo cambiador al almacén",
        "Llevar el brazo cambiador al punto de cambio... Retirar el brazo cambiador... cuando el brazo abandona la zona de posible colisión",
        "brazo cambiador",
        """\r
LL SUB_ARM_BACK ; Retirar el brazo cambiador.\r
LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta."""@es,
        "Herramienta en el brazo cambiador. [...] Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK"@es,
        "Retirar el brazo cambiador. [...] Llevar el brazo cambiador al punto de cambio."@es,
        "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es,
        "brazo cambiador"@es,
        "brazo cambiador de movimientos independientes que puede moverse durante el mecanizado."@es ;
    ns1:tieneComponente ns1:Pinza,
        ns1:Pinza2 .

ns1:Tabla_ConfiguracionModoHSC a ns1:Tabla ;
    rdfs:label "Tabla de configuración del modo HSC (canal)"@es ;
    ns1:textoExtracto """\r
| HSC |  |\r
| --- | --- |\r
| HSCDEFAULTMODE | Modo por defecto al programar #HSC ON. |\r
| FEEDAVRG | Calcular el promedio del avance. |\r
| MINCORFEED | Velocidad mínima en las esquinas. |\r
| CORNER | Ángulo máximo de la esquina para mecanizarla en arista viva. |\r
| SMOOTHFREQ | Frecuencia de suavizado en la interpolación. |\r
| HSCFILTFREQ | Frecuencia del filtro (modo CONTERROR). |\r
| FASTFACTOR | Porcentaje de avance por defecto (modo FAST). |\r
| FTIMELIM | Diferencia de tiempo admisible en la interpolación del avance (modo FAST). |\r
| FSMOOTHFREQ | Frecuencia de suavizado en la interpolación (modo FAST). |\r
| FASTFILTFREQ | Frecuencia del filtro (modo FAST). |\r
| SURFFILTFREQ | Frecuencia del filtro de ejes (modo SURFACE). |\r
| FREQRES | Primera frecuencia de resonancia de la máquina. |\r
| SOFTFREQ | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. |\r
| HSCROUND | Valor por defecto del error máximo de la trayectoria en HSC. |\r
| ORISMOOTH | Suavizado de la orientación de los ejes rotativos trabajando con RTCP. """ .

ns1:Tabla_HomogeneizacionParametrosCNC_Drive a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y DRIVE"@es,
        "Tabla de homogeneización de parámetros entre CNC y regulador (DRIVE)"@es ;
    ns1:identificador "Tabla 2.1 (pág. 51-52)" ;
    ns1:textoExtracto """\r
| CNC       | DRIVE       | Sercos  | Feedback | Observaciones |\r
|-----------|-------------|---------|----------|---------------|\r
| AXISCH    | PP55 (bit 0,2,3) | Posición. |          | B1=0 B2=0 B3=0; No cambia el signo de contaje (AXISCH==NO)...\r
| I0TYPE    | PP115 (bit 1,5)  |         | Externa. | B1=0 B5=0; Si I0 no codificado...""",
        """\r
| CNC       | DRIVE   | Sercos | Feedback | Observaciones                                                                 |\r
|-----------|---------|--------|----------|-------------------------------------------------------------------------------|\r
| AXISTYPE  | PP76    |        |          | PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo. |\r
| PITCH     | NP123   |        |          |                                                                               |\r
| NPULSES2  | PP115 (bit 0), NP117 |    | Externa. | B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0).""" .

ns1:Tabla_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica (VOLCOMP)",
        "Tabla de compensación volumétrica VOLCOMP",
        "Tabla de compensación volumétrica (VOLCOMP)"@es ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla VOLCOMP.",
        "Parámetro incluido en la tabla VOLCOMP. Estos parámetros definen los ejes a compensar mediante la compensación volumétrica.",
        "Parámetro incluido en la tabla VOLCOMP. Ejes que al moverse generan variaciones. [...] El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE."@es ;
