ns1:Parametro_F500 a ns1:Parametro ;
    rdfs:label "F 500" ;
    ns1:textoExtracto "F 500 250" ;
    ns1:valor "500" .

ns1:Parametro_FASTFACTOR_MPG a ns1:Parametro ;
    rdfs:label "FASTFACTOR MPG" ;
    ns1:identificador "FASTFACTOR MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de avance que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST." ;
    ns1:valor "valor por defecto (modificable desde programa pieza)" .

ns1:Parametro_FASTFILTFREQ_MPG a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1153 ;
    ns1:identificador "FASTFILTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas. Este parámetro introduce un desfase constante, independiente de las frecuencias."@es .

ns1:Parametro_FBACKAL a ns1:Parametro ;
    rdfs:label "FBACKAL" ;
    ns1:activaAlarma ns1:Alarma_Captacion ;
    ns1:identificador "(V.)[ch].MPA.FBACKAL[set].xn" ;
    ns1:textoExtracto "FBACKAL Activar la alarma de captación. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.FBACKAL[set].xn Este parámetro permite activar la alarma de captación. Esta alarma pretende discernir la desconexión o ruptura de alguno de los cables de la captación para señales tanto TTL diferenciales como senoidales." ;
    ns1:valor "Sí / No" .

ns1:Parametro_FBACKTIME a ns1:Parametro ;
    rdfs:label "FBACKTIME"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:identificador "FBACKTIME" ;
    ns1:textoExtracto "Constante de tiempo para la captación mixta."@es .

ns1:Parametro_FCAS a ns1:Parametro ;
    rdfs:label "FCAS" ;
    ns1:documentadoEn ns1:Sistema_Se_alesConsultaCNC ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "Opción de control de colisiones (FCAS) que activa/desactiva la marca COLLISIONACTIV." .

ns1:Parametro_FILTERIN a ns1:Parametro ;
    rdfs:label "Cota teórica del interpolador antes del filtro (FILTERIN)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.FILTERIN.xn / (V.)[ch].A.FILTERIN.sn / (V.)[ch].SP.FILTERIN.sn" ;
    ns1:textoExtracto "Cota teórica del interpolador antes del filtro. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_FILTEROUT a ns1:Parametro ;
    rdfs:label "Cota teórica del interpolador después del filtro (FILTEROUT)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.FILTEROUT.xn / (V.)[ch].A.FILTEROUT.sn / (V.)[ch].SP.FILTEROUT.sn" ;
    ns1:textoExtracto "Cota teórica del interpolador después del filtro. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_FINALSUB a ns1:Parametro ;
    rdfs:label "Parámetro FINALSUB",
        "FINALSUB"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasControlNumerico ;
    ns1:identificador "(V.)[ch].MPG.FINALSUB",
        "FINALSUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.FINALSUB. Este parámetro indica el nombre de la subrutina asociada a la sentencia #FINALSUB. Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada.",
        "Nombre: Parámetro general FINALSUB. Canales: Subrutina por canal."@es .

ns1:Parametro_FINALSUB_CHN a ns1:Parametro ;
    rdfs:label "FINALSUB CHN" ;
    ns1:identificador "FINALSUB CHN" ;
    ns1:monitoreaParametro ns1:Subrutina_Finalsub_fst ;
    ns1:textoExtracto "FINALSUB CHN | Subrutina asociada al comando #FINALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ns1:valor "Finalsub.fst" .

ns1:Parametro_FINEORG a ns1:Parametro ;
    rdfs:label "FINEORG" ;
    ns1:habilitadoPor ns1:Tabla_TrasladosOrigen ;
    ns1:identificador "(V.)MPG.FINEORG" ;
    ns1:textoExtracto "FINEORG Definición fina de los traslados de origen. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:Parametro_FIXORI a ns1:Parametro ;
    rdfs:label "FIXORI" ;
    ns1:monitoreaParametro ns1:Sistema_GraficosHD ;
    ns1:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS.",
        "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS"@es .

ns1:Parametro_FLIMIT a ns1:Parametro ;
    rdfs:label "FLIMIT" ;
    ns1:identificador "FLIMIT" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "FLIMIT Límite máximo de seguridad para el avance del eje. Parámetro válido para ejes lineales y rotativos. [...] Este parámetro establece el límite máximo de seguridad para el avance del eje, a aplicar por ejemplo, cuando se realizan labores de mantenimiento en la máquina, operaciones con las seguridades deshabilitadas (puertas abiertas), etc." ;
    ns1:valor "0 a 500000.0000 mm/min / 0 a 19685.03937 inch/min / 0 a 72000000.0000 grados/min" .

ns1:Parametro_FLIMITACCH a ns1:Parametro ;
    rdfs:label "FLIMITACCH" ;
    ns1:identificador "FLIMITACCH" ;
    ns1:textoExtracto "FLIMITACCH Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. FLIMITACCHC1 (también se puede programar como FLIMITACCH) FLIMITACCHC2 FLIMITACCHC3 FLIMITACCHC4" .

ns1:Parametro_FLIMITACCHC1 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC1" ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" .

ns1:Parametro_FLIMITACCHC2 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC2" ;
    ns1:identificador "FLIMITACCHC2" ;
    ns1:textoExtracto "FLIMITACCHC2" .

ns1:Parametro_FLIMITACCHC3 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC3" ;
    ns1:identificador "FLIMITACCHC3" ;
    ns1:textoExtracto "FLIMITACCHC3" .

ns1:Parametro_FLIMITACCHC4 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC4" ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4" .

ns1:Parametro_FL_X a ns1:Parametro ;
    rdfs:label "Límite físico en eje X (FL)" ;
    ns1:textoExtracto "límites físicos (FL) para X-Y-Z" ;
    ns1:valor "FL_X" .

ns1:Parametro_FPRMAN a ns1:Parametro ;
    rdfs:label "FPRMAN (G95 permitida en modo manual)" ;
    ns1:habilitadoPor ns1:ModoOperacion_Manual ;
    ns1:identificador "Sí/No" ;
    ns1:textoExtracto "Este parámetro indica si se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual; no afecta al movimiento con volantes o en modo MDI/MDA." ;
    ns1:valor "Sí" .

ns1:Parametro_FREAL a ns1:Parametro ;
    rdfs:label "V.[ch].G.FREAL" ;
    ns1:documentadoEn ns1:Tabla_13_3_3_VariablesAvanceTrayectoria ;
    ns1:identificador "V.[ch].G.FREAL" ;
    ns1:textoExtracto "Avance real filtrado sobre la trayectoria. Esta variable tiene en cuenta el override y las aceleraciones y deceleraciones de la máquina. Unidades: Milímetros/minuto o pulgadas/minuto."@es ;
    ns1:valor "Avance real filtrado sobre la trayectoria"@es .

ns1:Parametro_FREQRES_MPG a ns1:Parametro ;
    rdfs:label "FREQRES MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1153 ;
    ns1:identificador "FREQRES MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_CONTERROR ;
    ns1:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR."@es .

ns1:Parametro_FSMOOTHFREQ a ns1:Parametro ;
    rdfs:label "FSMOOTHFREQ" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "(V.)[ch].MPG.FSMOOTHFREQ",
        "FSMOOTHFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST,
        ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Frecuencia de suavizado en la interpolación (modo FAST y SURFACE). Valores posibles: De 0 a 500.0000. Valor por defecto: 20. Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para los modos HSC FAST y SURFACE. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada.",
        "Frecuencia de suavizado en la interpolación (modo FAST)."@es ;
    ns1:valor "20" .

ns1:Parametro_FSMOOTHFREQ_MPG a ns1:Parametro ;
    rdfs:label "FSMOOTHFREQ MPG" ;
    ns1:identificador "FSMOOTHFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para el modo HSC FAST. Evita acelerar y decelerar por encima de una determinada frecuencia." .

ns1:Parametro_FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "FTIMELIM" ;
    ns1:monitoreaParametro ns1:ModoHSC_FAST,
        ns1:ModoHSC_SURFACE,
        ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo.",
        "FTIMELIM Diferencia de tiempo admisible en la interpolación del avance (modo FAST y SURFACE). Valores posibles: De 0 a 100000.0000 %. Valor por defecto: 200 %. [...] El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo.",
        "aumenta el tiempo máximo permitido de ejecución total; por ejemplo, un valor de 200% o 300% permitirá hasta el doble o triple de tiempo de ejecución en el tramo interpolado. En aquellos bloques relativamente grandes, en los que la adaptación del avance suponga un tiempo adicional mayor del especificado en FTIMELIM, el CNC adaptará el avance usando la máxima dinámica, para evitar pérdidas de tiempo innecesarias.",
        "Diferencia de tiempo admisible en la interpolación del avance (modo FAST)."@es ;
    ns1:valor "0",
        "200",
        "200%",
        "200% / 300%",
        "300%" .

ns1:Parametro_FTIMELIM_MPG a ns1:Parametro ;
    rdfs:label "FTIMELIM MPG" ;
    ns1:identificador "FTIMELIM MPG" ;
    ns1:monitoreaParametro ns1:ModoHSCFAST ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo. Si se programa con valor 0, el CNC no realiza la interpolación del avance y por tanto la ejecución es más rápida." ;
    ns1:valor "0 (sin interpolación) o porcentaje (ej. 200%, 300%)" .

ns1:Parametro_FUNPLC a ns1:Parametro ;
    rdfs:label "FUNPLC" ;
    ns1:identificador "FUNPLC" ;
    ns1:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FUNPLC" ;
    ns1:valor "No" .

ns1:Parametro_FZMAX_1.3 a ns1:Parametro ;
    rdfs:label "FZMAX 1.3" ;
    ns1:monitoreaParametro ns1:Comando_DMC_ON_Programado_Completo,
        ns1:Comando_DMC_ON_Programado_Parcial ;
    ns1:textoExtracto "FZMAX 1.3" ;
    ns1:valor "1.3" .

ns1:Parametro_FZMIN_0.8 a ns1:Parametro ;
    rdfs:label "FZMIN 0.8" ;
    ns1:monitoreaParametro ns1:Comando_DMC_ON_Programado_Completo,
        ns1:Comando_DMC_ON_Programado_Parcial ;
    ns1:textoExtracto "FZMIN 0.8" ;
    ns1:valor "0.8" .

ns1:Parametro_FastFactorMPG a ns1:Parametro ;
    rdfs:label "FASTFACTOR MPG"@es ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el..."@es .

ns1:Parametro_FeedForward a ns1:Parametro ;
    rdfs:label "Feed forward" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" ;
    ns1:valor "feed forward" .

ns1:Parametro_FiltroAceleracion_276 a ns1:Parametro ;
    rdfs:label "Filtro de aceleración" ;
    ns1:monitoreaParametro ns1:ReguladorMechatrolink_276 ;
    ns1:textoExtracto "activar filtros de aceleración" .

ns1:Parametro_FiltroDeceleracion_276 a ns1:Parametro ;
    rdfs:label "Filtro de deceleración" ;
    ns1:monitoreaParametro ns1:ReguladorMechatrolink_276 ;
    ns1:textoExtracto "activar filtros de aceleración o deceleración" .

ns1:Parametro_FiltroSuavizadoTrayectoria a ns1:Parametro ;
    rdfs:label "Filtro de suavizado de trayectoria"@es ;
    ns1:textoExtracto "Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado. Este parámetro introduce un desfase no constante, dependiente de las frecuencias."@es ;
    ns1:valor "variable (dependiente de frecuencias)"@es .

ns1:Parametro_FormatoArchivoInformacionAdicional a ns1:Parametro ;
    rdfs:label "Formato de archivo de información adicional para errores del PLC"@es ;
    ns1:monitoreaParametro ns1:Sistema_ArchivosInformacionAdicional ;
    ns1:textoExtracto "El archivo deberá ser de texto (extensión txt) y podrá tener cualquier nombre. La información de cada mensaje y error debe estar estructurada de acuerdo al siguiente formato: [id] <texto>."@es ;
    ns1:valor "<id> [id]\\n<texto> Texto de hasta 500 caracteres"@es .

ns1:Parametro_FrecuenciaCentral a ns1:Parametro ;
    rdfs:label "Frecuencia central (FREQUENCY)"@es ;
    ns1:identificador "FREQUENCY" ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ns1:Parametro_FrecuenciaResonancia_fr a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia (fr)"@es ;
    ns1:identificador "fr" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es .

ns1:Parametro_FuncionG17_Canal1 a ns1:Parametro ;
    rdfs:label "Función G17 (plano X-Y, canal 1)"@es ;
