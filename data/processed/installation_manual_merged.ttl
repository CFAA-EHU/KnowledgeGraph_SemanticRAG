    ns1:habilitadoPor ns1:SistemaEjes_XYZ ;
    ns1:textoExtracto "Con el cabezal normal, configuración de ejes X Y Z."@es .

ns1:CabezalOrtogonal a ns1:ComponenteMecanico ;
