ns1:Esquema_FeedForward a ns1:Esquema ;
    rdfs:label "Esquema de bloques de feed-forward"@es ;
    ns1:identificador "feed-forward_block_diagram" ;
    ns1:textoExtracto "esquema de bloques de feed-forward: 'Programmed Feedrate' alimenta un bloque 'FFGAIN'; 'Nominal Position' entra en un sumador con 'PROGAIN' y la señal de error 'ε'; la salida conjunta genera la 'Analog output' que actúa sobre la 'Actual position'."@es .

ns1:Esquema_SecuenciaCompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema de secuencia para compensación volumétrica"@es ;
    ns1:identificador "12.1.4" ;
    ns1:textoExtracto "Diagrama 3D de una malla de puntos dentro de un triedro X-Y-Z con números (1…12) que indican el orden de recorrido de las mediciones. Se muestra la posición inicial sobre cada eje (INIPOSAX1/2/3), incrementos entre puntos (INCREAX1/2/3) y la distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3, con flechas que marcan la secuencia de avance primero en X, luego en Y y finalmente en Z."@es .

