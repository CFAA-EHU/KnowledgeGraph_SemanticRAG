ns1:Esquema_17.1_TDATA1 a ns1:Esquema ;
    ns1:identificador "17.1 - Cálculo del parámetro TDATA1" ;
    ns1:ilustradoEn ns1:Pagina_708 ;
    ns1:textoExtracto "Esquema combinado con variables TDATA1, ΔZ, L y R, y anotación de la solución TDATA1 = |ΔZ| − R − L; se incluye vista de referencias y vectores de medición." .

ns1:Esquema_AsignacionBitsTeclasOP_PANEL_H_E a ns1:Esquema ;
    rdfs:label "Esquema de asignación de bits a teclas del OP-PANEL-H/E"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_OP_PANEL_H_E ;
    ns1:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos."@es .

ns1:Figura_DiagramaTemporalNoSincronizado a ns1:Figura ;
    rdfs:label "Diagrama temporal de transferencia no sincronizada (SSTROBE/MSTROBE/PLC EXECUTION)"@es ;
    ns1:textoExtracto "Diagrama temporal con SSTROBE/MSTROBE y la traza 'PLC EXECUTION', incluyendo una cota de duración MINAENDW. Muestra que, en transferencias no sincronizadas, el CNC mantiene el 'strobe' durante el tiempo mínimo y continúa la ejecución sin esperar confirmación del PLC."@es .

ns1:Figura_DiagramaTemporalSincronizado a ns1:Figura ;
    rdfs:label "Diagrama temporal de transferencia sincronizada (SSTROBE/MSTROBE/AUXEND)"@es ;
    ns1:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos y numeradas (1–4) para indicar la secuencia de ejecución. Se resalta el parámetro de temporización MINAENDW mediante una cota horizontal."@es .

