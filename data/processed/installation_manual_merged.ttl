    rdfs:label "Conector RIO5 X3" ;
    ns1:identificador "RIO5_X3" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_RIO5_X4 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X4" ;
    ns1:identificador "RIO5_X4" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_RIO5_X5 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X5" ;
    ns1:identificador "RIO5_X5" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_RIO5_X6 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X6" ;
    ns1:identificador "RIO5_X6" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_RIO5_X7 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X7" ;
    ns1:identificador "RIO5_X7" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_RIO5_X8 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X8" ;
    ns1:identificador "RIO5_X8" ;
    ns1:textoExtracto "conectores X1–X8" .

ns1:Conector_X1_1238 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X1 (Entradas/Salidas Digitales)"@es ;
    ns1:detalladoEnEsquema ns1:EsquemaConexion_1238 ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL INPUT [...] X1 [...] DIGITAL OUTPUT [...] X1"@es .

ns1:Conector_X2_1238 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X2 (Dirección/Reset CAN)"@es ;
    ns1:detalladoEnEsquema ns1:EsquemaConexion_1238 ;
    ns1:identificador "X2" ;
    ns1:textoExtracto "ADDRESS RESET [...] X2 [...] G N D [...] X2"@es .

ns1:Conector_X3_1238 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X3 (Salidas Digitales HDDL)"@es ;
    ns1:detalladoEnEsquema ns1:EsquemaConexion_1238 ;
    ns1:identificador "X3" ;
    ns1:textoExtracto "SSCCHHAAGIIEENNNLL HDDDL [...] X3 [...] OOOOOO 1111111"@es .

ns1:ConectoresCNC a ns1:ComponenteElectrico ;
    rdfs:label "Conectores del CNC" ;
    ns1:textoExtracto "se comunican con el exterior a través de los conectores del CNC" .

ns1:Conexion_Red_FagorCNCTCP_1381 a ns1:InterfazUsuario ;
    rdfs:label "Conexión FagorCNCTCP"@es ;
    ns1:identificador "FagorCNCTCP" ;
    ns1:textoExtracto "Para modificar la conexión, en el menú PLC > Connections seleccionar la opción FagorCNCTCP y pulsar Edit. [...] Definir la IP adecuada (la del CNC)."@es .

ns1:Conexion_SYS_Tool1_C1 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C1 (rotación: 0 1 0 -90)"@es ;
    ns1:compuestoPor ns1:Herramienta_SYS_Tool1 ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C1\" rotation=\"0 1 0 -90\"/>"@es .

ns1:Conexion_SYS_Tool1_C2 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C2 (rotación: 0 1 0 -90)"@es ;
    ns1:compuestoPor ns1:Herramienta_SYS_Tool1 ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S2\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C2\" rotation=\"0 1 0 -90\"/>"@es .

ns1:Conexion_SYS_Tool1_C3 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C3 (rotación: 0 1 0 -90)"@es ;
    ns1:compuestoPor ns1:Herramienta_SYS_Tool1 ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S3\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C3\" rotation=\"0 1 0 -90\"/>"@es .

ns1:ConfiguracionEjesCompartidos_1077 a ns1:Sistema ;
    rdfs:label "Configuración de 2 ejes con misma entrada captación y salida analógica"@es ;
    ns1:controla ns1:Parametro_ANAOUTID_1077,
        ns1:Parametro_COUNTERID_1077,
        ns1:Parametro_COUNTERTYPE_1077 ;
    ns1:detalladoEnEsquema ns1:TablaParametrosEjes_1077 ;
    ns1:textoExtracto "Hay máquinas donde existen 2 ejes que nunca están de forma simultánea en la misma configuración, ya que uno de ellos está siempre aparcado; por ejemplo, en el caso de cambio de cabezales con motor interior para mover su articulación. En estos casos, ambos motores están controlados por el mismo regulador y para el CNC sólo hay una entrada de captación y una salida analógica."@es ;
    ns1:tieneComponente ns1:MotorEje1_1077,
        ns1:MotorEje2_1077 .

ns1:ConfiguracionEjesGantry_71 a ns1:Parametro ;
    rdfs:label "Configuración de los ejes gantry"@es ;
    ns1:identificador "GANTRY" ;
    ns1:textoExtracto "Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema."@es .

ns1:ConfiguracionEjesRotativos_1349 a ns1:InterfazUsuario ;
    rdfs:label "Configuración gráficos para ciclos de ejes rotativos (modelo M)"@es ;
    ns1:documentadoEn ns1:Manual_19_1 ;
    ns1:identificador "F3D" ;
    ns1:textoExtracto "En los gráficos F3D hay que cargar la configuración máquina (archivo xca) correspondiente a la configuración de ejes definida. Los archivos xca se pueden cargar bien desde el menú de softkeys o bien desde el programa mediante la sentencia #DEFGRAPH."@es .

ns1:ConfiguracionEjes_Torno3Canales6Ejes2Cabezales a ns1:Sistema ;
    rdfs:label "Configuración de ejes para torno con 3 canales, 6 ejes y 2 cabezales" ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ y ꞏ2ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas." ;
    ns1:tieneComponente ns1:Eje_U_Indice1_Logico5,
        ns1:Eje_V_Indice2_Logico6 .

ns1:ConfiguracionOverride a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de override en roscado" ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "Si hay programados dos o más G33 para la misma rosca, todos los roscados deben comenzar a la misma velocidad; en caso contrario, el punto de entrada a la rosca no coincidirá en todos los roscados."@es .

ns1:ConfiguradorEtherCAT_Studio a ns1:InterfazUsuario ;
    rdfs:label "Studio. Configurador EtherCAT"@es ;
    ns1:identificador "Studio" ;
    ns1:textoExtracto "Studio. Configurador EtherCAT."@es .

ns1:ConmutadorFeedOverride_1251 a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador feed override" ;
    ns1:textoExtracto "Inhibir desde el PLC todas las posiciones del conmutador feed override." .

ns1:ConmutadorRotativo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador rotativo (RCS-S)" ;
    ns1:textoExtracto "dirección física, fijada por su conmutador rotativo (número de nodo)." .

ns1:Conmutador_FeedOverride a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador feed override" ;
    ns1:textoExtracto "Si el teclado está asociado a un canal en concreto, un cambio del override sólo afecta a ese canal, aunque forme parte de un grupo. Si el teclado está asociado al canal activo, un cambio de override afecta a todos los canales del sistema de forma simultánea, formen o no parte de un grupo." .

ns1:ConsultaAsincrona_M11 a ns1:Parametro ;
    rdfs:label "Consulta asíncrona M11 (CNCRD TM.TOOL)"@es ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "<condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11) no repetir la consulta mientras no finalice la misma."@es .

ns1:ConsultaSincrona_M12 a ns1:Parametro ;
    rdfs:label "Consulta síncrona M12 (CNCRD G.FREAL)"@es ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12)"@es .

ns1:Contador_CPR1 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C1 (preselección valor 100)"@es ;
    ns1:identificador "CPR 1" ;
    ns1:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100."@es ;
    ns1:valor "100" .

ns1:ContadoraSercos_Nodo3 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (Nodo 3)"@es ;
    ns1:documentadoEn ns1:Sistema_ContadoresYEjes_1261 ;
    ns1:identificador "Nodo 3" ;
    ns1:textoExtracto "2 contadoras Sercos (nodos 3, 5)"@es .

ns1:ContadoraSercos_Nodo5 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (Nodo 5)"@es ;
    ns1:documentadoEn ns1:Sistema_ContadoresYEjes_1261 ;
    ns1:identificador "Nodo 5" ;
    ns1:textoExtracto "2 contadoras Sercos (nodos 3, 5)"@es .

ns1:ContadoraSercos_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (RCS-S)" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID,
        ns1:Parametro_SERCOUNTID ;
    ns1:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID). Las entradas de captación del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente.",
        "Módulo RCS-S (contadora Sercos)" .

ns1:Contadora_RCS_S_Nodo3 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S (nodo 3)" ;
    ns1:identificador "RCS-S_Nodo3" ;
    ns1:textoExtracto "contadoras RCS-S (nodos 3 y 5)" .

ns1:Contadora_RCS_S_Nodo5 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S (nodo 5)" ;
    ns1:identificador "RCS-S_Nodo5" ;
    ns1:textoExtracto "contadoras RCS-S (nodos 3 y 5)" .

ns1:ControlDutyPWM a ns1:Parametro ;
    rdfs:label "Control de duty del PWM (#PWRCTRL ON [DUTY])" ;
    ns1:identificador "#PWRCTRL ON [DUTY]" ;
    ns1:textoExtracto "Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY]). El PLC desactiva esta marca para deshabilitar el control de duty activo. El PLC activa esta marca para habilitar el control de duty activo en el CNC; si no hay un control de duty activo, esta marca no hace nada." .

ns1:ControlFrecuenciaPWM a ns1:Parametro ;
    rdfs:label "Control de frecuencia del PWM (#PWRCTRL ON [FREQ])" ;
    ns1:identificador "#PWRCTRL ON [FREQ]" ;
    ns1:textoExtracto "Esta marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ])." .

ns1:ControlNumericoTandem a ns1:ComponenteElectrico ;
    rdfs:label "Control numérico del eje tándem"@es ;
    ns1:controla ns1:LazoPosicionTandem,
        ns1:LazoVelocidadTandem ;
    ns1:textoExtracto "En el diagrama de bloques aparece una zona correspondiente al regulador y otra al control numérico, que engloba el lazo de posición y el control del tándem."@es .

ns1:ControladorPI_1069 a ns1:ComponenteElectrico ;
    rdfs:label "Controlador PI del tándem"@es ;
    ns1:controla ns1:MotorEsclavo_1069,
        ns1:MotorMaestro_1069 ;
    ns1:textoExtracto "PI del tándem. PI cuya función es conseguir que cada motor realice el par que le corresponde. Incrementa su consigna de velocidad si el par que se suministra es demasiado pequeño y la reduce si el par suministrado es demasiado elevado."@es .

ns1:CremalleraGantry a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera (gantry)"@es ;
    ns1:textoExtracto "dos motores (maestro y esclavo) engranados sobre la misma cremallera"@es .

ns1:Cremallera_Tandem a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera del eje tándem"@es ;
    ns1:textoExtracto "cremallera"@es .

ns1:DECELG0 a ns1:Parametro ;
    rdfs:label "DECELG0 (Deceleración trapezoidal en G0)" ;
    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Deceleración: DECELG0" .

ns1:DECJERKG0 a ns1:Parametro ;
    rdfs:label "DECJERKG0 (Jerk de deceleración en G0)" ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de deceleración: DECJERKG0" .

ns1:DIAGNOSIS a ns1:Componente ;
    rdfs:label "DIAGNOSIS" ;
    ns1:textoExtracto "Información para la diagnosis. Esta carpeta contiene la información relevante para un correcto diagnóstico de los errores, incluido el archivo reportfagor.zip." .

ns1:DISCROSS1 a ns1:Parametro ;
    rdfs:label "DISCROSS1" ;
    ns1:textoExtracto "Se aplica a las tablas de compensación cruzada definidas en los parámetros máquina. El PLC pone la marca a (=1) para deshabilitar la tabla 1." ;
    ns1:valor "0,1" .

ns1:DISCROSS17 a ns1:Parametro ;
    rdfs:label "DISCROSS17" ;
    ns1:textoExtracto "Hay una marca para cada tabla. El PLC pone la marca a (=1) para deshabilitar la tabla." ;
    ns1:valor "0,1" .

ns1:DM00 a ns1:Parametro ;
    rdfs:label "DM00" ;
    ns1:identificador "DM00" ;
    ns1:textoExtracto "DM00. Estas marcas están asociadas a las funciones M00. El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DM00C1 a ns1:Parametro ;
    rdfs:label "DM00C1" ;
    ns1:identificador "DM00C1" ;
    ns1:textoExtracto "DM00C1 (también se puede programar como DM00). El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DM00C2 a ns1:Parametro ;
    rdfs:label "DM00C2" ;
    ns1:identificador "DM00C2" ;
    ns1:textoExtracto "DM00C2. El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DM00C3 a ns1:Parametro ;
    rdfs:label "DM00C3" ;
    ns1:identificador "DM00C3" ;
    ns1:textoExtracto "DM00C3. El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DM00C4 a ns1:Parametro ;
    rdfs:label "DM00C4" ;
    ns1:identificador "DM00C4" ;
    ns1:textoExtracto "DM00C4. El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DM03SP1 a ns1:Parametro ;
    rdfs:label "DM03SP1" ;
    ns1:identificador "DM03SP1" ;
    ns1:textoExtracto "DM03SP1 (también se puede programar como DM03). El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." .

ns1:DMCPOWERFACTOR a ns1:Parametro ;
    rdfs:label "DMCPOWERFACTOR" ;
    ns1:identificador "DMCPOWERFACTOR" ;
    ns1:textoExtracto "potencia a alcanzar multiplicada por el parámetro DMCPOWERFACTOR" .

ns1:DMCPWRHOLD a ns1:Parametro ;
    rdfs:label "DMCPWRHOLD" ;
    ns1:identificador "DMCPWRHOLD" ;
    ns1:textoExtracto "DMCPWRHOLD [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si todos los valores de potencia leídos a lo largo de 2 segundos exceden la potencia a alcanzar multiplicada por el parámetro DMCPOWERFACTOR." .

ns1:DMCPWRPEAK a ns1:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "DMCPWRPEAK [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si la potencia leída supera a la potencia a alcanzar (potencia objetivo + potencia en vacío) en el porcentaje definido en el parámetro DMCPEAKSIZE." .

ns1:DMC_FrecuenciaAprendizaje a ns1:Frecuencia ;
    ns1:textoExtracto "Al finalizar la inspección de herramienta, el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'."@es .

ns1:DRIVERS a ns1:Componente ;
    rdfs:label "DRIVERS" ;
    ns1:textoExtracto "Drivers del CNC. Esta carpeta contiene algunos drivers necesarios para el correcto funcionamiento del CNC." .

ns1:DeceleracionBusquedaReferencia a ns1:Parametro ;
    rdfs:label "Deceleración en búsqueda de referencia" ;
    ns1:textoExtracto "El CNC decelera el eje, pasa del avance rápido [...] al avance lento"@es .

ns1:DiagramaBloquesTandem_11_2_3 a ns1:Esquema ;
    rdfs:label "Diagrama de bloques del sistema de control del eje tándem"@es ;
    ns1:ilustradoEn ns1:Pagina_577_578 ;
    ns1:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo. [...] El diagrama de bloques representativo de la aplicación del control del eje tándem es el siguiente."@es .

ns1:DiagramaPalpadorMedida_2_3_25 a ns1:Esquema ;
    rdfs:label "Esquema de palpador de medida esférico"@es ;
    ns1:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza."@es .

ns1:DiagramaPalpadorTorno_2_3_25 a ns1:Esquema ;
    rdfs:label "Esquema de palpador de sobremesa para torno"@es ;
    ns1:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno."@es .

ns1:Diagrama_PrimeraPalpacion_Z a ns1:Figura ;
    rdfs:label "Diagrama 'Primera palpación' (TDATA2)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': C=0°, B=+90°, contacto sobre cara Z con preselección Z=0; se destaca la rotación de B y el sistema de ejes X-Z."@es .

ns1:Diagrama_SegundaPalpacion_X a ns1:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (TDATA6)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=−90°, C=0°, palpación de la primera cara X con lectura ΔX′; se representa orientación del cabezal y referencias 1 y 2."@es .

ns1:Diagrama_SegundaPalpacion_Z a ns1:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (TDATA2)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': C=0°, B=−90°, repetición sobre cara Z con lectura ΔZ; ilustra el cambio del centro de giro ① y la lectura que interviene en la ecuación de TDATA2."@es .

ns1:Diagrama_TerceraPalpacion_X a ns1:Figura ;
    rdfs:label "Diagrama 'Tercera palpación' (TDATA6)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Tercera palpación': B=+90°, C=0°, palpación de la segunda cara X con lectura ΔX; muestra la simetría del procedimiento respecto al giro de B."@es .

ns1:Diagrama_TornoHorizontal a ns1:Esquema ;
    rdfs:label "Diagrama 'Torno horizontal'" ;
    ns1:documentadoEn ns1:HMI_ConfiguracionGraficos_2.11.9 ;
    ns1:textoExtracto "Representación esquemática del eje pieza con variantes de signo para X y Z (X±/Z±). Se muestran piezas y portaherramientas con las flechas de los ejes y sus sentidos, para seleccionar la proyección gráfica correcta por canal." .

ns1:Diagrama_TornoVertical a ns1:Esquema ;
    rdfs:label "Diagrama 'Torno vertical'" ;
    ns1:documentadoEn ns1:HMI_ConfiguracionGraficos_2.11.9 ;
    ns1:textoExtracto "Disposición vertical del husillo/plato con flechas de ejes X y Z en distintas combinaciones de signo; ayuda a elegir la vista del gráfico en máquinas verticales o doble torreta." .

ns1:DialogoCopiaSeguridad a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de copia de seguridad" ;
    ns1:textoExtracto "el CNC muestra la opción de guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido." .

