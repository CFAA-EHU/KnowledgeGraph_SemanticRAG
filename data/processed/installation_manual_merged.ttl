ns1:TablaDeParametrosParaConfiguracionDeEntradasSalidasDigitalesEnBusCANopenPag680681 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para configuración de entradas/salidas digitales en bus CANopen (pág. 680-681)"@es ;
    ns1:textoExtracto """\r
| Parámetro. | Significado. |\r
| --- | --- |\r
| NDIMOD | Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0). |\r
| DIMODADDR | Direcciones base de los bloques lógicos de entradas digitales. |\r
| MNEMONIC | Mnemónico del bloque lógico. |\r
| NODE | Número de nodo de la cabecera al que pertenece el bloque lógico. Valores posibles: De 1 a 126 (por defecto; 0). |\r
| BLOCK | Número de bloque lógico. Valores posibles: De 1 a 64 (por defecto; 0). |\r
| ADDRESS | Dirección base del bloque lógico. Valores posibles: De 1 a 1017 (por defecto; el primer valor válido). |\r
| NDI | Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0).\r
"""@es .

ns1:TablaDeVariablesAsociadasAVelocidadEnLazoDePosicionPag628 a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a velocidad en lazo de posición (pág. 628)"@es ;
    ns1:textoExtracto """\r
| Variables. | PRG | PLC | INT |\r
| --- | --- | --- | --- |\r
| (V.)[ch].A.TFEED.xn\r
(V.)[ch].A.TFEED.sn\r
(V.)[ch].SP.TFEED.sn\r
Valor instantáneo teórico de la velocidad a la entrada del lazo de\r
posición. Unidades: -. | R(*) | R | R |\r
| (V.)[ch].A.FEED.xn\r
(V.)[ch].A.FEED.sn\r
(V.)[ch].SP.FEED.sn\r
Valor instantáneo real de la velocidad a la entrada del lazo de posición. Unidades: -. | R(*) | R | R |\r
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

ns1:TablaDeVariablesParaAnalisisDelModoHSCPaginas630632 a ns1:Tabla ;
    rdfs:label "Tabla de variables para análisis del modo HSC (páginas 630-632)"@es ;
    ns1:textoExtracto """\r
| Variable. | Significado. |\r
| --- | --- |\r
| V.G.PARLIMF | Causa que limita el avance en el bloque en ejecución. |\r
| V.G.AXLIMF | Número lógico del eje que limita el avance, en el bloque en ejecución. |\r
| V.G.PARLIMC | Causa que limita el avance en la esquina, en el bloque actual. |\r
| V.G.AXLIMC | Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución. |\r
| V.G.LIMERROR | Valor del error que desactiva las splines (modo CONTERROR). |\r
| V.G.PATHFEED | Avance teórico sobre la trayectoria. |\r
| V.G.FREAL | Avance real sobre la trayectoria."""@es .

