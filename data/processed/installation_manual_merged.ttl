ns1:Parametro_fdeeb7d64c a ns1:Parametro ;
    rdfs:label "BKUPREG" ;
    ns1:identificador "BKUPREG" ;
    ns1:textoExtracto "BKUPREG Número de registros de PLC no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPREG Este parámetro indica el número de registros de PLC que se almacenan en la RAM con batería." ;
