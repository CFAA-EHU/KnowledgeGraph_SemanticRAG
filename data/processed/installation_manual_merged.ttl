    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal. # RET %L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:Rutina_M06 a ns1:ModoOperacion ;
    rdfs:label "Rutina de cambio automático de herramienta" ;
    ns1:compuestoPor ns1:GiroDelAlmacenDeHerramientas,
        ns1:SeleccionarPosicionLEAVEPOSYDescargarHerramientaDelCabezal,
        ns1:SeleccionarPosicionTAKEPOSYCargarHerramientaEnCabezal,
        ns1:TransferenciaDeHerramientaCabezalAlmacen ;
    ns1:identificador "M06" ;
    ns1:monitoreaParametro ns1:Registro_LEAVEPOS,
        ns1:Registro_TAKEPOS ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

ns1:SERCOUNTID4 a ns1:ComponenteElectrico ;
    ns1:identificador "SERCOUNTID=4" ;
    ns1:textoExtracto "módulo configurado como SERCOUNTID=4" ;
    ns1:tieneComponente ns1:IDNSercos33349 .

ns1:SERPOWSEValor7 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valor 7)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "7"@es ;
    ns1:valor "7" .

ns1:SERPOWSEValor8 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valor 8)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "8"@es ;
    ns1:valor "8" .

ns1:SERPOWSEValores14 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valores 1-4)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "1 a 4"@es ;
    ns1:valor "1-4" .

ns1:SERPOWSEValores56 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valores 5-6)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "5 a 6"@es ;
    ns1:valor "5-6" .

ns1:SHORTESTWAYPosicionamientoPorCaminoMasCorto_8e05cd50ab a ns1:Parametro ;
    rdfs:label "SHORTESTWAY (Posicionamiento por camino más corto)" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "SHORTESTWAY Posicionamiento por el camino más corto. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.SHORTESTWAY.xn" ;
    ns1:valor "No" .

ns1:SOFTFREQMPG a ns1:Parametro ;
    rdfs:label "SOFTFREQ MPG" ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPag621622 ;
    ns1:identificador "SOFTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado. Este parámetro se debe ajustar con ayuda de la aplicación FineTune."@es .

ns1:SPDLNAMEN a ns1:Parametro ;
    rdfs:label "SPDLNAME n" ;
    ns1:documentadoEn ns1:Tabla_SPDLNAME ;
    ns1:identificador "SPDLNAME_n" ;
    ns1:textoExtracto "SPDLNAME n Nombre de los cabezales. Valores posibles: S, S1ꞏꞏS9. Valor por defecto: Comenzando por SPDLNAME1; S, S1... Variable asociada: (V.)MPG.SPDLNAMEn Parámetro incluido en la tabla SPDLNAME." ;
    ns1:valor "S" .

ns1:SPDLTOGR a ns1:ModoOperacion ;
    rdfs:label "SPDLTOGR" ;
    ns1:textoExtracto "SET SPDLTOGR" .

ns1:SSICRCTYPETipoDeCRC a ns1:Parametro ;
    rdfs:label "SSICRCTYPE (Tipo de CRC)"@es ;
    ns1:textoExtracto "SSICRCTYPE Tipo de CRC. Valores posibles: No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN. Valor por defecto: No calcular CRC. Variable asociada: (V.)[ch].MPA.SSICRCTYPE[set].xn Cuando el encoder transmite información adicional a la cota, este parámetro define el tipo de cálculo a realizar para comprobar la coherencia en los datos."@es ;
    ns1:valor "No calcular CRC"@es .

ns1:SUBCH1TOMZLlevarLaHerramientaDeLaPinza1AlAlmacenM105FuncionAuxiliarParaEjecutarAccionVPLCM11051MarcaCH1TOMZAlGestor_db6f30de06 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_CH1_TO_MZ ; Llevar la herramienta de la pinza 1 al almacén. M105 ; Función auxiliar para ejecutar acción. V.PLC.M[1105]=1 ; Marca CH1TOMZ al gestor." .

ns1:SUBCH1TOSPDLlevarLaHerramientaDeLaPinza1AlCabezalM102FuncionAuxiliarParaEjecutarAccionVPLCM11021MarcaCH1TOSPDLAlGestor_c2a4b3498e a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal. M102 ; Función auxiliar para ejecutar acción. V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor." .

ns1:SUBGRTOSPDColocarLaHerramientaDeTierraEnElCabezalMSGInsertarHerramientaTDYPulsarMARCHAVTMNXTOOLMensajeAlOperarioParaQuePongaLaHerramientaM0EsperarAQueFinaliceLaOperacionMSGQuitarMensaje_08be6389dc a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal. # MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje." .

ns1:SUBM6NcESBLKActivarTratamientoDeBloqueUnicoDSTOPDeshabilitarTeclaSTOPM6OrdenAlGestorParaComenzarElCambioDeHerramienta_03d6b11ffa a ns1:Esquema ;
    ns1:textoExtracto "#SUB_M6.nc #ESBLK ; Activar tratamiento de bloque único #DSTOP ; Deshabilitar tecla STOP M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:SUBMZTOCH1CogerLaHerramientaDelAlmacenConLaPinza1M101FuncionAuxiliarParaEjecutarAccionVPLCM11011MarcaMZTOCH1AlGestor_120bebe9bb a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. M101 ; Función auxiliar para ejecutar acción. V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor." .

ns1:SUBPATHCHN a ns1:Parametro ;
    rdfs:label "SUBPATH CHN" ;
    ns1:identificador "CHN" ;
    ns1:monitoreaParametro ns1:Maquina_8055 ;
    ns1:textoExtracto "Parámetro máquina; general del canal. Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." .

ns1:SUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1M103FuncionAuxiliarParaEjecutarAccionVPLCM11031MarcaSPDLTOCH1AlGestor_04707e7a9e a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1. M103 ; Función auxiliar para ejecutar acción. V.PLC.M[1103]=1 ; Marca SPDLTOCH1 al gestor." .

ns1:SUBSPDTOGRQuitarLaHerramientaDelCabezalLlevarlaATierraMSGExtraerHerramientaTDYPulsarMARCHAVTMTOOLMensajeAlOperarioParaQueQuiteLaHerramientaM0EsperarAQueFinaliceLaOperacionMSGQuitarMensajeVPLCM11071MarcaSPDLTOGRAlGestor_37d200a0e0 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra). # MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje. V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor." .

ns1:SURFFILFREQMPG a ns1:Parametro ;
    rdfs:label "SURFFILFREQ MPG" ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPag621622 ;
    ns1:identificador "SURFFILFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave."@es .

ns1:SalidaDelFiltroDePrecargaTFILTOUT a ns1:Parametro ;
    rdfs:label "Salida del filtro de precarga (TFILTOUT)" ;
    ns1:documentadoEn ns1:TablaDeVariablesAsociadasAlTandemPag579_27515f38b8 ;
    ns1:identificador "(V.)[ch].A.TFILTOUT.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TFILTOUT.xn | Salida del filtro de precarga" .

ns1:SalidaDelPIDelEjeMaestroDelTandemTPIOUT a ns1:Parametro ;
    rdfs:label "Salida del PI del eje maestro del tándem (TPIOUT)" ;
    ns1:documentadoEn ns1:TablaDeVariablesAsociadasAlTandemPag579_27515f38b8 ;
    ns1:identificador "(V.)[ch].A.TPIOUT.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TPIOUT.xn | Salida del PI del eje maestro del tándem (en rpm)" ;
    ns1:valor "rpm"^^xsd:string .

ns1:SalidaEstado a ns1:Parametro ;
    rdfs:label "Salida de estado" ;
    ns1:textoExtracto "Indica el estado lógico del temporizador. Se referencia mediante la letra T seguida del número de temporizador que se desea referenciar, por ejemplo T1, T25, T102, etc." .

ns1:SalidaPieza a ns1:Parametro ;
    rdfs:label "Salida de la pieza" ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Si la herramienta está saliendo de la pieza, el DMC se desactiva cuando finaliza la salida. [...] seguirá detectando las salidas de pieza." .

ns1:Salida_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida O3"@es ;
    ns1:identificador "O3" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2."@es .

ns1:Salida_Estado_C a ns1:ComponenteElectrico ;
    rdfs:label "Salida estado C" ;
    ns1:identificador "C" ;
    ns1:textoExtracto "Todos los contadores disponen de la salida estado C [...]"^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Salida_O12 a ns1:Parametro ;
    rdfs:label "Salida O12" ;
    ns1:identificador "O12" ;
    ns1:textoExtracto "CPS T2 EQ 2000 = O12" .

ns1:Salida_O2 a ns1:Parametro ;
    rdfs:label "Salida O2" ;
    ns1:identificador "O2" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." ;
    ns1:valor "1" .

ns1:Salida_O6 a ns1:Parametro ;
    rdfs:label "Salida O6" ;
    ns1:identificador "O6" ;
    ns1:textoExtracto "(I12 AND I23) OR M54 = O6" .

ns1:Salida_O8 a ns1:Parametro ;
    rdfs:label "Salida O8" ;
    ns1:identificador "O8" ;
    ns1:textoExtracto "NOT M14 AND NOT B7R120 = O8" .

ns1:Salida_SystemOK a ns1:Parametro ;
    rdfs:label "System OK" ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "Si es correcta activa la salida System OK."@es .

ns1:ScriptConfiguracion_OpenPCS_1530 a ns1:Componente ;
    rdfs:label "Script de configuración de OpenPCS" ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_1530 ;
    ns1:textoExtracto "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."^^rdfs:Literal .

ns1:SeAconsejaIncluirLaGestionDelCambioDeHerramientaEnLaRutinaAsociadaAM06YDejarComoLaborDelPLCElControlDeLosDispositivosExternos a ns1:Sistema ;
    ns1:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos." .

ns1:SeDisponeDeUnGrupoDeMarcasParaCadaAlmacen a ns1:Componente ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén." .

ns1:Se_alACTFBACK a ns1:Parametro ;
    rdfs:label "Marca ACTFBACK(axis)"@es ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna. [...] El CNC pone esta marca a (=1) para indicar que se está trabajando con la captación externa (captación directa)."@es ;
    ns1:valor "1 (captación externa), 0 (captación interna)" .

ns1:Se_alAXISNEG a ns1:ComponenteElectrico ;
    rdfs:label "AXISNEG(axis)" ;
    ns1:controla ns1:MovimientoEjeNegativo ;
    ns1:identificador "AXISNEG" ;
    ns1:textoExtracto "AXISNEG(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, negativo (NEG)."@es .

ns1:Se_alAXISPOS a ns1:ComponenteElectrico ;
    rdfs:label "AXISPOS(axis)" ;
    ns1:controla ns1:MovimientoEjePositivo ;
    ns1:identificador "AXISPOS" ;
    ns1:textoExtracto "AXISPOS(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, positivo (POS)."@es .

ns1:Se_alDRENAV a ns1:Parametro ;
    rdfs:label "Habilitación del regulador del eje V (DRENAV)"@es ;
    ns1:identificador "DRENAV" ;
    ns1:monitoreaParametro ns1:ReguladorEjeDigital ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV = SPENAV = SERVOVON."@es .

ns1:Se_alDetencionSincronizacion a ns1:ComponenteElectrico ;
    rdfs:label "Señal de detención de sincronización" ;
    ns1:monitoreaParametro ns1:VelocidadDeEje ;
    ns1:textoExtracto "electrónica, si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula. El sistema permanece en espera hasta que se desactive la señal para reanudar la ejecución y el movimiento desde el punto en el que se detuvo."@es .

ns1:Se_alENABLE a ns1:ComponenteElectrico ;
    rdfs:label "ENABLE(axis)" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "Para controlar el eje sólo en los desplazamientos, se debe utilizar la marca ENABLE. [...] El CNC la pone a (=1) cada vez que quiere mover el eje."@es .

ns1:Se_alEmergencia_Gestor a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Señal de emergencia del gestor." .

ns1:Se_alEnableEje a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE(axis)"@es ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "El CNC la pone a (=1) cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418."@es .

ns1:Se_alFBACKSEL a ns1:Parametro ;
    rdfs:label "Marca FBACKSEL(axis)"@es ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El tipo de captación se podrá conmutar desde el PLC mediante la marca FBACKSEL(axis)."@es .

ns1:Se_alPARK a ns1:Parametro ;
    rdfs:label "Señal PARK"@es ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El CNC pone la marca PARK a (=1) y comienza a aparcar el eje. [...] Se resetea la señal PARK."@es ;
    ns1:valor "1" .

ns1:Se_alSERVOON a ns1:ComponenteElectrico ;
    rdfs:label "SERVO(axis)ON" ;
    ns1:habilitadoPor ns1:CondicionServoON ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "Esta marca debe estar a (=1) para permitir el movimiento (desbloqueo) del eje correspondiente. Si durante el desplazamiento del eje o cabezal se pone la marca SERVO(axis)ON a (=0) el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente."@es .

ns1:Se_alUNPARK a ns1:Parametro ;
    rdfs:label "Señal UNPARK"@es ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El CNC pone la marca UNPARK a (=1) y comienza a desaparcar el eje. [...] Se resetea la señal UNPARK."@es ;
    ns1:valor "1" .

ns1:Se_al_ADVINPOS a ns1:ComponenteElectrico ;
    rdfs:label "Señal lógica ADVINPOS" ;
    ns1:controla ns1:SistemaExc_ntrica ;
    ns1:textoExtracto "El parámetro indica cuanto tiempo antes de llegar los ejes a posición se activa la señal lógica de anticipación ADVINPOS del canal. Esta señal se puede utilizar para iniciar el movimiento del punzón antes de que los ejes alcancen la posición." .

ns1:Se_al_FEEDHOL a ns1:Actuador ;
    rdfs:label "_FEEDHOL" ;
    ns1:identificador "_FEEDHOL" ;
    ns1:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

ns1:Se_al_FHOUT a ns1:Sensor ;
    rdfs:label "FHOUT" ;
    ns1:identificador "FHOUT" ;
    ns1:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:Se_al_INTOL a ns1:Parametro ;
    rdfs:label "Señal INTOL (PLC)" ;
    ns1:textoExtracto "El palpado finalizará cuando se desactive la señal INTOL del PLC." ;
    ns1:valor "Desactivada"^^xsd:string .

ns1:Se_al_START a ns1:Sensor ;
    rdfs:label "START" ;
    ns1:identificador "START" ;
    ns1:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:Se_al_XFERINH a ns1:InterfazUsuario ;
    rdfs:label "Señal _XFERINH" ;
    ns1:documentadoEn ns1:SistemaControlCNC ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para _XFERINH" .

ns1:Seccion_6_8_SenalesModificablesGenerales a ns1:Capitulo ;
    rdfs:label "Sección 6.8 Señales modificables generales" ;
    ns1:documentadoEn ns1:Pagina_ae525e2d4e ;
    ns1:textoExtracto "Señales modificables generales. AUXEND Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes: AUXENDC1, AUXENDC2, AUXENDC3, AUXENDC4." .

ns1:SecuenciaDeTMOPERATION10 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 10" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra." .

ns1:SecuenciaDeTMOPERATION11 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 11" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:SecuenciaDeTMOPERATION8 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 8" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SecuenciaDeTMOPERATION9 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 9" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Coger la herramienta del cabezal con la pinza 2 y activar la marca SPDLTOCH2. 3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK, si se desea, para que continúe la ejecución del programa. 5 Dejar la herramienta de la pinza 2 en el almacén y activar la marca CH2TOMZ." .

ns1:SecuenciaOperacion1 a ns1:ModoOperacion ;
    rdfs:label "Primera secuencia" ;
    ns1:textoExtracto "Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SecuenciaOperacion2 a ns1:ModoOperacion ;
    rdfs:label "Segunda secuencia" ;
    ns1:textoExtracto "Segunda secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SecuenciaParametros_12_1_4 a ns1:Parametro ;
    rdfs:label "Secuencia de valores para archivo de parámetros"@es ;
    ns1:identificador "12.1.4" ;
    ns1:textoExtracto "4 X(P1) Y(P1) Z(P2) X(P2) Y(P1) Z(P2) Z X(Pn) Y(P1) Z(P2) X Y X(Pn) NPOINTAX1 Y(Pn) X(P4) NPOINTAX2 Z(P2) X(P3) Y(P2) X(P2) XYZ(P1) 5 X(P1) Y(P2) Z(P2) X(P2) Y(P2) Z(P2) Z X(Pn) Y(P2) Z(P2) X(P1) Y(Pn) Z(P2) X Y X(P2) Y(..."@es .

ns1:Secuencia_AlignC_Diametral a ns1:ModoOperacion ;
    rdfs:label "ALIGNC = Sí (mecanizado diametral)"@es ;
    ns1:documentadoEn ns1:Pagina_d9e5061d23 ;
    ns1:textoExtracto "Secuencia 'ALIGNC = Sí' (3 viñetas): mecanizado diametral con herramienta que sólo cubre media superficie; se muestra (1) avance hasta el centro, (2) giro de 180° del eje C y (3) retroceso para completar el mecanizado, indicando la necesidad de reorientar el eje para cubrir todo el diámetro."@es .

ns1:SegundoTecladoEnElBusVolantes456 a ns1:InterfazUsuario ;
    rdfs:label "Segundo teclado en el bus (volantes -4, -5, -6)"@es ;
    ns1:identificador "-4,-5,-6" ;
    ns1:ilustradoEn ns1:Tabla_OrdenVolantesManual ;
    ns1:textoExtracto "Segundo teclado en el bus. | -4 -5 -6"@es .

ns1:SeleccionDeTipoDeAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Selección de tipo de aceleración"@es ;
    ns1:ejecutadoPor ns1:Personal_Operador ;
    ns1:requiereMantenimiento ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "Para seleccionar una aceleración distinta desde el programa pieza, para el modo automático, utilizar la sentencia #SLOPE."@es .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDelCabezal a ns1:Parametro ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYPonerLaHerramientaEnElCabezal a ns1:Parametro ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

ns1:SeleccioneLaProximaHerramientaEnElAlmacen a ns1:Componente ;
    ns1:textoExtracto "seleccione la próxima herramienta en el almacén" .

ns1:SelectorMovimientos a ns1:InterfazUsuario ;
    rdfs:label "Selector de movimientos"@es ;
    ns1:habilitadoPor ns1:ModoSeleccionEjesVolante ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos [...]."@es .

ns1:SenalEmergenciaGestor a ns1:Sensor ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:SenalFEEDHOL a ns1:Sensor ;
    rdfs:label "_FEEDHOL"@en ;
    ns1:textoExtracto "señales _STOP o _FEEDHOL"@es .

ns1:SenalPLCABORT a ns1:Parametro ;
    rdfs:label "Señal PLCABORT (por canal)"@es ;
    ns1:identificador "PLCABORT" ;
    ns1:textoExtracto "PLCABORT [...] Hay una marca para cada canal"@es .

ns1:SenalPWMDesdeCNC a ns1:ComponenteElectrico ;
    rdfs:label "Señal PWM desde CNC"@es ;
    ns1:compuestoPor ns1:SistemaControlPWM ;
    ns1:textoExtracto "Estado del PWM desde el CNC"@es .

ns1:SenalPWMDesdePLC a ns1:ComponenteElectrico ;
    rdfs:label "Señal PWM desde PLC"@es ;
    ns1:compuestoPor ns1:SistemaControlPWM ;
    ns1:textoExtracto "Estado del PWM desde el PLC"@es .

ns1:SenalRETRACTRetiradaDeEjes a ns1:InterfazUsuario ;
    rdfs:label "Señal RETRACT (retirada de ejes)" ;
    ns1:habilitadoPor ns1:Parametro_d3fa2731be ;
    ns1:identificador "RETRACT (RETRACTC1-4)" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado. El canal del CNC pone esta señal a nivel lógico alto cuando empieza a retirar los ejes de la pieza, y la mantiene así hasta que finaliza el movimiento." .

ns1:SenalREVOK a ns1:Sensor ;
    rdfs:label "Señal REVOK" ;
    ns1:controla ns1:Maquina_Cabezal ;
    ns1:textoExtracto "La señal REVOK se pone a nivel lógico alto cuando las revoluciones reales del cabezal se encuentran entre dichos porcentajes. La señal REVOK se puede utilizar para gestionar la señal Feed-hold y evitar el mecanizado con revoluciones inferiores y superiores a las programadas." .

ns1:SenalSANALOG a ns1:Parametro ;
    rdfs:label "Señal SANALOG (desde PLC)"@es ;
    ns1:textoExtracto "Cuando sea necesario utilizar la señal SANALOG desde PLC, su valor también vendrá expresado en diezmilésimas de milímetro o milésimas de grado."@es ;
    ns1:valor "0.0001 mm o 0.001°"@es .

ns1:SenalSANALOGDesdePLC a ns1:Parametro ;
    rdfs:label "Señal SANALOG desde PLC"@es ;
    ns1:textoExtracto "su valor también vendrá expresado en diezmilésimas de rpm del motor."@es ;
    ns1:valor "diezmilésimas de rpm"@es .

ns1:SenalSTOP a ns1:Sensor ;
    rdfs:label "_STOP"@en ;
    ns1:textoExtracto "señales _STOP o _FEEDHOL"@es .

