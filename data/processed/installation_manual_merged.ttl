ns1:ParametrosAceleracionG0 a ns1:Sistema ;
    rdfs:label "Sistema de parámetros de aceleración en G0" ;
    ns1:requiereMantenimiento ns1:ModoFAST,
        ns1:MovimientoG0 ;
    ns1:textoExtracto "Los parámetros LACC1G0 y LACC2G0 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE) o cuando se trabaja con HSC en modo FAST. El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ns1:tieneComponente ns1:Parametro_47aa74aeeb,
        ns1:Parametro_8b482c2aa1,
        ns1:Parametro_9e669bb2d9,
        ns1:Parametro_db5f50cd24 .

ns1:ParametrosComunicacionHMI_666 a ns1:Parametro ;
    rdfs:label "Parámetros de comunicación HMI-CNC"@es ;
    ns1:monitoreaParametro ns1:InterfazHMI_666 ;
    ns1:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC. Para validar los cambios que se realicen en estos parámetros es necesario reinicializar el CNC."@es .

ns1:ParametrosDeConfiguracion a ns1:Parametro ;
    rdfs:label "parámetros de configuración"@es ;
    ns1:textoExtracto "Cada almacén tiene sus propios parámetros de configuración."@es .

ns1:ParametrosDeConfiguracionDeNesting a ns1:Parametro ;
    rdfs:label "Parámetros de configuración de nesting" ;
    ns1:documentadoEn ns1:ManualDeLosModelosCNC8060Y8070 ;
    ns1:textoExtracto "material, espesor, longitud y anchura de la chapa, márgenes izquierdo/derecho y superior/inferior"@es .

ns1:ParametrosDelReguladorDRIVE a ns1:Parametro ;
    rdfs:label "Parámetros del regulador (DRIVE)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "DRIVE: Lista de parámetros del regulador, que equivalen a cada parámetro del CNC."@es .

ns1:ParametrosEjesCabezales a ns1:Parametro ;
    rdfs:label "Parámetros de ejes y cabezales" ;
    ns1:textoExtracto "Estos parámetros indican las propiedades de los ejes y cabezales, límites de recorrido, condiciones de desplazamiento, volantes asociados, trabajo con palpador, compensaciones, etc. Cada eje o cabezal puede disponer de hasta 4 sets de trabajo. En cada uno de ellos hay que definir el ajuste de los avances y ganancias, búsquedas de referencia, aceleraciones, etc." .

ns1:ParametrosGenerales a ns1:Parametro ;
    rdfs:label "Parámetros generales" ;
    ns1:textoExtracto "Estos parámetros definen el nombre de los ejes y cabezales, condiciones tras el encendido, rutinas asociadas a determinadas funciones, etc. Algunos de estos parámetros hay que definirlos en primer lugar porque configuran las tablas de parámetros de ejes. Por ejemplo, el número y denominación de los ejes y cabezales, etc." .

ns1:ParametrosMaquina a ns1:Parametro ;
    rdfs:label "Parámetros máquina",
        "parámetros máquina"@es ;
    ns1:monitoreaParametro ns1:SistemaCNC8070 ;
    ns1:textoExtracto "En los parámetros máquina se define el número de almacenes disponibles y las características de cada uno."@es ;
    ns1:valor "tabla de levas de los parámetros máquina" .

ns1:ParametrosMaquinaDelCNC a ns1:Parametro ;
    rdfs:label "Parámetros máquina del CNC"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "CNC: Lista de parámetros máquina del CNC."@es .

ns1:ParametrosMaquina_Compensacion a ns1:Parametro ;
    rdfs:label "Parámetros máquina para compensación" ;
    ns1:monitoreaParametro ns1:CompensacionVolumetrica_Basica ;
    ns1:textoExtracto "El OEM debe definir en los parámetros máquina todos los datos de la compensación (ejes que se mueven, ejes a compensar, posición y tamaño del volumen a compensar, etc) y seleccionar el fichero que contiene los datos de la compensación." .

ns1:ParametrosMaquina_ConfiguracionOriginal a ns1:Parametro ;
    rdfs:label "Parámetros máquina (configuración original de canales)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionAXISEXCH ;
    ns1:textoExtracto "La configuración original (la definida en los parámetros máquina) de un canal con ejes y cabezales del tipo AXISEXCH=Mantenido, se puede recuperar bien validando los parámetros máquina o bien deshaciendo los cambios, por ejemplo con un programa pieza. Hay que tener en cuenta que al validar los parámetros máquina se restablece la configuración de todos los canales."@es .

ns1:ParametrosModoManual a ns1:Parametro ;
    rdfs:label "Parámetros del modo manual" ;
    ns1:textoExtracto "Extrae solo la A-Box canonica correspondiente a este fragmento." .

ns1:ParametrosRelacionadosConLaGestionDelAlmacen a ns1:Parametro ;
