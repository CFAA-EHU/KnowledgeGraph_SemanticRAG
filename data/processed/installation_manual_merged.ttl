    ns1:monitoreaParametro ns1:Variable_DRV_Mechatrolink,
        ns1:Variable_DRV_Sercos ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

ns1:Parametro_2545d5fa63 a ns1:Parametro ;
