    ns1:monitoreaParametro ns1:ParametroSANALOG_Posicion ;
    ns1:textoExtracto "Cabezal Sercos en posición. La consigna en SANALOG vendrá expresada en diezmilésima de grado." .

ns1:CabezalSercosVelocidad a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Sercos (modo velocidad)" ;
    ns1:monitoreaParametro ns1:ParametroSANALOG_Velocidad ;
    ns1:textoExtracto "Cabezal Sercos en velocidad. La consigna en SANALOG vendrá expresada en diezmilésima de rpm." .

ns1:CabezalTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (cinemática tipo 52)"@es ;
    ns1:textoExtracto "Cabezal: T1: Vector traslación del primer eje rotativo. T2: Vector traslación del segundo eje rotativo. T3: Vector traslación del portaherramientas."@es ;
    ns1:tieneComponente ns1:EjeRotativo1_Cabezal,
        ns1:EjeRotativo2_Cabezal,
        ns1:Portaherramientas_Cabezal .

ns1:Cabezal_Generico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (genérico)" ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn [...] el CNC comienza a enviar consigna a dicho cabezal" ;
    ns1:tieneComponente ns1:ComponenteElectrico_SLIMITACSPDL .

ns1:Cabezal_Indice1 a ns1:Componente,
        ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es,
        "Cabezal con índice 1 (SPDLNAME 1)"@es ;
    ns1:documentadoEn ns1:Pagina_560,
        ns1:Tabla_ConfiguracionEjesCabezales_1023 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ10ꞏ. Selección de planos en el canal ꞏ1ꞏ."@es,
        "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ. Selección de planos en el canal ꞏ1ꞏ."@es,
        "SPDLNAME 1 [...] Cabezal con índice ꞏ1ꞏ."@es .

ns1:Cabezal_Indice1_1041 a ns1:ComponenteMecanico ;
