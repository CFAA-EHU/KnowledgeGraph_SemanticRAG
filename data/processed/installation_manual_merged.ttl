    ns1:textoExtracto "El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de la marca _FEEDHOL." .

ns1:InterfazUsuario_ModoSetup a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de Modo Setup" ;
