ns1:Ejemplo1_CPS_C12_GT_R14 a ns1:Tabla ;
    rdfs:label "Ejemplo CPS: Comparación GT (C12 > R14)"@es ;
    ns1:ilustradoEn ns1:Instruccion_CPS ;
    ns1:textoExtracto "| CPS C12 GT R14 = M100 | Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario. |"@es .

ns1:Ejemplo2_CPS_T2_EQ_100 a ns1:Tabla ;
    rdfs:label "Ejemplo CPS: Comparación EQ (T2 == 100)"@es ;
    ns1:ilustradoEn ns1:Instruccion_CPS ;
    ns1:textoExtracto "| CPS T2 EQ 100 = TG1 5 2000 | Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100, se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s. |"@es .

ns1:EjemploFuncionamientoCNC_PLC_493_494 a ns1:ModoOperacion ;
    rdfs:label "Ejemplo de funcionamiento CNC-PLC (pág. 493-494)"@es ;
    ns1:controla ns1:SistemaGestionPLC_493 ;
    ns1:textoExtracto "Ejemplo de funcionamiento. El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es ;
    ns1:tieneComponente ns1:Herramienta_T7,
        ns1:Herramienta_T8,
        ns1:Herramienta_T9 .

ns1:EjemploProgramacionPLC_638 a ns1:Sistema ;
    rdfs:label "Ejemplo de programación PLC"@es ;
    ns1:compuestoPor ns1:DirectivaEND_638,
        ns1:DirectivaPRG_638,
        ns1:InstruccionI100_M102_638,
        ns1:InstruccionM300_638,
        ns1:InstruccionO25_638 ;
    ns1:identificador "PRG_638" ;
    ns1:textoExtracto """\r
| Ejemplo de programación: |  |\r
| --- | --- |\r
| PRG | ; Proposición directiva |\r
| ; Ejemplo | ; Comentario |\r
| I100 = M102 | ; Proposición ejecutable |\r
| I28 AND I30 | ; Expresión lógica |\r
| = O25 | ; Instrucción de acción |\r
| I32 \\ | ; Instrucción de consulta (1ª parte de expresión) |\r
| AND I36 | ; Instrucción de consulta (2ª parte de expresión) |\r
| = M300 | ; Instrucción de acción |\r
| END | ; Proposición directiva """@es .

