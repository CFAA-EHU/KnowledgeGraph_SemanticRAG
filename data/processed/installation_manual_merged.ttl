ns1:Sistema_SimulacionTecladoPLC a ns1:Sistema ;
    rdfs:label "Sistema de simulación de teclado desde PLC"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_8.4_SimulacionTecladoPLC ;
    ns1:textoExtracto """\r
La primera tecla de usuario (B0KEYBD1) envía el carácter "a".\r
La segunda tecla de usuario (B1KEYBD1) envía el carácter "A".\r
Combinación de teclas. Para simular desde el PLC una combinación de teclas (por ejemplo [CTRL]+[F1]).\r
""" ;
    ns1:tieneComponente ns1:TeclaUsuario_B0KEYBD1,
        ns1:TeclaUsuario_B1KEYBD1 .

ns1:Sistema_SincronizacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de ejes y cabezales" ;
    ns1:textoExtracto "SYNCSET Set de parámetros para la sincronización. [...] Si los cabezales maestro y esclavo se encuentra en el mismo canal, el cabezal maestro asume el set definido en su parámetro SYNCSET. [...] Cuando los cabezales se sincronizan en velocidad, el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio)." ;
    ns1:tieneComponente ns1:Parametro_DSYNCVELW,
        ns1:Parametro_SYNCSET .

