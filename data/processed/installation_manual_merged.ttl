ns1:Variable_CUTTING a ns1:Parametro ;
    rdfs:label "Marca CUTTING (V.PLC.CUTTING)" ;
    ns1:textoExtracto "El OEM debe gestionar la marca CUTTING desde estas subrutinas. [...] Esta marca refleja el estado de la variable V.PLC.CUTTING." ;
