ns1:ModuloHardware_OpenPCS_1530 a ns1:Componente ;
    rdfs:label "Módulo hardware de OpenPCS remoto" ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_1530 ;
    ns1:textoExtracto "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."^^rdfs:Literal .

ns1:ModuloLimiteDeVuelta a ns1:Parametro ;
    rdfs:label "Módulo (límite de vuelta)"@es ;
    ns1:monitoreaParametro ns1:MovimientoIncrementalNormal ;
    ns1:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es ;
    ns1:valor "1 vuelta"@es .

ns1:ModuloPE100 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PE 100" ;
    ns1:identificador "PE 100" ;
    ns1:textoExtracto "PE 100 [...] END" .

ns1:ModuloPeriodicoPE a ns1:ComponenteElectrico ;
    rdfs:label "Módulo periódico (PE)" ;
    ns1:textoExtracto "Módulo periódico (PE) El procesamiento del módulo periódico se desarrolla de la siguiente forma: 1 EL PLC tiene en cuenta los valores que disponen, al comienzo de la ejecución del módulo, las entradas físicas (módulos remotos). 2 El PLC ejecuta el módulo periódico. 3 EL PLC asigna a las salidas físicas (módulos remotos) los valores que disponen en este momento los recursos O del PLC. 4 El PLC da por finalizada la ejecución del módulo periódico." .

ns1:ModuloPeriodicoPE30000 a ns1:Sistema ;
    rdfs:label "Módulo periódico PE 30000" ;
    ns1:identificador "PE 30000" ;
    ns1:textoExtracto "Una tarea que es suficiente evaluarla cada 30 segundos se definirá en un módulo periódico que se ejecute cada 30 segundos (PE 30000)" ;
    ns1:tieneFrecuencia ns1:Frecuencia_30segundos .

ns1:ModuloPrincipalPRG a ns1:ComponenteElectrico ;
    rdfs:label "Módulo principal (PRG)" ;
    ns1:textoExtracto "Módulo principal (PRG) El procesamiento del módulo principal se desarrolla de la siguiente forma: 1 El PLC asigna a los recursos I los valores que disponen en este momento las entradas físicas (módulos remotos). 2 El PLC asume los valores que disponen las variables internas del CNC (CNCREADY, START, FHOUT, ...). 3 El PLC ejecuta el módulo principal (PRG). 4 El PLC actualiza las variables internas del CNC (EMERGEN, STOP, FEEDHOL, ...) con los valores que disponen en este momento los recursos asociados del PLC. 5 EL PLC asigna a las salidas físicas (módulos remotos) los valores que disponen en este momento los recursos O del PLC. 6 El PLC da por finalizado el ciclo, encontrándose preparado para comenzar uno nuevo." .

ns1:ModuloRCS_S_1391 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:monitoreaParametro ns1:Parametro_381319e81c,
        ns1:Parametro_52b7e95117 ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en [...] una contadora Sercos. La selección se realiza mediante los parámetros COUNTERTYPE y COUNTERID."@es .

ns1:ModuloRIO5Address1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIO5 (address = 1)" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "(address = 1) RIO5 - Entradas analógicas. - 1..4 - Entradas PT100. - 5..6" ;
    ns1:tieneComponente ns1:EntradaPT1001Direccion5,
