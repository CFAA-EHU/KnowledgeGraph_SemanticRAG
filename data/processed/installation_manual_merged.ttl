    ns1:identificador "(V.)[ch].MPG.MAXACCEL" ;
    ns1:monitoreaParametro ns1:Variable_Temporal_MAXACCEL ;
    ns1:textoExtracto "Máxima aceleración sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 600000000.0000 mm/min / de 0.00004 a 23622047.24409 inch/min. Valor por defecto: No hay avance máximo. Este parámetro permite suavizar el avance sobre la trayectoria, limitando la aceleración máxima sobre ella." ;
    ns1:valor "600000000.0000 mm/min (límite superior)" .

