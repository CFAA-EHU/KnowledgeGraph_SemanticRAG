    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "Configurar los gráficos para los ciclos de ejes rotativos [...] Si no están parametrizados los ejes, la posición por defecto de la herramienta en las diferentes configuraciones de máquina será la siguiente." .

ns1:InterfazUsuario_GraficosCiclosEjesRotativos a ns1:InterfazUsuario ;
    rdfs:label "Gráficos para ciclos de ejes rotativos" ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "Configurar los gráficos para los ciclos de ejes rotativos. Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS) y según la opción elegida en la tabla de herramientas." .

ns1:InterfazUsuario_HBLS a ns1:InterfazUsuario ;
