    ns1:ilustradoEn ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "PowerSetPoint (potencia objetivo aprendida). 34.73 %"@es ;
    ns1:valor "34.73"^^xsd:string .

ns1:PrecargaDelEjeTandem a ns1:Parametro ;
    rdfs:label "Precarga del eje tándem"@es ;
    ns1:textoExtracto "Par previo aplicado a ambos ejes del tándem en sentidos opuestos."@es ;
    ns1:valor "par previo (sentidos opuestos)"@es .

ns1:PrecargaDelEjeTandem_9ade44f014 a ns1:Parametro ;
    rdfs:label "Precarga del eje tándem"@es ;
    ns1:monitoreaParametro ns1:ConfiguracionEjeTandem_1177 ;
    ns1:textoExtracto "Par previo aplicado a ambos ejes del tándem en sentidos opuestos. De esta manera se establece una tracción entre ellos con el fin de eliminar la holgura piñón-cremallera cuando se encuentra en reposo."@es .

ns1:PrecargaPRELOAD a ns1:Parametro ;
    rdfs:label "Precarga (PRELOAD)" ;
    ns1:documentadoEn ns1:TablaDeVariablesAsociadasAlTandemPag579_27515f38b8 ;
    ns1:identificador "(V.)[ch].A.PRELOAD.xn" ;
    ns1:textoExtracto "(V.)[ch].A.PRELOAD.xn | Precarga" .

ns1:PrimerTecladoEnElBusVolantes123 a ns1:InterfazUsuario ;
    rdfs:label "Primer teclado en el bus (volantes -1, -2, -3)"@es ;
    ns1:identificador "-1,-2,-3" ;
    ns1:ilustradoEn ns1:Tabla_OrdenVolantesManual ;
    ns1:textoExtracto "Primer teclado en el bus. | -1 -2 -3"@es .

ns1:ProcedimientoDePalpacionParaCalculoDeTDATA1 a ns1:TareaMantenimiento ;
    rdfs:label "Procedimiento de palpación para cálculo de TDATA1"@es ;
    ns1:monitoreaParametro ns1:TDATA1ParametroDeCalculoParaCabezalAngular ;
    ns1:requiereMantenimiento ns1:Sistema_CabezalesRotativos ;
    ns1:textoExtracto "Primera palpación. Con los ejes rotativos B y C posicionados en 0º realizar un movimiento de palpación sobre la cara Z y preseleccionar la cota Z=0. Segunda palpación. Con el eje rotativo B posicionado en 0º y el eje C en 180º realizar un movimiento de palpación sobre la misma cara."@es .

ns1:ProcesoAjusteTandem_1181 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de ajuste del tándem"@es ;
    ns1:requiereMantenimiento ns1:MaquinaTandem_1181 ;
    ns1:textoExtracto "En este proceso debe tenerse en cuenta el tipo de máquina de la que se dispone. En general, una máquina tándem posee frecuencia de resonancia baja; por lo tanto, el CNC debe generar consignas de posición sin componentes frecuenciales superiores a la frecuencia de resonancia. Es recomendable iniciar el proceso con valores de jerk bajos (menores de 10 m/sg3) y Kv baja. Siempre es posible aumentarlos en un reajuste posterior."@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaResonanciaBaja_1181 .

ns1:ProcesoAjusteTandem_1182 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de ajuste del tándem"@es ;
    ns1:monitoreaParametro ns1:ACForwardACFGAIN,
        ns1:Parametro_57bb7ed26d,
        ns1:Parametro_d1102e08cb ;
    ns1:requiereMantenimiento ns1:SistemaTandem_1182 ;
    ns1:textoExtracto "En caso de que los motores sean diferentes, deben ajustarse los ejes de tal manera que la respuesta dinámica sea la misma o similar. [...] Para finalizar, reajustar el lazo de velocidad en ambos motores con el método utilizado normalmente."@es .

ns1:ProcesoBusquedaCero a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de cero"@es ;
    ns1:ejecutadoPor ns1:ReguladorSercosPosicion ;
    ns1:textoExtracto "el proceso de búsqueda de cero. [...] La búsqueda de cero la controla el regulador."@es .

ns1:ProcesoBusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia (ejes y cabezales)" ;
    ns1:controla ns1:SistemaCaptacion_I0 ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionReferencia ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación con I0s codificados. Cuando el eje pulsa el micro, invierte el sentido y se desplaza al avance indicado en el parámetro REFFEED2. El desplazamiento continúa, tras soltar el micro, hasta que el CNC recibe un impulso de I0 del sistema de captación." .

ns1:ProcesoBusquedaReferencia_Gantry a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia máquina (ejes gantry)"@es ;
    ns1:monitoreaParametro ns1:Param_REFDIREC,
        ns1:Param_REFFEED1,
        ns1:Param_REFFEED2,
        ns1:Param_REFSHIFT,
        ns1:Param_REFVALUE ;
    ns1:textoExtracto "El CNC comenzará el desplazamiento de ambos ejes en el sentido indicado por el parámetro REFDIREC del eje maestro. Este desplazamiento se realiza al avance indicado en el parámetro REFFEED1 del eje maestro, hasta que alguno de los ejes pulse su micro."@es .

ns1:ProcesoCalibracionCabezalAngular_1450 a ns1:TareaMantenimiento ;
    rdfs:label "Calibración del cabezal angular con reloj comparador"@es ;
    ns1:ejecutadoPor ns1:PersonalTecnico_1450 ;
    ns1:ilustradoEn ns1:InterfazCNC_TDAT1_1450 ;
    ns1:requiereMantenimiento ns1:CabezalAngular_1450 ;
    ns1:textoExtracto "Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal. [...] Apuntar la cota que aparece en el CNC (Y)."@es .

ns1:ProcesoCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "proceso de cambio de herramienta" ;
    ns1:compuestoPor ns1:PasoCogerHerramienta,
        ns1:PasoContinuarEjecucion,
        ns1:PasoDejarHerramienta,
        ns1:PasoFinalizarMovimiento,
        ns1:PasoSeleccionHerramienta ;
    ns1:textoExtracto "El cambio de herramienta se realiza de la siguiente manera (ejemplo con 2 pinzas). (1)Durante el mecanizado, el almacén selecciona la nueva herramienta. (2)El CNC finaliza el movimiento de los ejes. (3)El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio. (4)El brazo cambiador vuelve al almacén para dejar la herramienta. (5)El CNC continúa con la ejecución del programa." .

ns1:ProcesoCargaSubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Carga de subrutinas FST en memoria RAM"@es ;
    ns1:requiereMantenimiento ns1:MemoriaRAM_CNC ;
    ns1:textoExtracto "Para cargar una subrutina en la memoria RAM, está debe tener extensión fst. [...] El CNC comprueba si está cargada en memoria RAM, y si no lo está y hay espacio, la carga."@es .

ns1:ProcesoDeResetConRESETIN a ns1:Esquema ;
    ns1:identificador "Proceso de reset con RESETIN" ;
    ns1:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t. Muestra flancos de subida/bajada, orden de eventos y la relación entre marcas del PLC y respuesta del canal durante el reset." .

ns1:ProcesoReferenciadoMechatrolink a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia máquina (Mechatrolink)" ;
    ns1:ilustradoEn ns1:EsquemaCronogramaReferenciado ;
    ns1:monitoreaParametro ns1:PerfilDeVelocidadREFFEED1_fb0c1b35da,
        ns1:PulsosDeI0,
        ns1:PulsosDeMicro ;
    ns1:textoExtracto "Cronograma de señales durante la búsqueda: perfiles de velocidad (REFFEED1) y aproximaciones, pulsos de micro y de I0; se indican fases 1–4 mediante marcas temporales y niveles lógicos que guían la secuencia de referenciado." .

ns1:Proceso_BusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:controla ns1:Se_al_DECEL_axis ;
    ns1:requiereMantenimiento ns1:ModoManual ;
    ns1:textoExtracto "Esta marca se usa durante la búsqueda de referencia máquina. [...] El CNC decelera el eje, pasa del avance rápido [...] al avance lento. [...] búsqueda de cero."@es .

ns1:Proceso_InicializacionRegulador a ns1:ModoOperacion ;
    rdfs:label "Proceso de inicialización del regulador"@es ;
    ns1:controla ns1:Regulador_Sercos ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "1 Tras accionar el interruptor general del armario eléctrico se le proporcionan 24 V DC al regulador. 2 El regulador efectúa una comprobación interna. Si es correcta activa la salida System OK."@es .

ns1:Proceso_Latcheo a ns1:TareaMantenimiento ;
    ns1:textoExtracto "activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso" .

