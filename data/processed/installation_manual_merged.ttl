ns1:InstruccionesConsultaPLC_CNC_648 a ns1:InterfazUsuario ;
    rdfs:label "Instrucciones de consulta PLC-CNC"@es ;
    ns1:monitoreaParametro ns1:MarcasComunicacionCNC_648,
        ns1:RecursosPLC_648,
        ns1:RegistrosComunicacionCNC_648 ;
    ns1:textoExtracto "Permiten evaluar el estado de los recursos del PLC y de las marcas y registros de comunicación CNC-PLC. Se disponen de las siguientes instrucciones de consulta. • Instrucciones de consulta simples. • Instrucciones de consulta de detección de flancos. • Instrucciones de consulta de comparación."@es .

ns1:InterfazCNC_PLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de intercambio CNC-PLC"@es ;
    ns1:controla ns1:PLC_ProgramaEjecutable ;
    ns1:monitoreaParametro ns1:Parametro_MaquinaGeneral ;
    ns1:textoExtracto "Existe un intercambio de información entre el CNC y el PLC que se realiza de modo automático. Desde el PLC se puede: • Controlar las entradas y salidas físicas (módulos remotos). • Consultar y/o modificar las variables de intercambio CNC-PLC. Desde el CNC se puede: • Transferir las funciones auxiliares M, H y S. • Acceder a los recursos del PLC desde cualquier programa pieza."@es .

ns1:InterfazConfiguracionDisco a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración 'Configuration > Disk' (S.M.A.R.T.)" ;
    ns1:monitoreaParametro ns1:ParametroEstadoDisco ;
    ns1:textoExtracto "Captura de interfaz del panel 'Configuration > Disk' con lectura S.M.A.R.T. del disco M2-SATA. Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.) en un cuadro con iconos y valores por columna." .

