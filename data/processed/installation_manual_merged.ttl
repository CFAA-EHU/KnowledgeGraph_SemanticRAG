ns1:MarcaResetIN a ns1:Parametro ;
    rdfs:label "RESETIN"@es ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "cuando el PLC activa la marca RESETIN"@es .

ns1:MarcaSYNCPOSI a ns1:ComponenteElectrico ;
    rdfs:label "Marca SYNCPOSI (sincronización en posición)" ;
    ns1:monitoreaParametro ns1:ParametroDSYNCPOSW ;
    ns1:textoExtracto "SYNCPOSI [...] Esta marca se activa en el cabezal esclavo cuando está sincronizado en posición. Esta marca se pone a (=0) si se supera el máximo error en posición permitido" .

ns1:MarcaSYNCRONP a ns1:ComponenteElectrico ;
    rdfs:label "Marca SYNCRONP (sincronización en posición)" ;
    ns1:textoExtracto "SYNCRONP [...] Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización en posición. Esta marca permite distinguir entre una sincronización en posición o en velocidad" .

ns1:MarcaSYNSPEED a ns1:ComponenteElectrico ;
    rdfs:label "Marca SYNSPEED (sincronización en velocidad)" ;
    ns1:monitoreaParametro ns1:ParametroDSYNCVELW ;
    ns1:textoExtracto "SYNSPEED [...] Esta marca se activa en el cabezal esclavo cuando está sincronizado en velocidad. Esta marca se pone a (=0) si se supera el máximo error en velocidad permitido" .

ns1:MarcaSobretemperaturaCNC a ns1:Parametro ;
    rdfs:label "Marca de sobretemperatura en PLC" ;
    ns1:activaAlarma ns1:AlarmaSobretemperatura ;
    ns1:monitoreaParametro ns1:SistemaTemperaturaCNC ;
    ns1:textoExtracto "Incluir esta marca en la maniobra del PLC para restringir la operativa del CNC en caso de sobretemperatura. Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo." .

ns1:MarcaVolanteActivo_M1000 a ns1:Actuador ;
    rdfs:label "Marca: Volante de avance activo (M1000)" ;
    ns1:controla ns1:AvisoVolanteActivo ;
    ns1:identificador "M1000" ;
    ns1:textoExtracto "M1000 _____ Volante de avance activo." .

ns1:Marca_ALARM a ns1:Componente ;
    rdfs:label "Marca _ALARM (canal genérico)" ;
    ns1:identificador "_ALARM" ;
    ns1:textoExtracto "_ALARM. El canal del CNC activa esta marca (nivel \"0\") cuando hay una alarma, una emergencia generada por el canal del CNC o cuando el PLC activa señal de emergencia _EMERGEN." .

ns1:Marca_ALARMC1 a ns1:Componente ;
    rdfs:label "Marca _ALARM Canal 1" ;
    ns1:identificador "_ALARMC1" ;
    ns1:textoExtracto "_ALARMC1 (también se puede programar como _ALARM)" .

ns1:Marca_ALARMC2 a ns1:Componente ;
    rdfs:label "Marca _ALARM Canal 2" ;
    ns1:identificador "_ALARMC2" ;
