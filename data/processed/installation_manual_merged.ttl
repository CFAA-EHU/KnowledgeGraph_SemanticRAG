ns1:Tabla_ParametrosMovimiento_4_4_8 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de movimiento independiente (4.4.8)"@es ;
    ns1:documentadoEn ns1:Pagina_380_381 ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | axis | Eje a posicionar. | pos | Posición a alcanzar. | direction | Sentido de desplazamiento. Se programa mediante los parámetros \"DIRPOS\" (sentido positivo) o \"DIRNEG\" (sentido negativo). | feed | Avance de posicionamiento. | blend | Enlace dinámico con el siguiente bloque. Se programa mediante los parámetros \"PRESENT\", \"NULL\", \"NEXT\" o \"WAITINPOS\"."@es .

ns1:Tabla_RedefinicionCinematica_15_a_52 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 15 → tipo 52"@es,
        "Tabla de redefinición de cinemática tipo 15 a tipo 52"@es ;
    ns1:detalladoEnEsquema ns1:SistemaCinematico_Tipo52 ;
    ns1:documentadoEn ns1:Manual_Broaching,
        ns1:Manual_Seccion_2.9.12 ;
    ns1:textoExtracto """\r
| Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15. |\r
| TDATA31 | 0 |\r
| TDATA32 | -TDATA5 |\r
| TDATA33 | -TDATA6 |\r
| TDATA34 | 1 |\r
| TDATA35 | 0 |\r
| TDATA36 | 0 |\r
| TDATA37 | TDATA9 |\r
| TDATA38 | TDATA11 |\r
| TDATA39 | 0 |\r
| TDATA40 | A elegir. |\r
| TDATA49 | 1 |\r
"""@es,
        "Adaptar una cinemática tipo 15 a una cinemática tipo 52. [...] Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15."@es .

ns1:Tabla_ResumenVariablesDMC_1331 a ns1:Tabla ;
