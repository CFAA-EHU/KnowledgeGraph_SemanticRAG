    ns1:identificador "TMOPERATION=10" ;
    ns1:requiereMantenimiento ns1:Herramienta_8a97f8ec90 ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:OperacionEnZonaProhibida a ns1:AccionProhibida ;
    rdfs:label "Operación en zona prohibida" ;
    ns1:textoExtracto "una zona prohibida. Los límites de software se pueden fijar mediante los parámetros máquina, mediante las funciones G198/G199 o mediante variables." .

ns1:OperacionLogica_AND a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica AND" ;
    ns1:identificador "AND" ;
    ns1:textoExtracto "= AND [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: AND R1/1024 R1/1024 R1/1024" .

ns1:OperacionLogica_OR a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica OR" ;
    ns1:identificador "OR" ;
    ns1:textoExtracto "= OR [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: OR R CNC-PLC R CNC-PLC R CNC-PLC" .

ns1:OperacionLogica_XOR a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica XOR" ;
    ns1:identificador "XOR" ;
    ns1:textoExtracto "= XOR [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: XOR R CNC-PLC R CNC-PLC R CNC-PLC" .

ns1:OperacionMecanizado_1090 a ns1:AccionProhibida ;
    rdfs:label "Operación de mecanizado" ;
    ns1:textoExtracto "durante el mecanizado (al ejecutar la T)" .

ns1:OperacionSobreCabezal a ns1:AccionProhibida ;
