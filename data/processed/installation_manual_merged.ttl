        ns1:Tabla_Cinematica_2_9_12 ;
    ns1:textoExtracto "| TDATA22 | 0 |"@es ;
    ns1:valor "0" .

ns1:Parametro_30e9dfc866 a ns1:Parametro ;
    rdfs:label "MANACCP" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "(V.)[ch].MPA.MANACCP.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Máximo porcentaje aceleración manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20." ;
    ns1:valor "20" .

ns1:Parametro_30ec16f062 a ns1:Parametro ;
    rdfs:label "DATA" ;
    ns1:documentadoEn ns1:TablaCAMTABLE ;
    ns1:identificador "DATA" ;
    ns1:textoExtracto "Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles." .

ns1:Parametro_3106008782 a ns1:Parametro ;
    rdfs:label "Parámetro de tipo de ventana" ;
    ns1:textoExtracto "Tipo de ventana para el latcheo. Esta opción se programa mediante los siguientes comandos. DISABLE No hay ventana de latcheo (opción por defecto). El latcheo de la cota se puede realizar en cualquier posición del recorrido del eje. EXCLUSIVE El latcheo de la cota se realiza si el eje está fuera de la ventana. INCLUSIVE El latcheo de la cota se realiza si el eje está dentro de la ventana." .

ns1:Parametro_316056bd88 a ns1:Parametro ;
    rdfs:label "CAXNAME" ;
    ns1:identificador "CAXNAME" ;
    ns1:textoExtracto "CAXNAME Nombre por defecto del eje C. Valores posibles: Cualquier nombre de eje válido; X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: C." ;
    ns1:valor "C" .

ns1:Parametro_31af274d18 a ns1:Parametro ;
    rdfs:label "VOLCOMP4"@es ;
    ns1:documentadoEn ns1:TablaDeVariablesDeCompensacionVolumetricaPag611612 ;
    ns1:identificador "V.PLC.VOLCOMP4" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "(V.)PLC.VOLCOMP4"@es .

ns1:Parametro_32e44c92b0 a ns1:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ns1:textoExtracto "G2G3MODAL: La programación en G2/G3 se mantiene modal. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ns1:valor "Sí" .

ns1:Parametro_330352d8be a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED1 (avance inicial de búsqueda de referencia)"@es ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "la búsqueda de referencia se ejecuta al avance indicado en REFFEED1 hasta que se pulsa el micro de referencia máquina"@es ;
    ns1:valor "100.0000" .

ns1:Parametro_331fa9a44b a ns1:Parametro ;
    rdfs:label "TDATA26",
        "TDATA26"@es ;
    ns1:documentadoEn ns1:TablaDeEquivalenciaDeParametrosParaCinematicaVectorialTipo52,
