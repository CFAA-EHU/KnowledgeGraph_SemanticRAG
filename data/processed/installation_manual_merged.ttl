ns1:Parametro_21184be7e5 a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:textoExtracto "La aceleración pasa a ser constante y su valor es ACCEL." .

ns1:Parametro_211a5f4e57 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW" ;
    ns1:identificador "LASERFOLLOW" ;
    ns1:textoExtracto "LASERFOLLOW Compensar la dispersión por el recorrido del láser de CO2. Este parámetro muestra la tabla para definir la compensación." .

ns1:Parametro_2313205137 a ns1:Parametro ;
