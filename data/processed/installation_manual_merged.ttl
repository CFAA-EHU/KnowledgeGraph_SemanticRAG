    ns1:identificador "SET n" ;
    ns1:monitoreaParametro ns1:CNC_GamasTrabajo ;
    ns1:textoExtracto "SET n Gamas de trabajo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado" .

ns1:Parametro_Share a ns1:Parametro ;
    rdfs:label "SHARE"@es ;
    ns1:textoExtracto "Porcentaje de señal que pasa a través del filtro."@es ;
    ns1:valor "SHARE" .

ns1:Parametro_Sincronizacion_POS a ns1:Parametro ;
    rdfs:label "Parámetro de sincronización en posición (POS)" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "Se programa mediante los parámetros \"POS\" (sincronización en posición)" .

ns1:Parametro_Sincronizacion_VEL a ns1:Parametro ;
    rdfs:label "Parámetro de sincronización en velocidad (VEL)" ;
    ns1:identificador "VEL" ;
    ns1:textoExtracto "Se programa mediante los parámetros \"VEL\" (sincronización en velocidad)" .

ns1:Parametro_Smax_67 a ns1:Parametro ;
    rdfs:label "Velocidad máxima (S.max)" ;
    ns1:identificador "S.max" ;
    ns1:textoExtracto "S.max Velocidad máxima... Se dispone de un eje tándem con una velocidad máxima de 2000 rpm." ;
    ns1:valor "2000 rpm"@es .

ns1:Parametro_TCOMPLIM_67 a ns1:Parametro ;
