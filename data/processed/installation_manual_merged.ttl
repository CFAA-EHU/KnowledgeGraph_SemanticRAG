    ns1:monitoreaParametro ns1:Parametro_Desaparcado ;
    ns1:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar.",
        "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar."@es .

ns1:SensorPresenciaEjeB a ns1:Sensor ;
    rdfs:label "Sensor de presencia del eje B" ;
    ns1:identificador "I15" ;
    ns1:monitoreaParametro ns1:ParametroPresenciaEjeB,
        ns1:Se_alPARKEDB ;
    ns1:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje \"B\" PARKB AND NOT I15 = SET PARKEDB",
        "el eje está presente (I15), el eje está desaparcado (RES PARKEDB). [...] Esta marca normalmente está afectada por la entrada correspondiente al sensor de presencia del eje." .

ns1:Sensor_CaptacionMotor a ns1:Sensor ;
    rdfs:label "Captación motor (sensor interno)" ;
    ns1:textoExtracto "captación interna (captación motor)" .

ns1:Sensor_ControlGap a ns1:Sensor ;
    rdfs:label "Sensor de control de gap",
        "Sensor de control del gap" ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINID,
        ns1:Parametro_GAPDISTLIMIT,
        ns1:Parametro_GAPTOL,
        ns1:Parametro_GAPVOLTLIMIT ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION.",
        "El sensor puede estar conectado a una salida analógica de los módulos remotos CAN o de un regulador Sercos. En ambos casos, este parámetro identifica la salida analógica que se está usando.",
        "Entrada analógica de los módulos remotos EtherCAT. En este caso, este parámetro indica el registro del PLC que mapea la entrada analógica conectada al sensor." .

ns1:Sensor_ErrorSeguimiento a ns1:Sensor ;
    rdfs:label "Sensor de error de seguimiento (ε)" ;
    ns1:textoExtracto "señal de error \"ε\"" .

