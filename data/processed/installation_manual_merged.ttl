ns1:Esquema_EjeC_Cilindrico a ns1:Esquema ;
    rdfs:label "Esquema del eje C cilíndrico (#CYL)" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA4 ;
    ns1:ilustradoEn ns1:Pagina_277 ;
    ns1:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza. Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular)" .

ns1:Esquema_EjeTandem_MasterSlave a ns1:Esquema ;
    rdfs:label "Esquema mecánico de eje tándem con motores Master/Slave" ;
    ns1:ilustradoEn ns1:SistemaEjeTandem ;
    ns1:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." .

ns1:Esquema_EjesTornoInclinado a ns1:Esquema ;
    rdfs:label "Esquema de torno con ejes no ortogonales (X, X', Z)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_EjesNoOrtogonales ;
    ns1:ilustradoEn ns1:Manual_OpenPCS_SeccionParametrosMaquina ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad, mostrando cómo un movimiento programado en X se descompone en componentes sobre Z y X'."@es .

ns1:Esquema_FresadoraPuente_Gantry a ns1:Esquema ;
    rdfs:label "Esquema de fresadora puente con ejes gantry X-U y Z-W" ;
    ns1:ilustradoEn ns1:SistemaFresadoraPuente ;
    ns1:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." .

ns1:Esquema_GapToNeg_No a ns1:Esquema ;
    rdfs:label "Esquema GAPTONEG = No (eje Z invertido)"@es ;
    ns1:textoExtracto "Esquema 'GAPTONEG = No': representa un eje Z invertido (Z+ hacia abajo). El movimiento para lograr el gap se realiza en sentido positivo."@es .

ns1:Esquema_GapToNeg_Yes a ns1:Esquema ;
    rdfs:label "Esquema GAPTONEG = Sí (eje Z estándar)"@es ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)."@es .

ns1:Esquema_Geometrico_XM_TDATA6 a ns1:Esquema ;
    rdfs:label "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA6 ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6 = 2·XM − TDATA1, con esquema Y-Z, marca de ángulo 45° y flechas de referencia; se destaca la relación entre la media de lecturas laterales y el descentramiento respecto a TDATA1."@es .

ns1:Esquema_LaserCompensation a ns1:Esquema ;
    rdfs:label "Diagrama de compensación de dispersión láser CO₂"@es ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser."@es .

ns1:Esquema_LazoControlGap a ns1:Esquema ;
    rdfs:label "Diagrama de bloques del lazo de control del gap"@es ;
    ns1:ilustradoEn ns1:Grafico_PerfilVelocidadGap ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del gap: 'GAP SENSOR FEEDBACK' → filtro paso bajo (ORDER/FREQUENCY) → 'POSITION LOOP' con 'GAP P-GAIN'. Representa la cadena de señal y dónde actúan los parámetros GAPGAIN y GAPSENSORFILTER."@es ;
    ns1:tieneComponente ns1:SensorGap .

ns1:Esquema_LimitesSoftwareEjes a ns1:Esquema ;
    rdfs:label "Esquema de límites de software de ejes (SL/FL)"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "Vista adicional del mismo concepto con otro plano de observación; se duplican anotaciones SL/FL y trayectorias de T para resaltar cómo el CNC detiene la ejecución al intentar salir de SL, con ejes indicados y zonas sombreadas. Diagrama de selección de límites donde dos grupos SL1/SL2 definen ventanas válidas; un gráfico a trazos y sombreado cruzado explica que el CNC aplica siempre el límite más restrictivo (superior e inferior), con pequeñas vistas esquemáticas en X-Y."@es .

ns1:Esquema_LimitesSoftwareVolumenTrabajo a ns1:Esquema ;
    rdfs:label "Volumen de trabajo con límites físicos (FL) y de software (SL)" ;
    ns1:ilustradoEn ns1:SistemaReferencias_Torno ;
    ns1:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z; el punto T (portaherramientas) se relaciona con OM y se sombrean regiones válidas/inválidas para posiciones programables según herramienta activa." .

ns1:Esquema_MesaRotativa_EjeA a ns1:Esquema ;
