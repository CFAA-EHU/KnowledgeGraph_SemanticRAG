ns1:Parametro_Velocidad_Desplazamiento a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad (F_)"@es ;
    ns1:identificador "F_" ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal."@es .

ns1:Parametro_WIDTH a ns1:Parametro ;
    rdfs:label "WIDTH" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionVentanaPrincipal ;
    ns1:textoExtracto "Anchura de la ventana. Parámetro incluido en la tabla WINDOW."@es .

ns1:Parametro_Width a ns1:Parametro ;
    rdfs:label "WIDTH"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVentanaPrincipal ;
    ns1:identificador "WIDTH" ;
    ns1:textoExtracto """\r
WIDTH Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles.\r
Parámetro incluido en la tabla WINDOW.\r
"""@es ;
    ns1:valor 800 .

ns1:Parametro_X1 a ns1:Parametro ;
    rdfs:label "X1" ;
    ns1:textoExtracto "X1: Cota anotada en palpación (punto 1)." .

ns1:Parametro_X100 a ns1:Parametro ;
    rdfs:label "Cota X100" ;
    ns1:textoExtracto "El CNC desplaza el eje a la cota X100." ;
    ns1:valor "X100" .

ns1:Parametro_XFERINH a ns1:Parametro ;
    rdfs:label "Parámetro _XFERINH"@es ;
    ns1:documentadoEn ns1:Tabla_XFITOIND ;
    ns1:identificador "_XFERINH" ;
    ns1:textoExtracto "La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC."@es .

ns1:Parametro_XFITOIND a ns1:Parametro ;
    rdfs:label "Parámetro XFITOIND",
        "XFITOIND" ;
    ns1:identificador "(V.)[ch].MPG.XFITOIND",
        "XFITOIND" ;
    ns1:textoExtracto "El CNC primero evalúa el transfer inhibit del canal (marca _XFERINH) y a continuación el particular del eje (marca _IXFERINH(axis)).",
        "XFITOIND El transfer inhibit del canal afecta a los ejes independientes. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.XFITOIND Este parámetro indica si el transfer inhibit del canal (marca _XFERINH) afecta a los movimientos de eje independiente programados desde el PLC." ;
    ns1:valor "Sí" .

ns1:Parametro_XM a ns1:Parametro ;
    rdfs:label "X_M" ;
    ns1:identificador "X_M" ;
    ns1:textoExtracto "X = 0,5·(Xa + Xb)" .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "Z" ;
    ns1:textoExtracto "Z: Cota anotada en palpación (punto 2)." .

ns1:Parametro_cam a ns1:Parametro ;
    rdfs:label "cam"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLevaElectronica_4_4_7 ;
    ns1:identificador "cam" ;
    ns1:textoExtracto "Número de leva."@es,
        "cam | Número de leva."@es ;
    ns1:valor "Número de leva"@es .

ns1:Parametro_file a ns1:Parametro ;
    rdfs:label "file"@es ;
    ns1:identificador "file" ;
    ns1:textoExtracto "file | Nombre y dirección (path) del archivo con los datos de la leva."@es ;
    ns1:valor "Nombre y dirección (path) del archivo con los datos de la leva"@es .

ns1:Parametro_t_TG2 a ns1:Parametro ;
    rdfs:label "Valor temporal 't' en TG2"@es ;
    ns1:identificador "t" ;
    ns1:monitoreaParametro ns1:Parametro_TG2 ;
    ns1:textoExtracto "t mantiene el valor alcanzado [...] la rampa de t; al devolver TEN=1, la temporización se reanuda."@es .

ns1:ParametrosAlmacenes a ns1:Parametro ;
    rdfs:label "Parámetros de los almacenes"@es ;
    ns1:textoExtracto "Estos parámetros indican el número de almacenes, tipo, número de posiciones, etc."@es .

ns1:ParametrosBusEtherCAT a ns1:Parametro ;
    rdfs:label "Información general del bus EtherCAT"@es ;
    ns1:textoExtracto "Información general del bus."@es .

ns1:ParametrosEjesCabezales a ns1:Parametro ;
    rdfs:label "Parámetros de ejes y cabezales"@es ;
    ns1:textoExtracto "Estos parámetros indican las propiedades de los ejes y cabezales, límites de recorrido, condiciones de desplazamiento, volantes asociados, trabajo con palpador, compensaciones, etc. Cada eje o cabezal puede disponer de hasta 4 sets de trabajo. En cada uno de ellos hay que definir el ajuste de los avances y ganancias, búsquedas de referencia, aceleraciones, etc."@es .

ns1:ParametrosGeneralesMaquina a ns1:Parametro ;
    rdfs:label "Parámetros generales"@es ;
    ns1:textoExtracto "Estos parámetros definen el nombre de los ejes y cabezales, condiciones tras el encendido, rutinas asociadas a determinadas funciones, etc. Algunos de estos parámetros hay que definirlos en primer lugar porque configuran las tablas de parámetros de ejes. Por ejemplo, el número y denominación de los ejes y cabezales, etc."@es .

ns1:ParametrosHMI a ns1:Parametro ;
    rdfs:label "Parámetros HMI"@es ;
    ns1:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC."@es .

ns1:ParametrosMaquina_CNC a ns1:Parametro ;
    rdfs:label "Parámetros máquina del CNC"@es ;
    ns1:documentadoEn ns1:Capitulo_ParametrosMaquina ;
    ns1:textoExtracto "Los parámetros máquina del CNC están agrupados [...] datos específicos de la máquina. Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc."@es .

ns1:ParametrosMaquina_CompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Parámetros máquina para compensación volumétrica" ;
    ns1:identificador "VOLCOMP1-VOLCOMP4" ;
    ns1:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:ParametrosMaquina_ConfiguracionTandem a ns1:Parametro ;
    rdfs:label "Parámetros máquina para configuración de parejas tándem"@es ;
    ns1:textoExtracto "Las parejas tándem del sistema se configuran desde los parámetros máquina. Cada pareja tándem dispone de los siguientes parámetros máquina generales para su configuración."@es .

ns1:ParametrosModoManual a ns1:Parametro ;
    rdfs:label "Parámetros del modo manual"@es ;
    ns1:textoExtracto "Estos parámetros permiten personalizar los volantes y las teclas de JOG."@es .

ns1:ParametrosOEM a ns1:Parametro ;
    rdfs:label "Parámetros OEM"@es ;
    ns1:textoExtracto "Estos parámetros permiten configurar la lectura/escritura de variables del regulador, editar levas, definir un grupo de parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina, etc."@es .

ns1:ParametrosTablaCinematicas a ns1:Parametro ;
    rdfs:label "Parámetros de la tabla de cinemáticas"@es ;
    ns1:textoExtracto "Estos parámetros indican el tipo y características de cada una de las cinemáticas."@es .

ns1:ParametrosTablaFuncionesM a ns1:Parametro ;
    rdfs:label "Parámetros de la tabla de funciones M"@es ;
    ns1:textoExtracto "Estos parámetros permiten definir nuevas funciones M y personalizar el tipo de sincronización y la rutina asociada a cada una de las funciones M del sistema."@es .

ns1:PasswordFabricante a ns1:ElementoSeguridad ;
    rdfs:label "Password de fabricante" ;
    ns1:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante." .

ns1:PerdidaPosicionCNC a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de posición CNC"@es ;
    ns1:mitigaRiesgo ns1:BusquedaReferenciaM_quina ;
    ns1:textoExtracto "Esta operación es necesaria cuando el CNC pierde la posición del origen (por ejemplo, apagando la máquina)."@es .

ns1:PerfilLeva a ns1:Parametro ;
    rdfs:label "Perfil de leva" ;
    ns1:textoExtracto "final del perfil de leva" .

ns1:PerfilVelocidad_HSC a ns1:Parametro ;
    rdfs:label "Perfil de velocidad (modo HSC)" ;
    ns1:textoExtracto "perfiles de velocidad y aceleración más suaves pero de menor precisión en las esquinas" .

ns1:PersonalTecnico a ns1:Personal ;
    rdfs:label "Personal técnico"@es ;
    ns1:textoExtracto "Antes de actualizar el software, consulte la lista de posibles incompatibilidades"@es .

ns1:PersonalTecnico_1309 a ns1:Personal ;
    rdfs:label "Técnico de calibración"@es ;
    ns1:textoExtracto "Retirar el reloj, sin soltarlo, y posicionar el B=0º eje rotativo C en 180º. [...] Tocar con el reloj en el punto 2."@es .

ns1:Personal_1362 a ns1:Personal ;
    rdfs:label "Operador de CNC"@es ;
    ns1:textoExtracto "Este es el archivo que se debe copiar al CNC."@es .

ns1:Personal_Operador a ns1:Personal ;
    rdfs:label "Operador de máquina" ;
    ns1:textoExtracto "Configuración realizada por personal durante el modo manual." .

ns1:Personal_Tecnico_1072 a ns1:Personal ;
    rdfs:label "Técnico de ajuste"@es ;
    ns1:textoExtracto "Proceso de ajuste del tándem (implicito: requiere intervención técnica)"@es .

ns1:Personal_UsuarioAdministrador a ns1:Personal ;
    rdfs:label "Usuario con acceso administrador"@es ;
    ns1:textoExtracto "para instalar software de terceros, usted debe disponer de un sistema abierto, es decir, con acceso al modo administrador."@es .

ns1:PinonCremalleraTandem_1068 a ns1:ComponenteMecanico ;
    rdfs:label "Sistema piñón-cremallera del eje tándem"@es ;
    ns1:textoExtracto "eliminar la holgura piñón-cremallera cuando se encuentra en reposo"@es .

ns1:PinonCremallera_1056 a ns1:ComponenteMecanico ;
    rdfs:label "Sistema piñón-cremallera"@es ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera. [...] La rigidez del sistema piñón - cremallera es mayor que la de los husillos largos."@es .

ns1:PinonEsclavoGantry a ns1:ComponenteMecanico ;
    rdfs:label "Piñón esclavo (gantry)"@es ;
    ns1:textoExtracto "el esclavo compensa con par opuesto para mantener la tensión mecánica"@es .

ns1:PinonMaestroGantry a ns1:ComponenteMecanico ;
    rdfs:label "Piñón maestro (gantry)"@es ;
    ns1:textoExtracto "piñón maestro aplica mayor par motor"@es .

ns1:Pinza a ns1:ComponenteMecanico ;
    rdfs:label "Pinza"@es ;
    ns1:textoExtracto "Almacén síncrono con brazo cambiador (1 ó 2 pinzas)."@es .

ns1:PinzasBrazoCambiador_7.5 a ns1:ComponenteMecanico ;
    rdfs:label "Pinzas del brazo cambiador"@es ;
    ns1:textoExtracto "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén."@es .

ns1:PlaquitaMecanizado_01 a ns1:Consumible ;
    rdfs:label "Plaquita de mecanizado"@es ;
    ns1:textoExtracto "cada uno con su plaquita o fresa"@es .

ns1:Portaherramientas_01 a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas (estación 1)"@es ;
    ns1:textoExtracto "varios portaherramientas montados radialmente"@es .

ns1:Portaherramientas_02 a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas (estación 2)"@es ;
    ns1:textoExtracto "varios portaherramientas montados radialmente"@es .

ns1:Portaherramientas_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas (cabezal, cinemática tipo 52)"@es ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas."@es .

ns1:PotenciaConsumida_1339 a ns1:Parametro ;
    rdfs:label "Potencia consumida por el cabezal"@es ;
    ns1:textoExtracto "Vigilancia de la potencia consumida. Durante el funcionamiento, el DMC vigila continuamente la potencia consumida por el cabezal, para detectar problemas con la herramienta o en el mecanizado."@es .

ns1:PotenciaCorte_Parametro a ns1:Parametro ;
    rdfs:label "Potencia de corte (potencia objetivo)"@es ;
    ns1:textoExtracto "La base para la optimización es la potencia de corte a alcanzar, también llamada potencia objetivo. Esta potencia no solo depende de la herramienta, sino también del material y de las condiciones de corte (avance, velocidad de giro del cabezal, profundidad de pasada y paso lateral)."@es .

ns1:ProcesoLatcheoCotas_693 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de latcheo de cotas con palpador o entrada digital" ;
    ns1:requiereMantenimiento ns1:SistemaControlEjes_693 ;
    ns1:textoExtracto "palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso. Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje. Un reset del canal cancela los procesos de latcheo en todos los ejes del canal. Las funciones M02 y M30 no se darán por ejecutadas hasta que finalicen todos los procesos de latcheo activos en los ejes del canal." .

ns1:ProcesoLatcheo_780 a ns1:ModoOperacion ;
    rdfs:label "Proceso de latcheo"@es ;
    ns1:controla ns1:MarcaLatcheo_780 ;
    ns1:textoExtracto "proceso de latcheo en el eje con el palpador indicado"@es .

ns1:ProcesoReferenciadoEjesGantry_1109 a ns1:ModoOperacion ;
    rdfs:label "Proceso de referencia de ejes gantry (maestro-esclavo)"@es ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo. Durante el proceso, el CNC lee el incremento en la cota real del eje esclavo y la envía al eje maestro como incremento de la cota teórica, haciendo así que el eje maestro siga al esclavo con tan solo el retraso entre la cota teórica y la real."@es .

ns1:PulsadorVolanteAvance_I71 a ns1:ComponenteElectrico ;
    rdfs:label "Pulsador para activar/desactivar volante de avance (I71)" ;
    ns1:controla ns1:VolanteAvance ;
    ns1:identificador "I71" ;
    ns1:textoExtracto "I71 _____ Pulsador para activar y desactivar el volante de avance." .

ns1:PuntoReferenciaM_quina a ns1:ComponenteMecanico ;
    rdfs:label "Punto de referencia máquina"@es ;
    ns1:textoExtracto "El punto de referencia máquina es un punto de la máquina fijado por el fabricante y referenciado respecto al cero máquina. Este punto puede estar situado en cualquier parte de la máquina."@es .

ns1:QC_C65_10K a ns1:InterfazUsuario ;
    rdfs:label "Panel QC-C65□-10K (pantalla integrada, keypad numérico y teclas de jog)"@es ;
    ns1:ilustradoEn ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Fotografía del panel QC-C65□-10K con pantalla integrada y keypad numérico; a la derecha, un bloque de teclas de jog dispuesto en rejilla. La figura apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx para este modelo."@es .

ns1:RAPIDC1 a ns1:Parametro ;
    rdfs:label "RAPIDC1" ;
    ns1:identificador "RAPIDC1" ;
    ns1:textoExtracto "RAPIDC1 (también se puede programar como RAPID) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un posicionamiento rápido." .

ns1:RAPIDC2 a ns1:Parametro ;
    rdfs:label "RAPIDC2" ;
    ns1:identificador "RAPIDC2" ;
    ns1:textoExtracto "RAPIDC2 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un posicionamiento rápido." .

ns1:RAPIDC3 a ns1:Parametro ;
    rdfs:label "RAPIDC3" ;
    ns1:identificador "RAPIDC3" ;
    ns1:textoExtracto "RAPIDC3 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un posicionamiento rápido." .

ns1:RAPIDC4 a ns1:Parametro ;
    rdfs:label "RAPIDC4" ;
    ns1:identificador "RAPIDC4" ;
    ns1:textoExtracto "RAPIDC4 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un posicionamiento rápido." .

ns1:RCS_S_4F4AO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S-4F4AO" ;
    ns1:identificador "RCS-S-4F4AO" ;
    ns1:textoExtracto "4 entradas de contaje. - Señal incremental TTL, TTL diferencial y Vpp. - Protocolo SSI, FeeDat, EnDat 2.1 y EnDat 2.2. 4 salidas analógicas ±10 V (16 bits) de propósito general." ;
    ns1:tieneComponente ns1:E21A,
        ns1:E21B,
        ns1:E21C,
        ns1:E21D,
        ns1:I37A,
        ns1:I37B .

ns1:RESTMEM a ns1:Sensor ;
    rdfs:label "RESTMEM (Cancelación de emergencia)"@es ;
