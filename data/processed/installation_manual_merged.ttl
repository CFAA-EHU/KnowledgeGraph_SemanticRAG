ns1:ModoOperacion_HSC_CONTERRO a ns1:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR" ;
    ns1:monitoreaParametro ns1:Parametro_FREQRES ;
    ns1:textoExtracto "modo HSC CONTERROR" .

ns1:ModoOperacion_HSC_SURFACE_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE/FAST" ;
    ns1:habilitadoPor ns1:Parametro_SLOPETYPE ;
    ns1:textoExtracto "Modo HSC SURFACE/FAST." .

ns1:ModoOperacion_INT a ns1:ModoOperacion ;
    rdfs:label "Modo INT (aplicación externa)"@es ;
    ns1:textoExtracto "accesibles desde [...] (INT) una aplicación externa"^^rdf:XMLLiteral .

ns1:ModoOperacion_ImpulsoAdicional a ns1:ModoOperacion ;
    rdfs:label "Modo de impulso adicional de consigna"@es ;
    ns1:controla ns1:Parametro_PEAKDISP ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con impulso adicional de consigna; parámetro BAKANOUT distinto de cero"@es .

ns1:ModoOperacion_LatcheoCotas a ns1:ModoOperacion ;
    rdfs:label "Latcheo de cotas" ;
    ns1:textoExtracto "Funcionamiento del latcheo de cotas. Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:ModoOperacion_LimitadorSenial_TG4 a ns1:ModoOperacion ;
    rdfs:label "Modo limitador de la señal (entrada TG4)"@es ;
    ns1:textoExtracto "En este modo de funcionamiento el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG4 hasta que transcurra el tiempo indicado mediante la constante de tiempo, o hasta que se produzca un flanco de bajada en la entrada TG4."@es ;
    ns1:tieneComponente ns1:Entrada_TG4,
        ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_T,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS .

ns1:ModoOperacion_LinealTrapezoidal a ns1:ModoOperacion ;
    rdfs:label "Perfil lineal trapezoidal"@es ;
    ns1:ilustradoEn ns1:Figura_2.4.8_CondicionesPorDefecto_Canal ;
    ns1:textoExtracto "Los desplazamientos más rápidos se consiguen con la aceleración lineal"@es .

ns1:ModoOperacion_Linearlike a ns1:ModoOperacion ;
    rdfs:label "Modo Linearlike" ;
    ns1:documentadoEn ns1:Sistema_EjeRotativo ;
    ns1:textoExtracto "Comportamiento cuando AXISMODE = Linearlike." .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:textoExtracto "modo MDI/MDA" .

