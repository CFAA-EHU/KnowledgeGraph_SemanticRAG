ns1:Manual_CicloCalibracionHerramienta a ns1:Manual ;
    rdfs:label "Sección 14.6: Subrutinas asociadas al ciclo de calibración de herramienta" ;
    ns1:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica de los palpadores, por lo que deben ser adaptadas y configuradas apropiadamente por el OEM." .

ns1:Manual_Maquina a ns1:Manual ;
    rdfs:label "Manual de la máquina" ;
    ns1:textoExtracto "Sección 6.5 Señales lógicas de consulta; láser" .

ns1:Manual_OpenPCS_1530 a ns1:Manual ;
    rdfs:label "Manual de configuración OpenPCS remoto" ;
    ns1:textoExtracto "Configurar el CNC para utilizar el PLC remoto. [...] La información que necesita el OpenPCS para generar el PLC adecuado para el CNC está en la carpeta ..\\Fagor\\Plc\\Openpcs del propio CNC."^^rdfs:Literal .

ns1:Manual_Q7_A a ns1:Manual ;
    rdfs:label "Manual de la plataforma Q7-A" ;
    ns1:textoExtracto "Proceso de configuración del bus EtherCAT en la plataforma Q7-A." .

ns1:Manual_Seccion2_6_1 a ns1:Manual ;
    rdfs:label "Sección 2.6.1: Resolución de la captación" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Variable asociada: (V.)[ch].MPA.NPULSES2[set].xn" .

ns1:MaquinaBrochadora a ns1:Maquina ;
    rdfs:label "Máquina brochadora",
        "Máquina con control DMC" ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR. Si el usuario selecciona desde el conmutador del panel de mando, un override por debajo de MINDMCOVR, el CNC inhibe el DMC (no lo desactiva); cuando el override vuelva a superar MINDMCOVR, el DMC volverá a funcionar con normalidad." ;
    ns1:tieneComponente ns1:PanelMando .

ns1:Maquina_Generica a ns1:Maquina ;
    rdfs:label "Máquina",
        "Máquina (contexto de referencia G74)"@es ;
    ns1:textoExtracto "búsqueda de referencia máquina"@es ;
    ns1:tieneComponente ns1:Cabezal_Generico .

ns1:Maquina_TornoControlNumerico a ns1:Maquina ;
    rdfs:label "Máquina-herramienta de control numérico"@es ;
    ns1:textoExtracto "Parámetros máquina; generales."@es .

ns1:ModoAvance_Rapido a ns1:ModoOperacion ;
    rdfs:label "Modo de avance rápido" ;
    ns1:textoExtracto "el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual" .

ns1:ModoEjecucion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución bloque a bloque" ;
    ns1:textoExtracto "el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–" .

ns1:ModoHSCFAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST" ;
    ns1:textoExtracto "modo HSC FAST mejora la calidad del mecanizado... Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para el modo HSC FAST. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria... Sólo se aplica con el modo HSC FAST activo." .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo bloque a bloque",
        "Modo de ejecución 'bloque a bloque'" ;
    ns1:identificador "SBOUT" ;
    ns1:textoExtracto "modo de ejecución \"bloque a bloque\"" .

ns1:ModoOperacion_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "HSC FAST",
        "Modo FAST (HSC optimizado para avance)",
        "Modo HSC FAST",
        "Modo HSC FAST"@es ;
    ns1:identificador "FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST). Es el modo recomendado de trabajo en las siguientes circunstancias: [...] En el modo FAST se logra una superficie mecanizada más suave y una velocidad más continua." .

ns1:ModoOperacion_HSC_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE",
