ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "POSERROR",
        "Parámetro de compensación de husillo (POSERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_CROSSCOMP_DATA,
        ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.POSERROR[pt].xn",
        "POSERROR" ;
    ns1:monitoreaParametro ns1:Tabla_CompensacionCruzada ;
    ns1:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n",
        "Este parámetro indica el error cuando el eje se desplaza en sentido positivo. Si no se ha definido la tabla con compensación bidireccional, este error también se aplicará a los desplazamientos en sentido negativo.",
        "POSERROR Error en sentido positivo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0.",
        "POSERROR: Error a compensar en los desplazamientos en sentido positivo. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.POSERROR[tbl][pt].",
        "Error a compensar en los desplazamientos en sentido positivo."@es,
        "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.POSERROR[pt].xn"@es ;
    ns1:valor "0",
        "Entre ±99999.9999 grados" .

ns1:Parametro_POSERROR_107 a ns1:Parametro ;
    rdfs:label "POSERROR"@es ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR."@es .

ns1:Parametro_POSINREF a ns1:Parametro ;
    rdfs:label "POSINREF" ;
    ns1:textoExtracto "Búsqueda de referencia con movimiento del eje al punto de referencia. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No.",
        "POSINREF Búsqueda de referencia con movimiento del eje al punto de referencia. Parámetro válido para ejes" ;
    ns1:valor "No" .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION" ;
    ns1:documentadoEn ns1:Tabla_CROSSCOMP_DATA,
        ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "POSITION" ;
    ns1:monitoreaParametro ns1:Tabla_CompensacionCruzada ;
    ns1:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n",
        "POSITION Posición de cada punto. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0.",
        "POSITION: Posición del eje maestro. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.POSITION[tbl][pt].",
        "Posición del eje maestro."@es ;
    ns1:valor "0" .

ns1:Parametro_POSITION_107 a ns1:Parametro ;
    rdfs:label "POSITION"@es ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR."@es .

