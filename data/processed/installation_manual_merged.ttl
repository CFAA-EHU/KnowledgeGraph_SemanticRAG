        "11",
        "6",
        "9" .

ns1:Parametro_0e7672c52c a ns1:Parametro ;
    rdfs:label "INPOTIME" ;
    ns1:identificador "V.[ch].MPA.MPA.INPOTIME[set].xn" ;
    ns1:textoExtracto "INPOTIME Tiempo mínimo en banda de muerte. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0." ;
    ns1:valor "0-1000000 ms" .

ns1:Parametro_0e7814b322 a ns1:Parametro ;
    rdfs:label "FBACKSEL" ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna. [...] Con el flanco de subida de esta marca se conmuta a la captación externa (captación directa) y con el flanco de bajada se conmuta a captación interna (captación motor)." ;
    ns1:valor "0,1" .

ns1:Parametro_0e8f867adf a ns1:Parametro ;
    rdfs:label "ADDAX"@es ;
    ns1:identificador "ADDAX" ;
    ns1:textoExtracto "ADDAX Eje aditivo paralelo. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.ADDAX[nb]"@es .

ns1:Parametro_0f31341cf2 a ns1:Parametro ;
    rdfs:label "Parámetro V.MTB.P[8]"@es ;
    ns1:identificador "P8" ;
    ns1:textoExtracto "V.MTB.P[8] = 12,5"@es ;
