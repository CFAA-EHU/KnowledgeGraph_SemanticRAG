ns1:LevaNoPeriodica a ns1:ModoOperacion ;
    rdfs:label "Leva no periódica" ;
    ns1:monitoreaParametro ns1:ParametroType ;
    ns1:textoExtracto "No periódica. Se define asignando al parámetro type el valor 'ONCE'. En este modo se mantiene la sincronización para el rango definido del eje maestro." .

ns1:LevaPeriodica a ns1:ModoOperacion ;
    rdfs:label "Leva periódica" ;
    ns1:monitoreaParametro ns1:ParametroType ;
    ns1:textoExtracto "Periódica. Se define asignando al parámetro type el valor 'CONT'. En este modo, al llegar al final del rango del eje maestro se recalcula el offset para volver a ejecutar la leva, desplazada en dicho rango." .

ns1:LicenciaLocal a ns1:Componente ;
    rdfs:label "Licencia local (LOCAL)" ;
    ns1:habilitadoPor ns1:LlaveHardware ;
    ns1:identificador "LOCAL" ;
    ns1:textoExtracto "Elija licencia local si la llave hardware va a estar conectada al PC en el que se está instalando el software del CNC." .

ns1:LicenciaRed a ns1:Componente ;
    rdfs:label "Licencia de red (NET)" ;
    ns1:habilitadoPor ns1:LlaveHardware ;
    ns1:identificador "NET" ;
    ns1:textoExtracto "Elija licencia de red si la llave hardware va a estar conectada a un servidor." .

ns1:LimiteRecorridoNegativo a ns1:Parametro ;
    rdfs:label "Límite de recorrido negativo" ;
    ns1:textoExtracto "ha sobrepasado el límite de recorrido en el sentido negativo (NEG)"@es .

ns1:LimiteRecorridoPositivo a ns1:Parametro ;
    rdfs:label "Límite de recorrido positivo" ;
    ns1:textoExtracto "ha sobrepasado el límite de recorrido en el sentido positivo (POS)"@es .

ns1:LimiteSoftwareEje a ns1:Parametro ;
    rdfs:label "Límite de software del eje" ;
    ns1:monitoreaParametro ns1:PLC_ControlEjes ;
    ns1:textoExtracto "los límites de software y las zonas de trabajo en el eje indicado" .

ns1:LimitesSoftwareCNC a ns1:Parametro ;
    rdfs:label "Límites de software aplicados por el CNC (SL)"@es ;
    ns1:identificador "SL" ;
    ns1:monitoreaParametro ns1:PosicionEjes ;
    ns1:textoExtracto "SL Límites de software, aplicados por el CNC."@es .

ns1:LimitesSoftwareEjes a ns1:Parametro ;
    rdfs:label "Límites de software de ejes"@es,
        "Límites de software de los ejes"@es ;
    ns1:monitoreaParametro ns1:PosicionEjes ;
    ns1:textoExtracto "Los límites de software definen los límites de recorrido de los ejes, para evitar que los carros alcancen los topes mecánicos. El CNC permite definir límites de software en los ejes lineales y ejes rotativos linearlike."@es,
        "de un eje respecto de los límites de software, antes de dar error de límites sobrepasados. El movimiento teórico programado del eje sólo se permite hasta el límite exacto, pero a la cota real del eje se le permite este margen antes de dar error."@es .

ns1:LoadFilter_Accion a ns1:AccionProhibida ;
    rdfs:label "Load filter" ;
    ns1:textoExtracto "Cada vez que se modifica está opción, hay que validarla con el icono \"Load filter\" situado en la parte superior derecha." .

ns1:LubricanteEjes a ns1:Consumible ;
    rdfs:label "Lubricante para ejes" ;
    ns1:textoExtracto "LUBR(axis) se deben utilizar para el engrase de los ejes" .

ns1:M106 a ns1:ModoOperacion,
        ns1:TareaMantenimiento ;
    rdfs:label "M106",
        "Gestión de herramienta en pinza 2"@es ;
    ns1:ejecutadoPor ns1:BrazoCambiador ;
    ns1:identificador "M106" ;
    ns1:requiereMantenimiento ns1:Pinza2 ;
    ns1:textoExtracto "El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar.",
        "Tratamiento de la función M106: • Dar por finalizada cuando el brazo abandona la zona de posible colisión y se puede mecanizar. • Activar la marca CH2TOMZ cuando se haya dejado la herramienta, para que el gestor sepa que la herramienta se ha llevado de la pinza 2 al almacén."@es .

ns1:MAXGLBP a ns1:Parametro ;
    rdfs:label "MAXGLBP" ;
