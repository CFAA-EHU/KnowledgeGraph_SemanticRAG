    ns1:textoExtracto "selección de puntos de entrada/salida, microjuntas y orden de corte" .

ns1:Parametro_OverrideAvance a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override)" ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "El DMC adapta el avance modificando el override. Ver en la página 732. \"18.4.3 Porcentaje de avance (feed override).\"" .

ns1:Parametro_OverrideDMC a ns1:Parametro ;
    rdfs:label "Override del DMC"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "B Override del DMC. Los límites de la barra de consumo serán los definidos en los parámetros máquina."@es .

ns1:Parametro_OverrideFinal a ns1:Parametro ;
    rdfs:label "Override final (DMC + conmutador)"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "J Override final (override del DMC + override del conmutador)."@es .

ns1:Parametro_PANELOFF a ns1:Parametro ;
    rdfs:label "PANELOFF" ;
    ns1:controla ns1:InterfazUsuario_PanelJog ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el panel de jog correspondiente. Se admite PANELOFF o PANELOFF1 para el primer panel de jog."@es .

ns1:Parametro_PANELOFF1 a ns1:Parametro ;
    rdfs:label "PANELOFF1",
        "Registro PANELOFF1"@es ;
    ns1:controla ns1:InterfazUsuario_PanelJog,
        ns1:InterfazUsuario_PanelJog_1 ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "La marca PANELOFF1 deshabilita el primero del bus. Hay una marca para cada panel de jog. Se admite PANELOFF o PANELOFF1 para el primer panel de jog."@es,
        "PANELOFF1: Si el PLC pone esta marca a (=1) se deshabilita el panel de jog correspondiente (primer panel del bus CAN)."@es ;
    ns1:valor "0",
        "1" .

