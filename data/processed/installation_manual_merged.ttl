ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Mechatrolink" ;
    ns1:detalladoEnEsquema ns1:Tabla_DRIVEVAR ;
    ns1:monitoreaParametro ns1:Parametro_DRV_Mechatrolink ;
    ns1:textoExtracto "Características y limitaciones de los dispositivos Mechatrolink. El acceso mediante variables DRV a los dispositivos Mechatrolink tiene las siguientes características y limitaciones: acceso asíncrono a variables (solo lectura) y síncrono a parámetros (lectura/escritura), exclusión entre variables y parámetros por eje, límite de 2 variables por eje.",
        "Mechatrolink. Las variables DRV pueden acceder a las variables y/o parámetros de los servos. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura."@es .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "Módulo PRG del PLC",
        "PLC",
        "Sistema PLC",
        "PLC"@es,
        "Sistema PLC para compensación volumétrica"@es ;
    ns1:controla ns1:Marca_CUTVARACT,
        ns1:Parametro_RESTARTPOINT,
        ns1:Parametro_VOLCOMP1,
        ns1:Parametro_VOLCOMP2,
        ns1:Parametro_VOLCOMP3,
        ns1:Parametro_VOLCOMP4,
        ns1:Sistema_CNC ;
    ns1:cumpleNormativa ns1:Directiva_DEF,
        ns1:Directiva_EXTERN,
        ns1:Directiva_PDEF ;
    ns1:detalladoEnEsquema ns1:Tabla_SeñalesPLC_VOLCOMP ;
    ns1:documentadoEn ns1:Tabla_SenalesLogicasConsultaLaser ;
    ns1:monitoreaParametro ns1:Parametro_V_ch_G_BLKN,
        ns1:Parametro_V_ch_G_LINEN ;
    ns1:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables.",
        "El PLC permite definir una serie de símbolos para facilitar la programación y posterior comprensión del programa de PLC.",
        "módulo PRG del PLC",
        """\r
Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente.\r
Todas las compensaciones volumétricas pueden estar activas simultáneamente, siempre que no haya ejes comunes entre ellas.\r
El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada.\r
"""@es,
        "El PLC activa esta marca cuando el CNC ejecuta un piercing o un cutting después de reiniciar por un punto interrumpido."@es,
        "PLC"@es,
        "el CNC pone la gama que indica el PLC"@es,
        "la maniobra del PLC"@es ;
    ns1:tieneComponente ns1:Parametro_PRGFREQ ;
    ns1:tieneFrecuencia ns1:Frecuencia_PRGFREQ .

