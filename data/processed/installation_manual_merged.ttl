    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC1 (equivalente a TMOPSTROBE). El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ns1:Marca_TMOPSTROBEC2 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC2" ;
    ns1:identificador "TMOPSTROBEC2" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC2. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ns1:Marca_TMOPSTROBEC3 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC3" ;
    ns1:identificador "TMOPSTROBEC3" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC3. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

