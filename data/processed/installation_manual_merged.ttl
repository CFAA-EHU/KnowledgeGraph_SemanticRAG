ns1:Marca_ADVINPOS a ns1:Parametro ;
    rdfs:label "ADVINPOS" ;
    ns1:textoExtracto "También puede utilizarse la marca ADVINPOS." .

ns1:Marca_CNCEX a ns1:Parametro ;
    rdfs:label "Marca CNCEX"@es ;
    ns1:identificador "CNCEX" ;
    ns1:textoExtracto "Esta marca sólo es válida cuando el canal está ejecutando un CNCEX; no en otras ejecuciones de programa o MDI. Una vez anulada la ejecución, el CNC desactiva esta marca y además pone la marca FREE del canal a (=1)."@es .

ns1:Marca_CNCOFF a ns1:InterfazUsuario ;
    rdfs:label "Marca CNCOFF" ;
