ns1:DetencionDeLaRampa a ns1:Parametro ;
    rdfs:label "Detención de la rampa" ;
    ns1:textoExtracto "Diagrama del efecto de TEN en modo monoestable: con el temporizador ya activo, forzar TEN=0 detiene la rampa de t (línea horizontal) y congela T; al restablecer TEN=1, la temporización continúa hasta completar el tiempo programado." .

ns1:DeterminaSiLosEjesSeDesplazanAlAvanceDefinidoEnMAXFEED a ns1:Parametro ;
    rdfs:label "Determina si los ejes se desplazan al avance definido en MAXFEED" ;
    ns1:identificador "MPG.DEFAULTFEED" ;
    ns1:textoExtracto "Este parámetro determina si los ejes se desplazan al avance definido en MAXFEED cuando se programa un movimiento en G01/G02/G03 sin programar el avance." .

ns1:DeterminaSiLosMovimientosProgramadosDesdeElPLCEstanAfectadosPorLaMarca a ns1:Parametro ;
    rdfs:label "Determina si los movimientos programados desde el PLC están afectados por la marca" ;
    ns1:identificador "XFITOIND" ;
    ns1:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND." .

ns1:DiagramaCompensacion a ns1:Figura ;
    rdfs:label "Diagrama de compensación con eje esclavo" ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser." .

ns1:DiagramaPrimeraPalpacion a ns1:Figura ;
    rdfs:label "Diagrama Primera Palpación" ;
    ns1:textoExtracto "Diagrama 'Primera palpación': C=0°, B=+90°, contacto sobre cara Z con preselección Z=0; se destaca la rotación de B y el sistema de ejes X-Z." .

ns1:DiagramaSegundaPalpacion a ns1:Figura ;
    rdfs:label "Diagrama Segunda Palpación" ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': C=0°, B=−90°, repetición sobre cara Z con lectura ΔZ; ilustra el cambio del centro de giro ① y la lectura que interviene en la ecuación de TDATA2." .

ns1:DiagramaSincronizacionAuxEnd a ns1:Figura ;
    rdfs:label "Diagrama de sincronización AUXEND/MSTROBE" ;
    ns1:ilustradoEn ns1:Pagina439 ;
    ns1:textoExtracto "Diagrama de sincronización AUXEND/MSTROBE con eje temporal y marcas numeradas (1–4) asociado a la ejecución de funciones auxiliares S/M. Representa la desactivación/activación de AUXEND respecto a STROBE y el tiempo mínimo MINAENDW para finalizar la sincronización." .

ns1:DiagramaTecladoJogPanel a ns1:Esquema ;
    rdfs:label "Diagrama de teclado con nueve casillas activas" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido." .

ns1:DiagramaTecladoLCD10K a ns1:Esquema ;
    rdfs:label "Diagrama de teclado LCD-10K" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog." .

ns1:DiagramaTemporalEntradaTEN a ns1:Figura ;
    rdfs:label "Diagrama temporal de la entrada TEN" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TEN (enable) y su efecto sobre el temporizador: se representan, en paralelo y a lo largo del eje temporal, las señales TEN y TG1/TGx (flancos de activación), la rampa de conteo t (creciente desde 0) y el estado lógico T (alto mientras la temporización está activa)." .

ns1:DiagramaTemporalEntradaTRS a ns1:Figura ;
    rdfs:label "Diagrama temporal de la entrada TRS" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TRS (reset): se muestran los flancos de subida de TRS que inicializan el temporizador (T→0 y t→0), así como la dependencia de la reactivación mediante la entrada de arranque." .

ns1:DiagramaTemporalReset a ns1:Figura ;
    rdfs:label "Diagrama temporal Proceso de reset con RESETIN" ;
    ns1:ilustradoEn ns1:Pagina439 ;
    ns1:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t. Muestra flancos de subida/bajada, orden de eventos y la relación entre marcas del PLC y respuesta del canal durante el reset." .

ns1:DiagramaTerceraPalpacion a ns1:Figura ;
    rdfs:label "Diagrama Tercera Palpación" ;
    ns1:textoExtracto "Diagrama 'Tercera palpación': B=+90°, C=0°, palpación de la segunda cara X con lectura ΔX; muestra la simetría del procedimiento respecto al giro de B." .

