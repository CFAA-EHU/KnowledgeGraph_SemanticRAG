ns1:TablaDeVariablesDeAvanceSobreTrayectoriaPag624 a ns1:Tabla ;
    rdfs:label "Tabla de variables de avance sobre trayectoria (pág. 624)"@es ;
    ns1:textoExtracto """\r
| Variables. | PRG | PLC | INT |\r
| --- | --- | --- | --- |\r
| (V.)[ch].G.PATHFEED\r
Avance teórico sobre la trayectoria. Unidades: Milímetros/minuto o pulgadas/minuto. | R(*) | R | R |\r
| (V.)[ch].G.FREAL\r
Avance real filtrado sobre la trayectoria. Esta variable tiene en cuenta\r
el override y las aceleraciones y deceleraciones de la máquina. Unidades: Milímetros/minuto o pulgadas/minuto. | R(*) | R | R\r
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

ns1:TablaFuncionesM_561 a ns1:Tabla ;
    rdfs:label "Tabla de funciones M (sincronización)" ;
    ns1:documentadoEn ns1:Pagina_248,
