ns1:InstruccionLatcheoCota_766 a ns1:TareaMantenimiento ;
    rdfs:label "Instrucción de latcheo de cota con TOUCHPROBE"@es ;
    ns1:documentadoEn ns1:Manual_Seccion4_4_10 ;
    ns1:requiereMantenimiento ns1:SistemaCNC_766 ;
    ns1:textoExtracto "Se entiende por latcheo de cota a que el CNC capture la cota de un eje cuando se produce un evento dado. La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador, de una entrada digital física o de una entrada lógica."@es .

ns1:InstruccionMDS_742 a ns1:Parametro ;
