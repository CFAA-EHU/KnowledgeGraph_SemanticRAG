    ns1:tieneComponente ns1:EntradasDigitales_Nodo1,
        ns1:SalidasDigitales_Nodo1 .

ns1:Nodo2_RIO5 a ns1:Sistema ;
    rdfs:label "Nodo 2: Grupo remoto RIO5"@es ;
    ns1:identificador "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno."@es ;
    ns1:tieneComponente ns1:ModuloEntradasDigitales_24I_N2_1,
        ns1:ModuloEntradasDigitales_24I_N2_2,
        ns1:ModuloEntradasDigitales_24I_N2_3 .

ns1:Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2: Grupo remoto RIOR"@es ;
    ns1:identificador "Nodo 2 (RIOR)" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales."@es ;
    ns1:tieneComponente ns1:EntradasDigitales_Nodo2,
        ns1:SalidasDigitales_Nodo2 .

ns1:Nodo3_RIO5 a ns1:Sistema ;
    rdfs:label "Nodo 3: Grupo remoto RIO5"@es ;
    ns1:identificador "Nodo 3" ;
    ns1:textoExtracto "Nodo 3: Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno."@es ;
    ns1:tieneComponente ns1:ModuloEntradasDigitales_24I_N3_1,
        ns1:ModuloEntradasDigitales_24I_N3_2 .

ns1:NodoModulo_1266 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo-módulo del bus CANopen"@es ;
    ns1:controla ns1:EntradaSalidaDigital_1266 ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus."@es .

ns1:Nodo_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (RIO5)",
        "Nodo RIO5" ;
    ns1:compuestoPor ns1:Modulo_24DI_1_RIO5,
        ns1:Modulo_24DI_2_RIO5,
        ns1:Modulo_24DI_3_RIO5 ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques.",
        "chasis RIO5 con tres módulos de 24 entradas (24+48). Se muestran múltiples tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8), velocidades y dirección, ilustrando la suma de bloques lógicos por módulo." .

ns1:Nodo_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOR)",
        "Nodo RIOR" ;
    ns1:compuestoPor ns1:Bloque_48DI_RIOR ;
    ns1:identificador "I97-O81" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques.",
        "tarjeta RIOR similar a la anterior, configurada como bloque de 48 entradas y 32 salidas con inicio en I97 y O81. La imagen enfatiza la equivalencia física con una numeración distinta por bloques lógicos." .

ns1:Nodo_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOW)",
        "Nodo RIOW" ;
    ns1:compuestoPor ns1:Bloque_24DI_RIOW,
        ns1:Bloque_40DI_RIOW ;
    ns1:identificador "I104-I200" ;
    ns1:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee, tanto en número como en dimensión.",
        "bastidor RIOW con 64 entradas digitales, representado como dos bloques (24 y 40 entradas) iniciados en direcciones altas (I104 e I200)." .

ns1:OP_PANEL_1 a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL (variante 1)" ;
    ns1:ilustradoEn ns1:EsquemaTeclasJog ;
    ns1:textoExtracto "Conjunto de tres diagramas de paneles (dos 'OP-PANEL' y un 'LCD-10K') que muestran la disposición de 15 teclas numeradas y el bloque 'USERKEYS'." ;
    ns1:tieneComponente ns1:BloqueUSERKEYS .

ns1:OP_PANEL_2 a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL (variante 2)" ;
    ns1:ilustradoEn ns1:EsquemaTeclasJog ;
    ns1:textoExtracto "Tres diagramas paralelos de teclados (dos 'OP-PANEL' y un 'LCD-10K')." ;
    ns1:tieneComponente ns1:BloqueUSERKEYS .

ns1:OP_PANEL_H_E a ns1:InterfazUsuario ;
    rdfs:label "Módulo OP-PANEL-H/E (panel de control)" ;
    ns1:identificador "OP-PANEL-H/E" ;
    ns1:textoExtracto "En versiones anteriores, la marca PANELOFF del PLC deshabilitaba tanto la parte de jog como la parte alfanumérica (módulo OP-PANEL-H/E)." .

ns1:OpcionSoftwareGapControl a ns1:Componente ;
    rdfs:label "Opción de software 'GAP CONTROL'" ;
    ns1:identificador "GAP CONTROL" ;
    ns1:textoExtracto "Para el control del gap es necesario disponer de la opción de software 'GAP CONTROL'." .

ns1:OpcionSoftware_CANopenTerceros a ns1:ModoOperacion ;
    rdfs:label "CANopen de terceros" ;
    ns1:textoExtracto "Nueva opción de software \"CANopen de terceros\"." .

ns1:OpcionSoftware_SistemaCerrado a ns1:Parametro ;
    rdfs:label "Sistema cerrado (opción de software)"@es ;
    ns1:identificador "Sistema cerrado" ;
    ns1:textoExtracto "dispone de un 'Sistema cerrado'"@es .

ns1:OpenPCS_InterfazConexionFagorCNCTCP a ns1:InterfazUsuario ;
    rdfs:label "Diálogo Connections → FagorCNCTCP → Edit"@es ;
    ns1:textoExtracto "Diálogo \"Connections → FagorCNCTCP → Edit\" del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a \"Settings\"."@es ;
    ns1:tieneComponente ns1:OpenPCS_AccesoSettings,
        ns1:OpenPCS_BotonCancel,
        ns1:OpenPCS_BotonOK,
        ns1:OpenPCS_ParametroHost,
        ns1:OpenPCS_ParametroIP,
        ns1:OpenPCS_ParametroPuerto .

ns1:OpenPCS_InterfazSettings a ns1:InterfazUsuario ;
    rdfs:label "Diálogo Settings de conexión FagorCNCTCP"@es ;
    ns1:textoExtracto "Diálogo \"Settings\" de la conexión mostrando edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC); campos de host/puerto y botones \"OK/Cancel\"."@es ;
    ns1:tieneComponente ns1:OpenPCS_BotonCancel,
        ns1:OpenPCS_BotonOK,
        ns1:OpenPCS_ParametroHost,
        ns1:OpenPCS_ParametroIP,
        ns1:OpenPCS_ParametroPuerto .

ns1:OpenPCS_Remoto_1381 a ns1:Sistema ;
    rdfs:label "OpenPCS remoto"@es ;
    ns1:identificador "IEC-61131" ;
    ns1:textoExtracto "El OpenPCS deberá estar instalado en un PC externo, el cual podrá estar conectado al CNC a través de una red o un cable cruzado. [...] Configurar el CNC para utilizar el PLC remoto."@es .

ns1:OperacionAlmacen_7 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén" ;
    ns1:ejecutadoPor ns1:Pinza_1 ;
    ns1:identificador "TMOPERATION = 7" ;
    ns1:textoExtracto "TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra. La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 2-1-3. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:OperacionAlmacen_782_01 a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en cabezal y activar marca GRTOSPDL"@es ;
    ns1:identificador "TMOPERATION = 7" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es .

ns1:OperacionAlmacen_782_02 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra y tomar herramienta del almacén"@es ;
    ns1:identificador "TAKEPOS=# ; LEAVEPOS=-4" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén."@es .

ns1:OperacionAlmacen_782_03 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra y activar SPDLTOGR"@es ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR."@es .

ns1:OperacionAlmacen_782_04 a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta del almacén en cabezal"@es ;
    ns1:textoExtracto "Poner la herramienta del almacén en el cabezal y activar la"@es .

ns1:OperacionAlmacen_7_11_2 a ns1:ModoOperacion ;
    rdfs:label "Operación de gestión de herramientas en almacén (Sección 7.11.2)"@es ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta. [...] La secuencia de esta operación es la siguiente. En esta operación, el gestor admite dos secuencias. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1."@es ;
    ns1:tieneComponente ns1:Pinza1 .

ns1:OperacionAlmacen_8 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra" ;
    ns1:identificador "TMOPERATION = 8" ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:OperacionAlmacen_9 a ns1:TareaMantenimiento ;
    rdfs:label "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal" ;
    ns1:ejecutadoPor ns1:Pinza_2 ;
    ns1:identificador "TMOPERATION = 9" ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:OperacionAlmacen_935 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de transferencia de herramienta (TMOPERATION=10)"@es ;
    ns1:ejecutadoPor ns1:Pinza_1 ;
    ns1:identificador "TMOPERATION=10" ;
    ns1:requiereMantenimiento ns1:Herramienta_935_1 ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. [...] TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:OperacionAlmacen_937 a ns1:ModoOperacion ;
    rdfs:label "Operación de intercambio de herramientas en almacén"@es ;
    ns1:controla ns1:Marca_CH1TOMZ,
        ns1:Marca_CH1TOSPDL,
        ns1:Marca_MZTOCH1,
        ns1:Marca_SPDLTOCH1 ;
    ns1:ejecutadoPor ns1:Pinza_1 ;
    ns1:identificador "7.9.2" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1. 2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ. 3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es .

ns1:OperacionAlmacen_958 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de transferencia de herramienta (almacén ↔ tierra)"@es ;
    ns1:identificador "TMOPERATION=10" ;
    ns1:requiereMantenimiento ns1:Herramienta_958_Pinza2 ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 3 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:OperacionAlmacen_Desconocida a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta en el almacén" ;
    ns1:textoExtracto "del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:OperacionAlmacen_Seq1 a ns1:TareaMantenimiento ;
    rdfs:label "Primera secuencia de operación del almacén"@es ;
    ns1:identificador "Seq1" ;
    ns1:ilustradoEn ns1:Marca_CH1TOSPDL,
        ns1:Marca_CH2TOMZ,
        ns1:Marca_SPDLTOCH2 ;
    ns1:requiereMantenimiento ns1:Pinza_1,
        ns1:Pinza_2 ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es .

ns1:OperacionAlmacen_Seq2 a ns1:TareaMantenimiento ;
    rdfs:label "Segunda secuencia de operación del almacén"@es ;
    ns1:identificador "Seq2" ;
    ns1:ilustradoEn ns1:Marca_CH1TOSPDL,
        ns1:Marca_CH2TOMZ,
        ns1:Marca_SPDLTOCH2,
        ns1:Marca_TCHANGEOK ;
    ns1:requiereMantenimiento ns1:Pinza_1,
        ns1:Pinza_2 ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL. 3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK. 5 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ."@es .

ns1:OperacionAlmacen_TM1 a ns1:TareaMantenimiento ;
    rdfs:label "Asumir herramienta activa"@es ;
    ns1:activaAlarma ns1:Marca_MZTOSPDL ;
    ns1:identificador "TMOPERATION = 1" ;
    ns1:textoExtracto "TMOPERATION = 1 Asumir la herramienta actual como herramienta activa."@es .

ns1:OperacionAlmacen_TM10 a ns1:TareaMantenimiento ;
    rdfs:label "Transportar herramienta del almacén a tierra vía cabezal"@es ;
    ns1:activaAlarma ns1:Marca_SPDLTOGR ;
    ns1:identificador "TMOPERATION = 10" ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:OperacionAlmacen_TM11 a ns1:TareaMantenimiento ;
    rdfs:label "Orientar almacén"@es ;
    ns1:activaAlarma ns1:Marca_MZROT ;
    ns1:identificador "TMOPERATION = 11" ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén."@es .

ns1:OperacionAlmacen_TM15 a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar posición del almacén"@es ;
    ns1:identificador "TMOPERATION = 15" ;
    ns1:textoExtracto "TMOPERATION = 15 Seleccionar una posición del almacén. TAKEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo."@es .

ns1:OperacionAlmacen_TM3 a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en cabezal"@es ;
    ns1:activaAlarma ns1:Marca_GRTOSPDL ;
    ns1:identificador "TMOPERATION = 3" ;
    ns1:requiereEPI ns1:HerramientaTierra ;
    ns1:textoExtracto "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra."@es .

ns1:OperacionAlmacen_TM4 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en tierra"@es ;
    ns1:activaAlarma ns1:Marca_SPDLTOGR ;
    ns1:identificador "TMOPERATION = 4" ;
    ns1:textoExtracto "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra."@es .

ns1:OperacionAlmacen_TM9 a ns1:TareaMantenimiento ;
    rdfs:label "Transportar herramienta de tierra al almacén vía cabezal"@es ;
    ns1:activaAlarma ns1:Marca_GRTOSPDL ;
    ns1:identificador "TMOPERATION = 9" ;
    ns1:requiereEPI ns1:HerramientaTierra ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal."@es .

ns1:OperacionAlmacenamientoHerramientas_961 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de almacenamiento de herramientas (MZID)"@es ;
    ns1:requiereMantenimiento ns1:Herramienta_Almacen,
        ns1:Herramienta_Cabezal,
        ns1:Pinza_1,
        ns1:Pinza_2 ;
    ns1:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es .

ns1:OperacionCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (coger/dejar)"@es,
        "Operación de cambio de herramienta (TMOPERATION=11)"@es ;
    ns1:detalladoEnEsquema ns1:GestorHerramientasCNC ;
    ns1:ejecutadoPor ns1:AlmacenHerramientas_7_11_2 ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:requiereMantenimiento ns1:Pinza1,
        ns1:Pinza2 ;
    ns1:textoExtracto "En el cambio de herramienta pueden estar implicados dos almacenes. [...] Cuando se realiza un cambio de herramienta, ésta siempre se guarda en el almacén del que se cogió."@es,
        "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1. Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es .

ns1:OperacionCambioHerramientaEntreAlmacenes a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en almacén y coger de otro (TMOPERATION=14)"@es ;
    ns1:controla ns1:MarcaMZTOSPDL,
        ns1:MarcaSPDLTOMZ ;
    ns1:identificador "TMOPERATION=14" ;
    ns1:requiereMantenimiento ns1:OperacionOrientarDosAlmacenes ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es .

ns1:OperacionCambioHerramienta_TM10 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (TMOPERATION=10): Coger herramienta del almacén y dejarla en tierra"@es ;
    ns1:identificador "TMOPERATION=10" ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra."@es .

ns1:OperacionCambioHerramienta_TM11 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (TMOPERATION=11): Coger herramienta del almacén con pinza 1"@es ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:requiereMantenimiento ns1:Pinza1 ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es .

ns1:OperacionCambioHerramienta_TM8 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (TMOPERATION=8): Dejar herramienta en tierra y coger herramienta de tierra"@es ;
    ns1:identificador "TMOPERATION=8" ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es .

ns1:OperacionCambioHerramienta_TM9 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (TMOPERATION=9): Llevar herramienta de tierra al almacén"@es ;
    ns1:identificador "TMOPERATION=9" ;
    ns1:requiereMantenimiento ns1:HerramientaTierra,
        ns1:Pinza2 ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS=-4 Herramienta de tierra."@es .

ns1:OperacionCargaHerramienta_7.5 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de carga de herramienta (T1 M6 en modo carga)"@es ;
    ns1:identificador "TMOPERATION=9" ;
    ns1:requiereMantenimiento ns1:ModoCargaAlmacen_7.5 ;
    ns1:textoExtracto "Si a continuación se ejecuta la instrucción T1 M6 el gestor entiende que se desea llevar la herramienta T1 de tierra al almacén pasando por el cabezal y se lo comunicará al PLC con TMOPERATION=9."@es .

ns1:OperacionCogerHerramienta a ns1:ModoOperacion ;
    rdfs:label "Coger herramienta del almacén (Caso 1)"@es ;
    ns1:habilitadoPor ns1:Subrutina_SUB_ARM_BACK,
        ns1:Subrutina_SUB_ARM_TO_CHG,
        ns1:Subrutina_SUB_CH1_TO_SPD,
        ns1:Subrutina_SUB_SPD_AUTCHG ;
    ns1:textoExtracto """\r
    $CASE 1 ; Coger una herramienta del almacén y ponerla en el cabezal.\r
    Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1.\r
    """@es ;
    ns1:valor "1" .

ns1:OperacionCogerHerramientaDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén (TMOPERATION=1)" ;
    ns1:activaAlarma ns1:MarcaMZTOSPDL ;
    ns1:textoExtracto "TMOPERATION = 1 Coger una herramienta del almacén y ponerla en el cabezal. TAKEPOS=# Posición del almacén para coger la herramienta." .

ns1:OperacionDejarHerramienta a ns1:ModoOperacion ;
    rdfs:label "Dejar herramienta en el almacén (Caso 2)"@es ;
    ns1:habilitadoPor ns1:Subrutina_SUB_ARM_TO_CHG,
        ns1:Subrutina_SUB_SPD_AUTCHG ;
    ns1:textoExtracto "$CASE 2 ; Dejar la herramienta del cabezal en el almacén."@es ;
    ns1:valor "2" .

ns1:OperacionDejarHerramientaEnAlmacen a ns1:TareaMantenimiento ;
