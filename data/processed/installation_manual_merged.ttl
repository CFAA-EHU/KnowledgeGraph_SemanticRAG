    ns1:identificador "I10" ;
    ns1:textoExtracto "I10 = PARKEDV Eje presente. Sensor de presencia del eje 'V'." .

ns1:Sensor_SERVOON a ns1:Sensor ;
    rdfs:label "SERVOON" ;
    ns1:controla ns1:ModoOperacion_DesplazamientoEje ;
    ns1:textoExtracto "la marca SERVOON. [...] Si transcurrido este tiempo la señal SERVOON siga sin estar activa, el CNC muestra el error 'eje bloqueado'" .

ns1:SistemaAlmacenamiento_Asincrono a ns1:Sistema ;
    rdfs:label "Sistema de cambio asíncrono (carrusel-gantry + brazo de doble pinza)"@es ;
    ns1:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta; flechas indican secuencia alrededor del cabezal."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_BrazoDoblePinza,
        ns1:ComponenteMecanico_CarruselGantry .

ns1:SistemaCaptacionMixta a ns1:Sistema ;
    rdfs:label "Sistema de captación mixta (externa+interna)",
        "Sistema de captación interna+externa"@es ;
    ns1:monitoreaParametro ns1:Parametro_FBACKSRC,
        ns1:Parametro_FBMIXTIME ;
    ns1:textoExtracto "FBACKSEL(axis) [...] cuando el sistema dispone de captación externa+interna. [...] con el flanco de subida de esta marca se conmuta a la captación externa (captación directa) y con el flanco de bajada se conmuta a captación interna (captación motor)",
        "Cuando el tipo de captación es interna+externa, el CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos."@es ;
    ns1:tieneComponente ns1:ComponenteCaptacionMotor,
        ns1:SensorCaptacionExterna,
        ns1:SensorCaptacionInterna .

ns1:SistemaControlAparcado a ns1:Sistema ;
    rdfs:label "Sistema de control de aparcado/desaparcado de ejes"@es ;
    ns1:compuestoPor ns1:ManiobraAparcarEje,
        ns1:ManiobraDesaparcarEje ;
    ns1:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC [...] Maniobra para desaparcar un eje o cabezal desde el CNC"@es ;
    ns1:tieneComponente ns1:ReguladorEjeDigital,
        ns1:SensorPresenciaEje .

ns1:SistemaEjes a ns1:Sistema ;
    rdfs:label "Sistema de movimiento de ejes" ;
    ns1:textoExtracto "el CNC detiene el movimiento de los ejes respetando la rampa de frenado y controlando el GAP durante la rampa" .

ns1:SistemaEjesGantry_1104 a ns1:Sistema ;
