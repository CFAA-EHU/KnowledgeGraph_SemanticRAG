ns1:Frecuencia_1000kHz a ns1:Frecuencia ;
    rdfs:label "1000 kHz" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "Hasta 20 metros."@es ;
    ns1:valor "1000" .

ns1:Frecuencia_1MHz_RecomendadaLaser a ns1:Frecuencia ;
    rdfs:label "1 MHz (recomendada para modelo láser)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "Para el modelo láser con módulos RIOR, se recomienda utilizar una frecuencia de comunicación de 1 MHz."@es ;
    ns1:valor "1000" .

ns1:Frecuencia_250kHz a ns1:Frecuencia ;
    rdfs:label "250 kHz" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "Entre 100 y 500 metros. [...] sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR; en los módulos remotos de la serie RIO5 no está disponible esta velocidad."@es ;
    ns1:valor "250" .

ns1:Frecuencia_2MHz_462 a ns1:Frecuencia ;
    rdfs:label "Frecuencia por defecto (2 MHz)"@es ;
    ns1:textoExtracto "Valor por defecto: 2 MHz. Se recomienda utilizar la frecuencia por defecto (2 MHz), válida hasta 100 m de cable."@es ;
    ns1:valor "2 MHz" .

ns1:Frecuencia_4MHz_462 a ns1:Frecuencia ;
    rdfs:label "Frecuencia máxima (4 MHz)"@es ;
    ns1:textoExtracto "Para seleccionar la velocidad de 4 MHz, el encoder debe poder trabajar a esa velocidad y la longitud del cable debe ser inferior a los 50m."@es ;
    ns1:valor "4 MHz" .

ns1:Frecuencia_500kHz a ns1:Frecuencia ;
    rdfs:label "500 kHz" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "Entre 40 y 100 metros."@es ;
    ns1:valor "500" .

ns1:Frecuencia_800kHz a ns1:Frecuencia ;
    rdfs:label "800 kHz" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "Entre 20 y 40 metros."@es ;
    ns1:valor "800" .

ns1:Frecuencia_Autoscan a ns1:Frecuencia ;
    rdfs:label "Autoscan" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusCAN_71 ;
    ns1:textoExtracto "El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos. Dependiendo de la configuración del bus, esta opción puede hacer que el arranque del CNC sea más lento que si hay una frecuencia definida."@es .

ns1:Fresadora_1Canal_5Ejes_1Cabezal a ns1:Maquina ;
    rdfs:label "Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal"@es ;
    ns1:compuestoPor ns1:SistemaEjes_Canal1 ;
    ns1:textoExtracto "Supongamos una máquina de un canal con tres ejes y cabezal y dos ejes sin asignar inicialmente. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S). Sin asignar. 2 ejes (A B)"@es ;
    ns1:tieneComponente ns1:Cabezal_S1,
        ns1:Eje_A,
        ns1:Eje_B,
        ns1:Eje_X,
        ns1:Eje_Y,
        ns1:Eje_Z .

ns1:Fresadora_3Canales_9Ejes_2Cabezales a ns1:Maquina ;
    rdfs:label "Fresadora con 3 canales, 9 ejes y 2 cabezales"@es ;
    ns1:textoExtracto "Supongamos una máquina con tres canales dónde los dos primeros canales disponen de ejes y cabezales para mecanizar y el tercer canal es un sistema de carga y descarga controlado por dos ejes."@es ;
    ns1:tieneComponente ns1:Canal_1,
        ns1:Canal_2,
        ns1:Canal_3 .

