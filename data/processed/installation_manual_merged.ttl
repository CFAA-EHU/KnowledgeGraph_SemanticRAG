    ns1:textoExtracto "Ambas operaciones se realizan desde la tabla de herramientas y almacén, mediante las softkeys 'Salvar' y 'Cargar'."@es .

ns1:InterfazUsuario_TablaHerramientas_CNC a ns1:InterfazUsuario ;
    rdfs:label "Tabla de herramientas CNC (Sección 18.3)"@es ;
    ns1:ilustradoEn ns1:Tabla_ParametrosHerramientas_18_3 ;
    ns1:textoExtracto "Captura de interfaz de la tabla de herramientas del CNC con resaltados 'A' (tipo de herramienta) y 'B' (número de dientes 1–100). Incluye lista de herramientas, iconos, campos editables y un panel contextual de parámetros, útil para que el DMC limite el avance por diente."@es .

ns1:InterfazUsuario_TeclaAvanceRapido a ns1:InterfazUsuario ;
