    ns1:valor "200" .

ns1:Parametro_MAXERROR a ns1:Parametro ;
    rdfs:label "MAXERROR" ;
    ns1:textoExtracto "Error de posición.",
        "MAXERROR Error de posición. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 9999.99999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 9999.99999 grados. Valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados. Variable asociada: (V.)[ch].MPA.MAXERROR[set].xn Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." ;
    ns1:valor "0.1000"^^xsd:string,
        "Error de posición" .

ns1:Parametro_MAXERROR_HSC a ns1:Parametro ;
    rdfs:label "Máximo error de posición del eje en HSC"@es ;
    ns1:identificador "MPA.MAXERROR[set].xn" ;
    ns1:textoExtracto "Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo. Valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados. Variable asociada: (V.)[ch].MPA.MAXERROR[set].xn"@es ;
    ns1:valor "0.1000" .

ns1:Parametro_MAXFREQ a ns1:Parametro ;
    rdfs:label "MAXFREQ",
        "MAXFREQ"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceG00 ;
    ns1:identificador "MAXFREQ",
        "V.[ch].MPG.MAXFREQ" ;
    ns1:textoExtracto "MAXFREQ Frecuencia necesaria para alcanzar G00FEED. [...] Valores posibles: De 0.0010 a 10000.0000 Hz. Valor por defecto: 50 Hz."@es,
        "MAXFREQ Máxima frecuencia generada sobre la trayectoria de mecanizado. Valores posibles: De 0 a 500 Hz. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.MAXFREQ"@es ;
    ns1:valor 0,
        "50" .

ns1:Parametro_MAXJERK a ns1:Parametro ;
    rdfs:label "MAXJERK",
        "Variable (V.)[ch].G.MAXJERK"@es ;
    ns1:identificador "(V.)[ch].MPG.MAXJERK",
        "G.MAXJERK" ;
    ns1:monitoreaParametro ns1:Variable_Temporal_MAXJERK ;
    ns1:textoExtracto "Máximo jerk sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 6E11 mm/min / de 0.00004 a 2.362E10 inch/min. Valor por defecto: No hay avance máximo. Este parámetro permite suavizar el avance sobre la trayectoria, limitando el jerk máximo sobre ella.",
        "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina."@es ;
    ns1:valor "6E11 mm/min (límite superior)",
        "temporal"@es .

ns1:Parametro_MAXOFFSET_TDATA_I a ns1:Parametro ;
    rdfs:label "MAX OFFSET (TDATA_I)" ;
    ns1:textoExtracto "MAX OFFSET: A definir por el OEM. Máximo offset que puede definir el usuario. [...] Variable asociada: (V.)MPK.MAXOFTDATA_Ikin[nb]" ;
    ns1:valor "A definir por el OEM" .

ns1:Parametro_MAXROUND a ns1:Parametro ;
    rdfs:label "MAXROUND",
        "MAXROUND (Máximo error de redondeo en G5)",
        "Parámetro MAXROUND" ;
    ns1:identificador "MAXROUND",
        "V.[ch].MPG.MAXROUND" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "Este parámetro define la desviación máxima permitida entre el punto programado y el perfil resultante del matado de arista. El CNC lo tiene en cuenta con ROUNDTYPE = Error cordal. Este parámetro también define el error de contorno máximo permitido para el modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST).",
        "MAXROUND Máximo error de redondeo en G5.",
        "MAXROUND Máximo error de redondeo en G5. Valores posibles: De 0.02 a 99999.9999 mm o grados / de 0.00079 a 3937.00787 inch. Valor por defecto: 0.1000 mm o grados / 0.00394 inch." ;
    ns1:valor "0.00394 inch",
        "0.1000 mm / 0.00394 inch" .

