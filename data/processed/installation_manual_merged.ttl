    ns1:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID).",
        "Tabla de identificadores de la ruleta asociadas a las contadoras Sercos. Valores posibles: De 1 a 15.",
        "Tabla de identificadores de la ruleta asociadas a las contadoras Sercos"@es ;
    ns1:valor "1-15"^^xsd:string .

ns1:Parametro_SHORTESTWAY_60 a ns1:Parametro ;
