ns1:ProgramaPLC_694 a ns1:Sistema ;
    rdfs:label "Programa PLC combinado (mnemónicos, contactos, C)"@es ;
    ns1:compuestoPor ns1:FicheroContactos_694,
        ns1:FicheroLenguajeC_694,
        ns1:FicheroMnemotecnicos_694 ;
    ns1:identificador "\\MTB\\PLC\\PROJECT" ;
    ns1:textoExtracto "El programa de PLC puede combinar varios ficheros en lenguaje de mnemónicos (extensión \"plc\"), varios ficheros en lenguaje C (extensión \"c\") y un fichero en lenguaje de contactos (extensión \"ld\"). Todos los ficheros que componen el programa PLC deben estar en el directorio \\MTB\\PLC\\PROJECT."@es ;
    ns1:tieneComponente ns1:SubrutinaSUMA_694 .

ns1:ProgramaPLC_ManiobraVolante a ns1:Sistema ;
    rdfs:label "Programa PLC para maniobra del volante de avance" ;
