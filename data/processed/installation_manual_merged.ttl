        ns1:Parametro_TDATA6 ;
    ns1:ilustradoEn ns1:Pagina_270 ;
    ns1:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan, con flechas y cotas, la posición del eje rotativo del cabezal (TDATA1–TDATA3), la ubicación del eje de mesa (TDATA4–TDATA6) y la colocación del cabezal (TDATA13–TDATA15), junto a los casos de TDATA11."@es .

ns1:Esquema_Cinematica_TYPE17 a ns1:Esquema ;
