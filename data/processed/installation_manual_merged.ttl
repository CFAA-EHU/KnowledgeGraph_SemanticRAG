| 0 | 10000 | 6000 | 10000 | 6000 |\r
| 4000 | 10000 | 6000 | 4000 | 4000 |\r
| 7000 | 10000 | 6000 | 7000 | 4000 |\r
| 12000 | 10000 | 6000 | 10000 | 6000 """@es .

