ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:identificador "LOOPTIME",
        "MPG.LOOPTIME" ;
    ns1:monitoreaParametro ns1:BusCAN,
        ns1:Sistema_PLC ;
    ns1:textoExtracto "LOOPTIME Tiempo de ciclo del CNC. Valores posibles: De 1 a 20 ms. Valor por defecto: 4 ms. Variable asociada: (V.)MPG.LOOPTIME Este parámetro fija el periodo de muestreo que utiliza el CNC.",
        "parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación",
        "periodo de muestreo LOOPTIME = 4 ms",
        "El tiempo de ciclo del bus está definido por el parámetro LOOPTIME."@es,
        "Se recomienda utilizar un tiempo de ciclo de 2 milisegundos (LOOPTIME=2)."@es,
        "periodo de muestreo de 4 ms (LOOPTIME=4)"@es ;
    ns1:valor 4,
        "2",
        "4 ms",
        "LOOPTIME" .

ns1:Parametro_LOSPDLIM a ns1:Parametro ;
    rdfs:label "LOSPDLIM" ;
    ns1:textoExtracto "porcentajes fijados por los parámetros máquina LOSPDLIM" .

ns1:Parametro_LSCRWDATA a ns1:Parametro ;
    rdfs:label "LSCRWDATA - Tabla de compensación de husillo" ;
    ns1:identificador "LSCRWDATA" ;
    ns1:textoExtracto "LSCRWDATA Tabla de compensación de husillo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra la tabla para definir la compensación de husillo." .

ns1:Parametro_LSCRWDATA_BIDIR a ns1:Parametro ;
