    ns1:documentadoEn ns1:Tabla_2.3.31_ControlGap ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap."@es ;
    ns1:valor "No" .

ns1:ConfiguracionNumeracionRecursosBus a ns1:Sistema ;
