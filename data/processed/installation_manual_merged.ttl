    rdfs:label "Precarga en reposo" ;
    ns1:textoExtracto "Precarga en reposo." .

ns1:Esquema_Precarga_VelocidadConstante_1 a ns1:Esquema ;
    rdfs:label "Precarga a velocidad constante (par de fricción > precarga)" ;
    ns1:textoExtracto "Precarga a velocidad constante. Par de fricción > Precarga." .

ns1:Esquema_Precarga_VelocidadConstante_2 a ns1:Esquema ;
