    rdfs:label "AXISTYPE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "AXISTYPE Tipo de eje. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: Lineal / Rotativo / Cabezal. Valor por defecto: Lineal.",
        "AXISTYPE | Rotativo.",
        "Parámetro: AXISTYPE | Valor: Rotativo." ;
    ns1:valor "Lineal",
        "Rotativo" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE",
        "Parámetro COUNTERTYPE",
        "Parámetro COUNTERTYPE (Tipo de entrada de captación del eje)" ;
    ns1:documentadoEn ns1:TablaParametrosVolanteJog,
        ns1:Tabla_MANPG,
        ns1:Tabla_ParametrosMPG_488 ;
    ns1:identificador "COUNTERTYPE",
        "MPMAN.COUNTERTYPE[hw]" ;
    ns1:monitoreaParametro ns1:Sistema_EjesAnalogicos,
        ns1:Sistema_EntradaCaptacionVolante ;
    ns1:textoExtracto "COUNTERTYPE Tipo de entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto.",
        "COUNTERTYPE Tipo de entrada de captación del volante. Valores posibles: Remoto / Teclado / Local / Contadora Sercos / Variable. Valor por defecto: Remoto.",
        "COUNTERTYPE | Tipo de entrada de captación del eje.",
        "La selección se realiza mediante el parámetro COUNTERTYPE.",
        "Tipo de entrada de captación del eje.",
        "Tipo de entrada de captación del eje; regulador, local o remota.",
        "Tipo de entrada de captación del volante.",
        "cambiar el valor del parámetro COUNTERTYPE de 'remoto' a 'regulador' en los ejes implicados",
        "COUNTERTYPE | Remoto."@es,
        "COUNTERTYPE | Remoto. | Volante conectado a los módulos remotos."@es,
        "COUNTERTYPE | Teclado. | Volante conectado al teclado."@es ;
    ns1:valor "Local",
        "Módulo RCS-S (contadora Sercos)",
        "Regulador",
        "Remoto",
        "Remoto"^^xsd:string,
        "Teclado",
        "remoto/regulador" .

ns1:Parametro_ConstanteTiempo a ns1:Parametro ;
    rdfs:label "Constante de tiempo (0-4294967295 ms)",
        "Constante de tiempo"@es,
        "Constante de tiempo (duración del retardo)"@es ;
    ns1:monitoreaParametro ns1:ModoOperacion_TemporizadorMonoestable_TG1,
        ns1:Temporizador_T10 ;
    ns1:textoExtracto "La constante de tiempo se define con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y 4294967295 ms, lo que equivale a 1193 horas (casi 50 días).",
        "La duración del retardo la fija la constante de tiempo... Una vez transcurrido el tiempo especificado en la constante de tiempo se da por finalizada la temporización."@es,
        "La duración del retardo, está determinada por la constante de tiempo [...] tiempo especificado mediante la constante de tiempo"@es,
        "el estado del temporizador se mantiene [...] hasta que transcurre el tiempo indicado en la constante de tiempo."@es,
        "hasta que transcurra el tiempo indicado mediante la constante de tiempo"@es ;
    ns1:valor "0-4294967295" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL",
        "DECEL (Deceleración)",
        "Parámetro DECEL" ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosLeapfrog ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "(V.)[ch].MPA.DECEL[set].xn",
        "DECEL" ;
    ns1:monitoreaParametro ns1:Leapfrog,
        ns1:Movimiento_G1_G2_G3,
        ns1:Sistema_CNC ;
    ns1:textoExtracto "Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE).",
        "DECEL Deceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valores posibles (2): De 0.00004 a 23622047.2440 inch/s². Valores posibles (3): De 0.0010 a 600000000.0000 grados/s². Valor por defecto: 3000.0000 mm/s² / 118.12023 inch/s² / 3000.0000 grados/s².",
        "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3",
        "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK.",
        "La deceleración pasa a ser constante y su valor es DECEL.",
        "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL.",
        "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)",
        "del orden de un tercio de [...] DECEL",
        "mesetas a ACCEL/DECEL." ;
    ns1:valor "3000.0000" .

ns1:Parametro_DECINPUT a ns1:Parametro ;
