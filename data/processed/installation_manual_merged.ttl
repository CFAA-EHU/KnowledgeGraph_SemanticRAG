    ns1:monitoreaParametro ns1:ModoOperacion_Manual_JogContinuo ;
    ns1:textoExtracto "avance definido para el modo jog continuo (parámetro JOGFEED)." ;
    ns1:valor "1000.0000" .

ns1:Parametro_31512d7fec a ns1:Parametro ;
    rdfs:label "GAPANAINTYPE",
        "GAPANAINTYPE"@es ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "GAPANAINTYPE=Remoto CAN, GAPANAINTYPE=Regulador, GAPANAINTYPE=Captación, GAPANAINTYPE=EtherCAT" ;
    ns1:valor "Regulador",
        "Remoto CAN, Regulador, Captación, EtherCAT",
        "Ubicación de la entrada analógica (módulo remoto CAN o regulador Sercos)"@es .

