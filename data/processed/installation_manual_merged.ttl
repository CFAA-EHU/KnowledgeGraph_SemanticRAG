ns1:ModoOperacion_Velocidad a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad" ;
    ns1:documentadoEn ns1:GrupoMultieje_Sercos ;
    ns1:textoExtracto "modo Sercos velocidad" .

ns1:ModoOperacion_WAITINPOS a ns1:ModoOperacion ;
    rdfs:label "WAITINPOS" ;
    ns1:textoExtracto "WAITINPOS El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." .

ns1:ModoProteccion_Basico a ns1:ModoOperacion ;
    rdfs:label "Modo de protección básico del software CNC" ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoRetardoConexion_TG2 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión (TG2)" ;
    ns1:identificador "TG2" ;
    ns1:monitoreaParametro ns1:Parametro_T,
        ns1:Parametro_t ;
    ns1:textoExtracto "un flanco de subida en TG2 inicia t desde 0 mientras T permanece a 0; al cumplirse la constante de tiempo, T pasa a 1 y se mantiene hasta un flanco de bajada en TG2. Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado." .

ns1:ModoRetardoDesconexion_TG3 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la desconexión (entrada TG3)"@es ;
    ns1:monitoreaParametro ns1:Parametro_T ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador. La duración del retardo, está determinada por la constante de tiempo."@es ;
    ns1:tieneComponente ns1:Entrada_TG3,
        ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Salida_T .

ns1:ModoSincronizacion_684 a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización con ratio de transmisión constante"@es ;
    ns1:identificador "4.4.9" ;
    ns1:monitoreaParametro ns1:Parametro_RatioTransmision_684 ;
    ns1:textoExtracto "El ratio de transmisión se determina al programar la sentencia y su valor permanece constante durante toda la operación. En este modo de sincronización no se contempla la posibilidad de modificar este valor mientras el sistema está operativo, ya que este comportamiento es más propio de una leva electrónica que de un engranaje electrónico."@es .

ns1:ModoTelediagnosis a ns1:ModoOperacion ;
    rdfs:label "Telediagnosis" ;
    ns1:textoExtracto "Puede ser necesaria su utilización cuando se trabaja con telediagnosis (control remoto de CNC)." .

ns1:ModoTrabajo_DiskMonitor a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo (ventana DiskMonitor)"@es ;
    ns1:textoExtracto "Cambio del modo de trabajo (ventana diskMonitor). [...] el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro. Este proceso implica reiniciar el equipo, y si el fabricante lo ha definido así, también será necesario introducir la contraseña correspondiente."@es .

ns1:ModoUser a ns1:ModoOperacion ;
    rdfs:label "Modo User (acceso a parámetros)"@es ;
    ns1:textoExtracto """\r
Modo User. Las variables sólo pueden escribir los parámetros con permiso de escritura. [...] Los nuevos valores se mantienen tras reiniciar o apagar el CNC.\r
"""@es .

ns1:ModoUtilidades a ns1:ModoOperacion ;
    rdfs:label "Modo utilidades" ;
    ns1:requiereMantenimiento ns1:Contrase_aAcceso ;
    ns1:textoExtracto "Parámetros máquina, definida en el modo utilidades. Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .

ns1:Modo_DDSSETUP a ns1:ModoOperacion ;
    rdfs:label "Modo DDSSETUP" ;
    ns1:documentadoEn ns1:Carpeta_DRIVE ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al modo DDSSETUP." .

ns1:Modo_DMC a ns1:ModoOperacion ;
    rdfs:label "Modo de operación DMC" ;
    ns1:identificador "DMC" ;
    ns1:requiereMantenimiento ns1:Herramienta_DMC ;
    ns1:textoExtracto "Para activar el DMC sobre un cabezal [...] El DMC ha detectado un consumo de potencia [...] durante DMC." .

ns1:Modo_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDISIMU" ;
    ns1:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ns1:Modo_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (CNC)"@es ;
    ns1:textoExtracto "Esta marca [NEXTMPGAXIS] sólo se tiene en cuenta cuando el CNC se encuentra en modo manual y el selector en modo volante."@es .

ns1:ModuloContadoraSercos a ns1:ComponenteElectrico ;
