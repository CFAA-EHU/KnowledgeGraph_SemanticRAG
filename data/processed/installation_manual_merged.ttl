    ns1:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es .

ns1:Cabezal4_715 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 4" ;
