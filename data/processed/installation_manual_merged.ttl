    ns1:identificador "G.DMCOVR" ;
    ns1:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje." ;
    ns1:valor "Porcentaje"^^xsd:string .

ns1:Parametro_G_LEARNEDPWRSP a ns1:Parametro ;
