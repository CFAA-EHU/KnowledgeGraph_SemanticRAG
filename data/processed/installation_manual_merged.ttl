    ns1:textoExtracto "address = 0) CNC • (address = 1) RIO5" .

ns1:ModuloContadoraSercos_1388 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo contadora Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_66d58fe6dc,
        ns1:Parametro_8bb67668a8 ;
    ns1:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos. Desde el punto de vista de parametrización, las contadoras Sercos tienen una doble identificación, física y lógica, como se explica a continuación. Identificación física del módulo dentro del bus. Cada contadora deberá identificarse físicamente por una numeración (Sercos ID), a través de la ruleta que incorpora en su frontal."^^rdfs:Literal ;
    ns1:tieneComponente ns1:RuletaIdentificacion_1388 .

ns1:ModuloESRemotaAddress1 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=1)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:ModuloESRemotaAddress3 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=3)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:ModuloESRemotaAddress4 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=4)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:ModuloEntradas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas digitales"@es ;
    ns1:textoExtracto "La entrada digital podrá ser una entrada física del módulo"@es ;
