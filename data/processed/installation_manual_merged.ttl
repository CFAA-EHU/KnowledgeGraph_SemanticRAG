ns1:InterfazUsuario_ce30f3051b a ns1:InterfazUsuario ;
    rdfs:label "FLIMITAC" ;
    ns1:controla ns1:Parametro_ea96462f96 ;
    ns1:identificador "FLIMITAC" ;
