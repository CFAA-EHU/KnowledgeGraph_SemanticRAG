ns1:FBACKSRCTipoDeCaptacion a ns1:Parametro ;
    rdfs:label "FBACKSRC (Tipo de captación)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA_306 ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "FBACKSRC Tipo de captación. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: Interna / Externa / Interna + Externa. Valor por defecto: Interna. Variable asociada: (V.)[ch].MPA.FBACKSRC.xn"@es ;
    ns1:valor "Interna" .

ns1:FDistanciaDesdeLaSuperficieDeLaMesaHastaElEjeA a ns1:Parametro ;
    rdfs:label "F (Distancia desde la superficie de la mesa hasta el eje A)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "F = ΔZ – Pz"@es ;
    ns1:valor "ΔZ – Pz"^^rdfs:Literal .

ns1:FEEDHOL a ns1:Parametro ;
    rdfs:label "_FEEDHOL" ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes. Cuando la marca vuelve a nivel lógico alto, el movimiento de los ejes continúa. Todas las paradas y arranques de ejes se producen con las rampas de aceleración deceleración correspondientes. • Esta marca no afecta al movimiento independiente de un eje (interpolador independiente). • En los ejes hirth, si el eje no se detiene en una posición correcta, no se activa la marca MATCH(axis). • Esta marca no apaga el láser. Si está el control de potencia activo, el láser saca la potencia mínima definida. Si el PLC pone la marca _FEEDHOL a nivel lógico bajo en un bloque sin movimiento, el CNC continua la ejecución del programa hasta detectar un bloque con movimiento. El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de esta marca. El texto aparece en color rojo cuando la marca _FEEDHOL está activa. Si en la pantalla no se dispone de este texto, no se muestra el estado de esta marca." .

ns1:FFGAINFeedForward_25633c22dd a ns1:Parametro ;
    rdfs:label "FFGAIN (Feed Forward)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "feed forward (parámetro FFGAIN)"@es .

ns1:FFGAINFeedrateGain a ns1:Parametro ;
    rdfs:label "FFGAIN (Feedrate Gain)" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento_e ;
    ns1:textoExtracto "Programmed FFGAIN Feedrate" .

ns1:FLIMITParametroDeLimiteDeAvance a ns1:Parametro ;
    rdfs:label "FLIMIT (Parámetro de límite de avance)"@es ;
    ns1:identificador "FLIMIT" ;
    ns1:textoExtracto "parámetro FLIMIT"@es .

ns1:FTIMELIMParametroMaquina a ns1:Parametro ;
    rdfs:label "FTIMELIM (parámetro máquina)" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC. En versiones previas el parámetro FTIMELIM se programaba en milisegundos. A partir de este versión, este parámetro se define en porcentaje." .

ns1:Fabricante a ns1:Personal ;
    rdfs:label "Fabricante" ;
    ns1:textoExtracto "el CNC hace una copia de seguridad de la carpeta MTB y la próxima vez que se encienda el equipo arrancará en modo usuario. El equipo debe ser entregado al usuario preparado para arrancar en modo usuario." .

ns1:FactorDeConversionFACTOR a ns1:Parametro ;
    rdfs:label "Factor de conversión (FACTOR)"@es ;
    ns1:documentadoEn ns1:Tabla_SAI ;
    ns1:identificador "FACTOR" ;
    ns1:textoExtracto "FACTOR Factor de conversión. Valores posibles: Entre ±999999999.999999999. Valor por defecto: 0.0061035. Variable asociada: (V.)MPG.FACTOR[n] El factor indica la resolución del convertidor A/D de la entrada analógica; es decir, representa el incremento de valor analógico por cada unidad de convertidor."@es ;
    ns1:valor 0.0061035 .

ns1:FagorEtherCATMapper a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:identificador "fagorethercatmapper-x.x.x" ;
    ns1:textoExtracto "Aunque \"Fagor EtherCAT Mapper\" se puede ejecutar en el propio CNC, se recomienda la instalación en un PC externo, junto al configurador." .

ns1:FalloCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en compensación volumétrica por fichero VCOMPFILE incorrecto"@es ;
    ns1:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto. • El fichero definido en VCOMPFILE no tiene definidos todos los puntos. [...] SOLUCIÓN Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos."@es .

ns1:FalloEnDeteccionDeEntradasALaPieza a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en detección de entradas a la pieza"@es ;
    ns1:mitigaRiesgo ns1:MecanizadoEnVacioNoDetectado ;
    ns1:textoExtracto "el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío"@es .

ns1:Fallo_DMCSPDL_NoConfigurado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro DMCSPDL no está configurado como 'Sí' en cabezal"@es ;
    ns1:textoExtracto "Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí."@es .

ns1:Fallo_DMC_NoProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Comando ON/OFF no programado para función DMC"@es ;
    ns1:textoExtracto "Falta programar el comando ON/OFF para activar o anular la función."@es .

ns1:FaseAprendizaje_DMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje del DMC",
        "Fase de aprendizaje del DMC"@es ;
    ns1:requiereMantenimiento ns1:DMC_ModoAutomatico,
        ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "comenzará una fase de aprendizaje, tanto si al activar DMC se había programado PWRSP como si no. [...] La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio." .

