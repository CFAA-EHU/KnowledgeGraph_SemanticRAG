    rdfs:label "DEF (Definición de símbolo)" ;
    ns1:identificador "DEF" ;
    ns1:textoExtracto "DEF Definición de símbolo." .

ns1:Instruccion_DVS a ns1:AccionProhibida ;
    rdfs:label "DVS (División aritmética)" ;
    ns1:identificador "DVS" ;
    ns1:textoExtracto "DVS" .

ns1:Instruccion_END a ns1:ModoOperacion ;
    rdfs:label "END (Final de módulo)" ;
    ns1:identificador "END" ;
    ns1:textoExtracto "END Final de módulo." .

ns1:Instruccion_EXTERN a ns1:ModoOperacion ;
    rdfs:label "EXTERN (Definición de subrutina externa)" ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa." .

ns1:Instruccion_IMA a ns1:ModoOperacion ;
    rdfs:label "IMA (Consultas sobre valores imagen)" ;
    ns1:identificador "IMA" ;
    ns1:textoExtracto "IMA Las consultas se realizarán sobre los valores imagen." .

ns1:Instruccion_JMP a ns1:AccionProhibida ;
    rdfs:label "JMP (Salto incondicional)"@es ;
    ns1:identificador "JMP" ;
    ns1:textoExtracto "= JMP Salto incondicional. Si el resultado obtenido en la evaluación de la expresión lógica es un '1', provoca un salto a la etiqueta especificada. Si el resultado es '0' continúa en la siguiente línea de programa."@es .

ns1:Instruccion_L a ns1:ModoOperacion ;
    rdfs:label "L (Etiqueta)" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L Etiqueta." .

ns1:Instruccion_LatcheoCota_TOUCHPROBE a ns1:TareaMantenimiento ;
    rdfs:label "Instrucción TOUCHPROBE para latcheo de cota"@es ;
    ns1:identificador "TOUCHPROBE" ;
    ns1:requiereMantenimiento ns1:Sistema_LatcheoCota ;
    ns1:textoExtracto "La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador, de una entrada digital física o de una entrada lógica."@es .

ns1:Instruccion_MDS a ns1:AccionProhibida ;
    rdfs:label "MDS (Módulo o resto de división)" ;
    ns1:identificador "MDS" ;
    ns1:textoExtracto "MDS" .

ns1:Instruccion_MOV a ns1:AccionProhibida ;
    rdfs:label "Instrucción MOV (Mover)"@es ;
    ns1:identificador "MOV" ;
    ns1:monitoreaParametro ns1:Parametro_BitsTransmitir,
        ns1:Parametro_FormatoBCD,
        ns1:Parametro_FormatoBinario,
        ns1:Parametro_LimiteBCD_32bits ;
    ns1:textoExtracto """\r
= MOV Mover. Permite mover información de un recurso a otro del PLC.\r
El formato de programación es:\r
Origen Destino Código origen Código destino Bits a transmitir\r
0(Bin) 0(Bin) 32 I1/1024 =MOV I1/1024 1(BCD) 1(BCD) 28 O1/1024\r
O1/1024 24 M1/8192 M1/8192 20 MSG1/1024 MSG1/1024 16 ERR1/1024\r
ERR1/1024 12 R1/1024 T1/512 8 R CNC-PLC C1/256 4 R1/1024 R CNC-PLC"""@es .

ns1:Instruccion_MOV_C123_R200 a ns1:TareaMantenimiento ;
    rdfs:label "Instrucción MOV C123 R200" ;
    ns1:controla ns1:Parametro_ValorCuentaContador ;
    ns1:textoExtracto "I2 = MOV C123 R200. Transfiere la cuenta de C123 al registro R200." .

ns1:Instruccion_MOV_I11_I14_O16 a ns1:AccionProhibida ;
    rdfs:label "Transferencia MOV I11 = MOV I14 O16 108" ;
    ns1:activaAlarma ns1:Salidas_O16 ;
    ns1:controla ns1:Entrada_I11 ;
    ns1:identificador "108" ;
    ns1:textoExtracto "Si la entrada I11 vale '1' el PLC realiza una transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD, hacia las 8 salidas O16 y siguientes en código binario." .

ns1:Instruccion_NGS_R_1_1024 a ns1:AccionProhibida ;
    rdfs:label "NGS R 1/1024 (Cambio de signo)" ;
    ns1:identificador "NGS R 1/1024" ;
    ns1:monitoreaParametro ns1:Entrada_I16,
        ns1:Registro_R89 ;
    ns1:textoExtracto "NGS R 1/1024 Cambio de signo del registro. Cambia el signo del registro. I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:Instruccion_NGU_R_1_1024 a ns1:AccionProhibida ;
    rdfs:label "NGU R 1/1024 (Complementación de bits)" ;
    ns1:identificador "NGU R 1/1024" ;
    ns1:monitoreaParametro ns1:Entrada_I15,
        ns1:Registro_R152 ;
    ns1:textoExtracto "NGU R 1/1024 Complementa los bits de un registro. Realiza una complementación de los 32 bits del registro (cambia el estado de cada uno de los bits). I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

