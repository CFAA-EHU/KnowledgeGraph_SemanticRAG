    ns1:ejecutadoPor ns1:CNC_304 ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC. La búsqueda de cero se realiza sin parar el cabezal, si previamente se encontraba girando."@es .

ns1:BusquedaDeEjes a ns1:Parametro ;
