    ns1:monitoreaParametro ns1:ProcesoLatcheoEje ;
    ns1:textoExtracto "LATCH1DONE(axis) [...] El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." .

ns1:Marca_LATCH2DONE a ns1:Parametro ;
