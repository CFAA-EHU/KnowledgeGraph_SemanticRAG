ns1:InterfazUsuario_DMC a ns1:InterfazUsuario ;
    ns1:controla ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Al finalizar la inspección de herramienta, el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'."@es .

ns1:InterfazUsuario_DMC_Opciones a ns1:InterfazUsuario ;
    rdfs:label "Menú de softkeys 'Opciones DMC'"@es ;
    ns1:textoExtracto "Menú vertical de softkeys 'Opciones DMC' con tres acciones: repetir fase de aprendizaje, desactivar DMC y re-activar DMC."@es ;
