ns1:Parametro_G90 a ns1:Parametro ;
    rdfs:label "G90 (Modo coordenadas absolutas)"@es ;
    ns1:identificador "G90" ;
    ns1:textoExtracto "Dependiendo del modo de trabajo activo G90 [...] la posición de los nuevos límites estará definida en coordenadas absolutas (G90) en el sistema de referencia de la máquina."@es .

ns1:Parametro_G91 a ns1:Parametro ;
    rdfs:label "G91 (Modo coordenadas incrementales)"@es ;
