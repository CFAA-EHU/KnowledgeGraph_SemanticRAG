ns1:ComponenteElectrico_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder",
        "Encoder (captación motor)",
        "Encoder con marcas de referencia I0"@es ;
    ns1:monitoreaParametro ns1:Parametro_ModoBusquedaCodificadoCreciente,
        ns1:Parametro_ModoBusquedaCodificadoDecreciente,
        ns1:Parametro_ModoBusquedaNormal ;
    ns1:textoExtracto "En ejes con captación motor absoluta, el CNC conoce en todo momento la posición relativa del eje por vuelta del motor.",
        "Número de impulsos del encoder. Este parámetro define el número de impulsos por vuelta del encoder.",
        "El encóder puede tener una o varias marcas de I0, pero sólo hay una marca seleccionada (por ejemplo, con un micro (home-switch)). El encóder referencia la posición con esta marca de I0."@es .

ns1:ComponenteElectrico_EntradaCaptacionExterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación externa (directa)" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "El parámetro COUNTERTYPE indica dónde está ubicada la entrada para la captación externa (directa) del eje; en los módulos remotos (4 entradas por módulo, TTL diferencial y senoidal 1 Vpp), en la captación libre de un regulador Sercos o en las entradas de captación locales de la unidad central." .

