    rdfs:label "G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ns1:Param_HIRTH a ns1:Parametro ;
    rdfs:label "Eje Hirth (HIRTH)" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Se denomina eje Hirth al que debe posicionarse siempre en posiciones múltiplos de un valor dado. [...] Variable asociada: (V.)[ch].MPA.HIRTH.xn" ;
    ns1:valor "No"^^xsd:string .

ns1:Param_HPITCH a ns1:Parametro ;
    rdfs:label "Paso del eje Hirth (HPITCH)" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "HPITCH Paso del eje Hirth. [...] Valor por defecto: 1 mm / 0.03937 inch / 1 grado. Variable asociada: (V.)[ch].MPA.HPITCH.xn" ;
