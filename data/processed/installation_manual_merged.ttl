ns1:IconoAdvertenciaTriangulo a ns1:Sensor ;
    rdfs:label "Triángulo de advertencia"@es ;
    ns1:mitigaRiesgo ns1:BloqueAdvertenciaOvertemp ;
    ns1:textoExtracto "A la izquierda de algunas filas aparece un icono que indica la existencia de archivo de ayuda asociado. La imagen ejemplifica cómo el CNC presenta, prioriza y permite abrir ayudas asociadas a mensajes/errores del PLC. --- Páginas: 403 | Sección: 5.5 Visualización de errores y mensajes del PLC | Título: — ---"@es .

ns1:IconoAyudaVerde a ns1:Sensor ;
    rdfs:label "Icono verde"@es ;
    ns1:textoExtracto "Conjunto de iconos de estado de mensajes: un triángulo de advertencia que indica que el mensaje no tiene archivo de información adicional, y un icono verde que señala que sí existe archivo de ayuda asociado. Estos pictogramas actúan como leyenda visual para interpretar rápidamente la disponibilidad de ayuda contextual. --- Páginas: 416 | Sección: 6.1 Señales de consulta generales | Título: — ---"@es .

ns1:Icono_MapeadorEtherCAT a ns1:InterfazUsuario ;
