ns1:GestorPLC_Marcas a ns1:Sistema ;
    rdfs:label "Gestor PLC (Marcas M1101-M1107)" ;
    ns1:controla ns1:AlmacenHerramientas,
        ns1:Cabezal,
        ns1:Pinza1,
        ns1:Pinza2 ;
    ns1:textoExtracto """\r
V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor.\r
V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor.\r
V.PLC.M[1104]=1 ; Marca SPDLTOCH2 al gestor.\r
V.PLC.M[1106]=1 ; Marca CH2TOMZ al gestor.\r
V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor.""" .

