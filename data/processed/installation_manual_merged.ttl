ns1:ACForward a ns1:Parametro ;
    rdfs:label "AC-Forward"@es ;
    ns1:textoExtracto "El [...] AC-Forward lo aplica el CNC."@es .

ns1:AContinuacionSeMuestraUnaDescripcionDetalladaDeLasOperacionesValidasParaEsteAlmacen a ns1:Sistema ;
