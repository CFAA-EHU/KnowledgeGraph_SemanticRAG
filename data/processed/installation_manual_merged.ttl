ns1:ModoOperacion_PRG a ns1:ModoOperacion ;
    rdfs:label "Modo PRG (programa pieza)"@es ;
    ns1:textoExtracto "accesibles desde; (PRG) el programa pieza"^^rdf:XMLLiteral .

ns1:ModoOperacion_PalpadoG100 a ns1:ModoOperacion ;
    rdfs:label "Palpado programado con G100" ;
    ns1:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:ModoOperacion_ParametrosMaquina a ns1:ModoOperacion ;
    rdfs:label "Parámetros máquina" ;
    ns1:habilitadoPor ns1:Parametro_COMPONENT ;
    ns1:textoExtracto "Parámetros máquina" .

ns1:ModoOperacion_Posicion a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos posición" ;
    ns1:documentadoEn ns1:GrupoMultieje_Sercos ;
    ns1:textoExtracto "modo Sercos posición" .

ns1:ModoOperacion_PosicionamientoAlmacen a ns1:ModoOperacion ;
    rdfs:label "Posicionamiento del almacén" ;
    ns1:habilitadoPor ns1:Marca_MZROT ;
    ns1:textoExtracto "Seleccionar una posición del almacén [...] secuencia de esta operación"@es ;
    ns1:tieneComponente ns1:Parametro_LEAVEPOS,
        ns1:Parametro_NEXTPOS,
        ns1:Parametro_TAKEPOS,
        ns1:Parametro_TMOPERATION .

ns1:ModoOperacion_RTCP_ON a ns1:ModoOperacion ;
    rdfs:label "RTCP ON" ;
    ns1:identificador "RTCP ON" ;
    ns1:textoExtracto "#RTCP ON B-30 B" .

ns1:ModoOperacion_RetardoConexion_TG2 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión (Entrada TG2)"@es ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la activación de la entrada de arranque TG2 y la activación de la salida de estado T del temporizador. La duración del retardo la fija la constante de tiempo."@es ;
    ns1:tieneComponente ns1:Entrada_TG2,
        ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Salida_T .

ns1:ModoOperacion_Retrace a ns1:ModoOperacion ;
    rdfs:label "Retrace" ;
    ns1:monitoreaParametro ns1:Parametro_NRETBLK ;
    ns1:textoExtracto "La función retrace se puede activar durante una interpolación, a mitad de un bloque, y también al final del bloque, tanto si la ejecución está detenida por M0 como por el modo bloque a bloque." .

ns1:ModoOperacion_SETUP a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP"@es,
        "Modo SETUP (puesta a punto)"@es ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea .fst se cargarán en la memoria RAM la primera vez que se ejecutan dentro del programa."@es,
        "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ns1:ModoOperacion_SenoCuadrado a ns1:ModoOperacion ;
    rdfs:label "Perfil seno cuadrado"@es ;
    ns1:ilustradoEn ns1:Figura_2.4.8_CondicionesPorDefecto_Canal ;
    ns1:textoExtracto "los más lentos con la seno cuadrado"@es .

ns1:ModoOperacion_SercosPosicion a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos posición" ;
    ns1:textoExtracto "Se recomienda que los ejes (excepto ejes tándem) operen en modo Sercos posición [...] La búsqueda de cero la controla el CNC." .

ns1:ModoOperacion_Simulado a ns1:ModoOperacion ;
    rdfs:label "Modo Simulado" ;
    ns1:habilitadoPor ns1:Parametro_DRIVETYPE ;
    ns1:textoExtracto "La opción Simulado se debe usar cuando no hay eje físico o durante la puesta a punto. Con la opción Simulado, el CNC simula todos los movimientos, asume como cota real la cota teórica y no proporciona consignas al exterior." .

ns1:ModoOperacion_SincronizacionCabezales a ns1:ModoOperacion ;
    rdfs:label "Sincronización de cabezales" ;
    ns1:textoExtracto "el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio)" .

ns1:ModoOperacion_SincronizacionEjes a ns1:ModoOperacion ;
    rdfs:label "Sincronización de ejes" ;
    ns1:textoExtracto "el eje esclavo se mueve al mismo avance que el eje maestro (teniendo en cuenta el ratio)" .

ns1:ModoOperacion_SincronizacionPosicion a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización en posición" ;
    ns1:monitoreaParametro ns1:Parametro_Sincronizacion_POS,
        ns1:Variable_VASYNCPOSOFF ;
    ns1:textoExtracto "Sincronización en posición (en fase). [...] Se programa mediante los parámetros \"POS\"" .

ns1:ModoOperacion_SincronizacionVelocidad a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización en velocidad" ;
    ns1:monitoreaParametro ns1:Parametro_Sincronizacion_VEL,
        ns1:Variable_VASYNCVELOFF ;
    ns1:textoExtracto "Sincronización en velocidad. [...] FOLLOW ON (A1, Z, VEL)" .

