    rdfs:label "Modo Operación Automático" ;
    ns1:textoExtracto "[ AUTOMATIC MODE] AUTO1=Seleccionar programa AUTO2=Prg en simulación AUTO3=Inspección AUTO4=Abandonar inspección AUTO5=Reposicionar AUTO6=Reposicionar inicio bloque AUTO7=Modo ejecución AUTO8=Cancelar bloque AUTO9=Gráficos" .

ns1:ModoOperacionFAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST)" .

ns1:ModoOperacionInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "modo de inspección de herramienta" ;
    ns1:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva." .

ns1:ModoOperacionMonoestable a ns1:ModoOperacion ;
    rdfs:label "Modo monoestable" ;
    ns1:textoExtracto "En este modo de funcionamiento el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG1 hasta que transcurre el tiempo indicado en la constante de tiempo." .

ns1:ModoOperacionOffline a ns1:ModoOperacion ;
    rdfs:label "Modo offline" ;
    ns1:textoExtracto "Para añadir cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"." .

ns1:ModoOperacionOnline a ns1:ModoOperacion ;
    rdfs:label "Modo online" ;
    ns1:textoExtracto "Con el programa arrancado, el primer paso es seleccionar el adaptador de red Ethernet." .

ns1:ModoOperacionSincronizacionIndependiente a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización independiente" ;
    ns1:textoExtracto "En este modo de sincronización no se contempla la posibilidad de modificar este valor mientras el sistema está operativo, ya que este comportamiento es más propio de una leva electrónica que de un engranaje electrónico." .

ns1:ModoOperacionVolante a ns1:ModoOperacion ;
    rdfs:label "modo volante" ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset." .

