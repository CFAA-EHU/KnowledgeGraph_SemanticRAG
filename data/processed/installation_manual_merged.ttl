ns1:Registro_R201 a ns1:Parametro ;
    rdfs:label "Registro R201" ;
    ns1:identificador "R201" ;
    ns1:textoExtracto "R201 = B0100 0101" ;
    ns1:valor "B01000101" .

ns1:Registro_R202 a ns1:Parametro ;
    rdfs:label "Registro R202" ;
    ns1:identificador "R202" ;
    ns1:textoExtracto "() = AND R200 R201 R202 ; R202 = B0" ;
    ns1:valor "B00000000" .

ns1:Registro_R203 a ns1:Parametro ;
    rdfs:label "Registro R203" ;
    ns1:identificador "R203" ;
    ns1:textoExtracto "() = OR R200 R201 R203 ; R203 = B11010111" ;
    ns1:valor "B11010111" .

ns1:Registro_R204 a ns1:Parametro ;
    rdfs:label "Registro R204",
        "Registro R204 (pulsar CTRL)" ;
    ns1:identificador "R204" ;
    ns1:textoExtracto "() = XOR R200 R201 R204 ; R204 = B11010111",
        "MOV $1D R204 ; Pulsar la tecla [CTRL]"@es ;
    ns1:valor "$1D",
        "B11010111" .

ns1:Registro_R205 a ns1:Parametro ;
    rdfs:label "Registro R205",
        "Registro R205 (soltar CTRL)" ;
    ns1:identificador "R205" ;
    ns1:textoExtracto "() = AND B1111 R201 R205 ; R205 = B00000101",
        "MOV $9D R205 ; Soltar la tecla [CTRL]"@es ;
    ns1:valor "$9D",
        "B00000101" .

ns1:Registro_R206 a ns1:Parametro ;
    rdfs:label "Registro R206",
        "Registro R206 (pulsar F1)" ;
    ns1:identificador "R206" ;
    ns1:textoExtracto "() = OR R200 B1111 R206 ; R206 = B10011111",
        "MOV $3B R206 ; Pulsar la tecla [F1]"@es ;
    ns1:valor "$3B",
        "B10011111" .

ns1:Registro_R207 a ns1:Parametro ;
    rdfs:label "Registro R207",
        "Registro R207 (soltar F1)" ;
    ns1:identificador "R207" ;
    ns1:textoExtracto "() = XOR B1010 B1110 R207 ; R207 = B00000100",
        "MOV $BB R207 ; Soltar la tecla [F1]"@es ;
    ns1:valor "$BB",
        "B00000100" .

ns1:Registro_R300 a ns1:Parametro ;
    rdfs:label "Registro R300 (valor del contador)" ;
    ns1:monitoreaParametro ns1:FragmentoCodigo_6_8_1 ;
    ns1:textoExtracto "El registro R300 muestra el valor del contador"@es .

