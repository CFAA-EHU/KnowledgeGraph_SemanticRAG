ns1:EntradaLogica_AUXEND a ns1:ComponenteElectrico ;
    rdfs:label "Entrada general AUXEND" ;
    ns1:textoExtracto "El CNC espera la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC." .

ns1:EntradaLogica_PLC a ns1:InterfazUsuario ;
    rdfs:label "Entrada lógica PLC para latcheo condicional"@es ;
    ns1:controla ns1:Sistema_LatcheoCota ;
    ns1:textoExtracto "Si el evento seleccionado es una entrada lógica, la activación de la misma puede realizarse desde programa PLC y por lo tanto estar condicionada indirectamente a cualquier otro evento gestionado por el PLC."@es .

ns1:EntradaSalidaDigital_1266 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas y salidas digitales"@es ;
    ns1:textoExtracto "Configurar las salidas digitales. Las entradas y salidas digitales se configuran desde los parámetros máquina."@es .

ns1:Entrada_CDW a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CDW (descontaje)"@es ;
    ns1:identificador "CDW" ;
    ns1:textoExtracto "(CDW) Entrada de descontaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se decrementa en una unidad. Se referencia mediante las letras CDW seguidas del número de contador que se desea referenciar, por ejemplo CDW 1, CDW 25, CDW 102, etc."@es .

ns1:Entrada_CEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CEN (enable)"@es ;
    ns1:identificador "CEN" ;
    ns1:textoExtracto "(CEN) Entrada de enable. Permite detener la cuenta interna del contador. [...] Con CEN a (=0) se detiene la cuenta del contador y no se hace caso a las entradas CUP y CDW."@es .

ns1:Entrada_CPR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CPR (preselección)"@es ;
    ns1:identificador "CPR" ;
    ns1:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es .

ns1:Entrada_CUP a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CUP (contaje)"@es ;
    ns1:identificador "CUP" ;
    ns1:textoExtracto "(CUP) Entrada de contaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se incrementa en una unidad. Se referencia mediante las letras CUP seguidas del número de contador que se desea referenciar, por ejemplo CUP 1, CUP 25, CUP 102, etc."@es .

ns1:Entrada_I11 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I11" ;
    ns1:textoExtracto "Si la entrada I11 vale '1'..." .

ns1:Entrada_I12 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I12"@es ;
    ns1:identificador "I12" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoI12 ;
    ns1:textoExtracto "Devuelve un 1 si la entrada I12 se encuentra activa y un 0 en caso contrario."@es .

ns1:Entrada_I15 a ns1:Parametro ;
    rdfs:label "Entrada I15" ;
    ns1:identificador "I15" ;
    ns1:textoExtracto "I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

ns1:Entrada_I16 a ns1:Parametro ;
    rdfs:label "Entrada I16" ;
    ns1:identificador "I16" ;
    ns1:textoExtracto "I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:Entrada_I1_I48 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas I1–I48" ;
    ns1:identificador "I1…I48" ;
    ns1:textoExtracto "Rango de entradas en Remote Group 1." .

ns1:Entrada_I2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I2"@es ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2. [...] Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2."@es .

ns1:Entrada_TEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de enable (TEN)"@es ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "(TEN) Entrada de enable. Permite detener y reanudar la temporización. Se referencia mediante las letras TEN seguidas del número de temporizador, por ejemplo TEN 1, TEN 25, TEN 102, etc."@es .

ns1:Entrada_TEN_10 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TEN 10"@es ;
    ns1:identificador "TEN 10" ;
    ns1:textoExtracto "I2 = TEN 10. La entrada I2 controla la entrada de enable del temporizador T10."@es .

ns1:Entrada_TG1 a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "Entrada TG1 (modo monoestable)",
        "Entrada TG1"@es,
        "Entrada de arranque TG1"@es ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "TG1 activa el modo monoestable.",
        "entrada de arranque TG1 del temporizador T4"@es,
        "entradas [...] TG1"@es .

ns1:Entrada_TRS a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de reset (TRS)"@es ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "(TRS) Entrada de reset. Permite inicializar el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta. Se referencia mediante las letras TRS seguidas del número de temporizador, por ejemplo TRS 1, TRS 25, TRS 102, etc."@es .

