ns1:GrupoLimitesSoftware_1 a ns1:Parametro ;
    rdfs:label "Grupo 1 de límites de software"@es ;
    ns1:identificador "SL1" ;
    ns1:textoExtracto "El CNC puede tener dos grupos de límites de software activos, donde cada grupo puede estar compuesto por un límite superior y otro inferior en cada eje."@es .

ns1:GrupoLimitesSoftware_2 a ns1:Parametro ;
    rdfs:label "Grupo 2 de límites de software"@es ;
    ns1:identificador "SL2" ;
    ns1:textoExtracto "El CNC puede tener dos grupos de límites de software activos, donde cada grupo puede estar compuesto por un límite superior y otro inferior en cada eje."@es .

ns1:GrupoMultieje_1078 a ns1:Sistema ;
    rdfs:label "Grupo multieje (A1 + A2)"@es ;
    ns1:compuestoPor ns1:Motor_A1_1078,
        ns1:Motor_A2_1078 ;
    ns1:textoExtracto "Un grupo multieje consiste en varios ejes o cabezales Sercos controlados por un único regulador, aunque no de forma simultánea. [...] Grupo multieje compuesto por dos ejes, cada uno controlado por un motor."@es ;
    ns1:tieneComponente ns1:Eje_A1_1078,
        ns1:Eje_A2_1078 .

ns1:GrupoMultieje_A1_A2 a ns1:Sistema ;
    rdfs:label "Grupo multieje A1-A2"@es ;
    ns1:controla ns1:Eje_A1,
        ns1:Eje_A2 ;
    ns1:detalladoEnEsquema ns1:RequisitosMultieje_11_4 ;
    ns1:textoExtracto "Grupo multieje compuesto por dos ejes controlados por un único motor. La captación interna (motor) de ambos ejes estará ubicada en el regulador mientras que la captación externa (directa) de cada eje podrá estar situada en los módulos remotos, en un regulador Sercos o de forma local en la propia unidad central."@es ;
    ns1:tieneComponente ns1:Motor_GrupoMultieje_A1_A2 .

ns1:HBH3 a ns1:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH3" ;
