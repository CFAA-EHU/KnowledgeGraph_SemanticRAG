    rdfs:label "Movimiento de posicionamiento incremental (MOVE ADD)"@es ;
    ns1:identificador "MOVE ADD" ;
    ns1:textoExtracto "incremental (MOVE ADD). El formato de programación para cada uno de ellos es el siguiente. MOVE ADD (axis, pos, feed, blend)"@es .

