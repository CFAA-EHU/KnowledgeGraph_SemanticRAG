    ns1:requiereMantenimiento [ a ns1:TareaMantenimiento ;
            rdfs:label "Configuración de micros para búsqueda de referencia" ;
            ns1:textoExtracto "los micros deben estar dispuestos de manera que al realizar la búsqueda de referencia del eje esclavo, el eje maestro no pulse su micro" ] ;
    ns1:textoExtracto "Ejes Sercos posición" .

ns1:SistemaSimulacionTecladoPLC a ns1:Sistema ;
