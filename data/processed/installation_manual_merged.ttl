ns1:InstruccionAritmeticaT123 a ns1:AccionProhibida ;
    rdfs:label "Instruccion aritmetica T123" ;
    ns1:textoExtracto "En instrucciones de tipo aritmético y comparación hace referencia al tiempo transcurrido. I2 = MOV T123 R200 Transfiere el tiempo de T123 al registro R200. CPS T123 GT 1000 = M100 Compara si el tiempo de T123 es mayor que 1000, en cuyo caso activa la marca M100." .

ns1:InstruccionBinariaT123 a ns1:AccionProhibida ;
    rdfs:label "Instruccion binaria T123" ;
    ns1:textoExtracto "En instrucciones de tipo binario hace referencia al estado lógico del temporizador. T123 = M100 Asigna a M100 el estado (0/1) de T123." .

