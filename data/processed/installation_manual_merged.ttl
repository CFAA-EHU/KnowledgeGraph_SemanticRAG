ns1:SubrutinaRAM_1184 a ns1:Sistema ;
    rdfs:label "Subrutinas en memoria RAM (extensión *.fst)"@es ;
    ns1:textoExtracto "Cuando finaliza el programa (M02/M30) o tras un reset, si ningún otro canal está ejecutando las subrutinas, el CNC las borra de la memoria RAM. De esta forma, los cambios que se realicen en la subrutina serán tenidos en cuenta la próxima vez que se ejecute el programa."@es .

ns1:SubrutinaReset_14_3 a ns1:ModoOperacion ;
