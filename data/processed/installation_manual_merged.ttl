ns1:Motor_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Motor de eje/cabezal" ;
    ns1:textoExtracto "El motor responderá a todas las variaciones de consigna. [...] Si el PLC desactiva la señal DRENA (drive enable), el circuito de potencia del dispositivo se apaga y el motor queda sin par." .

ns1:Motor_EjeEsclavo_1072 a ns1:ComponenteMecanico ;
    rdfs:label "Motor del eje esclavo"@es ;
    ns1:monitoreaParametro ns1:Parametro_SP43_1072,
        ns1:Parametro_TP85_1072 ;
    ns1:textoExtracto "el segundo motor está siendo arrastrado por el primero [...] Comprobar que los sentidos de giro de ambos motores son coherentes"@es .

ns1:Motor_EjeMaestro_1072 a ns1:ComponenteMecanico ;
    rdfs:label "Motor del eje maestro"@es ;
    ns1:monitoreaParametro ns1:Parametro_SP43_1072,
        ns1:Parametro_TP85_1072 ;
    ns1:textoExtracto "asegurar un perfecto funcionamiento tanto del eje maestro [...] Comprobar además que ambos ejes se mueven en el mismo sentido"@es .

ns1:Motor_Esclavo a ns1:ComponenteMecanico ;
