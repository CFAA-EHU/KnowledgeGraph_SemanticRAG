        "entradas [...] TG4"@es .

ns1:EntradasFisicas_ModulosRemotos a ns1:ComponenteElectrico ;
    rdfs:label "Entradas físicas (módulos remotos)" ;
    ns1:textoExtracto "El PLC asigna a los recursos I los valores que disponen en este momento las entradas físicas (módulos remotos)." .

ns1:EsquemaPaso3_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 3) del plano XY con patrón de relleno completo en X para cada fila Y(Pn)"@es ;
    ns1:identificador "Paso 3" ;
    ns1:textoExtracto "Esquema 3D (Paso 3) del plano XY con el patrón de relleno completo en X para cada fila Y(Pn). Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2 y cómo se genera la lista ordenada de puntos antes de subir de cota Z."@es .

ns1:EsquemaPosicionamiento_17_2 a ns1:Esquema ;
    rdfs:label "Esquema de posicionamiento para medición con reloj comparador (ejes B, C, Y, Z)"@es ;
    ns1:textoExtracto "B=0º [...] C=0º [...] Desplazar la mesa en el eje Y hasta que el reloj y el cilindro se toquen en el punto 1. [...] Z Y R 1 Segundo contacto."@es .

ns1:Esquema_CaptacionDirecta_CounterTypeRegulador a ns1:Esquema ;
    rdfs:label "Esquema: COUNTERTYPE = Regulador (captación directa)"@es ;
    ns1:ilustradoEn ns1:Pagina_587 ;
    ns1:textoExtracto "Esquema de conexión donde la captación directa (encoder) entra en la segunda entrada del regulador Sercos; se distinguen captación de motor y directa, y el lazo Sercos hacia el módulo de accionamiento."@es .

ns1:Esquema_CaptacionDirecta_CounterTypeRemoto a ns1:Esquema ;
    rdfs:label "Esquema: COUNTERTYPE = Remoto (módulo CANfagor)"@es ;
    ns1:ilustradoEn ns1:Pagina_587 ;
    ns1:textoExtracto "Diagrama de cableado con módulo remoto CANfagor de contadoras (X1…X5, CAN L/H, alimentación y terminaciones). La captación directa se enruta al módulo remoto y el CNC recibe posición vía bus CAN."@es .

ns1:Esquema_CinematicaTipo52 a ns1:Esquema ;
    rdfs:label "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA21_26,
        ns1:Parametro_TDATA31_33,
        ns1:Parametro_TDATA41_43,
        ns1:Parametro_TDATA8_18 ;
    ns1:textoExtracto "Conjunto de diagramas de cinemática combinada: pictogramas de cabezal/mesa y esquema con cinco vectores de traslación (T1–T5) y cinco de dirección (V1–V5). Se representan ejes X-Y-Z, flechas, y jerarquía de elementos (cabezal vs mesa)" .

ns1:Esquema_ConexionSensorGapRIOR a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap a módulos remotos CAN (RIOR)"@es ;
    ns1:detalladoEnEsquema ns1:SensorGap ;
    ns1:identificador "CNC – RIOR – CAN – GAP SENSOR" ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador."@es .

ns1:Esquema_EntradasAnalogicas_Fagor_IB_IL_AI4_U-PAC a ns1:Esquema ;
    rdfs:label "Esquema de configuración: Entradas analógicas Fagor (IB IL AI 4 - U-PAC)"@es ;
    ns1:documentadoEn ns1:Pagina_756 ;
    ns1:textoExtracto "selección de primera entrada, rango de medición por canal y frecuencia de muestreo; interfaz con listas desplegables por canal"@es .

ns1:Esquema_GamasTrabajo_Ejes a ns1:Esquema ;
    rdfs:label "Gamas de trabajo - Parámetros máquina de los ejes" ;
    ns1:detalladoEnEsquema ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "conjunto de tres gráficos sincronizados para aceleración trapezoidal/seno-cuadrado: velocidad v(t), aceleración a(t) y jerk j(t). Se numeran siete fases (1–7) con líneas de puntos, mostrando rampas con pendiente limitada por ACCJERK/DECJERK, mesetas a ACCEL/DECEL y tramos de avance constante." .

ns1:Esquema_GapSensorGraph a ns1:Esquema ;
    rdfs:label "Gráfico del sensor de gap (mV vs mm/inch)"@es ;
    ns1:ilustradoEn ns1:Param_GAPDISTLIMIT,
        ns1:Param_GAPSENSOROFFSET,
        ns1:Param_GAPVOLTLIMIT ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical). Representa la señal del sensor (SENSOR SIGNAL) frente al offset aplicado (GAPSENSOROFFSET), el límite de voltaje (GAPVOLTLIMIT) y el límite de distancia (GAPDISTLIMIT)."@es .

ns1:Esquema_MesaRotativa_17_3 a ns1:Esquema ;
    rdfs:label "Esquema de preselección y cálculo de parámetros para mesa rotativa (Sección 17.3)"@es ;
    ns1:identificador "17.3" ;
    ns1:textoExtracto "Dibujo de preselección X con A=90°, B=−90° y palpado en X sobre la mesa; se representa la lectura ΔX y la asignación X=−r para hacer coincidir X=0 con la superficie de la mesa, indicando el radio de bola del palpador r."@es,
        "Dos disposiciones del eje B (A=0° con B=0° y B=−90°) para determinar TDATA2, TDATA4 y TDATA5. Se anotan lecturas ΔX1, ΔZ y ΔZ1, y se marcan distancias E y F desde la mesa hasta los ejes B y A respectivamente, con líneas de cota y referencias Pz y r."@es .

ns1:Esquema_SalidasAnalogicas_Fagor_IB_IL_AO2_U-PAC a ns1:Esquema ;
    rdfs:label "Esquema de configuración: Salidas analógicas Fagor (IB IL AO 2 - U-PAC)"@es ;
    ns1:documentadoEn ns1:Pagina_757 ;
    ns1:textoExtracto "definición de la primera salida y del rango de cada canal; panel con campos por salida y tipos de rango"@es .

ns1:FalloLicenciaNoEncontrada a ns1:DiagnosticoFallo ;
    rdfs:label "Licencia no encontrada"@es ;
    ns1:textoExtracto "El pendrive con la licencia debe estar conectado al PC. [...] significa que el programa no encuentra la licencia."@es .

ns1:Figura_AlmacenCarruselBrazo1Pinza a ns1:Figura ;
    rdfs:label "Ilustración de carrusel con brazo de 1 pinza"@es ;
    ns1:ilustradoEn ns1:Pagina_514 ;
    ns1:textoExtracto "Ilustración del carrusel cercano al cabezal con un brazo de una sola pinza. El brazo extrae la herramienta del carrusel y la entrega al husillo."@es .

ns1:Figura_AlmacenCarruselBrazo2Pinzas a ns1:Figura ;
    rdfs:label "Ilustración de carrusel con brazo de 2 pinzas"@es ;
    ns1:ilustradoEn ns1:Pagina_514 ;
    ns1:textoExtracto "Ilustración del carrusel con brazo de dos pinzas: se distinguen dos mordazas para operaciones de toma y entrega en secuencia cruzada."@es .

ns1:Figura_AlmacenTorreta a ns1:Figura ;
    rdfs:label "Ilustración de torreta de torno con herramientas"@es ;
    ns1:ilustradoEn ns1:Pagina_492 ;
    ns1:textoExtracto "Ilustración de torreta de torno con varias estaciones y herramientas montadas; se destaca la herramienta activa alineada con el punto de trabajo."@es .

ns1:Figura_EsquemaBloquesEtherCAT a ns1:Figura ;
    rdfs:label "Esquema de bloques cromáticos del bus EtherCAT" ;
    ns1:textoExtracto "Vista en bloques del bus con leyenda cromática: azul (entradas digitales), morado (salidas digitales), rojo/gris (mapeos a/desde registros PLC), verde/amarillo (AI/AO Fagor)." .

ns1:FiltroAntirresonante a ns1:Componente,
        ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "Filtro antirresonante",
        "Filtro antirresonante (banda eliminada)",
        "Filtro antirresonante (banda eliminada)"@es ;
    ns1:ilustradoEn ns1:Figura_FiltroNotch ;
    ns1:monitoreaParametro ns1:Parametro_ORDER,
        ns1:Parametro_TYPE ;
    ns1:textoExtracto "Antirresonante (banda eliminada)",
        "El filtro \"antirresonante\" (banda eliminada), que limita una zona de la banda pasante.",
        "Filtro \"antirresonante\" (banda eliminada). Si la máquina tiene una frecuencia de resonancia en una zona intermedia de su banda pasante, será conveniente eliminar esa frecuencia con un filtro \"antirresonante\".",
        "Curva de magnitud con una hendidura estrecha entre f1 y f2 que suprime la frecuencia de resonancia dentro de la banda pasante. Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es ;
    ns1:valor "f1–f2 (banda eliminada)"@es .

ns1:FiltroEjes_HSC a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de suavizado para ejes (modo HSC)" ;
    ns1:controla ns1:PerfilVelocidad_HSC ;
    ns1:textoExtracto "filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina" .

ns1:FiltroPasoBajo a ns1:Componente,
        ns1:Parametro ;
    rdfs:label "Filtro paso bajo",
        "Filtro paso bajo para eliminación de frecuencias de resonancia"@es ;
    ns1:ilustradoEn ns1:Figura_FiltroPasoBajo ;
    ns1:monitoreaParametro ns1:Parametro_ORDER,
        ns1:Parametro_TYPE ;
    ns1:textoExtracto "El filtro \"paso bajo\", para un misma frecuencia, necesita menos orden y como consecuencia, introduce menos retardo. Este tipo de filtro introduce un desfase no constante, dependiente de las frecuencias.",
        "Filtros \"paso bajo\". Si la máquina presenta la frecuencia de resonancia al final de su banda pasante, bastará con eliminarla mediante un filtro \"paso bajo\".",
        "Los filtros \"paso bajo\", que limitan la banda pasante a partir de una determinada frecuencia.",
        "Curva de magnitud típica de un filtro paso bajo: respuesta plana (Ao) y caída a partir de la frecuencia de corte 'FREQUENCY', con marca de –3 dB (0,707·Ao). El gráfico explica el efecto de limitar banda para suavizar movimientos y evitar resonancias altas."@es ;
    ns1:valor "FREQUENCY (frecuencia de corte)"@es .

