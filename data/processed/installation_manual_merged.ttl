    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:identificador "(V.)MPM.COMMENT[pos]",
        "COMMENT" ;
    ns1:textoExtracto "COMMENT Descripción de la función M.",
        "COMMENT Descripción de la función M. Este campo ofrece la posibilidad de asociar una pequeña descripción a la función M. Este campo es informativo; no es utilizado por el CNC."@es .

ns1:Parametro_COMPAXIS a ns1:Parametro ;
    rdfs:label "COMPAXIS",
        "COMPAXIS"@es ;
    ns1:identificador "MPG.COMPAXIS[tbl]" ;
    ns1:monitoreaParametro ns1:Tabla_CompensacionCruzada ;
    ns1:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n",
        "COMPAXIS Eje que sufre variaciones (compensado). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.COMPAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece cuál es el eje compensado en la compensación cruzada."@es .

ns1:Parametro_COMPAXIS_104 a ns1:Parametro ;
    rdfs:label "COMPAXIS"@es ;
