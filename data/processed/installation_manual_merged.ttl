    ns1:identificador "MPG.ETHERCATBUS" ;
    ns1:textoExtracto "ETHERCATBUS Activar el bus EtherCAT. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.ETHERCATBUS Activar el bus EtherCAT."@es ;
    ns1:valor "No" .

ns1:Parametro_ExtensionFST a ns1:Parametro ;
