    ns1:monitoreaParametro ns1:Param_LOSPDLIM,
        ns1:Param_UPSPDLIM,
        ns1:Parametro_LOSPDLIM,
        ns1:Parametro_UPSPDLIM ;
    ns1:textoExtracto "Cuando se trabaja con M3 y M4 la señal REVOK se pone a nivel lógico alto cuando las revoluciones reales del cabezal se encuentran entre dichos porcentajes.",
