    ns1:monitoreaParametro ns1:ParametroEXTMULT_90k ;
    ns1:textoExtracto "HO SO 90.000 imp|ulsos."@es .

ns1:Encoder_CaptacionDirecta a ns1:Sensor ;
    rdfs:label "Encoder (captación directa)"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_CaptacionDirecta_CounterTypeLocal,
        ns1:Esquema_CaptacionDirecta_CounterTypeRegulador ;
    ns1:monitoreaParametro ns1:Parametro_PosicionEje ;
    ns1:textoExtracto "captación directa (encoder) entra en la segunda entrada del regulador"@es .

ns1:Encoder_Componente a ns1:ComponenteElectrico ;
    rdfs:label "Encóder" ;
    ns1:monitoreaParametro ns1:Encoder_Parametro_DATALENGTH,
        ns1:Encoder_Parametro_SERIALNUMBER ;
    ns1:textoExtracto "Si el encóder es lineal, resolución en nanómetros. • Si el encóder es angular, número de impulsos por vuelta." .

ns1:EntradaAnalogica_AI1_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI1 (RIO5)" ;
    ns1:identificador "AI1" ;
    ns1:textoExtracto "Entradas analógicas (AI1..AI4) del módulo RIO5." .

ns1:EntradaAnalogica_AI5_PT100_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI5 (RIO5)" ;
    ns1:identificador "AI5" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_EntradasActivas ;
    ns1:textoExtracto "Entradas PT100 (AI5..AI6) del módulo RIO5." .

ns1:EntradaCPR_Contador a ns1:InterfazUsuario ;
    rdfs:label "Entrada de preselección (CPR)"@es ;
    ns1:identificador "CPR" ;
    ns1:monitoreaParametro ns1:Parametro_ValorContador ;
    ns1:textoExtracto "Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es .

ns1:EntradaCaptacionInterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación interna (motor)" ;
    ns1:textoExtracto "captación interna (motor)" .

ns1:EntradaCaptacion_CANfagor a ns1:Parametro ;
    rdfs:label "Número de entrada de captación (módulos CANfagor)"@es ;
    ns1:monitoreaParametro ns1:ModuloContadoras_CANfagor ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza."@es .

ns1:EntradaCaptacion_Laser a ns1:Parametro ;
    rdfs:label "Entrada de captación del cabezal láser"@es ;
    ns1:monitoreaParametro ns1:CabezalLaser ;
    ns1:textoExtracto "la entrada de captación del cabezal será 0 ya que no hay captación real."@es ;
    ns1:valor "0" .

ns1:EntradaCaptacion_RCS_S a ns1:Parametro ;
    rdfs:label "Número de entrada de captación (módulo RCS-S)"@es ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza. [...] Las entradas de captación del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente."@es .

ns1:EntradaCaptacion_Sercos a ns1:Parametro ;
    rdfs:label "Dirección lógica del regulador Sercos (1-32)"@es ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "El parámetro indica la dirección lógica del regulador (de 1 a 32). La dirección lógica la establece el conmutador rotativo 'address'."@es ;
    ns1:valor "1-32" .

ns1:EntradaPT100_AI3_Nodo2 a ns1:Sensor ;
    rdfs:label "Entrada PT100 (AI3) en RIOR" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_n ;
    ns1:textoExtracto "Entradas PT100 (AI3..AI4) en módulo RIOR." .

ns1:EntradaPT100_AI4_Nodo2 a ns1:Sensor ;
    rdfs:label "Entrada PT100 (AI4) en RIOR" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_n ;
    ns1:textoExtracto "Entradas PT100 (AI3..AI4) en módulo RIOR." .

ns1:EntradaPT100_AI5 a ns1:Sensor ;
    rdfs:label "Entrada PT100 (AI5)" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_n ;
    ns1:textoExtracto "Entradas PT100 (AI5..AI6) en módulo RIO5." .

ns1:EntradaPT100_AI6 a ns1:Sensor ;
    rdfs:label "Entrada PT100 (AI6)" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_n ;
    ns1:textoExtracto "Entradas PT100 (AI5..AI6) en módulo RIO5." .

ns1:Entrada_I3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3 (reset temporizador)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "Por defecto y cada vez que se activa un temporizador el PLC pone esta entrada a (=0). I3 = TRS 10. La entrada I3 controla la entrada de reset del temporizador T10." .

ns1:EntradasAnalogicas_Fagor a ns1:Sensor ;
    rdfs:label "Entradas analógicas Fagor (verde)"@es ;
    ns1:documentadoEn ns1:Tabla_20_2_2_Interface ;
    ns1:textoExtracto "Color verde. Registros de las entradas analógicas Fagor."@es .

ns1:EntradasDigitales_Interface a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (azul)"@es ;
    ns1:documentadoEn ns1:Tabla_20_2_2_Interface ;
    ns1:textoExtracto "Color azul. Entradas digitales."@es .

ns1:Entradas_I14 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas I14 y siguientes" ;
    ns1:textoExtracto "transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD" .

ns1:ErrorCNC_LatcheoConcurrente a ns1:AvisoSeguridad ;
    rdfs:label "Error de latcheo concurrente" ;
    ns1:mitigaRiesgo ns1:G100 ;
    ns1:textoExtracto "si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error"@es .

ns1:ErrorLicenciaArranque a ns1:AvisoSeguridad ;
    rdfs:label "Error de licencia al arrancar el programa"@es ;
    ns1:solucionaFallo ns1:FalloLicenciaNoEncontrada ;
    ns1:textoExtracto "Error de licencia al arrancar el programa. El pendrive con la licencia debe estar conectado al PC. Si al arrancar el programa se produce el siguiente error, significa que el programa no encuentra la licencia."@es .

ns1:ErrorLimiteEjes a ns1:AvisoSeguridad ;
    rdfs:label "Error de límites de eje sobrepasados"@es ;
    ns1:monitoreaParametro ns1:LimitesSoftwareEjes,
        ns1:ToleranciaLimiteEjes ;
    ns1:textoExtracto "antes de dar error de límites sobrepasados [...] Cuando no hay movimiento teórico programado sólo se dará error de límites si se supera la tolerancia en un periodo de muestreo; por ejemplo, si se da un golpe al eje que le saque de límites de forma brusca."@es .

ns1:Error_0046 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0046: 'Eje inexistente'" ;
    ns1:identificador "0046" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME,
        ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:textoExtracto "0046 'Eje inexistente' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS. SOLUCIÓN Corregir los parámetros máquina. Los nombres de eje válidos son los definidos en el parámetro AXISNAME." .

ns1:Error_1445 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1445: 'Valor de parámetro no válido'" ;
    ns1:identificador "1445" ;
    ns1:textoExtracto "1445 'Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA En una sentencia o en un ciclo fijo, un parámetro tiene un valor no válido. SOLUCIÓN Revisar la programación." .

ns1:Error_1447 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1447: 'Opción de software no permitida'" ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "1447 'Opción de software no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de la opción de software necesaria para ejecutar la orden programada. SOLUCIÓN En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC." .

ns1:Error_23101 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23101: 'Error en el análisis del fichero de definición de la compensación volumétrica'" ;
    ns1:identificador "23101" ;
    ns1:monitoreaParametro ns1:Parametro_NPOINTSAX1,
        ns1:Parametro_NPOINTSAX2,
        ns1:Parametro_NPOINTSAX3,
        ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "23101 'Error en el análisis del fichero de definición de la compensación volumétrica' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados. Compensación volumétrica básica: • El fichero no es del tipo csv. • El formato del fichero definido en VCOMPFILE no es correcto. • El fichero definido en VCOMPFILE no tiene definidos todos los puntos. El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3 Compensación volumétrica media y grande: • El formato del fichero definido en VCOMPFILE no es correcto." .

ns1:Error_2427 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2427: Sintaxis incorrecta en #DMC ON" ;
    ns1:identificador "2427" ;
    ns1:mitigaRiesgo ns1:Solucion_2427 ;
    ns1:textoExtracto "#DMC ON [<PWRSP value><,OVRMIN value><,OVRMAX value><,FZMIN value><,FZMAX value>] [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2428 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2428: Sintaxis incorrecta en #DMC OFF" ;
    ns1:identificador "2428" ;
    ns1:mitigaRiesgo ns1:Solucion_2428 ;
    ns1:textoExtracto "#DMC OFF [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2429 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2429: Parámetro DMC fuera de rango" ;
    ns1:identificador "2429" ;
    ns1:mitigaRiesgo ns1:Solucion_2429 ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango [...] CAUSA Algún comando de la sentencia #DMC tiene un valor no válido." .

ns1:Error_2430 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2430: FZMIN ≥ FZMAX en #DMC ON" ;
    ns1:identificador "2430" ;
    ns1:mitigaRiesgo ns1:Solucion_2430 ;
    ns1:textoExtracto "#DMC ON: FZMIN debe ser menor que FZMAX. [...] CAUSA En la función #DMC, el avance mínimo es mayor que el avance máximo." .

ns1:Error_2431 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2431: OVRMIN ≥ OVRMAX en #DMC ON" ;
    ns1:identificador "2431" ;
    ns1:mitigaRiesgo ns1:Solucion_2431 ;
    ns1:textoExtracto "#DMC ON: OVRMIN debe ser menor que OVRMAX. [...] CAUSA En la función #DMC, el override mínimo es mayor que el override máximo." .

ns1:Error_2432 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2432: DMCON no permitido con cabezal analógico" ;
    ns1:identificador "2432" ;
    ns1:mitigaRiesgo ns1:Solucion_2432 ;
    ns1:textoExtracto "#DMCON: Programación no permitida con cabezal analógico. [...] CAUSA El CNC ha intentado activar el DMC sobre un cabezal analógico." .

ns1:Error_2433 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2433: Falta comando ON/OFF en DMC",
        "Error 2433: Falta programación ON/OFF" ;
    ns1:identificador "2433" ;
    ns1:mitigaRiesgo ns1:Solucion_2433 ;
    ns1:solucionaFallo ns1:Comando_DMCOFF,
        ns1:Comando_DMCON ;
    ns1:textoExtracto "Es obligatorio programar ON/OFF. DETECCIÓN Durante la ejecución. CAUSA Falta programar el comando ON/OFF para activar o anular la función. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Incluir el comando ON para activar la función (por ejemplo, #DMCON [...]) o el comando OFF para anularla (por ejemplo, #DMC OFF).",
        "Es obligatorio programar ON/OFF. [...] CAUSA Falta programar el comando ON/OFF para activar o anular la función." .

ns1:Error_2458 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2458: Cabezal sin permiso DMC (DMCSPDL)" ;
    ns1:identificador "2458" ;
    ns1:solucionaFallo ns1:Parametro_DMCSPDL ;
    ns1:textoExtracto "#DMC ON:El cabezal master debe tener el parámetro DMCSPDL = Sí. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." .

ns1:Error_3100 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3100: Potencia excesiva en el cabezal detectada durante DMC" ;
    ns1:identificador "3100" ;
    ns1:mitigaRiesgo ns1:Herramienta_DMC ;
    ns1:textoExtracto "3100 Potencia excesiva en el cabezal detectada durante DMC. [...] Esto puede indicar que la herramienta está desgastada o deteriorada." .

ns1:Error_3101 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3101: Potencia excesiva en el cabezal detectada durante DMC" ;
    ns1:identificador "3101" ;
    ns1:mitigaRiesgo ns1:Herramienta_DMC ;
    ns1:textoExtracto "3101 Potencia excesiva en el cabezal detectada durante DMC. [...] Esto puede indicar que la herramienta ha colisionado con la pieza, por lo que el CNC detiene los ejes manteniendo el giro del cabezal." .

ns1:Error_3103 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3103: Potencia objetivo insuficiente para el funcionamiento correcto con DMC" ;
    ns1:identificador "3103" ;
    ns1:monitoreaParametro ns1:Variable_TV51 ;
    ns1:textoExtracto "3103 Potencia objetivo insuficiente para el funcionamiento correcto con DMC. [...] La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío." .

ns1:Error_3753 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753"@es ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "mostrará el error 3753. Con este error, el usuario decide la validez de la cota."@es .

ns1:Error_9347 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9347: 'Eje repetido en VOLCOMP'" ;
    ns1:identificador "9347" ;
    ns1:monitoreaParametro ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:textoExtracto "9347 'Eje repetido en VOLCOMP' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces. SOLUCIÓN Corregir los parámetros máquina." .

ns1:Error_AsignacionRecurso a ns1:AvisoSeguridad ;
    rdfs:label "Error de asignación de recurso" ;
    ns1:mitigaRiesgo ns1:Overlapped_Configuracion_Modulo ;
    ns1:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." .

ns1:Error_ERR1_ERR1024 a ns1:AvisoSeguridad ;
    rdfs:label "Errores (ERR1-ERR1024)"@es ;
    ns1:activaAlarma ns1:Senal_Emergencia_PLC ;
    ns1:documentadoEn ns1:Tabla_MensajesErrores_PLC ;
    ns1:identificador "ERR1-ERR1024" ;
    ns1:textoExtracto "Errores (ERR1-ERR1024). Al activarlas (=1) producen un error, muestran el mensaje de error e interrumpen la ejecución del CNC. Los errores del PLC pueden configurarse para que activen la señal de emergencia del PLC (_EMERGEN)."@es .

ns1:Error_LecturaVariableInexistente a ns1:AvisoSeguridad ;
    rdfs:label "Error: Variable inexistente" ;
    ns1:textoExtracto "Si se solicita información de una variable inexistente (por ejemplo la cota de un eje que no existe) se mostrará un mensaje de error." .

ns1:Error_RangoExcedido a ns1:AvisoSeguridad ;
    rdfs:label "Error: Rango excedido" ;
    ns1:textoExtracto "Si se intenta leer un valor cuyo rango es mayor al del registro PLC, el CNC devolverá valor cero y mostrará el error correspondiente." .

ns1:EsquemaCinematica_TYPE21 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=21" ;
    ns1:identificador "TYPE=21" ;
    ns1:monitoreaParametro ns1:ParametroTDATA_1,
        ns1:ParametroTDATA_12,
        ns1:ParametroTDATA_2,
        ns1:ParametroTDATA_3,
        ns1:ParametroTDATA_4,
        ns1:ParametroTDATA_5,
        ns1:ParametroTDATA_7,
        ns1:ParametroTDATA_8,
        ns1:ParametroTDATA_9 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=21 con ejes X-Y-Z y rotaciones C/A/B. Presenta el orden de ejes (1º-3º), componentes TDATA (1, 2, 3, 4, 5, 7, 8, 9, 12) y flechas de sentido; organiza jerárquicamente dirección y posición de cada giro." .

ns1:EsquemaCinematica_TYPE22 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=22" ;
    ns1:identificador "TYPE=22" ;
    ns1:monitoreaParametro ns1:ParametroTDATA_11,
        ns1:ParametroTDATA_2,
        ns1:ParametroTDATA_5,
        ns1:ParametroTDATA_7,
        ns1:ParametroTDATA_8 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=22 con ejes X-Y-Z y rotación C/B. Se especifican TDATA (2, 5, 7, 8, 11) y el orden 1º-3º; las anotaciones (+/−) establecen polaridad y sentido del giro respecto a los ejes lineales." .

ns1:EsquemaCinematica_TYPE23 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=23" ;
    ns1:identificador "TYPE=23" ;
    ns1:monitoreaParametro ns1:ParametroTDATA_1,
        ns1:ParametroTDATA_10,
        ns1:ParametroTDATA_11,
        ns1:ParametroTDATA_12,
        ns1:ParametroTDATA_13,
        ns1:ParametroTDATA_2,
        ns1:ParametroTDATA_21,
        ns1:ParametroTDATA_22,
        ns1:ParametroTDATA_23,
        ns1:ParametroTDATA_3,
        ns1:ParametroTDATA_4,
        ns1:ParametroTDATA_5,
        ns1:ParametroTDATA_6,
        ns1:ParametroTDATA_7,
        ns1:ParametroTDATA_8,
        ns1:ParametroTDATA_9 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=23 (A/B/C con X-Y-Z). Diagramas con TDATA 1–13 y 21–23 que representan posiciones, offsets y sentidos de giro; incluye numeración de ejes 1º-3º y convenciones de signo." .

ns1:EsquemaCinematica_TYPE24 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=24" ;
    ns1:identificador "TYPE=24" ;
    ns1:monitoreaParametro ns1:ParametroTDATA_2,
        ns1:ParametroTDATA_4,
        ns1:ParametroTDATA_5,
        ns1:ParametroTDATA_8 ;
    ns1:textoExtracto "Esquema de cinemática TYPE=24 (A/B/C con X-Y-Z). Muestra vectores asociados a TDATA (2, 4, 5, 8) y la correspondencia entre traslaciones/giros con indicación de orden y sentido." .

ns1:EsquemaComportamientoEjeRotativo a ns1:Esquema ;
    rdfs:label "Comportamiento de eje rotativo de posicionamiento"@es ;
    ns1:documentadoEn ns1:Pagina_572 ;
    ns1:textoExtracto "Tres diagramas polares comparan el comportamiento de un eje rotativo 'de posicionamiento' (camino más corto), mostrando arcos de 60° y 300° con flechas que indican trayectorias mínima y alternativa; los rótulos B300/–B300 señalan límites de módulo y la cota visible."@es .

ns1:EsquemaCotasRotativas_Modulo a ns1:Esquema ;
    rdfs:label "Visualización de cotas en ejes rotativos (modo módulo)"@es ;
    ns1:documentadoEn ns1:Pagina_571 ;
    ns1:textoExtracto "Conjunto de tres esquemas circulares que representan la visualización de cotas en ejes rotativos en modo 'módulo', con marcas de ±300° y flechas de sentido de giro. Se ilustran límites superior e inferior del módulo y cómo se mapea la posición angular alrededor de 0°, destacando sectores sombreados y anotaciones de 30° para indicar direccionalidad y rango visible."@es .

ns1:EsquemaDIN66217_Ejes a ns1:Esquema ;
    rdfs:label "Esquema de nomenclatura de ejes según DIN 66217"@es ;
    ns1:documentadoEn ns1:Pagina_570 ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "Ilustración conceptual de la norma DIN 66217 para nomenclatura de ejes: dibujos con triedro XYZ y flechas que indican ejes principales (X, Y, Z), auxiliares paralelos (U, V, W) y rotativos (A, B, C) alrededor de X, Y, Z respectivamente. La gráfica sitúa los ejes respecto al plano de trabajo y el eje perpendicular, ayudando a identificar la función de cada eje en la máquina."@es .

ns1:EsquemaEncoderLineal a ns1:Esquema ;
    rdfs:label "Esquema de encoder lineal con referencia codificada"@es ;
    ns1:detalladoEnEsquema ns1:EncoderLineal_Componente ;
    ns1:textoExtracto "esquema de encoder lineal con referencia codificada: se dibuja la regla con el 'cero del cristal (OG)', el 'cero máquina (OM)' y el desplazamiento 'ABSOFF'. Una lupa esquematiza la serigrafía; la flecha de lectura indica que el origen de codificación puede quedar dentro o fuera de la regla"@es .

ns1:EsquemaOsciloscopioDMC a ns1:Esquema ;
    rdfs:label "Captura del osciloscopio (DMC)" ;
    ns1:detalladoEnEsquema ns1:MAXDMCOVR ;
    ns1:ilustradoEn [ a ns1:Pagina ;
            ns1:identificador "734" ] ;
    ns1:textoExtracto "A Control del override para optimizar la potencia. B Mecanizado en G00. C Entrada a la pieza. D Movimiento en vacío; override máximo (parámetro máquina MAXDMCOVR)." .

ns1:EsquemaPaso5_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 5) mostrando varios planos intermedios Z"@es ;
    ns1:identificador "Paso 5" ;
    ns1:textoExtracto "Esquema 3D (Paso 5) mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance. La representación enfatiza la construcción volumétrica por capas, manteniendo los incrementos definidos para cada eje."@es .

ns1:EsquemaSecuenciaAparcadoCNC a ns1:Esquema ;
    rdfs:label "Diagrama temporal de secuencia de aparcado/desaparcado (iniciada desde CNC)"@es ;
    ns1:detalladoEnEsquema ns1:SenalDRENA,
        ns1:SenalPARK,
        ns1:SenalPARKED,
        ns1:SenalREFPOIN,
        ns1:SenalUNPARK,
        ns1:VentanaTemporalMINAENDW ;
    ns1:textoExtracto "Diagrama temporal multiseñal que muestra la secuencia de aparcado/desaparcado gestionada desde el CNC. Incluye trazas PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis), numeradas (1–6) para los hitos del proceso. Se señalan ventanas temporales MINAENDW."@es .

ns1:EsquemaSecuenciaAparcadoPLC a ns1:Esquema ;
    rdfs:label "Diagrama temporal de secuencia de aparcado/desaparcado (iniciada desde PLC)"@es ;
    ns1:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC."@es .

ns1:Esquema_17.1_TDATA5_PrimeraPalpacion a ns1:Esquema ;
    ns1:identificador "17.1 - TDATA5 (Primera palpación)" ;
    ns1:ilustradoEn ns1:Pagina_708 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara X próxima al origen y preselección X=0; se señalan ejes X-Z y posición ①." .

ns1:Esquema_17_1_CalculoParametroTDATA2 a ns1:Esquema ;
