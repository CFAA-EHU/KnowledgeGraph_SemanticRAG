ns1:Parametro_SSIALARMBITS a ns1:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ns1:identificador "(V.)[ch].MPA.SSIALARMBITS[set].xn",
        "SSIALARMBITS" ;
    ns1:textoExtracto "El captador puede mandar uno o varios bits indicando una condición de alarma si algo ha ido mal, o bien uno o varios bits de reconocimiento (acknowledge) si la transmisión ha sido efectuada correctamente. Valores posibles: De 0 a 2. Valor por defecto: 0.",
        "SSIALARMBITS = 1 | 1 bit de alarma/acknowledge.",
        "SSIALARMBITS = 2" ;
    ns1:valor "0-2",
        "1",
        "2" .

ns1:Parametro_SSICRCBITS a ns1:Parametro ;
