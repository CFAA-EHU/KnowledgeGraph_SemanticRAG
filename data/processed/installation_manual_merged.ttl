ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal",
        "Cabezal de la máquina",
        "Cabezal de máquina",
        "Cabezal"@es,
        "Cabezal de máquina"@es,
        "Cabezal portaherramientas"@es ;
    ns1:compuestoPor ns1:RutinaM06 ;
    ns1:textoExtracto """\r
Llevar la herramienta de la pinza 1 al cabezal.\r
Coger la herramienta del cabezal con la pinza 2.\r
Quitar la herramienta del cabezal (llevarla a tierra).\r
Colocar la herramienta de tierra en el cabezal.""",
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático.",
        "La herramienta se ha llevado de la pinza 1 al cabezal.",
        "Llevar la herramienta de la pinza 1 al cabezal. Quitar la herramienta del cabezal (llevarla a tierra). Colocar la herramienta de tierra en el cabezal.",
        "Quitar la herramienta del cabezal.",
        "cabezal",
        "pasando por el cabezal",
        """\r
LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático.\r
LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.\r
"""@es,
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] LL SUB_CH1_TO_SPD ; Llevar la herramienta [...] al cabezal."@es,
        "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es,
        "cabezal"@es,
        "llevar el cabezal al punto de cambio [...] quitar la herramienta del cabezal [...] colocar la herramienta de tierra en el cabezal"@es,
        "ponerla en el cabezal... Dejar la herramienta del cabezal..."@es ;
    ns1:tieneFrecuencia ns1:PuntoCambioAutomatico,
        ns1:PuntoCambioManual .

