    ns1:identificador "ABSOFF" ;
    ns1:monitoreaParametro ns1:Parametro_4e0ce00763 ;
    ns1:textoExtracto "Offset del captador respecto a I0."@es .

ns1:Parametro_cb7224ec89 a ns1:Parametro ;
    rdfs:label "MANNEGSW" ;
