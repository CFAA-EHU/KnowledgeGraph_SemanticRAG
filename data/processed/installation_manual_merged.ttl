    ns1:documentadoEn ns1:Tabla_PlanosTrabajo_205 ;
    ns1:identificador "G90" ;
    ns1:textoExtracto """\r
ISYSTEM Tipo de coordenadas (G90/G91) por defecto. Valor por defecto: G90.\r
Las coordenadas de un punto se pueden definir en cotas absolutas (G90) respecto el origen.\r
"""@es .

