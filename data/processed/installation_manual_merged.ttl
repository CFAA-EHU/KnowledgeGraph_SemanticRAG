ns1:ConfiguracionAlmacenes a ns1:Sistema ;
    rdfs:label "Configuración de almacenes y cambio de herramienta"@es ;
    ns1:detalladoEnEsquema ns1:EjemplosTiposAlmacen ;
    ns1:textoExtracto "Para configurar adecuadamente los almacenes y el cambio de herramienta se debe: • Personalizar los parámetros máquina. • Definir la tabla de herramientas y de los almacenes. • Elaborar el programa de PLC. • Programar la rutina asociada a la herramienta y a la función M06."@es ;
    ns1:tieneComponente ns1:ParametrosMaquina_Almacenes,
        ns1:ProgramaPLC_CambioHerramienta,
        ns1:RutinaM06,
        ns1:TablaHerramientas .

ns1:ConfiguracionArranqueNesting_1283 a ns1:InterfazUsuario ;
    rdfs:label "Configuración de arranque del nesting (pág. 691)"@es ;
    ns1:ilustradoEn ns1:Pagina_691 ;
    ns1:textoExtracto "Hay tres formas diferentes para arrancar el nesting. [...] Para arrancar el nesting, ir al modo Diagnosis, y en el menú horizontal seleccionar Apps > Lantek."@es ;
    ns1:tieneComponente ns1:ArchivoBAT_CNC8070L,
        ns1:ArchivoConfig_AppsINI,
        ns1:TeclaUSERKEY .

ns1:ConfiguracionCabezalesCanal a ns1:Sistema ;
    rdfs:label "Configuración de cabezales del canal"@es ;
    ns1:identificador "2.4.3" ;
    ns1:textoExtracto "A la hora de definir los cabezales, hay que tener en cuenta que el orden en el que se definen establece su índice en el canal. El primer cabezal de la tabla tendrá índice ꞏ1ꞏ y así sucesivamente. Al igual que el nombre del cabezal, el índice en el canal permite identificar el cabezal en variables, marcas de PLC, etc."@es .

ns1:ConfiguracionCinematicaTipos13a16 a ns1:ModoOperacion ;
    rdfs:label "Configuración cinemática (tipos 13 a 16)" ;
    ns1:textoExtracto "En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta, por lo que se parametrizará TDATA10=1 TDATA11=1." ;
    ns1:tieneComponente ns1:TDATA10,
        ns1:TDATA11 .

ns1:ConfiguracionEjeGantry a ns1:Sistema ;
    rdfs:label "Configuración de un eje gantry"@es ;
    ns1:textoExtracto "MASTERAXIS | Eje maestro o principal. SLAVEAXIS | Eje esclavo. WARNCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning."@es ;
    ns1:tieneComponente ns1:Parametro_MASTERAXIS,
        ns1:Parametro_SLAVEAXIS,
        ns1:Parametro_WARNCOUPE .

ns1:ConfiguracionEjeTandem_1068 a ns1:Sistema ;
    rdfs:label "Configuración del eje tándem"@es ;
    ns1:textoExtracto "Distribución de par. Ganancia de normalización de los pares generados por los motores cuyo fin es establecer un reparto de pares que no siga una relación 1:1. Precarga. Par previo aplicado a ambos ejes del tándem en sentidos opuestos. De esta manera se establece una tracción entre ellos con el fin de eliminar la holgura piñón-cremallera cuando se encuentra en reposo. Se determina como la diferencia de par que suministra cada uno de los ejes."@es ;
    ns1:tieneComponente ns1:MotorTandemDerecho_1068,
        ns1:MotorTandemIzquierdo_1068,
        ns1:PinonCremalleraTandem_1068 .

ns1:ConfiguracionEjesCanal_183 a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo 'plano' (intercambio de ejes)"@es ;
    ns1:habilitadoPor ns1:Funcion_G20,
        ns1:Sentencia_TOOL_AX ;
    ns1:identificador "2.4.2" ;
    ns1:textoExtracto """\r
    Configuración de ejes tipo "plano". Intercambio de ejes.\r
    Se permite el intercambio de ejes, pero se debe tener en cuenta que el comportamiento anterior se mantiene;\r
    es decir, todo el tratamiento explicado anteriormente se mantiene para los ejes primero y segundo del canal que resulten del intercambio.\r
    """@es .

ns1:ConfiguracionGrupoMultieje_1094 a ns1:Sistema ;
    rdfs:label "Configuración del grupo multieje (GROUP_1)" ;
    ns1:compuestoPor ns1:Parametro_MULNAXIS_1094,
        ns1:Parametro_MULNGROUP_1094 ;
    ns1:identificador "GROUP_1" ;
    ns1:textoExtracto "Configuración del grupo multieje. | MULTIAXIS | GROUP_1 |" ;
    ns1:tieneComponente ns1:Eje_A1_1094,
        ns1:Eje_A2_1094 .

ns1:ConfiguracionSensorGap_1292 a ns1:Sistema ;
    rdfs:label "Configuración del sensor del gap"@es ;
    ns1:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor. [...] Ajustar la señal de colisión del sensor."@es ;
