    ns1:textoExtracto "Componente TDATA 8 en esquemas TYPE=21, TYPE=22, TYPE=23 y TYPE=24" .

ns1:Parametro_ACFWFACTOR a ns1:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ns1:identificador "ACFWFACTOR" ;
    ns1:monitoreaParametro ns1:Sensor_EjeAsociado ;
    ns1:textoExtracto "ACFWFACTOR Constante de tiempo de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0.001 a 1000000.0000 ms. Valor por defecto: 1000.0000 ms.",
        "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicara el parámetro TRANSDELAY (aproximadamente la suma de TRANSDELAY y ACFWFACTOR en un ajuste analógico o Sercos velocidad).",
        "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicaría el parámetro TRANSDELAY (aproximadamente la suma de TRANSDELAY y ACFWFACTOR en un ajuste analógico o Sercos velocidad)." ;
    ns1:valor "1000.0000 ms" .

ns1:Parametro_COMPID a ns1:Parametro ;
    rdfs:label "COMPID" ;
    ns1:identificador "COMPID" ;
    ns1:textoExtracto "parámetro COMPID" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID",
        "Parámetro COUNTERID" ;
    ns1:documentadoEn ns1:TablaParametrosVolanteJog,
        ns1:Tabla_MANPG,
        ns1:Tabla_ParametrosMPG_488 ;
    ns1:identificador "COUNTERID",
        "MPMAN.COUNTERID[hw]" ;
    ns1:monitoreaParametro ns1:EntradaCaptacionExterna,
        ns1:Sistema_EjesAnalogicos,
        ns1:Sistema_EntradaCaptacionVolante ;
    ns1:textoExtracto "COUNTERID Entrada de captación asociada al volante. Valores posibles: De 1 a 40 si captación remotas CAN / de -1 a -9 si captación en el teclado / de 1 a 2 si captación local / de 1 a 32 si captación en módulo RCS-S / 1 si la captación variable. Valor por defecto: 0.",
        "COUNTERID Número de la entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Módulos remotos, de 1 a 40 / Regulador Sercos, de 1 a 32 / Contadora Sercos, de 1 a 32 / Entradas locales, de 1 a 2. Valor por defecto: 0.",
        "COUNTERID | 1 - 32.",
        "COUNTERID | Número de la entrada de captación del eje.",
        "Entrada de captación asociada al volante.",
        "Número de la entrada de captación del eje.",
        "en el parámetro COUNTERID hay que indicar cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador.",
        "los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles",
        "COUNTERID | -2 | Conector MPG2."@es,
        "COUNTERID | 1 | Entrada de contaje X1."@es,
        "COUNTERID | Número de la entrada de captación."@es ;
    ns1:valor 0,
        "-2",
        "1",
        "1 - 32",
        "1-2 (unidad central)",
        "1-32",
        "1-32 (dirección lógica)",
        "1-4 (primer módulo)",
        "5-8 (segundo módulo)" .

ns1:Parametro_EntradaCaptacionEje a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del eje"@es,
        "Parámetro de entrada de captación asociada al eje"@es,
        "Parámetro de ubicación de entrada de captación del eje"@es ;
    ns1:identificador "2.6.20" ;
    ns1:monitoreaParametro ns1:Sensor_EntradaCaptacionLocal,
        ns1:Sensor_EntradaCaptacionRemota,
        ns1:Sensor_EntradaCaptacionSercos ;
    ns1:textoExtracto "Cuando la captación del eje esté en un regulador Sercos, en este regulador parametrizar el parámetro PP5=-0,0001."@es,
        "Direct Feedback Motor Feedback Sercos Número de la entrada de captación del eje. Dependiendo del tipo de captación, este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador."@es,
        "Este parámetro indica dónde está ubicada la entrada de captación del eje; en los módulos remotos, en la captación libre de un regulador Sercos, en un módulo RCS-S (contadora Sercos) o en las entradas de captación locales de la unidad central."@es,
        "este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador o contadora"@es ;
    ns1:valor "PP5=-0,0001"@es .

ns1:Parametro_EstadoMecanizado a ns1:Parametro ;
    rdfs:label "Estado de mecanizado de la herramienta (0: inactivo, 1: activo)"@es ;
    ns1:textoExtracto "el CNC consulta esta marca para saber si la herramienta está mecanizando (=1) o no (=0)."@es .

ns1:Parametro_FRAPIDEN a ns1:Parametro ;
    rdfs:label "FRAPIDEN",
        "FRAPIDEN (eje)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceRapido ;
    ns1:identificador "FRAPIDEN" ;
    ns1:monitoreaParametro ns1:Maquina_Actual,
        ns1:ModoOperacion_Autom_tico ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN",
        "FRAPIDEN Avance rápido del eje, para los desplazamientos en el modo automático. Parámetro válido para ejes lineales, rotativos y cabezales.",
        "FRAPIDEN Avance rápido en el canal, para los desplazamientos en el modo automático. Valores posibles: De 0 a 500000.0000 mm/min / de 0 a 19685.03937 inch/min. Valor por defecto: 0.",
        "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN"@es,
        "FRAPIDEN (eje)"@es ;
    ns1:valor 0.0,
        "0-500000.0000 mm/min",
        "6000" .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED",
        "JOGFEED (Avance en modo jog continuo)"@es ;
    ns1:documentadoEn ns1:Tabla_Manual,
        ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "JOGFEED" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "JOGFEED: 100 mm/min.",
        "Modo de trabajo manual. Avance en modo jog continuo.",
        "Si no se define, el CNC asume para el reposicionamiento el avance definido para el modo jog continuo (parámetro JOGFEED).",
        "Avance en modo jog continuo."@es,
        "JOGFEED Avance en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro define el avance para los desplazamientos en jog continuo en modo manual."@es,
        "JOGFEED | Modo de trabajo manual. Avance en modo jog continuo."@es ;
    ns1:valor "100 mm/min",
        "1000.0000" .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
