    ns1:ejecutadoPor ns1:GestorHerramientas,
        ns1:PLC_ControlAlmacen ;
    ns1:requiereMantenimiento ns1:FuncionM06_Ejecucion,
        ns1:FuncionT_Ejecucion,
        ns1:SistemaGestion_CNC_PLC ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases; la primera con la ejecución de la función T y la segunda con la ejecución de la función M06."@es .

ns1:Canal_3 a ns1:Componente,
        ns1:Sistema ;
    rdfs:label "Canal 3",
        "Canal 3"@es,
        "Canal 3 (Sistema de carga/descarga)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCanales ;
    ns1:identificador "3",
        "Canal ꞏ3ꞏ" ;
    ns1:textoExtracto "el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ y ꞏ3ꞏ",
        "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales. [...] el tercer canal es un sistema de carga y descarga controlado por dos ejes."@es,
        "Canal ꞏ3ꞏ. 2 ejes (U V)"@es ;
    ns1:tieneComponente ns1:Eje_U,
        ns1:Eje_U1_Canal3,
        ns1:Eje_U_Canal3,
        ns1:Eje_V .

ns1:CarpetaMTB a ns1:InterfazUsuario,
        ns1:Sistema ;
    rdfs:label "Carpeta MTB",
        "Carpeta MTB (Machine Tool Builder)",
        "Carpeta MTB (configuración activa)",
        "Carpeta MTB"@es ;
    ns1:compuestoPor ns1:SubcarpetaPROJECT,
        ns1:SubcarpetaRELEASE,
        ns1:SubcarpetaSUB,
        ns1:SubcarpetaTUNING,
        ns1:SubcarpetaWATCH ;
    ns1:identificador "..\\MTB",
        "MTB" ;
    ns1:textoExtracto "1.7.1 Carpeta MTB (Machine Tool Builder).",
        "el fabricante dispone de la carpeta ..\\MTB para que pueda guardar las modificaciones que realiza en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, etc.",
        "el sistema moverá la carpeta correspondiente [...] y la renombrará como MTB. [...] Si el fabricante ha creado la carpeta MTB manualmente, por ejemplo copiándola de algún backup, el sistema no hará ningún cambio en el arranque ni al modificar el código de validación.",
        "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB. [...] la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es .

ns1:CompensacionVolumetrica_Basica a ns1:ModoOperacion,
        ns1:Parametro ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:identificador "Compensación volumétrica básica" ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande.",
        "• El volumen a compensar está definido por hasta 25 puntos en cada eje. • Esta compensación corrige los errores de traslación. • Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. • El OEM debe definir en los parámetros máquina todos los datos de la compensación (ejes que se mueven, ejes a compensar, posición y tamaño del volumen a compensar, etc) y seleccionar el fichero que contiene los datos de la compensación. • La compensación básica es la más rápida de calibrar, pero puede ser menos precisa que las otras (corrige menos componentes de error)." .

ns1:ComponenteMecanico_Pinza1 a ns1:ComponenteMecanico ;
    rdfs:label "Pinza 1 (recogida de herramienta)"@es ;
    ns1:textoExtracto "pinza 1"@es .

ns1:ComponenteMecanico_Pinza2 a ns1:ComponenteMecanico ;
