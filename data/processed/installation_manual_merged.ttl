ns1:Parametro_EXPSCHK a ns1:Parametro ;
    rdfs:label "EXPSCHK" ;
    ns1:identificador "MPG.EXPSCHK" ;
    ns1:textoExtracto "EXPSCHK Activar la vigilancia de 24 V en las salidas digitales locales. Valores posibles: ON / OFF. Valor por defecto: ON. Variable asociada: (V.)MPG.EXPSCHK" ;
    ns1:valor "ON/OFF" .

ns1:Parametro_EXTMULT a ns1:Parametro ;
    rdfs:label "Parámetro EXTMULT (multiplicador externo)",
        "Factor externo para I0 codificados (EXTMULT)"@es ;
    ns1:identificador "MPA.EXTMULT[set].xn" ;
    ns1:textoExtracto "EXTMULT Factor externo para I0 codificados. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 65535. Valor por defecto: 0."@es,
        "Número de ondas entre I0 fijos = 20000/(20 x EXTMULT) = 1000"@es ;
    ns1:valor "0" .

ns1:Parametro_EjeLogicoConSigno_1242 a ns1:Parametro ;
    rdfs:label "Parámetro de eje lógico (con signo)"@es ;
    ns1:textoExtracto "El parámetro se define con un valor comprendido entre -1 y +16 (con signo). El signo indica el sentido positivo (+) o negativo (-) y el número corresponde al eje lógico, según el parámetro AXISNAME."@es ;
    ns1:valor "-1 a +16 (entero con signo)"@es .

ns1:Parametro_EjeLogico_1242 a ns1:Parametro ;
    rdfs:label "Parámetro de eje lógico"@es ;
    ns1:textoExtracto "El parámetro se define con un valor comprendido entre 1 y 16 (sin signo), que corresponde al eje lógico, según el parámetro AXISNAME."@es ;
    ns1:valor "1 a 16 (entero sin signo)"@es .

ns1:Parametro_Eje_Avance a ns1:Parametro ;
    rdfs:label "Parámetro de avance de eje" ;
    ns1:textoExtracto "avances, ganancias, aceleraciones" ;
    ns1:valor "variable según set" .

ns1:Parametro_EjesNoOrtogonales a ns1:Parametro ;
    rdfs:label "Transformación angular de eje inclinado (ejes no ortogonales)"@es ;
    ns1:documentadoEn ns1:Manual_OpenPCS_SeccionParametrosMaquina ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad, mostrando cómo un movimiento programado en X se descompone en componentes sobre Z y X'."@es .

ns1:Parametro_EntradasDigitales_Bus a ns1:Parametro ;
    rdfs:label "Parámetro de entradas digitales (bus)"@es ;
    ns1:textoExtracto "Entradas digitales. Primera = 10 Offset = 100"@es ;
    ns1:valor "Primera: 10 ; Offset: 100"@es .

ns1:Parametro_EntradasSalidas_1266 a ns1:Parametro ;
    rdfs:label "Configuración de entradas y salidas digitales"@es ;
    ns1:textoExtracto "Las entradas y salidas digitales se configuran desde los parámetros máquina."@es ;
    ns1:valor "Rango: 1...1024"@es .

ns1:Parametro_ErrorNegativo a ns1:Parametro ;
    rdfs:label "NEGERROR" ;
    ns1:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:Parametro_ErrorPositivo a ns1:Parametro ;
    rdfs:label "POSERROR" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:Parametro_ErrorSplines a ns1:Parametro ;
    rdfs:label "Valor del error que desactiva las splines"@es ;
    ns1:documentadoEn ns1:Tabla_ValoresErrorHSC ;
    ns1:textoExtracto "Valor del error que desactiva las splines"@es ;
    ns1:valor "-1" .

ns1:Parametro_EstadoBusMechatrolink a ns1:Parametro ;
    rdfs:label "Estado del bus Mechatrolink" ;
    ns1:textoExtracto "El estado del bus Mechatrolink se consulta mediante la marca MLINKRDY." .

ns1:Parametro_EstadoCanalC1 a ns1:Parametro ;
    rdfs:label "Estado del canal 1 (CNC)" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a [INCYCLEC1]." .

ns1:Parametro_EstadoCanalC2 a ns1:Parametro ;
    rdfs:label "Estado del canal 2 (CNC)" ;
    ns1:textoExtracto "INCYCLEC2." .

ns1:Parametro_EstadoCanalC3 a ns1:Parametro ;
    rdfs:label "Estado del canal 3 (CNC)" ;
    ns1:textoExtracto "INCYCLEC3." .

ns1:Parametro_EstadoCanalC4 a ns1:Parametro ;
    rdfs:label "Estado del canal 4 (CNC)" ;
    ns1:textoExtracto "INCYCLEC4." .

ns1:Parametro_EstadoI12 a ns1:Parametro ;
    rdfs:label "Estado lógico de la entrada I12"@es ;
    ns1:textoExtracto "Devuelve un 1 si la entrada I12 se encuentra activa y un 0 en caso contrario."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_EstadoLED_PrimerVolante a ns1:Parametro ;
    rdfs:label "Estado LED del primer volante HBLS" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las teclas del volante HBLS" ;
    ns1:valor "bit=1 (encendido)" .

ns1:Parametro_EstadoLED_SegundoVolante a ns1:Parametro ;
    rdfs:label "Estado LED del segundo volante HBLS" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las teclas del volante HBLS" ;
    ns1:valor "bit=1 (encendido)" .

ns1:Parametro_EstadoLogicoContador a ns1:Parametro ;
    rdfs:label "Estado lógico del contador (C=1 si cuenta es cero, C=0 en otros casos)" ;
    ns1:textoExtracto "El estado lógico del contador será C=1 cuando el valor de la cuenta sea cero y C=0 el resto de los casos." ;
    ns1:valor 0,
        1 .

ns1:Parametro_EstadoLogico_703 a ns1:Parametro ;
    rdfs:label "Nivel lógico (0/1)" ;
    ns1:textoExtracto "Abreviaciones utilizadas en este capítulo. (=0) nivel lógico bajo. (=1) nivel lógico alto."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Parametro_EstadoSTART a ns1:Parametro ;
    rdfs:label "Estado lógico de la tecla START"@es ;
    ns1:textoExtracto "Devuelve un 1 cuando la tecla start del panel frontal está pulsada y un 0 en caso contrario."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_FASTACC a ns1:Parametro ;
    rdfs:label "FASTACC" ;
    ns1:textoExtracto "Aceleración máxima permitida (modo FAST).",
        "FASTACC Aceleración máxima permitida (modo FAST). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 100000.0000 mm/s². Valores posibles (2): De 0 a 3937.00787 inch/s². Valores posibles (3): De 0 a 100000.0000 grados/s². Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.FASTACC[set].xn Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." ;
    ns1:valor "0"^^xsd:string,
        "Aceleración máxima" .

ns1:Parametro_FASTFACTOR a ns1:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "FASTFACTOR" ;
    ns1:monitoreaParametro ns1:ModoHSC_FAST,
        ns1:ModoOperacion_FAST ;
    ns1:textoExtracto "FASTFACTOR Porcentaje de avance por defecto (modo FAST). Valores posibles: De 0 a 100. Valor por defecto: 100. [...] Este parámetro afecta al avance en las esquinas e indica el porcentaje de aceleración que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST.",
        "el porcentaje definido en el parámetro FASTFACTOR. Este parámetro afecta directamente a la velocidad de paso por las esquinas",
        "Porcentaje de avance por defecto (modo FAST)."@es ;
    ns1:valor "100" .

ns1:Parametro_FASTFILTFREQ a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "(V.)[ch].MPG.FASTFILTFREQ",
        "FASTFILTFREQ" ;
    ns1:monitoreaParametro ns1:FiltroEjes_HSC,
        ns1:ModoOperacion_FAST,
        ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Frecuencia del filtro (modo FAST). Valores posibles: De 0 a 500.0000. Valor por defecto: 17. Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas.",
        "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ",
        "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ.",
        "parámetro FASTFILTFREQ para el modo FAST",
        "Frecuencia del filtro (modo FAST)."@es ;
    ns1:valor "17" .

ns1:Parametro_FBACKSRC_A1_1094 a ns1:Parametro ;
    rdfs:label "FBACKSRC (Eje A1)" ;
    ns1:identificador "FBACKSRC_A1" ;
    ns1:textoExtracto "FBACKSRC | Externa Remoto" ;
    ns1:valor "Externa Remoto" .

ns1:Parametro_FBACKSRC_A2_1094 a ns1:Parametro ;
    rdfs:label "FBACKSRC (Eje A2)" ;
    ns1:identificador "FBACKSRC_A2" ;
    ns1:textoExtracto "FBACKSRC | Externa Remoto" ;
    ns1:valor "Externa Remoto" .

ns1:Parametro_FEDYNFAC a ns1:Parametro ;
    rdfs:label "FEDYNFAC",
        "Parámetro FEDYNFAC (Factor de error dinámico de seguimiento)"@es,
        "Porcentaje de desviación permitido para error de seguimiento"@es ;
    ns1:identificador "FEDYNFAC",
        "MPA.FEDYNFAC[set].xn" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento,
        ns1:Sistema_FLWEMONITOR ;
    ns1:textoExtracto "El tipo de monitorización \"Lineal\" efectúa una supervisión dinámica que permite un error de seguimiento porcentual. El porcentaje lo fija el parámetro FEDYNFAC.",
        "FEDYNFAC: Porcentaje de desviación permitido para el error de seguimiento. Valores posibles: De 0 a 100 %."@es,
        "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn [...] Este parámetro indica el error porcentual permitido; es decir, la desviación del error de seguimiento real respecto al teórico."@es ;
    ns1:valor 50,
        "50" .

ns1:Parametro_FEEDAVRG a ns1:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionModoHSC,
        ns1:Tabla_ParametrosHSC_1150 ;
    ns1:identificador "(V.)[ch].MPG.FEEDAVRG",
        "FEEDAVRG",
        "FEEDAVRG MPG" ;
    ns1:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.FEEDAVRG Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará.",
        "definir el parámetro FEEDAVRG con valor ꞏNoꞏ",
        "Calcular el promedio del avance."@es,
        "Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará."@es ;
    ns1:valor "Promedio de avance (configurable: Sí/No)",
        "Sí" .

ns1:Parametro_FEEDBACKTYPE a ns1:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ns1:identificador "V.[ch].MPA.FEEDBACKTYPE[set].xn" ;
    ns1:monitoreaParametro ns1:Sistema_RCS_S ;
    ns1:textoExtracto "tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE)",
        "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad."@es ;
    ns1:valor "FeeDat, EnDat",
        "TTL diferencial" .

ns1:Parametro_FEEDND a ns1:Parametro ;
    rdfs:label "FEEDND" ;
    ns1:documentadoEn ns1:Tabla_FeedOverride_217 ;
    ns1:identificador "(V.)[ch].MPG.FEEDND",
        "FEEDND" ;
    ns1:ilustradoEn ns1:InterfazUsuario_PanelMPG ;
    ns1:textoExtracto "FEEDND Aplicar el avance programado a todos los ejes del canal. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FEEDND Este parámetro indica si el avance programado se aplica a todos los ejes del canal o sólo a los ejes principales.",
        "Parámetro que determina si el avance programado considera todos los ejes o solo los principales."@es ;
    ns1:valor "No" .

ns1:Parametro_FFORMAT a ns1:Parametro ;
    rdfs:label "Formato de visualización de F programada (FFORMAT)" ;
    ns1:textoExtracto "Formato de visualización de la F programada. Valor por defecto: 5.2. Este parámetro establece el formato numérico (enteros y decimales) para visualizar el avance." ;
    ns1:valor "5.2" .

ns1:Parametro_FFWTYPE a ns1:Parametro ;
    rdfs:label "FFWTYPE",
        "FFWTYPE (Tipo de pre-control)",
        "Parámetro FFWTYPE" ;
    ns1:identificador "FFWTYPE" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro [MANFFGAIN] cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos.",
        "FFWTYPE Tipo de pre-control. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: OFF / Feed Forward / AC-Forward / Feed Forward + AC-Forward. Valor por defecto: OFF Variable asociada: (V.)[ch].MPA.FFWTYPE[set].xn",
        "parámetro FFWTYPE si regulador analógico o simulado" ;
    ns1:valor "OFF" .

ns1:Parametro_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "FLWEMONITOR",
        "Parámetro de seguimiento MPA.MINFLWE"@es ;
    ns1:identificador "FLWEMONITOR",
        "V.[ch].MPA.MINFLWE[set].xn" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento ;
    ns1:solucionaFallo ns1:ErrorSeguimiento ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta el parámetro ESTDELAY con FLWEMONITOR=Lineal.",
        "FLWEMONITOR Tipo de monitorización del error de seguimiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: OFF / Standard / Lineal. Valor por defecto: Standard.",
        "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn. El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR"@es ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grados",
        "Lineal",
        "Standard" .

ns1:Parametro_FOLLOW_WAITINLIMIT a ns1:Parametro ;
    rdfs:label "#FOLLOW[WAITINLIMIT]" ;
    ns1:identificador "#FOLLOW[WAITINLIMIT]" ;
    ns1:textoExtracto "#FOLLOW[WAITINLIMIT]" .

