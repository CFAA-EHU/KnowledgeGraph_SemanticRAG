ns1:Tabla_ParametrosDRV_Sercos a ns1:Tabla ;
    rdfs:label "Tabla de parámetros DRV para regulador Sercos"@es ;
    ns1:textoExtracto """\r
    | Campo. | Significado. |\r
    | --- | --- |\r
    | MNEMONIC | Mnemónico asignado a la variable DRV. [...] Consultar el manual del regulador.\r
    | AXIS | Nombre del eje o cabezal al que accede la variable; si se define como "*", todos los ejes y cabezales.\r
    | ID | Identificador ID Sercos de la variable a consultar en el regulador.\r
    | TYPE | Tipo de acceso, síncrono o asíncrono. [...] No todas las variables se pueden definir con acceso síncrono.\r
    | MODE | Modo de acceso. El acceso a las variables podrá ser solo lectura o de lectura y escritura.\r
    """@es .

ns1:Tabla_ParametrosDesplazamientoManual a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de desplazamiento en modo manual"@es ;
    ns1:textoExtracto """\r
| Parámetro. | Desplazamiento. |\r
| --- | --- |\r
| INCJOGDIST1 | 0.0010 mm o grados / 0.00003937 inch. |\r
| INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch. |\r
| INCJOGDIST3 | 0.1000 mm o grados / 0.00393700 inch. |\r
| INCJOGDIST4 | 1.0000 mm o grados / 0.03937007 inch. |\r
| INCJOGDIST5 | 10.000 mm o grados / 0.39370078 inch. |\r
""" .

ns1:Tabla_ParametrosGap a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de control del gap",
        "Tabla de parámetros de configuración del gap"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_GAPCOLLISIONMODE,
        ns1:Parametro_GAPTOL,
        ns1:Parametro_GAPTOLCANCEL,
        ns1:Parametro_GAPTONEG ;
    ns1:documentadoEn ns1:Manual_Operacion ;
    ns1:ilustradoEn ns1:Pagina_698 ;
    ns1:textoExtracto "Tabla con valores y significados de GAPTOL, GAPTOLCANCEL, GAPCOLLISIONMODE y GAPTONEG en el control del gap.",
        "Configurar los límites del gap. | Parámetro. | Significado. | [...] Configurar la respuesta del CNC al sobrepasar los límites del gap."@es .

ns1:Tabla_ParametrosHSC_1153 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (pág. 621-622)"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionHSC ;
    ns1:textoExtracto """\r
| Parámetro. |  | Significado. |\r
| FASTFILTFREQ MPG |  | Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST...\r
| FREQRES MPG |  | Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna...\r
| SOFTFREQ MPG |  | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal...\r
| HSCROUND MPG |  | Valor por defecto del error máximo de la trayectoria en HSC...\r
| SURFFILFREQ MPG |  | Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE..."""@es .

ns1:Tabla_ParametrosLatcheo_4_4_10 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de latcheo (Sección 4.4.10)"@es ;
    ns1:textoExtracto """\r
| Parámetro. | Significado. |\r
| --- | --- |\r
| axis | Nombre del eje objeto del latcheo. |\r
| probe | Número de palpador a utilizar como evento para el latcheo. |\r
| wintype | Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana). |\r
| winminpos | Límite inferior para la ventana del latch. |\r
| winmaxpos | Límite superior para la ventana del latch. |\r
"""@es .

ns1:Tabla_ParametrosLeapfrog a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de leapfrog" ;
    ns1:documentadoEn ns1:Leapfrog ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | SLOPETYPE | Tipo de aceleración por defecto; lineal, trapezoidal y seno cuadrado (square sine). | ACCEL/DECEL | Aceleración y deceleración. [...] | ACCJERK/DECJERK | Jerk de aceleración y deceleración. [...] |" .

ns1:Tabla_ParametrosSincronizacion_4_4_9 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de sincronización (4.4.9)"@es ;
    ns1:documentadoEn ns1:Pagina_382_383 ;
    ns1:textoExtracto """\r
| Parámetro. | Significado. |\r
| --- | --- |\r
| master | Nombre del eje maestro. |\r
| slave | Nombre del eje esclavo. |\r
| Nnratio | Opcional. Numerador del ratio de transmisión. Rotaciones del eje esclavo. |\r
| Ddratio | Opcional. Denominador del ratio de transmisión. Rotaciones del eje maestro. |\r
| synctype | Tipo de sincronización. Se programa mediante los parámetros "POS" (sincronización en posición) o "VEL" (sincronización en velocidad)."""@es .

ns1:Tabla_Se_alesPLC_VOLCOMP a ns1:Tabla ;
