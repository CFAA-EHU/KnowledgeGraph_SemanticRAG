    ns1:textoExtracto "El CNC respeta el avance por diente mínimo [...] fijado para la herramienta en la sentencia #DMCON (comandos FZMIN, FZMAX)"@es .

ns1:Parametro_FactorConversion_RIOR a ns1:Parametro ;
    rdfs:label "Factor de conversión (módulo RIOR)" ;
    ns1:textoExtracto "Factor = 200 / 32767 = 0,0061035 (para devolver el valor en decimiliamperios)" ;
    ns1:valor "0.0061035" .

ns1:Parametro_FiltroMPA_SHARE a ns1:Parametro ;
    rdfs:label "Parámetro MPA.SHARE[nb].xn"@es ;
    ns1:identificador "MPA.SHARE[nb].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SHARE[nb].xn Parámetro incluido en la tabla FILTER. Este parámetro indica el porcentaje de señal que pasa a través del filtro."@es ;
    ns1:valor "SHARE=100(Ar-Ao)/Ar" .

ns1:Parametro_FormatoBCD a ns1:Parametro ;
    rdfs:label "Formato BCD (código 1)"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Los códigos de origen y destino indican el formato (binario o BCD) en que se encuentra y se desea dejar la información."@es ;
