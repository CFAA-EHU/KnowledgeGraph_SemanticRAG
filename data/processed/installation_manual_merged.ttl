        ns1:RemoteGroup_1,
        ns1:RemoteGroup_2,
        ns1:RemoteGroup_3 ;
    ns1:identificador "Numeración según el orden de los grupos remotos" ;
    ns1:textoExtracto "Esquema de 'Numeración según el orden de los grupos remotos': tres bloques 'Remote Group (1–3)' con módulos encestados bajo un 'POWER SUPPLY'; flechas negras indican el orden de numeración (arriba-abajo, izquierda-derecha). Bajo cada grupo se anotan rangos resultantes de O e I (p. ej., O1…O32, I1…I48)." .

ns1:Esquema_NumeracionParametrosMaquina a ns1:Esquema ;
    rdfs:label "Esquema de numeración mediante parámetros máquina"@es ;
    ns1:identificador "Numeración mediante parámetros máquina"@es ;
    ns1:textoExtracto "dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos. El diagrama enfatiza asignación por índices múltiplos de 16+1 y cómo se distribuyen las entradas/salidas a partir de dichos índices."@es .

ns1:Esquema_PlanoTrabajoXC a ns1:Esquema ;
    rdfs:label "Render 3D del plano de trabajo XC con eje C activado"@es ;
    ns1:ilustradoEn ns1:Pagina_160 ;
    ns1:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo). El gráfico contextualiza el mecanizado con eje C, destacando la orientación de la herramienta respecto al plato y el sistema de coordenadas."@es .

ns1:Esquema_PosicionesEjeA a ns1:Esquema ;
    rdfs:label "Esquema de posiciones del eje A (A=−90°, B=−90° y A=+90°, B=−90°)"@es ;
    ns1:identificador "EjeA_Posiciones" ;
    ns1:textoExtracto "Esquema de dos posiciones con centro común del eje A (A=−90°, B=−90° y A=+90°, B=−90°)."@es .

ns1:Esquema_RTCP_Comparativo a ns1:Esquema ;
    rdfs:label "Esquema comparativo RTCP ON/OFF (pieza girada B-30°)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA51 ;
    ns1:ilustradoEn ns1:Manual_OpenPCS_SeccionParametrosMaquina ;
    ns1:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1. Se representan X', Z' y la posición de la herramienta, indicando si el sistema pieza gira con la mesa (RTCP completo) o mantiene paralelismo con coordenadas máquina."@es .

ns1:Esquema_ReglaManoDerecha a ns1:Esquema ;
    rdfs:label "Regla de la mano derecha (DIN 66217)",
        "Regla de la mano derecha para ejes rotativos" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA18,
        ns1:Parametro_TDATA19,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 ;
    ns1:ilustradoEn ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA11 ;
    ns1:textoExtracto "Dibujo de 'regla de la mano derecha' con ejes X, Y, Z y un croquis de giro alrededor del eje lineal positivo indicado por el pulgar. Ilustra el criterio de signo para TDATA10/TDATA11 en ejes rotativos.",
        "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." .

ns1:Esquema_RotacionRegistros_RL1_RR1 a ns1:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 1 (RL1/RR1)" ;
    ns1:identificador "4.4.5_Rotación_Tipo1_RL1_RR1" ;
    ns1:textoExtracto "flechas muestran el desplazamiento de bits y la entrada/salida de '0' por el extremo opuesto, indicando la pérdida del bit expulsado. Se visualiza la dirección de giro y la estructura de 32 bits del registro." .

ns1:Esquema_RotacionRegistros_RL2_RR2 a ns1:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 2 (RL2/RR2)" ;
    ns1:identificador "4.4.5_Rotación_Tipo2_RL2_RR2" ;
    ns1:textoExtracto "rotación circular donde el bit desplazado reingresa por el extremo contrario, preservando el conjunto de 32 bits. Se ilustran, con flechas, los ciclos de rotación y la conservación de información." .

ns1:Esquema_SecuenciaPaso1 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 1) - Secuencia de muestreo en eje X"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_MallaVolumetrica_3D ;
    ns1:textoExtracto "Esquema 3D (Paso 1) de un volumen con un plano basal y puntos en X a partir del origen X(P1), Y(P1), Z(P1). Flechas indican la progresión de muestreo a lo largo del eje X conforme a NPOINTSAX1 y el incremento INCREAX1, con la cota inicial marcada en cada eje."@es .

ns1:Esquema_SecuenciaPaso2 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 2) - Secuencia de muestreo en plano XY"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_MallaVolumetrica_3D ;
    ns1:textoExtracto "Esquema 3D (Paso 2) que prolonga la secuencia anterior: para cada posición fija en Y(P1), se completan todos los puntos de X; después se pasa a Y(P2)… hasta NPOINTSAX2. Las flechas negras muestran la dirección de barrido y la rejilla del plano XY ayuda a visualizar la densidad de puntos."@es .

ns1:Esquema_SentidoGiroUnico a ns1:Esquema ;
    rdfs:label "Esquema de sentido de giro único (UNIDIR = Positivo)"@es ;
    ns1:documentadoEn ns1:Seccion_2.5.8_ConfiguracionEjesRotativos ;
    ns1:ilustradoEn ns1:Pagina_158 ;
    ns1:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario, enfatizando que en G90 el eje siempre toma el sentido predeterminado."@es .

ns1:Esquema_TDATA2 a ns1:Esquema ;
    rdfs:label "Diagramas para cálculo de TDATA2"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA5 ;
    ns1:ilustradoEn ns1:Parametro_TDATA2 ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3). Se representan los palpados, las lecturas ΔX y la combinación con TDATA5 para calcular TDATA2, con flechas de giro y ejes X-Z."@es .

ns1:Esquema_TDATA6_1y2 a ns1:Esquema ;
    rdfs:label "Secuencia 'Primer y segundo contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2). Se muestran lecturas Xa y la preselección para centrar X=0 en el eje del cilindro. Flechas indican los giros del eje B y los desplazamientos en X."@es .

ns1:Esquema_TDATA6_3y4 a ns1:Esquema ;
    rdfs:label "Secuencia 'Tercer y cuarto contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "Secuencia 'Tercer y cuarto contacto': desde X=+R con B=0°, C=0° (punto 3) a B=+90° (punto 4). Se representa la lectura Xb y la simetría del procedimiento respecto a la secuencia anterior."@es .

ns1:Esquema_TDATA_TYPE1_5 a ns1:Esquema ;
    rdfs:label "Planchas de cotas TDATA para cabezales TYPE=1–5"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA ;
    ns1:ilustradoEn ns1:Pagina_258 ;
    ns1:textoExtracto "Planchas con cinco viñetas (TYPE=1…5) que dibujan la cabeza y ejes con cotas TDATA1…TDATA7. Flechas y signos (+/−) identifican distancias desde la nariz del husillo al eje secundario, separaciones X/Y/Z entre centros de giro y el ángulo entre ejes rotativos."@es .

ns1:Esquema_TDATA_TYPE6_8 a ns1:Esquema ;
    rdfs:label "Viñetas de cotas TDATA para cabezales angulares TYPE=6–8"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA ;
    ns1:ilustradoEn ns1:Pagina_258 ;
    ns1:textoExtracto "Tres viñetas (TYPE=6…8) con la misma gramática gráfica de cotas y signos para cabezales angulares YZ/ZX/ZY."@es .

ns1:Esquema_TiposCabezal_ABC a ns1:Esquema ;
    rdfs:label "Tríptico comparativo de cabezales esférico/ortogonal/angular (A-B-C)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA ;
    ns1:ilustradoEn ns1:Pagina_257 ;
    ns1:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z. Incluye letras A/B/C y ángulo α para orientar distancias TDATA."@es .

ns1:Esquema_TransferenciaBits_MOV a ns1:Esquema ;
    rdfs:label "Esquema de transferencia de bits en =MOV con conversión Bin↔BCD" ;
    ns1:identificador "4.4.4_Instrucciones_Aritméticas_MOV" ;
    ns1:textoExtracto "se representan bloques INPUT/OUTPUT con bits indexados (S1…S8/…S16) y su mapeo hacia salidas, indicando anchuras (4, 8, …, 32 bits) y códigos de origen/destino. La gráfica ilustra la conversión y el direccionamiento de grupos de bits." .

ns1:Esquema_TripticoG00FEED a ns1:Esquema ;
    rdfs:label "Tríptico de aceleración trapezoidal para G00FEED" ;
    ns1:detalladoEnEsquema ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_G00FEED ;
    ns1:textoExtracto "tríptico de aceleración trapezoidal para alcanzar G00FEED en tiempo t: gráficos v(t), a(t) y j(t) con indicaciones t/2 o t/3. Se comparan dos parametrizaciones: (i) ACCEL máxima y ACCJERK mínimo; (ii) ACCEL menor y ACCJERK mayor, que acorta el tiempo hasta aceleración máxima y mantiene más tiempo la meseta." .

ns1:EstadoC_Contador a ns1:Parametro ;
    rdfs:label "Marca de estado C (cuenta cero)" ;
    ns1:monitoreaParametro ns1:ContadorPLC ;
    ns1:textoExtracto "la marca de estado C que vale 1 cuando la cuenta es cero" .

ns1:EstadoInactivo a ns1:Parametro ;
    rdfs:label "No hay que hacer nada"@es ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 => No hay que hacer nada"@es .

ns1:EstructuraModularPLC_Seccion3_2 a ns1:Sistema ;
    rdfs:label "Estructura modular del programa de PLC (Sección 3.2)"@es ;
    ns1:compuestoPor ns1:ModuloEjecucionPeriodica_PE,
        ns1:ModuloPrimerCiclo_CY1,
        ns1:ModuloPrincipal_PRG ;
    ns1:textoExtracto "El programa PLC puede estar formado por los siguientes módulos. Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE) y finalizar con la proposición directiva END."@es .

ns1:Etiqueta_L12 a ns1:Parametro ;
    rdfs:label "Etiqueta L12"@es ;
    ns1:identificador "L12" ;
    ns1:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios."@es .

ns1:Etiqueta_L123 a ns1:Parametro ;
    rdfs:label "Etiqueta L123"@es ;
    ns1:identificador "L123" ;
    ns1:textoExtracto "= JMP L123 Si la etiqueta se definió como L123."@es .

ns1:Etiqueta_L_ASA2 a ns1:Parametro ;
    rdfs:label "Etiqueta L_ASA2"@es ;
    ns1:identificador "L_ASA2" ;
    ns1:textoExtracto "= JMP L_ASA2 Si la etiqueta se definió como L_ASA2."@es .

ns1:ExploradorUtilidades a ns1:InterfazUsuario ;
    rdfs:label "Explorador del modo utilidades" ;
    ns1:textoExtracto "La gestión de ficheros de flash, pendrives, ethernet, etc se hará exclusivamente desde el explorador del modo utilidades." .

ns1:ExportarArchivoRutado_1376 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de rutado"@es ;
    ns1:identificador "Exports router file"@en ;
    ns1:textoExtracto "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ns1:ExportarConfiguracion_1362 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de configuración (ETG Standard)"@es ;
    ns1:ejecutadoPor ns1:Personal_1362 ;
    ns1:requiereMantenimiento ns1:InterfazUsuario_1362 ;
    ns1:textoExtracto "Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Export\" y \"Export Master Configuration ETG Standard\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ns1:FBACKAL a ns1:Parametro ;
    rdfs:label "FBACKAL" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "Activación de la alarma de captación. La alarma de captación debe estar activada."@es .

ns1:FCAS a ns1:Parametro ;
    rdfs:label "FCAS (control de colisiones)" ;
    ns1:monitoreaParametro ns1:SistemaControlColisiones ;
    ns1:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ns1:FEDYNFAC a ns1:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto "Para una monitorización \"lineal\" del error de seguimiento, este parámetro indica el error porcentual permitido, desviación del error de seguimiento real respecto al teórico."@es .

ns1:FEDYNFAC_Parametro a ns1:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ns1:textoExtracto "límites proporcionales a F (pendiente ±%FEDYNFAC)"@es ;
    ns1:valor "FEDYNFAC" .

ns1:FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "El feed forward se define con el parámetro FFGAIN y se puede modificar desde el PLC mediante variables." .

ns1:FFWTYPE a ns1:Parametro ;
    rdfs:label "FFWTYPE" ;
    ns1:identificador "FFWTYPE" ;
    ns1:textoExtracto "El CNC no permite modificar el override del cabezal durante un roscado si detecta que en alguna gama de los ejes implicados no está activo el feed forward (parámetro FFWTYPE) o si el feed forward activo es inferior al 90%." .

ns1:FLIMITACCHC1 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC1 (Límite de seguridad para avance, canal 1)" ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" .

ns1:FLIMITACCHC2 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC2 (Límite de seguridad para avance, canal 2)" ;
    ns1:identificador "FLIMITACCHC2" ;
    ns1:textoExtracto "FLIMITACCHC2" .

ns1:FLIMITACCHC3 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC3 (Límite de seguridad para avance, canal 3)" ;
    ns1:identificador "FLIMITACCHC3" ;
    ns1:textoExtracto "FLIMITACCHC3" .

ns1:FLIMITACCHC4 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC4 (Límite de seguridad para avance, canal 4)" ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4" .

ns1:FLWEMONITOR a ns1:Parametro ;
    rdfs:label "FLWEMONITOR" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "Tipo de monitorización del error de seguimiento. La monitorización debe estar activada."@es .

ns1:FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM (parámetro máquina para mecanizado HSC)" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC. En versiones previas el parámetro FTIMELIM se programaba en milisegundos. A partir de este versión, este parámetro se define en porcentaje." ;
    ns1:valor "porcentaje" .

ns1:FagorEtherCATMapper a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:identificador "fagorethercatmapper-x.x.x.exe" ;
    ns1:textoExtracto "Aunque \"Fagor EtherCAT Mapper\" se puede ejecutar en el propio CNC, se recomienda la instalación en un PC externo, junto al configurador."@es .

ns1:FaseAprendizajeDMC a ns1:ModoOperacion ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ns1:identificador "G.LEARNEDPWRSP" ;
    ns1:textoExtracto "La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio. Si la herramienta sale de la pieza, deja de contar el tiempo hasta que la herramienta vuelva a entrar en la pieza." ;
    ns1:valor "potencia objetivo obtenida en la fase de aprendizaje" .

ns1:FaseAprendizaje_DMC a ns1:ModoOperacion ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ns1:habilitadoPor ns1:Comando_DMC_ON_Default,
        ns1:Comando_DMC_ON_Programado_Parcial ;
    ns1:textoExtracto "(El DMC inicia la fase de aprendizaje para calcular la potencia objetivo).",
        "Cada vez que se programa #DMCON sin potencia objetivo (comando PWRSP), el DMC la determina mediante una fase de aprendizaje que éste pondrá en marcha automáticamente. [...] La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio." .

ns1:FicheroConfiguracionExpert a ns1:InterfazUsuario ;
    ns1:identificador "..\\LantekInside\\Expert\\Expert.exe.config" ;
    ns1:textoExtracto "Editar el fichero ..\\LantekInside\\Expert\\Expert.exe.config con un editor de texto." ;
    ns1:tieneComponente ns1:ParametroLanguage,
        ns1:ParametroLocalLanguage .

ns1:FicheroENI_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ns1:documentadoEn ns1:ConfiguradorTopologiaKPA_EtherCAT_Studio ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "El configurador de la topología genera el fichero ENI que contiene la información de los dispositivos EtherCAT conectados al CNC. Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"fagor_ethercatConfFile.xml\"." .

ns1:Figura_AlmacenAsincrono_BrazoCambiador a ns1:Figura ;
    rdfs:label "Ilustración de almacén asíncrono tipo cadena con brazo cambiador"@es ;
    ns1:ilustradoEn ns1:Pagina_541 ;
    ns1:textoExtracto "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal. Se observa la cinta portaherramientas serpenteante y el brazo operando en paralelo al mecanizado. El elemento visual comunica la independencia de movimientos y la posibilidad de activar la marca de continuación (TCHANGEOK) tras el intercambio en el husillo."@es .

ns1:Figura_AlmacenHerramientasAsincrono a ns1:Figura ;
    rdfs:label "Ilustración de almacén asíncrono con brazo cambiador"@es ;
    ns1:ilustradoEn ns1:Pagina_472 ;
    ns1:textoExtracto "Ilustración de un almacén asíncrono con brazo cambiador: cadena tipo 'crawler' o almacén lineal alejado del cabezal y un brazo de doble pinza desplazándose de forma independiente. La escena muestra el movimiento del brazo mientras la cadena transporta portaherramientas, optimizando tiempos al poder moverse durante el mecanizado."@es .

ns1:Figura_AlmacenHerramientasConBrazoSimple a ns1:Figura ;
    rdfs:label "Ilustración de almacén síncrono con brazo cambiador (1–2 pinzas)"@es ;
    ns1:ilustradoEn ns1:Pagina_469 ;
    ns1:textoExtracto "Ilustración de un almacén síncrono con brazo cambiador (1–2 pinzas): se aprecia un disco portaherramientas cercano al cabezal y un brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo. Se sugiere la secuencia de toma y depósito, con el brazo actuando solo cuando no hay mecanizado."@es .

ns1:Figura_AlmacenHerramientasSinBrazo a ns1:Figura ;
    rdfs:label "Ilustración de almacén síncrono sin brazo cambiador"@es ;
    ns1:ilustradoEn ns1:Pagina_469 ;
    ns1:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal; el carrusel se posiciona frente al husillo para realizar el intercambio directamente, sin intervención de brazo. La imagen resalta el plato portaherramientas circular y la proximidad al cabezal."@es .

ns1:Figura_BandaErrorSeguimiento a ns1:Figura ;
    rdfs:label "Banda de error de seguimiento (zona sombreada)"@es ;
    ns1:ilustradoEn ns1:Sistema_CNC ;
    ns1:textoExtracto "Si no está dentro de la banda permitida (zona sombreada en la figura) se muestra el error correspondiente."@es .

ns1:Figura_CinematicasCabezalMesa_Intro a ns1:Figura ;
    rdfs:label "Iconos introductorios de cinemáticas cabezal-mesa"@es ;
    ns1:ilustradoEn ns1:Sistema_CinematicoCabezalMesa ;
    ns1:textoExtracto "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa."@es .

ns1:Figura_ComparativaTecladosCNC a ns1:Figura ;
    rdfs:label "Galería comparativa de teclados CNC por distribución de idioma"@es ;
    ns1:documentadoEn ns1:Seccion_8_1_ConfiguracionTeclado ;
    ns1:ilustradoEn ns1:Pagina_541 ;
    ns1:textoExtracto "Galería comparativa de cuatro teclados CNC según distribución: tres variantes rotuladas 'Español (España)' y una 'Inglés (Estados Unidos)'. Las vistas muestran la disposición física de teclas, presencia de teclas de función específicas del CNC y agrupación por bloques (alfanumérico, cursores, funciones), útil para asociar los 'scan codes' a su posición y entender las diferencias por idioma/distribución."@es .

ns1:Figura_ConfiguracionEjesPlanoTorno a ns1:Figura ;
    rdfs:label "Configuración de ejes tipo plano (torno)"@es ;
    ns1:detalladoEnEsquema ns1:SistemaEjesTorno ;
    ns1:ilustradoEn ns1:Pagina_114 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo plano (torno)': máquina con dos ejes principales (Z+ y X+) representados; el plano de trabajo habitual es G18 (ZX). La vista ayuda a interpretar qué ejes forman abscisas/ordenadas y cómo afecta al mecanizado y a la definición del eje longitudinal."@es .

ns1:Figura_ConfiguracionEjesTriedroFresadora a ns1:Figura ;
    rdfs:label "Configuración de ejes tipo triedro"@es ;
    ns1:detalladoEnEsquema ns1:SistemaEjesFresadora ;
    ns1:ilustradoEn ns1:Pagina_114 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo triedro': máquina con tres ejes (X+, Y+, Z+), propia de fresadora. Sirve para visualizar el triedro cartesiano y los planos G17/G18/G19 según el orden de ejes del canal, base para programar trayectorias en 3D."@es .

ns1:Figura_DiagramaTG2_TEN a ns1:Figura ;
    rdfs:label "Diagrama del efecto de TEN en TG2"@es ;
    ns1:ilustradoEn ns1:Parametro_TEN_TG2,
        ns1:Parametro_TG2,
        ns1:Parametro_T_TG2,
        ns1:Parametro_t_TG2 ;
    ns1:textoExtracto "Diagrama del efecto de TEN en TG2: con el retardo en marcha, poner TEN=0 pausa la rampa de t; al devolver TEN=1, la temporización se reanuda. Se muestran, en secuencia, los estados de TG2, TEN, t y T."@es .

ns1:Figura_DiagramaTG3_Desconexion a ns1:Figura ;
    rdfs:label "Diagrama del retardo a la desconexión (TG3)"@es ;
    ns1:ilustradoEn ns1:Parametro_TG3,
        ns1:Parametro_T_TG3,
        ns1:Parametro_t_TG3 ;
    ns1:textoExtracto "Diagrama del retardo a la desconexión: tras un flanco de subida en TG3, T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0."@es .

ns1:Figura_DiagramaTG3_TEN a ns1:Figura ;
    rdfs:label "Diagrama del efecto de TEN en TG3"@es ;
    ns1:ilustradoEn ns1:Parametro_TEN_TG3,
        ns1:Parametro_TG3,
        ns1:Parametro_T_TG3,
        ns1:Parametro_t_TG3 ;
    ns1:textoExtracto "Diagrama del efecto de TEN en TG3: con el retardo activo, TEN=0 pausa t; al restituir TEN=1, la cuenta continúa hasta completar la constante de tiempo, tras lo cual T se desactiva."@es .

ns1:Figura_DiagramaTG3_TRS a ns1:Figura ;
    rdfs:label "Diagrama del efecto de TRS en TG3"@es ;
    ns1:ilustradoEn ns1:Parametro_TG3,
        ns1:Parametro_TRS_TG3,
        ns1:Parametro_T_TG3,
        ns1:Parametro_t_TG3 ;
    ns1:textoExtracto "Diagrama del efecto de TRS en TG3: un flanco de subida en TRS inicializa el temporizador (T=0, t=0) y exige una nueva activación por TG3 para reiniciar la secuencia. Se muestran claramente las relaciones entre TG3, TRS, t y T."@es .

ns1:Figura_DimensionesCabezalAngular a ns1:Figura ;
    rdfs:label "Figura de dimensiones del cabezal angular TYPE=6" ;
    ns1:ilustradoEn ns1:CabezalAngular_TYPE6 ;
    ns1:textoExtracto "El signo (+) en las figuras indica el sentido que se asume como positivo." .

ns1:Figura_EfectoPrecarga a ns1:Figura ;
    rdfs:label "Efecto de la precarga en diferentes situaciones" ;
    ns1:ilustradoEn ns1:Esquema_Precarga_Aceleracion,
        ns1:Esquema_Precarga_Deceleracion,
        ns1:Esquema_Precarga_Reposo,
        ns1:Esquema_Precarga_VelocidadConstante_1,
        ns1:Esquema_Precarga_VelocidadConstante_2 ;
    ns1:textoExtracto "Los siguientes diagramas muestran el efecto de la precarga en diferentes situaciones." .

ns1:Figura_FollowingError_PROGAIN a ns1:Figura ;
    rdfs:label "Gráfico de 'Actual Feed' y 'Following Error' para ajuste de PROGAIN"@es ;
    ns1:ilustradoEn ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "gráfico con fondo cuadriculado que muestra 'Actual Feed' (avance real) y 'Following Error (E)' (error de seguimiento) durante una maniobra de aceleración y parada. [...] útil para visualizar el ajuste de la ganancia proporcional (PROGAIN)."@es .

ns1:Figura_HisteresisREVEHYST a ns1:Figura ;
    rdfs:label "Diagrama temporal de histéresis REVEHYST"@es ;
    ns1:ilustradoEn ns1:Parametro_REVEHYST ;
    ns1:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. [...] La curva de posición incluye pequeñas oscilaciones; sobre ella se superponen tramos sombreados etiquetados REVEHYST a ambos lados del cero, indicando la banda de histéresis que debe superarse para aplicar/cancelar el impulso adicional de consigna."@es .

ns1:Figura_Keybdx_761_762 a ns1:Figura ;
