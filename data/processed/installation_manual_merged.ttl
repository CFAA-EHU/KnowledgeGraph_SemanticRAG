ns1:Variable_PARLIMC_13_3_4 a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.PARLIMC" ;
    ns1:identificador "V.[ch].G.PARLIMC" ;
    ns1:monitoreaParametro ns1:SistemaControlCNC_13_3_4 ;
    ns1:textoExtracto """\r
    Causa que limita el avance en la esquina, en el bloque en ejecución. La variable devuelve uno de los siguientes valores.\r
    [1] El avance máximo del eje.\r
    [4] La aceleración en la esquina (parámetro CORNERACC).\r
    [5] El jerk en la esquina (parámetro CORNERJERK).\r
    [8] El error cordal en la esquina (modo CONTERROR).\r
    [9] Geometría de la esquina (modo FAST).\r
    """ .

