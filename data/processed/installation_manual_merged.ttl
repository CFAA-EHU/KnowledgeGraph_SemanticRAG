ns1:Parametro_PRELFITI a ns1:Parametro ;
    rdfs:label "MPG.PRELFITI[nb]",
        "PRELFITI",
        "PRELFITI (Tiempo de filtro de precarga)" ;
    ns1:documentadoEn ns1:Tabla_1070_VariablesTandem ;
    ns1:identificador "MPG.PRELFITI[nb]" ;
    ns1:textoExtracto "Para aplicar la precarga de una forma gradual [...] se puede definir el parámetro PRELFITI. Este parámetro habilita un filtro de primer orden que establece el tiempo que tarda el CNC en aplicar la precarga de forma progresiva.",
        "Tiempo del filtro para aplicar la precarga. Valores posibles: De 0 a 65535 milisegundos (con valor 0, se deshabilita el filtro). Valor por defecto: 0 ms. Variable asociada: (V.)MPG.PRELFITI[nb] [...] Filtro de primer orden que establece el tiempo que tarda el CNC en aplicar la precarga de forma progresiva.",
        "(V.)MPG.PRELFITI[nb] - Tándem [nb]. Tiempo para aplicar la precarga"@es ;
    ns1:valor "0 ms"^^xsd:string .

ns1:Parametro_PRELOAD a ns1:Parametro ;
    rdfs:label "MPG.PRELOAD[nb]",
        "PRELOAD",
        "PRELOAD (Precarga entre motores tándem)",
        "Precarga (PRELOAD)" ;
    ns1:documentadoEn ns1:Tabla_1070_VariablesTandem,
        ns1:Tabla_11.2.4_VariablesTandem ;
