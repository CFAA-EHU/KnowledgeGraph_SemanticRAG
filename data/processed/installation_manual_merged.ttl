    ns1:identificador "SLIMITACSPDL1" ;
    ns1:textoExtracto "SLIMITACSPDL1 (también se puede programar como SLIMITACSPDL)" .

ns1:SalidaAnalogica_Eje a ns1:ComponenteElectrico ;
    ns1:controla ns1:EjeAnalogico ;
    ns1:textoExtracto "La salida analógica se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración." .

ns1:Salida_T a ns1:ComponenteElectrico,
        ns1:InterfazUsuario ;
    rdfs:label "Salida T (estado del temporizador)"@es,
        "Salida de estado T (temporizador)"@es ;
    ns1:textoExtracto "salida T del temporizador [...] salida de estado del temporizador toma el valor T=1 [...] desactivándose la salida de estado del temporizador (T=0)"@es,
        "se activa la salida de estado del temporizador (T=1) manteniéndose en este estado hasta que se produzca un flanco de bajada en la entrada de arranque TG2."@es .

ns1:SalidasFisicas_ModulosRemotos a ns1:ComponenteElectrico ;
    rdfs:label "Salidas físicas (módulos remotos)" ;
    ns1:textoExtracto "El PLC asigna a las salidas físicas (módulos remotos) los valores que disponen en este momento los recursos O del PLC." .

ns1:Se_alENABLE_Eje a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE(axis)" ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "el CNC la pone a (=1) cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418." .

ns1:Se_alEmergenciaGestor a ns1:Sensor ;
    rdfs:label "Señal de emergencia del gestor"@es ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas."@es .

ns1:Se_al_DRENAV a ns1:Parametro ;
    rdfs:label "Señal DRENA (habilitación regulador eje V)" ;
    ns1:identificador "DRENAV" ;
    ns1:textoExtracto "En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA)." .

ns1:Se_al_PARKED a ns1:Parametro ;
    rdfs:label "Señal PARKED",
        "PARKED(axis)"@es ;
    ns1:identificador "PARKED" ;
    ns1:monitoreaParametro ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Desde al programa de PLC se pone la marca PARKED a (=1) para aparcar el eje correspondiente.",
        "Representa PARKED(axis) en el diagrama temporal, con iniciación por PARKED."@es ;
    ns1:valor "1" .

ns1:Se_al_SWITCH_axis a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "SWITCH(axis)" ;
    ns1:identificador "SWITCH(axis)" ;
    ns1:textoExtracto "El PLC activa esta marca para indicar al CNC cuál es el eje o cabezal que debe gobernar.",
        "SWITCH(axis) [...] permite conmutar entre los diferentes ejes o cabezales del grupo." .

ns1:Se_al_TANDEMOFF_axis a ns1:Parametro ;
    rdfs:label "TANDEMOFF(axis)" ;
    ns1:identificador "TANDEMOFF(axis)" ;
    ns1:textoExtracto "TANDEMOFF(axis) [...] permite desacoplar temporalmente en el lazo los ejes o cabezales implicados en el tándem." .

ns1:Se_al_TCHANGEOK a ns1:Parametro ;
    rdfs:label "Señal TCHANGEOK (confirmación de cambio)",
        "Señal TCHANGEOK (cambio de herramienta)"@es ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK",
        "El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06). TCHANGEOK Hay una marca para cada almacén."@es ;
    ns1:valor "1",
        "1 (activo)" .

ns1:Se_al_XFERINH a ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "Señal _XFERINH" ;
    ns1:identificador "_XFERINH" ;
    ns1:textoExtracto "Las señales _EMERGEN, _STOP, _FEEDHOL, _XFERINH y CYSTART deben estar definidas en el programa de PLC.",
        "marca general por canal (marca _XFERINH). El CNC evalúa ambas marcas de la siguiente manera: En los movimientos independientes programados desde el CNC, éste evalúa primero el transfer inhibit del canal (marca _XFERINH) y a continuación el particular del eje (marca _IXFERINH(axis))." .

ns1:SenalAUXEND a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "AUXEND",
        "Señal AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "AUXEND",
        "El cambio de gama se da por finalizado cuando el PLC recibe la confirmación de la señal AUXEND" ;
    ns1:valor "1" .

ns1:SenalENABLE a ns1:ComponenteElectrico,
        ns1:InterfazUsuario ;
    rdfs:label "ENABLE(axis)",
        "Señal ENABLE" ;
    ns1:habilitadoPor ns1:ModoLazoCerrado_G63,
        ns1:ModoLazoCerrado_G74,
        ns1:ModoLazoCerrado_M19,
        ns1:Sentencia_SERVO_ON ;
    ns1:identificador "ENABLE" ;
    ns1:monitoreaParametro ns1:ParametroSincronizacionActiva ;
    ns1:textoExtracto "Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales",
        "ENABLE(axis) [...] El CNC pone esta marca a (=1) para indicar al PLC que va a mover el eje o cabezal correspondiente en lazo cerrado [...] Esta marca también se habilita en los movimientos de eje independiente, en los movimientos de cabezal en lazo cerrado (por ejemplo M19 ó G74), o cuando un cabezal pasa a lazo cerrado mediante la sentencia #SERVO ON.",
        "se activa la señal ENABLE en los dos cabezales" ;
    ns1:tieneComponente ns1:SistemaSincronizacionCabezales .

ns1:SenalPARK a ns1:Parametro ;
    rdfs:label "Señal PARK"@es,
