ns1:Parametro_NDI a ns1:Parametro ;
    rdfs:label "NDI",
        "NDI (Número de entradas digitales del bloque lógico)"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen,
        ns1:Tabla_ParametrosCANopen_1265 ;
    ns1:identificador "MPG.DIMODNDI[nb]",
        "NDI" ;
    ns1:textoExtracto "NDI Número de entradas digitales del bloque lógico. Valores posibles: De 8 a 1024. Valor por defecto: 0. Variable asociada: (V.)MPG.DIMODNDI[nb] Número de entradas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)."@es,
        "Número de entradas digitales del módulo."@es,
        "Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0)."@es ;
    ns1:valor "8..1024 (múltiplo de 8)",
        "8-1024 (múltiplos de 8)"@es .

ns1:Parametro_NDIMOD a ns1:Parametro ;
    rdfs:label "NDIMOD",
        "NDIMOD"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1265,
        ns1:Tabla_ParametrosRIOR ;
    ns1:identificador "(V.)MPG.NDIMOD",
        "6",
        "MPG.NDIMOD",
        "NDIMOD" ;
    ns1:monitoreaParametro ns1:Nodo_RIOW_2 ;
    ns1:textoExtracto "NDIMOD Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDIMOD Este parámetro indica la cantidad de bloques lógicos en los que se dividen los módulos de entradas digitales conectados en el bus CANopen.",
        "NDIMOD Número total de módulos de entradas digitales. Valores posibles: De 0 a 64. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDIMOD Este parámetro indica la cantidad de módulos de entradas digitales conectados en el bus CAN.",
        "NDIMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico.",
        "NDIMOD | 5 | 2 bloques para el RIOW y 3 bloques para el RIO5.",
        "NDIMOD | 6 | En la serie RIO5, cada módulo se debe configurar como un bloque lógico. Cada módulo doble (módulo con dos placas) cuenta como dos bloques."@es,
        "Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0)."@es ;
    ns1:valor 0,
        6,
        "0-64",
        "0..42",
        "2",
        "5" .

