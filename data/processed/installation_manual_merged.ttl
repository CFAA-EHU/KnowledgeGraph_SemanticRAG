ns1:EsquemaTeclasJog a ns1:Esquema ;
    rdfs:label "Esquema de configuración de teclas JOG y USERKEYS" ;
    ns1:textoExtracto "Diagramas que muestran la disposición de 15 teclas numeradas y el bloque 'USERKEYS' en cuadrículas 3×5 o 4×4, con numeración 1–15 y recuadro para teclas de usuario. Incluye leyenda de valores aceptados para mapear teclas de usuario a funciones de jog (ejes 1…10 con signos ± y tecla R)." .

ns1:Esquema_17.1_TDATA6_PrimeraPalpacion a ns1:Esquema ;
    ns1:identificador "17.1 - TDATA6 (Primera palpación)" ;
    ns1:ilustradoEn ns1:Pagina_709 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R." .

ns1:Esquema_ConexionRIO5 a ns1:Esquema ;
    rdfs:label "Esquema de conexión RIO5 (páginas 682-685)"@es ;
    ns1:detalladoEnEsquema ns1:Modulo_ER_24I16O ;
    ns1:textoExtracto "POW X1 SP ADD 9AB 8 765 L C X2 X3 | ER 24I/16O CHS O+214V GND +24V X4 GON8D O+294V X5 EED10 GON16D 4 0 RESS CD 3 E 2F1 ERR I1 RUN X6 T 10 AN GLS ND SHH I 1 2 H I 1 3 GLS ND SHH H X7 I24"@es .

ns1:Esquema_EjesTorno_LONGAXIS_FACEAXIS_CAXIS a ns1:Esquema ;
    rdfs:label "Diagrama isométrico de ejes en máquina tipo torno (LONGAXIS, FACEAXIS, CAXIS)"@es ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)."@es .

ns1:Esquema_GapControlLoop a ns1:Esquema ;
    rdfs:label "Diagrama funcional del lazo de control del gap"@es ;
    ns1:detalladoEnEsquema ns1:Filtro_Cutoff,
        ns1:Param_GAP_PGAIN,
        ns1:Sensor_Gap ;
    ns1:ilustradoEn ns1:Filtro_Cutoff,
        ns1:Param_GAP_PGAIN ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: la realimentación del sensor (GAP SENSOR FEEDBACK) entra a un bucle de posición (POSITION LOOP) con ganancia proporcional de gap (GAP P-GAIN) y un filtro de corte (CUTOFF FILTER)."@es .

ns1:Esquema_LimitesPalpador_PRB a ns1:Esquema ;
    rdfs:label "Esquema de límites PRB1/PRB2/PRB3 del palpador"@es ;
    ns1:textoExtracto "Esquema de límites PRB1/PRB2/PRB3 (máximos y mínimos) del palpador sobre los tres primeros ejes del canal. Incluye un triedro X-Y-Z y vistas en planta con un bloque de referencia; flechas bidireccionales marcan cotas máximas y mínimas de cada eje, indicando que las posiciones se definen en coordenadas máquina (en torno, en radios)."@es .

ns1:Esquema_Temporizador_TEN a ns1:Esquema ;
    rdfs:label "Diagrama temporal de la entrada TEN (enable) del temporizador"@es ;
    ns1:identificador "Temporizador_TEN"@es ;
    ns1:textoExtracto "se representan, en paralelo y a lo largo del eje temporal, las señales TEN y TG1/TGx (flancos de activación), la rampa de conteo t (creciente desde 0) y el estado lógico T (alto mientras la temporización está activa). Se aprecian los flancos de subida/bajada que detienen (TEN=0) o reanudan (TEN=1) la cuenta y el mantenimiento del valor t al finalizar."@es .

ns1:Esquema_Temporizador_TRS a ns1:Esquema ;
    rdfs:label "Diagrama temporal de la entrada TRS (reset) del temporizador"@es ;
    ns1:identificador "Temporizador_TRS"@es ;
    ns1:textoExtracto "se muestran los flancos de subida de TRS que inicializan el temporizador (T→0 y t→0), así como la dependencia de la reactivación mediante la entrada de arranque. Las trazas incluyen TGx, TRS, la evolución de t (respuesta a 0) y el estado T que se fuerza a nivel bajo tras el reset."@es .

ns1:Figura_AlmacenCarruselSinBrazo a ns1:Figura ;
    rdfs:label "Ilustración de carrusel sin brazo cambiador"@es ;
    ns1:ilustradoEn ns1:Pagina_502 ;
    ns1:textoExtracto "Ilustración del carrusel próximo al cabezal sin brazo: el plato de herramientas se orienta y acerca al husillo para transferir la herramienta directamente."@es .

ns1:FragmentoCodigo_6_8_1 a ns1:InterfazUsuario ;
    rdfs:label "Ejemplo de código para tiempo de mecanizado (CY1 y PRG)"@es ;
    ns1:identificador "6.8.1" ;
    ns1:textoExtracto """\r
| Ejemplo de utilización para conocer el tiempo de mecanizado. |\r
| --- |\r
| CY1\r
()= MOV 0 R100\r
()= CNCWR (R100, PLC.TIMER, M11)\r
Inicializa el contador a 0 tras el encendido. END |\r
| PRG\r
AUTOMAT AND INCYCLE = TIMERON\r
Contador activo durante el mecanizado. ()= CNCRD (PLC.TIMER, R300, M12)\r
El registro R300 muestra el valor del contador. END\r
"""@es .

ns1:FuncionRetrace a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función RETRACE",
        "Función retrace" ;
    ns1:identificador "RETRACE" ;
    ns1:textoExtracto "La función retrace también finaliza tras ejecutar M30, con un reset y cuando el canal del CNC pone a (=1) la marca RETRAEND. La función retrace debe estar habilitada en el parámetro máquina RETRACAC.",
        "La función retrace también se cancela tras ejecutar M30, con un reset o cuando al PLC pone a (=0) la marca RETRACE del canal." .

ns1:Funcion_Cabezal1 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Funciones asignadas al Cabezal 1"@es ;
    ns1:textoExtracto """\r
Para poder conocer si un determinado cabezal ha recibido una determinada función, se pueden analizar todos los registros uno a uno o se pueden utilizar los siguientes comandos para analizar todos ellos a la vez.\r
"""@es .

ns1:GestorHerramientas a ns1:InterfazUsuario,
        ns1:Sistema ;
    rdfs:label "Gestor de herramientas"@es,
        "Gestor de herramientas (comunicación CNC-PLC)"@es,
        "Gestor de herramientas (interfaz CNC)"@es ;
    ns1:controla ns1:Almacen_Generico,
        ns1:PLC_ControlAlmacen,
        ns1:TablaAlmacenHerramientas ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén [...] El gestor envía una orden al PLC para efectuar el cambio."@es,
        "La comunicación entre el gestor y el PLC se realiza en 2 fases; [...] El gestor envía una orden al PLC para que seleccione la próxima herramienta [...] El gestor envía una orden al PLC para efectuar el cambio."@es,
        "Para la comunicación entre el gestor de herramientas y el PLC [...] el gestor esperará a que acabe el proceso en curso antes de atender la nueva solicitud."@es,
        "el gestor actualiza la tabla de almacén"@es .

ns1:Gestor_AlmacenSinBrazoCambiador a ns1:Sistema ;
