    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Número de puntos de la tabla."@es .

ns1:Parametro_d0b436d5c8 a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:identificador "V.[ch].MPA.MAXFEED[set].xn" ;
    ns1:textoExtracto "MAXFEED Máximo avance de mecanizado del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 500000.0000 mm/min. Valores posibles (2): De 0 a 19685.03937 inch/min. Valores posibles (3): De 0 a 500000.0000 grados/min. Valores posibles (4): De 0 a 1388.8889 rpm. Valor por defecto: 0. Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje; si se define con valor ꞏ0ꞏ, no se limita el" ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_d15f84e863 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC2" ;
    ns1:identificador "SBLOCKC2" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "SBLOCKC2. Si el PLC pone esta marca a (=1), el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–." .

ns1:Parametro_d1840fae63 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA16 = 1" ;
    ns1:documentadoEn ns1:TablaDeParametrosTDATA16ParaCinematicasDeMesaTipos912 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." ;
    ns1:valor "1" .

ns1:Parametro_d1ae534653 a ns1:Parametro ;
    rdfs:label "FREE",
        "PLCABORT" ;
    ns1:textoExtracto "Si se activa la marca PLCABORT sin estar lanzado un CNCEX, la marca permanece a (=1) hasta que se ejecute un CNCEX (el cual quedará abortado automáticamente) o hasta que se desactive (RES PLCABORT). FREE"@es ;
    ns1:valor "1" .

ns1:Parametro_d2850b748b a ns1:Parametro ;
    rdfs:label "_XFERINH" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _ XFERINHC1 (también se puede programar como _XFERINH) _XFERINHC2 _XFERINHC3 _XFERINHC4" .

