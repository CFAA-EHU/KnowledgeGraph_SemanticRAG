ns1:BusquedaDeReferenciaEnEjesSercos_d034cda1d6 a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia en ejes Sercos" ;
    ns1:requiereMantenimiento ns1:EjeSercosPosicion ;
    ns1:textoExtracto "Cuando los ejes son Sercos posición, en la homogeneización de parámetros el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma. REFFEED1 Velocidad rápida de búsqueda de referencia." .

ns1:BusquedaReferenciaEjesGantry a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia de ejes gantry" ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionEjesGantry ;
    ns1:textoExtracto "La búsqueda de referencia de los ejes gantry se puede realizar de las tres formas explicadas para el resto de ejes y cabezales." .

ns1:BusquedaReferenciaM_quina_1205 a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:ejecutadoPor ns1:ModoManual_1205 ;
    ns1:identificador "G74" ;
    ns1:requiereMantenimiento ns1:SistemaCNC_1205 ;
    ns1:textoExtracto "La búsqueda de referencia es la operación mediante la cual se realiza la sincronización del sistema. Esta operación es necesaria cuando el CNC pierde la posición del origen (por ejemplo, apagando la máquina)."@es .

ns1:BusquedaYCaptacionREFDIRECDECINPUTFBACKSRC a ns1:Parametro ;
    rdfs:label "Búsqueda y captación (REFDIREC, DECINPUT, FBACKSRC)" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP147 (bit 0,1,3,5)" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto """\r
REFDIREC (PP147 bit 0): B0=0; Sentido de búsqueda positivo. B0=1; Sentido de búsqueda negativo.\r
DECINPUT (PP147 bit 5): B5=0; Sí se dispone de micro. B5=1; No se dispone de micro.\r
FBACKSRC (PP147 bit 3/1): B3=0; Captación interna. B3=1; Captación externa. B1=0; La señal DECEL del CNC siempre es positiva.\r
""" .

ns1:CAMOFF a ns1:ModoOperacion ;
    rdfs:label "CAM OFF" ;
    ns1:documentadoEn ns1:ManualLevaElectronicaEspecifico ;
    ns1:identificador "CAM OFF" ;
    ns1:textoExtracto "cancelar la leva electrónica (CAM OFF). La ejecución del comando CAM OFF implica eliminar la sincronización de la leva. Una vez programado este comando, la leva termina cuando se alcanza el final de su perfil." .

ns1:CAMON a ns1:ModoOperacion ;
