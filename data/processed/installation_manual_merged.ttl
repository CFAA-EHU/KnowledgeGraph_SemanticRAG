ns1:Script_OpenPCS_1381 a ns1:Componente ;
    rdfs:label "Script de configuración OpenPCS"@es ;
    ns1:documentadoEn ns1:Sistema ;
    ns1:identificador "..\\Fagor\\Plc\\Openpcs" ;
    ns1:textoExtracto "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."@es .

ns1:Se_alCNC_MAXDIFF a ns1:ComponenteElectrico ;
    rdfs:label "MAXDIFF(axis)" ;
    ns1:identificador "MAXDIFF(axis)" ;
    ns1:textoExtracto "Esta marca se utiliza en los ejes gantry. El CNC activa (=1) esta marca cuando no puede corregir la diferencia de cota entre el eje maestro y esclavo, ya que la diferencia es superior a la indicada por el parámetro MAXDIFF(axis)." .

ns1:Se_alDRENAB a ns1:Parametro ;
    rdfs:label "Señal DRENAB",
        "Señal DRENAB (drenaje del eje B)" ;
    ns1:identificador "DRENAB" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB =",
        "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON" ;
    ns1:valor "DRENAB" .

ns1:Se_al_ACTFBACK a ns1:Parametro ;
    rdfs:label "Señal ACTFBACK" ;
    ns1:identificador "ACTFBACK(axis)" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna. El CNC pone esta marca a (=1) para indicar que se está trabajando con la captación externa (captación directa)." ;
