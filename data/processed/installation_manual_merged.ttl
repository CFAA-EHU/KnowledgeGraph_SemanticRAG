ns1:TDATA19 a ns1:Parametro ;
    rdfs:label "Ejes rotativos manuales o servocontrolados",
        "TDATA19" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado.",
        "TDATA19 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 7. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." ;
    ns1:valor "0" .

ns1:TDATA20 a ns1:Parametro ;
    rdfs:label "TDATA20" ;
    ns1:identificador "TDATA20" ;
    ns1:textoExtracto "TDATA20 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA10." ;
    ns1:valor "0" .

ns1:TDATA48 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario de la mesa" ;
    ns1:identificador "TDATA48" ;
    ns1:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:TDATA49 a ns1:Parametro ;
    rdfs:label "Eje rotativo secundario de la mesa manual o servocontrolado" ;
    ns1:identificador "TDATA49" ;
    ns1:textoExtracto "TDATA49 Eje rotativo secundario de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA49=1." ;
    ns1:valor "0" .

ns1:TDATA50 a ns1:Parametro ;
    rdfs:label "Origen para aplicar el RTCP" ;
    ns1:identificador "TDATA50" ;
    ns1:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza)." .

ns1:TDATA8 a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal",
        "TDATA8" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0.",
        "TDATA8 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Consultar el parámetro TDATA9." ;
    ns1:valor "0.0"^^xsd:float,
        "0" .

ns1:TDATA9 a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario",
        "TDATA9" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0.",
        "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado.",
        "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ns1:valor "0.0"^^xsd:float,
        "0" .

ns1:THREADOVR a ns1:Parametro ;
    rdfs:label "THREADOVR" ;
    ns1:identificador "THREADOVR" ;
    ns1:monitoreaParametro ns1:OverrideCabezal ;
    ns1:textoExtracto "THREADOVR Variación máxima permitida para el override durante el roscado. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se permite variar el override)." ;
    ns1:valor "0-100%" .

ns1:TMOPERATION_11 a ns1:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén y ponerla en el brazo (TMOPERATION=11)" ;
    ns1:controla ns1:Marca_MZTOCH1 ;
    ns1:ejecutadoPor ns1:Pinza1 ;
    ns1:identificador "11" ;
    ns1:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo. Esta operación es una optimización del cambio de herramienta que permite colocar una herramienta en la pinza ꞏ1ꞏ del brazo cambiador durante el mecanizado." .

ns1:TMOPERATION_12 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en almacén y coger otra del mismo almacén (TMOPERATION=12)" ;
    ns1:identificador "12" ;
    ns1:monitoreaParametro ns1:Parametro_LEAVEPOS,
        ns1:Parametro_TAKEPOS ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida cuando ambas herramientas son especiales y pueden colisionar en el brazo o no se desea que coincidan en el brazo cambiador." .

ns1:TMOPERATION_14 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en almacén y coger herramienta del brazo (TMOPERATION=14)" ;
    ns1:identificador "14" ;
    ns1:monitoreaParametro ns1:Parametro_LEAVEPOS,
        ns1:Parametro_MZID,
        ns1:Parametro_TAKEPOS ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son de almacenes diferentes." .

ns1:TTIME a ns1:Parametro ;
    rdfs:label "TTIME" ;
    ns1:identificador "TTIME" ;
    ns1:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa.",
        "TTIME Tiempo estimado para una función T. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ns1:valor 0 .

