ns1:Esquema_Cinematica_HeadTool a ns1:Esquema ;
    rdfs:label "Esquema comparativo de posición de referencia HEAD/TOOL"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA ;
    ns1:ilustradoEn ns1:Pagina_256 ;
    ns1:textoExtracto "Doble esquema de 'posición de referencia HEAD/TOOL' que compara 'Tool base/Auto tool base' frente a 'Head base'. Se marca la nariz del portaherramientas y vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación."@es .

ns1:Esquema_Cinematica_TYPE15_16 a ns1:Esquema ;
    rdfs:label "Esquema de parámetros cinemáticos para TYPE=15 y TYPE=16"@es ;
