        "0" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "Límite inferior de módulo (MODLOWLIM)",
        "Límite inferior del módulo (MODLOWLIM)",
        "MODLOWLIM" ;
    ns1:identificador "MODLOWLIM" ;
    ns1:monitoreaParametro ns1:Sistema_EjesRotativos ;
    ns1:textoExtracto "Los límites de módulo (límites de recorrido del eje rotativo) vienen fijados por los parámetros de gama MODUPLIM y MODLOWLIM.",
        "Los parámetros [...] MODLOWLIM [...] no tienen significado.",
        "MODLOWLIM Límite inferior del módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0.",
        "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas.",
        "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es ;
    ns1:valor "0",
        "Límite inferior del módulo",
        "Límites del módulo" .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "Límite superior de módulo (MODUPLIM)",
        "Límite superior del módulo (MODUPLIM)",
        "MODUPLIM" ;
    ns1:identificador "MODUPLIM" ;
    ns1:monitoreaParametro ns1:Sistema_EjesRotativos ;
    ns1:textoExtracto "Los límites de módulo (límites de recorrido del eje rotativo) vienen fijados por los parámetros de gama MODUPLIM y MODLOWLIM.",
        "Los parámetros [...] MODUPLIM [...] no tienen significado.",
        "MODUPLIM Límite superior del módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±99999.9999º. Valor por defecto: 360.",
        "MODUPLIM | Límites del módulo. Límites para visualizar las cotas.",
        "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es ;
    ns1:valor "360",
        "Límite superior del módulo",
        "Límites del módulo" .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
