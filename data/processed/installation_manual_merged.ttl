ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "MAXDIFREF",
        "MAXDIFREF"@es ;
    ns1:identificador "MAXDIFREF" ;
    ns1:textoExtracto "Máxima diferencia de posición permitida para considerar que no es necesario volver a referenciar. Parámetro válido para ejes lineales y rotativos. Valores posibles (1): De 0.0001 a 99999.0000 mm. Valores posibles (2): De 0 a 3936.96850 inch. Valores posibles (3): De 0.0001 a 99999.0000 grados. Valor por defecto: 0.0200 mm / 0.00079 inch / 0.0200 grados.",
        "Máxima diferencia de posición, entre la cota guardada por el CNC y el regulador, para volver a referenciar el eje (marca REFPOIN). Si tras un error o una caída del anillo Sercos, la diferencia es mayor que MAXDIFREF, el CNC pone la marca de PLC REFPOIN(axis)=0.",
        "Si la diferencia es menor que MAXDIFREF, el CNC arranca con la nueva posición calculada por el encóder [...] Si la diferencia es mayor que MAXDIFREF, el CNC arrancará con la posición guardada"@es,
        "diferencia de posiciones menor que el parámetro MAXDIFREF"@es ;
    ns1:valor "0.0200 mm / 0.00079 inch / 0.0200 grados",
        "Variable según configuración (mm/inch/grados)" .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE",
        "Máximo error de seguimiento en movimiento"@es,
        "Parámetro MAXFLWE (Umbral de error de seguimiento)"@es ;
    ns1:identificador "MAXFLWE",
        "MPA.MAXFLWE[set].xn",
        "PP159" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento,
        ns1:Sistema_FLWEMONITOR,
        ns1:Sistema_MonitorizacionErrorSeguimiento ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica.",
        "El tipo de monitorización \"Standard\" efectúa una supervisión constante del error de seguimiento, generándose un error cuando se supera el valor indicado por el parámetro MAXFLWE, si el eje está en movimiento.",
        "MAXFLWE | PP159 |  |  | Sólo si está activa la monitorización del error de seguimiento.",
        "Con FLWEMONITOR = Standard, MAXFLWE indica el máximo error de seguimiento permitido cuando el eje está en movimiento. Con FLWEMONITOR = Lineal, MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica."@es,
        "El parámetro MAXFLWE indica a partir de qué valor del error de [...]"@es ;
    ns1:valor "30.0000",
        "valor_umbral_error_seguimiento" .

ns1:Parametro_MAXMANACC a ns1:Parametro ;
    rdfs:label "MAXMANACC",
        "MAXMANACC (Aceleración máxima en jog continuo)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "MAXMANACC",
        "MPA.MAXMANACC.xn" ;
    ns1:textoExtracto "Aceleración máxima en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales.",
        "Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valores posibles (2): De 0.00004 a 23622047.2440 inch/s². Valores posibles (3): De 0.0010 a 600000000.0000 grados/s². Valor por defecto: 10000.0000 mm/s² / 393.70079 inch/s² / 10000.0000 grados/s².",
        "Modo de trabajo manual. Aceleración máxima en manual.",
        "Aceleración máxima en modo jog continuo."@es ;
    ns1:valor "10000.0000 mm/s² / 393.70079 inch/s² / 10000.0000 grados/s²",
        "De 0.0010 a 600000000.0000 mm/s²" .

ns1:Parametro_MAXOVR a ns1:Parametro ;
    rdfs:label "MAXOVR",
        "Límite máximo de override global (parámetro máquina MAXOVR)"@es ;
    ns1:identificador "(V.)[ch].MPA.MAXOVR.xn",
