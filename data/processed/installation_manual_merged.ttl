    ns1:textoExtracto "(TRS) Entrada de reset. Permite inicializar el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta. Se referencia mediante las letras TRS seguidas del número de temporizador, por ejemplo TRS 1, TRS 25, TRS 102, etc."@es .

ns1:EntradasAnal_gicasGP_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas de propósito general (EtherCAT)" ;
    ns1:identificador "40" ;
    ns1:textoExtracto "Entradas analógicas de propósito general. | 40" .

ns1:EntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas",
        "Entradas analógicas Fagor (IB IL AI 4 - U-PAC)" ;
    ns1:textoExtracto "(Elemento 1) Propiedades de 'Entradas analógicas Fagor (IB IL AI 4 - U-PAC)': selección de primera entrada, rango de medición por canal y frecuencia de muestreo; interfaz con listas desplegables por canal."@es ;
