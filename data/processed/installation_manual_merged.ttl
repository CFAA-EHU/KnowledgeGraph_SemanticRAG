    ns1:monitoreaParametro ns1:ComunicacionPLC_M06 ;
    ns1:textoExtracto "M1101 | MZTOCH1 - La herramienta se ha llevado del almacén a la pinza 1." ;
    ns1:valor "MZTOCH1" .

ns1:Parametro_05abe2f27e a ns1:Parametro ;
