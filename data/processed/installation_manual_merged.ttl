ns1:Parametro_GEOCONFIG a ns1:Parametro ;
    rdfs:label "GEOCONFIG",
        "Parámetro GEOCONFIG (configuración geométrica de ejes)"@es ;
    ns1:documentadoEn ns1:Manual,
        ns1:Tabla_ConfiguracionesMaquinas_1026 ;
    ns1:identificador "GEOCONFIG" ;
