    ns1:detalladoEnEsquema ns1:CalculoDelParametroTDATA1 ;
    ns1:ilustra ns1:ParametroTDATA1 ;
    ns1:textoExtracto "Diagrama 'Primer contacto' para TDATA1 con B=0°, C=0° y palpado en eje Y sobre cilindro (punto 1), mostrando preselección Y=R para centrar el eje del cilindro." .

ns1:EsquemaCalculoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema combinado para TDATA5",
        "Esquema de cálculo TDATA5" ;
    ns1:detalladoEnEsquema ns1:CalculoDelParametroTDATA5 ;
    ns1:ilustra ns1:ParametroTDATA5 ;
    ns1:textoExtracto "Esquema 'Primer contacto' para TDATA5 con B=0°, C=0°, palpado en eje X (punto 1) y preselección X=0." .

ns1:EsquemaCalculoTDATA6 a ns1:Esquema ;
    rdfs:label "Esquema combinado para TDATA6",
        "Esquema combinado para cálculo de TDATA6" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA6,
        ns1:ParametroTDATA6 ;
    ns1:textoExtracto "Esquema combinado con fórmula de solución TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°)" .

ns1:EsquemaCompensacionCruzada a ns1:Esquema ;
    rdfs:label "Diagrama Compensación Cruzada" ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:EsquemaCompensacionLaser a ns1:Esquema ;
    rdfs:label "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser" ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser. Muestra triedro X-Y y el efecto del seguimiento (#FOLLOW): líneas sólidas y discontinuas marcan el recorrido óptico y el desplazamiento del eje esclavo para mantener constante la longitud del haz, minimizando variaciones en el punto de corte." .

ns1:EsquemaCompensacionVolumetricaPaso3 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 3) del plano XY" ;
    ns1:textoExtracto "Esquema 3D (Paso 3) del plano XY con el patrón de relleno completo en X para cada fila Y(Pn). Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2 y cómo se genera la lista ordenada de puntos antes de subir de cota Z." .

ns1:EsquemaCompensacionVolumetricaPaso4 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 4) del segundo nivel Z(P2)" ;
    ns1:textoExtracto "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2): desde X(P1), Y(P1), Z(P2) se repite el barrido en X e Y. Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano." .

ns1:EsquemaCompensacionVolumetricaPaso5 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 5) con varios planos intermedios Z" ;
    ns1:textoExtracto "Esquema 3D (Paso 5) mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance. La representación enfatiza la construcción volumétrica por capas, manteniendo los incrementos definidos para cada eje." .

ns1:EsquemaCompensacionVolumetricaPaso6 a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 6) del volumen totalmente relleno" ;
    ns1:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn). Se observan todas las capas Z apiladas, el patrón de serpenteo por planos y la malla completa que sustenta la interpolación de errores dentro del volumen." .

ns1:EsquemaComportamientoEjePosicionamiento a ns1:Esquema ;
    rdfs:label "Comportamiento de un eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Tres diagramas polares comparan el comportamiento de un eje rotativo 'de posicionamiento' (camino más corto), mostrando arcos de 60° y 300° con flechas que indican trayectorias mínima y alternativa." .

ns1:EsquemaConexionSensorGap a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap" ;
    ns1:ilustra ns1:Componente_15b899c2b3 ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador." .

ns1:EsquemaConfiguracionEjes a ns1:Esquema ;
    rdfs:label "Configuración de ejes y cabezales" ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ2ꞏ." ;
    ns1:tieneComponente ns1:CabezalConIndice1_05815fed25,
        ns1:EjeConIndice1,
        ns1:EjeConIndice2 .

ns1:EsquemaConfiguracionEjesPlano a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo plano (torno)" ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo plano (torno)': máquina con dos ejes principales (Z+ y X+) representados; el plano de trabajo habitual es G18 (ZX). La vista ayuda a interpretar qué ejes forman abscisas/ordenadas y cómo afecta al mecanizado y a la definición del eje longitudinal." .

ns1:EsquemaConfiguracionEjesRotativos a ns1:Esquema ;
    rdfs:label "Configuración de los ejes rotativos" ;
    ns1:ilustra ns1:SentidoDeGiroUnico_1ecb002b83 ;
    ns1:textoExtracto "Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR." .

ns1:EsquemaConfiguracionEjesTriedro a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo triedro" ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo triedro': máquina con tres ejes (X+, Y+, Z+), propia de fresadora. Sirve para visualizar el triedro cartesiano y los planos G17/G18/G19 según el orden de ejes del canal, base para programar trayectorias en 3D." .

ns1:EsquemaControlGap a ns1:Esquema ;
    rdfs:label "Esquema del control de gap con boquilla láser" ;
    ns1:textoExtracto "Esquema del control de gap con boquilla láser, superficie de pieza y eje asociado (X/Z según máquina). Muestra el sensor manteniendo una distancia fija (gap) y la compensación en el eje longitudinal para seguir irregularidades; incluye rótulos 'LASER', 'GAP' y 'Workpiece surface'." .

ns1:EsquemaCotasEjesRotativos a ns1:Esquema ;
    rdfs:label "Visualización de cotas en ejes rotativos" ;
    ns1:textoExtracto "Conjunto de tres esquemas circulares que representan la visualización de cotas en ejes rotativos en modo 'módulo', con marcas de ±300° y flechas de sentido de giro." .

ns1:EsquemaDeCinematicaTYPE17 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=17" ;
    ns1:ilustradoEn ns1:ColocacionDelCabezal,
        ns1:ColocacionDelCabezal_5deee7899a,
        ns1:ColocacionDelCabezal_5e704d56ca,
        ns1:InversionDelSentidoDeGiro,
        ns1:PosicionDelEjeRotativoDelCabezal,
        ns1:PosicionDelEjeRotativoDelCabezal_0c1237dbe6,
        ns1:PosicionDelEjeRotativoDelCabezal_cc1e25cb0f,
        ns1:UbicacionDelEjeDeMesa,
        ns1:UbicacionDelEjeDeMesa_154bab715f,
        ns1:UbicacionDelEjeDeMesa_26e247c53a ;
    ns1:textoExtracto "Esquema de cinemática TYPE=17 para cabezal/mesa con ejes lineales X-Y-Z y rotativos A/B/C. Se muestran los tres órdenes de rotación (1º, 2º, 3º) y las distancias/offsets etiquetadas como TDATA (1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12). Las flechas indican sentidos positivos (+/−) y la disposición espacial del conjunto." .

ns1:EsquemaDeCinematicaTYPE18 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=18" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=18 con ejes X-Y-Z y rotaciones A/C. Incluye anotaciones TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) y numeración del orden de los giros (1º-3º). Las flechas y signos (+/−) marcan la dirección positiva según norma; se destaca la relación del eje rotativo con los lineales." .

ns1:EsquemaDeCinematicaTYPE19 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=19" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=19 con ejes lineales X-Y-Z y rotaciones A/C/B. Se detallan TDATA 1, 2, 7, 8, 11 y otros para offsets y sentidos; incluye orden de rotaciones y referencias de signo para los vectores de giro." .

ns1:EsquemaDeCinematicaTYPE20 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=20" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=20 con ejes X-Y-Z y rotación B, con despieces laterales que indican TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) y la secuencia 1º-3º. Las flechas muestran direccionalidad y el signo de cada componente." .

ns1:EsquemaDeCinematicaTYPE21 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=21" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=21 con ejes X-Y-Z y rotaciones C/A/B. Presenta el orden de ejes (1º-3º), componentes TDATA (1, 2, 3, 4, 5, 7, 8, 9, 12) y flechas de sentido; organiza jerárquicamente dirección y posición de cada giro." .

ns1:EsquemaDeCinematicaTYPE22 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=22" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=22 con ejes X-Y-Z y rotación C/B. Se especifican TDATA (2, 5, 7, 8, 11) y el orden 1º-3º; las anotaciones (+/−) establecen polaridad y sentido del giro respecto a los ejes lineales." .

ns1:EsquemaDeCinematicaTYPE23 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=23" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=23 (A/B/C con X-Y-Z). Diagramas con TDATA 1–13 y 21–23 que representan posiciones, offsets y sentidos de giro; incluye numeración de ejes 1º-3º y convenciones de signo." .

ns1:EsquemaDeCinematicaTYPE24 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=24" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=24 (A/B/C con X-Y-Z). Muestra vectores asociados a TDATA (2, 4, 5, 8) y la correspondencia entre traslaciones/giros con indicación de orden y sentido." .

ns1:EsquemaDeMesaRotativaABTYPE9 a ns1:Esquema ;
    rdfs:label "Esquema de mesa rotativa AB (TYPE=9)" ;
    ns1:detalladoEnEsquema ns1:ParametroTDATA2,
        ns1:ParametroTDATA3,
        ns1:ParametroTDATA4,
        ns1:ParametroTDATA5 ;
    ns1:textoExtracto "Conjunto de diagramas de una mesa rotativa AB (TYPE=9) que definen sentidos positivos y parámetros TDATA2, TDATA3, TDATA4 y TDATA5" .

ns1:EsquemaEjeCCilindrico a ns1:Esquema ;
    rdfs:label "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza" ;
    ns1:ilustradoEn ns1:Pagina277 ;
    ns1:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza. Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." .

ns1:EsquemaEjeCOffsets a ns1:Esquema ;
    rdfs:label "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento" ;
    ns1:ilustradoEn ns1:Pagina275 ;
    ns1:textoExtracto "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento. Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento), con ejes dibujados y símbolos (+) que fijan el sentido positivo." .

ns1:EsquemaEjeGantry a ns1:Esquema ;
    rdfs:label "Esquema Eje Gantry" ;
    ns1:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." .

ns1:EsquemaEjeTandem a ns1:Esquema ;
    rdfs:label "Esquema Eje Tándem" ;
    ns1:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." .

ns1:EsquemaEjemploTeclasJog a ns1:Esquema ;
    rdfs:label "Esquema de ejemplo que combina iconos de teclas con flechas de sentido" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Esquema de ejemplo que combina iconos de teclas (X±, Y±, '4±', '5±', '+', '−', 'R') con flechas de sentido. Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R." .

ns1:EsquemaGapControl a ns1:Esquema ;
    rdfs:label "Diagrama funcional del lazo de control del gap" ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: la realimentación del sensor (GAP SENSOR FEEDBACK) entra a un bucle de posición (POSITION LOOP)" .

ns1:EsquemaGapOrientation a ns1:Esquema ;
    rdfs:label "Orientación del eje Z" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)" .

ns1:EsquemaGapOrientationInverted a ns1:Esquema ;
    rdfs:label "Orientación del eje Z invertido" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = No': representa un eje Z invertido (Z+ hacia abajo). El movimiento para lograr el gap se realiza en sentido positivo." .

ns1:EsquemaInterconexionSercos a ns1:Esquema ;
    rdfs:label "Esquema de interconexión del sistema Sercos" ;
    ns1:ilustradoEn ns1:BastidorRIO5,
        ns1:BastidorRIO5Expansivo,
        ns1:BastidorRIO5Expansivo2_162ca15bea ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)." .

ns1:EsquemaModelizadoMaquina a ns1:Esquema ;
    rdfs:label "Esquema modelizado de la máquina (archivo xca)" ;
    ns1:documentadoEn ns1:CNC8070_e952ae6594 ;
    ns1:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)" .

ns1:EsquemaModuloOPPanel a ns1:Esquema ;
    rdfs:label "Imagen del módulo OP-PANEL-H/E" ;
    ns1:textoExtracto "Imagen del módulo OP-PANEL-H/E con distribución completa de teclado: override de husillo, sentidos de giro, posicionamiento, START/STOP, ZERO, RESET y teclas de usuario con leds." .

ns1:EsquemaNumeracionGruposRemotos a ns1:Esquema ;
    rdfs:label "Esquema Numeración Grupos Remotos" ;
    ns1:textoExtracto "Esquema de 'Numeración según el orden de los grupos remotos': tres bloques 'Remote Group (1–3)' con módulos encestados bajo un 'POWER SUPPLY';" .

ns1:EsquemaNumeracionParametrosMaquina a ns1:Esquema ;
    rdfs:label "Esquema de Numeración mediante parámetros máquina" ;
    ns1:ilustra ns1:IndiceBaseI1,
        ns1:IndiceBaseO1 ;
    ns1:textoExtracto "Esquema de 'Numeración mediante parámetros máquina': dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos." .

ns1:EsquemaParametrosHMI a ns1:Esquema ;
    rdfs:label "Parámetros máquina del HMI (interface)" ;
    ns1:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC. Para validar los cambios que se realicen en estos parámetros es necesario reinicializar el CNC." .

ns1:EsquemaParametrosMaquina a ns1:Esquema ;
    rdfs:label "Parámetros Máquina" ;
    ns1:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC. Algunos parámetros dependen del modelo de CNC y otros son comunes a ambos." .

ns1:EsquemaPosicionReferenciaHEADTOOL a ns1:Esquema ;
    rdfs:label "Doble esquema de posición de referencia HEAD/TOOL" ;
    ns1:textoExtracto "Doble esquema de 'posición de referencia HEAD/TOOL' que compara 'Tool base/Auto tool base' frente a 'Head base'. Se marca la nariz del portaherramientas y vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación." .

ns1:EsquemaPosicionReferenciaTDATA2 a ns1:Esquema ;
    rdfs:label "Pareja de diagramas para TDATA2" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA2_3e63bfb9b3 ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3)." .

ns1:EsquemaPosicionamientoCortoCamino a ns1:Esquema ;
    rdfs:label "Posicionamiento por el camino más corto (SHORTESTWAY = Sí)" ;
    ns1:ilustra ns1:PosicionamientoPorElCaminoMasCorto_58d417b415 ;
    ns1:textoExtracto "Esquema circular con arcos y flechas que ilustra 'Posicionamiento por el camino más corto (SHORTESTWAY = Sí)'. Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo." .

ns1:EsquemaPrecargaAceleracion a ns1:Esquema ;
    rdfs:label "Precarga con aceleración"@es ;
    ns1:textoExtracto "Diagrama con flechas que indican aceleración hacia la derecha; el piñón maestro aplica mayor par motor, mientras el esclavo compensa con par opuesto para mantener la tensión mecánica y minimizar el juego durante el arranque." .

ns1:EsquemaPrecargaDeceleracion a ns1:Esquema ;
    rdfs:label "Precarga con deceleración"@es ;
    ns1:textoExtracto "--" .

ns1:EsquemaPrecargaReposo a ns1:Esquema ;
    rdfs:label "Precarga en reposo"@es ;
    ns1:textoExtracto "Esquema lateral de dos trenes motor–reductor–piñón contra cremallera inmóviles; vectores opuestos de par en maestro y esclavo visualizan una tracción previa que elimina holguras cuando el sistema está parado." .

ns1:EsquemaPrecargaVelocidadConstante1 a ns1:Esquema ;
    rdfs:label "Precarga a velocidad constante. Par de fricción > Precarga"@es ;
    ns1:textoExtracto "Representación del avance a velocidad constante con fricción predominante; las flechas de par muestran cómo la precarga queda superada por el par de rozamiento, manteniendo contacto y estabilidad sin inversión de esfuerzo." .

ns1:EsquemaPrecargaVelocidadConstante2 a ns1:Esquema ;
    rdfs:label "Precarga a velocidad constante. Par de fricción < Precarga"@es ;
    ns1:textoExtracto "Gráfico similar al anterior, pero con precarga dominante sobre la fricción; los vectores de par opuestos aseguran la tracción piñón–cremallera manteniendo el conjunto sin holgura durante el avance." .

ns1:EsquemaPrimerSegundoContactoTDATA6 a ns1:Esquema ;
    rdfs:label "Secuencia Primer y Segundo Contacto TDATA6" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA6_a111c673af ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2)." .

ns1:EsquemaRIO5 a ns1:Esquema ;
    rdfs:label "Esquema RIO5" ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." .

ns1:EsquemaRIO5Expansivo a ns1:Esquema ;
    rdfs:label "Esquema RIO5 Expansivo" ;
    ns1:textoExtracto "Imagen 'Grupo 2': bastidor RIO5 con 24+48 entradas y 16+32 salidas digitales. Los módulos apilados representan tres bloques lógicos de entradas y dos de salidas; se aprecian etiquetas de conectores y disposición modular repetitiva que ilustra la expansión." .

ns1:EsquemaRIO5Expansivo2_05fb6a7258 a ns1:Esquema ;
    rdfs:label "Esquema RIO5 Expansivo 2" ;
    ns1:textoExtracto "Imagen 'Grupo 3': bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales." .

ns1:EsquemaReglaManoDerechaEjeC a ns1:Esquema ;
    rdfs:label "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10)" ;
    ns1:ilustradoEn ns1:Pagina276 ;
    ns1:textoExtracto "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10). Incluye tres vistas de manos con ejes anotados." .

ns1:EsquemaReglaManoDerechaXYZ a ns1:Esquema ;
    rdfs:label "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos" ;
    ns1:ilustradoEn ns1:Pagina274 ;
    ns1:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos. Tres bocetos de mano señalan dirección positiva del eje lineal (pulgar) y giro asociado (curvatura de dedos)." .

ns1:EsquemaSegundoContactoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema Segundo Contacto TDATA5" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA5 ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX." .

ns1:EsquemaSentidoGiroUnico a ns1:Esquema ;
    rdfs:label "Sentido de giro único (UNIDIR = Positivo)" ;
    ns1:ilustra ns1:SentidoDeGiroUnico_1ecb002b83 ;
    ns1:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario." .

ns1:EsquemaTeclasJog a ns1:Esquema ;
    rdfs:label "Esquema de teclas Jog" ;
    ns1:ilustradoEn ns1:Pagina438 ;
    ns1:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15. Indican la disposición y orden de teclas genéricas y de jog, útil para interpretar la correspondencia física-lógica de los bits en KEYBD y los efectos de selectores/overrides." .

ns1:EsquemaTercerCuartoContactoTDATA6 a ns1:Esquema ;
    rdfs:label "Secuencia Tercer y Cuarto Contacto TDATA6" ;
