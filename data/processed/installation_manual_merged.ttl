    ns1:textoExtracto "TDATA31 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas" ;
    ns1:valor "0.0"^^xsd:float,
        "-TDATA4",
        "0",
        "0, 1"@es .

ns1:Parametro_0cf9a7246b a ns1:Parametro ;
    rdfs:label "REVEHYST" ;
    ns1:identificador "REVEHYST" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionHolgura ;
    ns1:textoExtracto "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del eje no varíe al menos el valor definido en este parámetro" ;
    ns1:valor "0 a 99999.9999"^^xsd:string,
        "0.0005",
        "0.0005 mm" .

ns1:Parametro_11a7bafe8d a ns1:Parametro ;
    rdfs:label "Marca DMCPWRHOLD" ;
    ns1:identificador "DMCPWRHOLD" ;
    ns1:textoExtracto "activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." .

ns1:Parametro_1387c19354 a ns1:Parametro ;
