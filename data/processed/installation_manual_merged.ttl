    ns1:documentadoEn ns1:Tabla_PerfilesMovimiento_SLOPETYPE ;
    ns1:textoExtracto "aceleración trapezoidal [...] suavizan cambios (jerk limitado)"@es .

ns1:Parametro_SL_X a ns1:Parametro ;
    rdfs:label "Límite de software en eje X (SL)" ;
    ns1:textoExtracto "límites de software (SL) para X-Y-Z" ;
    ns1:valor "SL_X" .

ns1:Parametro_SOFTFREQ_MPG a ns1:Parametro ;
    rdfs:label "SOFTFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1153 ;
    ns1:identificador "SOFTFREQ MPG" ;
    ns1:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado. Este parámetro se debe ajustar con ayuda de la aplicación FineTune."@es .

ns1:Parametro_SOFTKEYMETRICS a ns1:Parametro ;
    rdfs:label "SOFTKEYMETRICS" ;
    ns1:documentadoEn ns1:InterfazUsuario_ConfiguracionSoftkeys ;
    ns1:textoExtracto "SOFTKEYMETRICS Dimensiones de las softkeys. Valores posibles: Estándar / Avanzado. Valor por defecto: Estándar." ;
    ns1:valor "Estándar" .

ns1:Parametro_SPDLNAME a ns1:Parametro ;
    rdfs:label "SPDLNAME",
        "Parámetro máquina SPDLNAME"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionEjesCabezales_1023 ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "CHSPDLNAME n Nombre de los cabezales. Valores posibles: Cualquier cabezal definido en SPDLNAME.",
        "Lista de cabezales del sistema. El orden en el que se definen los cabezales en SPDLNAME determina su número lógico.",
        "El índice de un cabezal en el sistema viene establecido por el orden en el que está definido en el parámetro máquina SPDLNAME."@es .

ns1:Parametro_SPDLNAME_n a ns1:Parametro ;
    rdfs:label "SPDLNAME n" ;
    ns1:documentadoEn ns1:Tabla_SPDLNAME ;
    ns1:identificador "MPG.SPDLNAMEn" ;
    ns1:textoExtracto "SPDLNAME n Nombre de los cabezales. Valores posibles: S, S1…S9. Valor por defecto: Comenzando por SPDLNAME1; S, S1..." ;
    ns1:valor "S" .

ns1:Parametro_SPDLTIME a ns1:Parametro ;
    rdfs:label "SPDLTIME",
        "SPDLTIME (tiempo de activación de cabezal)",
        "Parámetro de cabezal SPDLTIME"@es,
        "Tiempo estimado para función S (SPDLTIME)"@es ;
    ns1:identificador "SPDLTIME",
        "V.[ch].MPA.SPDLTIME.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_EDISIMU,
        ns1:Sistema_ControlCNC ;
    ns1:textoExtracto "El CNC sólo utiliza los registros de los cabezales cuyo parámetro SPDLTIME tenga un valor distinto de cero.",
        "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S.",
        "El comando SFUN sólo toma el valor de la S programada si el parámetro de cabezal SPDLTIME es distinto de cero."@es,
        "Variable asociada: (V.)[ch].MPA.SPDLTIME.xn [...] parámetro que indica el tiempo estimado para el proceso de la función S."@es ;
    ns1:valor "0",
        "tiempo estimado para función S" .

ns1:Parametro_SSIRESOL a ns1:Parametro ;
    rdfs:label "SSIRESOL" ;
    ns1:textoExtracto "SSIRESOL Resolución del contaje digital. Valores posibles: De 1 a 999999999. Valor por defecto: 10000." ;
    ns1:valor "10000" .

ns1:Parametro_SSIRESOL_Encoder8192 a ns1:Parametro ;
    rdfs:label "SSIRESOL (Encoder 8192 pulsos)" ;
    ns1:textoExtracto "Para el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. SSIRESOL = 8192." ;
    ns1:valor "8192" .

ns1:Parametro_SSIRESOL_InductosynABS a ns1:Parametro ;
    rdfs:label "SSIRESOL (Inductosyn ABSIND)" ;
    ns1:textoExtracto "Para el caso de SSITYPE = ABSIND (inductosyn ROT+ABS), el incremento del contaje es de 10000 unidades. SSIRESOL = 10000" ;
    ns1:valor "10000" .

ns1:Parametro_SSIRESOL_Regla20Micras a ns1:Parametro ;
    rdfs:label "SSIRESOL (Regla absoluta Fagor 20µ)" ;
    ns1:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ. SSIRESOL = 20 µ / 0,1 µ = 200." ;
    ns1:valor "200" .

ns1:Parametro_STARTDELAY a ns1:Parametro ;
    rdfs:label "STARTDELAY" ;
    ns1:textoExtracto "STARTDELAY Número de clocks a esperar entre el primer flanco de bajada y el primer flanco de subida. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_SUBINTSTOP a ns1:Parametro ;
    rdfs:label "Parámetro SUBINTSTOP",
        "SUBINTSTOP" ;
    ns1:identificador "(V.)[ch].MPG.SUBINTSTOP",
        "SUBINTSTOP" ;
    ns1:textoExtracto "SUBINTSTOP Ejecutar subrutinas de interrupción con programa parado o sin programa en ejecución. Valores posibles: Sí / No. Valor por defecto: No.",
        "Si el programa está interrumpido (STOP) o no hay programa en ejecución (canal en estado READY) la ejecución de la subrutina depende del parámetro SUBINTSTOP" ;
    ns1:valor "No" .

ns1:Parametro_SUBPATH a ns1:Parametro ;
    rdfs:label "SUBPATH" ;
    ns1:documentadoEn ns1:Tabla_Subrutinas_1179 ;
    ns1:identificador "SUBPATH",
        "V.[ch].MPG.SUBPATH" ;
    ns1:textoExtracto "SUBPATH Path de las subrutinas de programa. Este parámetro indica el directorio, por defecto, en que se encuentran las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055 MC y 8055 TC.",
        "Path: Parámetro general SUBPATH"@es ;
    ns1:valor "Directorio por defecto para subrutinas" .

ns1:Parametro_SUBPATH_CHN a ns1:Parametro ;
    rdfs:label "SUBPATH CHN" ;
    ns1:identificador "SUBPATH CHN" ;
    ns1:textoExtracto "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." ;
    ns1:valor "Directorio por defecto para subrutinas (8055-MC/8055-TC)" .

ns1:Parametro_SURFFILFREQ_MPG a ns1:Parametro ;
    rdfs:label "SURFFILFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1153 ;
    ns1:identificador "SURFFILFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave."@es .

ns1:Parametro_SURFFILTFREQ a ns1:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ns1:documentadoEn ns1:Manual_ModoHSC,
        ns1:Tabla_ConfiguracionModoHSC ;
    ns1:identificador "(V.)[ch].MPG.SURFFILTFREQ",
        "SURFFILTFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz.",
        "Frecuencia del filtro de ejes (modo SURFACE)."@es,
        "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz."@es ;
    ns1:valor "25",
        "25 Hz" .

ns1:Parametro_SWLIMITTOL a ns1:Parametro ;
    rdfs:label "Parámetro SWLIMITTOL" ;
    ns1:identificador "V.[ch].MPA.SWLIMITTOL.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SWLIMITTOL.xn. Este parámetro indica la máxima variación u oscilación permitida a un eje que está posicionado en el límite. Este parámetro indica la máxima variación u oscilación permitida a la cota real de un eje respecto de los límites de software, antes de dar error de límites sobrepasados." ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados (valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados)" .

ns1:Parametro_SWLIMITTOL_Descripcion a ns1:Parametro ;
    rdfs:label "Descripción del parámetro SWLIMITTOL" ;
    ns1:textoExtracto "La tolerancia indica la máxima variación u oscilación permitida a la cota real de un eje respecto de los límites de software, antes de dar error de límites sobrepasados. El movimiento teórico programado del eje sólo se permite hasta el límite exacto, pero a la cota real del eje se le permite este margen antes de dar error." .

ns1:Parametro_SZERO_SP42 a ns1:Parametro ;
