ns1:RelojesPLC a ns1:Sistema ;
    rdfs:label "Relojes internos del PLC"@es ;
    ns1:identificador "CLK" ;
    ns1:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC."@es .

ns1:RequisitosMultieje_11_4 a ns1:Tabla ;
    rdfs:label "Requisitos y limitaciones de grupo multieje (Sección 11.4)"@es ;
    ns1:documentadoEn ns1:Pagina_584_585 ;
    ns1:textoExtracto "Los ejes asociados a un mismo regulador deben cumplir los siguientes requisitos. • Pueden formar parte de un grupo multieje cualquier eje o cabezal Sercos del sistema, excepto los que formen parte de los ejes tándem o gantry. • Como cada eje y cabezal definido en el CNC puede tener varios sets de parámetros, la suma total de sets de todos los ejes y/o cabezales incluidos en un grupo no podrá superar los 8 sets disponibles en el regulador. • Como los ejes están controlados con el mismo regulador, todos los ejes de un grupo deben tener la misma dirección Sercos (parámetro DRIVEID). • Todos los ejes de un grupo deben trabajar en el mismo modo de operación Sercos, posición o velocidad (parámetro OPMODEP)."@es .

ns1:RutinaM06_Caso5 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio automático de herramienta (almacén → cabezal, pinzas 1/2) (Caso 5)",
        "Rutina M06 - Caso 5: Cambio de herramienta en almacén" ;
    ns1:ejecutadoPor ns1:BrazoCambiador ;
    ns1:identificador "CASE 5",
        "M06-CASE5" ;
    ns1:requiereMantenimiento ns1:CabezalM06,
        ns1:Pinza1,
        ns1:Pinza2,
        ns1:Subrutina_CH1_TO_MZ,
        ns1:Subrutina_CH1_TO_SPD,
        ns1:Subrutina_MZ_TO_CH1,
        ns1:Subrutina_SPD_AUTCHG,
        ns1:Subrutina_SPD_TO_CH1,
        ns1:Subrutina_SPD_TO_GR ;
    ns1:textoExtracto "$CASE 5 ; Dejar la herramienta del cabezal en el almacén, y coger otra del almacén. [...] LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio. LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.",
        "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." .

ns1:RutinaM06_EjecucionReal a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución real (V.S.EXECUTION = 1)" ;
    ns1:textoExtracto "$IF [V.S.EXECUTION == 1] ; CNC en ejecución" .

ns1:RutinaM06_EjecucionSimulada a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución simulada (V.S.EXECUTION = 0)" ;
    ns1:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G." .

ns1:Rutina_PROGRAM_RESET a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:textoExtracto "El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET)." .

