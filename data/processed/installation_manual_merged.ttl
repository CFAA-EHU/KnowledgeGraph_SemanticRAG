ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Administrator Mode",
        "Modo administrador (para actualización permanente)" ;
    ns1:textoExtracto "La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías.",
        "botón 'Restart Windows in Administrator Mode' [...] cartela de estado con fondo rojo y texto 'ADMINISTRATOR MODE'." .

ns1:ModoDiagnosis_EtherCAT a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:solucionaFallo ns1:Error24499_EtherCAT ;
    ns1:textoExtracto "Para conocer los detalles del error, consultar el modo diagnosis. Información detallada del módulo en error." .

ns1:ModoHSC_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST" ;
    ns1:textoExtracto "FASTFACTOR Porcentaje de avance por defecto (modo FAST). [...] Este parámetro afecta al avance en las esquinas e indica el porcentaje de aceleración que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST." .

ns1:ModoLazoCerrado_G63 a ns1:ModoOperacion ;
    rdfs:label "G63" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "Cuando el cabezal trabaja en lazo cerrado (M19 ó G63)" .

ns1:ModoLazoCerrado_G74 a ns1:ModoOperacion ;
    rdfs:label "G74" ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "cabezal en lazo cerrado (por ejemplo M19 ó G74)" .

ns1:ModoLazoCerrado_M19 a ns1:ModoOperacion ;
    rdfs:label "M19" ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "cabezal en lazo cerrado (por ejemplo M19 ó G74)" .

ns1:ModoLimitadorTG4 a ns1:ModoOperacion ;
    rdfs:label "Modo limitador de la señal (TG4)" ;
    ns1:identificador "TG4" ;
    ns1:textoExtracto "un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." .

ns1:ModoOperacion_Autom_tico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "Al activar el avance rápido durante la ejecución de un programa, cada eje tomará como avance el definido en su parámetro FRAPIDEN, siempre que no esté activa G0 o un roscado." .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "CONTERROR",
        "Modo CONTERROR",
        "CONTERROR"@es,
        "Modo CONTERROR"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorHSC,
        ns1:Tabla_ParametrosHSC_1150 ;
    ns1:identificador "CONTERROR" ;
    ns1:textoExtracto "modo CONTERROR",
        "modo CONTERROR (desactivación de splines por error).",
        "parámetro HSCFILTFREQ para el modo CONTERROR. Cuando el error con el que se ha generado la pieza no es considerablemente inferior al error que se pretende pedir al modo CONTERROR",
        "Modo de control de error de trayectoria."@es,
        "modo CONTERROR (error cordal en la esquina)"@es,
        "optimizando el error de contorno (modo CONTERROR)"@es .

ns1:ModoOperacion_CompensacionVolumetricaBasica a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:textoExtracto "La opción \"Compensación volumétrica grande\" también permite utilizar los otros dos tipos de compensación, media y básica. La opción \"Compensación volumétrica media\" también permite utilizar la opción básica." .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "Modo EDISIMU",
        "Modo EDISIMU (EDIT)",
        "Modo EDISIMU"@es ;
    ns1:identificador "EDIT" ;
    ns1:textoExtracto "Modo EDISIMU. | EDIT | [CTRL]+[F9]",
        "modo EDISIMU",
        "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa."@es .

ns1:ModoOperacion_G00 a ns1:ModoOperacion ;
    rdfs:label "G00",
        "G00 (Avance rápido)",
        "Modo de operación G00 (avance rápido)",
        "Mecanizado en G00"@es ;
    ns1:controla ns1:Parametro_G0MODAL ;
    ns1:identificador "G00" ;
    ns1:ilustradoEn ns1:Figura_18_4_4_Osciloscopio ;
    ns1:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63.",
        "RAPIDOVR Override actúa en G00 (entre 0 y 100%).",
        "avance máximo de mecanizado (movimientos en G01/G02/G03) del eje; [...] el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED.",
        "B Mecanizado en G00."@es ;
    ns1:tieneFrecuencia ns1:Parametro_G00FEED .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (introducción manual de datos)",
        "Modo MDI/MDA",
        "Modo MDI"@es ;
    ns1:identificador "MDI",
        "MDI, MDIC1, MDIC2, MDIC3, MDIC4" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo MDI (introducción manual de datos).",
        "Modo MDI/MDA. | MDI | [CTRL]+[F8]",
        "Si estando en modo automático se selecciona MDI se activan las marcas AUTOMAT y MDI. Si estando en modo manual se selecciona MDI se activan las marcas MANUAL y MDI.",
        "modo MDI/MDA",
        "si se activa G95 desde en MDI sobre el modo manual"@es .

ns1:ModoOperacion_RTCP a ns1:ModoOperacion ;
    rdfs:label "Modo RTCP",
        "RTCP",
        "RTCP (Control de Punto de Herramienta)"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasMesa_Tipos9_12 ;
    ns1:identificador "RTCP" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina.",
        "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es,
        "modo RTCP activo"@es .

