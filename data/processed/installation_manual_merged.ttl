    ns1:textoExtracto "\"DIRNEG\" (sentido negativo)"@es .

ns1:Parametro_DIRPOS a ns1:Parametro ;
    rdfs:label "DIRPOS" ;
    ns1:documentadoEn ns1:Parametro_direction ;
    ns1:identificador "DIRPOS" ;
    ns1:textoExtracto "\"DIRPOS\" (sentido positivo)"@es .

ns1:Parametro_DISCROSS a ns1:Parametro ;
    rdfs:label "DISCROSS" ;
    ns1:identificador "DISCROSS1, DISCROSS2, ..." ;
    ns1:textoExtracto "el PLC dispone de una marca para cada tabla; la marca DISCROSS1 es para la tabla 1, DISCROSS2 para la tabla 2 y así sucesivamente." .

