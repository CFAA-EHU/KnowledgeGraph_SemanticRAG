    ns1:monitoreaParametro ns1:ParametroGap_1289 ;
    ns1:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje. Fagor Automation recomienda utilizar una entrada del regulador."@es .

ns1:SensorGap_1299 a ns1:Sensor ;
    rdfs:label "Sensor de detección del gap"@es ;
    ns1:identificador "V.G.GAP" ;
    ns1:monitoreaParametro ns1:ParametroGap_1299 ;
    ns1:textoExtracto "Valor real del gap, detectado por el sensor."@es .

ns1:SensorGap_ParametrosGenerales a ns1:Sensor ;
    rdfs:label "Sensor de gap"@es ;
    ns1:detalladoEnEsquema ns1:GraficoSensorGap_100 ;
    ns1:documentadoEn ns1:Pagina_100 ;
    ns1:monitoreaParametro ns1:ParametroGap ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)."@es .

ns1:Sensor_Colision_Gap a ns1:Sensor ;
    rdfs:label "Sensor de colisión del gap" ;
    ns1:activaAlarma ns1:Marca_GAPCOLLISION ;
    ns1:textoExtracto "sensor de colisión" .

ns1:Sensor_CompensacionRampa_706 a ns1:Sensor ;
    rdfs:label "Sensor de compensación de perfil ascendente" ;
    ns1:monitoreaParametro ns1:Parametro_GAP_706 ;
    ns1:textoExtracto "Trazas para 'Pieza con perfil ascendente': representa la evolución del gap y la compensación progresiva del eje para mantener la distancia programada ante una rampa geométrica positiva" .

ns1:Sensor_ControlGapLaser a ns1:Sensor ;
    rdfs:label "Sensor de control de gap (máquina láser)" ;
    ns1:monitoreaParametro ns1:Parametro_TRANSDELAY ;
    ns1:textoExtracto "En máquinas láser con control de gap, el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." .

ns1:Sensor_FeedbackMotor a ns1:Sensor ;
    rdfs:label "Sensor de feedback del motor"@es ;
    ns1:monitoreaParametro ns1:Parametro_ConfiguracionMultieje_X1209ABCDE1F ;
    ns1:textoExtracto "Motor Feedback"@en .

ns1:Sensor_GAP_702 a ns1:Sensor ;
    rdfs:label "Sensor de compensación de gap" ;
    ns1:monitoreaParametro ns1:Parametro_GAP_702 ;
    ns1:textoExtracto "la compensación del eje del sensor se ve como correcciones sincronizadas ante cambios abruptos de perfil" .

ns1:Sensor_MATCH_axis a ns1:Sensor ;
    rdfs:label "Señal MATCH(axis)"@es ;
    ns1:identificador "MATCH(axis)" ;
    ns1:monitoreaParametro ns1:Parametro_HIRTH ;
    ns1:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien."@es .

ns1:Sensor_MSTROBE a ns1:Sensor ;
    rdfs:label "MSTROBE" ;
    ns1:identificador "MSTROBE" ;
    ns1:ilustradoEn ns1:Figura_DiagramaTemporalNoSincronizado,
        ns1:Figura_DiagramaTemporalSincronizado ;
    ns1:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es .

ns1:Sensor_PT100_Generico a ns1:Sensor ;
    rdfs:label "Sonda PT100" ;
    ns1:textoExtracto "Una entrada PT100 debe estar activa si tiene una de estas sondas de temperatura conectada." .

ns1:Sensor_ProximidadGap a ns1:Sensor ;
    rdfs:label "Sensor de proximidad (Gap)" ;
    ns1:textoExtracto "opción \"Gap\" para utilizar el sensor de proximidad como palpador (por ejemplo, para medir la inclinación de una chapa). La opción \"Gap\" sólo está disponible en el modelo láser." .

ns1:Sensor_Proximidad_140 a ns1:Sensor ;
    rdfs:label "Sensor de proximidad"@es ;
    ns1:textoExtracto "para un sensor de proximidad, no es necesario definir este parámetro."@es .

ns1:Sensor_RelojComparador a ns1:Sensor ;
    rdfs:label "Reloj comparador",
        "Reloj comparador"@es ;
    ns1:monitoreaParametro ns1:Parametro_BACKLASH,
        ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Método gráfico para localizar la 'línea más exterior' del cilindro: desplazamiento del reloj sobre la circunferencia hasta detectar cambio de giro de la aguja",
        "Para medir la holgura utilizar un reloj comparador. Desplazar el eje en una dirección y poner el reloj a 0. Desplazar el eje en sentido contrario en modo incremental hasta detectar que el eje se mueve."@es .

ns1:Sensor_SSTROBE a ns1:Sensor ;
    rdfs:label "SSTROBE" ;
    ns1:identificador "SSTROBE" ;
    ns1:ilustradoEn ns1:Figura_DiagramaTemporalNoSincronizado,
        ns1:Figura_DiagramaTemporalSincronizado ;
    ns1:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es .

ns1:Sensor_SYNSPEED a ns1:Sensor ;
    rdfs:label "Señal SYNSPEED" ;
    ns1:monitoreaParametro ns1:Parametro_SYNSPEED ;
    ns1:textoExtracto "la señal SYNSPEED se pone a nivel lógico bajo" .

ns1:SentenciaDEFGRAPH_1349 a ns1:Parametro ;
    rdfs:label "Sentencia #DEFGRAPH para carga de configuración"@es ;
    ns1:identificador "#DEFGRAPH" ;
    ns1:monitoreaParametro ns1:ArchivoConfiguracionXCA_1349 ;
    ns1:textoExtracto "Los archivos xca se pueden cargar [...] desde el programa mediante la sentencia #DEFGRAPH"@es .

ns1:Sentencia_ABORT a ns1:Parametro ;
    rdfs:label "Sentencia #ABORT"@es ;
    ns1:identificador "#ABORT" ;
    ns1:textoExtracto "el CNC reanuda la ejecución del programa a partir de la etiqueta indicada en la sentencia #ABORT activa en el programa pieza."@es .

ns1:Sentencia_DMCOFF a ns1:AccionProhibida ;
    rdfs:label "Sentencia #DMCOFF" ;
    ns1:identificador "#DMCOFF" ;
    ns1:textoExtracto "La sentencia #DMCOFF desactiva el DMC." .

ns1:Sentencia_FOLLOW a ns1:Parametro ;
    rdfs:label "#FOLLOW" ;
    ns1:identificador "#FOLLOW" ;
    ns1:textoExtracto "ejes sincronizados con #FOLLOW" .

ns1:Sentencia_GAPCTRL a ns1:Parametro ;
    rdfs:label "Sentencia #GAPCTRL" ;
    ns1:identificador "#GAPCTRL" ;
    ns1:textoExtracto "sentencia #GAPCTRL" .

ns1:Sentencia_KIN_ID a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #KIN ID"@es ;
    ns1:identificador "#KIN ID" ;
    ns1:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID."@es .

ns1:Sentencia_LINK a ns1:Parametro ;
    rdfs:label "#LINK" ;
    ns1:identificador "#LINK" ;
    ns1:textoExtracto "ejes acoplados con #LINK" .

ns1:Sentencia_ROTATEMZ a ns1:ModoOperacion ;
    rdfs:label "Sentencia #ROTATEMZ"@es ;
    ns1:requiereMantenimiento ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "En almacenes torreta se puede seleccionar una posición (sentencia #ROTATEMZ)."@es .

ns1:Sentencia_SYNC a ns1:Parametro ;
    rdfs:label "#SYNC" ;
    ns1:identificador "#SYNC" ;
    ns1:textoExtracto "sincronización de cabezales en lazo cerrado mediante la sentencia #SYNC" .

ns1:Servicio_Master_Win64 a ns1:Componente ;
    rdfs:label "Master (Win64)"@es ;
    ns1:compuestoPor ns1:Sistema_BusEtherCAT ;
    ns1:textoExtracto "bandeja del sistema mostrando el servicio 'Master (Win64)'"@es .

ns1:Simbolo_COOL_I12 a ns1:Parametro ;
    rdfs:label "Símbolo COOL I12" ;
    ns1:identificador "I12" ;
    ns1:textoExtracto "DEF COOL I12" ;
    ns1:valor "COOL" .

ns1:Simbolo_FAN_I23 a ns1:Parametro ;
    rdfs:label "Símbolo /FAN I23" ;
    ns1:identificador "I23" ;
    ns1:textoExtracto "DEF /FAN I23" ;
    ns1:valor "/FAN" .

ns1:SincronizacionCabezales a ns1:ModoOperacion ;
    rdfs:label "Sincronización de cabezales" ;
    ns1:controla ns1:MarcaGEAROK,
        ns1:MarcaSYNCPOSI,
        ns1:MarcaSYNCRONP,
        ns1:MarcaSYNSPEED ;
    ns1:textoExtracto "Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales y se espera a la señal SERVOON (en el caso de tener DWELL). Cuando está activa una sincronización de cabezales, no se tienen en cuenta las señales PLCCNTL, INHIBIT y SPDLEREV ni del cabezal maestro ni del esclavo." ;
    ns1:tieneComponente ns1:SenalENABLE,
        ns1:SenalINHIBIT,
        ns1:SenalPLCCNTL,
        ns1:SenalSERVOON,
        ns1:SenalSPDLEREV .

ns1:SincronizacionM_AntesAntes a ns1:ModoOperacion ;
    ns1:documentadoEn ns1:ComunicacionPLC_RutinaM06 ;
    ns1:textoExtracto "Personalizar todas funciones M con sincronización 'antes - antes' para que continúe el programa tras su finalización."@es .

ns1:SincronizacionZonasPLC a ns1:ModoOperacion ;
    rdfs:label "Sincronización de zonas entre PLC y programa pieza"@es ;
    ns1:textoExtracto "Sincronizar cambios en las zonas desde el programa pieza y el PLC. [...] Para asegurar la correcta sincronización de los cambios entre el programa pieza y el PLC, estos últimos deberían ejecutarse a través de subrutinas de interrupción."@es .

ns1:SintaxisVariablesCNC_Velocidad a ns1:InterfazUsuario ;
    rdfs:label "Sintaxis de variables CNC para velocidad en lazo de posición"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVelocidadLazo ;
    ns1:textoExtracto """\r
ꞏchꞏ Número de canal.\r
ꞏxnꞏ Nombre, número lógico o índice del eje (ej. 'Z', '4').\r
ꞏsnꞏ Nombre, número lógico o índice del cabezal (ej. 'S', '2').\r
Ejemplos:\r
- V.A.TFEED.Z → Eje Z.\r
- V.SP.TFEED.S → Cabezal S.\r
- V.[2].A.TFEED.1 → Eje índice '1' en canal '2'.\r
"""@es .

ns1:Sintaxis_AccesoVariables a ns1:InterfazUsuario ;
    rdfs:label "Sintaxis de acceso a variables por canal"@es ;
    ns1:documentadoEn ns1:Tabla_14_13_2_Variables ;
    ns1:textoExtracto "Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.INT1SUB | Canal ꞏ2ꞏ."@es .

ns1:Sintaxis_CNCRD_CNCWR a ns1:Tabla ;
    rdfs:label "Sintaxis de variables en comandos CNCRD y CNCWR" ;
    ns1:documentadoEn ns1:Comando_CNCRD,
        ns1:Comando_CNCWR ;
    ns1:textoExtracto "Sintaxis de las variables en los comandos CNCRD y CNCWR. Para estos dos comandos, en el mnemónico de la variable se puede definir el número de canal mediante un número entero, un registro o un símbolo definido mediante DEF o PDEF." .

ns1:Sintaxis_MPM_MPROGNAME a ns1:InterfazUsuario ;
    rdfs:label "Sintaxis de MPM.MPROGNAME[pos]"@es ;
    ns1:documentadoEn ns1:Tabla_14_11_2_Variables ;
    ns1:textoExtracto "Sintaxis. ꞏposꞏ Posición dentro de la tabla de funciones \"M\". | MPM.MPROGNAME[12] | Posición ꞏ12ꞏ de la tabla de funciones M."@es .

ns1:SistemaActualizacionSubrutinas a ns1:Sistema ;
    rdfs:label "Sistema de actualización de subrutinas del CNC" ;
    ns1:documentadoEn ns1:Carpeta_MtbSub,
        ns1:Carpeta_UsersSub ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] En la tercera opción instalación 'rename previous version and install it completely', el CNC siempre actualiza las subrutinas." ;
    ns1:tieneComponente ns1:Subrutina_G500,
        ns1:Subrutina_G501,
        ns1:Subrutina_G599 .

ns1:SistemaAlmacenamiento_Sincrono a ns1:Sistema ;
    rdfs:label "Sistema de cambio síncrono (carrusel sin brazo cambiador)"@es ;
    ns1:textoExtracto "Escena del tipo 'Síncrono': un carrusel se aproxima al cabezal sin brazo cambiador; flechas de aproximación/retirada muestran la imposibilidad de cambiar durante el mecanizado."@es .

ns1:SistemaArchivosCNC a ns1:Sistema ;
    rdfs:label "Sistema de archivos del CNC" ;
    ns1:compuestoPor ns1:BACKUPSDIR,
        ns1:CONFIGURATION,
        ns1:DIAGNOSIS,
        ns1:DRIVERS,
        ns1:FAGOR,
        ns1:MTB,
        ns1:TMP,
        ns1:USERS ;
    ns1:textoExtracto "Carpetas: BACKUPSDIR, CONFIGURATION, DIAGNOSIS, DRIVERS, FAGOR, MTB, TMP, USERS" .

ns1:SistemaBusCAN_1238 a ns1:Sistema ;
    rdfs:label "Sistema de bus CAN para paneles de mando"@es ;
    ns1:compuestoPor ns1:Conector_X1_1238,
        ns1:Conector_X2_1238,
        ns1:Conector_X3_1238 ;
    ns1:identificador "Address" ;
    ns1:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address). El primer panel de jog será el de numeración más baja y así sucesivamente."@es ;
    ns1:tieneComponente ns1:PanelJog_Address0_1238,
        ns1:PanelJog_Address1_1238,
        ns1:PanelJog_Address2_1238 .

ns1:SistemaBusquedaReferencia a ns1:Sistema ;
    rdfs:label "Sistema de búsqueda de referencia (ejes y cabezales)" ;
    ns1:compuestoPor ns1:Componente_MicroReferencia,
        ns1:Sensor_I0 ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosBusquedaReferencia ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia ;
    ns1:textoExtracto "A veces, para reajustar la máquina, es necesario soltar el sistema de captación por lo que el nuevo punto de referencia máquina no coincide con el anterior. [...] La búsqueda de referencia la realiza el servo y el micro de referencia debe estar cableado al servo.",
        "El eje se desplaza la menor distancia posible, menos de 200 mm, en el sentido indicado por el parámetro REFDIREC y al avance indicado en el parámetro REFFEED2 hasta que el CNC recibe un impulso de I0 del sistema de captación." ;
    ns1:tieneComponente ns1:Parametro_REFDIREC,
        ns1:Parametro_REFFEED1,
        ns1:Parametro_REFFEED2,
        ns1:Parametro_REFSHIFT,
        ns1:Parametro_REFVALUE .

ns1:SistemaBusquedaReferencia_1097 a ns1:Sistema ;
    rdfs:label "Sistema de búsqueda de referencia máquina (ejes y cabezales)"@es ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT_1097,
        ns1:Parametro_I0TYPE_1097,
        ns1:Parametro_REFDIREC_1097,
        ns1:Parametro_REFFEED1_1097,
        ns1:Parametro_REFFEED2_1097 ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados... El fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina."@es ;
    ns1:tieneComponente ns1:MicroReferencia_1097 .

ns1:SistemaCANopen_1264 a ns1:Sistema ;
    rdfs:label "Sistema de numeración de I/O en bus CANopen" ;
    ns1:documentadoEn ns1:Pagina_680_681 ;
    ns1:textoExtracto "Por defecto, el CNC numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus. Cuando el bus es CANopen, el CNC permite dividir los nodos de I/Os digitales en bloques lógicos (módulos virtuales), y a continuación, establecer la numeración de las I/Os de cada bloque lógico asignando un índice base a la primera de ellas."^^xsd:string ;
    ns1:tieneComponente ns1:NodoRIO5_1264,
        ns1:NodoRIOR_1264,
        ns1:NodoRIOW_1264,
        ns1:NodoTerceros_1264 .

ns1:SistemaCANopen_130 a ns1:Sistema ;
    rdfs:label "Sistema de numeración de I/Os (bus CANopen)"@es ;
    ns1:textoExtracto """\r
    El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus.\r
    Rango de recursos gestionados por PLC: 1...1024."""@es ;
    ns1:tieneComponente ns1:ParametrizacionCANopen_130 .

ns1:SistemaCNC8070 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070"@es ;
    ns1:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB"@es ;
    ns1:tieneComponente ns1:CarpetaMTB .

ns1:SistemaCNC_1231 a ns1:Sistema ;
    rdfs:label "Sistema CNC (gestión de subrutinas)" ;
    ns1:identificador "..\\Mtb\\Sub ; ..\\Users\\Sub" ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] el CNC siempre actualiza las subrutinas."@es ;
    ns1:tieneComponente ns1:InterfazSubrutinas_G8000-8999 .

ns1:SistemaCNC_Seccion6_1 a ns1:Sistema ;
    rdfs:label "Sistema CNC (Sección 6.1 - Señales de consulta generales)" ;
    ns1:activaAlarma ns1:Alarma_ColisionCNC ;
    ns1:textoExtracto "El canal del CNC desactiva esta marca (nivel '1') cuando se ha eliminado el mensaje del canal del CNC y ha desaparecido la causa de la alarma o emergencia. Para movimientos en automático, si el CNC detecta una colisión en un movimiento de posicionamiento o retirada dentro de un ciclo de palpador (o incluso fuera de éste), detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel '0')." .

ns1:SistemaCambioHerramientas_Brazo1Pinza a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (brazo 1 pinza)"@es ;
    ns1:ilustradoEn ns1:Figura_AlmacenCarruselBrazo1Pinza ;
    ns1:textoExtracto "El brazo extrae la herramienta del carrusel y la entrega al husillo; se aprecia la trayectoria de transferencia y la lógica de dos fases (T y M06)."@es .

ns1:SistemaCambioHerramientas_Brazo2Pinzas a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (brazo 2 pinzas)"@es ;
    ns1:ilustradoEn ns1:Figura_AlmacenCarruselBrazo2Pinzas ;
    ns1:textoExtracto "Dos mordazas para operaciones de toma y entrega en secuencia cruzada (pinza 1 ↔ cabezal, pinza 2 ↔ carrusel), minimizando el tiempo de intercambio."@es .

ns1:SistemaCambioHerramientas_CarruselSinBrazo a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (carrusel sin brazo)"@es ;
    ns1:ilustradoEn ns1:Figura_AlmacenCarruselSinBrazo ;
    ns1:textoExtracto "El plato de herramientas se orienta y acerca al husillo para transferir la herramienta directamente. Se sugiere el flujo en dos fases (T para preselección y M06 para el cambio)."@es .

ns1:SistemaCambioHerramientas_Torreta a ns1:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (torreta)"@es ;
    ns1:ilustradoEn ns1:Figura_AlmacenTorreta ;
    ns1:textoExtracto "Se destaca la herramienta activa alineada con el punto de trabajo. La composición apoya el texto sobre secuencia de cambio (giro de torreta) y la imposibilidad de cambiar durante el mecanizado, incluyendo el papel de T y M06."@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:monitoreaParametro ns1:Parametro_REFFEED1,
        ns1:Parametro_REFFEED2,
        ns1:Parametro_REFPULSE,
        ns1:Parametro_REFSHIFT,
        ns1:Parametro_REFVALUE ;
    ns1:textoExtracto "Cuando el sistema de captación no dispone de I0 codificado la búsqueda de referencia se ejecuta al avance indicado en REFFEED1 hasta que se pulsa el micro de referencia máquina, invierte el sentido a REFFEED2 y, tras despulsar el micro, continúa al avance indicado en REFFEED2 hasta que se recibe el impulso de I0 del sistema de captación.",
        "El sistema de captación no dispone de I0 codificado. [...] El sistema de captación dispone de I0 codificado y el eje utiliza la compensación de error husillo." .

ns1:SistemaCaptacionAbsoluta a ns1:Sistema ;
    rdfs:label "Sistema de captación absoluta"@es ;
    ns1:textoExtracto "cuando el sistema dispone de captación absoluta"@es ;
    ns1:tieneComponente ns1:Regulador,
        ns1:SistemaCNC .

ns1:SistemaCaptacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de captación de ejes (CNC)"@es ;
    ns1:textoExtracto "el CNC permite que ambos ejes utilicen la misma entrada de captación."@es ;
    ns1:tieneComponente ns1:CabezalLaser,
        ns1:ModuloContadoras_CANfagor,
        ns1:Modulo_RCS_S,
        ns1:Regulador_Sercos .

ns1:SistemaCaptacionExterna a ns1:Sistema ;
    rdfs:label "Sistema de captación externa"@es ;
    ns1:textoExtracto "ejes tándem [...] lo habitual es que el eje maestro vaya con captación externa y el eje esclavo con captación interna."@es .

ns1:SistemaCaptacionMotor a ns1:Sistema ;
    rdfs:label "Sistema de captación interna (motor)"@es ;
    ns1:textoExtracto "el CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos."@es ;
    ns1:tieneComponente ns1:ComponenteCaptacionMotor .

ns1:SistemaCaptacionRemota a ns1:Sistema ;
    rdfs:label "Sistema de captación remota CANfagor"@es ;
    ns1:monitoreaParametro ns1:Parametro_EntradaCaptacionEje ;
    ns1:textoExtracto "Entrada de captación en los módulos remotos CANfagor"@es ;
    ns1:tieneComponente ns1:ModuloContadoras_CANfagor .

ns1:SistemaCaptacionSinI0_1104 a ns1:Sistema ;
    rdfs:label "Sistema de captación sin I0s codificados"@es ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados."@es .

ns1:SistemaCaptacion_I0_Codificados a ns1:Sistema ;
    rdfs:label "Sistema de captación con I0s codificados" ;
    ns1:compuestoPor ns1:EjeEsclavo_Gantry,
        ns1:EjeMaestro_Gantry ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que dispone de I0s codificados" .

ns1:SistemaCaptacion_SinMicro a ns1:Sistema ;
    rdfs:label "Sistema de captación sin micros en ejes" ;
    ns1:compuestoPor ns1:EjeEsclavo_Gantry,
        ns1:EjeMaestro_Gantry ;
    ns1:textoExtracto "donde ningún eje dispone de micro" .

ns1:SistemaCartesiano_ZX a ns1:Sistema ;
    rdfs:label "Sistema cartesiano (Z-X)"@es ;
    ns1:textoExtracto "programar en el sistema cartesiano (Z-X)"@es .

ns1:SistemaCinematico a ns1:Sistema ;
    rdfs:label "Sistema de cinemática" ;
    ns1:textoExtracto "El resto de los ejes podrán ser rotativos o lineales, dependiendo del tipo de cinemática." ;
    ns1:tieneComponente ns1:Eje8,
        ns1:Ejes9ySiguientes,
        ns1:EjesLinealesCompensacion .

ns1:SistemaCinematicoTipo52 a ns1:Sistema ;
    rdfs:label "Sistema cinemático tipo 52 (cabezal–mesa)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:TDATA31,
        ns1:TDATA32,
        ns1:TDATA33,
        ns1:TDATA34,
        ns1:TDATA35,
        ns1:TDATA36 .

ns1:SistemaCinematico_Cabezal_Tipos17_24 a ns1:Sistema ;
    rdfs:label "Sistema cinemático del cabezal (tipos 17 a 24)"@es ;
    ns1:identificador "tipos 17-24" ;
    ns1:textoExtracto "Definición de las cinemáticas del cabezal (tipos 17 a 24)."@es ;
    ns1:tieneComponente ns1:EjeRotativoSecundario_Cabezal_Tipos17_24,
        ns1:EjeRotativoTerciario_Cabezal_Tipos17_24 .

ns1:SistemaComunicacionCNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC para funciones M" ;
    ns1:controla ns1:FuncionM100,
        ns1:FuncionM120,
        ns1:FuncionM135 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." ;
    ns1:tieneComponente ns1:RegistroMFUN1,
        ns1:RegistroMFUN2,
        ns1:RegistroMFUN3,
        ns1:RegistroMFUN4,
        ns1:RegistroMFUN5,
        ns1:RegistroMFUN6,
        ns1:RegistroMFUN7 .

ns1:SistemaComunicacionCNC_PLC_802 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC para señales modificables generales"@es ;
    ns1:textoExtracto "STROBE AUXEND MINAENDW 1 El canal del CNC indica al PLC en los registros MFUN y SFUN del canal las funciones que debe ejecutar y activa la marca MSTROBE o SSTROBE para que comience la ejecución. 2 El PLC, al detectar la activación de una de estas marcas, debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución. 3 Una vez ejecutadas las funciones auxiliares requeridas, el PLC debe activar la marca AUXEND para indicar al CNC que ha finalizado. La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro máquina MINAENDW. 4 Transcurrido dicho tiempo, el CNC desactiva la marca SSTROBE o MSTROBE correspondiente, dando por finalizada la ejecución."@es ;
    ns1:tieneComponente ns1:Marca_AUXEND_802,
        ns1:Marca_MSTROBE_802,
        ns1:Marca_SSTROBE_802,
        ns1:Marca_TIMERON_802,
        ns1:Parametro_MINAENDW_802,
        ns1:Variable_VPLC_TIMER_802 .

ns1:SistemaComunicacion_CNC_PLC_703 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC" ;
    ns1:controla ns1:InterfazUsuario_CNC_703 ;
    ns1:textoExtracto "El intercambio de información entre el CNC y el PLC permite: [...] La monitorización en la pantalla del CNC de los recursos del PLC."@es ;
    ns1:tieneComponente ns1:FuncionesAuxiliares_MHS_703,
        ns1:MarcasPLC_703,
        ns1:RegistrosPLC_703 .

ns1:SistemaConfiguracionEjes a ns1:Sistema ;
    rdfs:label "Configuración de ejes tipo 'plano'" ;
    ns1:compuestoPor ns1:FuncionG17,
        ns1:FuncionG18,
        ns1:FuncionG19,
        ns1:FuncionG20 ;
    ns1:documentadoEn ns1:TablaFuncionesG ;
    ns1:textoExtracto "Configuración de ejes tipo 'plano'. Programación de arcos. La programación del centro del arco I K depende del plano de trabajo activo.",
        "El eje longitudinal. En esta configuración se considera como eje longitudinal el segundo eje del canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX y el eje longitudinal el Z." .

ns1:SistemaControlAvance_PLC a ns1:Sistema ;
    rdfs:label "Sistema de control de avance (PLC)" ;
    ns1:monitoreaParametro ns1:ParametroImpulsosAnteriores_R101,
        ns1:ParametroImpulsosDesdeLectura_R102,
        ns1:ParametroImpulsosTotales_R100,
        ns1:ParametroPorcentajeAvance_R103 ;
    ns1:textoExtracto "Ejemplo de maniobra del PLC. La máquina dispone de un pulsador para activar y desactivar el volante de avance..." ;
    ns1:tieneComponente ns1:MarcaVolanteActivo_M1000,
        ns1:PulsadorVolanteAvance_I71,
        ns1:VolanteAvance .

ns1:SistemaControlCNC a ns1:Sistema ;
    rdfs:label "Sistema de control CNC" ;
    ns1:controla ns1:Se_alENABLE_Eje,
        ns1:Tecla_STOP_CNC ;
    ns1:textoExtracto "Esta marca no detiene el giro del cabezal. [...] Esta marca no desactiva el control del gap, excepto en el movimiento de aproximación.",
        "el CNC la pone a (=1) cada vez que quiere mover el eje" ;
    ns1:tieneComponente ns1:Senal_STOP,
        ns1:Senal_XFERINH .

ns1:SistemaControlCNC_828 a ns1:Sistema ;
    rdfs:label "Sistema de control CNC (gestión de servos y errores)"@es ;
    ns1:activaAlarma ns1:ErrorSeguimientoEje ;
    ns1:controla ns1:CondicionMovimientoEje ;
    ns1:textoExtracto "Al volver a controlarlo (SERVOON=1) vuelve a posición. ERROR"@es .

ns1:SistemaControlCNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema de control CNC-PLC" ;
    ns1:monitoreaParametro ns1:GEAR1,
        ns1:GEAR2,
        ns1:GEAR3,
        ns1:GEAR4,
        ns1:SenalAUXEND,
        ns1:SenalGEAROK ;
    ns1:textoExtracto "El PLC utiliza estas marcas para indicar al CNC cuál de las gamas del cabezal está seleccionada (=1). Cuando se solicita un cambio de gama, el CNC se lo indica al PLC mediante las funciones auxiliares M41, M42, M43 o M44." ;
    ns1:tieneComponente ns1:FuncionM41,
        ns1:FuncionM42,
        ns1:FuncionM43,
        ns1:FuncionM44 .

ns1:SistemaControlDMC a ns1:Sistema ;
    rdfs:label "Sistema de Control DMC (Fagor)" ;
    ns1:monitoreaParametro ns1:COMPID,
        ns1:DMCPEAKSIZE,
        ns1:DMCPOWERFACTOR,
        ns1:G_ADVCUTOFFT,
        ns1:G_ADVCUTOFFW ;
    ns1:textoExtracto "los gráficos STD (gráficos estándar Fagor) [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si..." ;
    ns1:tieneComponente ns1:ADVCUTOFF,
        ns1:DMCPWRHOLD,
        ns1:DMCPWRPEAK,
        ns1:KINCOMP1,
        ns1:KINCOMP2,
        ns1:KINCOMP3,
        ns1:KINCOMP4,
        ns1:KINCOMP5,
        ns1:KINCOMP6 .

ns1:SistemaControlEjeB a ns1:Sistema ;
    rdfs:label "Sistema de control del eje B" ;
    ns1:controla ns1:Se_alDRENAB,
        ns1:Se_alPARKEDB ;
    ns1:textoExtracto "El CNC reconocerá que se ha completado el proceso al detectar que se ha desactivado la señal PARKED. Se resetean las señales UNPARK y REFPOIN. En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)." ;
    ns1:tieneComponente ns1:SensorPresenciaEjeB .

ns1:SistemaControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ns1:monitoreaParametro ns1:Parametro_DWELL,
        ns1:Se_al_ACTFBACK_axis,
        ns1:Se_al_DEAD_axis,
        ns1:Se_al_SWITCH_axis,
        ns1:Se_al_TANDEMOFF_axis,
        ns1:SenalINHIBIT_axis ;
    ns1:textoExtracto "Para los ejes independientes y leva electrónica, si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula. El sistema permanece en espera hasta que se desactive la señal para reanudar la",
        "motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos." .

ns1:SistemaControlGapLaser a ns1:Sistema ;
    rdfs:label "Sistema de control del gap láser" ;
    ns1:controla ns1:ParametroGap ;
    ns1:textoExtracto "El control del gap permite mantener una distancia fija entre la boquilla del láser y la superficie de la chapa. Esta distancia la calcula un sensor conectado al CNC, de manera que éste compensará las variaciones del sensor sobre la distancia programada con movimientos adicionales en el eje longitudinal." ;
    ns1:tieneComponente ns1:SensorGapLaser .

ns1:SistemaControlTandem a ns1:Sistema ;
    rdfs:label "Sistema de control del eje tándem"@es ;
    ns1:compuestoPor ns1:ControlNumericoTandem,
        ns1:LazoPosicionTandem,
        ns1:LazoVelocidadTandem,
        ns1:ReguladorTandem ;
    ns1:detalladoEnEsquema ns1:DiagramaBloquesTandem_11_2_3 ;
    ns1:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo. [...] Control del eje tándem."@es ;
    ns1:tieneComponente ns1:MotorEsclavoTandem,
        ns1:MotorMaestroTandem .

ns1:SistemaControl_667 a ns1:Sistema ;
    rdfs:label "Sistema de control de consultas CNCRD/CPS"@es ;
    ns1:monitoreaParametro ns1:Parametro_R11,
        ns1:Parametro_R12 ;
    ns1:textoExtracto "Ejemplo de acceso a variables asíncronas [...] Ejemplos de acceso a variables síncronas [...]"@es ;
    ns1:tieneComponente ns1:ConsultaAsincrona_M11,
        ns1:ConsultaSincrona_M12,
        ns1:Parametro_R11,
        ns1:Parametro_R12 .

ns1:SistemaEjeTandem_PinonesCremallera a ns1:Sistema ;
    rdfs:label "Sistema de eje tándem con piñones y cremallera"@es ;
    ns1:compuestoPor ns1:Cremallera_Tandem,
        ns1:MotorEsclavo_Tandem,
        ns1:MotorMaestro_Tandem ;
    ns1:ilustradoEn ns1:Pagina_572 ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera. Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera."@es .

ns1:SistemaEjesCNC a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales (CNC/PLC)" ;
    ns1:controla ns1:ModoLazoCerrado_G63,
        ns1:ModoLazoCerrado_G74,
        ns1:ModoLazoCerrado_M19 ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que va a mover el eje o cabezal correspondiente en lazo cerrado, de manera que el PLC habilita el eje o cabezal si es necesario." ;
    ns1:tieneComponente ns1:SenalDIR,
        ns1:SenalENABLE,
        ns1:SenalINPOS,
        ns1:Senal_FEEDHOL .

ns1:SistemaEjesCabezales_86 a ns1:Sistema ;
    ns1:compuestoPor ns1:CabezalLogico_4_86,
        ns1:EjeLogico_1_86,
        ns1:EjeLogico_2_86,
        ns1:EjeLogico_3_86 ;
    ns1:detalladoEnEsquema ns1:TablaConfiguracionCabezales_86 ;
    ns1:textoExtracto "sistema con 3 ejes" .

ns1:SistemaEjesGantry_69 a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry"@es ;
    ns1:compuestoPor ns1:EjeGantryEsclavo_U_69,
        ns1:EjeGantryEsclavo_W_69,
        ns1:EjeGantryMaestro_X_69,
        ns1:EjeGantryMaestro_Z_69 ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry_69 ;
    ns1:textoExtracto "Se denomina eje gantry a una pareja de ejes que por construcción de la máquina deben desplazarse a la vez y de forma sincronizada."@es .

ns1:SistemaEjesNoOrtogonales a ns1:Sistema ;
    rdfs:label "Sistema de ejes no ortogonales (X, X', Z)"@es ;
    ns1:textoExtracto "Incluye rotulación 'X', 'X'' y 'Z' junto a la ilustración [...] destacando el concepto de ejes no ortogonales."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_HusilloHerramienta,
        ns1:Parametro_ANGANTR,
        ns1:Parametro_OFFANGAX .

ns1:SistemaEjesPrincipales a ns1:Sistema ;
    rdfs:label "Sistema de ejes principales (X, Y, Z) y rotativos (A, B, C)"@es ;
    ns1:documentadoEn ns1:Seccion2_9_2_DefinicionCinematicasCabezal ;
    ns1:textoExtracto "los ejes principales son X Y Z y los rotativos asociados a los mismos A, B, C"@es .

ns1:SistemaEjesTorno_1048 a ns1:Sistema ;
    rdfs:label "Sistema de ejes y cabezales (3 canales, 6 ejes, 2 cabezales)"@es ;
    ns1:compuestoPor ns1:Cabezal_S1_1048,
        ns1:Cabezal_S_1048,
        ns1:Eje_U_1048,
        ns1:Eje_V_1048,
        ns1:Eje_X1_1048,
        ns1:Eje_X_1048,
        ns1:Eje_Z1_1048,
        ns1:Eje_Z_1048 ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionEjesTorno_1048 ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ1ꞏ y ꞏ2ꞏ en torno de 3 canales, 6 ejes y 2 cabezales."@es .

ns1:SistemaEjes_CNC a ns1:Sistema ;
    rdfs:label "Sistema de ejes del canal CNC (configuración por planos)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionEjesCNC ;
    ns1:textoExtracto """\r
Configuración de ejes tipo 'plano'. Esta configuración dispone de dos ejes formando el habitual plano de trabajo en torno.\r
Puede haber más ejes, pero no pueden formar parte del triedro; deberán ser ejes auxiliares, rotativos, etc.\r
"""@es ;
    ns1:tieneComponente ns1:ModoOperacion_G17,
        ns1:ModoOperacion_G18,
        ns1:ModoOperacion_G19 .

ns1:SistemaEntradasAnalogicas_RIO5 a ns1:Sistema ;
    rdfs:label "Sistema de entradas analógicas RIO5" ;
    ns1:identificador "address = 1" ;
    ns1:textoExtracto "address = 1) RIO5 - Entradas analógicas. - 1..4 - Entradas PT100. - 5..6" ;
    ns1:tieneComponente ns1:SensorPT100_5,
        ns1:SensorPT100_6 .

ns1:SistemaEntradasAnalogicas_RIOR a ns1:Sistema ;
    rdfs:label "Sistema de entradas analógicas RIOR" ;
    ns1:identificador "address = 2" ;
    ns1:textoExtracto "address = 2) RIOR - Entradas analógicas. - 7..8 - Entradas PT100. - 9..10" ;
    ns1:tieneComponente ns1:SensorPT100_9 .

ns1:SistemaEntradasSalidasCNC a ns1:Sistema ;
    rdfs:label "Sistema de entradas y salidas físicas/lógicas del CNC" ;
    ns1:textoExtracto "Se denominan entradas y salidas físicas del CNC al conjunto de entradas y salidas del sistema que, siendo gobernadas por el PLC, se comunican con el exterior a través de los conectores del CNC. El CNC dispone además de una serie de entradas y salidas lógicas para el intercambio de información interna con las marcas y registros del PLC." ;
    ns1:tieneComponente ns1:ConectoresCNC,
        ns1:SenalesLogicasCNC .

ns1:SistemaGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry" ;
    ns1:textoExtracto "En los ejes gantry, la compensación se define para el eje maestro y el CNC la aplica también al eje esclavo." ;
    ns1:tieneComponente ns1:EjeEsclavo_Gantry,
        ns1:EjeMaestro_Gantry .

ns1:SistemaGantryTandem a ns1:Sistema ;
    rdfs:label "Sistema de arquitectura gantry con precarga en tándem"@es ;
    ns1:ilustradoEn ns1:EsquemaPrecargaTandem ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. [...] Diagrama con flechas que indican aceleración hacia la derecha; el piñón maestro aplica mayor par motor, mientras el esclavo compensa con par opuesto para mantener la tensión mecánica y minimizar el juego durante el arranque."@es ;
    ns1:tieneComponente ns1:CremalleraGantry,
        ns1:MotorEsclavoGantry,
        ns1:MotorMaestroGantry,
        ns1:PinonEsclavoGantry,
        ns1:PinonMaestroGantry,
        ns1:ReductorEsclavoGantry,
        ns1:ReductorMaestroGantry .

ns1:SistemaGantry_1109 a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry (maestro-esclavo)"@es ;
    ns1:controla ns1:ProcesoReferenciadoEjesGantry_1109 ;
    ns1:textoExtracto "ejes gantry"@es ;
    ns1:tieneComponente ns1:EjeEsclavo_1109,
        ns1:EjeMaestro_1109 .

ns1:SistemaIO_PLC a ns1:Sistema ;
    rdfs:label "Sistema de E/S locales del PLC" ;
    ns1:textoExtracto "Se denominan entradas y salidas locales porque se encuentran en la unidad central y no en los módulos remotos." ;
    ns1:tieneComponente ns1:EntradasLocalesPLC,
        ns1:SalidasLocalesPLC .

ns1:SistemaInterrupcionesPLC a ns1:Sistema ;
    rdfs:label "Sistema de interrupciones del PLC" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. [...] Si el PLC activa una de estas marcas, el canal interrumpe la ejecución del programa y ejecuta la subrutina de interrupción correspondiente" ;
    ns1:tieneComponente ns1:CanalINT1,
        ns1:CanalINT4,
        ns1:SubrutinaINT1SUB,
        ns1:SubrutinaINT4SUB .

ns1:SistemaMonitorizacionPalpadores a ns1:Sistema ;
    rdfs:label "Sistema de monitorización de palpadores CNC" ;
    ns1:activaAlarma ns1:AlarmaCaptacionLocal1,
        ns1:AlarmaCaptacionLocal2 ;
    ns1:monitoreaParametro ns1:ParametroFBACKAL ;
    ns1:textoExtracto "Monitorización a nivel de lazo, controlando todas las situaciones de colisión en cualquiera de los dos palpadores. El CNC puede monitorizar los palpadores conectados a las entradas locales y a las entradas remotas CAN. El CNC monitoriza las 2 entradas de palpador a la vez." ;
    ns1:tieneComponente ns1:EntradaLocal1,
        ns1:EntradaLocal2,
        ns1:EntradasRemotasCAN .

ns1:SistemaMulticabezal a ns1:Sistema ;
    rdfs:label "Sistema de opción multicabezal y canales"@es ;
    ns1:textoExtracto "Particularidades con la opción multicabezal y canales"@es ;
    ns1:tieneComponente ns1:Comando_HFUNC1,
        ns1:Comando_HFUNC2,
        ns1:Comando_HFUNC3,
        ns1:Comando_HFUNC4 .

ns1:SistemaMulticabezalCNC a ns1:Sistema ;
    rdfs:label "Sistema multicabezal con canales paralelos"@es ;
    ns1:identificador "Opción multicabezal y canales" ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro canales y cada canal puede ejecutar un programa pieza en paralelo con los demás. Esto significa que en cada canal se pueden ejecutar siete funciones auxiliares simultáneamente."@es ;
    ns1:tieneComponente ns1:CanalCNC_1,
        ns1:CanalCNC_2,
        ns1:CanalCNC_3,
        ns1:CanalCNC_4 .

ns1:SistemaMultieje_1092 a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes (A1 y A2)"@es ;
    ns1:compuestoPor ns1:EjeA1_1092,
        ns1:EjeA2_1092,
        ns1:ReguladorMultieje_1092 ;
    ns1:detalladoEnEsquema ns1:EsquemaConfiguracion_1092 ;
    ns1:textoExtracto "Ejemplo 1. Sistema con dos ejes, cada uno con su motor. El sistema tiene las siguientes características. • Un único regulador controla dos ejes, cada uno con su motor."@es .

ns1:SistemaNoProtegidoEscritura a ns1:Sistema ;
    rdfs:label "Sistema sin disco protegido contra escritura" ;
    ns1:documentadoEn ns1:Pagina43 ;
    ns1:textoExtracto "Sistema sin disco protegido contra escritura. Las modificaciones de la configuración en un CNC sin disco protegido contra escritura son permanentes." ;
    ns1:tieneComponente ns1:DialogoCopiaSeguridad .

ns1:SistemaNumeracionE_S a ns1:Sistema ;
    rdfs:label "Sistema de numeración de entradas/salidas físicas" ;
    ns1:monitoreaParametro ns1:ParametroIndiceBase ;
    ns1:textoExtracto "Desde los parámetros máquina se puede personalizar la numeración de los módulos de entradas y salidas. Si no se definen estos parámetros, el CNC numera los módulos automáticamente según el orden de los módulos remotos." ;
    ns1:tieneComponente ns1:ModuloPersonalizado1,
        ns1:ModuloPersonalizado2,
        ns1:ModuloPersonalizado3,
        ns1:ModuloPersonalizado4,
        ns1:ModuloRemotoGrupo1,
        ns1:ModuloRemotoGrupo2,
        ns1:ModuloRemotoGrupo3 .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "PLC"@es,
        "Sistema PLC"@es ;
    ns1:controla ns1:Comando_CAM_ON ;
    ns1:textoExtracto "PLC"@es,
        "el cual se puede cargar desde el [...] PLC. Al ejecutar una leva desde un archivo, el CNC lee sus datos de manera dinámica"@es .

ns1:SistemaPLC_Compilacion a ns1:Sistema ;
    rdfs:label "Sistema de compilación de programas PLC con integración de subrutinas en C" ;
    ns1:textoExtracto "Cada vez que el PLC compila un programa con subrutinas en lenguaje C, genera el archivo plc_pdef.h con los #define de todos los símbolos definidos en el programa PLC." ;
    ns1:tieneComponente ns1:Archivo_plc_pdef_h .

ns1:SistemaPanelesJog a ns1:Sistema ;
    rdfs:label "Sistema de paneles Jog"@es ;
    ns1:compuestoPor ns1:Parametro_JOGKEYBD2DEF,
        ns1:Parametro_JOGKEYBD3DEF,
        ns1:Parametro_JOGKEYBD4DEF,
        ns1:Parametro_JOGKEYBD5DEF,
        ns1:Parametro_JOGKEYBD6DEF,
        ns1:Parametro_JOGKEYBD7DEF,
        ns1:Parametro_JOGKEYBD8DEF,
        ns1:Parametro_JOGKEYDEF,
        ns1:Parametro_KEYBD1CH,
        ns1:Parametro_KEYBD2CH,
        ns1:Parametro_KEYBD3CH,
        ns1:Parametro_KEYBD4CH,
        ns1:Parametro_KEYBD5CH,
        ns1:Parametro_KEYBD6CH,
        ns1:Parametro_KEYBD7CH,
        ns1:Parametro_KEYBD8CH,
        ns1:Parametro_NKEYBD ;
    ns1:textoExtracto "Primer panel de mando del sistema. [...] Tercer panel de mando del sistema."@es ;
    ns1:tieneComponente ns1:CNC_PanelMando1,
        ns1:IOsRemotas1,
        ns1:IOsRemotas2,
        ns1:IOsRemotas3,
        ns1:JogPanel1,
        ns1:JogPanel2,
        ns1:JogPanel3 .

ns1:SistemaPlanoTrabajo_G18_1023 a ns1:Sistema ;
    rdfs:label "Sistema de plano de trabajo G18 (Canal 1, Ejes X-Z)"@es ;
    ns1:compuestoPor ns1:EjeX_Canal1_1023,
        ns1:EjeZ_Canal1_1023 ;
    ns1:documentadoEn ns1:Pagina_561_562 ;
    ns1:textoExtracto """\r
Selección de planos en el canal ꞏ1ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal: X (primer eje) y Z (segundo eje). El plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas.\r
"""@es .

ns1:SistemaProteccionEscritura_CNC a ns1:Sistema ;
    rdfs:label "Sistema de protección contra escritura del CNC" ;
    ns1:controla ns1:CNC8070_Software ;
    ns1:textoExtracto "Fagor entrega el equipo con el disco protegido frente a escritura, excepto aquellas carpetas o archivos que deben estar desprotegidos para el funcionamiento habitual del CNC." .

ns1:SistemaProtegidoEscritura a ns1:Sistema ;
    rdfs:label "Sistema con disco protegido contra la escritura" ;
    ns1:documentadoEn ns1:Pagina43 ;
    ns1:textoExtracto "Sistema con disco protegido contra la escritura." ;
    ns1:tieneComponente ns1:DialogoFinalizacionPuestaPunto,
        ns1:ModoSetup,
        ns1:ModoUsuario .

ns1:SistemaRIO5_ConfiguracionIO a ns1:Sistema ;
    rdfs:label "Configuración de E/S para módulos RIO5"@es ;
    ns1:textoExtracto """\r
    Cada módulo RIO5 se debe configurar como un bloque lógico.\r
    Se desea configurar cada nodo RIO5 de la siguiente manera:\r
    • El primer nodo RIO5 como un bloque de 24 entradas a partir de la I1.\r
    • El segundo nodo RIO5 como tres bloques de 24 entradas a partir de la I49, I73 e I97.\r
    • El tercer nodo RIO5 como dos bloques de 24 entradas a partir de la I257 e I129.\r
    """@es ;
    ns1:tieneComponente ns1:NodoRIO5_1,
        ns1:NodoRIO5_2,
        ns1:NodoRIO5_3,
        ns1:Parametro_NDIMOD .

ns1:SistemaSe_alesCabezales a ns1:Sistema ;
    rdfs:label "Sistema de señales modificables de los cabezales" ;
    ns1:textoExtracto "Señales modificables de los cabezales. SLIMITACSPDL Hay una marca para cada cabezal." ;
