    ns1:identificador "RESETIN" ;
    ns1:monitoreaParametro ns1:ProcesoResetCNC ;
    ns1:textoExtracto "el PLC activa la marca RESETIN. Una vez iniciado el reset, el PLC puede desactivar esta marca (RESETIN=0)" ;
