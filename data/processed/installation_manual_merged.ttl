ns1:Parametro_ConfigEjeZ a ns1:Parametro ;
    rdfs:label "Configuración del sentido del eje Z"@es ;
    ns1:documentadoEn ns1:Tabla_2.3.31_ControlGap ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales) [...] El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido)."@es ;
    ns1:valor "Sí/No"@es .

ns1:Parametro_ConfiguracionPalpador_140 a ns1:Parametro ;
    rdfs:label "Parámetro de configuración del palpador"@es ;
    ns1:identificador "Configuración_Palpador" ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada a la que está conectado el palpador."@es .

ns1:Parametro_ConsignaAnalogica_Sercos a ns1:Parametro ;
    rdfs:label "Gestión de la consigna analógica desde los reguladores Sercos"@es ;
    ns1:monitoreaParametro ns1:ModuloSalidasAnalogicas_226_228 ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos. En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar."@es .

ns1:Parametro_ConstanteTiempoMezclaCaptaciones a ns1:Parametro ;
    rdfs:label "Constante de tiempo para mezcla de captaciones"@es ;
    ns1:textoExtracto "Este parámetro permite definir la constante de tiempo a utilizar en la mezcla de captaciones; es decir, determina el retraso entre las cotas que se introducen al lazo de posición del encóder y de la regla. El CNC sólo tiene en cuenta este parámetro cuando la captación es externa o externa+interna."@es ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_ControlPI_276 a ns1:Parametro ;
    rdfs:label "Control PI (proporcional-integral)" ;
    ns1:monitoreaParametro ns1:ReguladorMechatrolink_276 ;
    ns1:textoExtracto "elegir un control P o PI para el lazo de velocidad" .

ns1:Parametro_ControlP_276 a ns1:Parametro ;
    rdfs:label "Control P (proporcional)" ;
    ns1:monitoreaParametro ns1:ReguladorMechatrolink_276 ;
    ns1:textoExtracto "elegir un control P o PI para el lazo de velocidad" .

ns1:Parametro_CoordenadasPiezaFija a ns1:Parametro ;
    rdfs:label "Parámetro de sistema de coordenadas pieza fija/rotatoria" ;
    ns1:controla ns1:ModoOperacion_RTCP ;
    ns1:textoExtracto "este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina" .

ns1:Parametro_CorrectorOffset_NCUTTERS a ns1:Parametro ;
