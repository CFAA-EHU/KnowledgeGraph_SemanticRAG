ns1:Tabla_CalculoTDATA2 a ns1:Tabla ;
    rdfs:label "Fórmula de cálculo para TDATA2" ;
    ns1:ilustradoEn ns1:Parametro_TDATA2 ;
    ns1:textoExtracto "TDATA2 = 0,5·ΔZ – TDATA5" .

ns1:Tabla_CalculoTDATA5 a ns1:Tabla ;
    rdfs:label "Tabla de cálculo de TDATA5" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "| Solución. | | --- | --- | | TDATA5 = 0,5 × ΔZ |" .

ns1:Tabla_CalculoTDATA6 a ns1:Tabla ;
    rdfs:label "Fórmula de cálculo para TDATA6" ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "TDATA6 = (ΔX + ΔX' – D – 2L – 2TDATA1) / (2·cos45)" .

