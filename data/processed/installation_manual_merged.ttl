ns1:Parametro_ESTDELAY a ns1:Parametro ;
    rdfs:label "ESTDELAY",
        "ESTDELAY (Tiempo de vigilancia de tendencia)"@es ;
    ns1:identificador "(V.)[ch].MPA.ESTDELAY[set].xn",
        "ESTDELAY" ;
    ns1:monitoreaParametro ns1:Sensor_FollowingError ;
    ns1:textoExtracto "ESTDELAY Retardo del error de seguimiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0.",
        "Una marca horizontal 'ESTDELAY' señala el retardo recomendado para alinear 'Theoretical Following Error' y 'Real Following Error' y evitar falsas alarmas (incluida protección antiembalamiento).",
        "vigila que el sentido real de movimiento coincida con el teórico, a partir del tiempo parametrizado en el parámetro ESTDELAY. [...] detecta si el eje se mueve en un sentido durante más tiempo que el indicado en el parámetro ESTDELAY."@es ;
    ns1:valor "0-1000000_ms" .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
