    ns1:textoExtracto "El palpador 2 será el asignado al parámetro PRBDI2.",
        "PRBDI2 Número de entrada asociada al palpador 2. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado). Variable asociada: (V.)MPG.PRBDI2",
        "el palpador 2 será el asignado al parámetro PRBDI2",
        "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es,
        "Número de entrada asociada al palpador 2."@es ;
    ns1:valor "0" .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (PROGAIN)",
        "PROGAIN",
        "PROGAIN (Ganancia proporcional)",
        "Ganancia proporcional (PROGAIN)"@es,
        "PROGAIN"@es ;
    ns1:identificador "PROGAIN" ;
    ns1:monitoreaParametro ns1:Sensor_ErrorSeguimiento,
        ns1:Sistema_ControlPosicion ;
    ns1:textoExtracto "PROGAIN Ganancia proporcional. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0.0 a 100.0 (1000/min). Valor por defecto: 1. Variable asociada: (V.)[ch].MPA.PROGAIN[set].xn Este parámetro fija el error de seguimiento (diferencia entre la cota teórica instantánea y la posición real del eje) que se desea obtener para un determinado avance.",
        "Programmed FFGAIN Feedrate ε Analog Nominal PROGAIN output Position Actual position",
        "ajuste de la ganancia proporcional (PROGAIN)",
        "Analog Nominal PROGAIN output"@es,
        "De estos movimientos se obtendrán los parámetros GAPGAIN, PROGAIN, FFGAIN y ACFGAIN."@es,
        "útil para visualizar el ajuste de la ganancia proporcional (PROGAIN)."@es ;
    ns1:valor "1",
        "PROGAIN" .

