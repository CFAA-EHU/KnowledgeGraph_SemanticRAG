    ns1:valor "No" .

ns1:DMC_1338 a ns1:Sistema ;
    rdfs:label "DMC"@es ;
    ns1:activaAlarma ns1:Aviso3103_1338 ;
    ns1:monitoreaParametro ns1:ParametroPotenciaObjetivo_1338,
        ns1:ParametroPotenciaVacio_1338 ;
    ns1:textoExtracto "Para garantizar un funcionamiento correcto del DMC, la potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío. Si el DMC detecta una situación de este tipo, muestra el aviso 3103."@es .

ns1:DMC_1339 a ns1:Sistema ;
    rdfs:label "Sistema DMC (Dynamic Milling Control)"@es ;
    ns1:activaAlarma ns1:AvisoColision_3101_1339,
        ns1:AvisoHerramientaDesgastada_3100_1339 ;
    ns1:monitoreaParametro ns1:PotenciaConsumida_1339 ;
    ns1:textoExtracto "vacío y la potencia objetivo durante el mecanizado son parecidos, es posible que el DMC no pueda distinguir con exactitud las entradas y salidas de la pieza, o que detecte falsas entradas o salidas. [...] Vigilancia de la potencia consumida. Durante el funcionamiento, el DMC vigila continuamente la potencia consumida por el cabezal, para detectar problemas con la herramienta o en el mecanizado."@es .

ns1:DTIME a ns1:Parametro ;
    rdfs:label "DTIME" ;
    ns1:identificador "DTIME" ;
    ns1:textoExtracto "Consultar el parámetro máquina general TTIME.",
        "DTIME Tiempo estimado para una función D. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ns1:valor 0 .

ns1:DeceleracionM19_264 a ns1:ModoOperacion ;
    rdfs:label "Deceleración por M19" ;
    ns1:requiereMantenimiento ns1:BusquedaCero_264 ;
    ns1:textoExtracto "Si está girando en M03 ó M04 y se programa M19, el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero."@es .

ns1:DiagramaCambioGamaGEAR1_GEAR2 a ns1:Esquema ;
    rdfs:label "Diagrama temporal de cambio de gama (GEAR1→GEAR2)"@es ;
    ns1:detalladoEnEsquema ns1:SeccionEntradasSalidasCNC ;
    ns1:textoExtracto "Diagrama temporal de cambio de gama (GEAR1→GEAR2) con señales MFUN, MSTROBE, AUXEND, indicadores GEAR1/GEAR2, pista 'CHANGE' y referencia MINAENDW. Describe la secuencia: solicitud M4x, comienzo/fin de cambio (AUXEND), confirmación de gama y liberación del strobe."@es .

ns1:DiagramaCompensacionCruzada_2_3_16 a ns1:Esquema ;
    rdfs:label "Diagrama de compensación cruzada MOVAXIS-COMPAXIS"@es ;
    ns1:ilustradoEn ns1:Pagina_77 ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS). El gráfico representa un volumen/carcasa con el eje maestro desplazándose; se señalan posiciones discretas 'POSITION n' y el error asociado 'POSERROR n'."@es .

ns1:DiagramaEstadosServoEnable a ns1:Esquema ;
    rdfs:label "Diagrama de estados para SERVOON/ENABLE"@es ;
    ns1:ilustradoEn ns1:SeccionEntradasSalidasCNC ;
    ns1:textoExtracto "Diagrama de estados para SERVOON/ENABLE con trazas 'Velocity Command', ventanas de DWELL y condición de ERROR. Expone la lógica de habilitación del regulador, la espera configurada por DWELL y el disparo de error si no se cumple la condición de servo activo antes del movimiento."@es .

ns1:DiagramaOscilacionCabezalPLC a ns1:Esquema ;
    rdfs:label "Diagrama temporal de oscilación del cabezal controlada por PLC"@es ;
    ns1:detalladoEnEsquema ns1:SeccionEntradasSalidasCNC ;
    ns1:textoExtracto "Diagrama temporal de oscilación del cabezal controlada por PLC durante cambio de gama, con trazas MFUN, MSTROBE, AUXEND, GEAR1/GEAR4 y señales SANALOG/PLCCNTL. Representa conmutación de control al PLC, consigna analógica residual y devolución del control al CNC."@es .

ns1:Diagrama_PrimeraPalpacion_707 a ns1:Figura ;
    rdfs:label "Diagrama 'Primera palpación' (B=0°, C=0°)" ;
    ns1:ilustradoEn ns1:Sistema_CabezalAngular_706 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara Z y preselección Z=0; flechas indican sentido de palpación y referencias OT y ejes Y-Z" .

ns1:Diagrama_Reset_439 a ns1:Figura ;
    rdfs:label "Diagrama temporal 'Proceso de reset con RESETIN'"@es ;
    ns1:ilustradoEn ns1:Sistema_Reset_PLC_439 ;
    ns1:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t. Muestra flancos de subida/bajada, orden de eventos y la relación entre marcas del PLC y respuesta del canal durante el reset."@es .

ns1:Diagrama_Sincronizacion_439 a ns1:Figura ;
    rdfs:label "Diagrama de sincronización AUXEND/MSTROBE"@es ;
    ns1:ilustradoEn ns1:Sistema_Sincronizacion_AUX_439 ;
    ns1:textoExtracto "Diagrama de sincronización AUXEND/MSTROBE con eje temporal y marcas numeradas (1–4) asociado a la ejecución de funciones auxiliares S/M. Representa la desactivación/activación de AUXEND respecto a STROBE y el tiempo mínimo MINAENDW para finalizar la sincronización."@es .

ns1:Diagrama_TemporizacionDWELL a ns1:Figura ;
    rdfs:label "Diagrama temporal de temporización DWELL para ejes muertos"@es ;
    ns1:textoExtracto "Diagrama temporal que alinea las señales SERVOON y ENABLE con la 'Velocity Command', marcando el intervalo DWELL. Ilustra la secuencia de quitar freno, habilitar regulador y retardar el inicio de movimiento en ejes 'muertos', útil en ejes verticales pesados o tándem."@es .

ns1:DialogoConexionFagorCNCTCP a ns1:InterfazUsuario ;
    rdfs:label "Diálogo 'Connections → FagorCNCTCP → Edit' en OpenPCS"@es ;
    ns1:documentadoEn ns1:InterfazOpenPCSRemoto ;
    ns1:textoExtracto "(Elemento 1) Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'."@es .

ns1:DirectivaVersionCNC_8060 a ns1:Directiva ;
    rdfs:label "Versión V1.60 (8060)" ;
    ns1:identificador "V1.60 (8060)" ;
    ns1:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas" .

ns1:DirectivaVersionCNC_8065 a ns1:Directiva ;
    rdfs:label "Versión V5.60 (8065)" ;
    ns1:identificador "V5.60 (8065)" ;
    ns1:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas" .

ns1:Directiva_IMA a ns1:Directiva ;
    rdfs:label "IMA",
        "Directiva IMA"@es ;
    ns1:identificador "IMA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen.",
        "sobre la forma en que debe ejecutarse el mismo (IMA)"@es .

ns1:Directiva_NOMONIT a ns1:Directiva ;
    rdfs:label "Directiva NOMONIT",
        "Directiva NOMONIT para deshabilitar monitorización en PLC",
        "NOMONIT" ;
    ns1:identificador "NOMONIT" ;
    ns1:textoExtracto "NOMONIT No monitorización.",
        "NOMONIT No monitorización. Cuando se programa esta directiva no se genera la información necesaria para la monitorización del programa de PLC.",
        "NOMONIT No monitorización. Cuando se programa esta directiva no se genera la información necesaria para la monitorización del programa de PLC. Es decir, que no se dispone de monitorización del programa. Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ns1:Directiva_PE_t a ns1:Directiva ;
    rdfs:label "PE t" ;
    ns1:documentadoEn ns1:Manual_EstructuraModularPLC ;
    ns1:identificador "PE t" ;
    ns1:textoExtracto "PE t Módulo periódico. Se ejecuta cada t milisegundos." .

ns1:Directiva_ProgramacionInicial a ns1:Directiva ;
    rdfs:label "Directiva de programación inicial" ;
    ns1:identificador "Directiva_ProgramacionInicial" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt. Se aconseja utilizar esta directiva cuando el tiempo de ejecución del programa de PLC es muy crítico. Definirla tras depurar el programa de PLC." .

ns1:Directiva_REA a ns1:Directiva ;
    rdfs:label "REA",
        "Directiva REA"@es ;
    ns1:identificador "REA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen.",
        "sobre la forma en que debe ejecutarse el mismo (REA)"@es .

ns1:Directorio_CNC8070_USERS a ns1:Componente ;
    rdfs:label "Directorio CNC8070\\USERS"@es ;
    ns1:identificador "CNC8070\\USERS" ;
    ns1:textoExtracto "los resultados del software, programas generados, etc deberán guardarse en un directorio desprotegido, por ejemplo CNC8070\\USERS."@es .

ns1:DistribucionParTandem a ns1:Parametro ;
    rdfs:label "Distribución de par del eje tándem"@es ;
    ns1:textoExtracto "Ganancia de normalización de los pares generados por los motores cuyo fin es establecer un reparto de pares que no siga una relación 1:1."@es ;
    ns1:valor "Ganancia de normalización"@es .

ns1:ENABLEPWM_Marca a ns1:Parametro ;
    rdfs:label "Marca ENABLEPWM" ;
    ns1:habilitadoPor ns1:PWM_Control ;
    ns1:textoExtracto "ENABLEPWM El PLC activa esta marca (cambio de 1 a 0) para habilitar el PWM activo en el CNC; si no hay un PWM activo, esta marca no hace nada." .

ns1:ENABLEPWRDUTY_Marca a ns1:Parametro ;
    rdfs:label "Marca ENABLEPWRDUTY" ;
    ns1:habilitadoPor ns1:PWM_Control ;
    ns1:textoExtracto "ENABLEPWRDUTY Marca activa por defecto. Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY]). El PLC desactiva esta marca para deshabilitar el control de duty activo." .

ns1:ENABLEPWROUT_Marca a ns1:Parametro ;
    rdfs:label "Marca ENABLEPWROUT" ;
    ns1:habilitadoPor ns1:PWM_Control ;
    ns1:textoExtracto "ENABLEPWROUT Marca activa por defecto. Esta marca está asociada al control de potencia a través de la salida analógica asociada al cabezal (#PWRCTRL ON [OUT]). El PLC desactiva esta marca para deshabilitar el control de potencia activo." .

ns1:EXTMULT_Parametro a ns1:Parametro ;
    rdfs:label "EXTMULT" ;
    ns1:textoExtracto "uso de ABSOFF y EXTMULT en la referencia"@es ;
    ns1:valor "EXTMULT" .

ns1:EjeC_MecanizadoDiametral a ns1:ComponenteMecanico ;
    rdfs:label "Eje C para alineación diametral"@es ;
    ns1:documentadoEn ns1:Pagina_117 ;
    ns1:textoExtracto "Secuencia 'ALIGNC = Sí' [...] giro de 180° del eje C y retroceso para completar el mecanizado, indicando la necesidad de reorientar el eje para cubrir todo el diámetro."@es .

ns1:EjeControlGap a ns1:ComponenteMecanico ;
    rdfs:label "Eje que controla el gap"@es ;
    ns1:controla ns1:SensorGap ;
    ns1:monitoreaParametro ns1:Parametro_ACFGAIN,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_GAPGAIN,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "El eje que controla el gap no debe ajustarse del modo estándar, sino que se hará con movimientos de aproximación con el control de gap activo."@es .

ns1:EjeEsclavo_SLAVE a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo (SLAVE) para compensación láser"@es ;
    ns1:ilustradoEn ns1:Esquema_CompensacionDispersionLaserCO2 ;
    ns1:textoExtracto "eje esclavo (SLAVE) [...] desplazamiento del eje esclavo para mantener constante la longitud del haz, minimizando variaciones en el punto de corte."@es .

