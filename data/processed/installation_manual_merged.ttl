ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID",
        "DRIVEID (Dirección del regulador Sercos)",
        "DRIVEID (dirección Sercos)",
        "DRIVEID"@es ;
    ns1:documentadoEn ns1:GrupoMultieje_Sercos,
        ns1:Tabla_MLINKDATA,
        ns1:Tabla_SERCOSDATA ;
    ns1:identificador "DRIVEID",
        "V.[ch].MPA.DRIVEID.xn" ;
    ns1:textoExtracto "DRIVEID Dirección del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro indica la posición (nodo) que ocupa el regulador en la conexión Sercos.",
        "DRIVEID Dirección del regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink. Valores posibles: De 1 a 14 (Mlink-I) / De 1 a 30 (Mlink-II). Valor por defecto: 1.",
        "todos los ejes de un grupo deben tener la misma dirección Sercos (parámetro DRIVEID)",
        "Dirección del regulador Sercos."@es,
        "Dirección del regulador."@es ;
    ns1:valor 1,
        "1" .

