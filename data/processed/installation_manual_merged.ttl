    rdfs:label "Subrutina asociada a función M" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "Las subrutinas asociadas a las funciones M deben estar en la carpeta ..\\MTB\\Sub. Al asociar una subrutina a una función M, la ejecución de la función M ejecuta la subrutina asociada sin ejecutar la propia función M." .

ns1:SubrutinaFuncionM06_869 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función M06 (cambio de herramienta)"@es ;
