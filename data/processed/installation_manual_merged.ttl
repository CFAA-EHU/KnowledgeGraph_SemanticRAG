ns1:Componente_RegistrosPLC a ns1:ComponenteElectrico ;
    ns1:documentadoEn ns1:Tabla_RecursosPLC_624 ;
    ns1:identificador "R1-R1024" ;
    ns1:textoExtracto "Registros (R1-R1024). Son elementos que permiten almacenar en 32 bits una variable numérica. El valor almacenado en cada registro será considerado como un número entero con signo, entre ± 2.147.483.647. Puede ser tratado como número decimal o hexadecimal (precedido por el carácter '$'). Se representan mediante la letra R, seguida del número de registro que se desea referenciar, desde R1 hasta R1024." .

ns1:Componente_ReglaFagor20um a ns1:ComponenteMecanico ;
    rdfs:label "Regla Fagor (paso 20 µm)"@es,
        "Regla Fagor de paso 20 µm"@es ;
