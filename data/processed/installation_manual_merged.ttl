ns1:Marca_HIRTHON a ns1:Parametro ;
    rdfs:label "HIRTHON" ;
    ns1:identificador "HIRTHON(axis)" ;
    ns1:textoExtracto "La marca HIRTHON(axis) indica si el eje Hirth está trabajando como eje Hirth (=1) o como un eje rotativo o lineal normal (=0), sin necesidad de posicionarse en posiciones concretas."@es ;
    ns1:valor "0",
        "1" .

ns1:Marca_INPOS a ns1:Parametro ;
    rdfs:label "INPOS" ;
    ns1:identificador "INPOS(axis)" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente se encuentra en posición y no hay ninguna petición de movimiento (marca ENABLE(axis) desactivada)."@es ;
    ns1:valor "0",
        "1" .

