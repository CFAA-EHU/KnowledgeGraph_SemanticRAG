ns1:Senal_WAITOUTC2 a ns1:InterfazUsuario ;
    rdfs:label "WAITOUTC2" ;
    ns1:identificador "WAITOUTC2" ;
    ns1:textoExtracto "WAITOUTC2"@es .

ns1:Senal_WAITOUTC3 a ns1:InterfazUsuario ;
