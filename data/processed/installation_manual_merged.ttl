ns1:Parametro_fe50e2f899 a ns1:Parametro ;
    rdfs:label "CIRINERR" ;
    ns1:identificador "CIRINERR" ;
    ns1:monitoreaParametro ns1:Variable_CIRINERR ;
    ns1:textoExtracto "CIRINERR Error absoluto máximo permitido en el radio. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.0100 mm o grados / 0.00039 inch." ;
