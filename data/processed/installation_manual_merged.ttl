    ns1:textoExtracto "el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente"@es,
        "trazas PARK(axis)"@es ;
    ns1:valor "1" .

ns1:SenalUNPARK a ns1:Parametro ;
    rdfs:label "Señal UNPARK"@es,
