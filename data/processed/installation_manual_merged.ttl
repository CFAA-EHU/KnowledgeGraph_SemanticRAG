ns1:Marca_DINDISTC2 a ns1:Parametro ;
    rdfs:label "DINDISTC2" ;
    ns1:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC2C1 DINDISTC2C3 DINDISTC2C4 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ns1:Marca_DRSTAF a ns1:Parametro ;
    rdfs:label "DRSTAF",
        "DRSTAF(axis)" ;
    ns1:identificador "DRSTAF(*)" ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador. Marcas DRSTAF(*)=0"@es,
        "Marcas DRSTAF(*)=1 DRSTAS(*)=0 [...] DRSTAF(*)=1 DRSTAS(*)=1 Regulador habilitado."@es ;
    ns1:valor "0",
        "1" .

ns1:Marca_DRSTAS a ns1:Parametro ;
    rdfs:label "DRSTAS",
        "DRSTAS(axis)" ;
    ns1:identificador "DRSTAS(*)" ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador. Marcas DRSTAS(*)=1"@es,
        "Marcas DRSTAF(*)=1 DRSTAS(*)=0 [...] DRSTAF(*)=1 DRSTAS(*)=1 Regulador habilitado."@es ;
    ns1:valor "0",
        "1" .

ns1:Marca_M100 a ns1:Alarma,
        ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "Marca M100",
        "Marca M100"@es ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "Asigna a M100 el estado (0/1) de T123. [...] Compara si el tiempo de T123 es mayor que 1000, en cuyo caso activa la marca M100.",
        "CPS C123 GT 1000 = M100. [...] activa la marca M100.",
        "El PLC activa la marca M100 cuando comienza la operación y la mantiene así hasta que finaliza la misma."@es,
        "La marca M100 mostrará el estado negado de la entrada I2."@es,
        "el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario"@es .

ns1:Marca_MZROT a ns1:Alarma,
        ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "MZROT",
        "Marca MZROT",
        "Marca MZROT (Indicador de finalización de operación)",
        "Marca MZROT"@es,
        "Marca de finalización: almacén orientado"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor ;
    ns1:identificador "MZROT" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación.",
        "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no.",
        "Activar la marca MZROT para indicar que ha finalizado la operación"@es,
        "MZROT (Almacén 1-4: MZROTMZ1, MZROTMZ2, MZROTMZ3, MZROTMZ4)"@es,
        "Utilizar con almacén tipo torreta y con almacén síncrono. El PLC debe poner esta marca a (=1) cuando la torreta ha girado. En el almacén síncrono se utiliza para optimizar el cambio orientando el almacén durante el mecanizado."@es,
        "activar la marca MZROT"@es ;
    ns1:valor "1" .

ns1:Marca_SPDLTOCH2 a ns1:AvisoSeguridad,
        ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "SPDLTOCH2",
        "Marca SPDLTOCH2"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor_732 ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "SPDLTOCH2 (Almacén 1-4: SPDLTOCH2MZ1, SPDLTOCH2MZ2, SPDLTOCH2MZ3, SPDLTOCH2MZ4)"@es,
        "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2."@es,
        "activar la marca SPDLTOCH2"@es ;
    ns1:valor "1" .

ns1:Marca_TCHANGEOK a ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "TCHANGEOK",
        "Marca TCHANGEOK"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor,
        ns1:Tabla_OperacionesPLC_TM ;
    ns1:identificador "TCHANGEOK" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "En almacenes asíncronos (con brazo cambiador de movimientos independientes) se puede activar la siguiente marca para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén. El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es,
        "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es,
        "TCHANGEOK (Almacén 1-4: TCHANGEOKMZ1, TCHANGEOKMZ2, TCHANGEOKMZ3, TCHANGEOKMZ4)"@es,
        "activar TCHANGEOK"@es ;
    ns1:valor "1" .

ns1:ModoAvance_Rapido a ns1:ModoOperacion ;
    rdfs:label "Avance rápido" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:ModoBusquedaBloque a ns1:ModoOperacion ;
    rdfs:label "Modo búsqueda de bloque" ;
    ns1:textoExtracto "opción –búsqueda de bloque– en el modo de operación automático" .

ns1:ModoHSCFAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST" ;
    ns1:textoExtracto "modo HSC FAST activo",
        "modo HSC FAST mejora la calidad del mecanizado" .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST",
        "FAST"@es,
        "Modo FAST"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorHSC ;
    ns1:identificador "FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST). En el modo FAST se logra una superficie mecanizada más suave y una velocidad más continua",
        "modo FAST",
        "modo FAST (geometría de la esquina)"@es,
        "optimizando la velocidad de mecanizado (modo FAST)"@es ;
    ns1:tieneComponente ns1:Parametro_FASTFACTOR,
        ns1:Parametro_FASTFILTFREQ .

ns1:ModoOperacion_ManualSuperpuesto_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo manual superpuesto (G201)" ;
    ns1:textoExtracto "modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." .

ns1:ModoOperacion_Setup a ns1:ModoOperacion ;
    rdfs:label "Modo Setup",
        "Modo SETUP (puesta a punto)"@es,
        "Modo setup (Setup Mode)"@es ;
    ns1:documentadoEn ns1:Tabla_ModosOperacionCNC ;
    ns1:identificador "Setup Mode" ;
    ns1:textoExtracto "El modo Setup se debe utilizar exclusivamente para la actualización del software del CNC y para la puesta a punto de la máquina; no permite instalar software de terceros. [...] SETUP MODE Nivel de protección. El modo setup dispone de un nivel intermedio de protección, donde está desprotegido todo aquello susceptible de ser modificado durante la puesta en marcha de la máquina; carpetas ..\\MTB, ..\\USERS, ..\\DIAGNOSIS y el registro de Windows.",
        "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM [...] se cargan en la memoria RAM durante la preparación de bloques."@es,
        "Modo setup (Setup Mode)."@es .

ns1:ModoSeguroPalpador a ns1:ModoOperacion ;
    rdfs:label "Modo seguro del palpador",
        "Modo seguro del palpador"@es ;
    ns1:textoExtracto "Estas marcas están asociadas al modo seguro del palpador.",
        "modo seguro del palpador"@es .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP",
        "Modo setup",
        "Modo setup (para actualización temporal)",
        "Setup Mode",
        "Modo Setup (acceso a parámetros)"@es ;
    ns1:habilitadoPor ns1:DialogoFinalizacionPuestaPunto ;
    ns1:identificador "puesta a punto" ;
    ns1:textoExtracto "La puesta a punto del CNC se realiza desde el modo setup. Fagor entrega el equipo preparado para arrancar en este modo.",
        "Modo SETUP (puesta a punto). En el encendido, el CNC mostrará un mensaje indicando que se encuentra en un modo no protegido y que la puesta a punto se encuentra sin finalizar.",
        "Si la instalación se hace en modo setup, el registro sólo tiene carácter temporal hasta que se apague el equipo.",
        "botón 'Restart Windows in Setup Mode' [...] cartela de estado con fondo amarillo y texto 'SETUP MODE'.",
        """\r
Modo Setup. Las variables pueden modificar los parámetros de solo lectura, desde un programa pieza. [...] Los nuevos valores se mantienen tras reiniciar o apagar el CNC.\r
"""@es .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)",
        "Módulo remoto RCS-S",
        "Módulo RCS-S"@es ;
    ns1:compuestoPor ns1:ConmutadorRotativo_RCS_S ;
    ns1:identificador "RCS-S",
        "SERCOUNTID" ;
    ns1:textoExtracto "Módulo RCS-S (contadora Sercos)",
        "módulo RCS-S [...] módulos RCS-S siempre ocupan posiciones entre la 1 y la 15.",
        "Entrada de captación en un módulo RCS-S. [...] Los módulos RCS-S se numeran según su orden lógico (parámetro SERCOUNTID)."@es .

ns1:OperacionesAlmacen_7_10_2 a ns1:ModoOperacion ;
    rdfs:label "Descripción detallada de las operaciones del almacén" ;
    ns1:identificador "7.10.2" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." .

ns1:OperacionesAlmacen_895 a ns1:Sistema ;
    rdfs:label "Operaciones del almacén (TAKEPOS, LEAVEPOS, NEXTPOS, MZID)"@es ;
    ns1:identificador "7.7.2" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación."@es .

ns1:Override_Avance_100 a ns1:Parametro ;
    rdfs:label "Override 100% avance" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." ;
    ns1:valor "100%" .

ns1:Pagina_556 a ns1:Pagina ;
    rdfs:label "Página 556 - Configuración de ejes y cabezales" ;
    ns1:identificador "556" ;
    ns1:textoExtracto "La configuración de ejes y cabezales del sistema se define mediante los parámetros máquina NAXIS, AXISNAME, NSPDL y SPDLNAME." .

ns1:Pagina_572_ConfiguracionTandem a ns1:Pagina ;
    rdfs:label "Página 572: Configuración de ejes tándem"@es ;
    ns1:identificador "572" ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes. • Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes). • Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es .

ns1:Pagina_730_731 a ns1:Pagina ;
    rdfs:label "Páginas 730-731: Modo automático. Estado y progreso del DMC"@es ;
    ns1:identificador "730-731" ;
    ns1:textoExtracto "Modo automático. Estado y progreso del DMC. A I F A B C B E D C D E F G H J A Estado del DMC; ON/OFF. B Override del DMC. [...] J Override final (override del DMC + override del conmutador)."@es .

ns1:ParametroGap a ns1:Parametro ;
    rdfs:label "Distancia del gap láser",
        "Gap (mm/inch)"@es,
        "Parámetro de control del gap"@es ;
    ns1:textoExtracto "Distancia (gap) a mantener respecto de la superficie.",
        "Este parámetro indica el número de nodo del regulador. Entrada analógica de los módulos remotos EtherCAT. En este caso, este parámetro indica el registro del PLC que mapea la entrada"@es,
        "mm/inch (vertical)"@es ;
    ns1:valor "mm/inch",
        "Milímetros o pulgadas"@es,
        "Nodo del regulador / Registro PLC (EtherCAT)"@es .

ns1:ParametroPosicionHerramienta a ns1:Parametro ;
    rdfs:label "Posición de la herramienta (cabezal/almacén/tierra)" ;
    ns1:textoExtracto "Marcas que activa la rutina M06 para que el PLC active la marca correspondiente del gestor." .

ns1:ParametroRoscadoConMacho a ns1:Parametro ;
    rdfs:label "Ciclo fijo de roscado con macho"@es ;
    ns1:textoExtracto "ciclo fijo de roscado con macho"@es .

ns1:ParametroRoscadoElectronico a ns1:Parametro ;
    rdfs:label "Roscado electrónico (G33)"@es ;
    ns1:textoExtracto "bloque de roscado electrónico (G33)"@es .

ns1:ParametroTDATA_2 a ns1:Parametro ;
    rdfs:label "TDATA 2" ;
    ns1:identificador "TDATA 2" ;
    ns1:textoExtracto "Componente TDATA 2 en esquemas TYPE=21, TYPE=22, TYPE=23 y TYPE=24" .

