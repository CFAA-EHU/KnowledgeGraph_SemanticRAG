ns1:DMC a ns1:ModoOperacion,
        ns1:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)",
        "DMC (Dynamic Motion Control)",
        "Dynamic Milling Control (DMC)",
        "DMC (Dynamic Machining Control)"@es ;
    ns1:monitoreaParametro ns1:DMCPEAKSIZE,
        ns1:MAXDMCOVR,
        ns1:MINDMCOVR,
        ns1:OverrideDMC,
        ns1:OverrideJOG,
        ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN,
        ns1:Parametro_PWRSP ;
    ns1:textoExtracto "DMC (control dinámico del mecanizado)",
        "La sentencia #DMCOFF desactiva el DMC. [...] desactivan el DMC.",
        "La sentencia #DMCON activa el DMC, siempre sobre el cabezal master. El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'.",
        "el CNC desactiva el DMC. [...] el CNC reactiva el DMC.",
        "Opciones del DMC (menú desplegable). • Repetir la fase de aprendizaje del DMC. • Desactivar el DMC."@es .

