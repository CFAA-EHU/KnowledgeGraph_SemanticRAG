ns1:Cabezal_S_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S (Canal 1, índice 1)",
        "Cabezal S (Canal 1)"@es ;
    ns1:identificador "S",
        "SPDLNAME 1" ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ.",
        "SPDNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ. [...] CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ4ꞏ."@es ;
    ns1:valor 4 .

ns1:Cabezal_S_Torno1Canal a ns1:ComponenteMecanico ;
