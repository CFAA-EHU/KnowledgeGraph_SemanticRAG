ns1:TablaConfiguracionCabezales_86 a ns1:Tabla ;
    ns1:identificador "2.3.6 Configuración de los cabezales" ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla será el cabezal lógico ꞏ4ꞏ y así sucesivamente. | AXISNAME | SPDLNAME | Orden lógico. | --- | --- | --- | AXISNAME 1 |  | Número lógico ꞏ1ꞏ. | AXISNAME 2 |  | Número lógico ꞏ2ꞏ. | AXISNAME 3 |  | Número lógico ꞏ3ꞏ. |  | SPDLNAME 1 | Número lógico ꞏ4ꞏ." .

ns1:TablaConfiguracionCanales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (CHAXISNAME/CHSPDLNAME)"@es ;
    ns1:identificador "Tabla_10.1.2_ConfiguracionEjesCabezales" ;
    ns1:textoExtracto "El primer cabezal de la tabla CHSPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente. | CHAXISNAME | CHSPDLNAME | Índice en el canal. | --- | --- | --- | CHAXISNAME 1 |  | Eje con índice ꞏ1ꞏ. | CHAXISNAME 2 |  | Eje con índice ꞏ2ꞏ. | CHAXISNAME 3 |  | Eje con índice ꞏ3ꞏ. |  | CHSPDLNAME 1 | Cabezal con índice ꞏ1ꞏ. |  | CHSPDLNAME 2 | Cabezal con índice ꞏ2ꞏ."@es .

ns1:Tabla_14_13_2_Variables a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles (PRG, MDI/MDA, PLC, INT)"@es ;
    ns1:identificador "14.13.2" ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es .

ns1:Tabla_2.3.31_ControlGap a ns1:Tabla ;
    rdfs:label "Tabla de configuración del eje Z para control del gap"@es,
        "Tabla de estados del parámetro GAPTONEG"@es ;
    ns1:documentadoEn ns1:Pagina_98_103 ;
    ns1:ilustradoEn ns1:Pagina_98_103 ;
    ns1:textoExtracto """\r
| Z+\r
Z-\r
LASER\r
GAP\r
WORKPIECE\r
GAPTONEG = Sí | Z-\r
Z+\r
LASER\r
GAP\r
WORKPIECE\r
GAPTONEG = No\r
""",
        """\r
| Valor. | Significado. |\r
| --- | --- |\r
| Sí. | El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap. |\r
| No | El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap. |\r
"""@es .

ns1:Tabla_413_G0ACDCJERK a ns1:Tabla ;
