ns1:MaquinaHerramienta a ns1:Maquina ;
    rdfs:label "Máquina-herramienta"@es ;
    ns1:textoExtracto "Para que la máquina-herramienta pueda ejecutar correctamente las instrucciones programadas, así como interpretar los elementos que tiene interconectados, el CNC debe conocer los datos específicos de la máquina."@es .

ns1:MaquinaTandem_1072 a ns1:Maquina ;
    rdfs:label "Máquina tándem"@es ;
    ns1:textoExtracto "una máquina tándem posee frecuencia de resonancia baja"@es ;
    ns1:tieneComponente ns1:Motor_EjeEsclavo_1072,
        ns1:Motor_EjeMaestro_1072,
        ns1:SistemaControlCNC_1072 .

ns1:Maquina_CentroMecanizado a ns1:Maquina ;
    rdfs:label "Centro de mecanizado"@es ;
    ns1:textoExtracto "Centro de mecanizado con volumen de trabajo a compensar, relacionado con elementos como mesa, columna y husillo."@es .

ns1:Maquina_ConHolgura a ns1:Maquina ;
    rdfs:label "Máquina con holgura" ;
    ns1:textoExtracto "En máquinas con mucha holgura, en las que se utiliza captación externa para conseguir mayor precisión, es posible que se produzca cierta inestabilidad." .

ns1:MarcaComunicacion_CNCRD a ns1:Parametro ;
    rdfs:label "Marca de comunicación (CNCRD)" ;
    ns1:textoExtracto "Siempre que se de un error en la lectura de la variable, la marca de comunicación se quedará a \"1\"." ;
    ns1:valor "1" .

ns1:MarcaComunicacion_CNCWR a ns1:Parametro ;
    rdfs:label "Marca de comunicación (CNCWR)" ;
    ns1:textoExtracto "La marca se pone a \"1\" cuando comienza la operación y se mantiene a dicho valor hasta que finaliza la misma. Siempre que se de un error en la lectura de la variable, la marca de comunicación se quedará a \"1\"." ;
    ns1:valor "1" .

ns1:MarcaENABLEPWRFREQ a ns1:Parametro ;
    rdfs:label "ENABLEPWRFREQ" ;
    ns1:identificador "ENABLEPWRFREQ" ;
    ns1:textoExtracto "ENABLEPWRFREQ Marca activa por defecto." .

ns1:MarcaGEAROK a ns1:ComponenteElectrico ;
