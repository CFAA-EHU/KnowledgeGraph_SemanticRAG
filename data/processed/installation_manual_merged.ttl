    ns1:textoExtracto "Coger una herramienta del brazo y ponerla en el cabezal."@es .

ns1:ModoOperacion_TM12 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=12 (Intercambio optimizado)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "12" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida cuando ambas herramientas son especiales y pueden colisionar en el brazo o no se desea que coincidan en el brazo cambiador."@es .

ns1:ModoOperacion_TM14 a ns1:ModoOperacion ;
