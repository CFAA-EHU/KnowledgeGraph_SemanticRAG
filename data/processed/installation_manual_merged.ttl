ns1:Parametro_9d07bcdb76 a ns1:Parametro ;
    rdfs:label "Parámetro de mezcla de captaciones"@es ;
    ns1:textoExtracto "el parámetro se define con valor distinto de ꞏ0ꞏ, se habilita la mezcla de captaciones; si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa. Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos."@es ;
    ns1:valor "0 (solo externa) / ≠0 (mezcla)"@es .

ns1:Parametro_9d5a5f34d0 a ns1:Parametro ;
