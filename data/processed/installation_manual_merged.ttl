ns1:ProcesoResetCNC a ns1:ModoOperacion ;
    rdfs:label "Proceso de reset del canal CNC" ;
    ns1:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN. 2 El canal asume las condiciones iniciales (las definidas en los parámetros máquina). 3 El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW. 4 El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." .

ns1:ReguladorEjeDigital a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de eje digital",
        "Regulador de eje digital"@es ;
    ns1:controla ns1:Sensor_13a807dabe ;
    ns1:identificador "DRENA" ;
    ns1:textoExtracto "En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA) [...] el CNC envía al regulador el comando para aparcar el eje" .

ns1:SWITCHAxis a ns1:Parametro ;
    rdfs:label "SWITCH(axis)",
        "Parámetro SWITCH(axis)"@es ;
    ns1:identificador "SWITCH(axis)" ;
    ns1:textoExtracto "SWITCH(axis) [...] permite conmutar entre los diferentes ejes o cabezales del grupo." .

ns1:Senal_INHIBIT_axis a ns1:ComponenteElectrico ;
    rdfs:label "Señal INHIBIT(axis)"@es ;
    ns1:identificador "INHIBIT(axis)" ;
    ns1:textoExtracto "INHIBIT(axis) Si el PLC pone esta marca a (=1) el CNC impide cualquier movimiento del eje o cabezal correspondiente. Este movimiento continuará cuando el PLC vuelva a poner esta marca a (=0)."@es .

ns1:Senal_MSTROBE a ns1:Sensor ;
    rdfs:label "MSTROBE",
        "Señal MSTROBE (sincronización función M)",
        "Señal MSTROBE"@es ;
    ns1:monitoreaParametro ns1:Registro_MFUN ;
    ns1:textoExtracto "señal MSTROBE [...] para las funciones –M– que no necesitan sincronización" .

