VOLCOMP2 (R/W)   |  |\r
VOLCOMP3         |  |\r
VOLCOMP4         |  |""" .

ns1:Tabla_TiemposEjesAnalogicos a ns1:Tabla ;
    rdfs:label "Tabla de tiempos de ciclo según número de ejes analógicos"@es ;
    ns1:textoExtracto """\r
| LOOPTIME | Número de ejes analógicos. |\r
| --- | --- |\r
| 4 ms. | Hasta 8 ejes analógicos. |\r
| 5 ms. | Hasta 12 ejes analógicos. |\r
| 6 ms. | Hasta 16 ejes analógicos. |\r
| 8 ms. | Hasta 20 ejes analógicos. |\r
| 10 ms. | Hasta 24 ejes analógicos. |\r
"""@es .

