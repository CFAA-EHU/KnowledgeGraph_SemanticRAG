ns1:Marca_CUTVARACT a ns1:Parametro ;
    rdfs:label "Marca CUTVARACT" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:Marca_CYSTART a ns1:Componente,
        ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "CYSTART",
        "Marca CYSTART" ;
    ns1:documentadoEn ns1:Pagina_437 ;
    ns1:identificador "CYSTART" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "CYSTART\" START AND (resto de condiciones) = CYSTART RESETOUT. El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset.",
        "PLC debe activar la marca CYSTART para que comience la ejecución del programa. START AND (resto de condiciones) = CYSTART",
        "el PLC debe activar la marca CYSTART para que comience la ejecución del programa" .

ns1:Marca_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP(axis)" ;
    ns1:identificador "DIFFCOMP(axis)" ;
    ns1:textoExtracto "Con el flanco de subida de SERVO(axis)ON si DIFFCOMP(axis) está activa. Con el flanco de subida de DIFFCOMP(axis) si SERVO(axis)ON está activa.",
        "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo" .

ns1:Marca_DINDISTC1C2 a ns1:Parametro ;
    rdfs:label "DINDISTC1C2" ;
    ns1:monitoreaParametro ns1:Marca_DINDISTC1,
        ns1:Marca_DINDISTC2 ;
    ns1:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ1ꞏ y el resto de pasadas se distribuyen con el canal ꞏ2ꞏ, el CNC activa la marca DINDISTC1C2." .

ns1:Marca_DINDISTC4 a ns1:Parametro ;
    rdfs:label "DINDISTC4" ;
    ns1:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC4C1 DINDISTC4C2 DINDISTC4C3 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ns1:Marca_DINDISTYPE a ns1:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPE" ;
    ns1:identificador "DINDISTYPE" ;
    ns1:textoExtracto "DINDISTYPE Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4 Esta marca está asociada a la distribución dinámica del mecanizado entre" .

