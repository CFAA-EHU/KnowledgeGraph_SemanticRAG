    ns1:tieneComponente ns1:Parametro_NSPDL,
        ns1:Tabla_SPDLNAME .

ns1:Sistema_CaptacionEje a ns1:Sistema ;
    rdfs:label "Sistema de captación de eje" ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosCaptacionEje ;
    ns1:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador. [...] Cuando el eje utiliza la segunda entrada de captación de otro regulador, el CNC no permite realizar su búsqueda de referencia, por lo que el eje debe disponer de captación absoluta." ;
    ns1:tieneComponente ns1:ComponenteElectrico_EntradaCaptacionExterna,
        ns1:ComponenteElectrico_EntradaCaptacionInterna .

