    ns1:textoExtracto "Sección 16.1.3 Configuración del arranque de la aplicación."@es .

ns1:Pagina_FuncionamientoContador a ns1:Pagina ;
    rdfs:label "Página 354: Funcionamiento de un contador" ;
    ns1:identificador "354" ;
    ns1:textoExtracto "Ver en la página 354. '3.6 Funcionamiento de un contador'."@es .

ns1:PalpadorMedidaMaquina_2_3_25 a ns1:Sensor ;
    rdfs:label "Palpador de medida (esférico)"@es ;
    ns1:detalladoEnEsquema ns1:DiagramaPalpadorMedida_2_3_25 ;
    ns1:documentadoEn ns1:Pagina_92 ;
    ns1:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza: se representa un palpador tipo esférico acercándose a la superficie de una pieza cilíndrica, con el vástago vertical y el punto de contacto marcado. La composición resalta la funcionalidad metrológica en ciclo (toma de puntos en la pieza), la dirección de aproximación y el rol del disparo del palpador como evento de medición."@es .

ns1:PalpadorSobremesaTorno_2_3_25 a ns1:Sensor ;
    rdfs:label "Palpador de sobremesa (torno)"@es ;
    ns1:detalladoEnEsquema ns1:DiagramaPalpadorTorno_2_3_25 ;
    ns1:documentadoEn ns1:Pagina_92 ;
    ns1:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno: se observa el útil de torneado aproximándose al palpador fijo instalado en la bancada. El dibujo destaca el punto de contacto, el soporte del palpador y la geometría de la herramienta, enfatizando la detección por contacto y la orientación del conjunto en un entorno de medición estático."@es .

ns1:Palpador_CNC a ns1:Sensor ;
    rdfs:label "Palpador para CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_LongitudPalpador,
        ns1:Parametro_RadioPalpador ;
    ns1:requiereMantenimiento ns1:CalibracionPalpador ;
    ns1:textoExtracto "Los parámetros máquina asociados al movimiento del palpador deben estar definidos y el palpador debe estar correctamente calibrado. Hay que conocer la longitud (L) y el radio (R) del palpador para calcular las dimensiones del cabezal."@es .

ns1:PanelFrontal_PLC a ns1:InterfazUsuario ;
    rdfs:label "Panel frontal del PLC"@es ;
    ns1:textoExtracto "El programa de PLC puede ser editado desde el panel frontal"@es .

ns1:PanelPC a ns1:ComponenteElectrico ;
    rdfs:label "PanelPC" ;
    ns1:textoExtracto "El software puede ir instalado bien en el CNC o bien en un PanelPC."@es .

ns1:PantallasHMI_46 a ns1:InterfazUsuario ;
    rdfs:label "Nuevas pantallas"@es ;
