    rdfs:label "Seleccionar posición LEAVEPOS y dejar herramienta con pinza 1"@es ;
    ns1:ejecutadoPor ns1:Personal_OperarioPLC ;
    ns1:identificador "M105" ;
    ns1:requiereMantenimiento ns1:Herramienta_Generica,
