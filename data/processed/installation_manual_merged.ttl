    ns1:identificador "GAPSENSORCH" ;
    ns1:textoExtracto "GAPSENSORCH | Cambiar el signo de la señal del sensor." .

ns1:CambioDeHerramientaAutomatico_2bddb72182 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:CambioDeHerramientaManual_05b3760b6b a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:CambioDeHerramienta_000198c399 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:solucionaFallo ns1:ActivarMarcaTCHANGEOKSinHerramientaEnElBrazo ;
    ns1:textoExtracto "Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén." .

ns1:CambioDeHerramienta_21bce437cc a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Herramienta" ;
    ns1:textoExtracto "para realizar el cambio de herramienta sólo es necesario programar la función T, sin necesidad de M6." .

ns1:CambioDeHerramienta_9ef2fc11dd a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Herramienta" ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases; la primera con la ejecución de la función T y la segunda con la ejecución de la función M06." .

ns1:CambioDeHerramienta_a508b893d0 a ns1:TareaMantenimiento ;
    rdfs:label "cambio de herramienta" ;
    ns1:textoExtracto "Cambiar la herramienta." .

ns1:CambioDeHerramienta_aa84b3cc8d a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "el proceso de carga de la herramienta se realizará cuando se ejecute el código \"T\"." .

ns1:CambioDeHerramienta_ab84772636 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "Orden al gestor para comenzar el cambio de herramienta." .

ns1:CambioDeHerramienta_b307bc70fb a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza. Cuando el CNC selecciona una herramienta, la rutina asociada a T ejecuta la función M06 (cambio de herramienta), detiene el mecanizado y el gestor envía al PLC el código correspondiente a la operación que debe efectuar." .

ns1:CambioDeHerramienta_e4835c35ad a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Herramienta" ;
    ns1:solucionaFallo ns1:CondicionModalEnCiclosFijos ;
