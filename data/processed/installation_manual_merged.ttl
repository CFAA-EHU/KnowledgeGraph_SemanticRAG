    rdfs:label "Eje gantry" ;
    ns1:textoExtracto "DIFFCOMP Eje gantry. Compensar la diferencia de cota entre ambos ejes tras G74." .

ns1:Sistema_ModulosRemotosCAN a ns1:Sistema ;
    rdfs:label "Módulos remotos CAN" ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los módulos remotos CAN. En este caso, este parámetro indica el número de la salida analógica que se utiliza para la consigna. Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." .

ns1:Sistema_RIOW_Nodo1 a ns1:Sistema ;
    rdfs:label "Módulo RIOW (Nodo 1) con 16 entradas y 8 salidas"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_RIO5_24DI_16DO ;
    ns1:identificador "Nodo 1 (RIOW)" ;
    ns1:textoExtracto "módulo RIOW con 16 entradas y 8 salidas. Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO, destacando la segmentación en bloques lógicos independientes (entradas/salidas) y su indexación inicial (I1/O81 en el ejemplo)."@es .

ns1:Sistema_a190cc5036 a ns1:Sistema ;
