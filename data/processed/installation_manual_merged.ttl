ns1:Parametro_08f8f9f7af a ns1:Parametro ;
    rdfs:label "PWMCANCEL" ;
    ns1:identificador "PWMCANCEL" ;
    ns1:textoExtracto "PWMCANCEL Cancelar el PWM tras M30 o reset. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:Parametro_097d39409c a ns1:Parametro ;
    rdfs:label "G0MODAL" ;
    ns1:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." ;
    ns1:valor "Sí/No" .

ns1:Parametro_09a5bca7cc a ns1:Parametro ;
    rdfs:label "NRETBLK",
        "Parámetro NRETBLK" ;
    ns1:identificador "NRETBLK" ;
    ns1:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK." ;
    ns1:valor "75" .

ns1:Parametro_09ac959ab8 a ns1:Parametro ;
    rdfs:label "LUBR" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "el CNC pone la marca LUBR a (=1) para indicar al PLC que se debe engrasar el eje. [...] El CNC pone la marca LUBR a (=0) e inicializa la cuenta a 0." ;
    ns1:valor "0,1" .

ns1:Parametro_09f69f3bb9 a ns1:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ns1:identificador "MPG.SWTOUTPUT" ;
    ns1:textoExtracto "Salida digital local asociada a la conmutación sincronizada. Valores posibles: De 0 a NLOCOUT (Número de salidas digitales locales). Valor por defecto: 0. Variable asociada: (V.)MPG.SWTOUTPUT" ;
    ns1:valor "0" .

ns1:Parametro_0a54903487 a ns1:Parametro ;
    rdfs:label "Parámetro TRS (reset)"@es ;
    ns1:textoExtracto "Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta."@es .

