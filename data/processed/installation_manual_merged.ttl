    rdfs:label "Versión de software V3.15"@es ;
    ns1:documentadoEn ns1:ManualMantenimiento ;
    ns1:identificador "V3.15" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta"@es .

ns1:VersionSoftware_V4.0 a ns1:Parametro,
        ns1:Sistema ;
    rdfs:label "Versión V4.0"@es,
        "Versión mínima para soporte Unicode"@es ;
    ns1:identificador "V4.0" ;
    ns1:monitoreaParametro ns1:SoporteUnicode_CNC ;
    ns1:textoExtracto "a la V4.0. Para convertir programas en formato Unicode a formato ANSI puede utilizar un editor de texto de terceros (por ejemplo, el Bloc de notas de Windows), pero al realizar esta operación, los caracteres especiales sin equivalente en formato ANSI se perderán."@es,
        "versión V4.0"@es ;
    ns1:valor "V4.0" .

