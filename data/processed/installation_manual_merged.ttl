ns1:AlmacenHerramientas a ns1:ComponenteMecanico,
        ns1:Sistema ;
    rdfs:label "Almacén de herramientas",
        "Almacén de herramientas"@es,
        "Almacén de herramientas (MZ)"@es ;
    ns1:compuestoPor ns1:HerramientaTierra,
        ns1:RutinaM06 ;
    ns1:documentadoEn ns1:TablaHerramientasSistema ;
    ns1:identificador "AlmacenHerramientas",
        "MZ" ;
    ns1:textoExtracto """\r
Coger la herramienta del almacén con la pinza 1.\r
Llevar la herramienta de la pinza 2 al almacén.""",
        "Coger la herramienta del almacén con la pinza 1. Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2.",
        "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén.",
        "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén.",
        "SUB_ARM_TO_MZ ; Llevar el brazo cambiador al almacén.",
        "almacén",
        """\r
LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta.\r
$CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén."""@es,
        """\r
LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén.\r
LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.\r
$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén.\r
"""@es,
        "Coger una herramienta del almacén... Dejar la herramienta del cabezal en el almacén."@es,
        "Dejar la herramienta [...] en el almacén"@es,
        "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén."@es,
        "Las herramientas siempre se guardan en el mismo almacén. [...] Cada herramienta se identifica mediante su número, que es único para todo el sistema; no podrá estar repetido ni en almacenes distintos ni en herramientas de tierra."@es,
        "almacén"@es,
        "coger la herramienta del almacén"@es,
        "dejar la herramienta [...] en el almacén [...] coger la herramienta del almacén"@es ;
    ns1:tieneComponente ns1:Herramienta,
        ns1:Pinza1,
        ns1:Pinza2 .

ns1:DMC_ModoOperacion a ns1:ModoOperacion ;
    rdfs:label "DMC",
        "Funcionamiento del DMC",
        "Modo DMC (Dynamic Milling Control)" ;
    ns1:identificador "#DMCON" ;
    ns1:textoExtracto "Funcionamiento del DMC. Una vez conocida la potencia objetivo, y tras detectar la entrada a la pieza, comenzará el funcionamiento normal del DMC. Durante el mecanizado, el DMC adapta el avance para que la potencia de corte (\"potencia consumida\" – \"potencia en vacío\") sea lo más cercana posible a la potencia objetivo. El DMC adapta el avance modificando el override.",
        "Tras ejecutar la sentencia #DMCON, el CNC activará el DMC siempre y cuando el cabezal tenga regulación digital, esté girando en M3 o M4 y haya alcanzado la velocidad de giro programada (marca REVOK).",
        "El DMC sólo puede estar activo en ejecución; en simulación, el CNC analizará las sentencias de activación y desactivación, pero no pondrá en marcha el DMC. El DMC sólo puede estar activo en modo automático; no se activa en modo manual."@es ;
    ns1:tieneFrecuencia ns1:DMC_FrecuenciaAprendizaje .

ns1:Eje_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje X",
        "Eje X"@es,
        "Eje X (Canal 1)"@es ;
    ns1:documentadoEn ns1:SistemaFresadora_3Canales_9Ejes_2Cabezales ;
    ns1:identificador "AXISNAME 1",
        "AXISNAME=X; Índice lógico=1",
        "X" ;
    ns1:textoExtracto "·· = TOUCHPROBE (X,1) ·· = TOUCHPROBE (X,2)",
        "2 ejes (X Z)"@es,
        "AXISNAME 1 | X | Número lógico ꞏ1ꞏ."@es,
        "AXISNAME 1: X | Número lógico ꞏ1ꞏ."@es,
        "configuración de ejes X Y Z"@es ;
    ns1:valor 1,
        "X" .

ns1:EsquemaCinematica_TYPE19 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=19 (ejes X-Y-Z, rotaciones A/C/B)" ;
    ns1:identificador "TYPE=19" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=19 con ejes lineales X-Y-Z y rotaciones A/C/B. Se detallan TDATA 1, 2, 7, 8, 11 y otros para offsets y sentidos; incluye orden de rotaciones y referencias de signo para los vectores de giro." .

ns1:Esquema_AsignacionTeclasLCD10K_246 a ns1:Esquema ;
    rdfs:label "Esquema de teclado LCD-10K (pág. 246)"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_LCD10K ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog."@es .

ns1:Norma_DIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217 para denominación de ejes"@es ;
    ns1:identificador "DIN66217" ;
    ns1:textoExtracto "La norma DIN 66217 denomina los diferentes tipos de ejes de la siguiente manera."@es .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario",
        "TDATA9",
        "TDATA9 (Tipo de control)",
        "TDATA9 (distinción manual/servo del eje principal)",
        "TDATA9"@es,
        "TDATA9 (distancia 3º a 2º centro de giro, eje Y)"@es,
        "TDATA9 - Eje rotativo principal del cabezal"@es ;
    ns1:cumpleNormativa ns1:Directiva_DIN66217 ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo1_16,
        ns1:Tabla_RedefinicionCinematicaVectorial_293_308 ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19).",
        "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA9=1.",
        "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual).",
        "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0.",
        "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal).",
        "TDATA9 | 1",
        "TDATA17 | TDATA9"@es,
        "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0."@es,
        "TDATA9 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje Y."@es,
        "TDATA9 | 0"@es,
        "distancias/offsets etiquetadas como TDATA (..., 9, ...)"@es,
        "| TDATA9 | 0 |"@es ;
    ns1:valor 0,
        "0",
        "0 o 1",
        "1",
        "distancia (eje Y)"@es .

