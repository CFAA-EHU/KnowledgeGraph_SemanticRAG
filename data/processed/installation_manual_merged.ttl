ns1:InterfazUsuario_OpenPCSRemoto_BarraIdiomaWindows a ns1:InterfazUsuario ;
    rdfs:label "Barra de idioma de Windows (OpenPCS Remoto)"@es ;
    ns1:textoExtracto "Barra de idioma de Windows con selector de 'Idioma de entrada' y 'Distribución del teclado'; se muestran entradas 'Spanish' y 'United States' y el estado/fecha del sistema. Indica la conmutación dinámica del idioma en la ventana activa, relevante para que los códigos de tecla coincidan con la distribución."@es .

ns1:InterfazUsuario_OpenPCSRemoto_ServiciosInstalados a ns1:InterfazUsuario ;
    rdfs:label "Diálogo 'Servicios instalados' para configuración de teclados (OpenPCS Remoto)"@es ;
    ns1:compuestoPor ns1:InterfazUsuario_OpenPCSRemoto_SeleccionIdiomaTeclado ;
    ns1:textoExtracto "Captura del diálogo 'Servicios instalados' mostrando el árbol de lenguajes y la acción 'Agregar…'. Se evidencian la lista de idiomas de entrada disponibles y las distribuciones asociadas, con botones de Aceptar/Cancelar que cierran el asistente de alta."@es .

ns1:InterfazUsuario_OrientacionFACEAXIS a ns1:InterfazUsuario ;
    rdfs:label "Indicador de orientación FACEAXIS"@es ;
    ns1:documentadoEn ns1:Tabla_IconosOrientacionHerramienta ;
    ns1:textoExtracto "El CNC orienta la herramienta según el primer eje definido como FACEAXIS."@es .

ns1:InterfazUsuario_OrientacionLONGAXIS a ns1:InterfazUsuario ;
