ns1:Tabla7_9_1 a ns1:Tabla ;
    ns1:compuestoPor ns1:Entity4HerramientaDeTierra,
        ns1:PosicionAlmacen_4 ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación. En el caso de las marcas que aparecen entre paréntesis, el gestor puede ejecutar las operaciones en cualquier orden, pero siempre debe ejecutar ambas." .

ns1:TablaAlmacen a ns1:Esquema ;
    ns1:textoExtracto "Tabla de los almacenes. Se dispone de una tabla para cada almacén. En cada una de las tablas se muestra qué herramienta hay en cada posición del almacén y en cada una de las pinzas del brazo cambiador (si se dispone de él). Aunque la tabla de almacén se puede inicializar manualmente, es el gestor el que se encarga de actualizar dinámicamente todos sus datos." ;
    ns1:tieneComponente ns1:Componente_e588de13e8 .

ns1:TablaAlmacen1 a ns1:Tabla ;
    ns1:textoExtracto "En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática." ;
    ns1:tieneComponente ns1:SoftkeyCargaDescarga1 .

ns1:TablaAlmacenHerramientas_985_479 a ns1:Tabla ;
    ns1:textoExtracto "Tras colocar la herramienta en el cabezal el gestor actualiza la tabla de almacén." .

ns1:TablaAsignacionCanales a ns1:Tabla ;
    rdfs:label "Tabla de asignación de paneles de jog a canales" ;
