ns1:ActualizacionDeSoftwareAVERSION2 a ns1:Sistema ;
    rdfs:label "Actualización de software a VERSION_2"@es ;
    ns1:compuestoPor ns1:ConexionSYSTool1AC1Rotacion01090,
        ns1:ConexionSYSTool1AC2Rotacion01090,
        ns1:ConexionSYSTool1AC3Rotacion01090,
        ns1:ToolViceSYSTool1HusilloS1,
        ns1:ToolViceSYSTool2HusilloS2,
        ns1:ToolViceSYSTool3HusilloS3,
        ns1:ToolViceSYSTool4HusilloS4 ;
    ns1:identificador "VERSION_2" ;
    ns1:textoExtracto "Incluir: <GeometryObject name=\"VERSION_2\"> </GeometryObject>"@es .

ns1:ActualizacionSoftware_1_4_1 a ns1:TareaMantenimiento ;
    rdfs:label "Actualización del software desde versiones anteriores"@es ;
    ns1:ejecutadoPor ns1:Personal_TecnicoCNC ;
    ns1:requiereMantenimiento ns1:ArchivosXCAVersion2 ;
    ns1:textoExtracto "El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones) y que utilizan la versión 2 de archivos xca. Por lo tanto, al actualizar la versión del CNC, es necesario instalar/actualizar los archivos xca que definen la configuración de la máquina."@es .

ns1:AgregarCabecerasALaTopologiaDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Agregar cabeceras a la topología del bus"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_ConfiguradorTopologiaBus ;
    ns1:ejecutadoPor ns1:Personal_TecnicoConfigurador ;
    ns1:textoExtracto "Para añadir cabeceras, [...] seleccionar la opción 'Append Slave'. [...] Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es .

ns1:AjusteDeGananciasDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de ganancias del regulador"@es ;
    ns1:requiereMantenimiento ns1:Regulador_Inercia ;
    ns1:textoExtracto "probar con varios valores. El ajuste óptimo se consigue cuando se minimiza el error de seguimiento al máximo pero sin invertir los picos."@es .

ns1:AjusteDelModoHSC a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del modo HSC" ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:ModoHSC ;
    ns1:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

ns1:Alarma_35ccc8ac61 a ns1:Alarma ;
    rdfs:label "Alarma de captación fallida"@es ;
    ns1:activaAlarma ns1:Sensor_27d9c8f749 ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "En ejes analógicos, si se produce una alarma de captación."@es .

ns1:Alarma_997e363996 a ns1:Alarma ;
    rdfs:label "TG3" ;
    ns1:activaAlarma ns1:Parametro_eac9a4ae87 ;
    ns1:controla ns1:Parametro_9eb0d1cf51 ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "tras un flanco de subida en TG3, T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0." .

ns1:Alarma_a4f7bb64b8 a ns1:Alarma ;
    rdfs:label "Marca OUTOFTOL (fuera de tolerancia del gap)"@es ;
    ns1:monitoreaParametro ns1:Parametro_9306311404 ;
    ns1:textoExtracto "OUTOFTOL [...] indica que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ns1:Alarma_e3ab051c1b a ns1:Alarma ;
    rdfs:label "Marca de salida del gap (GAPMIN/GAPMAX)"@es ;
    ns1:monitoreaParametro ns1:ParametrosGAPMINYGAPMAX ;
    ns1:textoExtracto "marca [...] ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ns1:Alarma_fa3b75ee31 a ns1:Alarma ;
    rdfs:label "TG2" ;
    ns1:activaAlarma ns1:Parametro_786b2eb120 ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado." .

