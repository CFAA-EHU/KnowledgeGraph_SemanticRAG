ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "IPLANE",
        "Parámetro IPLANE",
        "IPLANE (plano de trabajo por defecto)"@es,
        "Parámetro IPLANE (plano de trabajo por defecto)"@es,
        "Parámetro máquina IPLANE"@es ;
    ns1:documentadoEn ns1:Manual_CNC,
        ns1:Tabla_PlanosTrabajo_205 ;
    ns1:identificador "G17/G18",
        "IPLANE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "IPLANE Plano principal (G17/G18) por defecto. Valores posibles: G17 / G18. Valor por defecto: G17. Este parámetro indica el plano de trabajo principal que asume el CNC por defecto.",
        "el plano definido en el parámetro IPLANE",
        """\r
Se recomienda definir el parámetro IPLANE como G17. Para cambiar el plano de trabajo desde el programa pieza utilizar las funciones G17, G18, G19 ó G20.\r
"""@es,
        "El parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza."@es,
        "El plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)."@es ;
    ns1:valor "G17"^^xsd:string,
        "G17",
        "No aplicable (fijo en G18)"@es .

ns1:Parametro_IPOPOS a ns1:Parametro ;
    rdfs:label "Cota teórica a la salida del interpolador (IPOPOS)"@es ;
