ns1:ConsignaAdicionalReguladorAnalogico a ns1:Parametro ;
    rdfs:label "Consigna adicional (regulador analógico)"@es ;
    ns1:textoExtracto "la consigna adicional se expresará en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767. Al valor -32767 le corresponderá una consigna de -10 V; al valor 32767, una consigna de 10 V."@es ;
    ns1:valor "-32767/-10V ... 32767/10V" .

ns1:ConsignaDePosicionCotasAbsolutas a ns1:Parametro ;
