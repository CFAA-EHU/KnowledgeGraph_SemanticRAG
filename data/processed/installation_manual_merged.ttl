ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF",
        "FBACKDIFF"@es,
        "FBACKDIFF (Máxima diferencia entre captaciones)"@es ;
    ns1:documentadoEn ns1:TablaParametrosCNC_47,
        ns1:Tabla_ParametrosPuestaMarcha,
