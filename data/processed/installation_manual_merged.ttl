ns1:Parametro_TENDENCY a ns1:Parametro ;
    rdfs:label "TENDENCY (Test de tendencia para detección de embalamiento)"@es,
        "TENDENCY (Test de tendencia)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "TENDENCY" ;
    ns1:monitoreaParametro ns1:Parametro_ESTDELAY,
        ns1:Parametro_TENDTIME,
        ns1:Sistema_CNC ;
    ns1:textoExtracto "TENDENCY Activación del test de tendencia. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.TENDENCY.xn"@es,
        "TENDENCY | Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva. Se aconseja activarlo durante la puesta a punto de la máquina."@es ;
    ns1:valor "No" .

ns1:Parametro_TENDTIME a ns1:Parametro ;
    rdfs:label "TENDTIME (Tiempo de detección de embalamiento)"@es ;
    ns1:identificador "TENDTIME" ;
    ns1:textoExtracto "TENDTIME Tiempo para detectar el embalamiento del eje. [...] Valores posibles: De 0 a 65535 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.TENDTIME.xn"@es ;
    ns1:valor 0 .

ns1:Parametro_TMASTERAXIS a ns1:Parametro ;
    rdfs:label "MASTERAXIS (Parámetro TMASTERAXIS)",
        "MPG.TMASTERAXIS[nb]" ;
    ns1:documentadoEn ns1:Tabla_1070_VariablesTandem ;
    ns1:identificador "MPG.TMASTERAXIS[nb]",
        "TMASTERAXIS" ;
    ns1:textoExtracto "MASTERAXIS Pareja tándem. Eje/cabezal maestro o principal. [...] El motor maestro del tándem, además de generar par, es el responsable del posicionamiento.",
        "(V.)MPG.TMASTERAXIS[nb] - Tándem [nb]. Número lógico del eje maestro"@es ;
    ns1:valor "Cualquier eje definido en AXISNAME o cabezal definido en SPDLNAME" .

ns1:Parametro_TMOPERATION a ns1:Parametro ;
    rdfs:label "Tiempo de operación (TMOPERATION)",
        "TMOPERATION"@es,
        "V.PLC.TMOPERATION"@es ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "$BREAK $ENDSWITCH ; Fin análisis del tipo de operación. V.PLC.TMOPERATION = 0"@es,
        "TMOPERATION = 15"@es,
        "comunica al PLC la operación a efectuar asignando a TMOPERATION el valor adecuado."@es ;
    ns1:valor "0",
        "15" .

ns1:Parametro_TORQDIST_1073 a ns1:Parametro ;
    rdfs:label "TORQDIST" ;
    ns1:identificador "TORQDIST" ;
    ns1:textoExtracto "según el parámetro 'TORQDIST' (p.e para una distribución del 50%, la mitad del par)."@es ;
    ns1:valor "50%"^^xsd:string .

ns1:Parametro_TP85_1072 a ns1:Parametro ;
    rdfs:label "Parámetro TP85 (valor monitorizado de par)"@es ;
    ns1:identificador "TP85" ;
    ns1:textoExtracto "cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador"@es .

ns1:Parametro_TRANSDELAY a ns1:Parametro ;
    rdfs:label "TRANSDELAY" ;
    ns1:identificador "TRANSDELAY" ;
    ns1:monitoreaParametro ns1:Parametro_ACFGAIN,
        ns1:Parametro_ACFWFACTOR,
        ns1:Sensor_EjeAsociado ;
    ns1:textoExtracto "TRANSDELAY Corrección del retardo introducido por el bus y el regulador. Parámetro valido para ejes lineales y rotativos. Parámetro valido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0 a 4*LOOPTIME µs. Valor por defecto: 0.",
        "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." ;
    ns1:valor "0",
        "0-4*LOOPTIME µs"@es .

ns1:Parametro_TSLAVEAXIS a ns1:Parametro ;
    rdfs:label "MPG.TSLAVEAXIS[nb]",
        "SLAVEAXIS (Parámetro TSLAVEAXIS)" ;
    ns1:documentadoEn ns1:Tabla_1070_VariablesTandem ;
    ns1:identificador "MPG.TSLAVEAXIS[nb]",
        "TSLAVEAXIS" ;
    ns1:textoExtracto "SLAVEAXIS Pareja tándem. Eje/cabezal esclavo. [...] El motor esclavo únicamente suministra par.",
        "(V.)MPG.TSLAVEAXIS[nb] - Tándem [nb]. Número lógico del eje esclavo"@es ;
    ns1:valor "Cualquier eje definido en AXISNAME o cabezal definido en SPDLNAME" .

ns1:Parametro_Terr_67 a ns1:Parametro ;
    rdfs:label "Error de par entre motores (T.err)" ;
