    ns1:tieneComponente ns1:InterfazUsuario_KeyLED1,
        ns1:InterfazUsuario_KeyLED1_1,
        ns1:InterfazUsuario_KeyLED1_2 .

ns1:Sistema_ParametrosAritmeticosComunes a ns1:Sistema ;
    rdfs:label "Sistema de parámetros aritméticos comunes entre canales" ;
    ns1:textoExtracto "Los parámetros MAXCOMP y MINCOMP definen el grupo de parámetros aritméticos comunes a todos los canales que se desea utilizar. Los parámetros comunes son accesibles desde cualquier canal. El valor de estos parámetros es compartido por todos los canales." ;
    ns1:tieneComponente ns1:Parametro_BKUPCUP,
        ns1:Parametro_MAXCOMP,
        ns1:Parametro_MINCOMP .

ns1:Sistema_ProcesoReset a ns1:Sistema ;
    rdfs:label "Proceso de reset del CNC" ;
    ns1:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN (RESETIN=1). 2 El canal asume las condiciones iniciales (las definidas en los parámetros máquina). 3 El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. 4 El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." ;
    ns1:tieneComponente ns1:InterfazUsuario_TeclaRESET,
        ns1:Parametro_MINAENDW,
        ns1:Parametro_RESETIN,
        ns1:Parametro_RESETOUT,
        ns1:Subrutina_PROGRAM_RESET,
        ns1:Subrutina_PROGRAM_RESET_C1,
        ns1:Subrutina_PROGRAM_RESET_C2,
        ns1:Subrutina_PROGRAM_RESET_C3,
        ns1:Subrutina_PROGRAM_RESET_C4 .

ns1:Sistema_ProgramacionPLC a ns1:Sistema ;
    rdfs:label "Sistema de programación del PLC (modos REA/IMA y directivas)"@es ;
    ns1:cumpleNormativa ns1:Directiva_EXTERN,
        ns1:Directiva_L,
        ns1:Directiva_SUB ;
    ns1:textoExtracto "M1 M2 Con valores reales (REA) la salida O5 toma el valor 1 al finalizar el primer scan o ciclo, mientras que necesita 4 ciclos con valores imagen (IMA). [...] Una subrutina también puede comenzar la directiva L y finalizar con la directiva END."@es ;
    ns1:tieneFrecuencia ns1:ModoOperacion_ValoresImagen,
        ns1:ModoOperacion_ValoresReales .

ns1:Sistema_ProteccionTendenciaEmbalamiento a ns1:Sistema ;
    rdfs:label "Sistema de protección de tendencia y antiembalamiento"@es ;
    ns1:activaAlarma ns1:Alarma_ProteccionAntiembalamiento ;
    ns1:compuestoPor ns1:Parametro_ESTDELAY,
        ns1:Parametro_TENDENCY,
        ns1:Parametro_TENDTIME ;
    ns1:textoExtracto "Este parámetro [TENDENCY] habilita dos testeos: • Vigilancia de la tendencia del eje. [...] • Protección frente al embalamiento."@es .

ns1:Sistema_RIO5 a ns1:Sistema ;
    rdfs:label "Bastidor RIO5"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_RIO5_24DI_16DO ;
