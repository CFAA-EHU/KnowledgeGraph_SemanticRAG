ns1:EjeTandem a ns1:Sistema ;
    rdfs:label "Eje tándem" ;
    ns1:compuestoPor ns1:EjeEsclavo,
        ns1:EjeMaestro ;
    ns1:textoExtracto "En un eje tándem, tanto el eje maestro como esclavo deben estar habilitados antes de poder moverse"@es .

ns1:EjeTandem_1056 a ns1:Sistema ;
    rdfs:label "Eje tándem (maestro-esclavo)"@es ;
    ns1:compuestoPor ns1:MotorTandemEsclavo_1056,
        ns1:MotorTandemMaestro_1056,
        ns1:PinonCremallera_1056 ;
    ns1:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)."@es .

ns1:EjeTandem_1069 a ns1:Sistema ;
    rdfs:label "Eje tándem (configuración maestro-esclavo)"@es ;
    ns1:textoExtracto "La aplicación del valor de precarga implica necesariamente la unión mecánica entre los motores maestro y esclavo que forman el eje tándem. De no ser así, los motores se moverán incluso sin consigna de control."@es ;
    ns1:tieneComponente ns1:ControladorPI_1069,
        ns1:FiltroPrecarga_1069,
        ns1:MotorEsclavo_1069,
        ns1:MotorMaestro_1069 .

ns1:EjeVirtualHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Eje virtual de la herramienta"@es ;
    ns1:textoExtracto """\r
    Se define como eje virtual de la herramienta a un eje ficticio que siempre se mueve en la dirección en la que se encuentra orientada la herramienta.\r
    La finalidad del eje virtual de la herramienta, es facilitar el movimiento en la dirección de la herramienta cuando ésta no se encuentra alineada con los ejes de la máquina.\r
    """@es ;
    ns1:tieneComponente ns1:Parametro_VIRTAXCANCEL,
        ns1:Parametro_VIRTAXISNAME .

