ns1:Parametro_Posicion_50mm a ns1:Parametro ;
    rdfs:label "Posición 50 mm",
        "Posición 50 mm"@es ;
    ns1:documentadoEn ns1:Tabla_Posicionamiento_4_4_8 ;
    ns1:ilustradoEn ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS ;
    ns1:textoExtracto "marcas en 50 mm",
        "50mm"@es ;
    ns1:valor "50",
        "50mm" .

ns1:Parametro_PotenciaConsumidaCabezal a ns1:Parametro ;
    rdfs:label "Potencia consumida por el cabezal (%)"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "D Potencia consumida por el cabezal (definida como porcentaje de la potencia nominal)."@es .

ns1:Parametro_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo",
        "Potencia objetivo (PWRSP, %)"@es ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion,
        ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "calcula la potencia objetivo ('potencia consumida' – 'potencia en vacío').",
        "potencia objetivo obtenida en la fase de aprendizaje",
        "F Potencia objetivo o potencia de corte idónea (definida como porcentaje de la potencia nominal); potencia aprendida o potencia programada en la sentencia #DMCON (comando PWRSP)."@es,
        "La potencia objetivo se programa como un porcentaje de la potencia nominal del cabezal. La programación de la potencia objetivo es opcional; si no se programa, el CNC realiza una fase de aprendizaje para determinarla."@es ;
    ns1:valor ">=20% de la potencia en vacío"@es .

ns1:Parametro_PotenciaVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío",
        "Potencia en vacío (%)"@es ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion,
        ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "el CNC mide la potencia consumida por el cabezal en vacío (sin mecanizar). Conocer la potencia en vacío permite al CNC detectar las entradas y salidas en la pieza durante el mecanizado.",
        "G Potencia en vacío (definida como porcentaje de la potencia nominal)."@es .

ns1:Parametro_ProfundidadPasada a ns1:Parametro ;
    rdfs:label "Profundidad de pasada" ;
    ns1:textoExtracto "Se recomienda realizar la fase de aprendizaje con una profundidad de pasada lo más aproximada posible a la que se va utilizar durante el mecanizado; en caso contrario, si la profundidad de pasada es más pequeña, la potencia objetivo calculada puede no ser la apropiada." .

ns1:Parametro_Pulsos a ns1:Parametro ;
    rdfs:label "Unidad de pulsos"@es ;
    ns1:documentadoEn ns1:Tabla_PosUnits_260 ;
    ns1:textoExtracto "La comunicación con el regulador se realiza en pulsos."@es ;
    ns1:valor "pulsos"@es .

ns1:Parametro_RAPIDOVR a ns1:Parametro ;
    rdfs:label "RAPIDOVR" ;
    ns1:identificador "(V.)[ch].MPG.RAPIDOVR" ;
    ns1:ilustradoEn ns1:InterfazUsuario_PanelMPG ;
    ns1:monitoreaParametro ns1:ModoOperacion_G00 ;
    ns1:textoExtracto "RAPIDOVR Override actúa en G00 (entre 0 y 100%). Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.RAPIDOVR Este parámetro indica si se permite modificar el porcentaje de avance (entre el 0% y el 100%) cuando se trabaja en G0." ;
    ns1:valor "Sí" .

ns1:Parametro_RCSALARM_1260 a ns1:Parametro ;
    rdfs:label "Variable DRV.RCSALARM para control de alarmas de entradas de captación"@es ;
    ns1:activaAlarma ns1:Alarma_EntradaCaptacion1_1260,
        ns1:Alarma_EntradaCaptacion2_1260,
        ns1:Alarma_EntradaCaptacion3_1260,
        ns1:Alarma_EntradaCaptacion4_1260 ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "RCSALARM" ;
    ns1:textoExtracto "Ejemplo. Se desea desactivar las alarmas de la segunda entrada de captación del módulo configurado como SERCOUNTID=4. El acceso desde el CNC será V.DRV.RCSALARM.4. El acceso desde el PLC será DRV.RCSALARM.4."@es ;
    ns1:valor 0,
        "valor_original_mascara" .

ns1:Parametro_REFMODE a ns1:Parametro ;
    rdfs:label "REFMODE" ;
    ns1:textoExtracto "REFMODE Modo de búsqueda de cero. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos posición. Valores posibles: Regulador / CNC. Valor por defecto: CNC." ;
    ns1:valor "CNC" .

ns1:Parametro_REFPOIN a ns1:Parametro ;
    rdfs:label "REFPOIN" ;
    ns1:monitoreaParametro ns1:Sistema_ReferenciadoEjes ;
    ns1:textoExtracto "marca de PLC REFPOIN(axis)=0 [...] REFPOIN(axis)=1" ;
    ns1:valor "Booleano (0/1)" .

ns1:Parametro_REFPULSE_1077 a ns1:Parametro ;
    rdfs:label "REFPULSE" ;
    ns1:identificador "REFPULSE" ;
    ns1:textoExtracto "Flanco de la señal de I0"@es ;
    ns1:valor "debe ser igual en ambos ejes"@es .

ns1:Parametro_REFSHIFT_PP150 a ns1:Parametro ;
    rdfs:label "REFSHIFT (PP150)" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCNC_51_52 ;
    ns1:identificador "PP150" ;
    ns1:textoExtracto "REFSHIFT | PP150 [...] Posición. | Interna." .

ns1:Parametro_REFSHIFT_PP151 a ns1:Parametro ;
    rdfs:label "REFSHIFT (PP151)" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCNC_51_52 ;
    ns1:identificador "PP151" ;
    ns1:textoExtracto "REFSHIFT | PP151 | Posición. | Externa." .

ns1:Parametro_REPOSFEED a ns1:Parametro ;
    rdfs:label "REPOSFEED",
        "REPOSFEED (Avance de reposicionamiento post-inspección)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "REPOSFEED" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Avance de reposicionamiento tras una inspección de herramienta.",
        "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED.",
        "REPOSFEED Avance máximo de reposicionamiento. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado.",
        "Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.REPOSFEED.xn Avance de reposicionamiento tras una inspección de herramienta o una subrutina de interrupción.",
        "REPOSFEED | Avance de reposicionamiento tras una inspección de herramienta."@es ;
    ns1:valor "0 a 200000.0000 mm/min / 0 a 7874.01575 inch/min / 0 a 36000000.0000 grados/min" .

ns1:Parametro_RESPECTSIZES a ns1:Parametro ;
    rdfs:label "RESPECTSIZES" ;
    ns1:documentadoEn ns1:Tabla_MAGAZINE_MANAGEMENT ;
    ns1:textoExtracto "RESPECTSIZES En almacén rándom, buscar huecos del mismo tamaño. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.RESPECTSIZES Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ns1:valor "No" .

ns1:Parametro_RETRACTENABLE a ns1:Parametro ;
    rdfs:label "RETRACTENABLE" ;
    ns1:textoExtracto "RETRACTENABLE Habilitar la retirada de herramienta. Este parámetro muestra la tabla de parámetros para habilitar la retirada de herramienta en diferentes situaciones." ;
    ns1:tieneComponente ns1:Parametro_RETRACTTHREAD .

ns1:Parametro_REVEHYST_PP15 a ns1:Parametro ;
    rdfs:label "REVEHYST (PP15)" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCNC_51_52 ;
    ns1:identificador "PP15" ;
    ns1:textoExtracto "REVEHYST | PP15" .

ns1:Parametro_RKIN1 a ns1:Parametro ;
    rdfs:label "RKIN1" ;
    ns1:monitoreaParametro ns1:Sistema_ComunicacionPLC ;
    ns1:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ns1:Parametro_RKIN32 a ns1:Parametro ;
    rdfs:label "RKIN32" ;
    ns1:monitoreaParametro ns1:Sistema_ComunicacionPLC ;
    ns1:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ns1:Parametro_ROPARMAX a ns1:Parametro ;
    rdfs:label "ROPARMAX" ;
    ns1:identificador "V.MPG.ROPARMAX" ;
    ns1:textoExtracto "Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales." ;
    ns1:valor "0" .

ns1:Parametro_ROPARMIN a ns1:Parametro ;
    rdfs:label "ROPARMIN" ;
    ns1:identificador "V.MPG.ROPARMIN" ;
    ns1:textoExtracto "Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales. Si ambos parámetros se definen con valor 0, no hay parámetros protegidos. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_ROUNDFEED a ns1:Parametro ;
    rdfs:label "Parámetro ROUNDFEED",
        "ROUNDFEED" ;
    ns1:identificador "ROUNDFEED",
        "V.[ch].MPG.ROUNDFEED" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "Este parámetro define el porcentaje del avance activo que se va a emplear en el mecanizado. El CNC lo tiene en cuenta con ROUNDTYPE = %Avance.",
        "avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado. Dependiendo de la opción seleccionada, habrá que definir el parámetro MAXROUND o ROUNDFEED." ;
    ns1:valor "100" .

ns1:Parametro_RSTYPE a ns1:Parametro ;
    rdfs:label "RSTYPE",
        "RSTYPE (Tipo de línea serie)"@es ;
    ns1:identificador "MPG.RSTYPE",
        "RSTYPE" ;
    ns1:textoExtracto "RSTYPE Tipo de línea serie. Valores posibles: RS232 / RS485 / RS422. Valor por defecto: RS232.",
        "la línea serie debe estar configurada como RS422 (parámetro RSTYPE)"@es ;
    ns1:valor "RS232"^^xsd:string .

ns1:Parametro_RTCP_TDATA10 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA10 (RTCP)" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza." ;
    ns1:valor "0",
        "1" .

ns1:Parametro_RadioBolaPalpador a ns1:Parametro ;
    rdfs:label "R" ;
    ns1:textoExtracto "R: Radio de la bola del palpador." ;
    ns1:valor "R"^^xsd:string .

ns1:Parametro_RadioEjeC a ns1:Parametro ;
    rdfs:label "Radio en programación del eje C (#CYL)"@es ;
    ns1:identificador "#CYL" ;
    ns1:textoExtracto "En la sentencia #CYL es obligatorio programar el radio. Para corregir los programas de versiones anteriores, en los que no esté definido el radio, habrá que definirlo con valor 0 (cero)."@es ;
    ns1:valor "0" .

ns1:Parametro_Recurso_I3 a ns1:Parametro ;
    rdfs:label "Recurso I3" ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "IMA I3 AND REA M4 = 02"@es .

ns1:Parametro_Recurso_M4 a ns1:Parametro ;
    rdfs:label "Recurso M4" ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "IMA I3 AND REA M4 = 02"@es .

ns1:Parametro_Recurso_O32 a ns1:Parametro ;
    rdfs:label "Recurso O32" ;
    ns1:identificador "O32" ;
    ns1:textoExtracto "Las instrucciones de acción (=O32) siempre actualizan los valores reales de los recursos del PLC"@es .

ns1:Parametro_RefNeed a ns1:Parametro ;
    rdfs:label "Parámetro MPG.REFNEED"@es ;
    ns1:documentadoEn ns1:Tabla_CrossComp ;
    ns1:identificador "MPG.REFNEED[tbl]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.REFNEED[tbl]. Este parámetro indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación."@es ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_ResolucionEje_Encoder8192 a ns1:Parametro ;
    rdfs:label "Resolución del eje (Encoder 8192 + Husillo 10mm)" ;
    ns1:identificador "0.0012mm" ;
    ns1:textoExtracto "La resolución del eje será; 10 / 8192 = 0,0012 mm." ;
    ns1:valor "0.0012" .

ns1:Parametro_ResolucionEje_Inductosyn2Grad a ns1:Parametro ;
    rdfs:label "Resolución del eje (Inductosyn 2°)" ;
    ns1:identificador "0.0002°" ;
    ns1:textoExtracto "La resolución del eje será; 2° / 10000 = 0,0002 grados." ;
    ns1:valor "0.0002" .

ns1:Parametro_ResolucionEje_Inductosyn4Grad a ns1:Parametro ;
    rdfs:label "Resolución del eje (Inductosyn 4°)" ;
    ns1:identificador "0.0004°" ;
    ns1:textoExtracto "La resolución del eje será; 4° / 10000 = 0,0004 grados." ;
    ns1:valor "0.0004" .

ns1:Parametro_ResolucionMPG a ns1:Parametro ;
    rdfs:label "Resolución de desplazamiento por impulso MPG" ;
    ns1:identificador "V.[ch].MPA.MPGRESOL[pos].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MPGRESOL[pos].xn. En cada parámetro hay que definir la distancia que se desplaza el eje por cada impulso del volante. Si la resolución es negativa, se invierte el sentido de desplazamiento (movimiento contrario al indicado por las señales A y B del volante). Los valores más habituales son los definidos por defecto." ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados" .

ns1:Parametro_RetardoSimulacion a ns1:Parametro ;
    rdfs:label "Retardo entre envío de códigos de teclas"@es ;
    ns1:textoExtracto "Se recomienda utilizar un retardo de al menos 200 ms entre el envío de dos códigos (por seguridad)."@es ;
    ns1:valor "200" .

ns1:Parametro_SAI_ADDRESS a ns1:Parametro ;
    rdfs:label "Dirección de entrada analógica (ADDRESS)"@es ;
    ns1:documentadoEn ns1:Tabla_SAI ;
    ns1:identificador "MPG.ADDRESS" ;
    ns1:textoExtracto "ADDRESS Número de entrada analógica. Valores posibles: De 0 a 60. Valor por defecto: 0. Variable asociada: (V.)MPG.ADDRESS[n] Número de entrada analógica."@es ;
    ns1:valor 0 .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "SERBRATE (Velocidad de transmisión de Sercos)" ;
    ns1:identificador "V.MPG.SERBRATE" ;
    ns1:textoExtracto "SERBRATE Velocidad de transmisión de Sercos. Valores posibles: 2/4/8/16 Mbps (megabits por segundo). Valor por defecto: 4 Mbps." ;
    ns1:valor "4 Mbps" .

ns1:Parametro_SERCOUNTID_1260 a ns1:Parametro ;
    rdfs:label "Parámetro SERCOUNTID (número de nodo del módulo RCS-S)"@es ;
    ns1:documentadoEn ns1:Tabla_DriveVar_1260 ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "AXIS | Número de nodo del módulo RCS-S (parámetro SERCOUNTID)."@es .

ns1:Parametro_SERPOWSE a ns1:Parametro ;
    rdfs:label "SERPOWSE (Potencia óptica de Sercos)" ;
    ns1:identificador "V.MPG.SERPOWSE" ;
    ns1:textoExtracto "SERPOWSE Potencia óptica de Sercos. Valores posibles: De 1 a 6 (placa Sercos I) / de 1 a 8 (placa Sercos II). Valor por defecto: 4 (placa Sercos I) / 2 (placa Sercos II)." ;
    ns1:valor "4 (placa Sercos I) / 2 (placa Sercos II)" .

ns1:Parametro_SERPOWSE_92 a ns1:Parametro ;
    rdfs:label "SERPOWSE (configuración bus Sercos)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_92 ;
    ns1:textoExtracto "SERPOWSE | Longitud del cable. | Tipo de cable recomendado." ;
    ns1:valor "1-8" .

ns1:Parametro_SERVOOFF a ns1:Parametro ;
    rdfs:label "SERVOOFF" ;
    ns1:identificador "SERVOOFF" ;
    ns1:monitoreaParametro ns1:Sistema_ReguladorAnalogico ;
    ns1:textoExtracto "SERVOOFF Compensación del offset. [...] Valores posibles: Entre ±32767. Valor por defecto: 0. [...] correspondiendo para el valor ±32767 la consigna de ±10 V." ;
    ns1:valor "-32767 a 32767" .

ns1:Parametro_SERVOON a ns1:Parametro ;
    rdfs:label "SERVOON" ;
    ns1:monitoreaParametro ns1:Sensor_SERVOON ;
    ns1:textoExtracto "tras activar la marca ENABLE, el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOON está a (=0). [...] Cuando se desea controlar el eje sólo en los desplazamientos, se debe asignar al parámetro máquina DWELL un valor superior al tiempo entre 2 scan de PLC para que el eje no dé el error de 'eje bloqueado'" .

ns1:Parametro_SERVOSON a ns1:Parametro ;
    rdfs:label "Marca SERVOSON (habilitación cabezal)"@es ;
    ns1:textoExtracto "Para evitar errores del tipo 'eje bloqueado', en la maniobra del PLC se debe contemplar la habilitación de la marca SERVOSON con las funciones M19, roscado rígido y cuando se active la marca ENABLES."@es ;
    ns1:valor "SERVOSON" .

ns1:Parametro_SFTYPE a ns1:Parametro ;
    rdfs:label "SFTYPE" ;
    ns1:textoExtracto "SFTYPE Tipo de árbol de softkeys. Valores posibles: Estándar / Desplegables. Valor por defecto: Estándar. Dependiendo del valor seleccionado, el árbol de softkeys aparece de la siguiente forma." ;
    ns1:valor "Estándar" .

ns1:Parametro_SFUN1 a ns1:Parametro ;
    rdfs:label "SFUN1",
        "SFUN1 (velocidad cabezal 1)" ;
    ns1:documentadoEn ns1:Tabla_SFUN_Se_alesConsulta ;
    ns1:identificador "SFUN1" ;
    ns1:monitoreaParametro ns1:Sistema_ControlCNC ;
    ns1:textoExtracto "SFUN1 ... Estos registros indican la velocidad programada en cada uno de los cabezales.",
        "SFUN1 | ... | 1000" ;
    ns1:valor "1000"^^xsd:string .

ns1:Parametro_SFUN2 a ns1:Parametro ;
    rdfs:label "SFUN2",
        "SFUN2 (velocidad cabezal 2)" ;
    ns1:documentadoEn ns1:Tabla_SFUN_Se_alesConsulta ;
    ns1:identificador "SFUN2" ;
    ns1:monitoreaParametro ns1:Sistema_ControlCNC ;
    ns1:textoExtracto "SFUN2",
        "SFUN2 | ... | 550" ;
    ns1:valor "550"^^xsd:string .

ns1:Parametro_SFUN3 a ns1:Parametro ;
    rdfs:label "SFUN3",
        "SFUN3 (velocidad cabezal 3)" ;
    ns1:documentadoEn ns1:Tabla_SFUN_Se_alesConsulta ;
    ns1:identificador "SFUN3" ;
    ns1:monitoreaParametro ns1:Sistema_ControlCNC ;
    ns1:textoExtracto "SFUN3",
        "SFUN3 | ... | $FFFFFFFF" ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:Parametro_SFUN4 a ns1:Parametro ;
    rdfs:label "SFUN4",
        "SFUN4 (velocidad cabezal 4)" ;
    ns1:documentadoEn ns1:Tabla_SFUN_Se_alesConsulta ;
    ns1:identificador "SFUN4" ;
    ns1:monitoreaParametro ns1:Sistema_ControlCNC ;
    ns1:textoExtracto "SFUN4",
        "SFUN4 | ... | $FFFFFFFF" ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:Parametro_SHORTESTWAY_69 a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es .

ns1:Parametro_SINMAGNI a ns1:Parametro ;
    rdfs:label "SINMAGNI" ;
    ns1:identificador "SINMAGNI" ;
    ns1:monitoreaParametro ns1:Componente_SensorCaptacionSenosoidal ;
    ns1:textoExtracto "Factor de multiplicación para la señal de captación senoidal. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_SINMAGNI_1077 a ns1:Parametro ;
    rdfs:label "SINMAGNI" ;
    ns1:identificador "SINMAGNI" ;
    ns1:textoExtracto "Factor multiplicador de la señal sinusoidal"@es ;
    ns1:valor "debe ser igual en ambos ejes"@es .

ns1:Parametro_SLAVEAXIS_61 a ns1:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ns1:documentadoEn ns1:Tabla_ParametrosTandem_61 ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "Pareja tándem. Eje/cabezal esclavo."@es .

ns1:Parametro_SLIMIT a ns1:Parametro ;
    rdfs:label "SLIMIT" ;
    ns1:identificador "SLIMIT" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "SLIMIT Límite máximo de seguridad para la velocidad del cabezal. Parámetro válido para cabezales. [...] Valor por defecto: 0 (no hay limitación)." ;
    ns1:valor "0 a 200000.0000 rpm" .

ns1:Parametro_SLIMITAC a ns1:Parametro ;
    rdfs:label "Límite de seguridad para avance/velocidad (marca SLIMITAC)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución."@es .

ns1:Parametro_SLIMITACSPDL a ns1:Parametro ;
    rdfs:label "Límite de seguridad para velocidad de avance (marca SLIMITACSPDL)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución."@es .

ns1:Parametro_SLOPETYPE_LINEAR a ns1:Parametro ;
    rdfs:label "Perfil LINEAR (SLOPETYPE)"@es ;
    ns1:documentadoEn ns1:Tabla_PerfilesMovimiento_SLOPETYPE ;
    ns1:textoExtracto "velocidad v(t), aceleración a(t) y jerk j(t) [...] la lineal muestra transiciones bruscas"@es .

ns1:Parametro_SLOPETYPE_SQUARE_SINE a ns1:Parametro ;
    rdfs:label "Perfil SQUARE SINE (SLOPETYPE)"@es ;
    ns1:documentadoEn ns1:Tabla_PerfilesMovimiento_SLOPETYPE ;
