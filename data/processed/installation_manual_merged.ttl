ns1:Parametro_TCOMPLIM a ns1:Parametro ;
    rdfs:label "MPG.TCOMPLIM[nb]",
        "Parámetro TCOMPLIM"@es ;
    ns1:documentadoEn ns1:Tabla_1070_VariablesTandem ;
    ns1:identificador "(V.)MPG.TCOMPLIM[nb]",
        "MPG.TCOMPLIM[nb]" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "(V.)MPG.TCOMPLIM[nb] - Tándem [nb]. Limitación de la compensación"@es,
        "Parámetro incluido en la tabla TANDEM. Este parámetro limita la compensación máxima que introduce el tándem. Este límite también se aplica a la integral. Este parámetro hace referencia al motor maestro. Se define como porcentaje de la velocidad máxima del motor maestro. Si se programa con valor \"0\", la salida del control del tándem será cero, lo que implica deshabilitar el tándem."@es ;
    ns1:valor "0" .

