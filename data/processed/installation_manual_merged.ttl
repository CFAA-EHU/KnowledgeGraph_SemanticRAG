ns1:Operacion_CambioHerramientaOptimizado_959 a ns1:ModoOperacion ;
    rdfs:label "Cambio de herramienta optimizado (TMOPERATION=12)"@es ;
    ns1:identificador "TMOPERATION=12" ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo en los siguientes tipos de almacén síncrono: • Tipo no-random con brazo cambiador de dos pinzas. • Tipo random cuando se trata de herramientas especiales."@es .

ns1:Operacion_DejarHerramientaEnTierra_959 a ns1:TareaMantenimiento ;
