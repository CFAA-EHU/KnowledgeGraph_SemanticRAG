ns1:HBH4 a ns1:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH4" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 cuenta como un volante." .

ns1:HBLS a ns1:ComponenteElectrico ;
    rdfs:label "Mando portátil HBLS" ;
    ns1:textoExtracto "El mando portátil HBLS no cuenta como volante a la hora de definir este parámetro." .

ns1:HTIME a ns1:Parametro ;
