ns1:ComponenteElectrico_MemoriaRAM a ns1:ComponenteElectrico ;
    rdfs:label "Memoria RAM"@es ;
    ns1:textoExtracto "las rutinas OEM [...] se cargan en la memoria RAM durante la preparación de bloques. [...] el CNC las borra de la memoria RAM."@es .

ns1:ComponenteElectrico_MicroI0 a ns1:ComponenteElectrico ;
    rdfs:label "Micro I0" ;
    ns1:textoExtracto "Cuando hay micro de I0, el CNC no realiza la búsqueda de I0 sobre la marcha",
        "En los cabezales con micro de I0, el cabezal pasa dos veces sobre el micro",
        "el eje busca el micro, invierte el sentido de búsqueda, y cuando deja de pulsar el micro empieza a buscar el I0" .

ns1:ComponenteElectrico_MicroSeguridadEje a ns1:ComponenteElectrico ;
    rdfs:label "Micro de seguridad para búsqueda de referencia" ;
    ns1:textoExtracto "Cuando hay micro de I0, el CNC no realiza la búsqueda de I0 sobre la marcha, según esté girando en M3 ó M4; la búsqueda la realiza siempre en el sentido definido por el parámetro REFDIREC",
        "El eje realiza la búsqueda de referencia mediante las marcas codificadas, pero si pulsa el micro antes de terminar, invierte el sentido de búsqueda",
        "En los cabezales con micro de I0, el cabezal pasa dos veces sobre el micro",
        "el eje busca el micro, invierte el sentido de búsqueda, y cuando deja de pulsar el micro empieza a buscar el I0",
        "el eje dispone de un micro de seguridad para que el eje no se salga de los límites de recorrido al hacer la búsqueda" .

