    ns1:textoExtracto "v a j G00FEED ACCEL ACCJERK t t t t/3 t t/3 t t/3 t 3 G00FEED ACCEL ACCEL = x ACCJERK = 3 x"@es .

ns1:ModoOperacion_G01 a ns1:ModoOperacion ;
    rdfs:label "G01 (Interpolación lineal)",
        "Modo de operación G01 (interpolación lineal)" ;
    ns1:textoExtracto "G1 se mantiene modal. En el ámbito de influencia de un ciclo fijo se mantendrá activa la última G programada.",
        "avance máximo de mecanizado (movimientos en G01/G02/G03) del eje" ;
    ns1:tieneFrecuencia ns1:Parametro_MAXFEED .

ns1:ModoOperacion_G02 a ns1:ModoOperacion ;
    rdfs:label "Modo de operación G02 (interpolación circular horaria)" ;
    ns1:textoExtracto "avance máximo de mecanizado (movimientos en G01/G02/G03) del eje" ;
    ns1:tieneFrecuencia ns1:Parametro_MAXFEED .

ns1:ModoOperacion_G02_G03 a ns1:ModoOperacion ;
    rdfs:label "G02/G03 (Interpolación circular)" ;
    ns1:controla ns1:Parametro_G2G3MODAL ;
    ns1:textoExtracto "G2G3MODAL: La programación en G2/G3 se mantiene modal." .

ns1:ModoOperacion_G03 a ns1:ModoOperacion ;
    rdfs:label "Modo de operación G03 (interpolación circular antihoraria)" ;
    ns1:textoExtracto "avance máximo de mecanizado (movimientos en G01/G02/G03) del eje" ;
    ns1:tieneFrecuencia ns1:Parametro_MAXFEED .

ns1:ModoOperacion_G1 a ns1:ModoOperacion ;
    rdfs:label "G1" ;
    ns1:identificador "G1" ;
    ns1:textoExtracto "El CNC asume la función G1. Los desplazamientos en G1 se realizan al avance activo en el CNC. El CNC no visualiza G1 en la historia de funciones G. Al acceder al modo MDI/MDA y programar un movimiento sin G, el CNC lo ejecuta en G1. Al programar un movimiento desde el modo manual, el eje se mueve en G1." .

ns1:ModoOperacion_G170 a ns1:ModoOperacion ;
    rdfs:label "Función G170"@es ;
    ns1:identificador "G170" ;
    ns1:textoExtracto "La función G170 indica que el eje trabaje como un eje rotativo o lineal normal."@es .

ns1:ModoOperacion_G171 a ns1:ModoOperacion ;
    rdfs:label "Función G171"@es ;
    ns1:identificador "G171" ;
    ns1:textoExtracto "La función G171 indica que el eje trabaje como eje Hirth (función por defecto)."@es .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo G201 (Manual superpuesto a automático)"@es,
        "Modo manual superpuesto (G201)"@es ;
    ns1:controla ns1:Parametro_IPOACCP ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es,
        "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, estos parámetros indican cuánto se"@es .

