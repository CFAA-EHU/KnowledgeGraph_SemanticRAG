    ns1:textoExtracto "ADDORG Distancia entre los cero máquina de ambos ejes. Valores posibles: ±214748.3647 mm / Valor por defecto: 0. Variable asociada: (V.)MPK.ADDORG[nb]" ;
    ns1:valor "0" .

