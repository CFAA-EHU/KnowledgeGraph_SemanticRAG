ns1:Tarea_EngraseEjes a ns1:TareaMantenimiento ;
    rdfs:label "Engrase de ejes" ;
    ns1:requiereMantenimiento ns1:Senal_LUBR,
        ns1:Senal_LUBRENA,
        ns1:Senal_LUBROK ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." .

ns1:Tarea_SimulacionTecladoPLC a ns1:ModoOperacion ;
    rdfs:label "Simulación de teclado desde PLC" ;
    ns1:documentadoEn ns1:CombinacionTeclas_B0KEYBD1 ;
    ns1:textoExtracto "8.4 Simular el teclado desde el PLC (...) Enviar el código asociado a soltar la primera tecla (por ejemplo, tecla [CTRL]). Enviar el código asociado a soltar la segunda tecla (por ejemplo, tecla [F1])."@es .

ns1:TeclaESTOP a ns1:ElementoSeguridad ;
    rdfs:label "Tecla STOP (ESTOP)"@es ;
    ns1:identificador "ESTOP" ;
    ns1:mitigaRiesgo ns1:RutinaM06 ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP."@es .

ns1:TeclaSTOP a ns1:ElementoSeguridad ;
    rdfs:label "Tecla STOP" ;
    ns1:habilitadoPor ns1:RutinaM06 ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .

