@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AlarmaErrorEtherCATNoDisponible a ex:Alarma ;
    rdfs:label "0130 EtherCAT no disponible" ;
    ex:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo." .

ex:AlarmaErrorLecturaVariableRegulador a ex:Alarma ;
    rdfs:label "0131 Error en la lectura de variable de regulador" ;
    ex:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las" .

ex:AccionProhibidaContactarFagor a ex:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ex:SistemaCNC ex:activaAlarma ex:AlarmaErrorEtherCATNoDisponible ;
             ex:activaAlarma ex:AlarmaErrorLecturaVariableRegulador .