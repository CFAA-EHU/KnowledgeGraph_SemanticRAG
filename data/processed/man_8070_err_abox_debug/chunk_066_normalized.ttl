@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ComandoAPPEND a ex:Comando ;
    rdfs:label "A" ;
    ex:textoExtracto "Al abrir un archivo con el comando \"A\" (APPEND)" .

ex:ComandoDELETE a ex:Comando ;
    rdfs:label "D" ;
    ex:textoExtracto "Abrir un archivo con el comando \"D\" (DELETE)" .

ex:ComandoTYPE a ex:Comando ;
    ex:textoExtracto "el comando TYPE debe coincidir con el formato del archivo" .

ex:Archivo a ex:Componente ;
    ex:textoExtracto "Al abrir un archivo con el comando \"A\" (APPEND), el comando TYPE debe coincidir con el formato del archivo. Si el archivo no existe, el CNC crea uno nuevo en el formato especificado en el comando TYPE" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "el CNC crea uno nuevo en el formato especificado en el comando TYPE" .