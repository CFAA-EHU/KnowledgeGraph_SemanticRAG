@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AccionProhibidaContactarProveedor a ex:AccionProhibida ;
    rdfs:label "Póngase en contacto con su proveedor" ;
    ex:textoExtracto "póngase en contacto con su proveedor." .

ex:AccionProhibidaContactarFabricante a ex:AccionProhibida ;
    rdfs:label "Póngase en contacto con el fabricante de la máquina" ;
    ex:textoExtracto "póngase en contacto con el fabricante de la máquina." .

ex:DiagnosticoFalloLimiteJerkSobrepasado a ex:DiagnosticoFallo ;
    rdfs:label "'Límite de jerk sobrepasado'" ;
    ex:textoExtracto "'Límite de jerk sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza. CAUSA El eje está sobrepasando su límite de jerk permitido." .

ex:DiagnosticoFalloNoRTIT a ex:DiagnosticoFallo ;
    rdfs:label "'No RT IT'" ;
    ex:textoExtracto "'No RT IT' DETECCIÓN Durante el funcionamiento del CNC. CAUSA No entra la interrupción de tiempo real." .

ex:DiagnosticoFalloPositionLoopOverflow a ex:DiagnosticoFallo ;
    rdfs:label "Position Loop Overflow" ;
    ex:textoExtracto "Position Loop Overflow. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido." .

ex:TareaMantenimientoAjustarLOOPTIME a ex:TareaMantenimiento ;
    rdfs:label "Ajustar el parámetro LOOPTIME" ;
    ex:textoExtracto "ajustar el parámetro LOOPTIME." .

ex:ParametroLOOPTIME a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "parámetro LOOPTIME" .

ex:TareaMantenimientoReiniciarCNC a ex:TareaMantenimiento ;
    rdfs:label "Reiniciar el CNC" ;
    ex:textoExtracto "Reiniciar el CNC." .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" ;
    ex:textoExtracto "funcionamiento del CNC" .

ex:TareaMantenimientoAjustarLOOPTIME solucionaFallo ex:DiagnosticoFalloPositionLoopOverflow .
ex:AccionProhibidaContactarProveedor solucionaFallo ex:DiagnosticoFalloLimiteJerkSobrepasado .
ex:AccionProhibidaContactarProveedor solucionaFallo ex:DiagnosticoFalloNoRTIT .
ex:TareaMantenimientoReiniciarCNC solucionaFallo ex:DiagnosticoFalloNoRTIT .

ex:SistemaCNC monitoreaParametro ex:ParametroLOOPTIME .