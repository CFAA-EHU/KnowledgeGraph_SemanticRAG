@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametroValorEtiquetaN fuera de Rango a ex:Parametro ;
    rdfs:label "Valor de etiqueta N fuera de rango" ;
    ex:textoExtracto "'Valor de etiqueta N fuera de rango'" .

ex:DiagnosticoFalloNumeroBloqueInvalido a ex:DiagnosticoFallo ;
    rdfs:label "El número de bloque 'N' no es válido." ;
    ex:textoExtracto "CAUSA El número de bloque \"N\" no es válido." ;
    ex:solucionaFallo ex:TareaRevisarNumeroBloque .

ex:TareaRevisarNumeroBloque a ex:TareaMantenimiento ;
    rdfs:label "El número de bloque debe ser un valor positivo y menor que 2147483646" ;
    ex:textoExtracto "SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." .

ex:ParametroFuncionGInexistente a ex:Parametro ;
    rdfs:label "Función G inexistente" ;
    ex:textoExtracto "'Función G inexistente'" .

ex:DiagnosticoFalloFuncionGInexistente a ex:DiagnosticoFallo ;
    rdfs:label "La función G programada no existe." ;
    ex:textoExtracto "CAUSA La función G programada no existe." ;
    ex:solucionaFallo ex:TareaRevisarProgramacion .

ex:TareaRevisarProgramacion a ex:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación." .