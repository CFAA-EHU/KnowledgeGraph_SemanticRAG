@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFalloEsperandoAUXENDdePLC a ex:DiagnosticoFallo ;
    rdfs:label "Esperando AUXEND de PLC" ;
    ex:textoExtracto "20001 Esperando AUXEND de PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

ex:DiagnosticoFalloEsperandoCabezalParado a ex:DiagnosticoFallo ;
    rdfs:label "Esperando cabezal %x parado" ;
    ex:textoExtracto "20002 Esperando cabezal %x parado. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ex:DiagnosticoFalloEsperandoCargaPrograma a ex:DiagnosticoFallo ;
    rdfs:label "Esperando carga de programa" ;
    ex:textoExtracto "20003 Esperando carga de programa. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ex:DiagnosticoFalloEsperandoSenalREVOK a ex:DiagnosticoFallo ;
    rdfs:label "Esperando señal REVOK del cabezal %x para iniciar G33/G34" ;
    ex:textoExtracto "20004 Esperando señal REVOK del cabezal %x para iniciar G33/G34. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ex:DiagnosticoFalloEsperandoConfirmacionGama a ex:DiagnosticoFallo ;
    rdfs:label "Esperando confirmación de gama por el regulador" ;
    ex:textoExtracto "20005 Esperando confirmación de gama por el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ex:DiagnosticoFalloEsperandoFinalManiobraPARK a ex:DiagnosticoFallo ;
    rdfs:label "Esperando final de maniobra #PARK en el regulador" ;
    ex:textoExtracto "20006 Esperando final de maniobra #PARK en el regulador. DETECCIÓN Durante la ejecución." .

ex:DiagnosticoFalloEsperandoCanalDisponible a ex:DiagnosticoFallo ;
    rdfs:label "Esperando canal disponible para #EXEC/#EXBLK" ;
    ex:textoExtracto "20007 Esperando canal disponible para #EXEC/#EXBLK. DETECCIÓN Durante la ejecución." .

ex:TareaMantenimientoReset a ex:TareaMantenimiento ;
    rdfs:label "Pulsar [RESET] y analizar las causas del retraso" ;
    ex:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoAUXENDdePLC .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoCabezalParado .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoCargaPrograma .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoSenalREVOK .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoConfirmacionGama .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoFinalManiobraPARK .
ex:TareaMantenimientoReset solucionaFallo ex:DiagnosticoFalloEsperandoCanalDisponible .