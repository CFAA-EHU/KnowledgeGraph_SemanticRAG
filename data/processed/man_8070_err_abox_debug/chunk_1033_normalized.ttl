@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AccionModificarArchivoCompensacionVolumetrica a ex:AccionProhibida ;
    rdfs:label "Modificar el archivo de la compensación volumétrica" ;
    ex:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ex:FalloErrorFicheroCompensacion a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ex:textoExtracto "23034 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto." .

ex:AccionModificarArchivoCompensacionVolumetrica solucionaFallo ex:FalloErrorFicheroCompensacion .