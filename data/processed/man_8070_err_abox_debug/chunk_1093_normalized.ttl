@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AccionProhibidaComprobarTolerancias a ex:AccionProhibida ;
    rdfs:label "Comprobar las tolerancias de montaje" ;
    ex:textoExtracto "Comprobar las tolerancias de montaje." .

ex:AccionProhibidaLimpiarCristal o ex:AccionProhibidaLimpiarCinta a ex:AccionProhibida ;
    rdfs:label "Limpiar el cristal o la cinta de acero de la regla" ;
    ex:textoExtracto "Limpiar el cristal o la cinta de acero de la regla." .

ex:TareaMantenimientoReemplazarEncoder a ex:TareaMantenimiento ;
    rdfs:label "Reemplazar el encóder o la cabeza de la regla" ;
    ex:textoExtracto "Reemplazar el encóder o la cabeza de la regla." .

ex:AccionProhibidaComprobarTolerancias ex:textoExtracto "Comprobar las tolerancias de montaje." .
ex:AccionProhibidaLimpiarCristal a ex:AccionProhibida ;
    ex:textoExtracto "Limpiar el cristal o la cinta de acero de la regla." .
ex:TareaMantenimientoReemplazarEncoder ex:textoExtracto "Reemplazar el encóder o la cabeza de la regla." .

ex:DiagnosticoFalloErrorE21C a ex:DiagnosticoFallo ;
    rdfs:label "Error en el captador de imagen (CCD)" ;
    ex:identificador "E21C" ;
    ex:textoExtracto "Error en el captador de imagen (CCD). Captación E21C." .

ex:DiagnosticoFalloErrorE21D a ex:DiagnosticoFallo ;
    rdfs:label "Error en el captador de imagen (CCD)" ;
    ex:identificador "E21D" ;
    ex:textoExtracto "Error en el captador de imagen (CCD). Captación E21D." .

ex:DiagnosticoFalloErrorE21A a ex:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación fuera de rango" ;
    ex:identificador "E21A" ;
    ex:textoExtracto "Captación E21A. Tensión de alimentación fuera de rango." .

ex:DiagnosticoFalloErrorE21B a ex:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación fuera de rango" ;
    ex:identificador "E21B" ;
    ex:textoExtracto "Captación E21B. Tensión de alimentación fuera de rango." .

ex:TareaMantenimientoReemplazarEncoder ex:solucionaFallo ex:DiagnosticoFalloErrorE21C .
ex:TareaMantenimientoReemplazarEncoder ex:solucionaFallo ex:DiagnosticoFalloErrorE21D .