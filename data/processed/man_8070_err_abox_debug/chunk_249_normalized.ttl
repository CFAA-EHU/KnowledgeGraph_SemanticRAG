@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridadPosicionAlmacenLibre o inexistente a ex:AvisoSeguridad ;
    rdfs:label "Posición del almacén libre o inexistente" ;
    ex:textoExtracto "'Posición del almacén libre o inexistente' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe." .

ex:DiagnosticoFalloErrorEscrituraVariable a ex:DiagnosticoFallo ;
    rdfs:label "Error en la escritura de la variable" ;
    ex:textoExtracto "'Error en la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable no existe." .

ex:AvisoSeguridadPosicionAlmacenLibre ex:mitigaRiesgo ex:SistemaCNC ;
    ex:textoExtracto "Sólo es posible leer la herramienta que está en una posición válida del almacén." .

ex:TareaMantenimientoSolucionErrorEscritura a ex:TareaMantenimiento ;
    rdfs:label "Solución para error de escritura" ;
    ex:solucionaFallo ex:DiagnosticoFalloErrorEscrituraVariable ;
    ex:textoExtracto "Las posibles causas son las siguientes: • La variable no existe." .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" .