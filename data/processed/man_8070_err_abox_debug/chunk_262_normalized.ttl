@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AccionProhibidaNoAdmiteCambioGamaConG63 o ex:AccionProhibida
    a ex:AccionProhibida ;
    rdfs:label "No se admite cambio de gama de cabezal con G63 o #CAX activos" ;
    ex:textoExtracto "'No se admite cambio de gama de cabezal con G63 o #CAX activos'" .

ex:AccionProhibidaNoAdmiteG63SinGamaPrevia o ex:AccionProhibida
    a ex:AccionProhibida ;
    rdfs:label "No se admite G63 sin gama previa en el cabezal" ;
    ex:textoExtracto "'No se admite G63 sin gama previa en el cabezal'" .

ex:AccionProhibidaNoAdmiteCAXConG63Activa o ex:AccionProhibida
    a ex:AccionProhibida ;
    rdfs:label "No se admite #CAX con G63 activa" ;
    ex:textoExtracto "'No se admite #CAX con G63 activa'" .

ex:AccionProhibidaNoAdmiteCambiarCabezalMasterConG33 o ex:AccionProhibida
    a ex:AccionProhibida ;
    rdfs:label "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas" ;
    ex:textoExtracto "'No se admite cambiar el cabezal master con G33/G63/G95/G96 activas'" .

ex:DiagnosticoFallo1545 o ex:DiagnosticoFallo
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama de cabezal con G63 o #CAX activos" ;
    ex:textoExtracto "'No se admite cambio de gama de cabezal con G63 o #CAX activos'" .

ex:DiagnosticoFallo1546 o ex:DiagnosticoFallo
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite G63 sin gama previa en el cabezal" ;
    ex:textoExtracto "'No se admite G63 sin gama previa en el cabezal'" .

ex:DiagnosticoFallo1547 o ex:DiagnosticoFallo
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite #CAX con G63 activa" ;
    ex:textoExtracto "'No se admite #CAX con G63 activa'" .

ex:DiagnosticoFallo1548 o ex:DiagnosticoFallo
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas" ;
    ex:textoExtracto "'No se admite cambiar el cabezal master con G33/G63/G95/G96 activas'" .

ex:TareaMantenimientoSolucion1545 o ex:TareaMantenimiento
    a ex:TareaMantenimiento ;
    rdfs:label "Para cambiar la gama del cabezal, desactivar el roscado y el eje C" ;
    ex:textoExtracto "SOLUCIÓN Para cambiar la gama del cabezal, desactivar el roscado y el eje C." ;
    ex:solucionaFallo ex:DiagnosticoFallo1545 .

ex:TareaMantenimientoSolucion1546 o ex:TareaMantenimiento
    a ex:TareaMantenimiento ;
    rdfs:label "Antes de iniciar un roscado G63 el cabezal debe tener una gama activada" ;
    ex:textoExtracto "SOLUCIÓN Antes de iniciar un roscado G63 el cabezal debe tener una gama activada." ;
    ex:solucionaFallo ex:DiagnosticoFallo1546 .

ex:TareaMantenimientoSolucion1547 o ex:TareaMantenimiento
    a ex:TareaMantenimiento ;
    rdfs:label "Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C" ;
    ex:textoExtracto "SOLUCIÓN Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C." ;
    ex:solucionaFallo ex:DiagnosticoFallo1547 .

ex:TareaMantenimientoSolucion1548 o ex:TareaMantenimiento
    a ex:TareaMantenimiento ;
    rdfs:label "Desactivar G33/G63/G95/G96 antes de cambiar el cabezal master" ;
    ex:textoExtracto "SOLUCIÓN Desactivar G33/G63/G95/G96 antes de cambiar el cabezal master." ;
    ex:solucionaFallo ex:DiagnosticoFallo1548 .