@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametroF a ex:Parametro ;
    rdfs:label "Parámetro F" ;
    ex:textoExtracto "'CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z.'" .

ex:DiagnosticoFallo1751 a ex:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: S = 0" ;
    ex:textoExtracto "'MOYU RECTANGULAR: S = 0'" ;
    ex:causa "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." ;
    ex:solucion "Asignar al parámetro un valor mayor que 0." .

ex:ParametroS a ex:Parametro ;
    rdfs:label "Parámetro S" ;
    ex:textoExtracto "'CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado.'" .

ex:DiagnosticoFallo1752 a ex:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: T = 0" ;
    ex:textoExtracto "'MOYU RECTANGULAR: T = 0'" ;
    ex:causa "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." ;
    ex:solucion "Asignar al parámetro un valor mayor que 0." .

ex:ParametroT a ex:Parametro ;
    rdfs:label "Parámetro T" ;
    ex:textoExtracto "'CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada.'" .

ex:AccionProhibidaSinHerramienta a ex:AccionProhibida ;
    rdfs:label "No hay herramienta programada" ;
    ex:textoExtracto "'CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada.'" .

ex:TareaProgramarHerramienta a ex:TareaMantenimiento ;
    rdfs:label "Programar una herramienta" ;
    ex:textoExtracto "'SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado.'" ;
    ex:solucionaFallo ex:AccionProhibidaSinHerramienta .