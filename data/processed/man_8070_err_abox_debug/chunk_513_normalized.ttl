@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AccionProhibidaModificarLimitesSoftware a ex:AccionProhibida ;
    rdfs:label "Modificación de límites de software" ;
    ex:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ex:DiagnosticoFalloErrorRTCPInversa a ex:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada inversa de RTCP" ;
    ex:textoExtracto "'Error en el cálculo de la transformada inversa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas pieza a coordenadas máquina." .

ex:DiagnosticoFalloErrorRTCPDirecta a ex:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada directa de RTCP" ;
    ex:textoExtracto "'Error en el cálculo de la transformada directa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas máquina a coordenadas pieza." .

ex:DiagnosticoFalloMezclaEjesSimulados a ex:DiagnosticoFallo ;
    rdfs:label "No se pueden mezclar ejes simulados con no simulados" ;
    ex:textoExtracto "'No se pueden mezclar ejes simulados con no simulados' DETECCIÓN Durante la ejecución. CAUSA En el proceso de medición con palpador hay ejes simulados y no simulados." .

ex:AccionContactarFagor a ex:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor" ;
    ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor." .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" .

ex:AccionContactarFagor solucionaFallo ex:DiagnosticoFalloErrorRTCPInversa .
ex:AccionContactarFagor solucionaFallo ex:DiagnosticoFalloErrorRTCPDirecta .
ex:AccionContactarFagor solucionaFallo ex:DiagnosticoFalloMezclaEjesSimulados .