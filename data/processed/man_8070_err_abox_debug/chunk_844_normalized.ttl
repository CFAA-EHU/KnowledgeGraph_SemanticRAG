ex:Deteccion1 ex:identificador "8568" ;
ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA El ciclo no admite la programación del comando NR. SOLUCIÓN Eliminar el comando NR del bloque. Para repetir el bloque, utilizar la sentencia #RPT." ;
rdfs:label "Detección 8568" .

ex:Solucion1 ex:identificador "8568" ;
ex:textoExtracto "SOLUCIÓN Eliminar el comando NR del bloque. Para repetir el bloque, utilizar la sentencia #RPT." ;
rdfs:label "Solución 8568" .

ex:Deteccion2 ex:identificador "8569" ;
ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA El comando NR no admite los valores 0 y 1. SOLUCIÓN Programar el comando NR con un valor igual o superior a 2." ;
rdfs:label "Detección 8569" .

ex:Solucion2 ex:identificador "8569" ;
ex:textoExtracto "SOLUCIÓN Programar el comando NR con un valor igual o superior a 2." ;
rdfs:label "Solución 8569" .

ex:SentenciaOPEN ex:identificador "#OPEN" ;
ex:textoExtracto "#OPEN\"fichero\" <, A/D> <, KEEPLINE> <, FhandleFichero>]" ;
rdfs:label "#OPEN" .

ex:Deteccion3 ex:identificador "8570" ;
ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." ;
rdfs:label "Detección 8570" .

ex:Deteccion1 ex:detecta ex:Solucion1 .
ex:Deteccion2 ex:detecta ex:Solucion2 .
ex:Deteccion3 ex:detecta ex:SentenciaOPEN .