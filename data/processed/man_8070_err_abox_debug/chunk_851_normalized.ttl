@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SintaxisSentencia ex:tieneComponente ex:SintaxisSentenciaIncorrecta ;
ex:documentadoEn ex:ManualProgramacion .

ex:SintaxisSentenciaIncorrecta ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
ex:detalladoEnEsquema ex:SintaxisSentenciaIncorrecta .

ex:FaltaRecurso ex:tieneComponente ex:SintaxisSentenciaIncorrecta ;
ex:textoExtracto "8701 'Falta recurso o número tras símbolo' DETECCIÓN Durante la edición. CAUSA Falta recurso tras DFU, DFD, ERA o tras el símbolo de DEF/PDEF. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DFU/DFD/ERA recurso\"" ;
ex:documentadoEn ex:ManualProgramacion .

ex:RecursoAntesDeS_mbolo ex:tieneComponente ex:SintaxisSentenciaIncorrecta ;
ex:textoExtracto "8702 'Recurso antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El recurso está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\"" ;
ex:documentadoEn ex:ManualProgramacion .

ex:N_meroAntesDeS_mbolo ex:tieneComponente ex:SintaxisSentenciaIncorrecta ;
ex:textoExtracto "8703 'Número antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El número está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo número\"" ;
ex:documentadoEn ex:ManualProgramacion .

ex:SeEsperabaRecursoON_mero ex:tieneComponente ex:SintaxisSentenciaIncorrecta ;
ex:textoExtracto "8704 'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición." ;
ex:documentadoEn ex:ManualProgramacion .