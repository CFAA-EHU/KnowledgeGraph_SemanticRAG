@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Deteccion8704 a ex:Alarma ;
ex:detalladoEnEsquema ex:Esquema8704 ;
ex:textoExtracto "8704 'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos símbolos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"" ;
rdfs:label "Detección 8704" .

ex:Deteccion8705 a ex:Alarma ;
ex:detalladoEnEsquema ex:Esquema8705 ;
ex:textoExtracto "8705 'No se puede redefinir recursos' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos recursos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"" ;
rdfs:label "Detección 8705" .

ex:Deteccion8706 a ex:Alarma ;
ex:detalladoEnEsquema ex:Esquema8706 ;
ex:textoExtracto "8706 'No se puede redefinir números' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos números. SOLUCIÓN Programar \"DEF/PDEF símbolo" ;
rdfs:label "Detección 8706" .

ex:Esquema8704 a ex:Esquema ;
ex:detalladoEnEsquema ex:Deteccion8704 ;
rdfs:label "Esquema 8704" .

ex:Esquema8705 a ex:Esquema ;
ex:detalladoEnEsquema ex:Deteccion8705 ;
rdfs:label "Esquema 8705" .

ex:Esquema8706 a ex:Esquema ;
ex:detalladoEnEsquema ex:Deteccion8706 ;
rdfs:label "Esquema 8706" .