ex:_8847
  a ex:AvisoSeguridad ;
  rdfs:label "Demasiados símbolos de usuario"@es ;
  ex:detectadoEn "Durante la compilación del programa PLC"@es ;
  ex:causadoPor "Hay definidos más de 100 símbolos PDEF"@es ;
  ex:soluciona "Programar algunos símbolos PDEF como símbolos DEF. El PLC permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF."@es .

ex:_8848
  a ex:AvisoSeguridad ;
  rdfs:label "Demasiados errores"@es ;
  ex:detectadoEn "Durante la compilación del programa PLC"@es ;
  ex:causadoPor "El PLC ha detectado demasiados errores y"@es .