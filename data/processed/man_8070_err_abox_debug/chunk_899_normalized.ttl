PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:_8887 a ex:Instruccion ;
ex:identificador "8887" ;
ex:textoExtracto "MOVE INF(eje,sentido,velocidad,tipoEnlace)" .

ex:_8888 a ex:Instruccion ;
ex:identificador "8888" ;
ex:textoExtracto "CAM ON(leva,maestro,esclavo,offsetM,offsetE,factorM,factorE,ONCE/CONT)" .

ex:_8889 a ex:Instruccion ;
ex:identificador "8889" ;
ex:textoExtracto "FOLLOW/CAM OFF(esclavo)" .

ex:_8890 a ex:Instruccion ;
ex:identificador "8890" ;
ex:textoExtracto "FOLLOW ON(maestro,esclavo <,Ni,Di><,VEL/POS/POSDYN/WAITLIM>)" .

ex:_8891 a ex:Instruccion ;
ex:identificador "8891" ;
ex:textoExtracto "HOME(eje)" .

ex:_8892 a ex:Instruccion ;
ex:identificador "8892" ;
ex:textoExtracto "TOUCHPROBE(eje,palpador,ventana,limInf,limSup <,POS/NEG>)" .

ex:_8893 a ex:Instruccion ;
ex:identificador "8893" ;
ex:textoExtracto "TOUCHPROBE(eje,palpador <,ventana,limInf,limSup,POS/NEG>)" .

ex:_8894 a ex:AvisoFallo ;
ex:identificador "8894" ;
ex:textoExtracto "'Instrucción anterior incorrecta'" .