ex:_9050
  a ex:AvisoSeguridad ;
  rdfs:label "No hay memoria para recursos registros de sistema nuevos"@es ;
  ex:detectadoDurante "Durante la compilación del programa PLC"@es ;
  ex:causadoPor "El sistema no dispone de memoria para crear recursos nuevos"@es ;
  ex:solucion "Póngase en contacto con Fagor Automation"@es .

