ex:_9054
  a ex:AvisoSeguridad ;
  rdfs:label "No se puede abrir el puerto COM para MODBUSSVRRS"@es ;
  ex:detectadoDurante "Durante la compilación del programa PLC"@es ;
  ex:causadoPor "Falla la conexión al puerto serie para el servidor de MODBUS"@es ;
  ex:solucion "Revisar la conexión y parametrización del puerto serie"@es .

ex:_9301
  a ex:AvisoSeguridad ;
  rdfs:label "'Los ejes maestro y esclavo deben tener igual REFFEED1 y REFFEED2'"@es ;
  ex:detectadoDurante "Durante la validación de los parámetros máquina"@es ;
  ex:causadoPor "Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente velocidad de búsqueda de cero en algún set (parámetros REFFEED1 y REFFEED2)"@es ;
  ex:solucion "Revisar los parámetros máquina. La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es .

ex:_9302
  a ex:AvisoSeguridad ;
  rdfs:label "'Para asumir el nuevo valor es necesario rearrancar windows'"@es ;
  ex:detectadoDurante "Durante la validación de los parámetros máquina"@es ;
  ex:causadoPor "Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto"@es ;
  ex:solucion "Rearrancar windows"@es .