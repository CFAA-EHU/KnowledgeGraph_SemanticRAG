@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SOLUCI_N_9336
  a ex:Acci_nProhibida ;
  rdfs:label "Cambiar el tipo de captación en los sets diferentes"@es ;
  ex:identificador "9336" ;
  ex:textoExtracto "SOLUCIÓN Cambiar el tipo de captación en los sets diferentes. 9336 'Parámetros máquina incompatibles' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay activas dos prestaciones que son incompatibles entre sí. Los parámetros máquina relacionados aparecen en el mensaje de error (por ejemplo, los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie). SOLUCIÓN Anular uno de los dos"@es .

ex:Par_metro_HBLS
  a ex:Parametro ;
  rdfs:label "Parámetro HBLS"@es ;
  ex:identificador "HBLS" ;
  ex:textoExtracto "Parámetros máquina incompatibles. Los parámetros máquina relacionados aparecen en el mensaje de error (por ejemplo, los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie)"@es .

ex:Par_metro_MODBUSSVRRS
  a ex:Parametro ;
  rdfs:label "Parámetro MODBUSSVRRS"@es ;
  ex:identificador "MODBUSSVRRS" ;
  ex:textoExtracto "Parámetros máquina incompatibles. Los parámetros máquina relacionados aparecen en el mensaje de error (por ejemplo, los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie)"@es .

ex:SOLUCI_N_AnularUno
  a ex:Acci_nProhibida ;
  rdfs:label "Anular uno de los dos"@es ;
  ex:identificador "Anular uno de los dos" ;
  ex:textoExtracto "SOLUCIÓN Anular uno de los dos"@es .

ex:SOLUCI_N_9336 ex:ejecutadoPor ex:SOLUCI_N_AnularUno .

ex:Par_metro_HBLS ex:monitoreaParametro ex:SOLUCI_N_9336 .
ex:Par_metro_MODBUSSVRRS ex:monitoreaParametro ex:SOLUCI_N_9336 .