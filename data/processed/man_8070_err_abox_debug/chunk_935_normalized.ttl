@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DeteccionDeSalidaAnalogica
  a ex:Alarma ;
  ex:detalladoEnEsquema ex:EsquemaDeArranqueCNC ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:mitigaRiesgo ex:FalloDeSalidaAnalogica ;
  ex:requiereMantenimiento ex:MantenimientoDeParametrosMaquina ;
  ex:tieneComponente ex:ModuloRCS_S ;
  ex:textoExtracto "Durante el arranque del CNC o la validacion de los parametros maquina, el set activo en varios ejes esta utilizando la misma salida analogica de un modulo RCS-S (parametro ANAOUTID)." .

ex:FalloDeSalidaAnalogica
  a ex:DiagnosticoFallo ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:solucionaFallo ex:DeteccionDeSalidaAnalogica ;
  ex:tieneComponente ex:ModuloRCS_S ;
  ex:textoExtracto "Dos set activos no pueden compartir la misma salida analogica. Activar un set diferente en algun eje o configurar una salida analogica diferente en el set." .

ex:OffsetDeCinematica
  a ex:Alarma ;
  ex:detalladoEnEsquema ex:EsquemaDeValidacionParametrosMaquina ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:mitigaRiesgo ex:FalloDeOffsetDeCinematica ;
  ex:requiereMantenimiento ex:MantenimientoDeParametrosMaquina ;
  ex:tieneComponente ex:Cinematica ;
  ex:textoExtracto "Durante la validacion de parametros maquina o escritura de una variable, el offset definido para la cinematica esta fuera del rango permitido por el parametro maquina." .

ex:FalloDeOffsetDeCinematica
  a ex:DiagnosticoFallo ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:solucionaFallo ex:OffsetDeCinematica ;
  ex:tieneComponente ex:Cinematica ;
  ex:textoExtracto "Asignar a la variable V.MPK.OFTDATAkin[nb] de la cinematica un valor que este comprendido entre \"- MAX OFFSET\" y \"+ MAX OFFSET\" (rango definido por el parametro maquina de la cinematica correspondiente)." .

ex:VariableDRVExistente
  a ex:Alarma ;
  ex:detalladoEnEsquema ex:EsquemaDeValidacionParametrosMaquina ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:mitigaRiesgo ex:FalloDeVariableDRVExistente ;
  ex:requiereMantenimiento ex:MantenimientoDeParametrosMaquina ;
  ex:tieneComponente ex:ParametrosMaquinaOEM ;
  ex:textoExtracto "Durante la validacion de los parametros maquina o la definicion de variables del regulador, la variable DRV ya existe en los parametros maquina OEM." .

ex:FalloDeVariableDRVExistente
  a ex:DiagnosticoFallo ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:solucionaFallo ex:VariableDRVExistente ;
  ex:tieneComponente ex:ParametrosMaquinaOEM ;
  ex:textoExtracto "Revisar la definicion de la variable." .

ex:VariablesDRVConMnemonicIgual
  a ex:Alarma ;
  ex:detalladoEnEsquema ex:EsquemaDeValidacionParametrosMaquina ;
  ex:documentadoEn ex:ManualDeMantenimiento ;
  ex:mitigaRiesgo ex:FalloDeVariablesDRVConMnemonicIgual ;
  ex:requiereMantenimiento ex:MantenimientoDeParametrosMaquina ;
  ex:tieneComponente ex:ParametrosMaquinaOEM ;
  ex:textoExtracto "Durante la validacion de los parametros maquina, dos variables diferentes no pueden tener el mismo mnem