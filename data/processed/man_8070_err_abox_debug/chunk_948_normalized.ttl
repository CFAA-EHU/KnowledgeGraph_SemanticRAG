@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:_9505
  a ex:Alarma ;
  rdfs:label "Alarma de pulsos entre I0s" ;
  ex:detectadoPor ex:Regulador ;
  ex:tieneComponente ex:Encoder ;
  ex:mitigaRiesgo ex:RevisarParametrizacion ;
  ex:mitigaRiesgo ex:RevisarConexionado ;
  ex:textoExtracto "Durante el funcionamiento habitual del sistema, el regulador ha detectado un error en la correlación de pulsos entre dos señales de I0 del encoder. Revisar la parametrización y el conexionado del encoder." .

ex:_9506
  a ex:Error ;
  rdfs:label "Error de comprobación de CRC de PM" ;
  ex:detectadoPor ex:Regulador ;
  ex:tieneComponente ex:PM ;
  ex:solucionaFallo ex:ContactarFagorAutomation ;
  ex:textoExtracto "Durante el funcionamiento habitual del sistema, se ha detectado un error interno del regulador. Contacte con Fagor Automation." .

ex:_9507
  a ex:Error ;
  rdfs:label "Error en la detección de PM" ;
  ex:detectadoPor ex:Regulador ;
  ex:tieneComponente ex:PM ;
  ex:solucionaFallo ex:ContactarFagorAutomation ;
  ex:textoExtracto "Durante el funcionamiento habitual del sistema, se ha detectado un error interno del regulador. Contacte con Fagor Automation." .

ex:_9508
  a ex:Alarma ;
  rdfs:label "Watchdog de regulador" ;
  ex:detectadoPor ex:Regulador ;
  ex:mitigaRiesgo ex:ContactarFagorAutomation ;
  ex:textoExtracto "Durante el arranque o funcionamiento habitual del sistema, el regulador no responde; posible mal funcionamiento, conexionado, etc. Contacte con Fagor Automation." .

ex:_9509
  a ex:Alarma ;
  rdfs:label "Fallo 24 Vdc inesperado" ;
  ex:detectadoPor ex:Regulador ;
  ex:mitigaRiesgo ex:RevisarConexionado ;
  ex:mitigaRiesgo ex:RevisarAlimentacion ;
  ex:textoExtracto "Durante el arranque o funcionamiento habitual del sistema, el regulador ha detectado una caída en la tensión de control. Revisar el conexionado y la alimentación de control de 24 Vdc." .

ex:_9510
  a ex:Alarma ;
  rdfs:label "Lazos de corriente en mismo nodo incompatibles" ;
  ex:detectadoPor ex:ReguladorDoble ;
  ex:tieneComponente ex:Motor ;
  ex:mitigaRiesgo ex:ParametrizarMismoTipoControl ;
  ex:textoExtracto "Durante el funcionamiento habitual del sistema, un regulador doble tiene configurados modos incompatibles de control para cada motor. En un regulador doble, parametrizar el mismo tipo de control en ambos motores." .

ex:_9511
  a ex:Alarma ;
  rdfs:label "Error en la actualización de versión DSP" ;
  ex:detectadoPor ex:CNC ;
  ex:tieneComponente ex:DSP ;
  ex:mitigaRiesgo ex:ComprobarConexionado ;
  ex:mitigaRiesgo ex:ContactarFagorAutomation ;
  ex:textoExtracto "Durante el arranque del sistema, el CNC no puede actualizar la versión del DSP en algún regulador o RPS. Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ex:_9512
  a ex:Alarma ;
  rdfs:label "Error en la actualización de versión FPGA" ;
  ex:detectadoPor ex:CNC ;
  ex:tieneComponente ex:FPGA ;
  ex:mitigaRiesgo ex:ComprobarConexionado ;
  ex:textoExtracto "Durante el arranque o funcionamiento habitual del sistema, el CNC no puede actualizar la versión de la FPGA en algún regulador o RPS. Compruebe el conexionado." .