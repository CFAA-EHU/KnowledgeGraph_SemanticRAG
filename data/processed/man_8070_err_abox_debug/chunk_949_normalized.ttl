@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorActualizacionVersionFPGA
  a ex:Alarma ;
  rdfs:label "Error en la actualización de versión FPGA"@es ;
  ex:detectadoDurante [ ex:arranque, ex:funcionamiento ] ;
  ex:causadoPor ex:ErrorActualizacionVersionFPGA ;
  ex:solucionadoPor [ ex:comprobacionConexionado, ex:contactoConFagorAutomation ] .

ex:ErrorActualizacionVersionCPLD
  a ex:Alarma ;
  rdfs:label "Error en la actualización de versión CPLD"@es ;
  ex:detectadoDurante [ ex:arranque, ex:funcionamiento ] ;
  ex:causadoPor ex:ErrorActualizacionVersionCPLD ;
  ex:solucionadoPor [ ex:comprobacionConexionado, ex:contactoConFagorAutomation ] .

ex:arranque
  a ex:ModoOperacion ;
  rdfs:label "arranque"@es .

ex:funcionamiento
  a ex:ModoOperacion ;
  rdfs:label "funcionamiento"@es .

ex:comprobacionConexionado
  a ex:TareaMantenimiento ;
  rdfs:label "comprobación de conexionado"@es .

ex:contactoConFagorAutomation
  a ex:AvisoSeguridad ;
  rdfs:label "contacto con Fagor Automation"@es .