@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorPersistente
  a ex:Alarma ;
  rdfs:label "Error persistente" ;
  ex:detalladoEnEsquema ex:EsquemaArranqueFuncionamiento .

ex:ModuloABSIND
  a ex:ComponenteElectrico ;
  rdfs:label "Módulo ABSIND" ;
  ex:tieneComponente ex:CableAsociado .

ex:CableAsociado
  a ex:ComponenteElectrico ;
  rdfs:label "Cable asociado a esa captación" .

ex:FagorAutomation
  a ex:Empresa ;
  rdfs:label "Fagor Automation" .

ex:EsquemaArranqueFuncionamiento
  a ex:Esquema ;
  rdfs:label "Esquema de arranque y funcionamiento" ;
  ex:detalladoEnEsquema ex:Sistema .

ex:Sistema
  a ex:Sistema ;
  rdfs:label "Sistema" .