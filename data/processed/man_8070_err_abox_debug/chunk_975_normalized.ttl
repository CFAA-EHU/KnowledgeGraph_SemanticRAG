@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFalloLimiteCorrienteBallast a ex:DiagnosticoFallo ;
    rdfs:label "Límite de corriente en la resistencia de Ballast" ;
    ex:textoExtracto "CAUSA Límite de corriente en la resistencia de Ballast." .

ex:TareaMantenimientoRevisarConexionadoBallast a ex:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado e integridad de la resistencia de Ballast" ;
    ex:textoExtracto "SOLUCIÓN Revisar el conexionado e integridad de la resistencia de Ballast." ;
    ex:solucionaFallo ex:DiagnosticoFalloLimiteCorrienteBallast .

ex:DiagnosticoFalloSobrecargaBallast a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de la resistencia de Ballast" ;
    ex:textoExtracto "9558 Sobrecarga de la resistencia de Ballast." ;
    ex:deteccion "Durante el funcionamiento habitual del sistema." .

ex:TareaMantenimientoRevisarSeleccionBallast a ex:TareaMantenimiento ;
    rdfs:label "Revisar selección de la resistencia de Ballast" ;
    ex:textoExtracto "SOLUCIÓN Revisar selección de la resistencia de Ballast." ;
    ex:solucionaFallo ex:DiagnosticoFalloSobrecargaBallast .

ex:DiagnosticoFalloCortocircuito a ex:DiagnosticoFallo ;
    rdfs:label "Cortocircuito" ;
    ex:textoExtracto "9610 Cortocircuito." ;
    ex:deteccion "DETECCIÓN" .