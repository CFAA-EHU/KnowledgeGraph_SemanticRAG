@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Manual_FagorAutomation
    a ex:Manual ;
    rdfs:label "Manual original de Fagor Automation"@es ;
    ex:textoExtracto "Este manual, así como los documentos que deriven del mismo, han sido redactados en español. [...] Fagor Automation se reserva el derecho de modificar el contenido del manual, no estando obligado a notificar las variaciones."@es ;
    ex:identificador "MANUAL ORIGINAL"@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Fagor Automation se reserva el derecho de modificar el contenido del manual, no estando obligado a notificar las variaciones. Todas las marcas registradas o comerciales que aparecen en el manual pertenecen a sus respectivos propietarios."@es .

ex:Sistema_SeguridadesCNC
    a ex:Sistema ;
    rdfs:label "Seguridades del CNC"@es ;
    ex:textoExtracto "Es responsabilidad del fabricante de la máquina que las seguridades de la máquina estén habilitadas, con objeto de evitar lesiones a personas y prevenir daños al CNC o a los productos conectados a él."@es ;
    ex:documentadoEn ex:Manual_FagorAutomation .

ex:Alarma_CaptacionEjesAnalogicos
    a ex:Alarma ;
    rdfs:label "Alarma de captación para ejes analógicos"@es ;
    ex:textoExtracto "Alarma de captación para ejes analógicos."@es ;
    ex:activaAlarma ex:Sistema_SeguridadesCNC ;
    ex:documentadoEn ex:Manual_FagorAutomation .

ex:AvisoSeguridad_LimitesSoftwareEjes
    a ex:AvisoSeguridad ;
    rdfs:label "Límites de software para ejes lineales analógicos y sercos"@es ;
    ex:textoExtracto "Límites de software para ejes lineales analógicos y sercos."@es ;
    ex:mitigaRiesgo ex:Sistema_SeguridadesCNC ;
    ex:documentadoEn ex:Manual_FagorAutomation .

ex:AvisoSeguridad_ErrorSeguimientoEjes
    a ex:AvisoSeguridad ;
    rdfs:label "Monitorización del error de seguimiento para ejes analógicos y sercos"@es ;
    ex:textoExtracto "Monitorización del error de seguimiento para ejes analógicos y sercos (excepto el cabezal), tanto en el CNC como en los reguladores."@es ;
    ex:mitigaRiesgo ex:Sistema_SeguridadesCNC ;
    ex:documentadoEn ex:Manual_FagorAutomation .

ex:AvisoSeguridad_TestTendenciaEjes
    a ex:AvisoSeguridad ;
    rdfs:label "Test de tendencia en los ejes analógicos"@es ;
    ex:textoExtracto "Test de tendencia en los ejes analógicos."@es ;
    ex:mitigaRiesgo ex:Sistema_SeguridadesCNC ;
    ex:documentadoEn ex:Manual_FagorAutomation .