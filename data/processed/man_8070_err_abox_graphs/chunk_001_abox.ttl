@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisosDeSeguridadDuranteElArranqueYValidacionDelCNC a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad durante el arranque y validación del CNC" ;
    ns1:mitigaRiesgo ns1:CNC8070_f729afa2ee ;
    ns1:textoExtracto "Durante el arranque y la validación de parámetros del CNC, se comprueba el estado de las siguientes seguridades. Si alguna de ellas está deshabilitada el CNC muestra un mensaje de advertencia." .

ns1:AvisosDeSeguridadSobreLimitesDeSoftware a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad sobre límites de software" ;
    ns1:mitigaRiesgo ns1:CNC8070_f729afa2ee ;
    ns1:textoExtracto "• Límites de software para ejes lineales analógicos y sercos." .

ns1:AvisosDeSeguridadSobreMonitorizacionDelErrorDeSeguimiento a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad sobre monitorización del error de seguimiento" ;
    ns1:mitigaRiesgo ns1:CNC8070_f729afa2ee ;
    ns1:textoExtracto "• Monitorización del error de seguimiento para ejes analógicos y sercos (excepto el cabezal), tanto en el CNC como en los reguladores." .

ns1:AvisosDeSeguridadSobreTestDeTendencia a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad sobre test de tendencia" ;
    ns1:mitigaRiesgo ns1:CNC8070_f729afa2ee ;
    ns1:textoExtracto "• Test de tendencia en los ejes analógicos." .

ns1:Alarma_45488e215d a ns1:Alarma ;
    rdfs:label "Alarma de captación para ejes analógicos" ;
    ns1:textoExtracto "• Alarma de captación para ejes analógicos." .

ns1:CNC8070_f729afa2ee a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:Alarma_45488e215d ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC," .

