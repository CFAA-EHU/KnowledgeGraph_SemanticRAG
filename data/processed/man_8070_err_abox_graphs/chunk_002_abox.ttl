@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FAGOR_Automation
    a ex:Empresa ;
    rdfs:label "FAGOR AUTOMATION" ;
    ex:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC..." .

ex:CNC_Generic
    a ex:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)" ;
    ex:textoExtracto "lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC" .

ex:AvisoSeguridad_HardwareMod
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Modificación de hardware no autorizada" ;
    ex:textoExtracto "La modificación del hardware del CNC por personal no autorizado por Fagor Automation implica la pérdida de la garantía." ;
    ex:mitigaRiesgo ex:CNC_Generic .

ex:AvisoSeguridad_VirusInformaticos
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Virus informáticos en el sistema" ;
    ex:textoExtracto "La presencia de virus informáticos en el CNC puede provocar su mal funcionamiento. [...] implica la pérdida de la garantía." ;
    ex:mitigaRiesgo ex:CNC_Generic .

ex:AvisoSeguridad_ProductosDobleUso
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Productos de doble uso (Reglamento UE 428/2009)" ;
    ex:textoExtracto "Los productos fabricados por FAGOR AUTOMATION [...] si el producto según el reglamento UE 428/2009 está incluido en la lista de productos de doble uso, incluye en la identificación de producto el texto -MDU y necesita licencia de exportación según destino." ;
    ex:cumpleNormativa ex:Directiva_UE_428_2009 .

ex:Directiva_UE_428_2009
    a ex:Directiva ;
    rdfs:label "Reglamento (UE) 428/2009" ;
    ex:identificador "UE 428/2009" ;
    ex:textoExtracto "producto según el reglamento UE 428/2009 está incluido en la lista de productos de doble uso" .

ex:AvisoSeguridad_AplicacionesNoDocumentadas
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Aplicaciones no documentadas del CNC" ;
    ex:textoExtracto "Es posible que el CNC pueda ejecutar más funciones que las recogidas en la documentación asociada; [...] cualquier aplicación del CNC que no se encuentre recogida en la documentación se debe considerar como 'imposible'." ;
    ex:mitigaRiesgo ex:CNC_Generic .