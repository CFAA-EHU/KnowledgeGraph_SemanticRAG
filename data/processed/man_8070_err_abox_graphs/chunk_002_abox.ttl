@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_4921301d83 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de productos de doble uso" ;
    ns1:mitigaRiesgo ns1:CNC8070_02ae02186b ;
    ns1:textoExtracto "Los productos fabricados por FAGOR AUTOMATION a partir del 1 de abril de 2014, si el producto según el reglamento UE 428/2009 está incluido en la lista de productos de doble uso, incluye en la identificación de producto el texto -MDU y necesita licencia de exportación según destino." .

ns1:AvisoSeguridad_c03d248e8a a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de funciones no documentadas" ;
    ns1:mitigaRiesgo ns1:CNC8070_02ae02186b ;
    ns1:textoExtracto "En cualquier caso, Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC por la ejecución de funciones no recogidas en la documentación." .

ns1:AvisoSeguridad_c1a97fd4cf a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modificación del hardware",
        "Aviso de virus informáticos" ;
    ns1:mitigaRiesgo ns1:CNC8070_02ae02186b,
        ns1:ModificacionDelHardware ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC, y que sean imputables a una modificación del hardware por personal no autorizado por Fagor Automation." .

ns1:ModificacionDelHardware a ns1:AccionProhibida ;
    rdfs:label "Modificación del hardware" ;
    ns1:textoExtracto "La modificación del hardware del CNC por personal no autorizado por Fagor Automation implica la pérdida de la garantía." .

ns1:CNC8070_02ae02186b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "FAGOR AUTOMATION garantiza que el software instalado no contiene ningún virus informático." .

