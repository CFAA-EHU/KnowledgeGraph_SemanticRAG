@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Manual_FagorAutomation_CNC
    a               ex:Manual ;
    rdfs:label      "Manual de CNC Fagor Automation" ;
    ex:textoExtracto "CNC que no se encuentre recogida en la documentación se debe considerar como \"imposible\"... Los ejemplos descritos en este manual están orientados al aprendizaje. Antes de utilizarlos en aplicaciones industriales deben ser convenientemente adaptados y además se debe asegurar el cumplimiento de las normas de seguridad." ;
    ex:cumpleNormativa ex:NormativaSeguridadIndustrial .

ex:NormativaSeguridadIndustrial
    a               ex:Directiva ;
    rdfs:label      "Normativa de seguridad industrial para aplicaciones CNC" ;
    ex:textoExtracto "Antes de utilizarlos en aplicaciones industriales deben ser convenientemente adaptados y además se debe asegurar el cumplimiento de las normas de seguridad." .

ex:AvisoSeguridad_ManualCNC
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso de seguridad sobre uso correcto del CNC" ;
    ex:textoExtracto "Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC si éste se utiliza de manera diferente a la explicada en la documentación relacionada." ;
    ex:documentadoEn ex:Manual_FagorAutomation_CNC .