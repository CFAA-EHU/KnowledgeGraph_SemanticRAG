@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ERRORDELSISTEMA a ns1:AvisoSeguridad ;
    rdfs:label "ERROR DEL SISTEMA" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'ERROR DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Errores de software o hardware que provocan datos corruptos y/o resultados incongruentes." .

ns1:ElCNCNoSeApagoCorrectamenteEsNecesarioReferenciar a ns1:AvisoSeguridad ;
    rdfs:label "El CNC no se apagó correctamente, es necesario referenciar" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'El CNC no se apagó correctamente, es necesario referenciar' DETECCIÓN Durante el arranque del CNC." .

ns1:ErrorDeChecksumEnLosDatosDePLC a ns1:AvisoSeguridad ;
    rdfs:label "Error de checksum en los datos de PLC" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Error de checksum en los datos de PLC' DETECCIÓN Durante el arranque del CNC." .

ns1:ErrorEnLaPeticionDeMemoria a ns1:AvisoSeguridad ;
    rdfs:label "Error en la petición de memoria" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Error en la petición de memoria. Reiniciar Windows y CNC' DETECCIÓN Durante el arranque del CNC." .

ns1:WARNINGDELSISTEMA a ns1:AvisoSeguridad ;
    rdfs:label "WARNING DEL SISTEMA" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'WARNING DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Aviso de situaciones internas que pueden acabar en errores del sistema." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
