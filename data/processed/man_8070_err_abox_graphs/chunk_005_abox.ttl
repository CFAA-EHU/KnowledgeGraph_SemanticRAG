@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionParaRestaurarLosDatosDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Solución para restaurar los datos del CNC" ;
    ns1:solucionaFallo ns1:DatosDelCNCRelativosALasCotasTrasladosDeOrigenesEtcNoSonValidos ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con soporte técnico." .

ns1:DatosDelCNCRelativosALasCotasTrasladosDeOrigenesEtcNoSonValidos a ns1:DiagnosticoFallo ;
    rdfs:label "Datos del CNC relativos a las cotas, traslados de orígenes, etc no son válidos" ;
    ns1:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos. El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto." .

