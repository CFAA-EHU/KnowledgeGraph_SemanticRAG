@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloCNC_orgdata_tab_corrupto
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Fallo en fichero orgdata.tab del CNC" ;
    ex:textoExtracto    "Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos. El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto. [...] Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido." ;
    ex:identificador    "orgdata.tab" .

ex:FicheroCNC_orgdata_tab
    a                   ex:InterfazUsuario ;
    rdfs:label          "Fichero orgdata.tab (datos CNC)" ;
    ex:textoExtracto    "El fichero orgdata.tab que contiene estos datos [cotas, traslados de orígenes, contador de piezas, cinemáticas]." ;
    ex:identificador    "orgdata.tab" ;
    ex:monitoreaParametro  ex:ParametroCNC_cotas ,
                          ex:ParametroCNC_origenes ,
                          ex:ParametroCNC_contadorPiezas ,
                          ex:ParametroCNC_cinematicas .

ex:ParametroCNC_cotas
    a                   ex:Parametro ;
    rdfs:label          "Cotas (CNC)" ;
    ex:textoExtracto    "datos del CNC relativos a las cotas" .

ex:ParametroCNC_origenes
    a                   ex:Parametro ;
    rdfs:label          "Traslados de orígenes (CNC)" ;
    ex:textoExtracto    "traslados de orígenes" .

ex:ParametroCNC_contadorPiezas
    a                   ex:Parametro ;
    rdfs:label          "Contador de piezas (CNC)" ;
    ex:textoExtracto    "contador de piezas" .

ex:ParametroCNC_cinematicas
    a                   ex:Parametro ;
    rdfs:label          "Cinemáticas (CNC)" ;
    ex:textoExtracto    "cinemáticas" .