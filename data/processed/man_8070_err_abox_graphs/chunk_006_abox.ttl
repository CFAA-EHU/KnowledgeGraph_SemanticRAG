@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de Fallo (Alarmas)
ex:Alarma_0006
    a ex:Alarma ;
    rdfs:label "Preparación sobrepasa la mitad del tiempo de ciclo"@es ;
    ex:identificador "0006" ;
    ex:textoExtracto "0006 'La preparación sobrepasa la mitad del tiempo de ciclo' [...] SOLUCIÓN Disminuir el valor del parámetro PREPFREQ del canal."@es ;
    ex:activaAlarma ex:Parametro_PREPFREQ ;
    ex:solucionaFallo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Ajuste de PREPFREQ"@es ;
        ex:textoExtracto "Disminuir el valor del parámetro PREPFREQ del canal."@es
    ] .

ex:Alarma_0007
    a ex:Alarma ;
    rdfs:label "Reset incompleto del CNC"@es ;
    ex:identificador "0007" ;
    ex:textoExtracto "0007 'Para finalizar el reset es necesario reiniciar el CNC' [...] SOLUCIÓN Reiniciar el CNC."@es ;
    ex:solucionaFallo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Reinicio forzado del CNC"@es ;
        ex:textoExtracto "Reiniciar el CNC. Si el usuario pulsa la tecla [RESET] por tercera vez, la aplicación CNC se cierra."@es
    ] .

ex:Alarma_0008
    a ex:Alarma ;
    rdfs:label "Tecla rechazada"@es ;
    ex:identificador "0008" ;
    ex:textoExtracto "0008 'La tecla ha sido rechazada' [...] SOLUCIÓN Si ha sido un acto involuntario del usuario, ignorar el error. Si el error persiste [...] comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)."@es ;
    ex:solucionaFallo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Verificación de teclado"@es ;
        ex:textoExtracto "Comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)."@es
    ] .

ex:Alarma_0009
    a ex:Alarma ;
    rdfs:label "Fallo en gestión de FIFO de AEP"@es ;
    ex:identificador "0009" ;
    ex:textoExtracto "0009 Aviso de sistema: fallo en la gestión de la fifo de aep. [...] CAUSA El programa tiene un gran número de funciones G o parámetros aritméticos."@es .

### Parámetros y Componentes Relacionados
ex:Parametro_PREPFREQ
    a ex:Parametro ;
    rdfs:label "PREPFREQ" ;
    ex:textoExtracto "El parámetro PREPFREQ no tiene el efecto deseado. SOLUCIÓN Disminuir el valor del parámetro PREPFREQ del canal."@es ;
    ex:monitoreaParametro ex:Maquina_CNC .

ex:InterfazUsuario_TecladoCNC
    a ex:InterfazUsuario ;
    rdfs:label "Teclado del CNC"@es ;
    ex:textoExtracto "La tecla [START], las teclas de arranque del cabezal y la tecla de parada orientada del cabezal siempre se deben pulsar solas; si se pulsan simultáneamente con otra tecla, ambas quedan anuladas."@es .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido."@es ;
    ex:tieneComponente ex:InterfazUsuario_TecladoCNC .

### Diagnóstico Genérico (Pérdida de Datos)
ex:Diagnostico_PerdidaDatosCNC
    a ex:DiagnosticoFallo ;
    rdfs:label "Pérdida de datos del CNC"@es ;
    ex:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor."@es ;
    ex:solucionaFallo ex:Alarma_Generica_PerdidaDatos .

ex:Alarma_Generica_PerdidaDatos
    a ex:Alarma ;
    rdfs:label "Pérdida de datos en el CNC"@es ;
    ex:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido."@es .