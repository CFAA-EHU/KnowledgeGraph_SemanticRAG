@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_6cf7f82cb8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:RepetirArranquesDelCNC ;
    ns1:solucionaFallo ns1:ReiniciarCNC_48db6379dc ;
    ns1:textoExtracto "'Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor.'" .

ns1:EjecutarDosResetsDelCNCConsecutivos a ns1:AccionProhibida ;
    rdfs:label "Ejecutar dos resets del CNC consecutivos" ;
    ns1:textoExtracto "'Para finalizar el reset es necesario reiniciar el CNC'... CAUSA El usuario ha ejecutado dos reset del CNC consecutivos y ninguno de ellos ha finalizado correctamente." .

ns1:FrecuenciaDePreparacion a ns1:Parametro ;
    rdfs:label "Frecuencia de preparación" ;
    ns1:textoExtracto "'0006 'La preparación sobrepasa la mitad del tiempo de ciclo'... CONSECUENCIA El parámetro PREPFREQ no tiene el efecto deseado. SOLUCIÓN Disminuir el valor del parámetro PREPFREQ del canal." .

ns1:LaPreparacionSobrepasaLaMitadDelTiempoDeCiclo a ns1:DiagnosticoFallo ;
    rdfs:label "La preparación sobrepasa la mitad del tiempo de ciclo" ;
    ns1:textoExtracto "'0006 'La preparación sobrepasa la mitad del tiempo de ciclo' DETECCIÓN Durante el arranque del CNC o durante la ejecución. CAUSA La preparación de datos en el CNC por ciclo de PLC tiene una duración excesiva." .

ns1:ParaFinalizarElResetEsNecesarioReiniciarElCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Para finalizar el reset es necesario reiniciar el CNC" ;
    ns1:textoExtracto "'0007 'Para finalizar el reset es necesario reiniciar el CNC' DETECCIÓN Tras un reset del CNC. CAUSA El usuario ha ejecutado dos reset del CNC consecutivos y ninguno de ellos ha finalizado correctamente." .

ns1:ReiniciarCNCMasDeDosVeces a ns1:AccionProhibida ;
    rdfs:label "Reiniciar CNC más de dos veces" ;
    ns1:textoExtracto "'Para finalizar el reset es necesario reiniciar el CNC'... Si el usuario pulsa la tecla [RESET] por tercera vez, la aplicación CNC se cierra." .

ns1:ReiniciarCNC_48db6379dc a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar CNC" ;
    ns1:textoExtracto "'0007 'Para finalizar el reset es necesario reiniciar el CNC'... SOLUCIÓN Reiniciar el CNC." .

ns1:RepetirArranquesDelCNC a ns1:AccionProhibida ;
    rdfs:label "Repetir arranques del CNC" ;
    ns1:textoExtracto "'Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor.'" .

