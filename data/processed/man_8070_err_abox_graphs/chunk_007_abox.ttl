@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_5ae689e96c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sistema: fallo en la gestión de la fifo de aep" ;
    ns1:textoExtracto "0009 Aviso de sistema: fallo en la gestión de la fifo de aep." .

ns1:CNC8070_776ad2610b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC." .

ns1:ComprobarEnElTecladoQueNoHayNingunaTeclaPulsadaEnganchada a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)" ;
    ns1:solucionaFallo ns1:FalloTeclasIncompatibles ;
    ns1:textoExtracto "Si el error persiste o aparece durante el arranque, comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)." .

ns1:PonerseEnContactoConSuProveedor a ns1:TareaMantenimiento ;
    rdfs:label "Ponerse en contacto con su proveedor" ;
    ns1:solucionaFallo ns1:FalloTeclasIncompatibles ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:PulsarLaTeclaRESETPorTerceraVez a ns1:AccionProhibida ;
    rdfs:label "Pulsar la tecla [RESET] por tercera vez" ;
    ns1:textoExtracto "Si el usuario pulsa la tecla [RESET] por tercera vez, la aplicación CNC se cierra." .

ns1:ReiniciarElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar el CNC" ;
    ns1:solucionaFallo ns1:FalloTeclasIncompatibles ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC." .

ns1:FalloTeclasIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Error al pulsar teclas incompatibles simultáneamente" ;
    ns1:textoExtracto "El CNC ha detectado que dos teclas incompatibles han sido pulsadas a la vez." .

