@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_f416934859 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sistema: fallo en la gestión de la fifo de aep" ;
    ns1:mitigaRiesgo ns1:FalloGestionFifoAep ;
    ns1:textoExtracto "Aviso de sistema: fallo en la gestión de la fifo de aep. DETECCIÓN Durante la ejecución." .

ns1:ErrorEnTestDeRAMConBateria a ns1:AvisoSeguridad ;
    rdfs:label "Error en test de RAM con batería" ;
    ns1:textoExtracto "'Error en test de RAM con batería' DETECCIÓN Durante el arranque del CNC." .

ns1:FalloTestRam a ns1:DiagnosticoFallo ;
    rdfs:label "fallo en test de RAM con batería" ;
    ns1:textoExtracto "CAUSA El test de arranque ha detectado un error de" .

ns1:ReduccionDelNumeroDeParametrosAritmeticos a ns1:TareaMantenimiento ;
    rdfs:label "Reducción del número de parámetros aritméticos" ;
    ns1:solucionaFallo ns1:FalloGestionFifoAep ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de parámetros aritméticos usados o programar #FLUSH (vaciado del canal) en puntos de programa donde pequeñas esperas no tengan importancia." .

ns1:FalloGestionFifoAep a ns1:DiagnosticoFallo ;
    rdfs:label "fallo en la gestión de la fifo de aep" ;
    ns1:textoExtracto "CAUSA El programa tiene un gran número de funciones G o parámetros aritméticos." .

