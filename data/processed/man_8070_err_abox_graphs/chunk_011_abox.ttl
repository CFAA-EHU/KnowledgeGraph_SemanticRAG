@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c0f1506dc3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:AccesoAVariableIncorrecto,
        ns1:ApagadoInesperadoPorCaidaDeAlimentacion,
        ns1:ApagadoReinicioPorPantallaAzul,
        ns1:NoHayTecladoDeCAN ;
    ns1:textoExtracto "CNC 8070" .

ns1:ContactarConFagorAutomation_e49b4ad0f0 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation" ;
    ns1:solucionaFallo ns1:AccesoAVariableIncorrecto ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:RevisionDeAlimentacionDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de alimentación del CNC" ;
    ns1:solucionaFallo ns1:ApagadoInesperadoPorCaidaDeAlimentacion,
        ns1:ApagadoReinicioPorPantallaAzul ;
    ns1:textoExtracto "Revisar la alimentación del CNC." .

ns1:NoHayTecladoDeCAN a ns1:AccionProhibida ;
    rdfs:label "No hay teclado de CAN" ;
    ns1:textoExtracto "El CNC no ha detectado el teclado CAN." .

ns1:AccesoAVariableIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Acceso a variable incorrecto" ;
    ns1:textoExtracto "El CNC está accediendo a una variable de interfaz que no existe." .

ns1:ApagadoInesperadoPorCaidaDeAlimentacion a ns1:AccionProhibida ;
    rdfs:label "Apagado inesperado por caída de alimentación" ;
    ns1:textoExtracto "El CNC ha detectado un apagado inesperado por una caída de alimentación, durante el arranque del sistema operativo." .

ns1:ApagadoReinicioPorPantallaAzul a ns1:AccionProhibida ;
    rdfs:label "Apagado/reinicio por pantalla azul" ;
    ns1:textoExtracto "El cierre anterior del CNC fue debido a una excepción de bajo nivel (pantalla azul)." .

