@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0022
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0022: Variable no permitida en entorno de puesta a punto" ;
    ex:identificador "0022" ;
    ex:textoExtracto "0022 'Variable no permitida en el entorno de la puesta a punto' [...] SOLUCIÓN Consultar en el manual de operación la lista de variables permitidas." ;
    ex:documentadoEn ex:ManualOperacion .

ex:Error_0023
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0023: Parada de programa requerida para traza" ;
    ex:identificador "0023" ;
    ex:textoExtracto "0023 'Es necesario parar el programa para iniciar la traza por primera vez' [...] SOLUCIÓN Parar el programa en ejecución." ;
    ex:documentadoEn ex:ManualOperacion .

ex:Error_0024
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0024: Fallo al iniciar traza en osciloscopio" ;
    ex:identificador "0024" ;
    ex:textoExtracto "0024 'Error iniciando la traza' [...] SOLUCIÓN Comprobar las variables definidas en los canales del osciloscopio. El osciloscopio sólo puede acceder a dos variables Sercos de cada regulador." ;
    ex:documentadoEn ex:ManualOperacion .

ex:Error_0025
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0025: Fallo en registro de defines de PLC" ;
    ex:identificador "0025" ;
    ex:textoExtracto "0025 'Error al registrar defines de PLC' [...] SOLUCIÓN Borrar el archivo plc_prg.sym y compilar el programa PLC para volver a crear este archivo." ;
    ex:documentadoEn ex:ManualOperacion .

ex:Error_0026
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0026: Variable no permitida en entorno del osciloscopio" ;
    ex:identificador "0026" ;
    ex:textoExtracto "0026 'Variable no permitida en el entorno del oscilo' [...]" ;
    ex:documentadoEn ex:ManualOperacion .

ex:ManualOperacion
    a ex:Manual ;
    rdfs:label "Manual de operación" ;
    ex:textoExtracto "Consultar en el manual de operación la lista de variables permitidas." .

ex:Osciloscopio
    a ex:InterfazUsuario ;
    rdfs:label "Osciloscopio" ;
    ex:textoExtracto "iniciar una traza en el osciloscopio [...] El osciloscopio sólo puede acceder a dos variables Sercos de cada regulador." ;
    ex:monitoreaParametro ex:VariableSercos .

ex:VariableSercos
    a ex:Parametro ;
    rdfs:label "Variable Sercos" ;
    ex:textoExtracto "El osciloscopio sólo puede acceder a dos variables Sercos de cada regulador." .

ex:Archivo_plc_prg_sym
    a ex:Componente ;
    rdfs:label "Archivo plc_prg.sym" ;
    ex:identificador "plc_prg.sym" ;
    ex:textoExtracto "El archivo plc_prg.sym que contiene la información necesaria para crear las variables asociadas a los símbolos externos PDEF está corrupto." .