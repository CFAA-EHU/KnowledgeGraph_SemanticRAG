@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarEnElModoDiagnosisElEstadoDelBusCANYSiElCNCReconoceElTeclado a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado." .

ns1:ElCNCNoHaDetectadoElTecladoCAN a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC no ha detectado el teclado CAN" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN." .

ns1:PongaseEnContactoConElFabricanteDeLaMaquinaOConElDisenadorDeLasPagina_7b7a74eab9 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz" ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:VariableNoPermitidaEnElEntornoDeLaPuestaAPunto a ns1:AccionProhibida ;
    rdfs:label "'Variable no permitida en el entorno de la puesta a punto'" ;
    ns1:textoExtracto "'Variable no permitida en el entorno de la puesta a punto'" .

