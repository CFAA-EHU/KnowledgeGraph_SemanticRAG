@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0026
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 0026: Variable no permitida en el entorno del osciloscopio"@es ;
    ex:identificador "0026" ;
    ex:textoExtracto "0026 'Variable no permitida en el entorno del oscilo' DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA La variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña."@es .

ex:Solucion_0026
    a               ex:TareaMantenimiento ;
    rdfs:label      "Solución para error 0026: Consultar documentación de variables"@es ;
    ex:textoExtracto "Consultar en la documentación la lista de variables"@es ;
    ex:solucionaFallo ex:Error_0026 .

ex:Accion_RecompilarPLC
    a               ex:TareaMantenimiento ;
    rdfs:label      "Borrar archivo plc_prg.sym y recompilar programa PLC"@es ;
    ex:textoExtracto "Borrar el archivo plc_prg.sym y compilar el programa PLC para volver a crear este archivo."@es .