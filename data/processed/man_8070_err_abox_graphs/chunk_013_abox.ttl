@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualDeOperacionParaVariablesPermitidas a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual de operación para variables permitidas" ;
    ns1:solucionaFallo ns1:VariableNoPermitidaEnElEntornoDePuestaAPunto ;
    ns1:textoExtracto "Consultar en el manual de operación la lista de variables permitidas." .

ns1:DefinirVariableNoPermitidaEnElEntornoDePuestaAPunto a ns1:AccionProhibida ;
    rdfs:label "Definir variable no permitida en el entorno de puesta a punto" ;
    ns1:textoExtracto "'Variable no permitida en el entorno de la puesta a punto'" .

ns1:ErrorIniciandoLaTraza_cd851e1ae8 a ns1:DiagnosticoFallo ;
    rdfs:label "Error iniciando la traza" ;
    ns1:textoExtracto "'Error iniciando la traza'" .

ns1:IniciarTrazaConError a ns1:AccionProhibida ;
    rdfs:label "Iniciar traza con error" ;
    ns1:textoExtracto "'Error iniciando la traza'" .

ns1:IniciarTrazaConProgramaEnEjecucion a ns1:AccionProhibida ;
    rdfs:label "Iniciar traza con programa en ejecución" ;
    ns1:textoExtracto "'Es necesario parar el programa para iniciar la traza por primera vez'" .

ns1:PararProgramaEnEjecucionAntesDeIniciarTraza a ns1:TareaMantenimiento ;
    rdfs:label "Parar programa en ejecución antes de iniciar traza" ;
    ns1:solucionaFallo ns1:ErrorIniciandoLaTrazaConProgramaEnEjecucion ;
    ns1:textoExtracto "Parar el programa en ejecución." .

ns1:ErrorIniciandoLaTrazaConProgramaEnEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "Error iniciando la traza con programa en ejecución" ;
    ns1:textoExtracto "'Es necesario parar el programa para iniciar la traza por primera vez'" .

ns1:VariableNoPermitidaEnElEntornoDePuestaAPunto a ns1:DiagnosticoFallo ;
    rdfs:label "Variable no permitida en el entorno de puesta a punto" ;
    ns1:textoExtracto "'Variable no permitida en el entorno de la puesta a punto'" .

