@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MLINK
    a               ex:Parametro ;
    rdfs:label      "Parámetro MLINK" ;
    ex:textoExtracto "en el CNC está activo el modo Mlink-I (parámetro MLINK)" ;
    ex:identificador "MLINK" .

ex:ModoOperacion_MLINK_I
    a               ex:ModoOperacion ;
    rdfs:label      "Modo Mlink-I" ;
    ex:textoExtracto "en el CNC está activo el modo Mlink-I (parámetro MLINK)" .

ex:Sistema_Mechatrolink
    a               ex:Sistema ;
    rdfs:label      "Sistema Mechatrolink" ;
    ex:textoExtracto "El acceso a variables y/o parámetros de los dispositivos Mechatrolink" .

ex:Parametro_Mechatrolink
    a               ex:Parametro ;
    rdfs:label      "Parámetro Mechatrolink" ;
    ex:textoExtracto "hay definido un parámetro Mechatrolink" ;
    ex:monitoreaParametro ex:Sistema_Mechatrolink .

ex:DiagnosticoFallo_0031
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo 0031: Incompatibilidad Mechatrolink/MLINK-I" ;
    ex:identificador "0031" ;
    ex:textoExtracto "0031 'Sólo MLINKII permite parámetros mechatrolink en el oscilo'" ;
    ex:solucionaFallo ex:Parametro_Mechatrolink ;
    ex:textoExtracto "SOLUCIÓN En estas variables, el eje se debe programar mediante su nombre." .