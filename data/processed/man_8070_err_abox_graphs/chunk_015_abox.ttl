@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarLaDocumentacionParaLaListaDeVariablesPermitidas a ns1:TareaMantenimiento ;
    rdfs:label "Consultar la documentación para la lista de variables permitidas" ;
    ns1:solucionaFallo ns1:LaVariableDefinidaEsDeSimulacionBinariaStringOEstaProtegidaPorContrasena ;
    ns1:textoExtracto "Consultar en la documentación la lista de variables" .

ns1:DefinirVariableNoPermitidaEnElOsciloscopio a ns1:AccionProhibida ;
    rdfs:label "Definir variable no permitida en el osciloscopio" ;
    ns1:solucionaFallo ns1:LaVariableDefinidaEsDeSimulacionBinariaStringOEstaProtegidaPorContrasena ;
    ns1:textoExtracto "'Variable no permitida en el entorno del oscilo'" .

ns1:LaVariableDefinidaEsDeSimulacionBinariaStringOEstaProtegidaPorContrasena a ns1:DiagnosticoFallo ;
    rdfs:label "La variable definida es de simulación, binaria, string o está protegida por contraseña" ;
    ns1:textoExtracto "La variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña." .

