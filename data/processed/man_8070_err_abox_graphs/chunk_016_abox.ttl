@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Mechatrolink_MLINK
    a               ex:Parametro ;
    rdfs:label      "Parámetro Mechatrolink (MLINK)" ;
    ex:textoExtracto "hay definido un parámetro Mechatrolink, pero en el CNC está activo el modo Mlink-I (parámetro MLINK)" ;
    ex:identificador "MLINK" .

ex:Parametro_Mechatrolink_MLINK0
    a               ex:Parametro ;
    rdfs:label      "Parámetro Mechatrolink MLINK0" ;
    ex:textoExtracto "El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF" ;
    ex:identificador "MLINK0" .

ex:Parametro_Mechatrolink_MLINKF
    a               ex:Parametro ;
    rdfs:label      "Parámetro Mechatrolink MLINKF" ;
    ex:textoExtracto "El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF" ;
    ex:identificador "MLINKF" .

ex:Variable_Mechatrolink_P0
    a               ex:Parametro ;
    rdfs:label      "Variable Mechatrolink P0" ;
    ex:textoExtracto "El rango de variables Mechatrolink válido es P0 a PFFFF" ;
    ex:identificador "P0" .

ex:Variable_Mechatrolink_PFFFF
    a               ex:Parametro ;
    rdfs:label      "Variable Mechatrolink PFFFF" ;
    ex:textoExtracto "El rango de variables Mechatrolink válido es P0 a PFFFF" ;
    ex:identificador "PFFFF" .

ex:ModoOperacion_Mlink_I
    a               ex:ModoOperacion ;
    rdfs:label      "Modo Mlink-I" ;
    ex:textoExtracto "en el CNC está activo el modo Mlink-I (parámetro MLINK)" ;
    ex:identificador "Mlink-I" .

ex:ModoOperacion_Mlink_II
    a               ex:ModoOperacion ;
    rdfs:label      "Modo Mlink-II" ;
    ex:textoExtracto "El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está disponible para el modo Mlink-II a 32 bytes" ;
    ex:identificador "Mlink-II" .

ex:AvisoSeguridad_0032
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 0032: Parámetro o variable Mechatrolink fuera de rango" ;
    ex:textoExtracto "0032 Parámetro o variable mechatrolink fuera de rango. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro o variable tiene un valor no válido. SOLUCIÓN El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF. El rango de variables Mechatrolink válido es P0 a PFFFF" ;
    ex:identificador "0032" .

ex:AvisoSeguridad_0033
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 0033: Array no permitido en parámetros y variables Mechatrolink" ;
    ex:textoExtracto "0033 Array no permitido en parámetros y variables Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Los parámetros y variables Mechatrolink (parámetros máquina OEM) no admiten arrays. SOLUCIÓN Revisar la programación. Cada parámetro y variable Mechatrolink sólo puede estar asociada a un eje" ;
    ex:identificador "0033" .

ex:AvisoSeguridad_0034
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 0034: Falta programar el eje en el parámetro o variable Mechatrolink" ;
    ex:textoExtracto "0034 Falta programar el eje en el parámetro o variable Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Falta programar el eje en el parámetro o variable Mechatrolink (parámetros máquina OEM). SOLUCIÓN Revisar la programación. Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje" ;
    ex:identificador "0034" .

ex:AvisoSeguridad_0035
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 0035: Número máximo de variables en oscilo sobrepasado" ;
    ex:textoExtracto "0035 Número máximo de variables en oscilo sobrepasado. DETECCIÓN En el osciloscopio. CAUSA Hay más de dos canales del oscilo con variables del mismo regulador. SOLUCIÓN El número máximo de variables del mismo regulador que se pueden tracear simultáneamente en el oscilo es dos" ;
    ex:identificador "0035" .

ex:AvisoSeguridad_0036
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 0036: Inconsistencia en la recuperación de la herramienta activa" ;
    ex:textoExtracto "0036 Inconsistencia en la recuperación de la herramienta activa. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto" ;
    ex:identificador "0036" .

ex:DiagnosticoFallo_ParametroFueraRango
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Parámetro o variable Mechatrolink fuera de rango" ;
    ex:textoExtracto "El parámetro o variable tiene un valor no válido. SOLUCIÓN El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF. El rango de variables Mechatrolink válido es P0 a PFFFF" ;
    ex:solucionaFallo ex:AvisoSeguridad_0032 .

ex:DiagnosticoFallo_ArrayNoPermitido
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Arrays no permitidos en Mechatrolink" ;
    ex:textoExtracto "Los parámetros y variables Mechatrolink (parámetros máquina OEM) no admiten arrays. SOLUCIÓN Revisar la programación. Cada parámetro y variable Mechatrolink sólo puede estar asociada a un eje" ;
    ex:solucionaFallo ex:AvisoSeguridad_0033 .

ex:DiagnosticoFallo_FaltaEjeProgramado
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Falta programación de eje en Mechatrolink" ;
    ex:textoExtracto "Falta programar el eje en el parámetro o variable Mechatrolink. SOLUCIÓN Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje" ;
    ex:solucionaFallo ex:AvisoSeguridad_0034 .

ex:DiagnosticoFallo_InconsistenciaHerramientaActiva
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Inconsistencia en herramienta activa" ;
    ex:textoExtracto "La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto" ;
    ex:solucionaFallo ex:AvisoSeguridad_0036 .