@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirParametrosMechatrolinkEnModoMlinkI a ns1:AccionProhibida ;
    rdfs:label "Definir parámetros Mechatrolink en modo Mlink-I" ;
    ns1:textoExtracto "DETECCIÓN Al definir parámetros en un canal del osciloscopio." .

ns1:SolucionParaVariablesYOParametrosDeDispositivosMechatrolink a ns1:TareaMantenimiento ;
    rdfs:label "Solución para variables y/o parámetros de dispositivos Mechatrolink" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_111db707a8 ;
    ns1:textoExtracto "SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está" .

ns1:DiagnosticoFallo_111db707a8 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro Mechatrolink definido en el osciloscopio pero modo Mlink-I activo" ;
    ns1:textoExtracto "CAUSA En el osciloscopio hay definido un parámetro Mechatrolink, pero en el CNC está activo el modo Mlink-I (parámetro MLINK)" .

