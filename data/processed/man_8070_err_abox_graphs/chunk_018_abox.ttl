@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0037
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta siguiente"@es ;
    ex:identificador "0037" ;
    ex:textoExtracto "Inconsistencia en la recuperación de la herramienta siguiente. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta siguiente guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ex:Error_0038
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de los correctores de herramienta"@es ;
    ex:identificador "0038" ;
    ex:textoExtracto "Inconsistencia en la recuperación de los correctores de herramienta. DETECCIÓN Durante el arranque del CNC. CAUSA La información de los correctores guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ex:Error_0039
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal"@es ;
    ex:identificador "0039" ;
    ex:textoExtracto "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal. DETECCIÓN Durante el arranque del CNC. CAUSA La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ex:textoExtracto "Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta."@es .

ex:GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ex:textoExtracto "La información de la herramienta siguiente guardada en el disco no se corresponde con la guardada por el gestor de herramientas"@es .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "Durante el arranque del CNC"@es .

ex:Error_0037
    ex:documentadoEn ex:TablaHerramientas ;
    ex:mitigaRiesgo ex:GestorHerramientas .

ex:Error_0038
    ex:documentadoEn ex:TablaHerramientas ;
    ex:mitigaRiesgo ex:GestorHerramientas .

ex:Error_0039
    ex:mitigaRiesgo ex:GestorHerramientas .

ex:TablaHerramientas a ex:Tabla ;
    ex:tieneComponente ex:GestorHerramientas .