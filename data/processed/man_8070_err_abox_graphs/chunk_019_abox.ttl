@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitarElNumeroDeVariablesDelMismoReguladorEnElOsciloscopio a ns1:TareaMantenimiento ;
    rdfs:label "Limitar el número de variables del mismo regulador en el osciloscopio" ;
    ns1:solucionaFallo ns1:FalloInconsistenciaRecuperacionHerramienta ;
    ns1:textoExtracto "SOLUCIÓN El número máximo de variables del mismo regulador que se pueden tracear simultáneamente en el oscilo es dos." .

ns1:RevisarLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FalloNumeroMaximoVariablesOscilo ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FalloParametroVariableMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VerificarLaRecuperacionDeLaHerramientaActiva a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la recuperación de la herramienta activa" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC." .

ns1:FalloInconsistenciaRecuperacionHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta activa" ;
    ns1:textoExtracto "0036 Inconsistencia en la recuperación de la herramienta activa." .

ns1:FalloNumeroMaximoVariablesOscilo a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de variables en oscilo sobrepasado" ;
    ns1:textoExtracto "0035 Número máximo de variables en oscilo sobrepasado." .

ns1:FalloParametroVariableMechatrolink a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el eje en el parámetro o variable Mechatrolink" ;
    ns1:textoExtracto "0034 Falta programar el eje en el parámetro o variable Mechatrolink." .

