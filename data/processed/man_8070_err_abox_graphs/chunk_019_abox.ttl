@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloPosicionHerramienta
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo de posición de herramienta en cabezal"@es ;
    ex:textoExtracto "La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es ;
    ex:identificador "DETECCIÓN_DURANTE_ARRANQUE_CNC" .

ex:SistemaGestorHerramientas
    a               ex:Sistema ;
    rdfs:label      "Gestor de herramientas del CNC"@es ;
    ex:textoExtracto "gestor de herramientas"@es ;
    ex:monitoreaParametro ex:ParametroPosicionHerramienta .

ex:ParametroPosicionHerramienta
    a               ex:Parametro ;
    rdfs:label      "Posición de almacén de herramienta"@es ;
    ex:textoExtracto "posición de almacén de la herramienta"@es ;
    ex:valor         "no coincidente"@es .

ex:FicheroDatosHerramientas
    a               ex:Componente ;
    rdfs:label      "Fichero de datos de herramientas"@es ;
    ex:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es ;
    ex:identificador "DATOS_HERRAMIENTAS_CNC" .

ex:AlarmaArranqueCNC
    a               ex:Alarma ;
    rdfs:label      "Alarma de fallo en arranque del CNC"@es ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC."@es ;
    ex:activaAlarma  ex:FalloPosicionHerramienta .