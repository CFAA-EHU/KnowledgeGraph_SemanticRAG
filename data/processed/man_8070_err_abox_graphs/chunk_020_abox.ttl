@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0040
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0040: 'M Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque'"@es ;
    ex:identificador "0040" ;
    ex:textoExtracto "Durante la validación de los parámetros máquina. En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después. SOLUCIÓN El CNC siempre ejecuta la subrutina asociada a una función M al finalizar el bloque en el que está programada la función. Definir la función M sin sincronización o bien con sincronización Después-Después."@es .

ex:Error_0041
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0041: 'M duplicada en la tabla'"@es ;
    ex:identificador "0041" ;
    ex:textoExtracto "Durante la validación de los parámetros máquina. En la tabla de funciones M, hay una función repetida. SOLUCIÓN Corregir la definición de las funciones. En la tabla no puede haber dos funciones M con el mismo número."@es .

ex:Error_0042
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0042: 'Valor de parámetro máquina no válido'"@es ;
    ex:identificador "0042" ;
    ex:textoExtracto "Durante la validación de los parámetros máquina. El parámetro máquina tiene un valor no válido. En la ventana de error aparece cuál es el parámetro erróneo y el valor máximo y mínimo permitido. SOLUCIÓN Asignar al parámetro máquina un valor dentro de los límites permitidos."@es .

ex:Error_0043
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0043: 'Para asumir nuevo valor es necesario rearrancar el CNC'"@es ;
    ex:identificador "0043" ;
    ex:textoExtracto "Durante la validación de los parámetros máquina. El usuario ha modificado un parámetro máquina y es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor. SOLUCIÓN Reiniciar el CNC."@es .

ex:Error_0044
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0044: 'Nombre de eje no válido o nombre de eje sin definir'"@es ;
    ex:identificador "0044" ;
    ex:textoExtracto "Durante la validación de los parámetros máquina."@es .

ex:TablaFuncionesM a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ex:textoExtracto "En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después."@es .

ex:ParametroMaquina_0042
    a ex:Parametro ;
    rdfs:label "Parámetro máquina con valor no válido"@es ;
    ex:textoExtracto "El parámetro máquina tiene un valor no válido. En la ventana de error aparece cuál es el parámetro erróneo y el valor máximo y mínimo permitido."@es .

ex:ParametroMaquina_0043
    a ex:Parametro ;
    rdfs:label "Parámetro máquina modificado"@es ;
    ex:textoExtracto "El usuario ha modificado un parámetro máquina y es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor."@es .

ex:FuncionM_Duplicada a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función M duplicada en tabla"@es ;
    ex:textoExtracto "En la tabla de funciones M, hay una función repetida."@es ;
    ex:documentadoEn ex:TablaFuncionesM .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto. SOLUCIÓN Comprobar cuál es la posición correcta antes de continuar. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ex:Error_0040 ex:solucionaFallo ex:FuncionM_Duplicada .
ex:Error_0041 ex:solucionaFallo ex:FuncionM_Duplicada .
ex:Error_0042 ex:solucionaFallo ex:ParametroMaquina_0042 .
ex:Error_0043 ex:solucionaFallo ex:ParametroMaquina_0043 .
ex:TablaFuncionesM a ex:Tabla ;
    ex:documentadoEn ex:SistemaCNC .