@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_eed72f55d9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:InconsistenciaEnLaRecuperacionDeLaHerramientaActiva ;
    ns1:textoExtracto "Durante el arranque del CNC." .

ns1:ComprobarHerramientaCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar herramienta correcta" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar cuál es la herramienta correcta antes de continuar." .

ns1:DefinirHerramientaActiva a ns1:TareaMantenimiento ;
    rdfs:label "Definir herramienta activa" ;
    ns1:textoExtracto "Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta." .

ns1:InconsistenciaEnLaRecuperacionDeLaHerramientaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta activa" ;
    ns1:solucionaFallo ns1:ComprobarHerramientaCorrecta,
        ns1:DefinirHerramientaActiva ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la herramienta activa. DETECCIÓN Durante el arranque del CNC." .

