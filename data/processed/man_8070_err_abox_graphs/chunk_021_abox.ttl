@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarCualEsLaHerramientaCorrectaAntesDeContinuar a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cuál es la herramienta correcta antes de continuar" ;
    ns1:textoExtracto "Comprobar cuál es la herramienta correcta antes de continuar." .

ns1:ComprobarCualesSonLosCorrectoresCorrectosAntesDeContinuar a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cuáles son los correctores correctos antes de continuar" ;
    ns1:textoExtracto "Comprobar cuáles son los correctores correctos antes de continuar." .

ns1:DefinirEnElCNCCualEsLaHerramientaSiguientePorEjemploDesdeMDI a ns1:TareaMantenimiento ;
    rdfs:label "Definir en el CNC cuál es la herramienta siguiente (por ejemplo desde MDI)" ;
    ns1:textoExtracto "Definir en el CNC cuál es la herramienta siguiente (por ejemplo desde MDI)." .

ns1:DefinirEnLaTablaDeHerramientasCualEsLaHerramientaActiva a ns1:TareaMantenimiento ;
    rdfs:label "Definir en la tabla de herramientas cuál es la herramienta activa" ;
    ns1:textoExtracto "Definir en la tabla de herramientas cuál es la herramienta activa." .

ns1:DefinirEnLaTablaDeHerramientasLosCorrectoresDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir en la tabla de herramientas los correctores de herramienta" ;
    ns1:textoExtracto "Definir en la tabla de herramientas los correctores de herramienta." .

ns1:DefinirLaPosicionDeAlmacenDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir la posición de almacén de la herramienta" ;
    ns1:textoExtracto "La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas." .

ns1:InconsistenciaEnLaRecuperacionDeLaHerramientaSiguiente a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta siguiente" ;
    ns1:textoExtracto "0037 Inconsistencia en la recuperación de la herramienta siguiente." .

ns1:InconsistenciaEnLaRecuperacionDeLaPosicionEnElAlmacenDeLaHerramientaEnElCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal" ;
    ns1:textoExtracto "0039 Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal." .

ns1:InconsistenciaEnLaRecuperacionDeLosCorrectoresDeHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de los correctores de herramienta" ;
    ns1:textoExtracto "0038 Inconsistencia en la recuperación de los correctores de herramienta." .

ns1:PongaseEnContactoConSuProveedor a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con su proveedor" ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:RealizarUnCambioDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Realizar un cambio de herramienta" ;
    ns1:textoExtracto "en caso necesario, realizar un cambio de herramienta." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Durante el arranque del CNC." .

