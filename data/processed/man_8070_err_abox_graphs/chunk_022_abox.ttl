@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0045
    a ex:Alarma ;
    rdfs:label "Alarma 0045: Nombre de cabezal no válido" ;
    ex:textoExtracto "0045 'Nombre de cabezal no válido' [...] CAUSA El usuario ha definido el parámetro máquina con un nombre de cabezal incorrecto." ;
    ex:identificador "0045" .

ex:Alarma_0046
    a ex:Alarma ;
    rdfs:label "Alarma 0046: Eje inexistente" ;
    ex:textoExtracto "0046 'Eje inexistente' [...] CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." ;
    ex:identificador "0046" .

ex:Alarma_0047
    a ex:Alarma ;
    rdfs:label "Alarma 0047: Un eje principal no puede definirse como esclavo" ;
    ex:textoExtracto "0047 'Un eje principal no puede definirse como esclavo' [...] DETECCIÓN Durante la validación de los parámetros máquina." ;
    ex:identificador "0047" .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "Parámetro AXISNAME" ;
    ex:textoExtracto "Los nombres de eje válidos son los definidos en el parámetro AXISNAME. En el parámetro AXISNAME, el nombre del eje estará definido por 1 ó 2 caracteres. El primer carácter debe ser una de las letras X - Y - Z - U - V - W - A - B - C. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9." ;
    ex:valor "X, X1…X9, Y, Y1…Y9, Z, Z1…Z9, U, U1…U9, V, V1…V9, W, W1…W9, A, A1…A9, B, B1…B9, C, C1…C9"^^xsd:string .

ex:Parametro_SPDLNAME
    a ex:Parametro ;
    rdfs:label "Parámetro SPDLNAME" ;
    ex:textoExtracto "Los nombres de cabezal válidos son los definidos en el parámetro SPDLNAME. En el parámetro SPDLNAME, el nombre del cabezal estará definido por 1 ó 2 caracteres. El primer carácter debe ser la letra S. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9." ;
    ex:valor "S, S1…S9"^^xsd:string .

ex:Parametro_VMOVAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro VMOVAXIS" ;
    ex:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." .

ex:Parametro_VCOMPAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro VCOMPAXIS" ;
    ex:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." .

ex:Alarma_0045 ex:activaAlarma ex:Parametro_SPDLNAME .
ex:Alarma_0046 ex:activaAlarma ex:Parametro_AXISNAME , ex:Parametro_VMOVAXIS , ex:Parametro_VCOMPAXIS .