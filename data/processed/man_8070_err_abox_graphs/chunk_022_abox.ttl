@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_5ca8b13cbd a ns1:AvisoSeguridad ;
    rdfs:label "Aviso sobre fichero de datos" ;
    ns1:mitigaRiesgo ns1:FalloSistemaGestorHerramientas ;
    ns1:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:CNC8070_eed72f55d9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Durante el arranque del CNC." .

ns1:MalApagado a ns1:AccionProhibida ;
    rdfs:label "Mal apagado" ;
    ns1:textoExtracto "por un mal apagado o por una fallo del sistema." .

ns1:FalloSistemaGestorHerramientas a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en el gestor de herramientas" ;
    ns1:textoExtracto "La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema." .

