@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AntesAntesOAntesDespuesConSubrutinaNoAdmiteMovimientosEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque" ;
    ns1:mitigaRiesgo ns1:CNC8070_ae61964ab4 ;
    ns1:textoExtracto "'M Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque'" .

ns1:DefinirLaFuncionMSinSincronizacionOBienConSincronizacionDespuesDespues a ns1:TareaMantenimiento ;
    rdfs:label "Definir la función M sin sincronización o bien con sincronización Después-Después" ;
    ns1:solucionaFallo ns1:ErrorDeSincronizacionAntesAntesOAntesDespuesConSubrutina ;
    ns1:textoExtracto "SOLUCIÓN El CNC siempre ejecuta la subrutina asociada a una función M al finalizar el bloque en el que está programada la función. Definir la función M sin sincronización o bien con sincronización Después-Después." .

ns1:CNC8070_ae61964ab4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC siempre ejecuta la subrutina asociada a una función M al finalizar el bloque en el que está programada la función." .

ns1:ErrorDeSincronizacionAntesAntesOAntesDespuesConSubrutina a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sincronización Antes-Antes o Antes-Después con subrutina" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después." .

