@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_0047
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Un eje principal no puede definirse como esclavo"@es ;
    ex:identificador "0047" ;
    ex:textoExtracto "0047 'Un eje principal no puede definirse como esclavo' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry es el eje maestro de otro eje gantry."@es .

ex:Fallo_0048
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Un eje no puede ser esclavo de varios maestros"@es ;
    ex:identificador "0048" ;
    ex:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje"@es .

ex:Parametro_AXISNAME
    a               ex:Parametro ;
    rdfs:label      "AXISNAME" ;
    ex:identificador "AXISNAME" ;
    ex:textoExtracto "Los nombres de eje válidos son los definidos en el parámetro AXISNAME."@es ;
    ex:monitoreaParametro ex:Fallo_0047 .

ex:TablaEjesGantry a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de ejes gantry"@es ;
    ex:textoExtracto "Corregir la tabla de ejes gantry. El eje maestro de un eje gantry no puede ser esclavo en otro eje gantry."@es ;
    ex:solucionaFallo ex:Fallo_0047 .