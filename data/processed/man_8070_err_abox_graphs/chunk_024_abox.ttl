@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0048
    a ex:Alarma ;
    rdfs:label "Alarma 0048: Un eje no puede ser esclavo de varios maestros"@es ;
    ex:identificador "0048" ;
    ex:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry ya está definido como eje esclavo en otro eje gantry. SOLUCIÓN Corregir la tabla de ejes gantry."@es .

ex:Alarma_0049
    a ex:Alarma ;
    rdfs:label "Alarma 0049: Un eje maestro no puede ser a su vez esclavo y viceversa"@es ;
    ex:identificador "0049" ;
    ex:textoExtracto "0049 'Un eje maestro no puede ser a su vez esclavo y viceversa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje maestro de un eje gantry es el eje esclavo en otro eje gantry o viceversa. SOLUCIÓN Corregir la tabla de ejes gantry."@es .

ex:Alarma_0050
    a ex:Alarma ;
    rdfs:label "Alarma 0050: Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)"@es ;
    ex:identificador "0050" ;
    ex:textoExtracto "0050 'Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no son del mismo tipo; lineales o rotativos. SOLUCIÓN Los ejes de una pareja gantry tienen que ser del mismo tipo, lineales o rotativos (parámetro AXISTYPE)."@es .

ex:Alarma_0051
    a ex:Alarma ;
    rdfs:label "Alarma 0051: Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor"@es ;
    ex:identificador "0051" ;
    ex:textoExtracto "0051 'Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de un eje gantry no tienen las mismas propiedades. SOLUCIÓN Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes. • Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales. • Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales."@es .

ex:Parametro_AXISTYPE
    a ex:Parametro ;
    rdfs:label "AXISTYPE" ;
    ex:identificador "AXISTYPE" ;
    ex:textoExtracto "parámetro AXISTYPE"@es .

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:identificador "AXISMODE" ;
    ex:textoExtracto "parámetro AXISMODE"@es .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:identificador "FACEAXIS" ;
    ex:textoExtracto "parámetro FACEAXIS"@es .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:identificador "LONGAXIS" ;
    ex:textoExtracto "parámetro LONGAXIS"@es .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:identificador "SHORTESTWAY" ;
    ex:textoExtracto "parámetro SHORTESTWAY"@es .

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "CAXIS" ;
    ex:identificador "CAXIS" ;
    ex:textoExtracto "parámetro CAXIS"@es .

ex:Tabla_EjesGantry a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de ejes gantry"@es ;
    ex:textoExtracto "Corregir la tabla de ejes gantry"@es .