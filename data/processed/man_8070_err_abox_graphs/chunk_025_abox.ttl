@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLosParametrosMaquina a ns1:AccionProhibida ;
    rdfs:label "Corregir los parámetros máquina" ;
    ns1:textoExtracto "SOLUCIÓN Corregir los parámetros máquina." .

ns1:NombreDeEje a ns1:Parametro ;
    rdfs:label "Nombre de eje" ;
    ns1:textoExtracto "El parámetro máquina está sin definir o tiene un nombre de eje incorrecto." .

ns1:ReiniciarElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar el CNC" ;
    ns1:solucionaFallo ns1:NombreDeEjeNoValidoONombreDeEjeSinDefinir ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC." .

ns1:NombreDeEjeNoValidoONombreDeEjeSinDefinir a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de eje no válido o nombre de eje sin definir" ;
    ns1:textoExtracto "'Nombre de eje no válido o nombre de eje sin definir' DETECCIÓN Durante la validación de los parámetros máquina." .

