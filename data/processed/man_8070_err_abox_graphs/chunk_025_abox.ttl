@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "CAXIS" ;
    ex:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje." .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje." .

ex:Parametro_MPGAXIS
    a ex:Parametro ;
    rdfs:label "MPGAXIS" ;
    ex:textoExtracto "'Parámetro MPGAXIS repetido en varios volantes'." .

ex:AvisoSeguridad_0052
    a ex:AvisoSeguridad ;
    ex:identificador "0052" ;
    rdfs:label "Diferencia de módulos demasiado pequeña" ;
    ex:textoExtracto "0052 'Diferencia de módulos demasiado pequeña' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje. SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." ;
    ex:mitigaRiesgo ex:Parametro_MODUPLIM, ex:Parametro_MODLOWLIM .

ex:AvisoSeguridad_0053
    a ex:AvisoSeguridad ;
    ex:identificador "0053" ;
    rdfs:label "Parámetro MPGAXIS repetido en varios volantes" ;
    ex:textoExtracto "0053 'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros" ;
    ex:mitigaRiesgo ex:Parametro_MPGAXIS .