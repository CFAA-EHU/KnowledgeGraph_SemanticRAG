@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnEjeQueNoExiste a ns1:AccionProhibida ;
    rdfs:label "Asignar un eje que no existe" ;
    ns1:textoExtracto "El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe." .

ns1:DefinirUnEjePrincipalComoEsclavo a ns1:AccionProhibida ;
    rdfs:label "Definir un eje principal como esclavo" ;
    ns1:textoExtracto "Un eje principal no puede definirse como esclavo." .

ns1:DefinirUnNombreDeCabezalIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Definir un nombre de cabezal incorrecto" ;
    ns1:textoExtracto "El usuario ha definido el parámetro máquina con un nombre de cabezal incorrecto." .

ns1:NombreDelCabezalDefinidoPor1O2Caracteres a ns1:Parametro ;
    rdfs:label "Nombre del cabezal definido por 1 ó 2 caracteres" ;
    ns1:textoExtracto "En el parámetro SPDLNAME, el nombre del cabezal estará definido por 1 ó 2 caracteres." .

ns1:NombreDelEjeDefinidoPor1O2Caracteres a ns1:Parametro ;
    rdfs:label "Nombre del eje definido por 1 ó 2 caracteres" ;
    ns1:textoExtracto "En el parámetro AXISNAME, el nombre del eje estará definido por 1 ó 2 caracteres." .

