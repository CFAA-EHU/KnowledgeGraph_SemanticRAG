ns1:CorregirLaTablaDeEjesGantry a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la tabla de ejes gantry" ;
    ns1:solucionaFallo ns1:UnEjeMaestroNoPuedeSerASuVezEsclavoYViceversa,
        ns1:UnEjeNoPuedeSerEsclavoDeVariosMaestros_5cb8ed65ef ;
    ns1:textoExtracto "SOLUCIÓN Corregir la tabla de ejes gantry." .

ns1:Parametro_04c5e2a08e a ns1:Parametro ;
    rdfs:label "CAXIS" ;
    ns1:textoExtracto "parámetro CAXIS" .

ns1:Parametro_30c6909df1 a ns1:Parametro ;
    rdfs:label "AXISTYPE" ;
    ns1:textoExtracto "parámetro AXISTYPE" .

ns1:Parametro_a58e302752 a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:textoExtracto "parámetro AXISMODE" .

ns1:Parametro_c5cc3d5f93 a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:textoExtracto "parámetro LONGAXIS" .

ns1:Parametro_c9d81ee6b6 a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "parámetro FACEAXIS" .

ns1:Parametro_e5130a3ac2 a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "parámetro SHORTESTWAY" .

ns1:RevisarLaTablaDeEjesGantryYOElParametroAXISTYPEDeAmbosEjes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la tabla de ejes gantry y/o el parámetro AXISTYPE de ambos ejes" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDebenSerDelMismoTipoAXISTYPE ;
    ns1:textoExtracto "SOLUCIÓN Revisar la tabla de ejes gantry y/o el parámetro AXISTYPE de ambos ejes." .

ns1:RevisarLaTablaDeEjesGantryYOLosSiguientesParametrosMaquinaDeLosEjes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDebenTenerCiertosParametrosConElMismoValor ;
    ns1:textoExtracto "SOLUCIÓN Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes." .

ns1:LosEjesMaestroYEsclavoDebenSerDelMismoTipoAXISTYPE a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)" ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)'" .

ns1:LosEjesMaestroYEsclavoDebenTenerCiertosParametrosConElMismoValor a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor" ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor'" .

ns1:UnEjeMaestroNoPuedeSerASuVezEsclavoYViceversa a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje maestro no puede ser a su vez esclavo y viceversa" ;
    ns1:textoExtracto "'Un eje maestro no puede ser a su vez esclavo y viceversa'" .

ns1:UnEjeNoPuedeSerEsclavoDeVariosMaestros_5cb8ed65ef a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje no puede ser esclavo de varios maestros" ;
    ns1:textoExtracto "'Un eje no puede ser esclavo de varios maestros'" .

