@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarResolucionDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar resolución del eje" ;
    ns1:solucionaFallo ns1:DiferenciaDeModulosDemasiadoPequena_a803e5d01d ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:EjeDeGiro a ns1:Parametro ;
    rdfs:label "Eje de giro" ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:EjeFrontal_5142311d42 a ns1:Parametro ;
    rdfs:label "Eje frontal" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:EjeLongitudinal_d2218da3ce a ns1:Parametro ;
    rdfs:label "Eje longitudinal" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:ModoDelEje_9a7ca26fb8 a ns1:Parametro ;
    rdfs:label "Modo del eje" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:ModuloInferiorLimite a ns1:Parametro ;
    rdfs:label "Módulo inferior límite" ;
    ns1:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje. SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:ModuloSuperiorLimite a ns1:Parametro ;
    rdfs:label "Módulo superior límite" ;
    ns1:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje. SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:Parametro_c25cb75e44 a ns1:Parametro ;
    rdfs:label "Parámetro MPGAXIS repetido en varios volantes" ;
    ns1:textoExtracto "0053 'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros." .

ns1:RutaMasCorta_23d89831b3 a ns1:Parametro ;
    rdfs:label "Ruta más corta" ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:DiferenciaDeModulosDemasiadoPequena_a803e5d01d a ns1:DiagnosticoFallo ;
    rdfs:label "'Diferencia de módulos demasiado pequeña'" ;
    ns1:textoExtracto "0052 'Diferencia de módulos demasiado pequeña' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje." .

