@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_7f2dfecb2f a ns1:AvisoSeguridad ;
    rdfs:label "'Parámetro MPGAXIS repetido en varios volantes'" ;
    ns1:mitigaRiesgo ns1:AsignarVolantesRepetidosEnElMismoEje ;
    ns1:textoExtracto "'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros de manual, hay dos o más volantes asignados al mismo eje. SOLUCIÓN Un eje sólo puede tener asignando un volante." .

ns1:LimiteInferiorDelModulo_41d1480e1a a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo" ;
    ns1:textoExtracto "aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:LimiteSuperiorDelModulo_7ea12454dd a ns1:Parametro ;
    rdfs:label "Límite superior del módulo" ;
    ns1:textoExtracto "aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:LosEjesMOVAXISYCOMPAXISDebenSerDistintos a ns1:AvisoSeguridad ;
    rdfs:label "'Los ejes MOVAXIS y COMPAXIS deben ser distintos'" ;
    ns1:mitigaRiesgo ns1:CoincidirEjesMOVAXISYCOMPAXIS ;
    ns1:textoExtracto "'Los ejes MOVAXIS y COMPAXIS deben ser distintos' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una de las tablas de compensación cruzada coinciden el eje compensado y el eje cuyo movimiento altera al eje que se compensa. SOLUCIÓN En cada tabla de compensación cruzada, ambos ejes deben ser distintos (parámetros MOVAXIS y COMPAXIS)." .

ns1:PosicionesDeLaTablaDeCompensacionNoAscendentes a ns1:AvisoSeguridad ;
    rdfs:label "'Posiciones de la tabla de compensación no ascendentes'" ;
    ns1:mitigaRiesgo ns1:DefinirPosicionesEnLaTablaDeCompensacionNoAscendentes ;
    ns1:textoExtracto "'Posiciones de la tabla de compensación no ascendentes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación, los puntos a compensar no están ordenados correctamente o el valor a compensar en todos los puntos tienen valor cero. SOLUCIÓN El parámetro POSITION dentro de las tablas de compensación tiene que tomar valores ascendentes." .

ns1:TablaDeCompensacionConPendienteDeErrorSuperiorA1_d3c1f828db a ns1:AvisoSeguridad ;
    rdfs:label "'Tabla de compensación con pendiente de error superior a 1'" ;
    ns1:mitigaRiesgo ns1:DefinirTablaDeCompensacionConPendienteDeErrorSuperiorA1 ;
    ns1:textoExtracto "'Tabla de compensación con pendiente de error superior a 1' DETECCIÓN Durante la validación de los parámetros máquina (tabla de compensación de husillo)." .

ns1:UnMismoEjeEsALaVezCausaYEfectoDeLaCompensacionCruzada a ns1:AvisoSeguridad ;
    rdfs:label "'Un mismo eje es a la vez causa y efecto de la compensación cruzada'" ;
    ns1:mitigaRiesgo ns1:DefinirUnaMismaEjeComoCausaYEfectoDeLaCompensacionCruzada ;
    ns1:textoExtracto "'Un mismo eje es a la vez causa y efecto de la compensación cruzada' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación cruzada, siguiendo las diferentes asociaciones de ejes compensados (parámetro COMPAXIS) y ejes cuyos movimientos alteran a los ejes que se compensan (parámetro MOVAXIS), hay un eje cuyo movimiento depende de sí mismo. SOLUCIÓN Revisar la relación entre las compensaciones cruzadas definidas." .

ns1:AsignarVolantesRepetidosEnElMismoEje a ns1:AccionProhibida ;
    rdfs:label "Asignar volantes repetidos en el mismo eje" ;
    ns1:textoExtracto "'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros de manual, hay dos o más volantes asignados al mismo eje. SOLUCIÓN Un eje sólo puede tener asignando un volante." .

ns1:CoincidirEjesMOVAXISYCOMPAXIS a ns1:AccionProhibida ;
    rdfs:label "Coincidir ejes MOVAXIS y COMPAXIS" ;
    ns1:textoExtracto "'Los ejes MOVAXIS y COMPAXIS deben ser distintos' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una de las tablas de compensación cruzada coinciden el eje compensado y el eje cuyo movimiento altera al eje que se compensa. SOLUCIÓN En cada tabla de compensación cruzada, ambos ejes deben ser distintos (parámetros MOVAXIS y COMPAXIS)." .

ns1:DefinirPosicionesEnLaTablaDeCompensacionNoAscendentes a ns1:AccionProhibida ;
    rdfs:label "Definir posiciones en la tabla de compensación no ascendentes" ;
    ns1:textoExtracto "'Posiciones de la tabla de compensación no ascendentes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación, los puntos a compensar no están ordenados correctamente o el valor a compensar en todos los puntos tienen valor cero. SOLUCIÓN El parámetro POSITION dentro de las tablas de compensación tiene que tomar valores ascendentes." .

ns1:DefinirTablaDeCompensacionConPendienteDeErrorSuperiorA1 a ns1:AccionProhibida ;
    rdfs:label "Definir tabla de compensación con pendiente de error superior a 1" ;
    ns1:textoExtracto "'Tabla de compensación con pendiente de error superior a 1' DETECCIÓN Durante la validación de los parámetros máquina (tabla de compensación de husillo)." .

ns1:DefinirUnaMismaEjeComoCausaYEfectoDeLaCompensacionCruzada a ns1:AccionProhibida ;
    rdfs:label "Definir una misma eje como causa y efecto de la compensación cruzada" ;
    ns1:textoExtracto "'Un mismo eje es a la vez causa y efecto de la compensación cruzada' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación cruzada, siguiendo las diferentes asociaciones de ejes compensados (parámetro COMPAXIS) y ejes cuyos movimientos alteran a los ejes que se compensan (parámetro MOVAXIS), hay un eje cuyo movimiento depende de sí mismo. SOLUCIÓN Revisar la relación entre las compensaciones cruzadas definidas." .

