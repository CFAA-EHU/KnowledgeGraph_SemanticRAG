@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_0063
    a ex:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog incremental supera velocidad máxima del eje"@es ;
    ex:identificador "0063" ;
    ex:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro INCJOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro INCJOGFEED; debe ser inferior a G00FEED."@es ;
    ex:monitoreaParametro ex:Parametro_INCJOGFEED, ex:Parametro_G00FEED .

ex:Fallo_0064
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de I0TYPE en ejes maestro/esclavo gantry"@es ;
    ex:identificador "0064" ;
    ex:textoExtracto "'Los ejes maestro y esclavo deben tener el mismo I0TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA No coinciden el tipo de I0 en ambos ejes de la pareja gantry. SOLUCIÓN Ambos ejes deben tener el mismo tipo de I0 (parámetro I0TYPE)."@es ;
    ex:monitoreaParametro ex:Parametro_I0TYPE .

ex:Fallo_0065
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje Hirth no compatible con configuración Gantry"@es ;
    ex:identificador "0065" ;
    ex:textoExtracto "'Un eje Hirth no puede ser Gantry' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje hirth no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser hirth (parámetro HIRTH). Utilizar otro tipo de eje para construir el eje gantry."@es ;
    ex:monitoreaParametro ex:Parametro_HIRTH .

ex:Fallo_0066
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro REFSHIFT no permitido en ejes Gantry"@es ;
    ex:identificador "0066" ;
    ex:textoExtracto "'Un eje Gantry no puede tener REFSHIFT' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Alguno de los ejes que forman el eje gantry, en algún set de parámetros tiene definido el parámetro REFSHIFT con un valor distinto de 0. SOLUCIÓN Definir el parámetro REFSHIFT de todas las gamas con valor 0."@es ;
    ex:monitoreaParametro ex:Parametro_REFSHIFT .

ex:Fallo_0067
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje unidireccional incompatible con configuración Gantry"@es ;
    ex:identificador "0067" ;
    ex:textoExtracto "'Un eje Gantry no puede ser unidireccional' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje rotativo unidireccional no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser unidireccional (parámetro UNIDIR). Utilizar otro tipo de eje para construir el eje gantry."@es ;
    ex:monitoreaParametro ex:Parametro_UNIDIR .

ex:Fallo_0068
    a ex:DiagnosticoFallo ;
    rdfs:label "Orden incorrecto de ejes maestro/esclavo en AXISNAME (Gantry/Tandem)"@es ;
    ex:identificador "0068" ;
    ex:textoExtracto "'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina."@es ;
    ex:monitoreaParametro ex:Parametro_AXISNAME .

ex:Parametro_INCJOGFEED
    a ex:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ex:textoExtracto "parámetro INCJOGFEED"@es .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "parámetro G00FEED"@es .

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "I0TYPE" ;
    ex:textoExtracto "parámetro I0TYPE"@es .

ex:Parametro_HIRTH
    a ex:Parametro ;
    rdfs:label "HIRTH" ;
    ex:textoExtracto "parámetro HIRTH"@es .

ex:Parametro_REFSHIFT
    a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:textoExtracto "parámetro REFSHIFT"@es .

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "UNIDIR" ;
    ex:textoExtracto "parámetro UNIDIR"@es .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "AXISNAME" ;
    ex:textoExtracto "parámetro AXISNAME"@es .