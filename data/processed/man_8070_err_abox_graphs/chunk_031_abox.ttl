@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiferenciaEntreDosErroresConsecutivosMayorQueLaDistanciaQueSeparaAmbosPuntos a ns1:DiagnosticoFallo ;
    rdfs:label "diferencia entre dos errores consecutivos mayor que la distancia que separa ambos puntos" ;
    ns1:textoExtracto "En las tablas de compensación de husillo, la diferencia entre dos errores consecutivos es mayor que la distancia que separa ambos puntos." .

ns1:TablaDeCompensacionConPendienteDeErrorSuperiorA1_078d5699a1 a ns1:Tabla ;
    rdfs:label "Tabla de compensación con pendiente de error superior a 1" ;
    ns1:ilustra ns1:TablaDeCompensacionDeHusillo_d3a55621c4 ;
    ns1:textoExtracto "'Tabla de compensación con pendiente de error superior a 1'" .

ns1:ValorACompensarCeroEnTodosLosPuntos a ns1:AccionProhibida ;
    rdfs:label "valor a compensar cero en todos los puntos" ;
    ns1:textoExtracto "El valor a compensar no puede ser cero en todos los puntos." .

ns1:TablaDeCompensacionDeHusillo_d3a55621c4 a ns1:Parametro ;
    rdfs:label "tabla de compensación de husillo" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina (tabla de compensación de husillo)." .

