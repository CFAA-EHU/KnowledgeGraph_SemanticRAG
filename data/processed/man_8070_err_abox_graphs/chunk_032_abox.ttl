@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0069
    a ex:Alarma ;
    rdfs:label "Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene" ;
    ex:identificador "0069" ;
    ex:textoExtracto "0069 'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry tiene micro y el eje maestro no. SOLUCIÓN En un eje gantry podrá tener micro de referencia el eje maestro, ambos ejes o ninguno (parámetro DECINPUT)." .

ex:Alarma_0070
    a ex:Alarma ;
    rdfs:label "Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo" ;
    ex:identificador "0070" ;
    ex:textoExtracto "0070 'Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En alguna pareja gantry o tándem, los límites de software de ambos ejes son distintos. SOLUCIÓN Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)." .

ex:Alarma_0071
    a ex:Alarma ;
    rdfs:label "Vigilancia de error de seguimiento no activa en el CNC" ;
    ex:identificador "0071" ;
    ex:textoExtracto "0071 'Vigilancia de error de seguimiento no activa en el CNC' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En algún set de parámetros, no está activa la vigilancia del error de seguimiento. Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada. SOLUCIÓN Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)." .

ex:Alarma_0072
    a ex:Alarma ;
    rdfs:label "Alarma de captación sin activar" ;
    ex:identificador "0072" ;
    ex:textoExtracto "0072 'Alarma de captación sin activar' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En algún set de parámetros de un eje o cabezal analógico, no está activa la alarma de captación. Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada. SOLUCIÓN En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)." .

ex:Alarma_0073
    a ex:Alarma ;
    rdfs:label "Límites de soft sin activar" ;
    ex:identificador "0073" ;
    ex:textoExtracto "0073 'Límites de soft sin activar' DETECCIÓN Durante la validación de los parámetros máquina." .

ex:Parametro_DECINPUT
    a ex:Parametro ;
    rdfs:label "DECINPUT (micro de referencia)" ;
    ex:textoExtracto "parámetro DECINPUT" ;
    ex:valor "micro de referencia" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT+" ;
    ex:textoExtracto "parámetros LIMIT+ y LIMIT-" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT-" ;
    ex:textoExtracto "parámetros LIMIT+ y LIMIT-" .

ex:Parametro_FLWEMONITOR
    a ex:Parametro ;
    rdfs:label "FLWEMONITOR (vigilancia de error de seguimiento)" ;
    ex:textoExtracto "parámetro FLWEMONITOR" ;
    ex:valor "vigilancia de error de seguimiento" .

ex:Parametro_FBACKAL
    a ex:Parametro ;
    rdfs:label "FBACKAL (alarma de captación)" ;
    ex:textoExtracto "parámetro FBACKAL" ;
    ex:valor "alarma de captación" .

ex:Sistema_EjesGantry
    a ex:Sistema ;
    rdfs:label "Sistema de ejes Gantry/Tándem" ;
    ex:textoExtracto "pareja gantry o tándem. Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene. Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo." ;
    ex:tieneComponente ex:Parametro_DECINPUT, ex:Parametro_LIMIT, ex:Parametro_LIMIT .

ex:Alarma_0069 ex:activaAlarma ex:Parametro_DECINPUT .
ex:Alarma_0070 ex:activaAlarma ex:Parametro_LIMIT , ex:Parametro_LIMIT .
ex:Alarma_0071 ex:activaAlarma ex:Parametro_FLWEMONITOR .
ex:Alarma_0072 ex:activaAlarma ex:Parametro_FBACKAL .