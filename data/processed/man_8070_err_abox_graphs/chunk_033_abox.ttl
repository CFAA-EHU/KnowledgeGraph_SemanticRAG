@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0073
    a ex:Alarma ;
    rdfs:label "Alarma 0073: Límites de soft sin activar" ;
    ex:textoExtracto "0073 'Límites de soft sin activar' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En algún eje, los límites de software no están activados. Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." ;
    ex:identificador "0073" .

ex:Alarma_0074
    a ex:Alarma ;
    rdfs:label "Alarma 0074: Test de tendencia sin activar" ;
    ex:textoExtracto "0074 'Test de tendencia sin activar'" ;
    ex:identificador "0074" .

ex:Parametro_FBACKAL
    a ex:Parametro ;
    rdfs:label "Parámetro FBACKAL (activación de alarma de captación)" ;
    ex:textoExtracto "activar la alarma de captación en todos los sets (parámetro FBACKAL)" ;
    ex:identificador "FBACKAL" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro LIMIT+ (límite de software positivo)" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." ;
    ex:identificador "LIMIT+" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro LIMIT- (límite de software negativo)" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." ;
    ex:identificador "LIMIT-" .

ex:Sistema_EjesAnalogicos
    a ex:Sistema ;
    rdfs:label "Sistema de ejes y cabezales analógicos" ;
    ex:textoExtracto "En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)." ;
    ex:activaAlarma ex:Alarma_0073 ;
    ex:monitoreaParametro ex:Parametro_FBACKAL, ex:Parametro_LIMIT, ex:Parametro_LIMIT .