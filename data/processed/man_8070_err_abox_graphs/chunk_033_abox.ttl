@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DisminuirElValorDelParametroJOGFEED a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el valor del parámetro JOGFEED" ;
    ns1:solucionaFallo ns1:LaVelocidadDeJogIncrementalSuperaLaVelocidadMaximaDelEje ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED." .

ns1:IncrementoDeVelocidadDeJog a ns1:Parametro ;
    rdfs:label "Incremento de velocidad de jog" ;
    ns1:textoExtracto "El parámetro INCJOGFEED es superior a G00FEED." .

ns1:VelocidadDeJogIncremental a ns1:Parametro ;
    rdfs:label "Velocidad de jog incremental" ;
    ns1:textoExtracto "El parámetro JOGFEED es superior a G00FEED." .

ns1:LaVelocidadDeJogIncrementalSuperaLaVelocidadMaximaDelEje a ns1:DiagnosticoFallo ;
    rdfs:label "La velocidad de jog incremental supera la velocidad máxima del eje" ;
    ns1:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje'" .

