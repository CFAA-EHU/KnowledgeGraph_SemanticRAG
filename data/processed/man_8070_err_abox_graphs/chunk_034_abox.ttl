@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AmbosEjesDebenTenerElMismoTipoDeI0 a ns1:TareaMantenimiento ;
    rdfs:label "Ambos ejes deben tener el mismo tipo de I0" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDebenTenerElMismoI0TYPE ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben tener el mismo I0TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA No coinciden el tipo de I0 en ambos ejes de la pareja gantry." .

ns1:DefinirElParametroREFSHIFTDeTodasLasGamasConValor0 a ns1:TareaMantenimiento ;
    rdfs:label "Definir el parámetro REFSHIFT de todas las gamas con valor 0" ;
    ns1:solucionaFallo ns1:UnEjeGantryNoPuedeTenerREFSHIFT ;
    ns1:textoExtracto "'Un eje Gantry no puede tener REFSHIFT' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Alguno de los ejes que forman el eje gantry, en algún set de parámetros tiene definido el parámetro REFSHIFT con un valor distinto de 0." .

ns1:DesplazamientoDeReferencia_ae6acabd2f a ns1:Parametro ;
    rdfs:label "Desplazamiento de referencia" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "'Un eje Gantry no puede tener REFSHIFT' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Alguno de los ejes que forman el eje gantry, en algún set de parámetros tiene definido el parámetro REFSHIFT con un valor distinto de 0." .

ns1:DireccionUnica a ns1:Parametro ;
    rdfs:label "Dirección única" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "'Un eje Gantry no puede ser unidireccional' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje rotativo unidireccional no puede formar parte de un eje gantry." .

ns1:DisminuirElValorDelParametroINCJOGFEED a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el valor del parámetro INCJOGFEED" ;
    ns1:solucionaFallo ns1:LaVelocidadDeJogIncrementalSuperaLaVelocidadMaximaDelEje_0ad47e681b ;
    ns1:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro INCJOGFEED es superior a G00FEED." .

ns1:TipoDeEjeHirth a ns1:Parametro ;
    rdfs:label "Tipo de eje Hirth" ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "'Un eje Hirth no puede ser Gantry' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje hirth no puede formar parte de un eje gantry." .

