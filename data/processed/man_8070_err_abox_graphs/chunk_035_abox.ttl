ns1:DefinirEnLaTablaElEjeMaestroAntesQueElEjeEsclavoOIntercambiarElEjeMae_6bcfd2748a a ns1:TareaMantenimiento ;
    rdfs:label "Definir en la tabla el eje maestro antes que el eje esclavo o intercambiar el eje maestro y esclavo en la pareja gantry o tándem" ;
    ns1:solucionaFallo ns1:EjesGantrysTandemElEsclavoNoPuedePrecederAlMaestroEnAXISNAME ;
    ns1:textoExtracto "SOLUCIÓN Definir en la tabla el eje maestro antes que el eje esclavo o intercambiar el eje maestro y esclavo en la pareja gantry o tándem." .

ns1:EjesGantryElEsclavoNoPuedeTenerDECINPUTMicroDeReferenciaSiElMaestroNoLoTiene a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene" ;
    ns1:textoExtracto "'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene'" .

ns1:TablaDeAsignacionDeNombresDeEjes a ns1:Parametro ;
    rdfs:label "Tabla de asignación de nombres de ejes" ;
    ns1:textoExtracto "En las tablas de asignación de nombres de ejes (parámetro AXISNAME)" .

ns1:EjesGantrysTandemElEsclavoNoPuedePrecederAlMaestroEnAXISNAME a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME" ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME'" .

