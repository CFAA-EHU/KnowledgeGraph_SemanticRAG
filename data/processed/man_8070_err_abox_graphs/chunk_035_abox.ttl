@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0078
    a               ex:Alarma ;
    rdfs:label      "Alarma 0078: Ejes Gantry de canales distintos"@es ;
    ex:identificador "0078" ;
    ex:textoExtracto "'Los ejes maestro y esclavo deben pertenecer al mismo canal' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún eje gantry está formado por ejes de canales distintos. SOLUCIÓN En un eje gantry, ambos ejes deben pertenecer al mismo canal."@es .

ex:Alarma_0079
    a               ex:Alarma ;
    rdfs:label      "Alarma 0079: Eje esclavo Gantry aparcado"@es ;
    ex:identificador "0079" ;
    ex:textoExtracto "'Un eje esclavo Gantry no puede estar aparcado' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. gantry está aparcado; la señal CAUSA El CNC ha detectado que el eje esclavo de una pareja"@es .

ex:DiagnosticoFallo_0078
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Ejes Gantry en canales distintos"@es ;
    ex:textoExtracto "Algún eje gantry está formado por ejes de canales distintos. SOLUCIÓN En un eje gantry, ambos ejes deben pertenecer al mismo canal."@es ;
    ex:solucionaFallo ex:Alarma_0078 .

ex:DiagnosticoFallo_0079
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Eje esclavo Gantry aparcado"@es ;
    ex:textoExtracto "El CNC ha detectado que el eje esclavo de una pareja gantry está aparcado."@es ;
    ex:solucionaFallo ex:Alarma_0079 .

ex:Sistema_Gantry
    a               ex:Sistema ;
    rdfs:label      "Sistema de ejes Gantry"@es ;
    ex:textoExtracto "eje gantry"@es ;
    ex:activaAlarma ex:Alarma_0078 , ex:Alarma_0079 .