@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0080
    a ex:Alarma ;
    rdfs:label "Alarma 0080: Validación de parámetros generales"@es ;
    ex:identificador "0080" ;
    ex:textoExtracto "'Para validar el eje, hay que validar la tabla de PARAMETROS GENERALES' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha añadido algún eje al sistema (parámetro NAXIS), y sin validar la tabla de parámetros generales, ha intentado validar la tabla de parámetros de uno de los nuevos ejes."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_0080 .

ex:Alarma_0081
    a ex:Alarma ;
    rdfs:label "Alarma 0081: Banda de muerte inferior a resolución del eje"@es ;
    ex:identificador "0081" ;
    ex:textoExtracto "'La banda de muerte no puede ser menor que la resolución del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La banda de muerte es menor que la resolución del eje."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_0081 .

ex:Alarma_0082
    a ex:Alarma ;
    rdfs:label "Alarma 0082: Compensación de husillo o cruzada imposible"@es ;
    ex:identificador "0082" ;
    ex:textoExtracto "'Compensación de husillo o cruzada imposible para todas las gamas del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una compensación, el eje que se mueve (parámetro MOVAXIS) es rotativo y no tiene los mismos límites de módulo en todos los sets de parámetros."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_0082 .

ex:Alarma_0083
    a ex:Alarma ;
    rdfs:label "Alarma 0083: Tipos de regulador incompatibles en ejes gantry"@es ;
    ex:identificador "0083" ;
    ex:textoExtracto "'Los ejes maestro y esclavo deben ser del mismo tipo (DRIVETYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_0083 .

ex:Alarma_EjeAparcado
    a ex:Alarma ;
    rdfs:label "Alarma: Eje esclavo de pareja gantry aparcado"@es ;
    ex:textoExtracto "'no puede estar aparcado' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. gantry está aparcado; la señal CAUSA El CNC ha detectado que el eje esclavo de una pareja PARKED del eje esclavo está activa."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_EjeAparcado .

ex:DiagnosticoFallo_0080
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de validación: Parámetros generales no validados"@es ;
    ex:textoExtracto "El usuario ha añadido algún eje al sistema (parámetro NAXIS), y sin validar la tabla de parámetros generales, ha intentado validar la tabla de parámetros de uno de los nuevos ejes."@es ;
    ex:solucionaFallo ex:Parametro_NAXIS .

ex:DiagnosticoFallo_0081
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de configuración: Banda de muerte < resolución del eje"@es ;
    ex:textoExtracto "La banda de muerte es menor que la resolución del eje."@es ;
    ex:solucionaFallo ex:Parametro_INPOSW .

ex:DiagnosticoFallo_0082
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de compensación: Límites de módulo inconsistentes en eje rotativo"@es ;
    ex:textoExtracto "El eje que se mueve (parámetro MOVAXIS) es rotativo y no tiene los mismos límites de módulo en todos los sets de parámetros."@es ;
    ex:solucionaFallo ex:Parametro_MOVAXIS, ex:Parametro_MODUPLIM, ex:Parametro_MODLOWLIM .

ex:DiagnosticoFallo_0083
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de configuración: Tipos de regulador (DRIVETYPE) incompatibles en gantry"@es ;
    ex:textoExtracto "Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink."@es ;
    ex:solucionaFallo ex:Parametro_DRIVETYPE .

ex:DiagnosticoFallo_EjeAparcado
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de arranque: Eje esclavo gantry aparcado (señal PARKED activa)"@es ;
    ex:textoExtracto "El CNC ha detectado que el eje esclavo de una pareja PARKED del eje esclavo está activa."@es .

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:identificador "NAXIS" ;
    ex:textoExtracto "parámetro NAXIS"@es .

ex:Parametro_INPOSW
    a ex:Parametro ;
    rdfs:label "INPOSW" ;
    ex:identificador "INPOSW" ;
    ex:textoExtracto "parámetro INPOSW (banda de muerte)"@es .

ex:Parametro_MOVAXIS
    a ex:Parametro ;
    rdfs:label "MOVAXIS" ;
    ex:identificador "MOVAXIS" ;
    ex:textoExtracto "parámetro MOVAXIS (eje que se mueve en compensación)"@es .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:identificador "MODUPLIM" ;
    ex:textoExtracto "parámetro MODUPLIM (límite superior de módulo)"@es .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:identificador "MODLOWLIM" ;
    ex:textoExtracto "parámetro MODLOWLIM (límite inferior de módulo)"@es .

ex:Parametro_DRIVETYPE
    a ex:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ex:identificador "DRIVETYPE" ;
    ex:textoExtracto "parámetro DRIVETYPE (tipo de regulador: analógico, Sercos o Mechatrolink)"@es .

ex:Sistema_Gantry
    a ex:Sistema ;
    rdfs:label "Sistema de ejes gantry"@es ;
    ex:textoExtracto "eje esclavo de una pareja gantry"@es .