    ns1:textoExtracto "(parámetro FLWEMONITOR)" .

ns1:ElEjeEsclavoNoPuedeTenerDECINPUTSiElMaestroNoLoTiene a ns1:DiagnosticoFallo ;
    rdfs:label "El eje esclavo no puede tener DECINPUT si el maestro no lo tiene" ;
    ns1:textoExtracto "'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene'" .

ns1:EnAlgunSetDeParametrosNoEstaActivaLaAlarmaDeCaptacion a ns1:DiagnosticoFallo ;
    rdfs:label "En algún set de parámetros, no está activa la alarma de captación" ;
    ns1:textoExtracto "'Alarma de captación sin activar'" .

ns1:LIMITYLIMITNoPuedenSerDistintosEnElMaestroYEsclavo a ns1:DiagnosticoFallo ;
    rdfs:label "LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo" ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo'" .

ns1:LimitesDeSoftSinActivar_1c9bad02e5 a ns1:DiagnosticoFallo ;
    rdfs:label "Límites de soft sin activar" ;
    ns1:textoExtracto "'Límites de soft sin activar'" .

ns1:NoEstaActivaLaVigilanciaDelErrorDeSeguimiento a ns1:DiagnosticoFallo ;
    rdfs:label "No está activa la vigilancia del error de seguimiento" ;
    ns1:textoExtracto "'Vigilancia de error de seguimiento no activa en el CNC'" .

