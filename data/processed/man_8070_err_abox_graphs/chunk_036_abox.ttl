@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaAlarmaDeCaptacionEnTodosLosSetsParametroFBACKAL a ns1:TareaMantenimiento ;
    rdfs:label "Activar la alarma de captación en todos los sets (parámetro FBACKAL)" ;
    ns1:solucionaFallo ns1:EnAlgunSetDeParametrosNoEstaActivaLaAlarmaDeCaptacion ;
    ns1:textoExtracto "SOLUCIÓN En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)." .

ns1:ActivarLaVigilanciaDelErrorDeSeguimientoEnTodosLosSetsDeParametrosPar_2852ee4bd2 a ns1:TareaMantenimiento ;
    rdfs:label "Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)" ;
    ns1:solucionaFallo ns1:NoEstaActivaLaVigilanciaDelErrorDeSeguimiento ;
    ns1:textoExtracto "SOLUCIÓN Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)." .

ns1:ActivarLimitesDeSoft a ns1:TareaMantenimiento ;
    rdfs:label "Activar límites de soft" ;
    ns1:solucionaFallo ns1:LimitesDeSoftSinActivar_1c9bad02e5 ;
    ns1:textoExtracto "'Límites de soft sin activar'" .

ns1:DefinirAmbosEjesConLosMismosLimitesDeSoftwareParametrosLIMITYLIMIT a ns1:TareaMantenimiento ;
    rdfs:label "Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)" ;
    ns1:solucionaFallo ns1:ElEjeEsclavoNoPuedeTenerDECINPUTSiElMaestroNoLoTiene ;
    ns1:textoExtracto "SOLUCIÓN En un eje gantry podrá tener micro de referencia el eje maestro, ambos ejes o ninguno (parámetro DECINPUT)." .

ns1:DefinirAmbosEjesConLosMismosLimitesDeSoftwareParametrosLIMITYLIMIT_11918ee805 a ns1:TareaMantenimiento ;
    rdfs:label "Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)" ;
    ns1:solucionaFallo ns1:LIMITYLIMITNoPuedenSerDistintosEnElMaestroYEsclavo ;
    ns1:textoExtracto "SOLUCIÓN Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)." .

ns1:ElEjeEsclavoDeUnEjeGantryTieneMicroYElEjeMaestroNo a ns1:AccionProhibida ;
    rdfs:label "El eje esclavo de un eje gantry tiene micro y el eje maestro no" ;
    ns1:textoExtracto "'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene'" .

ns1:EnAlgunSetDeParametrosDeUnEjeOCabezalAnalogicoNoEstaActivaLaAlarmaDeCaptacion a ns1:AccionProhibida ;
    rdfs:label "En algún set de parámetros de un eje o cabezal analógico, no está activa la alarma de captación" ;
    ns1:textoExtracto "'Alarma de captación sin activar'" .

ns1:EnAlgunSetDeParametrosNoEstaActivaLaVigilanciaDelErrorDeSeguimiento a ns1:AccionProhibida ;
    rdfs:label "En algún set de parámetros, no está activa la vigilancia del error de seguimiento" ;
    ns1:textoExtracto "'Vigilancia de error de seguimiento no activa en el CNC'" .

ns1:EnAlgunaParejaGantryOTandemLosLimitesDeSoftwareDeAmbosEjesSonDistintos a ns1:AccionProhibida ;
    rdfs:label "En alguna pareja gantry o tándem, los límites de software de ambos ejes son distintos" ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo'" .

ns1:LimiteInferiorDeSoftware_e707e2f419 a ns1:Parametro ;
    rdfs:label "Límite inferior de software" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "(parámetros LIMIT+ y LIMIT-)" .

ns1:LimiteSuperiorDeSoftware_02cbbaf917 a ns1:Parametro ;
    rdfs:label "Límite superior de software" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "(parámetros LIMIT+ y LIMIT-)" .

ns1:LimitesDeSoftSinActivar a ns1:AccionProhibida ;
    rdfs:label "Límites de soft sin activar" ;
    ns1:textoExtracto "'Límites de soft sin activar'" .

ns1:MicroDeReferencia_b388e4eaf9 a ns1:Parametro ;
    rdfs:label "Micro de referencia" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "(parámetro DECINPUT)" .

ns1:Parametro_9fe8c4cf48 a ns1:Parametro ;
    rdfs:label "Alarma de captación" ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "(parámetro FBACKAL)" .

ns1:VigilanciaDelErrorDeSeguimiento a ns1:Parametro ;
