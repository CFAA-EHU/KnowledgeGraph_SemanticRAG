@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_0084
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 0084: Eje o cabezal no intercambiable sin asignar a canal" ;
    ex:textoExtracto "'Un eje o cabezal no intercambiable no puede quedar sin asignar a un canal'" ;
    ex:identificador "0084" .

ex:Parametro_DRIVETYPE
    a ex:Parametro ;
    rdfs:label "Parámetro DRIVETYPE (tipo de regulador)" ;
    ex:textoExtracto "Los ejes de una pareja gantry tienen que tener el mismo tipo de regulador (parámetro DRIVETYPE)." ;
    ex:identificador "DRIVETYPE" .

ex:Sistema_Gantry
    a ex:Sistema ;
    rdfs:label "Sistema de ejes gantry" ;
    ex:textoExtracto "Los ejes de una pareja gantry tienen que tener el mismo tipo de regulador (parámetro DRIVETYPE)." ;
    ex:tieneComponente ex:Eje_Gantry_1, ex:Eje_Gantry_2 ;
    ex:monitoreaParametro ex:Parametro_DRIVETYPE .

ex:Eje_Gantry_1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje gantry (par de la pareja)" ;
    ex:textoExtracto "Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink." .

ex:Eje_Gantry_2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje gantry (par de la pareja)" ;
    ex:textoExtracto "Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink." .

ex:Fallo_AsignacionCanal
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo: Cabezal o eje sin permiso de intercambio no asignado" ;
    ex:textoExtracto "Hay un eje o cabezal sin permiso de intercambio que no está asignado a ningún canal." .

ex:Cabezal_NoIntercambiable
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal sin permiso de intercambio" ;
    ex:textoExtracto "Hay un eje o cabezal sin permiso de intercambio que no está asignado a ningún canal." .