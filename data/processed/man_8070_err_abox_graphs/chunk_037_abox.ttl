@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_af2e3777fb a ns1:Alarma ;
    rdfs:label "Alarma de captación" ;
    ns1:textoExtracto "activar la alarma de captación en todos los sets (parámetro FBACKAL)" .

ns1:DefinirLimitesDeSoftware a ns1:TareaMantenimiento ;
    rdfs:label "Definir límites de software" ;
    ns1:monitoreaParametro ns1:LimiteInferiorDeSoftware_e707e2f419,
        ns1:LimiteSuperiorDeSoftware_02cbbaf917 ;
    ns1:solucionaFallo ns1:FalloLimitesSinActivar ;
    ns1:textoExtracto "Definir los límites de software de todos los ejes (parámetros LIMIT+ y LIMIT-)" .

ns1:Parametro_9fe8c4cf48 a ns1:Parametro ;
    rdfs:label "Parámetro de activación de alarma de captación" ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "(parámetro FBACKAL)" .

ns1:FalloLimitesSinActivar a ns1:DiagnosticoFallo ;
    rdfs:label "Límites de software no activados" ;
    ns1:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." .

ns1:LimiteInferiorDeSoftware_e707e2f419 a ns1:Parametro ;
    rdfs:label "Límite inferior de software" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "(parámetros LIMIT+ y LIMIT-)" .

ns1:LimiteSuperiorDeSoftware_02cbbaf917 a ns1:Parametro ;
    rdfs:label "Límite superior de software" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "(parámetros LIMIT+ y LIMIT-)" .

