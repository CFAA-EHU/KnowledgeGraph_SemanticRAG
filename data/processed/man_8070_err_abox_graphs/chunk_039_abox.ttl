ns1:CNC8070_e3122ae069 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:LosEjesMaestroYEsclavoDebenPertenecerAlMismoCanal_788811bea0,
