@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorConfiguracionEjes_39
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error de validación de parámetros máquina (ejes/cabezales)"@es ;
    ex:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal. Por ejemplo, un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema."@es ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Arranque con configuración de usuario inválida"@es ;
        ex:textoExtracto "Al ser imposible arrancar con la configuración del usuario, el CNC arranca con la configuración por defecto."@es
    ] ;
    ex:requiereMantenimiento [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Corrección de parámetros máquina"@es ;
        ex:textoExtracto "Corregir la configuración de parámetros máquina para eliminar el resto de errores y warnings."@es
    ] .

ex:ParametrosEjesCabezales_39
    a               ex:Parametro ;
    rdfs:label      "Parámetros de ejes/cabezales por canal"@es ;
    ex:textoExtracto "parámetros máquina [...] relacionados con los ejes o cabezales de algún canal"@es ;
    ex:monitoreaParametro ex:ErrorConfiguracionEjes_39 .

ex:SistemaCNC_39
    a               ex:Sistema ;
    rdfs:label      "Sistema de control numérico (CNC)"@es ;
    ex:textoExtracto "el CNC arranca con la configuración por defecto"@es ;
    ex:controla     ex:ParametrosEjesCabezales_39 ;
    ex:activaAlarma ex:ErrorConfiguracionEjes_39 .