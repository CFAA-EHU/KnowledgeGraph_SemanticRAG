@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarQueLosEjesDeUnaParejaGantryTenganElMismoTipoDeRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que los ejes de una pareja gantry tengan el mismo tipo de regulador" ;
    ns1:solucionaFallo ns1:AmbosEjesDeUnaParejaGantryNoTienenElMismoTipoDeRegulador ;
    ns1:textoExtracto "SOLUCIÓN Los ejes de una pareja gantry tienen que tener el mismo tipo de regulador (parámetro DRIVETYPE)." .

ns1:AsegurarQueLosEjesOCabezalesEstenAsignadosACanales a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que los ejes o cabezales estén asignados a canales" ;
    ns1:solucionaFallo ns1:UnEjeOCabezalNoIntercambiableNoPuedeQuedarSinAsignarAUnCanal ;
    ns1:textoExtracto "SOLUCIÓN Los cabezales o ejes que no son de intercambio" .

ns1:TipoDeReguladorParaLosEjes a ns1:Parametro ;
    rdfs:label "Tipo de regulador para los ejes" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "(parámetro DRIVETYPE)" .

ns1:AmbosEjesDeUnaParejaGantryNoTienenElMismoTipoDeRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador" ;
    ns1:textoExtracto "CAUSA Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink." .

ns1:UnEjeOCabezalNoIntercambiableNoPuedeQuedarSinAsignarAUnCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje o cabezal no intercambiable no puede quedar sin asignar a un canal" ;
    ns1:textoExtracto "'Un eje o cabezal no intercambiable no puede quedar sin asignar a un canal'" .

