@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_0094
    a                       ex:DiagnosticoFallo ;
    ex:identificador         "0094" ;
    rdfs:label               "Alguno de los canales debe tener el parámetro HIDDENCH = No" ;
    ex:textoExtracto          "0094 'Alguno de los canales debe tener el parámetro HIDDENCH = No' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)." ;
    ex:solucionaFallo         ex:Parametro_HIDDENCH .

ex:Parametro_HIDDENCH
    a                       ex:Parametro ;
    rdfs:label               "HIDDENCH" ;
    ex:textoExtracto          "parámetro HIDDENCH" ;
    ex:valor                  "No" .

ex:DiagnosticoFallo_0095
    a                       ex:DiagnosticoFallo ;
    ex:identificador         "0095" ;
    rdfs:label               "Un eje no puede ser MASTERAXIS de varias parejas de gantrys" ;
    ex:textoExtracto          "0095 'Un eje no puede ser MASTERAXIS de varias parejas de gantrys' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay dos ejes gantry con el mismo eje maestro. SOLUCIÓN Corregir la configuración de ejes gantry." .

ex:DiagnosticoFallo_0096
    a                       ex:DiagnosticoFallo ;
    ex:identificador         "0096" ;
    rdfs:label               "Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro" ;
    ex:textoExtracto          "0096 Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)." ;
    ex:solucionaFallo         ex:Parametro_DRIVETYPE ;
    ex:solucionaFallo         ex:Parametro_OPMODEP .

ex:Parametro_DRIVETYPE
    a                       ex:Parametro ;
    rdfs:label               "DRIVETYPE" ;
    ex:textoExtracto          "parámetros DRIVETYPE" ;
    ex:valor                  "Sercos velocidad" .

ex:Parametro_OPMODEP
    a                       ex:Parametro ;
    rdfs:label               "OPMODEP" ;
    ex:textoExtracto          "parámetros OPMODEP" .

ex:DiagnosticoFallo_0097
    a                       ex:DiagnosticoFallo ;
    ex:identificador         "0097" ;
    rdfs:label               "Par tandem\\gantry eliminado por estar precedido de par vacío" ;
    ex:textoExtracto          "0097 'Par tandem\\gantry eliminado por estar precedido de par vacío' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas. SOLUCIÓN Las parejas de ejes gantry o tándem tienen que ocupar posiciones consecutivas en las tablas." .

ex:DiagnosticoFallo_ParametrosDRV
    a                       ex:DiagnosticoFallo ;
    rdfs:label               "Variables DRV con identificador Sercos (ID), tipo de acceso (TYPE) o modo de acceso (MODE) inconsistentes" ;
    ex:textoExtracto          "Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." ;
    ex:solucionaFallo         ex:Parametro_ID ;
    ex:solucionaFallo         ex:Parametro_TYPE ;
    ex:solucionaFallo         ex:Parametro_MODE .

ex:Parametro_ID
    a                       ex:Parametro ;
    rdfs:label               "ID (Sercos)" ;
    ex:textoExtracto          "identificador Sercos (ID)" .

ex:Parametro_TYPE
    a                       ex:Parametro ;
    rdfs:label               "TYPE" ;
    ex:textoExtracto          "tipo de acceso (TYPE)" .

ex:Parametro_MODE
    a                       ex:Parametro ;
    rdfs:label               "MODE" ;
    ex:textoExtracto          "modo de acceso (MODE)" .