@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeTrazaDeVariablesInternas a ns1:AccionProhibida ;
    rdfs:label "Activación de traza de variables internas" ;
    ns1:textoExtracto "El CNC está ejecutando la traza de una variable interna." .

ns1:ArranqueConUnUnicoCanalDebidoAErroresDetectadosEnParametrosMaquina a ns1:AccionProhibida ;
    rdfs:label "Arranque con un único canal debido a errores detectados en parámetros máquina" ;
    ns1:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal." .

ns1:AsignacionDeCabezalesYEjesACanales a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de cabezales y ejes a canales" ;
    ns1:textoExtracto "Los cabezales o ejes que no son de intercambio (parámetro AXISEXCH) tienen que estar obligatoriamente asignados a un canal." .

ns1:AsociacionDeEjeNoPresenteEnLaListaDelSistema a ns1:AccionProhibida ;
    rdfs:label "Asociación de eje no presente en la lista del sistema" ;
    ns1:textoExtracto "un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:CorreccionDeErroresEnLaValidacionDeParametros a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de errores en la validación de parámetros" ;
    ns1:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal." .

ns1:DefinicionDeEjesDigitales a ns1:TareaMantenimiento ;
    rdfs:label "Definición de ejes digitales" ;
    ns1:textoExtracto "Eliminar las variables de regulador (DRV) definidas o definir los ejes digitales adecuados." .

ns1:DefinicionDeMasVariablesDRVDeLasPermitidas a ns1:AccionProhibida ;
    rdfs:label "Definición de más variables DRV de las permitidas" ;
    ns1:textoExtracto "En la tabla de parámetros OEM hay definidas más variables de regulador (DRV) de las permitidas." .

ns1:DefinicionDeVariableDRVParaEjeNoDigital a ns1:AccionProhibida ;
    rdfs:label "Definición de variable DRV para eje no digital" ;
    ns1:textoExtracto "Hay definida una variable de regulador (DRV) para un eje que no es digital (Sercos/Mechatrolink)." .

ns1:DefinicionDeVariableDRVParaEjeQueNoEsDigital a ns1:AccionProhibida ;
    rdfs:label "Definición de variable DRV para eje que no es digital" ;
    ns1:textoExtracto "Hay definida una variable de regulador (DRV) para un eje que no es digital (Sercos/Mechatrolink)." .

ns1:DefinicionDeVariablesDRVSinEjesDigitales a ns1:AccionProhibida ;
    rdfs:label "Definición de variables DRV sin ejes digitales" ;
    ns1:textoExtracto "En la tabla de parámetros OEM hay definidas variables de regulador (DRV) y no hay ejes digitales (Sercos/Mechatrolink) en el sistema." .

ns1:EliminacionDeVariablesDRVIncorrectas a ns1:TareaMantenimiento ;
    rdfs:label "Eliminación de variables DRV incorrectas" ;
    ns1:textoExtracto "Eliminar la variable de ese eje." .

ns1:IntercambioDeCabezalSinCanalAsignado a ns1:AccionProhibida ;
    rdfs:label "Intercambio de cabezal sin canal asignado" ;
    ns1:textoExtracto "Hay un eje o cabezal sin permiso de intercambio que no está asignado a ningún canal." .

ns1:LimiteDeVariablesDRVEnLaTablaDeParametros a ns1:TareaMantenimiento ;
    rdfs:label "Límite de variables DRV en la tabla de parámetros" ;
    ns1:textoExtracto "En la tabla de parámetros OEM puede haber 100 variables de regulador." .

ns1:NumeroMaximoDeVariablesDRVSobrepasado a ns1:AccionProhibida ;
    rdfs:label "Número máximo de variables DRV sobrepasado" ;
    ns1:textoExtracto "En la tabla de parámetros OEM hay definidas más variables de regulador (DRV) de las permitidas." .

ns1:PonerseEnContactoConFagor a ns1:TareaMantenimiento ;
    rdfs:label "Ponerse en contacto con Fagor" ;
    ns1:textoExtracto "Póngase en contacto con Fagor." .

ns1:VariablesDeReguladorSinEjesDigitalesDefinidos a ns1:AccionProhibida ;
    rdfs:label "Variables de regulador sin ejes digitales definidos" ;
    ns1:textoExtracto "En la tabla de parámetros OEM hay definidas variables de regulador (DRV) y no hay ejes digitales (Sercos/Mechatrolink) en el sistema." .

ns1:VerificacionDeLaListaDeEjesDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de la lista de ejes del sistema" ;
    ns1:textoExtracto "un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema." .

