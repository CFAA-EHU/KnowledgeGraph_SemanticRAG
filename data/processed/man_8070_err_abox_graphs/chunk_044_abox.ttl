@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9d0bf19613 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de configuración por defecto" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Se arranca con la configuración de ejes por defecto debido a errores en parámetros máquina'" .

ns1:CorreccionDeConfiguracionDeParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de configuración de parámetros máquina" ;
    ns1:solucionaFallo ns1:FalloParametrosMaquina ;
    ns1:textoExtracto "Corregir la configuración de parámetros máquina para eliminar el resto de errores y warnings." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:FalloParametrosMaquina a ns1:DiagnosticoFallo ;
    rdfs:label "Errores o warnings en parámetros máquina" ;
    ns1:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejaes o cabezales de algún canal." .

