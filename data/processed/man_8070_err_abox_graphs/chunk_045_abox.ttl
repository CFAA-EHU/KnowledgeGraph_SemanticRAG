@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDeAcceso_11d37ee2ef a ns1:Parametro ;
    rdfs:label "modo de acceso" ;
    ns1:textoExtracto "diferente modo de acceso (lectura o escritura)" .

ns1:TipoDeAcceso a ns1:Parametro ;
    rdfs:label "tipo de acceso" ;
    ns1:textoExtracto "diferente tipo de acceso (síncrono o asíncrono)" .

ns1:VariablesDRVConIgualIdentificadorIDNoPuedenTenerDiferenteMODEOTYPE a ns1:AccionProhibida ;
    rdfs:label "Variables DRV con igual identificador (ID) no pueden tener diferente MODE o TYPE" ;
    ns1:solucionaFallo ns1:DeteccionDuranteLaValidacionDeLosParametrosMaquina ;
    ns1:textoExtracto "'Variables DRV con igual identificador (ID) no pueden tener diferente MODE o TYPE'" .

ns1:VariablesDRVConIgualIdentificadorIDNoPuedenTenerDiferenteMnemonico a ns1:AccionProhibida ;
    rdfs:label "Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico" ;
    ns1:solucionaFallo ns1:DeteccionDuranteLaValidacionDeLosParametrosMaquina ;
    ns1:textoExtracto "'Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico'" .

ns1:DeteccionDuranteLaValidacionDeLosParametrosMaquina a ns1:DiagnosticoFallo ;
    rdfs:label "Detección durante la validación de los parámetros máquina" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina." .

