@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDeAcceso_d8344cdcec a ns1:Parametro ;
    rdfs:label "Modo de acceso" ;
    ns1:textoExtracto "(parámetro MODE)" .

ns1:TipoDeAcceso_ce2edc48f2 a ns1:Parametro ;
    rdfs:label "Tipo de acceso" ;
    ns1:textoExtracto "(parámetro TYPE)" .

ns1:ValidacionDeLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Validación de los parámetros máquina" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:VariablesDRVConIgualNombreMNEMONICNoPuedenTenerDiferenteIDMODEOTYPE a ns1:DiagnosticoFallo ;
    rdfs:label "Variables DRV con igual nombre (MNEMONIC) no pueden tener diferente ID, MODE o TYPE" ;
    ns1:solucionaFallo ns1:SolucionParaVariablesDRVInconsistentes ;
    ns1:textoExtracto "'Variables DRV con igual nombre (MNEMONIC) no pueden tener diferente ID, MODE o TYPE'" .

ns1:SolucionParaVariablesDRVInconsistentes a ns1:TareaMantenimiento ;
    rdfs:label "Solución para variables DRV inconsistentes" ;
    ns1:textoExtracto "Las variables DRV con el mismo identificador deben tener el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

