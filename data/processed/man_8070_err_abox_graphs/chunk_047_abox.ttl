@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DosEjesGantryConElMismoEjeMaestro a ns1:DiagnosticoFallo ;
    rdfs:label "Dos ejes gantry con el mismo eje maestro" ;
    ns1:textoExtracto "'Un eje no puede ser MASTERAXIS de varias parejas de gantrys' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay dos ejes gantry con el mismo eje maestro. SOLUCIÓN Corregir la configuración de ejes gantry." .

ns1:EjesTandemNoSonSercosVelocidad a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes tandem no son Sercos velocidad" ;
    ns1:textoExtracto "'Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)." .

ns1:IdentificadorSercos a ns1:Parametro ;
    rdfs:label "Identificador Sercos" ;
    ns1:textoExtracto "'diferente ID, MODE o TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

ns1:ModoDeAcceso_59b929b299 a ns1:Parametro ;
    rdfs:label "Modo de acceso" ;
    ns1:textoExtracto "'diferente ID, MODE o TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

ns1:ModoOperativoDelDriver a ns1:Parametro ;
    rdfs:label "Modo operativo del driver" ;
    ns1:textoExtracto "'Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)." .

ns1:ParametroHIDDENCH a ns1:Parametro ;
    rdfs:label "Parámetro HIDDENCH" ;
    ns1:textoExtracto "'Alguno de los canales debe tener el parámetro HIDDENCH = No' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)." .

ns1:ParametrosMaquinaConElMismoMnemonicoYDiferentesIDTYPEOMODE a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetros máquina con el mismo mnemónico y diferentes ID, TYPE o MODE" ;
    ns1:textoExtracto "'diferente ID, MODE o TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

ns1:ParejasDeEjesGantryOTandemNoOcupanPosicionesConsecutivas a ns1:DiagnosticoFallo ;
    rdfs:label "Parejas de ejes gantry o tandem no ocupan posiciones consecutivas" ;
    ns1:textoExtracto "'Par tandem\\gantry eliminado por estar precedido de par vacío' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas. SOLUCIÓN Las parejas de ejes gantry o tándem tienen que ocupar posiciones consecutivas en las tablas." .

ns1:TipoDeAcceso_ac595f4aad a ns1:Parametro ;
    rdfs:label "Tipo de acceso" ;
    ns1:textoExtracto "'diferente ID, MODE o TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

ns1:TipoDeDriver a ns1:Parametro ;
    rdfs:label "Tipo de driver" ;
    ns1:textoExtracto "'Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)." .

ns1:TodosLosCanalesDelSistemaEstanDefinidosComoOcultos a ns1:DiagnosticoFallo ;
    rdfs:label "Todos los canales del sistema están definidos como ocultos" ;
    ns1:textoExtracto "'Alguno de los canales debe tener el parámetro HIDDENCH = No' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)." .

