@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDePosicionesDeEjesGantryOTandem a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de posiciones de ejes gantry o tándem" ;
    ns1:solucionaFallo ns1:EjesGantryOTandemNoOcupanPosicionesConsecutivasEnLasTablas ;
    ns1:textoExtracto "Las parejas de ejes gantry o tándem tienen que ocupar posiciones consecutivas en las tablas." .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISEXCH" ;
    ns1:textoExtracto "'El eje maestro y el esclavo tienen diferente parámetro AXISEXCH'" .

ns1:ValidacionDePosicionesConsecutivasEnTablas a ns1:AvisoSeguridad ;
    rdfs:label "Validación de posiciones consecutivas en tablas" ;
    ns1:mitigaRiesgo ns1:ExistenciaDeHuecosOPosicionesSinAsignarEnLasTablas ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina, se debe asegurar que no existan huecos o posiciones sin asignar." .

ns1:EjesGantryOTandemNoOcupanPosicionesConsecutivasEnLasTablas a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes gantry o tándem no ocupan posiciones consecutivas en las tablas" ;
    ns1:textoExtracto "Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas." .

ns1:ExistenciaDeHuecosOPosicionesSinAsignarEnLasTablas a ns1:AccionProhibida ;
    rdfs:label "Existencia de huecos o posiciones sin asignar en las tablas" ;
    ns1:textoExtracto "Si existe un hueco en la tabla, es decir una posición sin asignar, el CNC anula las parejas definidas a continuación." .

