@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarMismoValorAlParametroAXISEXCH a ns1:TareaMantenimiento ;
    rdfs:label "asignar mismo valor al parámetro AXISEXCH" ;
    ns1:solucionaFallo ns1:DiferenteValorDeAXISEXCH ;
    ns1:textoExtracto "SOLUCIÓN Asignar el mismo valor al parámetro AXISEXCH de ambos ejes." .

ns1:CNC8070_8dd73e6893 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:DiferenteValorDeAXISEXCH,
        ns1:ValorDePROBEFEEDDemasiadoAlto ;
    ns1:textoExtracto "el CNC anula las parejas definidas a continuación" .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    rdfs:label "parámetro AXISEXCH" ;
    ns1:textoExtracto "'El eje maestro y el esclavo tienen diferente parámetro AXISEXCH'" .

ns1:ParametroPROBEFEED a ns1:Parametro ;
    rdfs:label "parámetro PROBEFEED" ;
    ns1:textoExtracto "'EL valor del PROBEFEED es demasiado alto para frenar respetando DECEL y JERK'" .

ns1:ValorDePROBEFEEDDemasiadoAlto a ns1:DiagnosticoFallo ;
    rdfs:label "valor de PROBEFEED demasiado alto" ;
    ns1:textoExtracto "El avance máximo de palpado (parámetro PROBEFEED) es superior al avance necesario para frenar en el espacio definido en PROBERANGE, respetando los valores de aceleración y de jerk del eje." .

ns1:DiferenteValorDeAXISEXCH a ns1:DiagnosticoFallo ;
    rdfs:label "diferente valor de AXISEXCH" ;
    ns1:textoExtracto "Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen el parámetro AXISEXCH con diferente valor." .

