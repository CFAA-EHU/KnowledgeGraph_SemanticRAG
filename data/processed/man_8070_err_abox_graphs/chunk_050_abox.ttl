@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error0104TimeOutDeComunicacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0104 Time out de comunicación" ;
    ns1:textoExtracto "'Time out de comunicación' DETECCIÓN Durante la ejecución." .

ns1:PongaseEnContactoConSuProveedor_cc752e5200 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con su proveedor" ;
    ns1:solucionaFallo ns1:Error0100DemasiadasVariablesEsperandoSerReportadas ;
    ns1:textoExtracto "SOLUCIÓN Si el error persiste, póngase en contacto con su proveedor." .

ns1:RevisarParametrosMaquinaYReiniciarCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros máquina y reiniciar CNC" ;
    ns1:solucionaFallo ns1:Error0103ValidacionDeParametrosMaquinaNoFinalizadaTimeout ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina que han provocado el bloqueo (si se conocen) o reiniciar el CNC." .

ns1:Error0100DemasiadasVariablesEsperandoSerReportadas a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0100 Demasiadas variables esperando ser reportadas" ;
    ns1:textoExtracto "'Demasiadas variables esperando ser reportadas' DETECCIÓN Durante la ejecución. CAUSA El número de variables modificadas en el CNC y que hay que reportar hacia el interface supera el máximo permitido." .

ns1:Error0103ValidacionDeParametrosMaquinaNoFinalizadaTimeout a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0103 Validación de parámetros máquina no finalizada (timeout)" ;
    ns1:textoExtracto "'Validación de parámetros máquina no finalizada (timeout)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La parametrización ha producido un bloqueo en la validación de parámetros máquina." .

