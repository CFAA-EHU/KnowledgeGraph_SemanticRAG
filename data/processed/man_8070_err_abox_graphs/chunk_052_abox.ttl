@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_a1ae095f97 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de no validación de parámetros" ;
    ns1:mitigaRiesgo ns1:FalloValidacionParametros ;
    ns1:textoExtracto "'No es posible validar parámetros: Cabezal o eje movimiento o en sincronización'" .

ns1:DetenerElMovimientoDelEjeOCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Detener el movimiento del eje o cabezal" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:solucionaFallo ns1:FalloValidacionParametros ;
    ns1:textoExtracto "SOLUCIÓN Detener el movimiento del eje o cabezal." .

ns1:FalloRegistroVariablesDRV a ns1:DiagnosticoFallo ;
    rdfs:label "Error al registrar variables DRV" ;
    ns1:textoExtracto "El CNC ha generado un error al intentar registrar las variables definidas en la tabla de parámetros OEM." .

ns1:FalloValidacionParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Error al validar parámetros máquina" ;
    ns1:textoExtracto "El usuario ha intentado validar una tabla de parámetros máquina mientras hay un programa pieza en ejecución o interrumpido, o hay un movimiento independiente en ejecución." .

