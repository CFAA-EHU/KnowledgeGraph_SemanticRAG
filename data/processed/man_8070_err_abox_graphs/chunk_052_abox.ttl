@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0125
    a ex:Alarma ;
    rdfs:label "Alarma 0125: Valor leído de fichero no válido" ;
    ex:textoExtracto "0125 Valor leído de fichero no válido." ;
    ex:identificador "0125" .

ex:DiagnosticoFallo_0125_CoresInvalidos
    a ex:DiagnosticoFallo ;
    rdfs:label "Código de validación de cores inválido" ;
    ex:textoExtracto "El número de cores definido en el código de validación no es válido para ese hardware." ;
    ex:activaAlarma ex:Alarma_0125 ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Autogeneración de código de validación" ;
        ex:textoExtracto "Póngase en contacto con Fagor para obtener un código de validación válido."
    ] .

ex:Empresa_Fagor
    a ex:Empresa ;
    rdfs:label "Fagor" ;
    ex:textoExtracto "Póngase en contacto con Fagor para obtener un código de validación válido." .