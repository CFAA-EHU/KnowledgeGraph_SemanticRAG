@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0125
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0125: Valor leído de fichero no válido" ;
    ex:textoExtracto "0125 Valor leído de fichero no válido. DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado datos incorrectos en el archivo que está cargando; por ejemplo, al cargar los datos de calibración no-lineal del gap (#LOAD). SOLUCIÓN Definir los datos correctamente. Consultar en la ventana de error los valores máximo y mínimo." ;
    ex:identificador "0125" .

ex:Error_0126
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0126: Lectura/escritura de variable no finalizada (timeout)" ;
    ex:textoExtracto "0126 Lectura/escritura de variable no finalizada (timeout). DETECCIÓN Durante la ejecución. CAUSA Se ha superado el tiempo mínimo de espera asignado al proceso de lectura/escritura de la variable. SOLUCIÓN Resetear el error. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." ;
    ex:identificador "0126" .

ex:Error_0127
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0127: Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD" ;
    ex:textoExtracto "0127 Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC. CAUSA Alguno de los dispositivos SercosIII no es válido para esta versión de PLD. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "0127" .

ex:Error_0128
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0128: Error en grabación PLD dispositivo S3, fichero de versión PLD no válido" ;
    ex:textoExtracto "0128 Error en grabación PLD dispositivo S3, fichero de versión PLD no válido. DETECCIÓN Durante el arranque del CNC. CAUSA La versión de PLD del CNC no es válida para el dispositivo SercosIII. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "0128" .

ex:Error_0129
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0129: Dispositivo inválido" ;
    ex:textoExtracto "0129 Dispositivo inválido. DETECCIÓN Durante la ejecución. CAUSA El dispositivo asociado a la variable de regulador que se quiere leer o escribir no es válido. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "0129" .

ex:Error_0130
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0130: EtherCAT no disponible" ;
    ex:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "0130" .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation." .