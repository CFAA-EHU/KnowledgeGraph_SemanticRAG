@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_978c314f69 a ns1:AccionProhibida ;
    rdfs:label "Acción de reset del sistema" ;
    ns1:textoExtracto "El CNC no admite este tipo de acciones con cabezales sincronizados activos, ya que implican un reset del sistema." .

ns1:CNC8070_9a4fdadeff a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:solucionaFallo ns1:ValidacionDeParametrosOCompilacionDelProgramaPLCDebeSerPreviaALaSincronizacion ;
    ns1:textoExtracto "CNC 8070" .

ns1:ValidacionDeParametrosOCompilacionDelProgramaPLCDebeSerPreviaALaSincronizacion a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros o compilación del programa PLC debe ser previa a la sincronización" ;
    ns1:textoExtracto "La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización." .

