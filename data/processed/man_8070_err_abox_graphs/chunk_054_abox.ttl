@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0130_EtherCAT_NoDisponible
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0130: EtherCAT no disponible"@es ;
    ex:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo."@es ;
    ex:identificador "0130" ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Contactar con Fagor Automation (error 0130)"@es ;
        ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es
    ] .

ex:Error_0131_LecturaVariableRegulador
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ex:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución."@es ;
    ex:identificador "0131" ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Contactar con Fagor Automation (error 0131)"@es ;
        ex:textoExtracto "Póngase en contacto con Fagor Automation."@es
    ] .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation."@es .