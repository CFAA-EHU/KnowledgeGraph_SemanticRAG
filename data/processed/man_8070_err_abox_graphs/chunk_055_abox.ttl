@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalizarYCorregirErroresEnCinematica a ns1:TareaMantenimiento ;
    rdfs:label "Analizar y corregir errores en cinemática" ;
    ns1:solucionaFallo ns1:ErrorEnLaInicializacionDeDatosDeLaCinematicaDeUsuario,
        ns1:ErrorEnLaInicializacionDeLaCinematicaDeUsuario,
        ns1:ErrorEnLaInicializacionDeParametrosDeLaCinematicaDeUsuario ;
    ns1:textoExtracto "SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:ComprobarMakeDeCinematica a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar make de cinemática" ;
    ns1:solucionaFallo ns1:NoSePudoCargarLaCinematicaDeUsuario ;
    ns1:textoExtracto "SOLUCIÓN Compruebe que al hacer el make de cinemática de usuario no se producen errores y que el driver kinematic.sys se genera correctamente." .

ns1:DetenerSimulacionParaValidarParametros_994995ac8d a ns1:TareaMantenimiento ;
    rdfs:label "Detener simulación para validar parámetros" ;
    ns1:solucionaFallo ns1:NoEsPosibleValidarParametrosDuranteLaSimulacionDeUnProgramaEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:ErrorEnLaInicializacionDeDatosDeLaCinematicaDeUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de datos de la cinemática de usuario" ;
    ns1:textoExtracto "'Error en la inicialización de datos de la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la función de inicialización y carga de datos de la cinemática de usuario (UserTransforDataInit) implementada en el fichero Kin_iniData.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:ErrorEnLaInicializacionDeLaCinematicaDeUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de la cinemática de usuario" ;
    ns1:textoExtracto "'Error en la inicialización de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:ErrorEnLaInicializacionDeParametrosDeLaCinematicaDeUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de parámetros de la cinemática de usuario" ;
    ns1:textoExtracto "'Error en la inicialización de parámetros de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforParamInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:NoEsPosibleValidarParametrosDuranteLaSimulacionDeUnProgramaEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible validar parámetros durante la simulación de un programa en el canal" ;
    ns1:textoExtracto "No es posible validar parámetros durante la simulación de un programa en el canal. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar los parámetros durante la simulación de un programa. SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:NoSePudoCargarLaCinematicaDeUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "No se pudo cargar la cinemática de usuario" ;
    ns1:textoExtracto "'No se pudo cargar la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no encuentra el fichero c:\\FagorCNC\\drivers\\kinematic.sys (o c:\\Cnc8070\\drivers\\kinematic.sys). SOLUCIÓN Compruebe que al hacer el make de cinemática de usuario no se producen errores y que el driver kinematic.sys se genera correctamente." .

