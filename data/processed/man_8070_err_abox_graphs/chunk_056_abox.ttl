@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_0151
    a ex:DiagnosticoFallo ;
    rdfs:label "Acceso de escritura denegado" ;
    ex:identificador "0151" ;
    ex:textoExtracto "0151 'Acceso de escritura denegado' [...] El CNC ha intentado escribir en un archivo que no tiene permiso de escritura." .

ex:Fallo_0152
    a ex:DiagnosticoFallo ;
    rdfs:label "No se puede abrir el fichero" ;
    ex:identificador "0152" ;
    ex:textoExtracto "0152 'No se puede abrir el fichero' [...] DETECCIÓN Al acceder a un archivo." .

ex:Archivo_cncWrite
    a ex:InterfazUsuario ;
    rdfs:label "cncWrite.txt" ;
    ex:textoExtracto "SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." .