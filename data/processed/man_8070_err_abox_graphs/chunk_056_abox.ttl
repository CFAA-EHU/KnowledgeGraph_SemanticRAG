@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetenerLaSimulacionDelProgramaParaValidarLosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Detener la simulación del programa para validar los parámetros" ;
    ns1:textoExtracto "SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:ValidarParametrosDuranteLaSimulacionDeUnPrograma a ns1:AccionProhibida ;
    rdfs:label "Validar parámetros durante la simulación de un programa" ;
    ns1:solucionaFallo ns1:CodigoDeValidacionTipoDeCPUNOCoherenteConEl ;
    ns1:textoExtracto "No es posible validar parámetros durante la simulación de un programa en el canal." .

ns1:CodigoDeValidacionTipoDeCPUNOCoherenteConEl a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación -tipo de CPU- NO coherente con el" ;
    ns1:textoExtracto "Código de validación -tipo de CPU-, NO coherente con el" .

