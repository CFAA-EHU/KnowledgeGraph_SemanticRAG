@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarElNombreYContenidoDeLaTablaSiLaTablaExisteReiniciarElCNC a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar el nombre y contenido de la tabla. Si la tabla existe, reiniciar el CNC." ;
    ns1:mitigaRiesgo ns1:ErrorAlLeerLaTablaTecnologica ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el nombre y contenido de la tabla. Si la tabla existe, reiniciar el CNC." .

ns1:DetenerSimulacionParaValidarParametros a ns1:AvisoSeguridad ;
    rdfs:label "Detener simulación para validar parámetros" ;
    ns1:mitigaRiesgo ns1:ValidacionDeParametrosDuranteSimulacionDelPrograma ;
    ns1:textoExtracto "SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:ElCNCInformaDeLaActualizacionNoEsNecesariaNingunaAccion a ns1:AvisoSeguridad ;
    rdfs:label "El CNC informa de la actualización; no es necesaria ninguna acción" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción." .

ns1:PongaseEnContactoConFagorParaObtenerUnCodigoDeValidacionValido a ns1:AvisoSeguridad ;
    rdfs:label "Póngase en contacto con Fagor para obtener un código de validación válido" ;
    ns1:mitigaRiesgo ns1:CodigoDeValidacionTipoDeCPUNoCoherenteConElHardware,
        ns1:NumeroDeCoresDefinidosEnElCodigoDeValidacionNoCoherenteConElHardware ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:ReiniciarElCNC_f5a16b6922 a ns1:AvisoSeguridad ;
    rdfs:label "Reiniciar el CNC" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC." .

ns1:SiElErrorPersistePongaseEnContactoConFagorAutomation a ns1:AvisoSeguridad ;
    rdfs:label "Si el error persiste, póngase en contacto con Fagor Automation" ;
    ns1:mitigaRiesgo ns1:NoHayHardwareDeSERCOSIIIOErrorEnLaCargaDelDriver ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:CodigoDeValidacionTipoDeCPUNoCoherenteConElHardware a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación -tipo de CPU- no coherente con el hardware" ;
    ns1:textoExtracto "0115 Código de validación -tipo de CPU-, NO coherente con el hardware." .

ns1:ErrorAlLeerLaTablaTecnologica a ns1:DiagnosticoFallo ;
    rdfs:label "Error al leer la tabla tecnológica" ;
    ns1:textoExtracto "'Error al leer la tabla tecnológica'" .

ns1:NoHayHardwareDeSERCOSIIIOErrorEnLaCargaDelDriver a ns1:DiagnosticoFallo ;
    rdfs:label "No hay hardware de SERCOS III o error en la carga del driver" ;
    ns1:textoExtracto "0118 No hay hardware de SERCOS III o error en la carga del driver." .

ns1:NumeroDeCoresDefinidosEnElCodigoDeValidacionNoCoherenteConElHardware a ns1:DiagnosticoFallo ;
    rdfs:label "Número de cores definidos en el código de validación no coherente con el hardware" ;
    ns1:textoExtracto "0117 El número de cores definidos en el código de validación NO es coherente con el hardware." .

ns1:ValidacionDeParametrosDuranteSimulacionDelPrograma a ns1:AccionProhibida ;
    rdfs:label "Validación de parámetros durante simulación del programa" ;
    ns1:textoExtracto "validar los parámetros durante la simulación de un programa." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

