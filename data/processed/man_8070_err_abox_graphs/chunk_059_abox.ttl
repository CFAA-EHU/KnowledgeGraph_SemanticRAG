@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaContactoFagorAutomation a ns1:AccionProhibida ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:CNC8070_8da2c8320e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:solucionaFallo ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3CheksumError_f984292951,
        ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3FAILED_1cc47b7e94,
        ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3S3ConnectFAILED_a96c2c605a ;
    ns1:textoExtracto "CNC 8070" .

ns1:NoEsPosibleValidarCambioDeParametroMaquina_3936c46ce3 a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible validar cambio de parámetro máquina" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no puede validar los parámetros máquina porque no ha terminado de arrancar." .

ns1:PongaseEnContactoConFagorAutomation_a864d4b557 a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ElNumeroDeCoresDefinidosEnElCodigoDeValidacionNOEsCoherenteConElHardware_01f646f6ce ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:ElNumeroDeCoresDefinidosEnElCodigoDeValidacionNOEsCoherenteConElHardware_01f646f6ce a ns1:DiagnosticoFallo ;
    rdfs:label "El número de cores definidos en el código de validación NO es coherente con el hardware" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware." .

ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3CheksumError_f984292951 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III." .

ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3FAILED_1cc47b7e94 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III." .

ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosConectadosASERCOS3S3ConnectFAILED_a96c2c605a a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III." .

