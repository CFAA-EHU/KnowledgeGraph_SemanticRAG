@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_APPEND
    a ex:AccionProhibida ;
    rdfs:label "Comando 'A' (APPEND)" ;
    ex:textoExtracto "Al abrir un archivo con el comando 'A' (APPEND), el comando TYPE debe coincidir con el formato del archivo." ;
    ex:identificador "A" .

ex:Comando_DELETE
    a ex:AccionProhibida ;
    rdfs:label "Comando 'D' (DELETE)" ;
    ex:textoExtracto "Abrir un archivo con el comando 'D' (DELETE)." ;
    ex:identificador "D" .

ex:Parametro_TYPE
    a ex:Parametro ;
    rdfs:label "Comando TYPE" ;
    ex:textoExtracto "el comando TYPE debe coincidir con el formato del archivo." ;
    ex:identificador "TYPE" .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "el CNC crea uno nuevo en el formato especificado en el comando TYPE." ;
    ex:controla ex:Comando_APPEND ;
    ex:controla ex:Comando_DELETE .