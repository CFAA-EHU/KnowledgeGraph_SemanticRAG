@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:DefinirLosDatosCorrectamente a ns1:AccionProhibida ;
    rdfs:label "Definir los datos correctamente" ;
    ns1:solucionaFallo ns1:ValorLeidoDeFicheroNoValido ;
    ns1:textoExtracto "SOLUCIÓN Definir los datos correctamente. Consultar en la ventana de error los valores máximo y mínimo." .

ns1:ErrorEnGrabacionPLDDispositivoS3DispositivoNoValidoParaVersionPLD_d98a37ee84 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD" ;
    ns1:textoExtracto "0127 Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC." .

ns1:PongaseEnContactoConFagorAutomation_ce0080fdcd a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:LecturaEscrituraDeVariableNoFinalizadaTimeout ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:PongaseEnContactoConFagorParaObtenerUnCodigoDeValidacionValido_0007c3d0b0 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor para obtener un código de validación válido" ;
    ns1:solucionaFallo ns1:CodigoDeValidacionNoEsValidoParaEseHardware ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:ResetearElError a ns1:AccionProhibida ;
    rdfs:label "Resetear el error" ;
    ns1:solucionaFallo ns1:LecturaEscrituraDeVariableNoFinalizadaTimeout ;
    ns1:textoExtracto "SOLUCIÓN Resetear el error. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:CodigoDeValidacionNoEsValidoParaEseHardware a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación no es válido para ese hardware" ;
    ns1:textoExtracto "el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:ValorLeidoDeFicheroNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Valor leído de fichero no válido" ;
    ns1:textoExtracto "0125 Valor leído de fichero no válido. DETECCIÓN Durante la ejecución." .

ns1:LecturaEscrituraDeVariableNoFinalizadaTimeout a ns1:DiagnosticoFallo ;
    rdfs:label "Lectura/escritura de variable no finalizada (timeout)" ;
    ns1:textoExtracto "0126 Lectura/escritura de variable no finalizada (timeout). DETECCIÓN Durante la ejecución." .

