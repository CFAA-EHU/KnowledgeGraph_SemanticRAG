ns1:CNC8070_d2c0f05568 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:DispositivoInvalido,
        ns1:ErrorEnGrabacionPLDDispositivoS3DispositivoNoValidoParaVersionPLD,
        ns1:ErrorEnGrabacionPLDDispositivoS3FicheroDeVersionPLDNoValido ;
    ns1:textoExtracto "CNC 8070" .

ns1:PongaseEnContactoConFagorAutomation_98c1273348 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:RepasarLosParametrosAsociadosALaVariableEnLaTablaDRV ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:DispositivoInvalido a ns1:Alarma ;
    rdfs:label "Dispositivo inválido" ;
    ns1:textoExtracto "0129 Dispositivo inválido. DETECCIÓN Durante la ejecución." .

ns1:ErrorEnGrabacionPLDDispositivoS3DispositivoNoValidoParaVersionPLD a ns1:Alarma ;
    rdfs:label "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD" ;
