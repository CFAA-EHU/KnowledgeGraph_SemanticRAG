ns1:ErrorEnGrabacionPLDDispositivoS3FicheroDeVersionPLDNoValido a ns1:Alarma ;
    rdfs:label "Error en grabación PLD dispositivo S3, fichero de versión PLD no válido" ;
    ns1:textoExtracto "0128 Error en grabación PLD dispositivo S3, fichero de versión PLD no válido. DETECCIÓN Durante el arranque del CNC." .

ns1:RepasarLosParametrosAsociadosALaVariableEnLaTablaDRV a ns1:DiagnosticoFallo ;
    rdfs:label "Repasar los parámetros asociados a la variable en la tabla DRV" ;
    ns1:textoExtracto "Si el error se ha generado en la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla." .

