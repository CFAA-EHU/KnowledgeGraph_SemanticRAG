@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_OverTemp
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de sobretemperatura (OVERTEMP)" ;
    ex:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo; si en tres muestras seguidas la temperatura supera los 60ºC (140ºF), el CNC muestra este aviso y activa la marca OVERTEMP. El warning muestra la temperatura actual." ;
    ex:activaAlarma ex:Alarma_OverTemp .

ex:Alarma_OverTemp
    a ex:Alarma ;
    rdfs:label "Alarma de sobretemperatura (OVERTEMP)" ;
    ex:textoExtracto "El CNC muestra este aviso y activa la marca OVERTEMP." .

ex:Sensor_TemperaturaAmbiente
    a ex:Sensor ;
    rdfs:label "Sensor de temperatura ambiente" ;
    ex:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo" ;
    ex:monitoreaParametro ex:Parametro_TemperaturaAmbiente .

ex:Parametro_TemperaturaAmbiente
    a ex:Parametro ;
    rdfs:label "Temperatura ambiente del equipo" ;
    ex:valor "60" ;
    ex:textoExtracto "si en tres muestras seguidas la temperatura supera los 60ºC (140ºF)" .

ex:Sistema_Refrigeracion
    a ex:Sistema ;
    rdfs:label "Sistema de refrigeración del hardware" ;
    ex:textoExtracto "La causa del aumento de temperatura puede ser un fallo en el sistema de refrigeración del hardware" ;
    ex:tieneComponente ex:Componente_VentiladorCPU .

ex:Componente_VentiladorCPU
    a ex:ComponenteElectrico ;
    rdfs:label "Ventilador de la CPU" ;
    ex:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado. Cuando la CPU dispone de ventilador, durante el régimen normal de funcionamiento del CNC, éste monitoriza y vigila que dicho ventilador esté en marcha." ;
    ex:mitigaRiesgo ex:Alarma_OverTemp .

ex:AvisoSeguridad_0170
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 'Tensión de pila baja' (0170)" ;
    ex:identificador "0170" ;
    ex:textoExtracto "0170 'Tensión de pila baja' [...] La pila está descargada; ha terminado su ciclo de vida útil." .

ex:Componente_PilaCNC
    a ex:ComponenteElectrico ;
    rdfs:label "Pila del CNC" ;
    ex:textoExtracto "La pila está descargada; ha terminado su ciclo de vida útil. Cuando el CNC está apagado, la pila se encarga de mantener datos necesarios para el CNC (por ejemplo, las cotas)." .

ex:AvisoSeguridad_0171
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 'Sobrepasamiento del LOOPTIME' (0171)" ;
    ex:identificador "0171" ;
    ex:textoExtracto "0171 'Sobrepasamiento del LOOPTIME' [...] Las interrupciones de tiempo real superan el tiempo permitido." .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "Parámetro LOOPTIME" ;
    ex:identificador "LOOPTIME" ;
    ex:textoExtracto "puede ser necesario tener que ajustar el parámetro LOOPTIME." .

ex:AvisoSeguridad_0172
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 'Ventilador de la CPU parado' (0172)" ;
    ex:identificador "0172" ;
    ex:textoExtracto "0172 Ventilador de la cpu parado. Riesgo de sobretemperatura. [...] El CNC ha detectado que el ventilador de la CPU está parado." .