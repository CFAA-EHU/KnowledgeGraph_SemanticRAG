@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OPENHandleDeFicheroEnUso a ns1:DiagnosticoFallo ;
    rdfs:label "#OPEN: handle de fichero en uso" ;
    ns1:textoExtracto "0150 #OPEN: handle de fichero en uso. DETECCIÓN Durante la ejecución." .

ns1:PongaseEnContactoConFagorAutomation_98c1273348 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:RepasarLosParametrosAsociadosALaVariableEnLaTablaDRV_c0d9cbb3fb a ns1:TareaMantenimiento ;
    rdfs:label "Repasar los parámetros asociados a la variable en la tabla DRV" ;
    ns1:solucionaFallo ns1:ErrorEnLaEscrituraDeVariableDeRegulador,
        ns1:ErrorEnLaLecturaDeVariableDeRegulador ;
    ns1:textoExtracto "Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla." .

ns1:ErrorEnLaEscrituraDeVariableDeRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la escritura de variable de regulador" ;
    ns1:textoExtracto "0132 Error en la escritura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de escritura de las variables del regulador ha generado error." .

ns1:ErrorEnLaLecturaDeVariableDeRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la lectura de variable de regulador" ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las variables del regulador ha generado error." .

