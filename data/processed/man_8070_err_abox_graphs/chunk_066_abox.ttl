@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_bb843c1644 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para acceso a archivos" ;
    ns1:mitigaRiesgo ns1:AccesoDeEscrituraDenegado ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." .

ns1:DarAlFicheroPermisoDeEscritura a ns1:TareaMantenimiento ;
    rdfs:label "Dar al fichero permiso de escritura" ;
    ns1:solucionaFallo ns1:AccesoDeEscrituraDenegado_592ef7729a ;
    ns1:textoExtracto "SOLUCIÓN Dar al fichero permiso de escritura." .

ns1:NoSePuedeAbrirElFichero a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede abrir el fichero" ;
    ns1:textoExtracto "'No se puede abrir el fichero' DETECCIÓN Al acceder a un archivo." .

ns1:AccesoDeEscrituraDenegado a ns1:AccionProhibida ;
    rdfs:label "Acceso de escritura denegado" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." .

ns1:AccesoDeEscrituraDenegado_592ef7729a a ns1:DiagnosticoFallo ;
    rdfs:label "Acceso de escritura denegado" ;
    ns1:textoExtracto "'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura." .

