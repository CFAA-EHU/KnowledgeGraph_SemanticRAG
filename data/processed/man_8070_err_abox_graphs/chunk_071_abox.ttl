@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionParaAbrirArchivoConComandoA a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para abrir archivo con comando A" ;
    ns1:textoExtracto "Al abrir un archivo con el comando \"A\" (APPEND), el comando TYPE debe coincidir con el formato del archivo. Si el archivo no existe, el CNC crea uno nuevo en el formato especificado en el comando TYPE." .

ns1:SolucionParaAbrirArchivoConComandoD a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para abrir archivo con comando D" ;
    ns1:textoExtracto "Abrir un archivo con el comando \"D\" (DELETE)." .

