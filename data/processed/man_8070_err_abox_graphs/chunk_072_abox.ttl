@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarParametroLOOPTIME a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar parámetro LOOPTIME" ;
    ns1:solucionaFallo ns1:InterrupcionesDeTiempoRealSuperanElTiempoPermitido ;
    ns1:textoExtracto "Si el error se repite con frecuencia, puede ser necesario ajustar el parámetro LOOPTIME." .

ns1:AvisoSeguridad_5c6e8d0392 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error #OPEN" ;
    ns1:solucionaFallo ns1:ElArchivoOPathIndicadoNoExiste ;
    ns1:textoExtracto "#OPEN:El fichero o path indicado no existe." .

ns1:AvisoSeguridad_92739e66f0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error 'RT IT Overflow'" ;
    ns1:textoExtracto "'RT IT Overflow' DETECCIÓN Durante el funcionamiento del CNC." .

ns1:ElArchivoOPathIndicadoNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "El archivo o path indicado no existe" ;
    ns1:textoExtracto "La sentencia #OPEN ha comprobado que el archivo no existe (comando \"R\")." .

ns1:InterrupcionesDeTiempoRealSuperanElTiempoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Interrupciones de tiempo real superan el tiempo permitido" ;
    ns1:textoExtracto "Las interrupciones de tiempo real superan el tiempo permitido." .

