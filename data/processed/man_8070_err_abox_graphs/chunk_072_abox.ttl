@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1017
    a ex:DiagnosticoFallo ;
    rdfs:label "G198: límite de software negativo fuera de rango" ;
    ex:textoExtracto "1017 'G198: límite de software negativo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite negativo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1017" .

ex:Fallo_1018
    a ex:DiagnosticoFallo ;
    rdfs:label "G199: límite de software positivo fuera de rango" ;
    ex:textoExtracto "1018 'G199: límite de software positivo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite positivo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1018" .

ex:Fallo_1019
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha realizado medición en el eje(s) solicitado" ;
    ex:textoExtracto "1019 'No se ha realizado medición en el eje(s) solicitado' DETECCIÓN Durante la ejecución. CAUSA La función G101 intenta incluir el offset de medición en un eje que no ha intervenido en la medición o el offset ha sido cancelado (G102). SOLUCIÓN Para incluir un offset de medición (G101), el eje debe haber realizado una medición." ;
    ex:identificador "1019" .

ex:Fallo_1020
    a ex:DiagnosticoFallo ;
    rdfs:label "Tiempo de rampa negativo" ;
    ex:textoExtracto "1020 'Tiempo de rampa negativo' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es negativo. SOLUCIÓN Programar un valor mayor o igual que cero." ;
    ex:identificador "1020" .

ex:Fallo_1021
    a ex:DiagnosticoFallo ;
    rdfs:label "Tiempo de rampa fuera de rango" ;
    ex:textoExtracto "1021 'Tiempo de rampa fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es demasiado alto. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1021" .

ex:Fallo_1022
    a ex:DiagnosticoFallo ;
    rdfs:label "Porcentaje de Feed-Forward fuera de rango" ;
    ex:textoExtracto "1022 'Porcentaje de Feed-Forward fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto. SOLUCIÓN El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." ;
    ex:identificador "1022" .

ex:Fallo_1023
    a ex:DiagnosticoFallo ;
    rdfs:label "Número de gama no válido" ;
    ex:textoExtracto "1023 'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." ;
    ex:identificador "1023" .

ex:Parametro_DIAMPROG
    a ex:Parametro ;
    rdfs:label "Parámetro DIAMPROG (programación en diámetros)" ;
    ex:textoExtracto "No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros activa (parámetro DIAMPROG)." ;
    ex:identificador "DIAMPROG" .

ex:Funcion_G101 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G101 (offset de medición)" ;
    ex:textoExtracto "La función G101 intenta incluir el offset de medición en un eje que no ha intervenido en la medición o el offset ha sido cancelado (G102)." ;
    ex:identificador "G101" .

ex:Funcion_G102 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G102 (cancelación de offset)" ;
    ex:textoExtracto "el offset ha sido cancelado (G102)." ;
    ex:identificador "G102" .

ex:Funcion_G132 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G132 (tiempo de rampa)" ;
    ex:textoExtracto "El tiempo de rampa de la función G132 es negativo. [...] El tiempo de rampa de la función G132 es demasiado alto." ;
    ex:identificador "G132" .

ex:Funcion_G134 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G134 (feed forward)" ;
    ex:textoExtracto "El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto." ;
    ex:identificador "G134" .

ex:Funcion_G135 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G135 (AC forward)" ;
    ex:textoExtracto "El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto." ;
    ex:identificador "G135" .

ex:Fallo_ProgramacionDiametros
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación en diámetros con cotas negativas" ;
    ex:textoExtracto "negativos en la programación de un eje en diámetros' DETECCIÓN Durante la ejecución. CAUSA No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros activa (parámetro DIAMPROG). SOLUCIÓN La programamación en coordenadas absolutas y en diámetros no admite cotas negativas." ;
    ex:identificador "Fallo_ProgramacionDiametros" .