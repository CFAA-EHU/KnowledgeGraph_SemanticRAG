@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1024
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1024: Número de gama fuera de rango" ;
    ex:textoExtracto "1024 'Número de gama fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es demasiado alto. SOLUCIÓN La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." ;
    ex:identificador "1024" .

ex:AvisoSeguridad_1025
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1025: Distancia programada igual a cero" ;
    ex:textoExtracto "1025 'Distancia programada igual a cero' DETECCIÓN Durante la ejecución. CAUSA Movimiento nulo en el bloque de G63. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1025" .

ex:AvisoSeguridad_1026
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1026: Trayectoria circular incorrecta con el radio programado" ;
    ex:textoExtracto "1026 'Trayectoria circular incorrecta con el radio programado' DETECCIÓN Durante la ejecución. CAUSA Radio demasiado pequeño para la interpolación circular. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1026" .

ex:AvisoSeguridad_1027
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1027: Punto inicial y final de trayectoria circular idénticos" ;
    ex:textoExtracto "1027 'Punto inicial y final de trayectoria circular idénticos (infinitas soluciones)' DETECCIÓN Durante la ejecución. CAUSA Radio nulo para la interpolación circular; las soluciones son infinitas. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1027" .

ex:AvisoSeguridad_1028
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1028: Diferencia entre el centro programado y el calculado demasiado grande" ;
    ex:textoExtracto "1028 'Diferencia entre el centro programado y el calculado demasiado grande' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular con la función G265 activa, la diferencia entre radio inicial y final supera los parámetros máquina CIRINERR y CIRINFACT. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1028" .

ex:AvisoSeguridad_1029
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1029: Radio nulo en trayectoria circular" ;
    ex:textoExtracto "1029 'Radio nulo en trayectoria circular' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Radio nulo en una interpolación circular. • Con la función G265 activa, el CNC calcula un radio nulo a partir de las coordenadas del centro programadas en la interpolación circular. • Con la función G264 activa, ambas coordenadas del centro son cero. SOLUCIÓN El radio de una interpolación circular no puede ser nulo. Ambas coordenadas del centro de una interpolación circular no pueden ser nulas." ;
    ex:identificador "1029" .

ex:AvisoSeguridad_1030
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1030: #AXIS programado sin G200/201/202" ;
    ex:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución." ;
    ex:identificador "1030" .

ex:Parametro_NPARSETS
    a ex:Parametro ;
    rdfs:label "Parámetro máquina NPARSETS" ;
    ex:textoExtracto "parámetro máquina NPARSETS del eje" ;
    ex:identificador "NPARSETS" .

ex:Parametro_CIRINERR
    a ex:Parametro ;
    rdfs:label "Parámetro máquina CIRINERR" ;
    ex:textoExtracto "parámetros máquina CIRINERR" ;
    ex:identificador "CIRINERR" .

ex:Parametro_CIRINFACT
    a ex:Parametro ;
    rdfs:label "Parámetro máquina CIRINFACT" ;
    ex:textoExtracto "parámetros máquina CIRINFACT" ;
    ex:identificador "CIRINFACT" .

ex:AvisoSeguridad_1028
    ex:monitoreaParametro ex:Parametro_CIRINERR ;
    ex:monitoreaParametro ex:Parametro_CIRINFACT .

ex:AvisoSeguridad_1024
    ex:monitoreaParametro ex:Parametro_NPARSETS .