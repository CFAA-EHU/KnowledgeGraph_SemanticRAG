@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarElParametroLOOPTIME a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar el parámetro LOOPTIME" ;
    ns1:solucionaFallo ns1:SobrepasadaTemperaturaDeSeguridad ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el parámetro LOOPTIME." .

ns1:AvisoSeguridad_cf4029911f a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de integridad del equipo" ;
    ns1:mitigaRiesgo ns1:CNC8070_fd08d84dd8 ;
    ns1:textoExtracto "En riesgo la integridad del equipo." .

ns1:ContactarConElSAT a ns1:AccionProhibida ;
    rdfs:label "Contactar con el SAT" ;
    ns1:textoExtracto "Contactar con el SAT." .

ns1:FrecuenciaChequeoTemperatura a ns1:Frecuencia ;
    rdfs:label "Cada minuto" ;
    ns1:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo;" .

ns1:TiempoDeBucle a ns1:Parametro ;
    rdfs:label "Tiempo de bucle" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Ajustar el parámetro LOOPTIME." .

ns1:CNC8070_fd08d84dd8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:SobrepasadaTemperaturaDeSeguridad ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento del CNC." .

ns1:SobrepasadaTemperaturaDeSeguridad a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrepasada temperatura de seguridad" ;
    ns1:textoExtracto "0169 Sobrepasada temperatura de seguridad. En riesgo la integridad del equipo." .

