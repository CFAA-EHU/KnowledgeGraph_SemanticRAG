@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_1030
    a                       ex:AvisoSeguridad ;
    rdfs:label              "Error 1030: '#AXIS programado sin G200/201/202'"@es ;
    ex:identificador        "1030" ;
    ex:textoExtracto        "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la sentencia #AXIS falta programar G200, G201 o G202. SOLUCIÓN Revisar la programación."@es .

ex:Error_1031
    a                       ex:AvisoSeguridad ;
    rdfs:label              "Error 1031: 'Se espera #AXIS'"@es ;
    ex:identificador        "1031" ;
    ex:textoExtracto        "1031 'Se espera #AXIS' DETECCIÓN Durante la ejecución."@es .

ex:Fallo_G264_CoordenadasNulas
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Fallo en G264: Coordenadas del centro nulas"@es ;
    ex:textoExtracto        "Con la función G264 activa, ambas coordenadas del centro son cero. SOLUCIÓN El radio de una interpolación circular no puede ser nulo. Ambas coordenadas del centro de una interpolación circular no pueden ser nulas."@es .