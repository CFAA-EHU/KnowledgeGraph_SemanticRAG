@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaOvertemp a ns1:Alarma ;
    ns1:activaAlarma ns1:AvisoSobreTemperatura ;
    ns1:textoExtracto "activa la marca OVERTEMP" .

ns1:TareaAjustarLooptime a ns1:TareaMantenimiento ;
    ns1:solucionaFallo ns1:SobrepasamientoDelLOOPTIME ;
    ns1:textoExtracto "ajustar el parámetro LOOPTIME." .

ns1:TareaContactarSAT a ns1:TareaMantenimiento ;
    ns1:solucionaFallo ns1:AvisoSobreTemperatura,
        ns1:TensionDePilaBaja,
        ns1:VentiladorDeCPUParado ;
    ns1:textoExtracto "póngase en contacto con el servicio de asistencia técnica." .

ns1:TiempoDeBucle a ns1:Parametro ;
    rdfs:label "Tiempo de bucle" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "ajustar el parámetro LOOPTIME." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:SobrepasamientoDelLOOPTIME a ns1:AvisoSeguridad ;
    rdfs:label "Sobrepasamiento del LOOPTIME" ;
    ns1:textoExtracto "'Sobrepasamiento del LOOPTIME' DETECCIÓN En condiciones de CNCREADY." .

ns1:TensionDePilaBaja a ns1:AvisoSeguridad ;
    rdfs:label "Tensión de pila baja" ;
    ns1:textoExtracto "'Tensión de pila baja' DETECCIÓN Durante el arranque del CNC o tras un reset." .

ns1:VentiladorDeCPUParado a ns1:AvisoSeguridad ;
    rdfs:label "Ventilador de CPU parado" ;
    ns1:textoExtracto "Ventilador de la cpu parado. Riesgo de sobretemperatura. Contactar con el SAT." .

ns1:AvisoSobreTemperatura a ns1:AvisoSeguridad ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "El CNC muestra este aviso y activa la marca OVERTEMP." .

