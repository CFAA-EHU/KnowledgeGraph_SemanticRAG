@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDelVentiladorDeLaCPU a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del ventilador de la CPU" ;
    ns1:solucionaFallo ns1:RiesgoDeSobretemperaturaDelEquipo ;
    ns1:textoExtracto "SOLUCIÓN Si el error" .

ns1:CNC8070_81006e6c03 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:EstadoDelVentiladorDeLaCPU,
        ns1:TemperaturaDeLaCPU_2eb2a9a39e ;
    ns1:textoExtracto "CNC 8070" .

ns1:EstadoDelVentiladorDeLaCPU a ns1:Parametro ;
    rdfs:label "Estado del ventilador de la CPU" ;
    ns1:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado." .

ns1:RiesgoDeSobretemperaturaDelEquipo a ns1:AccionProhibida ;
    rdfs:label "Riesgo de sobretemperatura del equipo" ;
    ns1:mitigaRiesgo ns1:CNC8070_81006e6c03 ;
    ns1:textoExtracto "CAUSA Riesgo de sobretemperatura del equipo. El CNC ha detectado que el ventilador de la CPU está parado." .

ns1:TemperaturaDeLaCPU_2eb2a9a39e a ns1:Parametro ;
    rdfs:label "Temperatura de la CPU" ;
    ns1:textoExtracto "CAUSA Riesgo de sobretemperatura del equipo." .

