@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1031
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1031: Falta sentencia #AXIS con G201"@es ;
    ex:textoExtracto "1031 'Se espera #AXIS' [...] CAUSA En el mismo bloque que la función G201 falta programar la sentencia #AXIS."@es ;
    ex:identificador "1031" .

ex:Fallo_1032
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1032: Falta posición del cabezal para M19"@es ;
    ex:textoExtracto "1032 'Falta posición del cabezal para M19' [...] CAUSA En el mismo bloque que la función M19 falta programar la posición del cabezal."@es ;
    ex:identificador "1032" .

ex:Fallo_1035
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1035: Parámetro #SLOPE fuera de rango"@es ;
    ex:textoExtracto "1035 '#SLOPE: parámetro fuera de rango' [...] CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto."@es ;
    ex:identificador "1035" .

ex:Parametro_SLOPE
    a               ex:Parametro ;
    rdfs:label      "Parámetro #SLOPE"@es ;
    ex:textoExtracto "En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto."@es ;
    ex:identificador "#SLOPE" .

ex:Fallo_1037
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1037: Coordenadas I/J/K ignoradas con G0/G1/G100/G63"@es ;
    ex:textoExtracto "1037 'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' [...] CAUSA El CNC ha encontrado los parámetros I, J, K con la función G0, G1, G100 o G63 activa."@es ;
    ex:identificador "1037" .

ex:Parametro_I
    a               ex:Parametro ;
    rdfs:label      "Parámetro I (coordenada)"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "I" .

ex:Parametro_J
    a               ex:Parametro ;
    rdfs:label      "Parámetro J (coordenada)"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "J" .

ex:Parametro_K
    a               ex:Parametro ;
    rdfs:label      "Parámetro K (coordenada)"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "K" .

ex:Fallo_1038
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1038: Compensación de radio activa en medición (G100)"@es ;
    ex:textoExtracto "1038 'No se admite compensación de radio activa en medición' [...] CAUSA El CNC intenta ejecutar la función G100 con la compensación de radio activa (G41/G42)."@es ;
    ex:identificador "1038" .

ex:Fallo_1039
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1039: Offset de medición previo en eje"@es ;
    ex:textoExtracto "1039 'Existe un valor de medición previo para el eje(s)' [...] CAUSA El CNC intenta realizar una medición (G100) en un eje que tiene un offset de medición anterior."@es ;
    ex:identificador "1039" ;
    ex:solucionaFallo ex:Funcion_G102 .

ex:Funcion_G102 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función G102 (anular offset de medición)"@es ;
    ex:textoExtracto "Utilizar la función G102 para anular el offset de medición incluido en el eje."@es ;
    ex:identificador "G102" .

ex:Fallo_1040
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1040: Búsqueda de cero en eje activo con G201"@es ;
    ex:textoExtracto "1040 'No se permite búsqueda de cero de un eje activo en G201' [...] CAUSA El CNC no puede realizar la búsqueda de referencia de un eje que está en modo manual aditivo (G201)."@es ;
    ex:identificador "1040" .

ex:Modo_G201
    a               ex:ModoOperacion ;
    rdfs:label      "Modo manual aditivo (G201)"@es ;
    ex:textoExtracto "modo manual aditivo (G201)"@es ;
    ex:identificador "G201" .

ex:Funcion_G200 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función G200"@es ;
    ex:textoExtracto "#AXIS falta programar G200, G201 o G202"@es ;
    ex:identificador "G200" .

ex:Funcion_G202 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función G202"@es ;
    ex:textoExtracto "#AXIS falta programar G200, G201 o G202"@es ;
    ex:identificador "G202" .

ex:Funcion_M19 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función M19"@es ;
    ex:textoExtracto "función M19 falta programar la posición del cabezal"@es ;
    ex:identificador "M19" .

ex:Funcion_G100 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función G100 (medición)"@es ;
    ex:textoExtracto "función G100 con la compensación de radio activa [...] medición (G100)"@es ;
    ex:identificador "G100" .

ex:Funcion_G41 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Compensación de radio G41"@es ;
    ex:textoExtracto "compensación de radio activa (G41/G42)"@es ;
    ex:identificador "G41" .

ex:Funcion_G42 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Compensación de radio G42"@es ;
    ex:textoExtracto "compensación de radio activa (G41/G42)"@es ;
    ex:identificador "G42" .