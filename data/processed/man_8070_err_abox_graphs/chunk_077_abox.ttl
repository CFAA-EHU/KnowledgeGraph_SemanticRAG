@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1040
    a ex:Alarma ;
    rdfs:label "Alarma 1040: Búsqueda de cero en eje activo con G201"@es ;
    ex:identificador "1040" ;
    ex:textoExtracto "'No se permite búsqueda de cero de un eje activo en G201' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede realizar la búsqueda de referencia de un eje que está en modo manual aditivo (G201)."@es ;
    ex:mitigaRiesgo ex:AccionProhibida_1040 .

ex:AccionProhibida_1040
    a ex:AccionProhibida ;
    rdfs:label "Búsqueda de referencia en eje con modo G201 activo"@es ;
    ex:textoExtracto "No se permite búsqueda de cero de un eje activo en G201"@es .

ex:ModoOperacion_G201
    a ex:ModoOperacion ;
    rdfs:label "Modo manual aditivo (G201)"@es ;
    ex:identificador "G201" ;
    ex:textoExtracto "modo manual aditivo (G201)"@es .

ex:ModoOperacion_G202
    a ex:ModoOperacion ;
    rdfs:label "Modo de anulación manual aditivo (G202)"@es ;
    ex:identificador "G202" ;
    ex:textoExtracto "Anular el modo manual aditivo del eje mediante la función G202"@es .

ex:Alarma_1041
    a ex:Alarma ;
    rdfs:label "Alarma 1041: Centro de trayectoria circular corregida fuera de rango"@es ;
    ex:identificador "1041" ;
    ex:textoExtracto "'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio"@es .