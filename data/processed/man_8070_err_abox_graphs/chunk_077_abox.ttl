@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorteEnLaRedPCAlimentadoConBateria_04cecf8e48 a ns1:AvisoSeguridad ;
    rdfs:label "'Corte en la red. PC alimentado con batería'" ;
    ns1:textoExtracto "Al leer el estado de la batería." .

ns1:EjesRotativosEsNecesarioCompletarLaVueltaCompleta_df01f31be8 a ns1:AvisoSeguridad ;
    rdfs:label "Ejes rotativos, es necesario completar la vuelta completa" ;
    ns1:textoExtracto "Definir el módulo del segundo eje rotativo entre 0 y 360º y validar la compensación volumétrica." .

ns1:FalloEnLaPeticionAUnVxD_1b2fd01e56 a ns1:AvisoSeguridad ;
    rdfs:label "'Fallo en la petición a un VxD'" ;
    ns1:textoExtracto "El CNC no se puede conectar con VcompciD." .

ns1:FalloRedCorte a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0201 'Corte en la red. PC alimentado con batería'" ;
    ns1:textoExtracto "Al leer el estado de la batería." .

ns1:FalloTemperaturaSeguridad a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0173 Marcha no permitida por sobrepasar temperatura de seguridad" ;
    ns1:textoExtracto "Cada vez que se pulsa [START], el CNC comprueba que la temperatura ambiente no sobrepase los 65ºC (149ºF), y en caso de superar dicho valor, invalida el [START] y muestra este error." .

ns1:FalloVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0174 Ejes rotativos, es necesario completar la vuelta completa" ;
    ns1:textoExtracto "El CNC no puede activar la compensación volumétrica porque entre los ejes que se mueven (parámetro MOVAXIS) hay más de un eje rotativo módulo, y el recorrido del segundo eje no es completo (0 a 360º)." .

ns1:FalloVxD a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0200 'Fallo en la petición a un VxD'" ;
    ns1:textoExtracto "Al leer el estado de la batería. CAUSA El CNC no se puede conectar con VcompciD." .

ns1:MarchaNoPermitidaPorSobrepasarTemperaturaDeSeguridad_7552e3c71e a ns1:AvisoSeguridad ;
    rdfs:label "Marcha no permitida por sobrepasar temperatura de seguridad" ;
    ns1:textoExtracto "Apagar el cnc y contactar con el SAT." .

ns1:SistemaRefrigeracion a ns1:Sistema ;
    rdfs:label "Sistema de refrigeración del hardware" ;
    ns1:textoExtracto "La causa del aumento de temperatura puede ser un fallo en el sistema de refrigeración del hardware o una temperatura ambiente muy elevada." .

