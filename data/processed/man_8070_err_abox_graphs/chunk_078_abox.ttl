@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_G201
    a                       ex:ModoOperacion ;
    rdfs:label              "Modo manual aditivo (G201)"@es ;
    ex:textoExtracto        "el modo manual aditivo (G201)"@es ;
    ex:identificador        "G201" .

ex:AvisoSeguridad_1041
    a                       ex:AvisoSeguridad ;
    rdfs:label              "Centro de la trayectoria circular corregida fuera de rango (1041)"@es ;
    ex:textoExtracto        "1041 'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio y las coordenadas del punto final o bien mediante las coordenadas del punto medio, del punto final y con la función G265 activa. Las coordenadas del centro de la interpolación calculadas por el CNC son demasiado grandes. Las coordenadas programadas para el centro, el punto medio o el radio son demasiado grandes. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador        "1041" ;
    ex:mitigaRiesgo         ex:ModoOperacion_G201 .

ex:AvisoSeguridad_1043
    a                       ex:AvisoSeguridad ;
    rdfs:label              "El tercer eje del plano no puede coincidir con el primero o segundo (1043)"@es ;
    ex:textoExtracto        "1043 'El tercer eje del plano no puede coincidir con el primero o segundo' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el parámetro 5 coincide con el 1 o con el 2. SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. Este parámetro no deberá coincidir ni con el primero ni con el segundo."@es ;
    ex:identificador        "1043" ;
    ex:mitigaRiesgo         ex:ModoOperacion_G201 .

ex:AvisoSeguridad_1044
    a                       ex:AvisoSeguridad ;
    rdfs:label              "El primer y segundo eje del plano no pueden coincidir (1044)"@es ;
    ex:textoExtracto        "1044 'El primer y segundo eje del plano no pueden coincidir' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el primer eje del plano (parámetro 1) y el segundo (parámetro 2) son el mismo eje. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador        "1044" ;
    ex:mitigaRiesgo         ex:ModoOperacion_G201 .

ex:AvisoSeguridad_1045
    a                       ex:AvisoSeguridad ;
    rdfs:label              "Programación incorrecta del primer eje del plano (1045)"@es ;
    ex:textoExtracto        "1045 'Programación incorrecta del primer eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el primer eje del plano (parámetro 1) es incorrecto. SOLUCIÓN El primer eje del plano debe ser uno de los tres primeros ejes del canal."@es ;
    ex:identificador        "1045" ;
    ex:mitigaRiesgo         ex:ModoOperacion_G201 .

ex:AvisoSeguridad_1046
    a                       ex:AvisoSeguridad ;
    rdfs:label              "Programación incorrecta del segundo eje del plano (1046)"@es ;
    ex:textoExtracto        "1046 'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal."@es ;
    ex:identificador        "1046" ;
    ex:mitigaRiesgo         ex:ModoOperacion_G201 .

ex:Parametro_G20_Param1
    a                       ex:Parametro ;
    rdfs:label              "Primer eje del plano (parámetro 1 en G20)"@es ;
    ex:textoExtracto        "el primer eje del plano (parámetro 1)"@es ;
    ex:identificador        "G20/1" .

ex:Parametro_G20_Param2
    a                       ex:Parametro ;
    rdfs:label              "Segundo eje del plano (parámetro 2 en G20)"@es ;
    ex:textoExtracto        "el segundo eje del plano (parámetro 2)"@es ;
    ex:identificador        "G20/2" .

ex:Parametro_G20_Param3
    a                       ex:Parametro ;
    rdfs:label              "Eje longitudinal de la herramienta (parámetro 3 en G20)"@es ;
    ex:textoExtracto        "el eje longitudinal de la herramienta (parámetro 3)"@es ;
    ex:identificador        "G20/3" .

ex:Parametro_G20_Param5
    a                       ex:Parametro ;
    rdfs:label              "Tercer eje del plano (parámetro 5 en G20)"@es ;
    ex:textoExtracto        "el tercer eje con el parámetro 5"@es ;
    ex:identificador        "G20/5" .