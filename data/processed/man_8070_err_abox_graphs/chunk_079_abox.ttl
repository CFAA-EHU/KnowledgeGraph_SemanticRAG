@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1046
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del segundo eje del plano"@es ;
    ex:identificador "1046" ;
    ex:textoExtracto "1046 'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal."@es ;
    ex:solucionaFallo ex:Parametro_G20_Par2 .

ex:DiagnosticoFallo_1047
    a ex:DiagnosticoFallo ;
    rdfs:label "Es necesario un tercer eje para el plano (índice 5)"@es ;
    ex:identificador "1047" ;
    ex:textoExtracto "1047 'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto."@es ;
    ex:solucionaFallo ex:Parametro_G20_Par3 .

ex:Parametro_G20_Par2
    a ex:Parametro ;
    rdfs:label "Parámetro 2 de la función G20 (segundo eje del plano)"@es ;
    ex:identificador "G20_Par2" ;
    ex:textoExtracto "el segundo eje del plano (parámetro 2) es incorrecto"@es .

ex:Parametro_G20_Par3
    a ex:Parametro ;
    rdfs:label "Tercer eje del plano (índice 5) en función G20"@es ;
    ex:identificador "G20_Par3" ;
    ex:textoExtracto "falta el tercer eje del plano o éste es incorrecto"@es .