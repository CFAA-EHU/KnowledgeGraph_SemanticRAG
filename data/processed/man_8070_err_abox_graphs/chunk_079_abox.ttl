@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ff336dadcd a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Hay un corte en la alimentación del CNC y la batería de emergencia está alimentado el CNC." .

ns1:CompensacionVolumetricaInexistente_107071415c a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación volumétrica inexistente" ;
    ns1:textoExtracto "El PLC ha intentado activar una compensación volumétrica que no existe." .

ns1:DefinirLaVariableConUnValorAdecuadoOModificarLaDinamica a ns1:TareaMantenimiento ;
    rdfs:label "Definir la variable con un valor adecuado o modificar la dinámica" ;
    ns1:solucionaFallo ns1:DYNOVRFueraDelRangoPermitido ;
    ns1:textoExtracto "Definir la variable con un valor adecuado o modificar la dinámica con ayuda de la barra-override ([CTRL][H])." .

ns1:DejarQueElCNCTermineLaSecuenciaAutomaticaDeApagado a ns1:TareaMantenimiento ;
    rdfs:label "Dejar que el CNC termine la secuencia automática de apagado" ;
    ns1:solucionaFallo ns1:CorteEnLaAlimentacionDelCNC ;
    ns1:textoExtracto "Tanto si el corte es fortuito como provocado por el usuario, dejar que el CNC termine la secuencia automática de apagado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC ha intentado activar una compensación volumétrica que no existe." .

ns1:VariableVGDYNOVR a ns1:Parametro ;
    rdfs:label "Variable V.G.DYNOVR" ;
    ns1:textoExtracto "La variable V.G.DYNOVR tiene un valor fuera de los límites fijados por los parámetros MINDYNOVR y MAXDYNOVR." .

ns1:CorteEnLaAlimentacionDelCNC a ns1:AccionProhibida ;
    rdfs:label "Corte en la alimentación del CNC" ;
    ns1:textoExtracto "Hay un corte en la alimentación del CNC y la batería de emergencia está alimentado el CNC." .

ns1:DYNOVRFueraDelRangoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "DYNOVR fuera del rango permitido" ;
    ns1:textoExtracto "La variable V.G.DYNOVR tiene un valor fuera de los límites fijados por los parámetros MINDYNOVR y MAXDYNOVR." .

