@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeMaterialDesdeTablasTecnologicas a ns1:AvisoSeguridad ;
    rdfs:label "Activación de material desde tablas tecnológicas" ;
    ns1:mitigaRiesgo ns1:LecturaDelNombreDeMaterialInactivo ;
    ns1:textoExtracto "Activar un material desde las tablas tecnológicas." .

ns1:ComprobacionDeOpcionDeSoftwareAsociada a ns1:AvisoSeguridad ;
    rdfs:label "Comprobación de opción de software asociada" ;
    ns1:mitigaRiesgo ns1:ActivacionDeCompensacionVolumetricaInexistente ;
    ns1:textoExtracto "Comprobar que está activa la opción de software asociada a la compensación volumétrica." .

ns1:ListaDeCompensacionesVolumetricasDefinidas_e26279aa11 a ns1:Parametro ;
    rdfs:label "Lista de compensaciones volumétricas definidas" ;
    ns1:textoExtracto "Comprobar la lista de compensaciones volumétricas definidas (parámetro VOLCOMPn)." .

ns1:Parametro_58870954d3 a ns1:Parametro ;
    rdfs:label "Parámetro COMPID de la cinemática" ;
    ns1:textoExtracto "El parámetro COMPID de la cinemática tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID." .

ns1:RevisionDelParametroCOMPID a ns1:AvisoSeguridad ;
    rdfs:label "Revisión del parámetro COMPID" ;
    ns1:mitigaRiesgo ns1:UsoDeCOMPIDInvalidoEnLaCinematica ;
    ns1:textoExtracto "Revisar el parámetro COMPID." .

ns1:ActivacionDeCompensacionVolumetricaInexistente a ns1:AccionProhibida ;
    rdfs:label "Activación de compensación volumétrica inexistente" ;
    ns1:textoExtracto "El PLC ha intentado activar una compensación volumétrica que no existe." .

ns1:LecturaDelNombreDeMaterialInactivo a ns1:AccionProhibida ;
    rdfs:label "Lectura del nombre de material inactivo" ;
    ns1:textoExtracto "Se ha intentado leer el nombre del material activo y no hay ninguno." .

ns1:UsoDeCOMPIDInvalidoEnLaCinematica a ns1:AccionProhibida ;
    rdfs:label "Uso de COMPID inválido en la cinemática" ;
    ns1:textoExtracto "El parámetro COMPID de la cinemática tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID." .

