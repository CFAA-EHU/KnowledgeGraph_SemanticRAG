@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaFuncionProgramadaRequiereAlgunEjePrincipalNoExistente a ns1:DiagnosticoFallo ;
    rdfs:label "La función programada requiere algún eje principal no existente" ;
    ns1:textoExtracto "'La función programada requiere algún eje principal no existente' DETECCIÓN Durante la ejecución." .

ns1:ProgramarElAvanceF a ns1:TareaMantenimiento ;
    rdfs:label "Programar el avance F" ;
    ns1:solucionaFallo ns1:BloqueDeMovimientoConAvanceNulo_fd11dc9c9b ;
    ns1:textoExtracto "SOLUCIÓN Programar el avance F." .

ns1:ProgramarUnaVelocidadDeCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Programar una velocidad de cabezal" ;
    ns1:solucionaFallo ns1:VelocidadDeCabezalNula_94335840e5 ;
    ns1:textoExtracto "SOLUCIÓN Programar una velocidad de cabezal." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:G20NoSeAdmiteCabezal_c35fef3143,
        ns1:LaFuncionOSentenciaRequiereProgramacionDeEjes ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:BloqueDeMovimientoConAvanceNulo_fd11dc9c9b a ns1:DiagnosticoFallo ;
    rdfs:label "Bloque de movimiento con avance nulo" ;
    ns1:textoExtracto "'Bloque de movimiento con avance nulo' DETECCIÓN Durante la ejecución. CAUSA No hay un avance activo en el canal." .

ns1:G20NoSeAdmiteCabezal_c35fef3143 a ns1:DiagnosticoFallo ;
    rdfs:label "G20: no se admite cabezal" ;
    ns1:textoExtracto "'G20: no se admite cabezal' DETECCIÓN Durante la ejecución. CAUSA La función G20 no admite la programación de cabezal." .

ns1:LaFuncionOSentenciaRequiereProgramacionDeEjes a ns1:DiagnosticoFallo ;
    rdfs:label "La función o sentencia requiere programación de ejes" ;
    ns1:textoExtracto "'La función o sentencia requiere programación de ejes' DETECCIÓN Durante la ejecución. CAUSA Falta programar los ejes sobre los que debe actuar la sentencia o función G programada." .

ns1:VelocidadDeCabezalNula_94335840e5 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de cabezal nula" ;
    ns1:textoExtracto "'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado con la función G63 tiene velocidad cero." .

