ex:AvisoSeguridad_1061
    a               ex:AvisoSeguridad ;
    rdfs:label      "Función G inexistente"@es ;
    ex:identificador "1061" ;
    ex:textoExtracto "1061 'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe. SOLUCIÓN Revisar la programación."@es .

ex:AvisoSeguridad_1062
    a               ex:AvisoSeguridad ;
    rdfs:label      "Funciones G incompatibles"@es ;
    ex:identificador "1062" ;
    ex:textoExtracto "1062 'Funciones G incompatibles' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

