@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AdvertenciaSobreCotasNegativasEnCoordenadasAbsolutas a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre cotas negativas en coordenadas absolutas" ;
    ns1:mitigaRiesgo ns1:ProgramarCotasNegativasEnCoordenadasAbsolutas ;
    ns1:textoExtracto "'negativos en la programación de un eje en diámetros' DETECCIÓN Durante la ejecución. CAUSA No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros activa (parámetro DIAMPROG). SOLUCIÓN La programamación en coordenadas absolutas y en diámetros no admite cotas negativas." .

ns1:AdvertenciaSobreInclusionDeOffsetSinMedicionPrevia a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre inclusión de offset sin medición previa" ;
    ns1:mitigaRiesgo ns1:IncluirOffsetDeMedicionSinMedicionPrevia ;
    ns1:textoExtracto "'No se ha realizado medición en el eje(s) solicitado' DETECCIÓN Durante la ejecución. CAUSA La función G101 intenta incluir el offset de medición en un eje que no ha intervenido en la medición o el offset ha sido cancelado (G102). SOLUCIÓN Para incluir un offset de medición (G101), el eje debe haber realizado una medición." .

ns1:AdvertenciaSobreNumeroDeGamaIncorrecto a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre número de gama incorrecto" ;
    ns1:mitigaRiesgo ns1:UsarNumeroDeGamaIncorrecto ;
    ns1:textoExtracto "'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

ns1:AdvertenciaSobrePorcentajeDeFeedForwardOACForwardDemasiadoAlto a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre porcentaje de Feed-Forward o AC forward demasiado alto" ;
    ns1:mitigaRiesgo ns1:ProgramarPorcentajeDeFeedForwardOACForwardDemasiadoAlto ;
    ns1:textoExtracto "'Porcentaje de Feed-Forward fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto. SOLUCIÓN El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." .

ns1:AdvertenciaSobreTiempoDeRampaDemasiadoAlto a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre tiempo de rampa demasiado alto" ;
    ns1:mitigaRiesgo ns1:ProgramarTiempoDeRampaDemasiadoAlto ;
    ns1:textoExtracto "'Tiempo de rampa fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:AdvertenciaSobreTiempoDeRampaNegativo a ns1:AvisoSeguridad ;
    rdfs:label "advertencia sobre tiempo de rampa negativo" ;
    ns1:mitigaRiesgo ns1:ProgramarTiempoDeRampaNegativo ;
    ns1:textoExtracto "'Tiempo de rampa negativo' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es negativo. SOLUCIÓN Programar un valor mayor o igual que cero." .

ns1:LimiteDeSoftwareNegativoFueraDeRango a ns1:Parametro ;
    rdfs:label "límite de software negativo fuera de rango" ;
    ns1:textoExtracto "'G198: límite de software negativo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite negativo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:LimiteDeSoftwarePositivoFueraDeRango a ns1:Parametro ;
    rdfs:label "límite de software positivo fuera de rango" ;
    ns1:textoExtracto "'G199: límite de software positivo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite positivo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:NumeroDeGamaNoValido_61d46c19d0 a ns1:Parametro ;
    rdfs:label "número de gama no válido" ;
    ns1:textoExtracto "'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

ns1:PorcentajeDeFeedForwardFueraDeRango a ns1:Parametro ;
    rdfs:label "porcentaje de Feed-Forward fuera de rango" ;
    ns1:textoExtracto "'Porcentaje de Feed-Forward fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto. SOLUCIÓN El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." .

ns1:ProgramacionEnDiametros_621300296b a ns1:Parametro ;
    rdfs:label "programación en diámetros" ;
    ns1:textoExtracto "'negativos en la programación de un eje en diámetros' DETECCIÓN Durante la ejecución. CAUSA No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros activa (parámetro DIAMPROG). SOLUCIÓN La programamación en coordenadas absolutas y en diámetros no admite cotas negativas." .

