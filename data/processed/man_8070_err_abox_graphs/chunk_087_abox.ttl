@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeGamaFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama fuera de rango" ;
    ns1:textoExtracto "'Número de gama fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es demasiado alto." .

ns1:Parametro_3588a27319 a ns1:Parametro ;
    rdfs:label "Parámetro máquina NPARSETS" ;
    ns1:textoExtracto "La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." .

ns1:SolucionParaElNumeroDeGama a ns1:TareaMantenimiento ;
    rdfs:label "Solución para el número de gama" ;
    ns1:solucionaFallo ns1:NumeroDeGamaNoValido ;
    ns1:textoExtracto "La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." .

ns1:SolucionParaFeedForward a ns1:TareaMantenimiento ;
    rdfs:label "Solución para feed forward" ;
    ns1:textoExtracto "El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." .

ns1:NumeroDeGamaNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama no válido" ;
    ns1:textoExtracto "'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

