@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AXISProgramadoSinG200201202 a ns1:AccionProhibida ;
    rdfs:label "#AXIS programado sin G200/201/202" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202'" .

ns1:AmbasCoordenadasDelCentroDeUnaInterpolacionCircularNoPuedenSerNulas a ns1:DiagnosticoFallo ;
    rdfs:label "Ambas coordenadas del centro de una interpolación circular no pueden ser nulas" ;
    ns1:textoExtracto "Ambas coordenadas del centro de una interpolación circular no pueden ser nulas." .

ns1:ElRadioDeUnaInterpolacionCircularNoPuedeSerNulo a ns1:DiagnosticoFallo ;
    rdfs:label "El radio de una interpolación circular no puede ser nulo" ;
    ns1:textoExtracto "SOLUCIÓN El radio de una interpolación circular no puede ser nulo." .

ns1:SeEsperaAXIS a ns1:AccionProhibida ;
    rdfs:label "Se espera #AXIS" ;
    ns1:textoExtracto "'Se espera #AXIS'" .

