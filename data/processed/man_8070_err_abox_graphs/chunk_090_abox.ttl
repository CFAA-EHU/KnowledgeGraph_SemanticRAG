@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CoordenadasDelCentroIgnoradasConG0G1G100G63Activas a ns1:DiagnosticoFallo ;
    rdfs:label "Coordenadas del centro ignoradas con G0/G1/G100/G63 activas" ;
    ns1:textoExtracto "'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' DETECCIÓN Durante la ejecución." .

ns1:Parametro_9466cef1f7 a ns1:Parametro ;
    rdfs:label "#SLOPE" ;
    ns1:textoExtracto "'#SLOPE: parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto." .

ns1:ProgramarValoresMenores a ns1:TareaMantenimiento ;
    rdfs:label "Programar valores menores" ;
    ns1:solucionaFallo ns1:SLOPEParametroFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Programar valores menores." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FaltaPosicionDelCabezalParaM19,
        ns1:SeEsperaAXIS_74aa325dd6 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:FaltaPosicionDelCabezalParaM19 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta posición del cabezal para M19" ;
    ns1:textoExtracto "'Falta posición del cabezal para M19' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la función M19 falta programar la posición del cabezal." .

ns1:SLOPEParametroFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "#SLOPE: parámetro fuera de rango" ;
    ns1:textoExtracto "'#SLOPE: parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto." .

ns1:SeEsperaAXIS_74aa325dd6 a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera #AXIS" ;
    ns1:textoExtracto "'Se espera #AXIS' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la función G201 falta programar la sentencia #AXIS." .

