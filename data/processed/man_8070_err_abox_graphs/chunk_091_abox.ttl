@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error1095
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1095: Velocidad F negativa o cero" ;
    ex:textoExtracto "'No se admite programar velocidad F negativa o cero' [...] CAUSA El avance (F) debe ser un valor positivo y no nulo." ;
    ex:identificador "1095" .

ex:Error1096
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1096: Velocidad programada con función E" ;
    ex:textoExtracto "'No se admite programar la velocidad con E' [...] CAUSA El avance se ha programado con la función E." ;
    ex:identificador "1096" .

ex:Parametro_F
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ex:textoExtracto "El avance (F) debe ser un valor positivo y no nulo." .

ex:Parametro_E
    a ex:Parametro ;
    rdfs:label "Parámetro E" ;
    ex:textoExtracto "El avance se ha programado con la función E." .

ex:Error1095 ex:solucionaFallo ex:Parametro_F .
ex:Error1096 ex:solucionaFallo ex:Parametro_E .