@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularModoManualAditivoDelEjeMedianteLaFuncionG202 a ns1:TareaMantenimiento ;
    rdfs:label "Anular modo manual aditivo del eje mediante la función G202" ;
    ns1:solucionaFallo ns1:NoSePermiteBusquedaDeCeroDeUnEjeActivoEnG201 ;
    ns1:textoExtracto "SOLUCIÓN Anular el modo manual aditivo del eje mediante la función G202 para realizar la búsqueda de referencia." .

ns1:CentroDeLaTrayectoriaCircularCorregidaFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Centro de la trayectoria circular corregida fuera de rango" ;
    ns1:textoExtracto "'Centro de la trayectoria circular corregida fuera de rango'" .

ns1:UtilizarLaFuncionG102ParaAnularElOffsetDeMedicionIncluidoEnElEje a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar la función G102 para anular el offset de medición incluido en el eje" ;
    ns1:textoExtracto "SOLUCIÓN Utilizar la función G102 para anular el offset de medición incluido en el eje." .

ns1:VolverAActivarElModoManualAditivoG201 a ns1:TareaMantenimiento ;
    rdfs:label "Volver a activar el modo manual aditivo (G201)" ;
    ns1:solucionaFallo ns1:NoSePermiteBusquedaDeCeroDeUnEjeActivoEnG201 ;
    ns1:textoExtracto "Tras la búsqueda de referencia, volver a activar el modo manual aditivo (G201)." .

ns1:NoSePermiteBusquedaDeCeroDeUnEjeActivoEnG201 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite búsqueda de cero de un eje activo en G201" ;
    ns1:textoExtracto "'No se permite búsqueda de cero de un eje activo en G201'" .

