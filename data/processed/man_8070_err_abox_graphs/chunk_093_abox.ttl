@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CentroDeLaTrayectoriaCircularCorregidaFueraDeRango_0fd91af8d1 a ns1:AccionProhibida ;
    rdfs:label "Centro de la trayectoria circular corregida fuera de rango" ;
    ns1:textoExtracto "'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio y las coordenadas del punto final o bien mediante las coordenadas del punto medio, del punto final y con la función G265 activa. Las coordenadas del centro de la interpolación calculadas por el CNC son demasiado grandes. Las coordenadas programadas para el centro, el punto medio o el radio son demasiado grandes." .

ns1:ElPrimerEjeDelPlanoDebeSerUnoDeLosTresPrimerosEjesDelCanal_3b59f45e1a a ns1:TareaMantenimiento ;
    rdfs:label "El primer eje del plano debe ser uno de los tres primeros ejes del canal" ;
    ns1:solucionaFallo ns1:ElPrimerEjeDelPlanoDebeSerUnoDeLosTresPrimerosEjesDelCanal ;
    ns1:textoExtracto "SOLUCIÓN El primer eje del plano debe ser uno de los tres primeros ejes del canal." .

ns1:ElPrimerYSegundoEjeDelPlanoNoPuedenCoincidir a ns1:AccionProhibida ;
    rdfs:label "El primer y segundo eje del plano no pueden coincidir" ;
    ns1:textoExtracto "'El primer y segundo eje del plano no pueden coincidir' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el primer eje del plano (parámetro 1) y el segundo (parámetro 2) son el mismo eje." .

ns1:ElSegundoEjeDelPlanoDebeSerUnoDeLosTresPrimerosEjesDelCanal_908d27e306 a ns1:TareaMantenimiento ;
    rdfs:label "El segundo eje del plano debe ser uno de los tres primeros ejes del canal" ;
    ns1:solucionaFallo ns1:ElSegundoEjeDelPlanoDebeSerUnoDeLosTresPrimerosEjesDelCanal ;
    ns1:textoExtracto "SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal." .

ns1:ElTercerEjeDelPlanoNoPuedeCoincidirConElPrimeroOSegundo a ns1:AccionProhibida ;
    rdfs:label "El tercer eje del plano no puede coincidir con el primero o segundo" ;
    ns1:textoExtracto "'El tercer eje del plano no puede coincidir con el primero o segundo' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el parámetro 5 coincide con el 1 o con el 2." .

ns1:ProgramacionIncorrectaDelPrimerEjeDelPlano a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta del primer eje del plano" ;
    ns1:textoExtracto "'Programación incorrecta del primer eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el primer eje del plano (parámetro 1) es incorrecto." .

ns1:ProgramacionIncorrectaDelSegundoEjeDelPlano_1ac867753f a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta del segundo eje del plano" ;
    ns1:textoExtracto "'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto." .

ns1:ProgramarElTercerEjeConElParametro5_eb9e1e308b a ns1:TareaMantenimiento ;
    rdfs:label "Programar el tercer eje con el parámetro 5" ;
    ns1:solucionaFallo ns1:ProgramarElTercerEjeConElParametro5 ;
    ns1:textoExtracto "SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. Este parámetro no deberá coincidir ni con el primero ni con el segundo." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_297ad1d849 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

