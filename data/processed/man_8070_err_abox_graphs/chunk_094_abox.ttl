@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1101
    a ex:Alarma ;
    rdfs:label "Sentencia #SET IPOPOS mal programada" ;
    ex:identificador "1101" ;
    ex:textoExtracto "1101 'Sentencia #SET IPOPOS mal programada' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ex:Alarma_1102
    a ex:Alarma ;
    rdfs:label "No se admite índice para R distinto de 1" ;
    ex:identificador "1102" ;
    ex:textoExtracto "1102 'No se admite índice para R distinto de 1' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite programar el radio con R o R1. SOLUCIÓN Revisar la programación." .

ex:Alarma_1103
    a ex:Alarma ;
    rdfs:label "Función O inexistente" ;
    ex:identificador "1103" ;
    ex:textoExtracto "1103 'Función O inexistente' DETECCIÓN Durante la ejecución. CAUSA La función O no existe. SOLUCIÓN Revisar la programación." .

ex:Alarma_1104
    a ex:Alarma ;
    rdfs:label "No se admite el carácter '%' dentro del programa principal" ;
    ex:identificador "1104" ;
    ex:textoExtracto "1104 'No se admite el carácter \"%\" dentro del programa principal' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite usar el carácter \"%\" como primer carácter en la definición del nombre del programa principal o de una subrutina local. SOLUCIÓN Eliminar este carácter del programa." .

ex:Alarma_1105
    a ex:Alarma ;
    rdfs:label "Se espera operador de asignación" ;
    ex:identificador "1105" ;
    ex:textoExtracto "1105 'Se espera operador de asignación' DETECCIÓN Durante la ejecución. CAUSA Falta un operador de asignación tras la variable o parámetro. SOLUCIÓN Los operadores de asignación válidos son \"=\", \"+=\", \"-=\", \"*=\", \"/=\". " .

ex:Alarma_1106
    a ex:Alarma ;
    rdfs:label "Se espera ']'" ;
    ex:identificador "1106" ;
    ex:textoExtracto "1106 'Se espera \"]\"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada falta el corchete de cierre \"]\". SOLUCIÓN Revisar la programación." .

ex:Alarma_1107
    a ex:Alarma ;
    rdfs:label "Eje inexistente o no disponible" ;
    ex:identificador "1107" ;
    ex:textoExtracto "1107 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje que no existe o que no está disponible en el sistema o en el canal. El eje programado en una sentencia o variable no existe en el sistema o en el canal. SOLUCIÓN Comprobar que el eje programado existe en el canal y que está disponible (que no está aparcado)." .

ex:Alarma_1108
    a ex:Alarma ;
    rdfs:label "Eje doblemente programado" ;
    ex:identificador "1108" ;
    ex:textoExtracto "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución. CAUSA En alguna de las siguientes funciones hay programado algún eje más de una vez." .