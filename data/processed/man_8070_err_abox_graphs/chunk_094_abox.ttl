@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeLaProgramacionDelSegundoEjeDelPlano a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de la programación del segundo eje del plano" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDelSegundoEjeDelPlano_a9cc5ec635 ;
    ns1:textoExtracto "El segundo eje del plano debe ser uno de los tres primeros ejes del canal." .

ns1:CorreccionDeLaProgramacionDelTercerEjeDelPlano a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de la programación del tercer eje del plano" ;
    ns1:solucionaFallo ns1:EsNecesarioUnTercerEjeParaElPlanoIndice5_48f720a33f ;
    ns1:textoExtracto "Si el eje" .

ns1:SegundoEjeDelPlano_f9ed5a8d70 a ns1:Parametro ;
    rdfs:label "Segundo eje del plano" ;
    ns1:textoExtracto "(parámetro 2) es incorrecto." .

ns1:EsNecesarioUnTercerEjeParaElPlanoIndice5_48f720a33f a ns1:DiagnosticoFallo ;
    rdfs:label "Es necesario un tercer eje para el plano (índice 5)" ;
    ns1:textoExtracto "'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto." .

ns1:ProgramacionIncorrectaDelSegundoEjeDelPlano_a9cc5ec635 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del segundo eje del plano" ;
    ns1:textoExtracto "'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto." .

