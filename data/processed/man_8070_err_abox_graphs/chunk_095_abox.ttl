@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDePlano a ns1:Parametro ;
    rdfs:label "Cambio de plano" ;
    ns1:textoExtracto "'En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto.'" .

ns1:EjeFrontalDefinidoDosVecesEnElPlanoActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Eje frontal definido dos veces en el plano activo" ;
    ns1:textoExtracto "'Eje frontal (FACEAXIS) definido dos veces en el plano activo'" .

ns1:EjeLongitudinalDeLaHerramienta_f28d898c00 a ns1:Parametro ;
    rdfs:label "Eje longitudinal de la herramienta" ;
    ns1:textoExtracto "'Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5.'" .

ns1:ModificarLasDimensionesDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Modificar las dimensiones de la herramienta" ;
    ns1:solucionaFallo ns1:CompensacionDeLongitudDeHerramientaConRadioFueraDeRango_5021e9f301 ;
    ns1:textoExtracto "'SOLUCIÓN Modificar las dimensiones de la herramienta.'" .

ns1:PrimerEjeDelPlano_4ae1a5608c a ns1:Parametro ;
    rdfs:label "Primer eje del plano" ;
    ns1:textoExtracto "'El parámetro no deberá coincidir ni con el primero ni con el segundo y deberá ser uno de los tres primeros ejes del canal.'" .

ns1:SegundoEjeDelPlano_e2ad2b95b6 a ns1:Parametro ;
    rdfs:label "Segundo eje del plano" ;
    ns1:textoExtracto "'El parámetro no deberá coincidir ni con el primero ni con el segundo y deberá ser uno de los tres primeros ejes del canal.'" .

ns1:TercerEjeDelPlano_7ac75f9fed a ns1:Parametro ;
    rdfs:label "Tercer eje del plano" ;
    ns1:textoExtracto "'Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5.'" .

ns1:CompensacionDeLongitudDeHerramientaConRadioFueraDeRango_5021e9f301 a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación de longitud de herramienta con radio fuera de rango" ;
    ns1:textoExtracto "'Compensación de longitud de herramienta con radio fuera de rango'" .

