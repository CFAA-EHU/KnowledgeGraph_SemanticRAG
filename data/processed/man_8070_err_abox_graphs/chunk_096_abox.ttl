ns1:AvisoSeguridad_7c2d76d610 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para eje frontal" ;
    ns1:mitigaRiesgo ns1:Parametro_c7af37e70e ;
    ns1:textoExtracto "En el plano de trabajo sólo puede haber un eje frontal." .

ns1:ModificarLasDimensionesDeLaHerramienta a ns1:TareaMantenimiento ;
