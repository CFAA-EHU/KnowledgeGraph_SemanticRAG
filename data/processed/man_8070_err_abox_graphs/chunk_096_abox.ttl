    ns1:solucionaFallo ns1:ExcesoDeDimensionesDeHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Modificar las dimensiones de la herramienta." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:EjeNoExistenteONoDisponibleEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ValoresResultadoDeLaMedicionFueraDeRango a ns1:DiagnosticoFallo ;
