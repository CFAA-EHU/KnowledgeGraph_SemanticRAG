@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionNumeroGarra a ns1:TareaMantenimiento ;
    rdfs:label "Verificar que el número de garra programado exista" ;
    ns1:solucionaFallo ns1:ElNumeroDeGarraProgramadoNoExiste ;
    ns1:textoExtracto "SOLUCIÓN El número de garra" .

ns1:SolucionRangoValores a ns1:TareaMantenimiento ;
    rdfs:label "Verificar que el valor obtenido en la palpación esté dentro del rango permitido" ;
    ns1:solucionaFallo ns1:ElCNCHaRealizadoUnaMedicionConLaFuncionG100YLaCotaOElOffsetObtenidoEs_e5d1bf5bb2 ;
    ns1:textoExtracto "SOLUCIÓN El valor obtenido en la palpación debe estar entre -2147483647 y 2147483646." .

ns1:ElCNCHaRealizadoUnaMedicionConLaFuncionG100YLaCotaOElOffsetObtenidoEs_e5d1bf5bb2 a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha realizado una medición con la función G100 y la cota o el offset obtenido es demasiado grande."@es ;
    ns1:textoExtracto "CAUSA El CNC ha realizado una medición con la función G100 y la cota o el offset obtenido es demasiado grande." .

ns1:ElNumeroDeGarraProgramadoNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "El número de garra programado no existe" ;
    ns1:textoExtracto "'Garra inexistente' DETECCIÓN Durante la ejecución. CAUSA El número de garra programado no existe." .

