@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error1115
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1115: 'No se espera $ELSEIF'"@es ;
    ex:textoExtracto "'No se espera $ELSEIF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSEIF sin una instrucción $IF previa. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1115" .

ex:Error1116
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1116: 'La sentencia $ELSEIF <condición> se programa sola en el bloque'"@es ;
    ex:textoExtracto "'La sentencia $ELSEIF <condición> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1116" .

