ex:TareaRevisarProgramacion
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar la programación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ex:Error1115 ex:solucionaFallo ex:TareaRevisarProgramacion .
