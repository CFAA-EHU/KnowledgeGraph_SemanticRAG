@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1123 a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación: $DEFAULT no programada sola en el bloque" ;
    ex:identificador "1123" ;
    ex:textoExtracto "'La sentencia $DEFAULT se programa sola en el bloque'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ex:Fallo_1124 a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación: $ENDSWITCH inesperado" ;
    ex:identificador "1124" ;
    ex:textoExtracto "'No se espera $ENDSWITCH'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación." .

ex:Fallo_1125 a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación: $ENDSWITCH programada sola en el bloque" ;
    ex:identificador "1125" ;
    ex:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución." .