@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarDocumentacion a ns1:TareaMantenimiento ;
    rdfs:label "Consultar documentación" ;
    ns1:solucionaFallo ns1:VariableSinPermisoDeEscritura ;
    ns1:textoExtracto "Consultar en la documentación los permisos de la variable." .

ns1:DefinirVariables a ns1:TareaMantenimiento ;
    rdfs:label "Definir variables" ;
    ns1:solucionaFallo ns1:VariableDeUsuarioSinInicializar ;
    ns1:textoExtracto "Revisar la programación. Definir adecuadamente la variable." .

ns1:RevisarPermisosDeVariables a ns1:TareaMantenimiento ;
    rdfs:label "Revisar permisos de variables" ;
    ns1:solucionaFallo ns1:VariableSinPermisoDeLectura ;
    ns1:textoExtracto "Consultar en la documentación los permisos de la variable." .

ns1:ValorDeEtiquetaNFueraDeRango a ns1:AvisoSeguridad ;
    rdfs:label "Valor de etiqueta N fuera de rango" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución." .

ns1:VariableDeUsuarioSinInicializar a ns1:AvisoSeguridad ;
    rdfs:label "Variable de usuario sin inicializar" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Variable de usuario sin inicializar' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario V.P.name o V.S.name no ha sido definida." .

ns1:VariableSinPermisoDeEscritura a ns1:AvisoSeguridad ;
    rdfs:label "Variable sin permiso de escritura" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Variable sin permiso de escritura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir desde el programa pieza o MDI una variable que no tiene permiso de escritura por programa." .

ns1:VariableSinPermisoDeLectura a ns1:AvisoSeguridad ;
    rdfs:label "Variable sin permiso de lectura" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'Variable sin permiso de lectura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer desde el programa pieza o MDI una variable que no tiene permiso de lectura por programa." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

