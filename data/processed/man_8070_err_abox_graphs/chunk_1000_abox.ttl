@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteInadecuadoDelEje a ns1:DiagnosticoFallo ;
    rdfs:label "ajuste inadecuado del eje" ;
    ns1:textoExtracto "Posible ajuste inadecuado del eje, falta alguna habilitación, fallo en el motor o regulador, sistema de" .

ns1:ComponenteElectrico_363905da8b a ns1:ComponenteElectrico ;
    rdfs:label "regulador" ;
    ns1:textoExtracto "fallo en el motor o regulador, sistema de" .

ns1:ComponenteMecanico_0056c2ad8a a ns1:ComponenteMecanico ;
    rdfs:label "motor" ;
    ns1:textoExtracto "fallo en el motor o regulador, sistema de" .

ns1:ErrorDeSeguimientoPermitido a ns1:Parametro ;
    rdfs:label "error de seguimiento permitido" ;
    ns1:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)." .

ns1:ParametroG00FEED a ns1:Parametro ;
    rdfs:label "parámetro G00FEED" ;
    ns1:textoExtracto "Revisar el parámetro G00FEED." .

ns1:RevisionDelParametroG00FEED a ns1:TareaMantenimiento ;
    rdfs:label "revisión del parámetro G00FEED" ;
    ns1:solucionaFallo ns1:ErrorDeSeguimientoExcesivo ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro G00FEED." .

ns1:ErrorDeSeguimientoExcesivo a ns1:AccionProhibida ;
    rdfs:label "Error de seguimiento excesivo" ;
    ns1:textoExtracto "9709 Error de seguimiento excesivo." .

ns1:Sistema a ns1:Sistema ;
    rdfs:label "sistema" ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema." .

