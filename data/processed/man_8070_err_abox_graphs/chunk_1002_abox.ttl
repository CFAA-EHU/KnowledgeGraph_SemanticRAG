@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReducirLaFrecuenciaDeEjecucion a ns1:TareaMantenimiento ;
    rdfs:label "Reducir la frecuencia de ejecución" ;
    ns1:solucionaFallo ns1:FalloSincronizacionModulos ;
    ns1:textoExtracto "Reducir la frecuencia de ejecución de los lazos." .

ns1:RevisarParametroI0TYPE a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetro I0TYPE" ;
    ns1:solucionaFallo ns1:FalloSincronizacionModulos ;
    ns1:textoExtracto "Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." .

ns1:RevisarParametrosCNCTIMESYSTEMTIMEPOSLOOPTIME a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME" ;
    ns1:solucionaFallo ns1:FalloInicializacionParametros ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:RevisarRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar regulador" ;
    ns1:solucionaFallo ns1:FalloRegulador ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema Principal" ;
    ns1:activaAlarma ns1:FalloInicializacionParametros,
        ns1:FalloRegulador,
        ns1:FalloSincronizacionModulos,
        ns1:WarningEnDrcLoop ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema." .

ns1:WarningEnDrcLoop a ns1:AvisoSeguridad ;
    rdfs:label "Warning en DrcLoop" ;
    ns1:textoExtracto "9719 Warning en DrcLoop." .

ns1:FalloInicializacionParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de los parámetros de un eje o cabezal" ;
    ns1:textoExtracto "CAUSA Error en el chequeo de coherencia de parámetros de tiempos de ciclo o error en la inicialización de los parámetros de un eje o cabezal." .

ns1:FalloRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador" ;
    ns1:textoExtracto "9720 Error en el regulador." .

ns1:FalloSincronizacionModulos a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la sincronización entre módulos" ;
    ns1:textoExtracto "9718 Fallo en la sincronización entre módulos." .

