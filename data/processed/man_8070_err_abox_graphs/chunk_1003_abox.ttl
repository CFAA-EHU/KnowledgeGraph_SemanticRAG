@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador del sistema" ;
    ns1:solucionadoPor ns1:ResetearErroresSinSolucionarLaCausa ;
    ns1:textoExtracto "El regulador ha generado un error sin determinar." .

ns1:AdecuarCicloDeTrabajoDelMotor a ns1:TareaMantenimiento ;
    rdfs:label "Adecuar ciclo de trabajo del motor" ;
    ns1:solucionaFallo ns1:FalloSobrecargaMotor ;
    ns1:textoExtracto "SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al" .

ns1:ComponenteElectrico_993da5aaa8 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del Sistema" ;
    ns1:controladoPor ns1:SistemaPrincipal ;
    ns1:textoExtracto "Sobrecarga en el motor." .

ns1:FalloSobrecargaMotor a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor" ;
    ns1:solucionadoPor ns1:AdecuarCicloDeTrabajoDelMotor ;
    ns1:textoExtracto "Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor." .

ns1:ReguladorSistema a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del Sistema" ;
    ns1:controladoPor ns1:SistemaPrincipal ;
    ns1:textoExtracto "Error en el regulador." .

ns1:ResetearErroresSinSolucionarLaCausa a ns1:AccionProhibida ;
    rdfs:label "Resetear errores sin solucionar la causa" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema Principal" ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema." ;
    ns1:tieneComponente ns1:ComponenteElectrico_993da5aaa8,
        ns1:ReguladorSistema .

