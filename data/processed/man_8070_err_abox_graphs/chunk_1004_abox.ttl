@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AdecuarElCicloDeTrabajo a ns1:AccionProhibida ;
    rdfs:label "Adecuar el ciclo de trabajo" ;
    ns1:textoExtracto "Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un motor de mayor par." .

ns1:ComponenteElectrico_67396b933d a ns1:ComponenteElectrico ;
    rdfs:label "Motor Principal" ;
    ns1:monitoreaParametro ns1:ProteccionI2tDelMotor ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_3904b1ca1b ;
    ns1:textoExtracto "Protección I²t del motor." .

ns1:ReducirElParAplicadoAlMotor a ns1:AccionProhibida ;
    rdfs:label "Reducir el par aplicado al motor" ;
    ns1:textoExtracto "Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un motor de mayor par." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema Principal" ;
    ns1:textoExtracto "funcionamiento habitual del sistema." .

ns1:UtilizarUnMotorDeMayorPar a ns1:AccionProhibida ;
    rdfs:label "Utilizar un motor de mayor par" ;
    ns1:textoExtracto "Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un motor de mayor par." .

ns1:FalloSaturacionPar a ns1:DiagnosticoFallo ;
    rdfs:label "Error de saturación de par" ;
    ns1:textoExtracto "9723 Error de saturación de par." .

ns1:FalloSobrecargaMotor a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor" ;
    ns1:textoExtracto "9722 Sobrecarga en el motor." .

ns1:ProteccionI2tDelMotor a ns1:Parametro ;
    rdfs:label "Protección I²t del motor" ;
    ns1:textoExtracto "Protección I²t del motor." .

ns1:TareaMantenimiento_3904b1ca1b a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de ajuste del ciclo de trabajo" ;
    ns1:solucionaFallo ns1:FalloSaturacionPar,
        ns1:FalloSobrecargaMotor ;
    ns1:textoExtracto "Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un motor de mayor par." .

