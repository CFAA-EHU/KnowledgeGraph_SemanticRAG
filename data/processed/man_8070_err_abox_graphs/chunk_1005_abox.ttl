@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarCableDeCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable de captación" ;
    ns1:solucionaFallo ns1:ErrorDeVelocidadNoSuperandoGP8 ;
    ns1:textoExtracto "• Comprobar que el cable de captación no esta deteriorado y que el conexionado entre pines es correcto (especialmente si el cable ha sido confeccionado por el usuario)." .

ns1:ComprobarCablesDePotencia a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cables de potencia" ;
    ns1:solucionaFallo ns1:ErrorDeVelocidadNoSuperandoGP8 ;
    ns1:textoExtracto "• Comprobar que no existen dos fases intercambiadas y que los cables de potencia tienen un buen contacto en su amarre." .

ns1:ComprobarParametrizacionNP116 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar parametrización NP116" ;
    ns1:solucionaFallo ns1:ErrorDeVelocidadNoSuperandoGP8 ;
    ns1:textoExtracto "• Comprobar que el valor con el que se ha parametrizado NP116 (con motores no Fagor) es correcto." .

ns1:ComprobarParametrizacionRV3ORP5 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar parametrización RV3 o RP5" ;
    ns1:solucionaFallo ns1:ErrorDeVelocidadNoSuperandoGP8 ;
    ns1:textoExtracto "• El valor de RV3 (o RP5 si se dispone de resolver) es correcto." .

ns1:ErrorEnElSeguimientoDeLaRampaDeEmergenciaEnFrenada_49727b8914 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el seguimiento de la rampa de emergencia en frenada" ;
    ns1:textoExtracto "9724 Error en el seguimiento de la rampa de emergencia en frenada. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:LiberarAccionamientoYAjustarValores a ns1:TareaMantenimiento ;
    rdfs:label "Liberar accionamiento y ajustar valores" ;
    ns1:solucionaFallo ns1:ErrorDeVelocidadNoSuperandoGP8 ;
    ns1:textoExtracto "• Liberar el accionamiento y si el error se repite sin un motivo aumentar los valores de GP7 y/o GP8. Para desactivar este error y hacer que este no vuelva a presentarse, parametrizar GP7=0." .

ns1:TiempoParaSuperarGP8 a ns1:Parametro ;
    rdfs:label "Tiempo para superar GP8" ;
    ns1:identificador "GP7" ;
    ns1:textoExtracto "aumentar los valores de GP7 y/o GP8." .

ns1:VelocidadLimite a ns1:Parametro ;
    rdfs:label "Velocidad límite" ;
    ns1:identificador "GP8" ;
    ns1:textoExtracto "velocidad de giro no ha superado GP8 durante un tiempo superior a GP7." .

ns1:ErrorDeVelocidadNoSuperandoGP8 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de velocidad no superando GP8" ;
    ns1:textoExtracto "Con par motor muy elevado la velocidad de giro no ha superado GP8 durante un tiempo superior a GP7." .

