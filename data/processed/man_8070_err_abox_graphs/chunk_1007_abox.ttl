@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_20008 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando condición #WAIT FOR" ;
    ns1:identificador "20008" ;
    ns1:textoExtracto "20008 Esperando condición #WAIT FOR. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] o esperar a que se cumpla la condición."@es .

ns1:AvisoSeguridad_20009 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando señal INPOS del cabezal %x" ;
    ns1:identificador "20009" ;
    ns1:textoExtracto "20009 Esperando señal INPOS del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:AvisoSeguridad_20010 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar proceso de sincronización de cabezales" ;
    ns1:identificador "20010" ;
    ns1:textoExtracto "20010 Esperando finalizar proceso de sincronización de cabezales. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:AvisoSeguridad_20011 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando respuesta del gestor de herramientas en el canal %c" ;
    ns1:identificador "20011" ;
    ns1:requiereConsumible ns1:Herramienta_Gestor ;
    ns1:textoExtracto "20011 Esperando respuesta del gestor de herramientas en el canal %c. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Esperar a que la herramienta esté disponible, o pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:AvisoSeguridad_20012 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar paso a modo MANUAL" ;
    ns1:habilitadoPor ns1:ModoOperacion_Manual ;
    ns1:identificador "20012" ;
    ns1:textoExtracto "20012 Esperando finalizar paso a modo MANUAL del canal %c. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:AvisoSeguridad_20013 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando confirmación de gama por el PLC" ;
    ns1:identificador "20013" ;
    ns1:textoExtracto "20013 Esperando confirmación de gama por el PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe confirmar la nueva gama."@es .

ns1:AvisoSeguridad_20014 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando final de búsqueda de cero del cabezal %x" ;
    ns1:identificador "20014" ;
    ns1:textoExtracto "20014 Esperando final de búsqueda de cero del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Esperando señal INPOS del cabezal %x" .

ns1:Herramienta_Gestor a ns1:Herramienta ;
    rdfs:label "Gestor de herramientas" ;
    ns1:textoExtracto "Esperando respuesta del gestor de herramientas en el canal %c."@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo MANUAL" ;
    ns1:textoExtracto "Esperando finalizar paso a modo MANUAL del canal %c."@es .

