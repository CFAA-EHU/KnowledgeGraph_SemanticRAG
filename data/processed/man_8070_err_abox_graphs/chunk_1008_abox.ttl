@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_20014_Timeout a ns1:AvisoSeguridad ;
    rdfs:label "Timeout en búsqueda de cero del cabezal"@es ;
    ns1:documentadoEn ns1:Sistema_20014 ;
    ns1:solucionaFallo ns1:AccionProhibida_20014_Timeout ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:TareaMantenimiento_AnalisisCausas_20014 a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de causas de retraso/timeout en cabezal"@es ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:Sistema_20014 ;
    ns1:textoExtracto "analizar las causas del retraso"@es .

ns1:AccionProhibida_20014_Timeout a ns1:AccionProhibida ;
    rdfs:label "Bloqueo por timeout en búsqueda de cero"@es ;
    ns1:mitigaRiesgo ns1:InterfazUsuario_Reset ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:InterfazUsuario_Reset a ns1:InterfazUsuario ;
    rdfs:label "Botón RESET"@es ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso."@es .

ns1:Sistema_20014 a ns1:Sistema ;
    rdfs:label "Sistema de búsqueda de cero del cabezal"@es ;
    ns1:identificador "20014" ;
    ns1:textoExtracto "20014 Esperando final de búsqueda de cero del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema."@es .

