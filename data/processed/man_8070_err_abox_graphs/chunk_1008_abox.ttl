@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AdecuarElCicloDeTrabajo_ed3624057a a ns1:TareaMantenimiento ;
    rdfs:label "Adecuar el ciclo de trabajo" ;
    ns1:solucionaFallo ns1:ProteccionI2tDelRegulador ;
    ns1:textoExtracto "SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un regulador de más potencia." .

ns1:DiagnosticoFallo_9adf491e6b a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de captación en volante" ;
    ns1:textoExtracto "9731 Alarma de captación en volante. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ResetearLosErrores a ns1:TareaMantenimiento ;
    rdfs:label "Resetear los errores" ;
    ns1:solucionaFallo ns1:ErrorEnLaRPS ;
    ns1:textoExtracto "SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarLosParametrosINVERTYLOOPCH a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros INVERT y LOOPCH" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2df3a6bc34 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros INVERT y LOOPCH." .

ns1:RevisarParametrizacionYOAjusteDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parametrización y/o ajuste del sistema" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_39f4598b20 ;
    ns1:textoExtracto "SOLUCIÓN Revisar parametrización y/o ajuste del sistema." .

ns1:DiagnosticoFallo_2df3a6bc34 a ns1:DiagnosticoFallo ;
    rdfs:label "OverRun" ;
    ns1:textoExtracto "9729 OverRun. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El signo de la consigna de par y del feedback de velocidad es erróneo." .

ns1:DiagnosticoFallo_39f4598b20 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrevelocidad" ;
    ns1:textoExtracto "9728 Sobrevelocidad. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Límite de velocidad alcanzado." .

ns1:ErrorEnLaRPS a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la RPS" ;
    ns1:textoExtracto "9730 Error en la RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La RPS ha generado un error sin determinar." .

ns1:ProteccionI2tDelRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Protección I²t del regulador" ;
    ns1:textoExtracto "CAUSA Protección I²t del regulador. El ciclo de trabajo es demasiado exigente para el regulador." .

