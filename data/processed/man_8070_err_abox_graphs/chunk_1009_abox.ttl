@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeConexionYAlimentacionDelVolante a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexión y alimentación del volante" ;
    ns1:solucionaFallo ns1:FalloComunicacionDoubleATMiss ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y la alimentación del volante." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema Principal" ;
    ns1:activaAlarma ns1:Alarma_53a731f504 ;
    ns1:textoExtracto "Sistema Principal" .

ns1:Alarma_53a731f504 a ns1:Alarma ;
    rdfs:label "Alarma de captación en volante" ;
    ns1:textoExtracto "9731 Alarma de captación en volante. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:FalloComunicacionDoubleATMiss a ns1:AccionProhibida ;
    rdfs:label "Fallo en la comunicación double AT Miss" ;
    ns1:textoExtracto "9733 Fallo en la comunicación double AT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

