@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error1125
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1125: Sentencia $ENDSWITCH sin $SWITCH previa"@es ;
    ex:identificador "1125" ;
    ex:textoExtracto "El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación. 'La sentencia $ENDSWITCH se programa sola en el bloque'"@es .

ex:Error1126
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1126: Variable contador $FOR no válida"@es ;
    ex:identificador "1126" ;
    ex:textoExtracto "'$FOR: variable contador no válida' [...] SOLUCIÓN El contador de la instrucción $FOR podrá ser una variable o parámetro aritmético."@es .

ex:Error1127
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1127: Sentencia $FOR <condición> no programada sola en el bloque"@es ;
    ex:identificador "1127" ;
    ex:textoExtracto "'La sentencia $FOR <condición> se programa sola en el bloque' [...] SOLUCIÓN Revisar la programación."@es .

ex:Error1128
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1128: Demasiados caracteres en condición $FOR"@es ;
    ex:identificador "1128" ;
    ex:textoExtracto "'$FOR: demasiados caracteres en la condición' [...] SOLUCIÓN Escribir el bloque que contiene la instrucción $FOR más breve."@es ;
    ex:valor "5100"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Error1129
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1129: Instrucción $ENDFOR sin $FOR previa"@es ;
    ex:identificador "1129" ;
    ex:textoExtracto "'No se espera $ENDFOR' [...] SOLUCIÓN Revisar la programación."@es .

ex:Error1130
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1130: Sentencia $ENDFOR no programada sola en el bloque"@es ;
    ex:identificador "1130" ;
    ex:textoExtracto "'La sentencia $ENDFOR se programa sola en el bloque' [...] SOLUCIÓN Revisar la programación."@es .

ex:Error1131
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1131: Sentencia $WHILE <condición> no programada sola en el bloque"@es ;
    ex:identificador "1131" ;
    ex:textoExtracto "'La sentencia $WHILE <condición> se programa sola en el bloque' [...] SOLUCIÓN Revisar la programación."@es .

ex:Error1132
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1132: Demasiados caracteres en condición $WHILE"@es ;
    ex:identificador "1132" ;
    ex:textoExtracto "'$WHILE: demasiados caracteres en la condición' [...] SOLUCIÓN El máximo número de caracteres permitidos es 5000."@es ;
    ex:valor "5000"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Error1133
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1133: Instrucción $ENDWHILE inesperada"@es ;
    ex:identificador "1133" ;
    ex:textoExtracto "'No se espera $ENDWHILE' [...] DETECCIÓN Durante la ejecución."@es .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa."@es ;
    ex:activaAlarma ex:Error1125, ex:Error1126, ex:Error1127, ex:Error1128, ex:Error1129, ex:Error1130, ex:Error1131, ex:Error1132, ex:Error1133 .