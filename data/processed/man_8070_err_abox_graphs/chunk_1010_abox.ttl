@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_6fe447fecc a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:FalloEnLaComunicacionAT,
        ns1:FalloEnLaComunicacionDoubleATMiss_996f267050,
        ns1:FalloEnLaComunicacionMDT,
        ns1:FalloEnLaComunicacionMDTMiss,
        ns1:FalloEnLaSincronizacion ;
    ns1:textoExtracto "CNC 8070" .

ns1:RevisarLaConexionSercosIII a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión Sercos III" ;
    ns1:solucionaFallo ns1:FalloEnLaComunicacionAT,
        ns1:FalloEnLaComunicacionDoubleATMiss_996f267050,
        ns1:FalloEnLaComunicacionMDT,
        ns1:FalloEnLaComunicacionMDTMiss ;
    ns1:textoExtracto "SOLUCIÓN Revisar la conexión Sercos III. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:FalloEnLaSincronizacion a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la sincronización" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC envía un mensaje de sincronismo en cada ciclo (4 ms, normalmente) que hace que los reguladores se sincronicen." .

ns1:FalloEnLaComunicacionAT a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación AT" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador." .

ns1:FalloEnLaComunicacionDoubleATMiss_996f267050 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación double AT Miss" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador." .

ns1:FalloEnLaComunicacionMDT a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación MDT" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. Un regulador no ha respondido a los datos cíclicos enviados por el CNC." .

ns1:FalloEnLaComunicacionMDTMiss a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación MDT Miss" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. Un regulador no ha respondido a los datos cíclicos enviados por el CNC." .

