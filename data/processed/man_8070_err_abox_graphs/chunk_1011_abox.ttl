@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PresenciaDeRuidoEnLaTransmision a ns1:AccionProhibida ;
    rdfs:label "Presencia de ruido en la transmisión" ;
    ns1:textoExtracto "Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión." .

ns1:RevisionDelCableDeTransmision a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del cable de transmisión" ;
    ns1:solucionaFallo ns1:ErrorDeSincronizacionDeReguladores ;
    ns1:textoExtracto "Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión." .

ns1:ErrorDeSincronizacionDeReguladores a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sincronización de reguladores" ;
    ns1:textoExtracto "Si en algún momento los reguladores no pueden sincronizarse o pierden la sincronización, se origina este error." .

