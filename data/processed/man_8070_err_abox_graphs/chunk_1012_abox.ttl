@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_Reset_20027 a ns1:AccionProhibida ;
    rdfs:label "Pulsar [RESET] para fallo 20027"@es ;
    ns1:solucionaFallo ns1:Fallo_20027 ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:Fallo_20028 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera excedida en lazo cerrado del cabezal"@es ;
    ns1:identificador "20028" ;
    ns1:textoExtracto "Esperando pasar a lazo cerrado el cabezal"@es .

ns1:InterfazUsuario_Reset a ns1:InterfazUsuario ;
    rdfs:label "Botón [RESET]"@es ;
    ns1:textoExtracto "Pulsar [RESET]"@es .

ns1:Fallo_20027 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera excedida en lazo abierto del cabezal"@es ;
    ns1:identificador "20027" ;
    ns1:textoExtracto "Esperando pasar a lazo abierto el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

