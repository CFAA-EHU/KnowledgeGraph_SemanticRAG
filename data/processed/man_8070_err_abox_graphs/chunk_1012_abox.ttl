@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DevolucionFrenadaDelSistemaMasSuave a ns1:TareaMantenimiento ;
    rdfs:label "Devolución/frenada del sistema más suave" ;
    ns1:solucionaFallo ns1:SobrecargaEnElReguladorRPS ;
    ns1:textoExtracto "SOLUCIÓN Devolución/frenada del sistema más suave. Utilizar una RPS más potente." .

ns1:ResetearErrores a ns1:TareaMantenimiento ;
    rdfs:label "Resetear errores" ;
    ns1:solucionaFallo ns1:ErrorEnElReguladorRPS ;
    ns1:textoExtracto "SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarConexionEtherCAT a ns1:TareaMantenimiento ;
    rdfs:label "Revisar conexión EtherCAT" ;
    ns1:solucionaFallo ns1:CRCIncorrecto,
        ns1:DataLinkNoPresente,
        ns1:PaquetePerdido,
        ns1:WorkingCounterError ;
    ns1:textoExtracto "SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." .

ns1:CRCIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "CRC incorrecto" ;
    ns1:textoExtracto "9740 CRC incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado o hay interferencias en el bus. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." .

ns1:DataLinkNoPresente a ns1:DiagnosticoFallo ;
    rdfs:label "DataLink no presente" ;
    ns1:textoExtracto "9738 DataLink no presente. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado. SOLUCIÓN Revisar la conexión EtherCAT. Conectar el cable EtherCAT." .

ns1:ErrorEnElReguladorRPS a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador RPS" ;
    ns1:textoExtracto "9742 Error en el regulador RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La RPS ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:PaquetePerdido a ns1:DiagnosticoFallo ;
    rdfs:label "Paquete perdido" ;
    ns1:textoExtracto "9739 Paquete perdido. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado o algún nodo no funciona correctamente. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." .

ns1:SobrecargaEnElReguladorRPS a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el regulador RPS" ;
    ns1:textoExtracto "9743 Sobrecarga en el regulador RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error I²t en la RPS. El ciclo de trabajo de devolución es demasiado exigente para la potencia de la RPS. SOLUCIÓN Devolución/frenada del sistema más suave. Utilizar una RPS más potente." .

ns1:WorkingCounterError a ns1:DiagnosticoFallo ;
    rdfs:label "Working Counter error" ;
    ns1:textoExtracto "9741 Working Counter error. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. Funcionamiento incorrecto de algúno de los nodos. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." .

