@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PulsarRESET a ns1:TareaMantenimiento ;
    rdfs:label "Pulsar [RESET]" ;
    ns1:solucionaFallo ns1:EsperandoCondicionWAITFOR_808e9e2dfa ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El canal debe quedar libre cuando finaliza la ejecución." .

ns1:RetrasoInjustificado a ns1:AccionProhibida ;
    rdfs:label "Retraso injustificado" ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

ns1:EsperandoCondicionWAITFOR_808e9e2dfa a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando condición #WAIT FOR" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

