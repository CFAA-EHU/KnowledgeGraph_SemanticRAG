@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalisisDeCausasDeRetraso a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de causas de retraso" ;
    ns1:solucionaFallo ns1:EsperandoCondicionWAITFOR_b544cf5541,
        ns1:EsperandoConfirmacionDeGamaPorElPLC_af4f238c96,
        ns1:EsperandoFinalDeBusquedaDeCeroDelCabezal,
        ns1:EsperandoFinalizarPasoAModoMANUALDelCanal,
        ns1:EsperandoFinalizarProcesoDeSincronizacionDeCabezales_93f68583a3,
        ns1:EsperandoRespuestaDelGestorDeHerramientasEnElCanal,
        ns1:EsperandoSenalINPOSDelCabezal ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:EsperaBloqueadaPorTiempoDeterminado a ns1:AccionProhibida ;
    rdfs:label "Espera bloqueada por tiempo determinado" ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El PLC debe confirmar la nueva gama." .

ns1:EsperandoCondicionWAITFOR_b544cf5541 a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando condición #WAIT FOR" ;
    ns1:textoExtracto "20008 Esperando condición #WAIT FOR. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

ns1:EsperandoConfirmacionDeGamaPorElPLC_af4f238c96 a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando confirmación de gama por el PLC" ;
    ns1:textoExtracto "20013 Esperando confirmación de gama por el PLC. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ns1:EsperandoFinalDeBusquedaDeCeroDelCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando final de búsqueda de cero del cabezal" ;
    ns1:textoExtracto "20014 Esperando final de búsqueda de cero del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ns1:EsperandoFinalizarPasoAModoMANUALDelCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando finalizar paso a modo MANUAL del canal" ;
    ns1:textoExtracto "20012 Esperando finalizar paso a modo MANUAL del canal %c. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ns1:EsperandoFinalizarProcesoDeSincronizacionDeCabezales_93f68583a3 a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando finalizar proceso de sincronización de cabezales" ;
    ns1:textoExtracto "20010 Esperando finalizar proceso de sincronización de cabezales. DETECCIÓN Durante la ejecución." .

ns1:EsperandoRespuestaDelGestorDeHerramientasEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando respuesta del gestor de herramientas en el canal" ;
    ns1:textoExtracto "20011 Esperando respuesta del gestor de herramientas en el canal %c. DETECCIÓN Durante la ejecución." .

ns1:EsperandoSenalINPOSDelCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando señal INPOS del cabezal" ;
    ns1:textoExtracto "20009 Esperando señal INPOS del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema." .

