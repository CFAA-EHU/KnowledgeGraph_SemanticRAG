@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Error23001 a ns1:DiagnosticoFallo ;
    ns1:identificador "23001" ;
    ns1:textoExtracto "23001 Número máximo de tablas de compensación sobrepasado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Hay más tablas de compensación de las permitidas. SOLUCIÓN Reducir el número de tablas." .

ns1:Error23002 a ns1:DiagnosticoFallo ;
    ns1:identificador "23002" ;
    ns1:textoExtracto "23002 Error en la compensación volumétrica: no se ha podido alocar la memoria de los datos de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Error al alocar la memoria. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error23003 a ns1:DiagnosticoFallo ;
    ns1:identificador "23003" ;
    ns1:textoExtracto "23003 Error en el fichero de compensación volumétrica: no se ha podido analizar la línea. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica no está en el formato correcto. SOLUCIÓN Convertir el archivo de compensación volumétrica al formato correcto." .

ns1:Error23004 a ns1:DiagnosticoFallo ;
    ns1:identificador "23004" ;
    ns1:textoExtracto "23004 Error en el fichero de compensación volumétrica: el primer eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El primer eje asignado a la compensación volumétrica no es correcto. SOLUCIÓN Corregir el eje." .

ns1:Error23005 a ns1:DiagnosticoFallo ;
    ns1:identificador "23005" ;
    ns1:textoExtracto "23005 Error en el fichero de compensación volumétrica: el segundo eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El segundo eje asignado a la compensación volumétrica no es correcto. SOLUCIÓN Corregir el eje." .

ns1:Error23006 a ns1:DiagnosticoFallo ;
    ns1:identificador "23006" ;
    ns1:textoExtracto "23006 Error en el fichero de compensación volumétrica: el tercer eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El tercer eje asignado a la compensación volumétrica no es correcto. SOLUCIÓN Corregir el eje." .

ns1:Error23007 a ns1:DiagnosticoFallo ;
    ns1:identificador "23007" ;
    ns1:textoExtracto "23007 Error en el fichero de compensación volumétrica: elemento fuera del rango esperado." .

ns1:FagorAutomation a ns1:Empresa ;
    ns1:textoExtracto "Fagor Automation" .

ns1:ParametrosMaquina a ns1:Parametro ;
    ns1:textoExtracto "validación de los parámetros máquina" .

ns1:SistemaArranque a ns1:Sistema ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." .

