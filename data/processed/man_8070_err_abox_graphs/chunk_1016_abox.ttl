@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_EjeCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Tercer eje de compensación volumétrica"@es ;
    ns1:textoExtracto "CAUSA El tercer eje asignado a la compensación volumétrica no es correcto. SOLUCIÓN Corregir el eje."@es .

ns1:Sistema_ValidacionParametrosMaquina a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:activaAlarma ns1:Fallo_23007_CompensacionVolumetrica ;
    ns1:controla ns1:Parametro_ArchivoCompensacionVolumetrica ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina."@es .

ns1:Parametro_ArchivoCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Variable/elemento de archivo de compensación volumétrica"@es ;
    ns1:monitoreaParametro ns1:Fallo_23007_CompensacionVolumetrica ;
    ns1:textoExtracto "Variable o elemento del archivo de compensación volumétrica fuera de rango."@es .

ns1:Fallo_23007_CompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (23007)"@es ;
    ns1:identificador "23007" ;
    ns1:textoExtracto "23007 Error en el fichero de compensación volumétrica: elemento fuera del rango esperado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Variable o elemento del archivo de compensación volumétrica fuera de rango. SOLUCIÓN Modificar el archivo de la compensación"@es .

