@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalisisDeCausasDelRetraso a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de causas del retraso" ;
    ns1:solucionaFallo ns1:FalloEsperandoFinalBusquedaCero ;
    ns1:textoExtracto "analizar las causas del retraso." .

ns1:PulsarRESET_3a5e3e4b00 a ns1:AccionProhibida ;
    rdfs:label "Pulsar [RESET]" ;
    ns1:solucionaFallo ns1:FalloEsperandoFinalBusquedaCero ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC debe confirmar la nueva gama." .

ns1:FalloEsperandoFinalBusquedaCero a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando final de búsqueda de cero del cabezal" ;
    ns1:textoExtracto "20014 Esperando final de búsqueda de cero del cabezal %x." .

