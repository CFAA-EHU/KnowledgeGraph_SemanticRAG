@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarSenalXFERINHDelPLC a ns1:AccionProhibida ;
    rdfs:label "Activar señal XFERINH del PLC" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH." .

ns1:AnalisisDeCausasDelRetraso a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de causas del retraso" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "analizar las causas del retraso." .

ns1:EjesEnPosicion a ns1:AccionProhibida ;
    rdfs:label "Ejes en posición" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "Esperando ejes en posición." .

ns1:FinalizarFuncionG174 a ns1:AccionProhibida ;
    rdfs:label "Finalizar función G174" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "La función G174 debe finalizar." .

ns1:LlegarAlCanalOSerLiberadoPorOtro a ns1:AccionProhibida ;
    rdfs:label "Llegar al canal o ser liberado por otro" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "El eje solicitado debe llegar al canal o ser liberado por otro." .

ns1:PonerEnMarchaElCabezal a ns1:AccionProhibida ;
    rdfs:label "Poner en marcha el cabezal" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "El cabezal debe ponerse en marcha para ejecutar G33/G34/G95." .

ns1:PulsarRESET_82a686b825 a ns1:AccionProhibida ;
    rdfs:label "Pulsar [RESET]" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoEsperadoSuperado ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema." .

ns1:TiempoDeEsperaSuperado a ns1:DiagnosticoFallo ;
    rdfs:label "Tiempo de espera superado" ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

