@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SenalDeInhibicionDeTransferencia a ns1:Parametro ;
    rdfs:label "Señal de inhibición de transferencia" ;
    ns1:identificador "_XFERINH" ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:activaAlarma ns1:RetrasoDeEjes ;
    ns1:controladoPor ns1:AnalizarCausasDelRetrasoYPulsarRESET ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH." .

ns1:AnalizarCausasDelRetrasoYPulsarRESET a ns1:TareaMantenimiento ;
    rdfs:label "Analizar causas del retraso y pulsar [RESET]" ;
    ns1:solucionaFallo ns1:EsperandoEjesEnPosicion ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso." .

ns1:EsperandoEjesEnPosicion a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando ejes en posición" ;
    ns1:textoExtracto "20020 Esperando ejes en posición." .

ns1:RetrasoDeEjes a ns1:AccionProhibida ;
    rdfs:label "Retraso de ejes" ;
    ns1:textoExtracto "La espera ha superado un tiempo determinado por causa" .

