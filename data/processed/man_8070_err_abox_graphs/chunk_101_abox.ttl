@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error1133
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1133: 'No se espera $ENDWHILE'" ;
    ex:textoExtracto "1133 'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDWHILE sin una instrucción $WHILE previa. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1133" .

ex:Error1134
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1134: 'La sentencia $ENDWHILE se programa sola en el bloque'" ;
    ex:textoExtracto "1134 'La sentencia $ENDWHILE se programa sola en el bloque' DETECCIÓN Durante la" ;
    ex:identificador "1134" .

ex:Error1132
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1132: Condición $WHILE excede máximo de caracteres" ;
    ex:textoExtracto "CAUSA La condición de la instrucción $WHILE supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 5000." ;
    ex:identificador "1132" ;
    ex:valor         "5000" .  # Máximo de caracteres permitidos