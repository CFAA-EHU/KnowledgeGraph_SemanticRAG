@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarLasFuncionesEnBloquesDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Programar las funciones en bloques diferentes" ;
    ns1:solucionaFallo ns1:FuncionesGIncompatibles_cefaeeb6ae ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_f1619182fe ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_f1619182fe a ns1:DiagnosticoFallo ;
    rdfs:label "Función G inexistente" ;
    ns1:textoExtracto "'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe." .

ns1:FuncionesGIncompatibles_cefaeeb6ae a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles" ;
    ns1:textoExtracto "'Funciones G incompatibles' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí." .

