@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23018 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: parámetro SQUARENESS_IS_POSITIVE incorrecto"@es ;
    ns1:identificador "23018" ;
    ns1:monitoreaParametro ns1:Parametro_SQUARENESS_IS_POSITIVE ;
    ns1:textoExtracto "23018 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"SQUARENESS_IS_POSITIVE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"SQUARENESS_IS_POSITIVE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23019 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: parámetro INTERVAL_TYPE incorrecto"@es ;
    ns1:identificador "23019" ;
    ns1:monitoreaParametro ns1:Parametro_INTERVAL_TYPE ;
    ns1:textoExtracto "23019 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"INTERVAL_TYPE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"INTERVAL_TYPE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23020 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: parámetro VALUE_TYPE incorrecto"@es ;
    ns1:identificador "23020" ;
    ns1:monitoreaParametro ns1:Parametro_VALUE_TYPE ;
    ns1:textoExtracto "23020 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"VALUE_TYPE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"VALUE_TYPE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23021 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: coordenada del primer eje fuera del límite inferior"@es ;
    ns1:identificador "23021" ;
    ns1:textoExtracto "23021 Error en el fichero de compensación volumétrica: la coordenada del primer eje está fuera del límite inferior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del primer eje está fuera del límite inferior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error23022 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: coordenada del primer eje fuera del límite superior"@es ;
    ns1:identificador "23022" ;
    ns1:textoExtracto "23022 Error en el fichero de compensación volumétrica: la coordenada del primer eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del primer eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error23023 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica: coordenada del segundo eje fuera del límite inferior"@es ;
    ns1:identificador "23023" ;
    ns1:textoExtracto "23023 Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite inferior del volumen."@es .

