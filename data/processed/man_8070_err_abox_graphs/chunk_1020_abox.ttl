@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PulsarRESETYAnalizarLasCausasDelRetraso a ns1:TareaMantenimiento ;
    rdfs:label "Pulsar [RESET] y analizar las causas del retraso" ;
    ns1:solucionaFallo ns1:EsperandoPasarALazoAbiertoElCabezal,
        ns1:EsperandoPasarALazoCerradoEl ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:EsperandoPasarALazoAbiertoElCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando pasar a lazo abierto el cabezal" ;
    ns1:textoExtracto "20027 Esperando pasar a lazo abierto el cabezal %x." .

ns1:EsperandoPasarALazoCerradoEl a ns1:DiagnosticoFallo ;
    rdfs:label "Esperando pasar a lazo cerrado el" ;
    ns1:textoExtracto "20028 Esperando pasar a lazo cerrado el" .

