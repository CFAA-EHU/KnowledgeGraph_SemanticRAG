@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConvertirArchivoXcaV10 a ns1:AccionProhibida ;
    rdfs:label "Convertir archivo xca v1.0" ;
    ns1:solucionaFallo ns1:ErroresAlGenerarElFicheroXcaAPartirDelFicheroPxca ;
    ns1:textoExtracto "SOLUCIÓN Convertir el archivo a v2.0." .

ns1:RevisarArchivoDefgraphErrLog a ns1:TareaMantenimiento ;
    rdfs:label "Revisar archivo Defgraph-err.log" ;
    ns1:solucionaFallo ns1:ErroresAlGenerarElFicheroXcaAPartirDelFicheroPxca ;
    ns1:textoExtracto "SOLUCIÓN Revisar el archivo Defgraph-err.log para ver las causas del error." .

ns1:ErroresAlGenerarElFicheroXcaAPartirDelFicheroPxca a ns1:DiagnosticoFallo ;
    rdfs:label "Errores al generar el fichero xca a partir del fichero pxca" ;
    ns1:textoExtracto "Ha habido errores al generar el fichero xca a partir del fichero pxca. Fichero .xca no generado." .

