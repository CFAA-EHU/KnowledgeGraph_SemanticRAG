@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_23024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (eje 2, límite superior)"@es ;
    ns1:identificador "23024" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionVolumetrica_Eje2 ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del segundo eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error_23025 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (eje 3, límite inferior)"@es ;
    ns1:identificador "23025" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionVolumetrica_Eje3 ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del tercer eje está fuera del límite inferior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del tercer eje está fuera del límite inferior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error_23026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (eje 3, límite superior)"@es ;
    ns1:identificador "23026" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionVolumetrica_Eje3 ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del tercer eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del tercer eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error_23027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (unidades inconsistentes)"@es ;
    ns1:identificador "23027" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionVolumetrica_Unidades ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son iguales. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error_23028 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (unidades inválidas)"@es ;
    ns1:identificador "23028" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionVolumetrica_Unidades ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son válidas."@es .

ns1:Parametro_CompensacionVolumetrica_Eje2 a ns1:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica (eje 2)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMaquina ;
    ns1:textoExtracto "coordenada del segundo eje"@es .

ns1:Parametro_CompensacionVolumetrica_Eje3 a ns1:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica (eje 3)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMaquina ;
    ns1:textoExtracto "coordenada del tercer eje"@es .

ns1:Parametro_CompensacionVolumetrica_Unidades a ns1:Parametro ;
    rdfs:label "Unidades del fichero de compensación volumétrica"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMaquina ;
    ns1:textoExtracto "unidades del archivo de compensación volumétrica"@es .

ns1:Sistema_ControlMaquina a ns1:Sistema ;
    rdfs:label "Sistema de control de máquina"@es ;
    ns1:textoExtracto "arranque del sistema o validación de los parámetros máquina"@es .

