@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConvertirElArchivoDeCompensacionVolumetricaAlFormatoCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Convertir el archivo de compensación volumétrica al formato correcto" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetrica_b757332dca ;
    ns1:textoExtracto "SOLUCIÓN Convertir el archivo de compensación volumétrica al formato correcto." .

ns1:CorregirElPrimerEje a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el primer eje" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetricaElPrimerEjeAsignadoEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Corregir el eje." .

ns1:CorregirElSegundoEje a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el segundo eje" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetricaElSegundoEjeAsignadoEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Corregir el eje." .

ns1:CorregirElTercerEje a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el tercer eje" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetricaElTercerEjeAsignadoEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Corregir el eje." .

ns1:ErrorEnLaCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la compensación volumétrica" ;
    ns1:textoExtracto "23002 Error en la compensación volumétrica: no se ha podido alocar la memoria de los datos de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Error al alocar la memoria." .

ns1:PongaseEnContactoConFagorAutomation_176255fba4 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ReducirNumeroDeTablas a ns1:TareaMantenimiento ;
    rdfs:label "Reducir número de tablas" ;
    ns1:solucionaFallo ns1:NumeroMaximoDeTablasDeCompensacionSobrepasado ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de tablas." .

ns1:ErrorEnElFicheroDeCompensacionVolumetricaElPrimerEjeAsignadoEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el primer eje asignado es incorrecto" ;
    ns1:textoExtracto "23004 Error en el fichero de compensación volumétrica: el primer eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El primer eje asignado a la compensación volumétrica no es correcto." .

ns1:ErrorEnElFicheroDeCompensacionVolumetricaElSegundoEjeAsignadoEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el segundo eje asignado es incorrecto" ;
    ns1:textoExtracto "23005 Error en el fichero de compensación volumétrica: el segundo eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El segundo eje asignado a la compensación volumétrica no es correcto." .

ns1:ErrorEnElFicheroDeCompensacionVolumetricaElTercerEjeAsignadoEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el tercer eje asignado es incorrecto" ;
    ns1:textoExtracto "23006 Error en el fichero de compensación volumétrica: el tercer eje asignado es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El tercer eje asignado a la compensación volumétrica no es correcto." .

ns1:ErrorEnElFicheroDeCompensacionVolumetrica_b757332dca a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "23003 Error en el fichero de compensación volumétrica: no se ha podido analizar la línea. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica no está en el formato correcto." .

ns1:NumeroMaximoDeTablasDeCompensacionSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de tablas de compensación sobrepasado" ;
    ns1:textoExtracto "23001 Número máximo de tablas de compensación sobrepasado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Hay más tablas de compensación de las permitidas." .

