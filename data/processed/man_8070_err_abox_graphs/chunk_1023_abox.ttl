@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMaquina_23000 a ns1:Sistema ;
    rdfs:label "Sistema de máquina (sección 23000-23999)"@es ;
    ns1:activaAlarma ns1:ErrorCompensacionVolumetrica_23028 ;
    ns1:textoExtracto "arranque del sistema o validación de los parámetros máquina"@es .

ns1:ErrorCompensacionVolumetrica_23028 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ns1:identificador "23028" ;
    ns1:monitoreaParametro ns1:ParametroVolumetria_23028 ;
    ns1:textoExtracto "23028 Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no..."@es .

ns1:ParametroVolumetria_23028 a ns1:Parametro ;
    rdfs:label "Unidades del fichero de volumetría"@es ;
    ns1:textoExtracto "error en las unidades del fichero de volumetría"@es ;
    ns1:valor "no válidas"@es .

