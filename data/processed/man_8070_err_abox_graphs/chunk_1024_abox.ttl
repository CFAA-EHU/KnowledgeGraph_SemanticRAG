@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: valor incorrecto de 'HEADER:COUNT'"@es ;
    ns1:identificador "23029" ;
    ns1:monitoreaParametro ns1:Parametro_HEADER_COUNT ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"HEADER:COUNT\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"HEADER:COUNT\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: unidades no válidas"@es ;
    ns1:identificador "23030" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son válidas. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23031 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: intervalos no constantes"@es ;
    ns1:identificador "23031" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: los intervalos de los puntos no son constantes. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los intervalos de los puntos no son constantes. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: puntos en orden incorrecto"@es ;
    ns1:identificador "23032" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: los puntos del fichero de volumetría no están en el orden esperado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos no están en el orden esperado. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23033 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: intervalo negativo"@es ;
    ns1:identificador "23033" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el intervalo es negativo. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El intervalo es negativo. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ns1:Error23034 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: valor incorrecto de 'AXIS_BEGIN'"@es ;
    ns1:identificador "23034" ;
    ns1:monitoreaParametro ns1:Parametro_AXIS_BEGIN ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina."@es .

ns1:SistemaValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina"@es .

ns1:Parametro_AXIS_BEGIN a ns1:Parametro ;
    rdfs:label "Parámetro AXIS_BEGIN"@es ;
    ns1:identificador "AXIS_BEGIN" ;
    ns1:textoExtracto "el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto"@es .

ns1:Parametro_HEADER_COUNT a ns1:Parametro ;
    rdfs:label "Parámetro HEADER:COUNT"@es ;
    ns1:identificador "HEADER:COUNT" ;
    ns1:textoExtracto "el valor del parámetro del fichero \"HEADER:COUNT\" es incorrecto"@es .

