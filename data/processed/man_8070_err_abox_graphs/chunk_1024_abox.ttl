@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirElEje a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el eje" ;
    ns1:solucionaFallo ns1:ErrorEnElEjeAsignadoALaCompensacionVolumetrica ;
    ns1:textoExtracto "SOLUCIÓN Corregir el eje." .

ns1:ModificarElArchivoDeLaCompensacion a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el archivo de la compensación" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetrica_f92468c245 ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación" .

ns1:ErrorEnElEjeAsignadoALaCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el eje asignado a la compensación volumétrica" ;
    ns1:textoExtracto "CAUSA El tercer eje asignado a la compensación volumétrica no es correcto." .

ns1:ErrorEnElFicheroDeCompensacionVolumetrica_f92468c245 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "23007 Error en el fichero de compensación volumétrica: elemento fuera del rango esperado." .

