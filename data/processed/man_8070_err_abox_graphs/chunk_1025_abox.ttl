@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarElArchivoDeLaCompensacionVolumetrica a ns1:AccionProhibida ;
    rdfs:label "Modificar el archivo de la compensación volumétrica" ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:ModificarElValorMinimoOMaximoDelArchivoDeCompensacion a ns1:AccionProhibida ;
    rdfs:label "Modificar el valor mínimo o máximo del archivo de compensación" ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor mínimo o máximo del archivo de compensación." .

ns1:ModificarLasCoordenadasParaQueEstenDentroDelVolumenDeCompensacion a ns1:AccionProhibida ;
    rdfs:label "Modificar las coordenadas para que estén dentro del volumen de compensación" ;
    ns1:textoExtracto "SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación." .

ns1:ModificarLosPuntosDelArchivoDeLaCompensacionVolumetrica a ns1:AccionProhibida ;
    rdfs:label "Modificar los puntos del archivo de la compensación volumétrica" ;
    ns1:textoExtracto "SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica." .

ns1:TareaMantenimiento_10db4dc41c a ns1:TareaMantenimiento ;
    rdfs:label "Tarea para modificar el valor mínimo o máximo del archivo de compensación" ;
    ns1:solucionaFallo ns1:FalloError23012 ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor mínimo o máximo del archivo de compensación." .

ns1:TareaMantenimiento_855bcf8614 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea para modificar las coordenadas para que estén dentro del volumen de compensación" ;
    ns1:solucionaFallo ns1:FalloError23010,
        ns1:FalloError23011 ;
    ns1:textoExtracto "SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación." .

ns1:TareaMantenimiento_9d4eceae23 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea para modificar los puntos del archivo de la compensación volumétrica" ;
    ns1:solucionaFallo ns1:FalloError23009,
        ns1:FalloError23010,
        ns1:FalloError23011 ;
    ns1:textoExtracto "SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica." .

ns1:TareaMantenimiento_ae4b15a5d8 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea para modificar el archivo de la compensación volumétrica" ;
    ns1:solucionaFallo ns1:FalloError23008 ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:FalloError23008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría" ;
    ns1:textoExtracto "23008 Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría." .

ns1:FalloError23009 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: los parámetros de 'SQUARENESS' no tienen puntos contiguos" ;
    ns1:textoExtracto "23009 Error en el fichero de compensación volumétrica: los parámetros de 'SQUARENESS' no tienen puntos contiguos." .

ns1:FalloError23012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo" ;
    ns1:textoExtracto "23012 Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo." .

ns1:FalloError23010 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación" ;
    ns1:textoExtracto "23010 Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación." .

ns1:FalloError23011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación" ;
    ns1:textoExtracto "23011 Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación." .

