@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarElArchivoDeLaCompensacionVolumetrica a ns1:AccionProhibida ;
    rdfs:label "Modificar el archivo de la compensación volumétrica" ;
    ns1:solucionaFallo ns1:ErrorEnElFicheroDeCompensacionVolumetrica_48ada22315 ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:ErrorEnElFicheroDeCompensacionVolumetrica_48ada22315 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "23018 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"SQUARENESS_IS_POSITIVE\" es incorrecto." .

