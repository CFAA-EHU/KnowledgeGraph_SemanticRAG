@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Principal a ns1:Maquina ;
    rdfs:label "máquina"@es ;
    ns1:activaAlarma ns1:Error_23040 ;
    ns1:textoExtracto "parámetros máquina"@es ;
    ns1:tieneComponente ns1:Sistema_CNC .

ns1:Parametro_CompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "parámetro de compensación volumétrica"@es ;
    ns1:monitoreaParametro ns1:Error_23040 ;
    ns1:textoExtracto "fichero de definición de la compensación volumétrica"@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "sistema CNC"@es ;
    ns1:activaAlarma ns1:Error_23040 ;
    ns1:textoExtracto "arranque del CNC"@es ;
    ns1:tieneComponente ns1:Parametro_CompensacionVolumetrica .

ns1:Error_23040 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ns1:identificador "23040" ;
    ns1:textoExtracto "23040 Error en el fichero de compensación volumétrica: no se puede abrir el fichero de volumetría."@es .

