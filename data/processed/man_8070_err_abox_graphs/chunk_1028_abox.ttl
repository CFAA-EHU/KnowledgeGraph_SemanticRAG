@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetricaINTERVALTYPE a ns1:Parametro ;
    rdfs:label "Compensación volumétrica INTERVAL_TYPE" ;
    ns1:identificador "INTERVAL_TYPE" ;
    ns1:textoExtracto "el valor del parámetro del fichero \"INTERVAL_TYPE\" es incorrecto." .

ns1:CompensacionVolumetricaSQUARENESSISPOSITIVE a ns1:Parametro ;
    rdfs:label "Compensación volumétrica SQUARENESS_IS_POSITIVE" ;
    ns1:identificador "SQUARENESS_IS_POSITIVE" ;
    ns1:textoExtracto "el valor del parámetro del fichero \"SQUARENESS_IS_POSITIVE\" es incorrecto." .

ns1:CompensacionVolumetricaVALUETYPE a ns1:Parametro ;
    rdfs:label "Compensación volumétrica VALUE_TYPE" ;
    ns1:identificador "VALUE_TYPE" ;
    ns1:textoExtracto "el valor del parámetro del fichero \"VALUE_TYPE\" es incorrecto." .

ns1:FalloCoordenadaFueraLimiteInferior a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: coordenada fuera del límite inferior" ;
    ns1:solucionaFallo ns1:ModificarArchivoDeCompensacionVolumetrica_3b082828d0 ;
    ns1:textoExtracto "la coordenada del primer eje está fuera del límite inferior del volumen." .

ns1:FalloCoordenadaFueraLimiteSuperior a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: coordenada fuera del límite superior" ;
    ns1:solucionaFallo ns1:ModificarArchivoDeCompensacionVolumetrica_3b082828d0 ;
    ns1:textoExtracto "la coordenada del primer eje está fuera del límite superior del volumen." .

ns1:FalloParametroIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: parámetro incorrecto" ;
    ns1:solucionaFallo ns1:ModificarArchivoDeCompensacionVolumetrica_3b082828d0 ;
    ns1:textoExtracto "el valor del parámetro del fichero es incorrecto." .

ns1:ModificarArchivoDeCompensacionVolumetrica_3b082828d0 a ns1:AccionProhibida ;
    rdfs:label "Modificar archivo de compensación volumétrica" ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

