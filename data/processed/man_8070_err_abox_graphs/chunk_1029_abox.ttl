@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_FormatoFicheroInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Formato de fichero inválido en compensación volumétrica" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El fichero no es del tipo csv. El formato del fichero definido en VCOMPFILE no es correcto."@es .

ns1:DiagnosticoFallo_PuntosFicheroIncompletos a ns1:DiagnosticoFallo ;
    rdfs:label "Fichero de compensación volumétrica con puntos incompletos" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El fichero definido en VCOMPFILE no tiene definidos todos los puntos."@es .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ns1:identificador "NPOINTSAX3" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto."@es .

