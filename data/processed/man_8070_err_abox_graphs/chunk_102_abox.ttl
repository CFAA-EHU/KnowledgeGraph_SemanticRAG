@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarLasFuncionesEnBloquesDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Programar las funciones en bloques diferentes."@es ;
    ns1:solucionaFallo ns1:FuncionesGIncompatiblesG54G59G159_9373e1ef4e,
        ns1:FuncionesGIncompatiblesG5G7G50G60G61_2ab7136893 ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:FuncionesGIncompatiblesG54G59G159_9373e1ef4e a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G54-G59/G159)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G54-G59/G159)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG5G7G50G60G61_2ab7136893 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G5/G7/G50/G60/G61)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G5/G7/G50/G60/G61)' DETECCIÓN Durante la ejecución. CAUSA" .

