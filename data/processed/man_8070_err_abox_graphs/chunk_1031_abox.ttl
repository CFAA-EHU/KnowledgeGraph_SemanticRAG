@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificacionDelArchivoDeCompensacion a ns1:TareaMantenimiento ;
    rdfs:label "Modificación del archivo de compensación" ;
    ns1:solucionaFallo ns1:FalloErrorFicheroCompensacion ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación" .

ns1:FalloErrorFicheroCompensacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "23028 Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría." .

