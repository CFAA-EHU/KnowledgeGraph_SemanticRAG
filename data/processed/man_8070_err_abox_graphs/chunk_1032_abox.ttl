    rdfs:label "Modificar el archivo de la compensación volumétrica" ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:Parametro_6fa3f6c2a2 a ns1:Parametro ;
    rdfs:label "Parámetro HEADER:COUNT incorrecto" ;
