@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_23152 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23152: Nombre de tabla demasiado largo"@es ;
    ns1:identificador "23152" ;
    ns1:mitigaRiesgo ns1:TablaParametrosMaquina_23152 ;
    ns1:monitoreaParametro ns1:VariableNombreTabla_23152 ;
    ns1:textoExtracto "23152 Nombre de tabla demasiado largo. DETECCIÓN Durante la ejecución. CAUSA El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo. SOLUCIÓN El..."@es .

ns1:TablaParametrosMaquina_23152 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina (feedback, motor, tandem, etc.)"@es ;
    ns1:textoExtracto "tabla de parámetros máquina (feedback, motor, tandem, etc)"@es .

ns1:VariableNombreTabla_23152 a ns1:Parametro ;
    rdfs:label "Variable de nombre de tabla"@es ;
    ns1:textoExtracto "nombre indicado en la variable"@es ;
    ns1:valor "nombre de tabla"@es .

