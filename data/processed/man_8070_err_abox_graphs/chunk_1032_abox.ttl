    ns1:textoExtracto "El parámetro \"HEADER:COUNT\" es incorrecto." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." .

