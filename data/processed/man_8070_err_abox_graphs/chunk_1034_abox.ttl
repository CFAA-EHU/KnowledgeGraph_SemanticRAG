@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarElValorDelRangoALaDiferenciaEntreElValorMaximoYMinimo a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar el valor del rango a la diferencia entre el valor máximo y mínimo" ;
    ns1:solucionaFallo ns1:ValorDelRangoInvalidoEnElFicheroDeCompensacionVolumetrica ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el valor del rango a la diferencia entre el valor máximo y el mínimo." .

ns1:ModificarArchivoDeCompensacionVolumetrica_578f48a6f6 a ns1:TareaMantenimiento ;
    rdfs:label "Modificar archivo de compensación volumétrica" ;
    ns1:solucionaFallo ns1:ErrorEnElParametroAXISBEGIN,
        ns1:ErrorEnElParametroAXISEND,
        ns1:ErrorEnElParametroAXISLENGTH ;
    ns1:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:PonerComoValorMaximoEnElFicheroElValorMaximoDeLaTabla a ns1:TareaMantenimiento ;
    rdfs:label "Poner como valor máximo en el fichero, el valor máximo de la tabla" ;
    ns1:solucionaFallo ns1:ValorMaximoSobrepasadoEnElFicheroDeCompensacionVolumetrica,
        ns1:ValorMinimoSobrepasadoEnElFicheroDeCompensacionVolumetrica ;
    ns1:textoExtracto "SOLUCIÓN Poner como valor máximo en el fichero, el valor máximo de la tabla." .

ns1:ErrorEnElParametroAXISBEGIN a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el parámetro AXIS_BEGIN" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"AXIS_BEGIN\" es incorrecto." .

ns1:ErrorEnElParametroAXISEND a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el parámetro AXIS_END" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"AXIS_END\" es incorrecto." .

ns1:ErrorEnElParametroAXISLENGTH a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el parámetro AXIS_LENGTH" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"AXIS_LENGTH\" es incorrecto." .

ns1:ValorDelRangoInvalidoEnElFicheroDeCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Valor del rango inválido en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados." .

ns1:ValorMaximoSobrepasadoEnElFicheroDeCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Valor máximo sobrepasado en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados." .

ns1:ValorMinimoSobrepasadoEnElFicheroDeCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Valor mínimo sobrepasado en el fichero de compensación volumétrica" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados." .

