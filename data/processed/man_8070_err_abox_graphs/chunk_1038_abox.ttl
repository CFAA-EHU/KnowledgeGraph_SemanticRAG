@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaDiagnosis a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis" ;
    ns1:ilustradoEn ns1:ModoDiagnosis ;
    ns1:monitoreaParametro ns1:FalloBus_24500,
        ns1:FalloTensionUM_24501 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:ErrorNodo_CNC a ns1:DiagnosticoFallo ;
    rdfs:label "Error en nodo CNC" ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error en un nodo. SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

ns1:FalloBus_24500 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del bus (24500)" ;
    ns1:identificador "24500" ;
    ns1:textoExtracto "24500 Se ha quitado el fallo del bus. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo del bus corregida. SOLUCIÓN No requiere ninguna acción." .

ns1:FalloTensionUM_24501 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa (24501)" ;
    ns1:identificador "24501" ;
    ns1:textoExtracto "24501 Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT" .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:mitigaRiesgo ns1:ErrorNodo_CNC ;
    ns1:textoExtracto "SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

