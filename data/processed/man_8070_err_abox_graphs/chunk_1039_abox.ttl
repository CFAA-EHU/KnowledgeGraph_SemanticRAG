@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetrica_e5bc926181 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ns1:textoExtracto "(parámetros VOLCOMP)" .

ns1:DefinirUnaCompensacionVolumetricaAdecuadaEnLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Definir una compensación volumétrica adecuada en los parámetros máquina" ;
    ns1:solucionaFallo ns1:NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes ;
    ns1:textoExtracto "SOLUCIÓN Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)" .

ns1:ElNombreONumeroIndicadoEnLaVariableDebeSerUnaTablaValida a ns1:TareaMantenimiento ;
    rdfs:label "El nombre o número indicado en la variable debe ser una tabla válida" ;
    ns1:solucionaFallo ns1:NumeroDeTablaInexistente ;
    ns1:textoExtracto "SOLUCIÓN El nombre o número indicado en la variable debe ser una tabla válida." .

ns1:NombreDeTabla a ns1:Parametro ;
    rdfs:label "Nombre de tabla" ;
    ns1:textoExtracto "El nombre o número de tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe." .

ns1:NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes'" .

ns1:NumeroDeTablaInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Número de tabla inexistente" ;
    ns1:textoExtracto "23151 Número de tabla inexistente." .

