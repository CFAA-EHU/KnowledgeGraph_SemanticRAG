@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnadirUnFicheroValido a ns1:TareaMantenimiento ;
    rdfs:label "Añadir un fichero válido" ;
    ns1:solucionaFallo ns1:ErrorEnElAnalisisDelFicheroDeDefinicionDeLaCompensacionVolumetrica_bd9c116598,
        ns1:FicheroDeCompensacionVolumetricaInvalido ;
    ns1:textoExtracto "SOLUCIÓN Añadir un fichero válido." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:CompensacionVolumetricaArchivo a ns1:Parametro ;
    rdfs:label "Compensación volumétrica archivo" ;
    ns1:textoExtracto "El archivo de la compensación volumétrica (parámetro VCOMPFILE)" .

ns1:ElNombreIndicadoEnLaVariableDebeSerUnaTablaValida a ns1:DiagnosticoFallo ;
    rdfs:label "El nombre indicado en la variable debe ser una tabla válida" ;
    ns1:solucionaFallo ns1:NombreDeLaTablaDeParametrosMaquinaInvalido ;
    ns1:textoExtracto "SOLUCIÓN El nombre indicado en la variable debe ser una tabla válida." .

ns1:ErrorEnElAnalisisDelFicheroDeDefinicionDeLaCompensacionVolumetrica_bd9c116598 a ns1:AccionProhibida ;
    rdfs:label "Error en el análisis del fichero de definición de la compensación volumétrica" ;
    ns1:textoExtracto "Error en el análisis del fichero de definición de la compensación volumétrica." .

ns1:FicheroDeCompensacionVolumetricaInvalido a ns1:AccionProhibida ;
    rdfs:label "Fichero de compensación volumétrica inválido" ;
    ns1:textoExtracto "El archivo de la compensación volumétrica (parámetro VCOMPFILE) está vacío o no tiene el formato adecuado." .

ns1:NombreDeLaTablaDeParametrosMaquinaInvalido a ns1:AccionProhibida ;
    rdfs:label "Nombre de la tabla de parámetros máquina inválido" ;
    ns1:textoExtracto "El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo." .

