@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConectarElCableDeEtherCAT a ns1:TareaMantenimiento ;
    rdfs:label "Conectar el cable de EtherCAT" ;
    ns1:solucionaFallo ns1:EtherCATDatalinkNoPresente ;
    ns1:textoExtracto "SOLUCIÓN Conectar el cable de EtherCAT." .

ns1:CopiarEnMtbDataElFicheroENIDeConfiguracionDeLaRedEtherCAT a ns1:TareaMantenimiento ;
    rdfs:label "Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT" ;
    ns1:solucionaFallo ns1:EtherCATFicheroENIDeConfiguracionNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT. El archivo se debe llamar fagor_ethercatConfFile.xml." .

ns1:EtherCATCRCIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: CRC Incorrecto" ;
    ns1:solucionaFallo ns1:RevisarElConexionadoYElEstadoDeLosEsclavos ;
    ns1:textoExtracto "24003 EtherCAT: CRC Incorrecto. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o hay interferancias en el bus. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:EtherCATFicheroDeRutadoNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Fichero de rutado no existe" ;
    ns1:textoExtracto "24020 EtherCAT: Fichero de rutado no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor." .

ns1:EtherCATFormatoDeFicheroENIDeConfiguracionIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Formato de fichero ENI de configuración incorrecto" ;
    ns1:solucionaFallo ns1:RevisarElConexionadoYElEstadoDeLosEsclavos ;
    ns1:textoExtracto "24011 EtherCAT: Formato de fichero ENI de configuración incorrecto. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero ENI de configuración de la red EtherCAT tiene un formato ilegible para el CNC." .

ns1:EtherCATWorkingCounterError a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Working Counter error" ;
    ns1:solucionaFallo ns1:RevisarElConexionadoYElEstadoDeLosEsclavos ;
    ns1:textoExtracto "24004 EtherCAT: Working Counter error. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Funcionamiento incorrecto de alguno de los esclavos de EtherCAT. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:EtherCATDatalinkNoPresente a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Datalink no presente" ;
    ns1:textoExtracto "24001 EtherCAT: Datalink no presente. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El cable EtherCAT está desconectado. SOLUCIÓN Conectar el cable de EtherCAT." .

ns1:EtherCATFicheroENIDeConfiguracionNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Fichero ENI de configuración no existe" ;
    ns1:textoExtracto "24010 EtherCAT: Fichero ENI de configuración no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero ENI de configuración de la red EtherCAT. SOLUCIÓN Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT." .

ns1:EtherCATPaquetePerdido a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Paquete perdido" ;
    ns1:textoExtracto "24002 EtherCAT: Paquete perdido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o algún esclavo no funciona correctamente. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:RevisarElConexionadoYElEstadoDeLosEsclavos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado y el estado de los esclavos" ;
    ns1:solucionaFallo ns1:EtherCATPaquetePerdido ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

