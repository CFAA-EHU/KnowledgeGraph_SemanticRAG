@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaDiagnosis a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ns1:monitoreaParametro ns1:Error24522,
        ns1:Error24523,
        ns1:Error24524,
        ns1:Error24525,
        ns1:Error24526,
        ns1:Error24527 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ns1:tieneComponente ns1:ModuloLocalbus .

ns1:Error24522 a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo %u"@es ;
    ns1:identificador "24522" ;
    ns1:textoExtracto "24522 Error periférico en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error24523 a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo %u se ha quitado"@es ;
    ns1:identificador "24523" ;
    ns1:textoExtracto "24523 Error periférico en el módulo %u se ha quitado. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es .

ns1:Error24524 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración incorrecta del módulo localbus"@es ;
    ns1:identificador "24524" ;
    ns1:textoExtracto "24524 La configuración del módulo localbus no coincide con el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error24525 a ns1:DiagnosticoFallo ;
    rdfs:label "Iniciar sistema restante no permitido"@es ;
    ns1:identificador "24525" ;
    ns1:textoExtracto "24525 Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error24526 a ns1:DiagnosticoFallo ;
    rdfs:label "Reconfiguración del bus local solicitada"@es ;
    ns1:identificador "24526" ;
    ns1:textoExtracto "24526 La aplicación solicitó una reconfiguración del bus local. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error24527 a ns1:DiagnosticoFallo ;
    rdfs:label "Iniciar sistema restante con módulos faltantes"@es ;
    ns1:identificador "24527" ;
    ns1:textoExtracto "24527 Comenzar con el sistema restante, %u módulos esperados, encontrados %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda"@es .

ns1:ModuloLocalbus a ns1:ComponenteElectrico ;
    rdfs:label "Módulo localbus"@es ;
    ns1:textoExtracto "La configuración del módulo localbus no coincide con el módulo %u."@es .

