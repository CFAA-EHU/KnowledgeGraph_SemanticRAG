@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2a545a2244 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error durante el proceso de rutado de recursos EtherCAT" ;
    ns1:mitigaRiesgo ns1:UsarVersionIncompatiblesDeLaAplicacionFagorEtherCATMapper ;
    ns1:textoExtracto "24022 EtherCAT: Error durante el proceso de rutado de recursos. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:AvisoSeguridad_e33319971d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de formato incorrecto del fichero EtherCAT" ;
    ns1:mitigaRiesgo ns1:GenerarUnFicheroDeRutadoIncorrecto ;
    ns1:textoExtracto "24021 EtherCAT: Formato del fichero de rutado incorrecto. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:CNC8070_0e979c837a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "desde el sistema CNC-PLC Fagor." .

ns1:RevisionDelFicheroDeRutado a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del fichero de rutado" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "SOLUCIÓN Revisar el fichero." .

ns1:GenerarUnFicheroDeRutadoIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Generar un fichero de rutado incorrecto" ;
    ns1:textoExtracto "El fichero de rutado (mapeo) de los recursos EtherCAT tiene un formato ilegible para CNC. El fichero puede estar incompleto o corrupto." .

ns1:UsarVersionIncompatiblesDeLaAplicacionFagorEtherCATMapper a ns1:AccionProhibida ;
    rdfs:label "Usar versión incompatibles de la aplicación Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "La versión de la aplicación Fagor EtherCAT Mapping es incompatible con la versión del CNC." .

