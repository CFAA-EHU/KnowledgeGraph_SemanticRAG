@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo"@es ;
    ns1:documentadoEn ns1:Error_24555,
        ns1:Error_24556,
        ns1:Error_24557,
        ns1:Error_24558,
        ns1:Error_24559 ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:PantallaDiagnosis a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ns1:monitoreaParametro ns1:Error_24555,
        ns1:Error_24556,
        ns1:Error_24557,
        ns1:Error_24558,
        ns1:Error_24559 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24555,
        ns1:Error_24556,
        ns1:Error_24557,
        ns1:Error_24558,
        ns1:Error_24559 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24555 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24555: Módulo con versión de chip no soportada"@es ;
    ns1:identificador "24555" ;
    ns1:textoExtracto "Se encontró un módulo con una versión de chip no soportada. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24556 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24556: Módulo de fabricante no soportado"@es ;
    ns1:identificador "24556" ;
    ns1:textoExtracto "Encontró un módulo del fabricante del dispositivo no soportado. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24557 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24557: Error grave en módulo localbus"@es ;
    ns1:identificador "24557" ;
    ns1:textoExtracto "Error grave en el módulo localbus. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24558 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24558: Error de hardware o firmware"@es ;
    ns1:identificador "24558" ;
    ns1:textoExtracto "Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24559 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24559: Error de hardware o firmware"@es ;
    ns1:identificador "24559" ;
    ns1:textoExtracto "Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

