@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarElModoDiagnosisParaObtenerMasInformacion a ns1:TareaMantenimiento ;
    rdfs:label "Consultar el modo diagnosis para obtener más información" ;
    ns1:solucionaFallo ns1:EtherCATErrorEnNodo ;
    ns1:textoExtracto "SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

ns1:ErrorEnUnNodoDelBusEtherCAT a ns1:AccionProhibida ;
    rdfs:label "Error en un nodo del bus EtherCAT" ;
    ns1:textoExtracto "Error en un nodo." .

ns1:EtherCATErrorDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Error desconocido" ;
    ns1:textoExtracto "Error de causa desconocida en el bus EtherCAT." .

ns1:OpcionDeSoftwareNoPermitida_006bd29951 a ns1:AccionProhibida ;
    rdfs:label "Opción de software no permitida" ;
    ns1:textoExtracto "La inicialización de EtherCAT ha detectado algún nodo no Fagor y no está activa la opción de software para conectar nodos de terceros." .

ns1:PongaseEnContactoConFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorDesconocidoEnElBusEtherCAT,
        ns1:VersionDeLaAplicacionFagorEtherCATMappingIncompatibleConLaVersionDelCNC ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:QuitarLosNodosNoFagorDelBusEtherCATOContratarLaOpcionDeSoftwareParaNo_eb0e630b33 a ns1:TareaMantenimiento ;
    rdfs:label "Quitar los nodos no Fagor del bus EtherCAT o contratar la opción de software para nodos de terceros" ;
    ns1:solucionaFallo ns1:EtherCATNodosEtherCATNoFagor ;
    ns1:textoExtracto "SOLUCIÓN Quitar los nodos no Fagor del bus EtherCAT o contratar la opción de software para nodos de terceros." .

ns1:ErrorDesconocidoEnElBusEtherCAT a ns1:AccionProhibida ;
    rdfs:label "Error desconocido en el bus EtherCAT" ;
    ns1:textoExtracto "Error de causa desconocida en el bus EtherCAT." .

ns1:EtherCATErrorEnNodo a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Error en nodo" ;
    ns1:textoExtracto "Error en un nodo." .

ns1:EtherCATNodosEtherCATNoFagor a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Nodos EtherCAT no Fagor" ;
    ns1:textoExtracto "La inicialización de EtherCAT ha detectado algún nodo no Fagor y no está activa la opción de software para conectar nodos de terceros." .

ns1:VersionDeLaAplicacionFagorEtherCATMappingIncompatibleConLaVersionDelCNC a ns1:AccionProhibida ;
    rdfs:label "Versión de la aplicación Fagor EtherCAT Mapping incompatible con la versión del CNC" ;
    ns1:textoExtracto "La versión de la aplicación Fagor EtherCAT Mapping es incompatible con la versión del CNC." .

