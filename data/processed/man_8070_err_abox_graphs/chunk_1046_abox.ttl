@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarModoDiagnosis a ns1:TareaMantenimiento ;
    rdfs:label "Consultar modo diagnosis" ;
    ns1:solucionaFallo ns1:ErrorEnUnNodo ;
    ns1:textoExtracto "SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

ns1:SeHaQuitadoElFalloDelBus a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha quitado el fallo del bus" ;
    ns1:textoExtracto "24500 Se ha quitado el fallo del bus. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo del bus corregida." .

ns1:TensionDeAlimentacionUMDefectuosa_f98607d3b3 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa" ;
    ns1:textoExtracto "24501 Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:ErrorEnUnNodo a ns1:DiagnosticoFallo ;
    rdfs:label "Error en un nodo" ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error en un nodo." .

