@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaDiagnosis a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ns1:tieneComponente ns1:NodoEtherCAT .

ns1:Error_24565 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24565: Fallo de activación del bus local"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24565" ;
    ns1:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24566 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24566: Fallo de activación del bus local"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24566" ;
    ns1:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24567 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24567: Módulo localbus perdido"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24567" ;
    ns1:textoExtracto "Módulo %u localbus perdido. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24568 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24568: Nuevo módulo localbus añadido"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24568" ;
    ns1:textoExtracto "Nuevo módulo %u localbus añadido. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24569 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24569: Módulo de bus local en posición incorrecta"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24569" ;
    ns1:textoExtracto "Módulo %u de bus local en posición incorrecta. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:NodoEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Nodo EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24565,
        ns1:Error_24566,
        ns1:Error_24567,
        ns1:Error_24568,
        ns1:Error_24569 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

