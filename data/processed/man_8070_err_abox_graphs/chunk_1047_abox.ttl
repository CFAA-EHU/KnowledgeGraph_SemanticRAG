ns1:ConsultarManualEspecificoDelNodo_14018a18f4 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:ReinicioDelDispositivoDespuesDelWatchdog_d9274c3068,
        ns1:TensionDeAlimentacionULDefectuosa_dc387f46c0,
        ns1:TensionDeAlimentacionUMDefectuosa_7aea054c17,
        ns1:TensionDeAlimentacionUSDefectuosa_f447842b4b ;
    ns1:textoExtracto "SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

