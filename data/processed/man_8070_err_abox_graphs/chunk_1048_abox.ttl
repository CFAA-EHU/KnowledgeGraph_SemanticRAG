@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AplicacionEnElModuloUNoListo a ns1:AccionProhibida ;
    rdfs:label "Aplicación en el módulo %u no listo" ;
    ns1:textoExtracto "24512 Aplicación en el módulo %u no listo." .

ns1:ConsultarManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:EmergenciaEtherCAT ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:MasDispositivosDeLosEsperados a ns1:AccionProhibida ;
    rdfs:label "Más dispositivos de los esperados" ;
    ns1:textoExtracto "24511 Más dispositivos de los esperados." .

ns1:ModuloIncorrectoEncontradoEnLaPosicionU a ns1:AccionProhibida ;
    rdfs:label "Módulo incorrecto encontrado en la posición %u" ;
    ns1:textoExtracto "24510 Módulo incorrecto encontrado en la posición %u." .

ns1:NoSeHaEncontradoNingunModulo a ns1:AccionProhibida ;
    rdfs:label "No se ha encontrado ningún módulo" ;
    ns1:textoExtracto "24509 No se ha encontrado ningún módulo." .

ns1:EmergenciaEtherCAT a ns1:DiagnosticoFallo ;
    rdfs:label "Emergencia EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

