@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_24569 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u de bus local en posición incorrecta"@es ;
    ns1:activaAlarma ns1:InterfazDiagnostico ;
    ns1:identificador "24569" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "Módulo %u de bus local en posición incorrecta. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

