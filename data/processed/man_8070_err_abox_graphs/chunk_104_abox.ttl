@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarLasFuncionesEnBloquesDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Programar las funciones en bloques diferentes."@es ;
    ns1:solucionaFallo ns1:FuncionesGIncompatiblesG115G116G117_f375642994,
        ns1:FuncionesGIncompatiblesG134G135 ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:FuncionesGIncompatiblesG115G116G117_f375642994 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G115/G116/G117)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G115/G116/G117)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG134G135 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G134/G135)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G134/G135)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G" .

