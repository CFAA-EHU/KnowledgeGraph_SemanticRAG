@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1142
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1142: La sentencia #TIME se programa sola en el bloque" ;
    ex:textoExtracto "1142 'La sentencia #TIME se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1142" .

ex:Fallo_1146
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1146: Trayectoria anterior a G37 no lineal" ;
    ex:textoExtracto "1146 'La trayectoria anterior a G37 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento anterior a la entrada tangencial no es lineal. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1146" .

ex:Fallo_1147
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1147: Trayectoria posterior a G38 no lineal" ;
    ex:textoExtracto "1147 'La trayectoria posterior a G38 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento posterior a la salida tangencial no es lineal. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1147" .

ex:Fallo_1149
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1149: Imposibilidad de ejecutar G36/G37/G38/G39" ;
    ex:textoExtracto "1149 'No es posible ejecutar G36/G37/G38/G39 programada' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede realizar la trayectoria de empalme con el radio programado. SOLUCIÓN Revisar el radio programado. Comprobar que el empalme es realmente posible entre los bloques inicial y final." ;
    ex:identificador "1149" .

ex:Fallo_1150
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1150: Funciones G36/G37/G38/G39 sin bloque de movimiento posterior" ;
    ex:textoExtracto "1150 'Las funciones G36/G37/G38/G39 deben estar seguidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un segundo bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el segundo bloque de movimiento." ;
    ex:identificador "1150" .

ex:Fallo_1151
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1151: Funciones G8/G36/G37/G38/G39 sin bloque de movimiento previo" ;
    ex:textoExtracto "1151 'Las funciones G8/G36/G37/G38/G39 deben estar precedidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un primer bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." ;
    ex:identificador "1151" .

ex:Fallo_1152
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1152: Anidamiento de subrutinas sobrepasado" ;
    ex:textoExtracto "1152 'Anidamiento de subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el número de niveles de imbricación permitido." ;
    ex:identificador "1152" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC no puede realizar la trayectoria de empalme con el radio programado." .