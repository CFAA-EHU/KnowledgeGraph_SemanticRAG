@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_24579 a ns1:DiagnosticoFallo ;
    rdfs:label "Suministro de actuador no presente"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24579" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal ;
    ns1:textoExtracto "Módulo %u: Suministro de actuador no presente. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24580 a ns1:DiagnosticoFallo ;
    rdfs:label "Suministro defectuoso de 24 V"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24580" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal ;
    ns1:textoExtracto "Módulo %u: suministro defectuoso de 24 V. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24581 a ns1:DiagnosticoFallo ;
    rdfs:label "Suministro defectuoso de 5 V"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24581" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal ;
    ns1:textoExtracto "Módulo %u: suministro defectuoso de 5 V. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24582 a ns1:DiagnosticoFallo ;
    rdfs:label "Unión fría no válida"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24582" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal ;
    ns1:textoExtracto "Módulo %u: Unión fría no válida Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24583 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación defectuosa"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24583" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal ;
    ns1:textoExtracto "Módulo %u: tensión de alimentación defectuosa. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema de comunicación EtherCAT"@es ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ns1:tieneComponente ns1:ActuadorGenericoDelModulo,
        ns1:CanalConUnionFriaNoValida,
        ns1:FuenteDe24VDelModulo,
        ns1:FuenteDe5VDelModulo .

ns1:ActuadorGenericoDelModulo a ns1:Actuador ;
    rdfs:label "Actuador genérico del módulo"@es ;
    ns1:textoExtracto "Suministro de actuador no presente"@es .

ns1:CanalConUnionFriaNoValida a ns1:ComponenteElectrico ;
    rdfs:label "Canal con unión fría no válida"@es ;
    ns1:textoExtracto "Unión fría no válida Canal %u"@es .

ns1:FuenteDe24VDelModulo a ns1:ComponenteElectrico ;
    rdfs:label "Fuente de 24 V del módulo"@es ;
    ns1:textoExtracto "suministro defectuoso de 24 V"@es .

ns1:FuenteDe5VDelModulo a ns1:ComponenteElectrico ;
    rdfs:label "Fuente de 5 V del módulo"@es ;
    ns1:textoExtracto "suministro defectuoso de 5 V"@es .

ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimal a ns1:AvisoSeguridad ;
    rdfs:label "Consultar manual específico del nodo para diagnóstico (código hexadecimal)"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

