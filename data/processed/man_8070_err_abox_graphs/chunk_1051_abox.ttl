@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoEmergencia_24584 a ns1:DiagnosticoFallo ;
    rdfs:label "Reinicio del dispositivo después del watchdog" ;
    ns1:identificador "24584" ;
    ns1:solucionaFallo ns1:ManualNodoEtherCAT ;
    ns1:textoExtracto "24584 Reinicio del dispositivo después del watchdog. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

