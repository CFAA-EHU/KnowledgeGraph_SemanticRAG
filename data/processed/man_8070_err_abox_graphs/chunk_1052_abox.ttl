@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:ErrorDeEmergenciaEtherCAT,
        ns1:NumeroMaximoDePuntosDeESSuperados ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:NoRequiereNingunaAccion a ns1:AccionProhibida ;
    rdfs:label "No requiere ninguna acción" ;
    ns1:solucionaFallo ns1:NumeroMaximoDeModulosExcedidos ;
    ns1:textoExtracto "No requiere ninguna acción." .

ns1:ErrorDeEmergenciaEtherCAT a ns1:DiagnosticoFallo ;
    rdfs:label "Error de emergencia EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:NumeroMaximoDeModulosExcedidos a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de módulos excedidos" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:NumeroMaximoDePuntosDeESSuperados a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de puntos de E/S superados" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

