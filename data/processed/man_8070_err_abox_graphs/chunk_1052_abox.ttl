ns1:SistemaEtherCAT_Modulos a ns1:Sistema ;
    rdfs:label "Sistema de comunicación EtherCAT (módulos)"@es ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ns1:tieneComponente ns1:ModuloEtherCATGenerico .

ns1:ModuloEtherCATGenerico a ns1:ComponenteElectrico ;
    rdfs:label "Módulo EtherCAT genérico"@es ;
    ns1:textoExtracto "Módulo %u"@es .

ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimalDeEmergencia a ns1:AvisoSeguridad ;
    rdfs:label "Consultar manual específico del nodo para diagnóstico (código hexadecimal de emergencia)"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

