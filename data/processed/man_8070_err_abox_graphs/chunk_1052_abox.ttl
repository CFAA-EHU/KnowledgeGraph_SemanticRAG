@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorBufferRecepcionLleno_24590 a ns1:DiagnosticoFallo ;
    rdfs:label "Buffer de recepción lleno"@es ;
    ns1:identificador "24590" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoCodigoHexadecimalDeEmergencia ;
    ns1:textoExtracto "Módulo %u: Buffer de recepción lleno. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

