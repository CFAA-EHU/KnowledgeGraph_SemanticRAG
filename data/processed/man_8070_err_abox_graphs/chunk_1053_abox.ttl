@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarEnElManualEspecificoDelNodoLaInformacionDeDiagnosisOElValorA_3b5ce915d9 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)" ;
    ns1:solucionaFallo ns1:EncontroUnModuloDelFabricanteDelDispositivoNoSoportado,
        ns1:ErrorGraveEnElModuloLocalbus,
        ns1:SeEncontroUnModuloConUnaVersionDeChipNoSoportada,
        ns1:SeProdujoUnErrorDeHardwareOFirmware ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:EncontroUnModuloDelFabricanteDelDispositivoNoSoportado a ns1:DiagnosticoFallo ;
    rdfs:label "Encontró un módulo del fabricante del dispositivo no soportado" ;
    ns1:textoExtracto "24556 Encontró un módulo del fabricante del dispositivo no soportado." .

ns1:ErrorGraveEnElModuloLocalbus a ns1:DiagnosticoFallo ;
    rdfs:label "Error grave en el módulo localbus" ;
    ns1:textoExtracto "24557 Error grave en el módulo localbus." .

ns1:SeEncontroUnModuloConUnaVersionDeChipNoSoportada a ns1:DiagnosticoFallo ;
    rdfs:label "Se encontró un módulo con una versión de chip no soportada" ;
    ns1:textoExtracto "24555 Se encontró un módulo con una versión de chip no soportada." .

ns1:SeProdujoUnErrorDeHardwareOFirmware a ns1:DiagnosticoFallo ;
    rdfs:label "Se produjo un error de hardware o firmware" ;
    ns1:textoExtracto "24558 Se produjo un error de hardware o firmware." .

