@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_d39fa78f9e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad por emergencia" ;
    ns1:mitigaRiesgo ns1:SistemaEtherCAT ;
    ns1:solucionaFallo ns1:ErrorDeEmergenciaEtherCAT ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ConsultarDiagnostico a ns1:TareaMantenimiento ;
    rdfs:label "Consultar diagnóstico" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ConsultarManualEspecifico a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:NoConsultarDiagnostico a ns1:AccionProhibida ;
    rdfs:label "No consultar diagnóstico" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:NoConsultarManualEspecificoDelNodo a ns1:AccionProhibida ;
    rdfs:label "No consultar manual específico del nodo" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:NoIgnorarEmergencia a ns1:AccionProhibida ;
    rdfs:label "No ignorar emergencia" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ErrorDeEmergenciaEtherCAT a ns1:DiagnosticoFallo ;
    rdfs:label "Error de emergencia EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

