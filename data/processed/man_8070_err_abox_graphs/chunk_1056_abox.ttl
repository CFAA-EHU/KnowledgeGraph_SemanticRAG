@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodoParaDiagnosticoOValorAdicionalDeError a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo para diagnóstico o valor adicional de error" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ConsultarManualSinEspecificidad a ns1:AccionProhibida ;
    rdfs:label "Consultar manual sin especificidad" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ElModuloUDeBusLocalTieneUnAnchoDeDatosDeProcesoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "El módulo %u de bus local tiene un ancho de datos de proceso incorrecto" ;
    ns1:textoExtracto "24571 El módulo %u de bus local tiene un ancho de datos de proceso incorrecto." .

ns1:ErrorAlObtenerLaConfiguracionDelBusLocal a ns1:DiagnosticoFallo ;
    rdfs:label "Error al obtener la configuración del bus local" ;
    ns1:textoExtracto "24572 Error al obtener la configuración del bus local." .

ns1:ModuloUCortocircuitoCanalU a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Cortocircuito Canal %u" ;
    ns1:textoExtracto "24573 Módulo %u: Cortocircuito Canal %u." .

ns1:ModuloUDeBusLocalEnPosicionIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u de bus local en posición incorrecta" ;
    ns1:textoExtracto "24569 Módulo %u de bus local en posición incorrecta." .

ns1:ModuloUDeBusLocalUEnError a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u de bus local %u en error" ;
    ns1:textoExtracto "24570 Módulo %u de bus local %u en error." .

