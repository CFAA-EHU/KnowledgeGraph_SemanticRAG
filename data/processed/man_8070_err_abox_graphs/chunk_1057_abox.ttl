@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:ModuloUFalloEnElSuministroDeES,
        ns1:ModuloUGrupoUDeSobrecargaDeEntrada,
        ns1:ModuloUSobrecargaDeCortocircuitoSalida ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:NoRealizarAccionesSinConsultaPrevia a ns1:AccionProhibida ;
    rdfs:label "No realizar acciones sin consulta previa" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ModuloUFalloEnElSuministroDeES a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: fallo en el suministro de E/S" ;
    ns1:textoExtracto "24577 Módulo %u: fallo en el suministro de E/S. DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:ModuloUGrupoUDeSobrecargaDeEntrada a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Grupo %u de sobrecarga de entrada" ;
    ns1:textoExtracto "24574 Módulo %u: Grupo %u de sobrecarga de entrada. DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:ModuloUSobrecargaDeCortocircuitoSalida a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: sobrecarga de cortocircuito/salida" ;
    ns1:textoExtracto "24575 Módulo %u: sobrecarga de cortocircuito/salida. DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

