@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualNodoEtherCAT a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT" ;
    ns1:solucionaFallo ns1:Error24626,
        ns1:Error24627,
        ns1:Error24650,
        ns1:Error24651,
        ns1:Error24652,
        ns1:ErrorGenericoEtherCAT ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema de comunicación EtherCAT" ;
    ns1:activaAlarma ns1:Error24626,
        ns1:Error24627,
        ns1:Error24650,
        ns1:Error24651,
        ns1:Error24652,
        ns1:ErrorGenericoEtherCAT ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24626 a ns1:AvisoSeguridad ;
    rdfs:label "Reconfiguración del bus local" ;
    ns1:identificador "24626" ;
    ns1:textoExtracto "La aplicación solicitaba una reconfiguración del bus local. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24627 a ns1:AvisoSeguridad ;
    rdfs:label "Módulos faltantes en el sistema" ;
    ns1:identificador "24627" ;
    ns1:textoExtracto "Comenzar con el sistema restante, %u módulos esperados, encontrados %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24650 a ns1:AvisoSeguridad ;
    rdfs:label "Cambio de estado no válido" ;
    ns1:identificador "24650" ;
    ns1:textoExtracto "Petición de cambio de estado: De %u a:%u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24651 a ns1:AvisoSeguridad ;
    rdfs:label "Error genérico de nodo EtherCAT" ;
    ns1:identificador "24651" ;
    ns1:textoExtracto "%u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24652 a ns1:AvisoSeguridad ;
    rdfs:label "Tiempo de ciclo del bus incorrecto" ;
    ns1:identificador "24652" ;
    ns1:textoExtracto "Cálculo erróneo del tiempo de ciclo del bus (Timer local muy lento). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ErrorGenericoEtherCAT a ns1:AvisoSeguridad ;
    rdfs:label "Emergencia de nodo EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

