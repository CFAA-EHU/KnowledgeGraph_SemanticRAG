@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:ModuloUErrorDeCodificadorCanalU,
        ns1:ModuloUErrorDeCodificadorCanalU_7a0ce7bc2b,
        ns1:ModuloUErrorDeFormatoDelFlash,
        ns1:ModuloUErrorDelDispositivo,
        ns1:ModuloUTablaDeParametrosNoValida,
        ns1:ReinicioDelDispositivoDespuesDelWatchdog_88f0cc0c1b ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ModuloUErrorDeCodificadorCanalU a ns1:AccionProhibida ;
    rdfs:label "Módulo %u: Error de codificador Canal %u" ;
    ns1:textoExtracto "24588 Módulo %u: Error de codificador Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUErrorDeCodificadorCanalU_7a0ce7bc2b a ns1:AccionProhibida ;
    rdfs:label "Módulo %u: Error de codificador Canal %u" ;
    ns1:textoExtracto "24589 Módulo %u: Error de codificador Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUErrorDeFormatoDelFlash a ns1:AccionProhibida ;
    rdfs:label "Módulo %u: Error de formato del flash" ;
    ns1:textoExtracto "24586 Módulo %u: Error de formato del flash. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUErrorDelDispositivo a ns1:AccionProhibida ;
    rdfs:label "Módulo %u: Error del dispositivo" ;
    ns1:textoExtracto "24585 Módulo %u: Error del dispositivo. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUTablaDeParametrosNoValida a ns1:AccionProhibida ;
    rdfs:label "Módulo %u: Tabla de parámetros no válida" ;
    ns1:textoExtracto "24587 Módulo %u: Tabla de parámetros no válida. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ReinicioDelDispositivoDespuesDelWatchdog_88f0cc0c1b a ns1:DiagnosticoFallo ;
    rdfs:label "Reinicio del dispositivo después del watchdog" ;
    ns1:textoExtracto "24584 Reinicio del dispositivo después del watchdog. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

