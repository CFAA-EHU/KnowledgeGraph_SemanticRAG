@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_24653_SyncManager_DireccionInvalida a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d dirección inválida (%d)"@es ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24653" ;
    ns1:textoExtracto "24653 Sync Manager %d dirección inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24654_SyncManager_TamanoInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d tamaño inválido (%d)"@es ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24654" ;
    ns1:textoExtracto "24654 Sync Manager %d tamaño inválido (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24655_SyncManager_ConfiguracionInvalida a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d configuración inválida (%d)"@es ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24655" ;
    ns1:textoExtracto "24655 Sync Manager %d configuración inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24656_RegistroActivacionDC_Invalido a ns1:DiagnosticoFallo ;
    rdfs:label "Registro de activación DC inválido"@es ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24656" ;
    ns1:textoExtracto "24656 Registro de activación DC inválido. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24657_ConfiguracionSyncType_NoSoportada a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada"@es ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24657" ;
    ns1:textoExtracto "24657 Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada. Compruebe los registros DC registers y SyncTypes soportados(0x1C32.4 and 0x1C33.4). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ns1:valor "0x1C32.1, 0x1C33.1, 0x1C32.4, 0x1C33.4" .

ns1:ManualNodoEtherCAT a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

