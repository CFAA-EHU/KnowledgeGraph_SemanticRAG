@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularLaCompensacionParaDefinirElNuevoPlanoDeTrabajo a ns1:TareaMantenimiento ;
    rdfs:label "Anular la compensación para definir el nuevo plano de trabajo"@es ;
    ns1:solucionaFallo ns1:NoSeAdmiteCambioDePlanoConCompensacionDeRadioActiva ;
    ns1:textoExtracto "SOLUCIÓN Anular la compensación para definir el nuevo plano de trabajo." .

ns1:DefinirLosEjesDelPlanoActivo a ns1:TareaMantenimiento ;
    rdfs:label "Definir los ejes del plano activo"@es ;
    ns1:solucionaFallo ns1:NoSeAdmiteG41G42SiFaltaElPrimerOSegundoEjeDelPlanoActivo_4ea7e3ddf9 ;
    ns1:textoExtracto "SOLUCIÓN Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal." .

ns1:ProgramarLasFuncionesEnBloquesDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Programar las funciones en bloques diferentes"@es ;
    ns1:solucionaFallo ns1:FuncionesGIncompatiblesG134G135,
        ns1:FuncionesGIncompatiblesG138G139,
        ns1:FuncionesGIncompatiblesG200G201G202,
        ns1:FuncionesGIncompatiblesG264G265,
        ns1:FuncionesGIncompatiblesG36G37G38G39,
        ns1:FuncionesGIncompatiblesG6G261G262 ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:FuncionesGIncompatiblesG134G135 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G134/G135)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G134/G135)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG138G139 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G138/G139)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G138/G139)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG200G201G202 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G200/G201/G202)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G200/G201/G202)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG264G265 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G264/G265)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G264/G265)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG36G37G38G39 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G36/G37/G38/G39)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G36/G37/G38/G39)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:FuncionesGIncompatiblesG6G261G262 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G6/G261/G262)"@es ;
    ns1:textoExtracto "'Funciones G incompatibles (G6/G261/G262)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí." .

ns1:NoSeAdmiteCambioDePlanoConCompensacionDeRadioActiva a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de plano con compensación de radio activa"@es ;
    ns1:textoExtracto "'No se admite cambio de plano con compensación de radio activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo o los ejes que componen el plano, con la compensación del radio activa." .

ns1:NoSeAdmiteG41G42SiFaltaElPrimerOSegundoEjeDelPlanoActivo_4ea7e3ddf9 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G41/G42 si falta el primer o segundo eje del plano activo"@es ;
    ns1:textoExtracto "'No se admite G41/G42 si falta el primer o segundo eje del plano activo' DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal." .

