@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloUBufferDeRecepcionLleno a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Buffer de recepción lleno" ;
    ns1:solucionaFallo ns1:ConsultarManualEspecificoDelNodo ;
    ns1:textoExtracto "Módulo %u: Buffer de recepción lleno. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

