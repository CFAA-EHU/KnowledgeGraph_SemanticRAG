@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarEnElManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en el manual específico del nodo" ;
    ns1:solucionaFallo ns1:AplicacionEnElModuloUNoListo_bfff22f64a,
        ns1:MasDispositivosDeLosEsperados_368520fece,
        ns1:ModuloIncorrectoEncontradoEnLaPosicionU_62cf672663,
        ns1:ModuloUDispositivoReset,
        ns1:ModuloUTimeoutDeComunicacion,
        ns1:NoSeHaEncontradoNingunModulo_9d2a7a8f17 ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:AplicacionEnElModuloUNoListo_bfff22f64a a ns1:DiagnosticoFallo ;
    rdfs:label "Aplicación en el módulo %u no listo" ;
    ns1:textoExtracto "24612 Aplicación en el módulo %u no listo. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:MasDispositivosDeLosEsperados_368520fece a ns1:DiagnosticoFallo ;
    rdfs:label "Más dispositivos de los esperados" ;
    ns1:textoExtracto "24611 Más dispositivos de los esperados. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloIncorrectoEncontradoEnLaPosicionU_62cf672663 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo incorrecto encontrado en la posición %u" ;
    ns1:textoExtracto "24610 Módulo incorrecto encontrado en la posición %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUDispositivoReset a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u dispositivo reset" ;
    ns1:textoExtracto "24613 Módulo %u dispositivo reset. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ModuloUTimeoutDeComunicacion a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u timeout de comunicación" ;
    ns1:textoExtracto "24614 Módulo %u timeout de comunicación. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:NoSeHaEncontradoNingunModulo_9d2a7a8f17 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha encontrado ningún módulo" ;
    ns1:textoExtracto "24609 No se ha encontrado ningún módulo. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

