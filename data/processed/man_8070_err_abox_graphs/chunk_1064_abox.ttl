@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodo_ba16c1f70d a ns1:AccionProhibida ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ErrorDeBusEnElDispositivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error de bus en el dispositivo" ;
    ns1:textoExtracto "24618 Error de bus en el dispositivo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

