@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComenzarConElSistemaRestanteNoPermitido a ns1:AccionProhibida ;
    rdfs:label "Comenzar con el sistema restante no permitido" ;
    ns1:solucionaFallo ns1:LaConfiguracionDelModuloLocalbusNoCoincide ;
    ns1:textoExtracto "Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados" .

ns1:ErrorDeFirmwareEnElModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Error de firmware en el módulo" ;
    ns1:textoExtracto "24621 Error de firmware en el módulo %u." .

ns1:ErrorDeHardwareEnElModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en el módulo" ;
    ns1:textoExtracto "24620 Error de hardware en el módulo %u." .

ns1:ErrorPerifericoEnElModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo" ;
    ns1:textoExtracto "24622 Error periférico en el módulo %u." .

ns1:ErrorPerifericoEnElModuloSeHaQuitado a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo se ha quitado" ;
    ns1:textoExtracto "24623 Error periférico en el módulo %u se ha quitado." .

ns1:LaConfiguracionDelModuloLocalbusNoCoincide a ns1:DiagnosticoFallo ;
    rdfs:label "La configuración del módulo Localbus no coincide" ;
    ns1:textoExtracto "24624 La configuración del módulo Localbus no coincide en el módulo %u." .

