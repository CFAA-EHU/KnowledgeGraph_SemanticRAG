@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalculoErroneoDelTiempoDeCicloDelBusTimerLocalMuyLento a ns1:AccionProhibida ;
    rdfs:label "Cálculo erróneo del tiempo de ciclo del bus (Timer local muy lento)" ;
    ns1:textoExtracto "Cálculo erróneo del tiempo de ciclo del bus (Timer local muy lento)." .

ns1:CambioDeEstadoDelSistema a ns1:AccionProhibida ;
    rdfs:label "Cambio de estado del sistema" ;
    ns1:textoExtracto "Petición de cambio de estado: De %u a:%u." .

ns1:ConsultarManualEspecificoDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:solucionaFallo ns1:EmergenciaEtherCAT ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ReconfiguracionDelBusLocal_857a9e3f21 a ns1:AccionProhibida ;
    rdfs:label "Reconfiguración del bus local" ;
    ns1:textoExtracto "La aplicación solicitaba una reconfiguración del bus local." .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:EmergenciaEtherCAT a ns1:DiagnosticoFallo ;
    rdfs:label "Emergencia EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

