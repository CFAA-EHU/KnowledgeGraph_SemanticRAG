@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualEspecificoDelNodo_ba16c1f70d a ns1:AccionProhibida ;
    rdfs:label "Consultar manual específico del nodo" ;
    ns1:mitigaRiesgo ns1:ConfiguracionDeSyncType0x1C321Or0x1C331NoSoportada,
        ns1:RegistroDeActivacionDCInvalido,
        ns1:SyncManagerDConfiguracionInvalidaD,
        ns1:SyncManagerDDireccionInvalidaD,
        ns1:SyncManagerDTamanoInvalidoD ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ConfiguracionDeSyncType0x1C321Or0x1C331NoSoportada a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada"@es ;
    ns1:textoExtracto "24657 Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada. Compruebe los registros DC registers y SyncTypes soportados(0x1C32.4 and 0x1C33.4)." .

ns1:RegistroDeActivacionDCInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Registro de activación DC inválido"@es ;
    ns1:textoExtracto "24656 Registro de activación DC inválido. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:SyncManagerDConfiguracionInvalidaD a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d configuración inválida (%d)"@es ;
    ns1:textoExtracto "24655 Sync Manager %d configuración inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:SyncManagerDDireccionInvalidaD a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d dirección inválida (%d)"@es ;
    ns1:textoExtracto "24653 Sync Manager %d dirección inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:SyncManagerDTamanoInvalidoD a ns1:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d tamaño inválido (%d)"@es ;
    ns1:textoExtracto "24654 Sync Manager %d tamaño inválido (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

