@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeEmergenciaCoE a ns1:DiagnosticoFallo ;
    rdfs:label "Código de emergencia CoE" ;
    ns1:textoExtracto "24659 Código de emergencia CoE: 0x%X, información adicional: 0x%X." .

ns1:ErrorEnVoltajeInterno15V15V a ns1:DiagnosticoFallo ;
    rdfs:label "Error en voltaje interno +15 V/-15 V" ;
    ns1:textoExtracto "24661 Error en voltaje interno +15 V/-15 V." .

ns1:FalloElTesteoDeMemoria a ns1:DiagnosticoFallo ;
    rdfs:label "Falló el testeo de memoria" ;
    ns1:textoExtracto "24663 Falló el testeo de memoria." .

ns1:SobrecorrienteEnLasSalidasAnalogica a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en las salidas analógica" ;
    ns1:textoExtracto "24662 Sobrecorriente en las salidas analógica." .

ns1:SobrecorrienteEnLasSalidasDigitales a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en las salidas digitales" ;
    ns1:textoExtracto "24660 Sobrecorriente en las salidas digitales." .

ns1:SoftwareException a ns1:DiagnosticoFallo ;
    rdfs:label "Software exception" ;
    ns1:textoExtracto "24658 Software exception, fichero: %s, linea: %d." .

