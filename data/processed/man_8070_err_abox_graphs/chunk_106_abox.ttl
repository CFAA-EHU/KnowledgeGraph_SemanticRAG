@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoSeAdmiteG41G42SiFaltaElPrimerOSegundoEjeDelPlanoActivo a ns1:AccionProhibida ;
    rdfs:label "No se admite G41/G42 si falta el primer o segundo eje del plano activo" ;
    ns1:mitigaRiesgo ns1:DefinirElPlanoDeTrabajo ;
    ns1:textoExtracto "'No se admite G41/G42 si falta el primer o segundo eje del plano activo'" .

ns1:DefinirElPlanoDeTrabajo a ns1:AvisoSeguridad ;
    rdfs:label "Definir el plano de trabajo" ;
    ns1:textoExtracto "SOLUCIÓN Definir el plano de trabajo. Si el canal ha cedido sus ejes a otro canales, recuperar el eje que falta." .

