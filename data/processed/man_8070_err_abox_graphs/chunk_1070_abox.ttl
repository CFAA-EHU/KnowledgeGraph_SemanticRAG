@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeFirmwareEnRIOREBOOTMode a ns1:AccionProhibida ;
    rdfs:label "Error de firmware en RIOR-E, BOOT mode" ;
    ns1:solucionaFallo ns1:VolverACargarElFirmwareDeAplicacion ;
    ns1:textoExtracto "24669 Error de firmware en RIOR-E, BOOT mode. DETECCIÓN Durante la ejecución. CAUSA Se ha detectado un nodo RIOR-E en BOOT mode." .

ns1:IdentificadorDePlacaAnalogicaIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Identificador de placa analógica incorrecto" ;
    ns1:solucionaFallo ns1:ConsultarInformacionDeDiagnosisOValorAdicionalQueAcompanaAlError ;
    ns1:textoExtracto "24668 Identificador de placa analógica incorrecto. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ConsultarInformacionDeDiagnosisOValorAdicionalQueAcompanaAlError a ns1:DiagnosticoFallo ;
    rdfs:label "Consultar información de diagnosis o valor adicional que acompaña al error" ;
    ns1:textoExtracto "SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:VolverACargarElFirmwareDeAplicacion a ns1:TareaMantenimiento ;
    rdfs:label "Volver a cargar el firmware de aplicación" ;
    ns1:textoExtracto "SOLUCIÓN Volver a cargar el firmware de aplicación." .

