@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:activaAlarma ns1:ErrorE034,
        ns1:ErrorE038,
        ns1:ErrorE039,
        ns1:ErrorE040,
        ns1:ErrorE041,
        ns1:ErrorE044,
        ns1:ErrorE045,
        ns1:ErrorE046,
        ns1:ErrorE047,
        ns1:ErrorE048,
        ns1:ErrorE083,
        ns1:ErrorE084,
        ns1:ErrorE085,
        ns1:ErrorE133,
        ns1:ErrorE233,
        ns1:ErrorE333,
        ns1:ErrorE433 ;
    ns1:textoExtracto "MÓDULO RCS-S" .

ns1:ErrorE034 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la identificación de la placa CPU" ;
    ns1:identificador "E034" ;
    ns1:textoExtracto "E034 Error en la identificación de la placa CPU. Contacte con Fagor Automation." .

ns1:ErrorE038 a ns1:AvisoSeguridad ;
    rdfs:label "Error de checksum del código" ;
    ns1:identificador "E038" ;
    ns1:textoExtracto "E038 Error de checksum del código. El checksum del código de programa cargado no es correcto. Vuelva a cargar el software. Si el problema persiste, es posible que las memorias RAM, FLASH o el código cargado sean defectuosos. Contacte con Fagor Automation." .

ns1:ErrorE039 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la placa Sercos" ;
    ns1:identificador "E039" ;
    ns1:textoExtracto "E039 Error en la placa Sercos ®. Contacte con Fagor Automation." .

ns1:ErrorE040 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo del clock de la placa del SerCon" ;
    ns1:identificador "E040" ;
    ns1:textoExtracto "E040 Fallo del clock de la placa del SerCon ®. Contacte con Fagor Automation." .

ns1:ErrorE041 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria del SerCon corrompida" ;
    ns1:identificador "E041" ;
    ns1:textoExtracto "E041 Memoria del SerCon corrompida. Contacte con Fagor Automation." .

ns1:ErrorE044 a ns1:AvisoSeguridad ;
    rdfs:label "Sistema de ficheros en flash corrompido" ;
    ns1:identificador "E044" ;
    ns1:textoExtracto "E044 Sistema de ficheros en flash corrompido. Contacte con Fagor Automation." .

ns1:ErrorE045 a ns1:AvisoSeguridad ;
    rdfs:label "Error de lectura de offset de analógicas" ;
    ns1:identificador "E045" ;
    ns1:textoExtracto "E045 Error de lectura de offset de analógicas. Contacte con Fagor Automation." .

ns1:ErrorE046 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la identificación de la placa de ejes" ;
    ns1:identificador "E046" ;
    ns1:textoExtracto "E046 Error en la identificación de la placa de ejes. Contacte con Fagor Automation." .

ns1:ErrorE047 a ns1:AvisoSeguridad ;
    rdfs:label "Identificación de placa de ejes desconocida" ;
    ns1:identificador "E047" ;
    ns1:textoExtracto "E047 Identificación de placa de ejes desconocida. Contacte con Fagor Automation." .

ns1:ErrorE048 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el código de la FPGA" ;
    ns1:identificador "E048" ;
    ns1:textoExtracto "E048 Error en el código de la FPGA. El código de la FPGA parece corrompido o no está presente. Pruebe a volver a cargar la versión de software otra vez. Si el problema persiste, es posible que las memorias RAM, FLASH o el código cargado sean defectuosos. Contacte con Fagor Automation." .

ns1:ErrorE083 a ns1:AvisoSeguridad ;
    rdfs:label "FPGA no cargada" ;
    ns1:identificador "E083" ;
    ns1:textoExtracto "E083 La FPGA no se ha podido cargar. Reinicie la contadora. Si el problema persiste, contacte con Fagor Automation." .

ns1:ErrorE084 a ns1:AvisoSeguridad ;
    rdfs:label "Reset por Watchdog" ;
    ns1:identificador "E084" ;
    ns1:textoExtracto "E084 Reset por Watchdog. El sistema se ha reiniciado al saltar la vigilancia por watchdog. Si el problema es repetitivo y/o persiste, contacte con Fagor Automation." .

ns1:ErrorE085 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la alimentación de las salidas analógicas" ;
    ns1:identificador "E085" ;
    ns1:textoExtracto "E085 Error en la alimentación de las salidas analógicas. Contacte con Fagor Automation." .

ns1:ErrorE133 a ns1:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21A" ;
    ns1:identificador "E133" ;
    ns1:textoExtracto "E133 Cable roto, señal A de la captación E21A." .

ns1:ErrorE233 a ns1:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21B" ;
    ns1:identificador "E233" ;
    ns1:textoExtracto "E233 Cable roto, señal A de la captación E21B." .

ns1:ErrorE333 a ns1:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21C" ;
    ns1:identificador "E333" ;
    ns1:textoExtracto "E333 Cable roto, señal A de la captación E21C." .

ns1:ErrorE433 a ns1:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21D" ;
    ns1:identificador "E433" ;
    ns1:textoExtracto "E433 Cable roto, señal A de la captación E21D. Para el caso de captación TTL diferencial. El cable de la señal A y/o /A puede estar roto o desconectado. Revisar el conexionado." .

