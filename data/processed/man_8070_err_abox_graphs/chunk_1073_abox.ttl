@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CaptacionSercos a ns1:Sistema ;
    rdfs:label "Sistema de captación de la contadora Sercos" ;
    ns1:activaAlarma ns1:Alarma_E138,
        ns1:Alarma_E238,
        ns1:Alarma_E338,
        ns1:Alarma_E438 ;
    ns1:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema." ;
    ns1:tieneComponente ns1:ComponenteElectrico_CableadoCaptacion,
        ns1:ComponenteElectrico_Captador .

ns1:Alarma_E138 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21A" ;
    ns1:identificador "E138" ;
    ns1:textoExtracto "E138 Alarma de amplitud en captación E21A." .

ns1:Alarma_E238 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21B" ;
    ns1:identificador "E238" ;
    ns1:textoExtracto "E238 Alarma de amplitud en captación E21B." .

ns1:Alarma_E338 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21C" ;
    ns1:identificador "E338" ;
    ns1:textoExtracto "E338 Alarma de amplitud en captación E21C." .

ns1:Alarma_E438 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21D" ;
    ns1:identificador "E438" ;
    ns1:textoExtracto "E438 Alarma de amplitud en captación E21D." .

ns1:ComponenteElectrico_CableadoCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Cableado de captación" ;
    ns1:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema." .

ns1:ComponenteElectrico_Captador a ns1:ComponenteElectrico ;
    rdfs:label "Captador de la contadora Sercos" ;
    ns1:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema." .

