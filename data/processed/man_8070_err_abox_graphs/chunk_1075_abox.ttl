@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCaptacionE21A a ns1:Sistema ;
    rdfs:label "Sistema de captación E21A" ;
    ns1:activaAlarma ns1:ErrorE143 ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "captación E21A" .

ns1:SistemaCaptacionE21B a ns1:Sistema ;
    rdfs:label "Sistema de captación E21B" ;
    ns1:activaAlarma ns1:ErrorE243 ;
    ns1:identificador "E21B" ;
    ns1:textoExtracto "captación E21B" .

ns1:SistemaCaptacionE21C a ns1:Sistema ;
    rdfs:label "Sistema de captación E21C" ;
    ns1:activaAlarma ns1:ErrorE343 ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "captación E21C" .

ns1:TareaRevisarCables a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cables y conexiones" ;
    ns1:mitigaRiesgo ns1:ErrorE143,
        ns1:ErrorE243,
        ns1:ErrorE343 ;
    ns1:textoExtracto "Revisar cables y conexiones." .

ns1:ErrorE143 a ns1:AvisoSeguridad ;
    rdfs:label "Error E143" ;
    ns1:identificador "E143" ;
    ns1:textoExtracto "E143 Error de comunicación en captación E21A. CRC incorrecto." .

ns1:ErrorE243 a ns1:AvisoSeguridad ;
    rdfs:label "Error E243" ;
    ns1:identificador "E243" ;
    ns1:textoExtracto "E243 Error de comunicación en captación E21B. CRC incorrecto." .

ns1:ErrorE343 a ns1:AvisoSeguridad ;
    rdfs:label "Error E343" ;
    ns1:identificador "E343" ;
    ns1:textoExtracto "E343 Error de comunicación en captación E21C. CRC incorrecto." .

