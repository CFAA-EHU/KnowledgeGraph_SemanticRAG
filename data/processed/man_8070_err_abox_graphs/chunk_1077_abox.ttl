@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeLaSubrutinaG8585 a ns1:TareaMantenimiento ;
    rdfs:label "revisión de la subrutina G8585" ;
    ns1:monitoreaParametro ns1:VariableVSG84585CFG ;
    ns1:solucionaFallo ns1:ConfiguracionErroneaValorIncorrectoDeLaVariableVSG84585CFG,
        ns1:ErrorInterno90EnG8585 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la asignación de datos a la variable en la subrutina G8585." .

ns1:ConfiguracionErroneaValorIncorrectoDeLaVariableVSG84585CFG a ns1:DiagnosticoFallo ;
    rdfs:label "configuración errónea: valor incorrecto de la variable V.S.G84585CFG" ;
    ns1:textoExtracto "85863 G8585 configuración errónea: valor incorrecto de la variable V.S.G84585CFG=%D. DETECCIÓN Durante la ejecución. CAUSA El valor asignado a la variable no es válido. SOLUCIÓN Revisar la asignación de datos a la variable en la subrutina G8585." .

ns1:ErrorInterno90EnG8585 a ns1:DiagnosticoFallo ;
    rdfs:label "error interno #90 en G8585" ;
    ns1:textoExtracto "85870 Error interno #90 en G8585: KINID=%D, TYPE=%D. DETECCIÓN Durante la ejecución. CAUSA Error en la ejecución de la subrutina G8585, en la cinemática indicada. SOLUCIÓN Revisar la subrutina G8585." .

ns1:VariableVSG84585CFG a ns1:Parametro ;
    rdfs:label "variable V.S.G84585CFG" ;
    ns1:identificador "V.S.G84585CFG" ;
    ns1:textoExtracto "valor incorrecto de la variable V.S.G84585CFG=%D." .

