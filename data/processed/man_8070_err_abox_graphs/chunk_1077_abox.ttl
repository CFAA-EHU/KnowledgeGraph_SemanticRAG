@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:contadora_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos" ;
    ns1:textoExtracto "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación" .

ns1:empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "contacte con Fagor Automation" .

ns1:error_E146 a ns1:AvisoSeguridad ;
    rdfs:label "E146 ABSIND: Error leyendo información en captación E21A" ;
    ns1:identificador "E146" ;
    ns1:textoExtracto "E146 ABSIND: Error leyendo información en captación E21A" .

ns1:error_E246 a ns1:AvisoSeguridad ;
    rdfs:label "E246 ABSIND: Error leyendo información en captación E21B" ;
    ns1:identificador "E246" ;
    ns1:textoExtracto "E246 ABSIND: Error leyendo información en captación E21B" .

ns1:error_E346 a ns1:AvisoSeguridad ;
    rdfs:label "E346 ABSIND: Error leyendo información en captación E21C" ;
    ns1:identificador "E346" ;
    ns1:textoExtracto "E346 ABSIND: Error leyendo información en captación E21C" .

ns1:error_E446 a ns1:AvisoSeguridad ;
    rdfs:label "E446 ABSIND: Error leyendo información en captación E21D" ;
    ns1:identificador "E446" ;
    ns1:textoExtracto "E446 ABSIND: Error leyendo información en captación E21D" .

ns1:error_arranque_ABSIND a ns1:AvisoSeguridad ;
    rdfs:label "Error de identificación en arranque del módulo ABSIND" ;
    ns1:textoExtracto "No se ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema" .

ns1:modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "No se ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema" .

