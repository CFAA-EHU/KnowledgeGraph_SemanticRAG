@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarElConexionado a ns1:AccionProhibida ;
    rdfs:label "Revisar el conexionado" ;
    ns1:solucionaFallo ns1:CableRotoSenalBDeLaCaptacionE21A,
        ns1:CableRotoSenalBDeLaCaptacionE21B ;
    ns1:textoExtracto "El cable de la señal A y/o /A puede estar roto o desconectado. Revisar el conexionado." .

ns1:RevisarNivelDeSenales a ns1:AccionProhibida ;
    rdfs:label "Revisar nivel de señales" ;
    ns1:solucionaFallo ns1:CableRotoSenalBDeLaCaptacionE21A,
        ns1:CableRotoSenalBDeLaCaptacionE21B ;
    ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador." .

ns1:CableRotoSenalBDeLaCaptacionE21A a ns1:Alarma ;
    rdfs:label "Cable roto, señal B de la captación E21A" ;
    ns1:textoExtracto "E134 Cable roto, señal B de la captación E21A." .

ns1:CableRotoSenalBDeLaCaptacionE21B a ns1:Alarma ;
    rdfs:label "Cable roto, señal B de la captación E21B" ;
    ns1:textoExtracto "E234 Cable roto, señal B de la captación E21B." .

