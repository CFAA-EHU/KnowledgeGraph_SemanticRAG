@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Senal_GRAY_Inductosyn a ns1:Parametro ;
    rdfs:label "Nivel de la señal GRAY del transductor Inductosyn/Resolver" ;
    ns1:monitoreaParametro ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Nivel de la señal GRAY del transductor inductosyn/resolver"@es .

ns1:Alarma_E185 a ns1:Alarma ;
    rdfs:label "E185 INDUCTOSYN: GRAY signal absent en captación E21A" ;
    ns1:identificador "E185" ;
    ns1:textoExtracto "E185 INDUCTOSYN: GRAY signal absent en captación E21A"@es .

ns1:Alarma_E285 a ns1:Alarma ;
    rdfs:label "E285 INDUCTOSYN: GRAY signal absent en captación E21B" ;
    ns1:identificador "E285" ;
    ns1:textoExtracto "E285 INDUCTOSYN: GRAY signal absent en captación E21B"@es .

ns1:Alarma_E385 a ns1:Alarma ;
    rdfs:label "E385 INDUCTOSYN: GRAY signal absent en captación E21C" ;
    ns1:identificador "E385" ;
    ns1:textoExtracto "E385 INDUCTOSYN: GRAY signal absent en captación E21C"@es .

ns1:Alarma_E485 a ns1:Alarma ;
    rdfs:label "E485 INDUCTOSYN: GRAY signal absent en captación E21D" ;
    ns1:identificador "E485" ;
    ns1:textoExtracto "E485 INDUCTOSYN: GRAY signal absent en captación E21D"@es .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:solucionaFallo ns1:Alarma_E185,
        ns1:Alarma_E285,
        ns1:Alarma_E385,
        ns1:Alarma_E485 ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación"@es .

