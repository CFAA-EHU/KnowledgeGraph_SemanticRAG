@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirElPlanoDeTrabajo a ns1:AvisoSeguridad ;
    rdfs:label "Definir el plano de trabajo" ;
    ns1:mitigaRiesgo ns1:SeEspera ;
    ns1:textoExtracto "SOLUCIÓN Definir el plano de trabajo. Si el canal ha cedido sus ejes a otro canales, recuperar el eje que falta mediante las sentencias #CALLAX o #SETAX." .

ns1:ProgramarLasFuncionesMDelMismoCabezalEnBloquesDiferentes a ns1:AvisoSeguridad ;
    rdfs:label "Programar las funciones M del mismo cabezal en bloques diferentes" ;
    ns1:mitigaRiesgo ns1:FuncionesMIncompatibles ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones M del mismo cabezal en bloques diferentes." .

ns1:RevisarLaProgramacion_2a64761237 a ns1:AvisoSeguridad ;
    rdfs:label "Revisar la programación" ;
    ns1:mitigaRiesgo ns1:G159NumeroDeOffsetNoValido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1088 'G159: número de offset no válido'" .

ns1:RevisarLaProgramacion_c653df7db8 a ns1:AvisoSeguridad ;
    rdfs:label "Revisar la programación" ;
    ns1:mitigaRiesgo ns1:SeEspera ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1087 'Se espera \"=\"'" .

ns1:FuncionesMIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones M incompatibles" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones M incompatibles entre sí." .

ns1:G159NumeroDeOffsetNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "'G159: número de offset no válido'" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la función G159, el traslado de origen programado no existe." .

ns1:SeEspera a ns1:DiagnosticoFallo ;
    rdfs:label "'Se espera \"=\"'" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia o la función programada no es correcta." .

