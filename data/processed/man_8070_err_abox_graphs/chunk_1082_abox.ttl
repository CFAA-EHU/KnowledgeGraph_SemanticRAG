@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_ErrorDesconocido_INDUCTOSYN a ns1:AvisoSeguridad ;
    rdfs:label "Error desconocido en captación INDUCTOSYN (E188/E288/E388/E488)" ;
    ns1:identificador "E188, E288, E388, E488" ;
    ns1:mitigaRiesgo ns1:Modulo_ABSIND ;
    ns1:textoExtracto "E188 INDUCTOSYN: Error desconocido en captación E21A. E288 INDUCTOSYN: Error desconocido en captación E21B. E388 INDUCTOSYN: Error desconocido en captación E21C. E488 INDUCTOSYN: Error desconocido en captación E21D."@es .

ns1:AvisoSeguridad_InconsistenciaSSITYPE a ns1:AvisoSeguridad ;
    rdfs:label "Inconsistencia parámetro SSITYPE (E189/E289/E389/E489)" ;
    ns1:identificador "E189, E289, E389, E489" ;
    ns1:mitigaRiesgo ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "E189 INDUCTOSYN: Inconsistencia parámetro SSITYPE con el tipo de captador conectado en captación E21A. [...] E489 INDUCTOSYN: Inconsistencia parámetro SSITYPE con el tipo de captador conectado en captación E21D."@es .

ns1:AvisoSeguridad_ParametroREFPULSEIncorrecto a ns1:AvisoSeguridad ;
    rdfs:label "Parámetro REFPULSE incorrecto (E192/E292/E392/E492)" ;
    ns1:identificador "E192, E292, E392, E492" ;
    ns1:mitigaRiesgo ns1:Parametro_REFPULSE ;
    ns1:textoExtracto "E192 Parámetro REFPULSE incorrecto en captación E21A. [...] E492 Parámetro REFPULSE incorrecto en captación E21D."@es .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation S. Coop" ;
    ns1:identificador "Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, contacte con Fagor Automation S. Coop."@es .

ns1:Dipswitch_S50 a ns1:ComponenteElectrico ;
    rdfs:label "Dipswitch S50" ;
    ns1:identificador "S50" ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND. El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC y con el tipo de captador (inductosyn/resolver) conectado al módulo ABSIND."@es .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:monitoreaParametro ns1:Parametro_REFPULSE,
        ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND asociado a esa captación. Si el error persiste, contacte con Fagor Automation. [...] El módulo ABSIND ha generado un error desconocido. Es probable que el error pueda deberse a un mal funcionamiento del mismo."@es ;
    ns1:tieneComponente ns1:Dipswitch_S50 .

ns1:Parametro_REFPULSE a ns1:Parametro ;
    rdfs:label "REFPULSE" ;
    ns1:identificador "REFPULSE" ;
    ns1:textoExtracto "Parámetro REFPULSE incorrecto en captación E21A/B/C/D. [...] El valor del parámetro máquina REFPULSE es incoherente con el tipo de captador conectado."@es .

ns1:Parametro_SSITYPE a ns1:Parametro ;
    rdfs:label "SSITYPE" ;
    ns1:identificador "SSITYPE" ;
    ns1:textoExtracto "Inconsistencia parámetro SSITYPE con el tipo de captador conectado en captación E21A/B/C/D. [...] El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC y con el tipo de captador (inductosyn/resolver) conectado al módulo ABSIND."@es .

