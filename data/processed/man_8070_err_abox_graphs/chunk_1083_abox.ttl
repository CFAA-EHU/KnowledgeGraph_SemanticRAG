    ns1:textoExtracto "E443 Error de comunicación en captación." .

ns1:ErrorDeComunicacionEnCaptacionE21ACRCIncorrecto a ns1:Alarma ;
    rdfs:label "Error de comunicación en captación E21A. CRC incorrecto." ;
    ns1:textoExtracto "E143 Error de comunicación en captación E21A. CRC incorrecto." .

ns1:ErrorDeComunicacionEnCaptacionE21BCRCIncorrecto a ns1:Alarma ;
