@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarCablesYConexionesE143 a ns1:AccionProhibida ;
    rdfs:label "Revisar cables y conexiones E143" ;
    ns1:activaAlarma ns1:ErrorDeComunicacionEnCaptacionE21ACRCIncorrecto ;
    ns1:textoExtracto "Revisar cables y conexiones. E143 Error de comunicación en captación E21A. CRC incorrecto." .

