@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EmpresaFagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:identificador "Fagor Automation" ;
    ns1:textoExtracto "contacte con Fagor Automation" .

ns1:ErrorE193 a ns1:AvisoSeguridad ;
    rdfs:label "E193 - Captación digital Fagor. Error en la pista absoluta E21A" ;
    ns1:identificador "E193" ;
    ns1:textoExtracto "E193 Captación digital Fagor. Error en la pista absoluta E21A." .

ns1:ErrorE293 a ns1:AvisoSeguridad ;
    rdfs:label "E293 - Captación digital Fagor. Error en la pista absoluta E21B" ;
    ns1:identificador "E293" ;
    ns1:textoExtracto "E293 Captación digital Fagor. Error en la pista absoluta E21B." .

ns1:ErrorE393 a ns1:AvisoSeguridad ;
    rdfs:label "E393 - Captación digital Fagor. Error en la pista absoluta E21C" ;
    ns1:identificador "E393" ;
    ns1:textoExtracto "E393 Captación digital Fagor. Error en la pista absoluta E21C." .

ns1:ErrorE493 a ns1:AvisoSeguridad ;
    rdfs:label "E493 - Captación digital Fagor. Error en la pista absoluta E21D" ;
    ns1:identificador "E493" ;
    ns1:textoExtracto "E493 Captación digital Fagor. Error en la pista absoluta E21D." .

ns1:FalloPosicionAbsoluta a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de contaje - No puede calcular la posición absoluta" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad ;
    ns1:textoExtracto "No puede calcular la posición absoluta. Pérdida de contaje. La señal analógica < 0,20 Vpp." .

ns1:ModuloRCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "MÓDULO RCS-S" .

ns1:SenalAnalogicaModuloRCS_S a ns1:Parametro ;
    rdfs:label "Señal analógica del módulo RCS-S" ;
    ns1:textoExtracto "La señal analógica < 0,20 Vpp" ;
    ns1:valor "< 0.20 Vpp" .

