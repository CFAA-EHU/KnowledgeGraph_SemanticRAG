    ns1:activaAlarma ns1:ErrorDeComunicacionEnCaptacionE21BCRCIncorrecto ;
    ns1:textoExtracto "E243 Error de comunicación en captación E21B. CRC incorrecto." .

ns1:RevisarCablesYConexionesE343 a ns1:AccionProhibida ;
