ns1:TareaComprobacionMontaje a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar tolerancias de montaje"@es ;
    ns1:textoExtracto "Comprobar las tolerancias de montaje."@es .

ns1:TareaComprobacionVelocidad a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar velocidad de encóder/regla"@es ;
    ns1:textoExtracto "Comprobar que el encóder o la regla están trabajando a una velocidad apropiada."@es .

ns1:TareaLimpiezaRegla a ns1:TareaMantenimiento ;
    rdfs:label "Limpiar cristal o cinta de acero de la regla"@es ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:TareaReemplazoEncoder a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar encóder o cabeza de regla"@es ;
    ns1:requiereConsumible ns1:EncoderFagor ;
    ns1:textoExtracto "reemplazar el encóder o la cabeza de la regla."@es .

ns1:EncoderFagor a ns1:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de regla Fagor"@es ;
    ns1:textoExtracto "Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. [...] Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es .

