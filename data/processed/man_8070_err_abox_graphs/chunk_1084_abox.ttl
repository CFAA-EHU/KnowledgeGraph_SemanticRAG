@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoEncoderDanado a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Encóder o cabeza de regla dañado"@es ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado. Reemplazar el encóder o la cabeza de la regla."@es .

ns1:ErrorE194 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la CPU (Captación E21A)"@es ;
    ns1:identificador "E194" ;
    ns1:textoExtracto "E194 Captación digital Fagor. Error en la CPU. Captación E21A."@es .

ns1:ErrorE195 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21A)"@es ;
    ns1:identificador "E195" ;
    ns1:textoExtracto "E195 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21A."@es .

ns1:ErrorE196 a ns1:AvisoSeguridad ;
    rdfs:label "Error en captador de imagen (CCD) (Captación E21A)"@es ;
    ns1:identificador "E196" ;
    ns1:textoExtracto "E196 Captación digital Fagor. Error en el captador de imagen (CCD). Captación E21A."@es .

ns1:ErrorE21C a ns1:AvisoSeguridad ;
    rdfs:label "Error en la pista absoluta E21C"@es ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "en la pista absoluta E21C. E493 Captación digital Fagor. Error en la pista absoluta E21D. No puede calcular la posición absoluta."@es .

ns1:ErrorE21D a ns1:AvisoSeguridad ;
    rdfs:label "Error en la pista absoluta E21D"@es ;
    ns1:identificador "E21D" ;
    ns1:textoExtracto "Error en la pista absoluta E21D. No puede calcular la posición absoluta. Pérdida de contaje. La señal analógica < 0,20 Vpp."@es .

ns1:ErrorE294 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la CPU (Captación E21B)"@es ;
    ns1:identificador "E294" ;
    ns1:textoExtracto "E294 Captación digital Fagor. Error en la CPU. Captación E21B."@es .

ns1:ErrorE295 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21B)"@es ;
    ns1:identificador "E295" ;
    ns1:textoExtracto "E295 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21B."@es .

ns1:ErrorE296 a ns1:AvisoSeguridad ;
    rdfs:label "Error en captador de imagen (CCD) (Captación E21B)"@es ;
    ns1:identificador "E296" ;
    ns1:textoExtracto "E296 Captación digital Fagor. Error en el captador de imagen (CCD). Captación E21B."@es .

ns1:ErrorE394 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la CPU (Captación E21C)"@es ;
    ns1:identificador "E394" ;
    ns1:textoExtracto "E394 Captación digital Fagor. Error en la CPU. Captación E21C."@es .

ns1:ErrorE395 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21C)"@es ;
    ns1:identificador "E395" ;
    ns1:textoExtracto "E395 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21C."@es .

ns1:ErrorE396 a ns1:AvisoSeguridad ;
    rdfs:label "Error en captador de imagen (CCD) (Captación E21C)"@es ;
    ns1:identificador "E396" ;
    ns1:textoExtracto "E396 Captación digital Fagor. Error en el captador de imagen (CCD). Captación E21C."@es .

ns1:ErrorE493 a ns1:AvisoSeguridad ;
    rdfs:label "Captación digital Fagor E493"@es ;
    ns1:identificador "E493" ;
    ns1:textoExtracto "E493 Captación digital Fagor."@es .

ns1:ErrorE494 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la CPU (Captación E21D)"@es ;
    ns1:identificador "E494" ;
    ns1:textoExtracto "E494 Captación digital Fagor. Error en la CPU. Captación E21D."@es .

ns1:ErrorE495 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21D)"@es ;
    ns1:identificador "E495" ;
    ns1:textoExtracto "E495 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21D."@es .

ns1:ErrorE496 a ns1:AvisoSeguridad ;
    rdfs:label "Error en captador de imagen (CCD) (Captación E21D)"@es ;
