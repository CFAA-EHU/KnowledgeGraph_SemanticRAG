@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFalloCCD a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en CCD o LED de la regla" ;
    ns1:solucionaFallo ns1:TareaMantenimientoReemplazoEncoder ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado; el CCD (Charge-Coupled Device) o el LED (Light-Emitting Diode)." .

ns1:DiagnosticoFalloTension a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación fuera de rango" ;
    ns1:mitigaRiesgo ns1:TareaMantenimientoLimpiezaOptica ;
    ns1:textoExtracto "Tensión de alimentación fuera de rango." .

ns1:ErrorE197 a ns1:AvisoSeguridad ;
    rdfs:label "Captación digital Fagor - Tensión de alimentación fuera de rango" ;
    ns1:identificador "E197" ;
    ns1:textoExtracto "E197 Captación digital Fagor. Tensión de alimentación fuera de rango." .

ns1:ErrorE21A a ns1:AvisoSeguridad ;
    rdfs:label "Captación E21A - Tensión de alimentación fuera de rango" ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "Captación E21A. Tensión de alimentación fuera de rango." .

ns1:ErrorE21B a ns1:AvisoSeguridad ;
    rdfs:label "Captación E21B - Tensión de alimentación fuera de rango" ;
    ns1:identificador "E21B" ;
    ns1:textoExtracto "Captación E21B. Tensión de alimentación fuera de rango." .

ns1:ErrorE21C a ns1:AvisoSeguridad ;
    rdfs:label "Error en el captador de imagen (CCD) - Captación E21C" ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "Error en el captador de imagen (CCD). Captación E21C." .

ns1:ErrorE21D a ns1:AvisoSeguridad ;
    rdfs:label "Error en el captador de imagen (CCD) - Captación E21D" ;
    ns1:identificador "E21D" ;
    ns1:textoExtracto "Error en el captador de imagen (CCD). Captación E21D." .

ns1:ErrorE297 a ns1:AvisoSeguridad ;
    rdfs:label "Captación digital Fagor - Tensión de alimentación fuera de rango" ;
    ns1:identificador "E297" ;
    ns1:textoExtracto "E297 Captación digital Fagor. Tensión de alimentación fuera de rango." .

ns1:ErrorE397 a ns1:AvisoSeguridad ;
    rdfs:label "Captación digital Fagor" ;
    ns1:identificador "E397" ;
    ns1:textoExtracto "E397 Captación digital Fagor." .

ns1:ErrorE496 a ns1:AvisoSeguridad ;
    rdfs:label "Captación digital Fagor - Error en CCD" ;
    ns1:identificador "E496" ;
    ns1:textoExtracto "Captación digital Fagor. Error en el captador de imagen (CCD)." .

ns1:SistemaCaptacionFagor a ns1:Sistema ;
    rdfs:label "Sistema de captación digital Fagor" ;
    ns1:textoExtracto "Captación digital Fagor." ;
    ns1:tieneComponente ns1:EncoderRegla,
        ns1:LEDRegla,
        ns1:SensorCCD_E21C,
        ns1:SensorCCD_E21D .

ns1:LEDRegla a ns1:ComponenteElectrico ;
    rdfs:label "LED de la regla" ;
    ns1:textoExtracto "el CCD (Charge-Coupled Device) o el LED (Light-Emitting Diode)." .

ns1:SensorCCD_E21C a ns1:Sensor ;
    rdfs:label "Captador de imagen (CCD) - E21C" ;
    ns1:monitoreaParametro ns1:ParametroTensionAlimentacion ;
    ns1:textoExtracto "Error en el captador de imagen (CCD). Captación E21C." .

ns1:SensorCCD_E21D a ns1:Sensor ;
    rdfs:label "Captador de imagen (CCD) - E21D" ;
    ns1:monitoreaParametro ns1:ParametroTensionAlimentacion ;
    ns1:textoExtracto "Error en el captador de imagen (CCD). Captación E21D." .

ns1:TareaMantenimientoLimpiezaOptica a ns1:TareaMantenimiento ;
    rdfs:label "Limpieza del cristal o cinta de acero de la regla" ;
    ns1:requiereMantenimiento ns1:EncoderRegla ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla." .

ns1:TareaMantenimientoReemplazoEncoder a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazo del encóder o cabeza de la regla" ;
    ns1:requiereMantenimiento ns1:EncoderRegla ;
    ns1:textoExtracto "Reemplazar el encóder o la cabeza de la regla." .

ns1:ParametroTensionAlimentacion a ns1:Parametro ;
    rdfs:label "Tensión de alimentación" ;
    ns1:textoExtracto "Tensión de alimentación fuera de rango." .

ns1:EncoderRegla a ns1:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de la regla" ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado; el CCD (Charge-Coupled Device) o el LED (Light-Emitting Diode). Reemplazar el encóder o la cabeza de la regla." .

