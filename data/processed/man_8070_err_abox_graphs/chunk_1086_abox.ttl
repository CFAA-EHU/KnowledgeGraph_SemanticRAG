@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarCableYConexion a ns1:AvisoSeguridad ;
    rdfs:label "comprobar cable y conexión" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:ComprobarGananciaYFase a ns1:AvisoSeguridad ;
    rdfs:label "comprobar ganancia y fase" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:ContacteConFagorAutomation_edb602e0a7 a ns1:AccionProhibida ;
    rdfs:label "contacte con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, contacte con Fagor Automation." .

ns1:ModuloABSIND_b64d08ae2e a ns1:ComponenteMecanico ;
    rdfs:label "módulo ABSIND" ;
    ns1:textoExtracto "ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema." .

ns1:NivelDeLaSenalIncrementalDelTransductorInductosynResolverDemasiadoAlto_65292688f9 a ns1:DiagnosticoFallo ;
    rdfs:label "nivel de la señal incremental del transductor inductosyn/resolver demasiado alto" ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto." .

ns1:NivelDeLaSenalIncrementalDelTransductorInductosynResolverDemasiadoBajo a ns1:DiagnosticoFallo ;
    rdfs:label "nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo" ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo." .

ns1:SustituirModuloABSINDOCable a ns1:AccionProhibida ;
    rdfs:label "sustituir módulo ABSIND o cable" ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

