@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Almacen_1 a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta no cabe en esa posición de almacén, ya está en el almacén o no está definida en la tabla de herramientas." .

ns1:Almacen_2 a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta no está en el almacén." .

ns1:BrazoCambiador_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "en los brazos cambiadores (si existen)" .

ns1:Cabezal_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Comprobar que el cabezal esté vacío" .

ns1:Cabezal_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "La herramienta no existe o ya está en el almacén, en el cabezal o en los brazos cambiadores (si existen)." .

ns1:Canal_1 a ns1:Componente ;
    ns1:textoExtracto "hay algún canal en estado de error" .

ns1:FicheroTabla_1 a ns1:Componente ;
    ns1:textoExtracto "El fichero con los datos no corresponde a la tabla que se desea cargar o ha sido modificado externamente." .

ns1:Herramienta_1 a ns1:Herramienta ;
    ns1:identificador "%1" ;
    ns1:textoExtracto "No se puede cargar la herramienta en la posición %1" .

ns1:Herramienta_2 a ns1:Herramienta ;
    ns1:identificador "%1" ;
    ns1:textoExtracto "No se puede descargar la herramienta %1" .

ns1:Herramienta_3 a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta no existe o ya está cargada en el almacén" .

ns1:Herramienta_4 a ns1:Herramienta ;
    ns1:identificador "%1" ;
    ns1:textoExtracto "La herramienta %1 no puede ser eliminada" .

ns1:TablaHerramientas_1 a ns1:Tabla ;
    ns1:textoExtracto "Cargando la tabla de herramientas." .

ns1:TablaHerramientas_2 a ns1:Tabla ;
    ns1:textoExtracto "Cargando la tabla de herramientas o de almacén." .

ns1:TablaHerramientas_3 a ns1:Tabla ;
    ns1:textoExtracto "Cargando la tabla de herramientas o de almacén." .

ns1:TablaHerramientas_4 a ns1:Tabla ;
    ns1:textoExtracto "al cargar la tabla de herramientas." .

