@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionParaFuncionDDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para función D doblemente programada" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2522b23d1f ;
    ns1:textoExtracto "Sólo puede haber una función D en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:SolucionParaFuncionHInexistente a ns1:TareaMantenimiento ;
    rdfs:label "Solución para función H inexistente" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_19a69af27f ;
    ns1:textoExtracto "SOLUCIÓN El número de la función deberá estar entre 1 y 65534." .

ns1:SolucionParaFuncionTDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para función T doblemente programada" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ea1387ea79 ;
    ns1:textoExtracto "Sólo puede haber una función T en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:SolucionParaVelocidadFDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para velocidad F doblemente programada" ;
    ns1:solucionaFallo ns1:VelocidadFDoblementeProgramada ;
    ns1:textoExtracto "Sólo puede haber una función F en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:DiagnosticoFallo_19a69af27f a ns1:DiagnosticoFallo ;
    rdfs:label "Función H inexistente" ;
    ns1:textoExtracto "'Función H inexistente' DETECCIÓN Durante la ejecución. CAUSA La función H no existe." .

ns1:DiagnosticoFallo_2522b23d1f a ns1:DiagnosticoFallo ;
    rdfs:label "Función D doblemente programada" ;
    ns1:textoExtracto "'Función D doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función D en el mismo bloque." .

ns1:DiagnosticoFallo_ea1387ea79 a ns1:DiagnosticoFallo ;
    rdfs:label "Función T doblemente programada" ;
    ns1:textoExtracto "'Función T doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función T en el mismo bloque." .

ns1:VelocidadFDoblementeProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad F doblemente programada" ;
    ns1:textoExtracto "'Velocidad F doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función F en el mismo bloque." .

