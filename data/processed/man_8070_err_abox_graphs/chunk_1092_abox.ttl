@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_CabezalHerramienta a ns1:AccionProhibida ;
    rdfs:label "acción prohibida: poner herramienta en cabezal"@es ;
    ns1:textoExtracto "No se puede poner en el cabezal la herramienta del brazo cambiador" .

ns1:AccionProhibida_PosicionAlmacen a ns1:AccionProhibida ;
    rdfs:label "acción prohibida: posición no existe"@es ;
    ns1:textoExtracto "' La posición no existe'" .

ns1:Herramienta_BrazoCambiador1 a ns1:Herramienta ;
    rdfs:label "herramienta del brazo cambiador 1"@es ;
    ns1:textoExtracto "La herramienta está en el brazo cambiador 1." .

ns1:Sistema_Almacen a ns1:Sistema ;
    rdfs:label "almacén"@es ;
    ns1:textoExtracto "En carga o descarga de una herramienta del almacén, con o sin maniobra." ;
    ns1:tieneComponente ns1:Almacen_Posicion .

ns1:Almacen_Posicion a ns1:Herramienta ;
    rdfs:label "posición del almacén"@es ;
    ns1:textoExtracto "La posición del almacén no existe." .

