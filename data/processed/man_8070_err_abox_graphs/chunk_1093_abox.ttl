@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Almacen a ns1:Sistema ;
    ns1:identificador "almacén" ;
    ns1:textoExtracto "La posición del almacén no existe." .

ns1:AplicacionExterna a ns1:Sistema ;
    ns1:identificador "aplicación externa" ;
    ns1:textoExtracto "está siendo usado por otra aplicación" .

ns1:DirectorioDestino a ns1:Parametro ;
    ns1:textoExtracto "SOLUCIÓN Definir el path correctamente o crear la carpeta de destino." ;
    ns1:valor "directorio" .

ns1:EspacioDisco a ns1:Parametro ;
    ns1:textoExtracto "no hay sitio en disco" ;
    ns1:valor "espacio en disco" .

ns1:FicheroDatos a ns1:Consumible ;
    ns1:identificador "fichero" ;
    ns1:textoExtracto "' Fichero %1 no encontrado' DETECCIÓN Al cargar la tabla de herramientas o almacén. CAUSA El fichero con los datos no existe." .

ns1:HerramientaAlmacen a ns1:Herramienta ;
    ns1:textoExtracto "En carga o descarga de una herramienta del almacén, con o sin maniobra." .

ns1:Impresora a ns1:ComponenteElectrico ;
    ns1:identificador "impresora" ;
    ns1:textoExtracto "ésta no existe o está mal configurada" .

ns1:Path a ns1:Parametro ;
    ns1:textoExtracto "' Path %1 no encontrado' DETECCIÓN Al cargar, guardar o imprimir la tabla de herramientas o almacén. CAUSA El path seleccionado no existe." ;
    ns1:valor "path" .

ns1:PermisoEscritura a ns1:Parametro ;
    ns1:textoExtracto "El fichero con los datos no se ha podido crear, ya existe y no tiene permiso de escritura" ;
    ns1:valor "permiso de escritura" .

ns1:PermisoLectura a ns1:Parametro ;
    ns1:textoExtracto "no tiene permiso de lectura" ;
    ns1:valor "permiso de lectura" .

ns1:TablaHerramientasAlmacen a ns1:Tabla ;
    ns1:textoExtracto "cambiador 1. ' La posición no existe' DETECCIÓN En carga o descarga de una herramienta del almacén, con o sin maniobra. CAUSA La posición del almacén no existe. SOLUCIÓN Elegir una posición existente del almacén. ' Path..." .

