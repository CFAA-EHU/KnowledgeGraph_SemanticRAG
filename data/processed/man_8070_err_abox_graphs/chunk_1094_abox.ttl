ns1:AscensoErroneoDeFase a ns1:DiagnosticoFallo ;
    rdfs:label "Ascenso erróneo de fase" ;
    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:ComprobarCableDeAlimentacionDelEncoderODeLaRegla a ns1:AccionProhibida ;
    rdfs:label "Comprobar cable de alimentación del encóder o de la regla" ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado." .

ns1:DescensoErroneoDeFase a ns1:DiagnosticoFallo ;
    rdfs:label "Descenso erróneo de fase" ;
    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:ErrorDeParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parámetros" ;
    ns1:textoExtracto "Pérdida de la configuración del encóder o de la cabeza de la regla. Reemplazar el encóder o la cabeza de la regla." .

ns1:FalloEnMDT a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en MDT" ;
    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:FalloEnMST a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en MST" ;
    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:FaseNoValida4 a ns1:DiagnosticoFallo ;
