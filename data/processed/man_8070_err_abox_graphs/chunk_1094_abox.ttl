    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:TensionDeAlimentacionFueraDeRango_3d7847571b a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación fuera de rango" ;
    ns1:textoExtracto "La tensión de alimentación debe estar entre 5,3 V y 4,1 V." .

ns1:VerificarConexionesEnElAnilloYLaIdentificacionDeCadaModulo a ns1:AccionProhibida ;
    rdfs:label "Verificar conexiones en el anillo y la identificación de cada módulo" ;
    ns1:textoExtracto "Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

