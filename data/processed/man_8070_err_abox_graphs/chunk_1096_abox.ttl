@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeHandshakeEnLaContadoraSercos a ns1:AvisoSeguridad ;
    rdfs:label "Error de handshake en la contadora Sercos" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "E413 Error de handshake en la contadora Sercos. El elemento master (CNC) envía un mensaje de sincronismo en cada ciclo (4ms, normalmente) que hace que los reguladores se sincronicen." .

ns1:ErrorDeRecepcionDeTelegramas_b820be6e15 a ns1:AvisoSeguridad ;
    rdfs:label "Error de recepción de telegramas" ;
    ns1:textoExtracto "E411 Error de recepción de telegramas. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:MensajeDeSincronismoRetrasado a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje de sincronismo retrasado" ;
    ns1:textoExtracto "E412 Mensaje de sincronismo retrasado. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

