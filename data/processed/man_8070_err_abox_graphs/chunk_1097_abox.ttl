@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CargarHerramientaEnPosicionNoDisponible a ns1:AccionProhibida ;
    rdfs:label "Cargar herramienta en posición no disponible" ;
    ns1:textoExtracto "'No se puede cargar la herramienta en la posición %1'" .

ns1:CargarHerramientaQueNoExisteOYaEstaCargada a ns1:AccionProhibida ;
    rdfs:label "Cargar herramienta que no existe o ya está cargada" ;
    ns1:textoExtracto "' La herramienta no existe o ya está cargada en el almacén'" .

ns1:CargarTablaConTipoIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Cargar tabla con tipo incorrecto" ;
    ns1:textoExtracto "' Tipo de tabla seleccionada incorrecta'" .

ns1:DescargarHerramientaQueNoExiste a ns1:AccionProhibida ;
    rdfs:label "Descargar herramienta que no existe" ;
    ns1:textoExtracto "' No se puede descargar la herramienta %1'" .

ns1:EjecutarManiobraConCabezalOcupado a ns1:AccionProhibida ;
    rdfs:label "Ejecutar maniobra con cabezal ocupado" ;
    ns1:textoExtracto "' No se puede ejecutar la maniobra. Comprobar que el cabezal esté vacío'" .

ns1:EliminarHerramientaQueNoSePuedeEliminar a ns1:AccionProhibida ;
    rdfs:label "Eliminar herramienta que no se puede eliminar" ;
    ns1:textoExtracto "' La herramienta %1 no puede ser eliminada'" .

