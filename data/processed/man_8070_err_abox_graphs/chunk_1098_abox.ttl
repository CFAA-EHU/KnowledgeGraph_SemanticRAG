@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_814825fc04 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de herramienta no eliminada" ;
    ns1:mitigaRiesgo ns1:Herramienta ;
    ns1:textoExtracto "'La herramienta %1 no puede ser eliminada'" .

ns1:CNC8070_1923e482f9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no encuentra la herramienta." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Definir la herramienta. Si está en el cabezal o en los brazos cambiadores, cargarla en el almacén." .

