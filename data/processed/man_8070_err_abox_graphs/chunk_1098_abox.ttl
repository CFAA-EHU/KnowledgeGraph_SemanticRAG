@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEjePlano a ns1:DiagnosticoFallo ;
    rdfs:label "Error en eje del plano" ;
    ns1:solucionaFallo ns1:PlanoEjeInvalido ;
    ns1:textoExtracto "Error en eje del plano" .

ns1:PlanoEjeValido a ns1:ModoOperacion ;
    rdfs:label "Plano con ejes válidos" ;
    ns1:textoExtracto "El plano debe estar formado por dos ejes diferentes. Ambos ejes deben estar presentes en el CNC." .

ns1:PlanoEjeInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Plano con ejes inválidos" ;
    ns1:textoExtracto "Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC." .

