ns1:DefinirLaHerramientaYCargarlaEnElAlmacen a ns1:AvisoSeguridad ;
    rdfs:label "Definir la herramienta y cargarla en el almacén" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "Definir la herramienta y cargarla en el almacén." .

ns1:ErrorRenombrandoLaHerramienta a ns1:AccionProhibida ;
    rdfs:label "Error renombrando la herramienta" ;
    ns1:textoExtracto "' Error renombrando la herramienta'" .

ns1:LaBaseDeDatosDebeTenerPermisoDeEscritura a ns1:AvisoSeguridad ;
    rdfs:label "La base de datos debe tener permiso de escritura" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "La base de datos debe tener permiso de escritura. Si la base de datos de las herramientas está siendo utilizada por otra aplicación, esperar a que se libere." .

ns1:NoSePuedePonerEnElCabezalLaHerramientaDelBrazoCambiador a ns1:AccionProhibida ;
    rdfs:label "No se puede poner en el cabezal la herramienta del brazo cambiador" ;
    ns1:textoExtracto "' No se puede poner en el cabezal la herramienta del brazo cambiador'" .

ns1:NoSePuedePonerUnaHerramientaEnElCabezalSiYaHayUnaEnElBrazo2 a ns1:AccionProhibida ;
    rdfs:label "No se puede poner una herramienta en el cabezal si ya hay una en el brazo 2" ;
    ns1:textoExtracto "' No se puede poner una herramienta en el cabezal si ya hay una en el brazo 2'" .

ns1:NoSePuedeRenombrarUnaHerramientaDeCabezalAlmacenOBrazos a ns1:AccionProhibida ;
    rdfs:label "No se puede renombrar una herramienta de cabezal, almacén o brazos" ;
    ns1:textoExtracto "' No se puede renombrar una herramienta de cabezal, almacén o brazos'" .

ns1:QuitarLaHerramientaDelBrazoCambiador1 a ns1:AvisoSeguridad ;
