@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1162
    a ex:Alarma ;
    rdfs:label "Alarma 1162: 'No se espera M17/M29/#RET'"@es ;
    ex:identificador "1162" ;
    ex:textoExtracto "1162 'No se espera M17/M29/#RET' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M17, M29 o #RET como final de programa. SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET."@es .

ex:Alarma_1163
    a ex:Alarma ;
    rdfs:label "Alarma 1163: 'No se espera M30/M02'"@es ;
    ex:identificador "1163" ;
    ex:textoExtracto "1163 'No se espera M30/M02' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M02 o M30 como final de subrutina. SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET."@es .

ex:Alarma_1164
    a ex:Alarma ;
    rdfs:label "Alarma 1164: 'Término desconocido en expresión matemática'"@es ;
    ex:identificador "1164" ;
    ex:textoExtracto "1164 'Término desconocido en expresión matemática' DETECCIÓN Durante la ejecución. CAUSA La expresión matemática es incorrecta. SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc."@es .

ex:Alarma_1165
    a ex:Alarma ;
    rdfs:label "Alarma 1165: 'Variable inexistente'"@es ;
    ex:identificador "1165" ;
    ex:textoExtracto "1165 'Variable inexistente' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable pedida no existe. • Error sintáctico en el nombre de la variable. • La variable es un array y no se ha indicado índice de array. • Se ha pedido una variable general para un eje determinado o a la inversa. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1166
    a ex:Alarma ;
    rdfs:label "Alarma 1166: 'Raíz de un número negativo'"@es ;
    ex:identificador "1166" ;
    ex:textoExtracto "1166 'Raíz de un número negativo' DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay una raíz cuadrada (SQRT) de un número negativo. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1167
    a ex:Alarma ;
    rdfs:label "Alarma 1167: 'Logaritmo de un número negativo o cero'"@es ;
    ex:identificador "1167" ;
    ex:textoExtracto "1167 'Logaritmo de un número negativo o cero' DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1168
    a ex:Alarma ;
    rdfs:label "Alarma 1168: 'Índice de variable fuera de rango'"@es ;
    ex:identificador "1168" ;
    ex:textoExtracto "1168 'Indice de variable fuera de rango' DETECCIÓN Durante la ejecución."@es .

ex:DiagnosticoFallo_1162
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1162: Revisión de programación de final de programa principal"@es ;
    ex:textoExtracto "SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET."@es ;
    ex:solucionaFallo ex:Alarma_1162 .

ex:DiagnosticoFallo_1163
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1163: Revisión de finalización de subrutinas"@es ;
    ex:textoExtracto "SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET."@es ;
    ex:solucionaFallo ex:Alarma_1163 .

ex:DiagnosticoFallo_1164
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1164: Revisión de términos en expresión matemática"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc."@es ;
    ex:solucionaFallo ex:Alarma_1164 .

ex:DiagnosticoFallo_1165
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1165: Revisión de variables en programación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1165 .

ex:DiagnosticoFallo_1166
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1166: Revisión de raíz cuadrada (SQRT) en programación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1166 .

ex:DiagnosticoFallo_1167
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1167: Revisión de logaritmos (LOG/LN) en programación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1167 .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "El CNC ha detectado una función M17, M29 o #RET como final de programa."@es ;
    ex:activaAlarma ex:Alarma_1162 , ex:Alarma_1163 , ex:Alarma_1164 , ex:Alarma_1165 , ex:Alarma_1166 , ex:Alarma_1167 , ex:Alarma_1168 .