@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BrazoCambiador1 a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador 1" ;
    ns1:textoExtracto "Quitar la herramienta del brazo cambiador 1." .

ns1:ComponenteMecanico_4040ae1c10 a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "La posición del almacén no existe." .

ns1:Herramienta_9347d3b254 a ns1:Herramienta ;
    rdfs:label "Herramienta del brazo cambiador" ;
    ns1:textoExtracto "La herramienta está en el brazo cambiador 1." .

ns1:QuitarHerramientaDelBrazoCambiador1 a ns1:TareaMantenimiento ;
    rdfs:label "Quitar herramienta del brazo cambiador 1" ;
    ns1:solucionaFallo ns1:ForzarHerramientaComoHerramientaDeCabezal ;
    ns1:textoExtracto "SOLUCIÓN Quitar la herramienta del brazo cambiador 1." .

ns1:SolucionElegirPosicionExistente a ns1:TareaMantenimiento ;
    rdfs:label "Elegir posición existente en almacén" ;
    ns1:solucionaFallo ns1:UsarPosicionNoExistenteEnAlmacen ;
    ns1:textoExtracto "SOLUCIÓN Elegir una posición existente." .

ns1:ForzarHerramientaComoHerramientaDeCabezal a ns1:AccionProhibida ;
    rdfs:label "Forzar herramienta como herramienta de cabezal" ;
    ns1:textoExtracto "Al forzar una herramienta como herramienta de cabezal." .

ns1:UsarPosicionNoExistenteEnAlmacen a ns1:AccionProhibida ;
    rdfs:label "Usar posición no existente en almacén" ;
    ns1:textoExtracto "La posición del almacén no existe." .

