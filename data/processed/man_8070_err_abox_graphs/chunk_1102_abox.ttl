@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CargarTablaInexistente a ns1:AccionProhibida ;
    rdfs:label "Cargar tabla inexistente" ;
    ns1:textoExtracto "Al cargar una tabla. Elegir ficheros que existan, indicar correctamente su path, darles permiso de lectura o cerrar la aplicación que los está usando." .

ns1:GuardarTablaSinPermisos a ns1:AccionProhibida ;
    rdfs:label "Guardar tabla sin permisos" ;
    ns1:textoExtracto "Al guardar una tabla o imprimir una tabla a un archivo. Elegir otro directorio para guardar las tablas, darles permiso de escritura, cerrar la aplicación que los está usando o liberar" .

