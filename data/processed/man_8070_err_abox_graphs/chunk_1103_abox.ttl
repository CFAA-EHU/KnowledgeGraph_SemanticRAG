@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_d705fdc5b3 a ns1:Herramienta ;
    rdfs:label "Impresora" ;
    ns1:textoExtracto "Al imprimir una tabla en una impresora, elegir una impresora que exista y que esté bien configurada." .

ns1:UsoSimultaneoDeAplicaciones a ns1:AccionProhibida ;
    rdfs:label "Uso simultáneo de aplicaciones" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_661e8d226a ;
    ns1:textoExtracto "cerrar la aplicación que los está usando" .

ns1:AvisoSeguridad_661e8d226a a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de espacio en disco" ;
    ns1:textoExtracto "Elegir otro directorio para guardar las tablas, darles permiso de escritura, cerrar la aplicación que los está usando o liberar espacio en el disco." .

