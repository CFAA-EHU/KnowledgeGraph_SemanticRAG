@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirElEjeDelPlano a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el eje del plano" ;
    ns1:solucionaFallo ns1:ErrorEnEjeDelPlano_ddb71af449 ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirElPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el perfil" ;
    ns1:solucionaFallo ns1:ErrorDeGeometria ;
    ns1:textoExtracto "SOLUCIÓN Corregir el perfil. Todas las trayectorias que definen el perfil deben estar correctamente definidas." .

ns1:CorregirElValorDeLaArista a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor de la arista" ;
    ns1:solucionaFallo ns1:ValorNoValido ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido." .

ns1:CorregirLosDatosDelArcoFinal a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del arco final" ;
    ns1:solucionaFallo ns1:ElArcoNoPasaPorSuCoordenadaFinal ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirLosDatosDelArcoInicial a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del arco inicial" ;
    ns1:solucionaFallo ns1:ElArcoNoPasaPorSuCoordenadaInicial ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirLosDatosDelArcoNoCoherente a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del arco no coherente" ;
    ns1:solucionaFallo ns1:NoHayArcoQueCumplaTodosLosDatos ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirLosDatosDelElemento a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del elemento" ;
    ns1:solucionaFallo ns1:ErrorEnDatosDelElemento ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirLosDatosDelElementoNoTangente a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del elemento no tangente" ;
    ns1:solucionaFallo ns1:ElementoNoTangenteAlAnterior ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:CorregirLosDatosDelPerfilCirculoORectangulo a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos del perfil 'círculo' o 'rectángulo'" ;
    ns1:solucionaFallo ns1:ErrorEnDatosDelPerfil ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento." .

ns1:MemoriaInsuficiente_fbc85846a4 a ns1:AccionProhibida ;
    rdfs:label "Memoria insuficiente" ;
    ns1:textoExtracto "' Memoria insuficiente' CAUSA No hay memoria de sistema para seguir con el editor de perfiles. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:PerfilSinResolver a ns1:AccionProhibida ;
    rdfs:label "Perfil sin resolver" ;
    ns1:textoExtracto "'Perfil sin resolver' CAUSA El perfil a salvar no está resuelto completamente. SOLUCIÓN Resolver el perfil que se desea salvar." .

ns1:ElArcoNoPasaPorSuCoordenadaFinal a ns1:AccionProhibida ;
    rdfs:label "El arco no pasa por su coordenada final" ;
    ns1:textoExtracto "' El arco no pasa por su coordenada final' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto final. SOLUCIÓN Corregir los datos del elemento." .

ns1:ElArcoNoPasaPorSuCoordenadaInicial a ns1:AccionProhibida ;
    rdfs:label "El arco no pasa por su coordenada inicial" ;
    ns1:textoExtracto "' El arco no pasa por su coordenada inicial' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto inicial. SOLUCIÓN Corregir los datos del elemento." .

ns1:ElementoNoTangenteAlAnterior a ns1:AccionProhibida ;
    rdfs:label "Elemento no tangente al anterior" ;
    ns1:textoExtracto "' Elemento no tangente al anterior' CAUSA La tangencia de un elemento no es coherente con el elemento anterior. SOLUCIÓN Corregir los datos del elemento." .

ns1:ErrorDeGeometria a ns1:AccionProhibida ;
    rdfs:label "Error de geometría" ;
    ns1:textoExtracto "' Error de geometría' CAUSA El perfil seleccionado tiene una geometría no válida. SOLUCIÓN Corregir el perfil." .

ns1:ErrorEnDatosDelElemento a ns1:AccionProhibida ;
    rdfs:label "Error en datos del elemento" ;
    ns1:textoExtracto "' Error en datos del elemento' CAUSA Los datos introducidos en un elemento son incorrectos. SOLUCIÓN Corregir los datos del elemento." .

ns1:ErrorEnDatosDelPerfil a ns1:AccionProhibida ;
    rdfs:label "Error en datos del perfil" ;
    ns1:textoExtracto "' Error en datos del perfil' CAUSA Datos no válidos en la edición de un perfil 'círculo' o 'rectángulo'. SOLUCIÓN Corregir los datos del elemento." .

ns1:ErrorEnEjeDelPlano_ddb71af449 a ns1:AccionProhibida ;
    rdfs:label "Error en eje del plano" ;
    ns1:textoExtracto "' Error en eje del plano' CAUSA Algún eje del plano no es válido." .

ns1:NoHayArcoQueCumplaTodosLosDatos a ns1:AccionProhibida ;
    rdfs:label "No hay arco que cumpla todos los datos" ;
    ns1:textoExtracto "' No hay arco que cumpla todos los datos' CAUSA El editor no puede encontrar un elemento arco coherente con todos los datos conocidos. SOLUCIÓN Corregir los datos del elemento." .

ns1:ValorNoValido a ns1:AccionProhibida ;
    rdfs:label "Valor no válido" ;
    ns1:textoExtracto "' Valor no válido' CAUSA El valor introducido para modificar una arista (redondeo, chaflán, entrada tangencial o salida tangencial) no es válido. SOLUCIÓN Corregir los datos del elemento." .

