@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirDatosDelElemento a ns1:TareaMantenimiento ;
    rdfs:label "Corregir datos del elemento" ;
    ns1:solucionaFallo ns1:ErrorEnEjeDelPlano ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido." .

ns1:ErrorEnEjeDelPlano a ns1:DiagnosticoFallo ;
    rdfs:label "Error en eje del plano" ;
    ns1:textoExtracto "' Error en eje del plano' CAUSA Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC." .

