@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:SolucionEjesPlano a ns1:TareaMantenimiento ;
    rdfs:label "Solución Ejes Plano" ;
    ns1:solucionaFallo ns1:ErrorEnEjeDelPlano ;
    ns1:textoExtracto "SOLUCIÓN El plano debe estar formado por dos ejes diferentes. Ambos ejes deben estar presentes en el CNC." .

ns1:ErrorEnEjeDelPlano a ns1:DiagnosticoFallo ;
    rdfs:label "Error en eje del plano" ;
    ns1:textoExtracto "' Error en eje del plano' CAUSA Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC." .

