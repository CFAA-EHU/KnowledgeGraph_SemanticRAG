@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElCabezalNoPerteneceAlCanal a ns1:AccionProhibida ;
    rdfs:label "El cabezal no pertenece al canal" ;
    ns1:textoExtracto "CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal." .

ns1:ElCabezalProgramadoEnElBloqueDebeExistirEnLaConfiguracionDelSistemaYDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "El cabezal programado en el bloque debe existir en la configuración del sistema y del canal" ;
    ns1:solucionaFallo ns1:ElCabezalNoExisteEnElSistema ;
    ns1:textoExtracto "SOLUCIÓN El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal." .

ns1:LosNombresValidosParaElCabezalSonSS1S9 a ns1:TareaMantenimiento ;
    rdfs:label "Los nombres válidos para el cabezal son S, S1, …, S9" ;
    ns1:solucionaFallo ns1:ElNombreDelCabezalNoEsValido ;
    ns1:textoExtracto "SOLUCIÓN Los nombres válidos para el cabezal son S, S1, …, S9." .

ns1:NombreDeCabezalDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de cabezal desconocido" ;
    ns1:textoExtracto "'Nombre de cabezal desconocido'" .

ns1:ProgramarElAvanceConLaFuncionF a ns1:TareaMantenimiento ;
    rdfs:label "Programar el avance con la función F" ;
    ns1:solucionaFallo ns1:ElAvanceSeHaProgramadoConLaFuncionE ;
    ns1:textoExtracto "SOLUCIÓN Programar el avance con la función F." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NoSeAdmiteProgramarLaVelocidadConE_0dcdeb0ae6 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VelocidadSDoblementeProgramada_38231e951d a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad S doblemente programada" ;
    ns1:textoExtracto "'Velocidad S doblemente programada'" .

ns1:ElAvanceSeHaProgramadoConLaFuncionE a ns1:AccionProhibida ;
    rdfs:label "El avance se ha programado con la función E" ;
    ns1:textoExtracto "CAUSA El avance se ha programado con la función E." .

ns1:ElCabezalNoExisteEnElSistema a ns1:AccionProhibida ;
    rdfs:label "El cabezal no existe en el sistema" ;
    ns1:textoExtracto "CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal." .

ns1:ElNombreDelCabezalNoEsValido a ns1:AccionProhibida ;
    rdfs:label "El nombre del cabezal no es válido" ;
    ns1:textoExtracto "CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal." .

ns1:NoSeAdmiteProgramarLaVelocidadConE_0dcdeb0ae6 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite programar la velocidad con E" ;
    ns1:textoExtracto "'No se admite programar la velocidad con E'" .

