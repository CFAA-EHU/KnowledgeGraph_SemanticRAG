@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1169
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1169: Sentencia #GET IPOOFFSET mal programada"@es ;
    ex:textoExtracto      "La sentencia #GET IPOOFFSET se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador      "1169" .

ex:AvisoSeguridad_1170
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1170: Sentencia #SYNC POS mal programada"@es ;
    ex:textoExtracto      "'La sentencia #SYNC POS se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador      "1170" .

ex:AvisoSeguridad_1171
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1171: Sentencias # programadas incorrectamente"@es ;
    ex:textoExtracto      "'Las sentencias # se programan solas en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. La única excepción es la sentencia #AXIS que se debe programar en el mismo bloque que la función G201."@es ;
    ex:identificador      "1171" .

ex:AvisoSeguridad_1172
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1172: Sentencia incompatible con compensación de radio activa"@es ;
    ex:textoExtracto      "'Sentencia no permitida con compensación de radio de herramienta activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una sentencia incompatible con la compensación de radio. SOLUCIÓN Desactivar la compensación de radio para ejecutar la sentencia."@es ;
    ex:identificador      "1172" .

ex:AvisoSeguridad_1173
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1173: Sentencia #UNLINK mal programada"@es ;
    ex:textoExtracto      "'La sentencia #UNLINK se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador      "1173" .

ex:AvisoSeguridad_1174
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1174: Conflicto en acoplo de ejes (#LINK)"@es ;
    ex:textoExtracto      "'#LINK: no se permite definir un nuevo acoplo con uno anterior activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador      "1174" .

