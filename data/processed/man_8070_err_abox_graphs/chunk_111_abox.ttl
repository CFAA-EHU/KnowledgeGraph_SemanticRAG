@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceDeParametroFueraDeRango_adf11d78c6 a ns1:AccionProhibida ;
    rdfs:label "Indice de parámetro fuera de rango" ;
    ns1:solucionaFallo ns1:ElParametroAritmeticoNoExisteNoEstaDentroDelRangoPermitidoPorLosParam_faf4e4c3e3 ;
    ns1:textoExtracto "'Indice de parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina." .

ns1:RevisarLaProgramacion_1fe4c615f9 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElParametroAritmeticoNoExisteNoEstaDentroDelRangoPermitidoPorLosParam_faf4e4c3e3 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." .

ns1:VelocidadSDoblementeProgramada_bf94f2fc13 a ns1:AccionProhibida ;
    rdfs:label "Velocidad S doblemente programada" ;
    ns1:solucionaFallo ns1:EnUnBloqueHayProgramadasParaElMismoCabezalDosOMasFuncionesS ;
    ns1:textoExtracto "'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones S." .

ns1:EnUnBloqueHayProgramadasParaElMismoCabezalDosOMasFuncionesS a ns1:DiagnosticoFallo ;
    rdfs:label "En un bloque hay programadas para el mismo cabezal dos o más funciones S" ;
    ns1:textoExtracto "CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones S." .

ns1:ElParametroAritmeticoNoExisteNoEstaDentroDelRangoPermitidoPorLosParam_faf4e4c3e3 a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina" ;
    ns1:textoExtracto "CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina." .

