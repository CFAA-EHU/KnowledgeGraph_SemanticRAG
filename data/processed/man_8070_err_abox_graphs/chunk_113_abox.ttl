@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminarCaracterDelPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar carácter '%' del programa" ;
    ns1:solucionaFallo ns1:NoSeAdmiteElCaracterDentroDelProgramaPrincipal_b2ca471c5d ;
    ns1:textoExtracto "SOLUCIÓN Eliminar este carácter del programa." .

ns1:RevisarProgramacionDeLaFuncionO a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de la función O" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_890b7ef9e5 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacionDelIndiceR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación del índice R" ;
    ns1:solucionaFallo ns1:NoSeAdmiteIndiceParaRDistintoDe1_bb83cd667f ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacionSentenciaIPOPOS a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación Sentencia IPOPOS" ;
    ns1:solucionaFallo ns1:SentenciaSETIPOPOSMalProgramada_6cadca48f9 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:DiagnosticoFallo_890b7ef9e5 a ns1:DiagnosticoFallo ;
    rdfs:label "Función O inexistente" ;
    ns1:textoExtracto "'Función O inexistente' DETECCIÓN Durante la ejecución. CAUSA La función O no existe." .

ns1:NoSeAdmiteElCaracterDentroDelProgramaPrincipal_b2ca471c5d a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite el carácter '%' dentro del programa principal" ;
    ns1:textoExtracto "'No se admite el carácter \"%\" dentro del programa principal' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite usar el carácter \"%\" como primer carácter en la definición del nombre del programa principal o de una subrutina local." .

ns1:NoSeAdmiteIndiceParaRDistintoDe1_bb83cd667f a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite índice para R distinto de 1" ;
    ns1:textoExtracto "'No se admite índice para R distinto de 1' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite programar el radio con R o R1." .

ns1:SentenciaSETIPOPOSMalProgramada_6cadca48f9 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #SET IPOPOS mal programada" ;
    ns1:textoExtracto "'Sentencia #SET IPOPOS mal programada' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

