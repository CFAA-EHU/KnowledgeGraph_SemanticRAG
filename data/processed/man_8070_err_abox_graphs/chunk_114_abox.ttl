@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1180
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de tipo de eje en acoplo (AXISTYPE)"@es ;
    ex:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)."@es ;
    ex:identificador "1180" ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "AXISTYPE" ;
        ex:textoExtracto "parámetro AXISTYPE"@es ;
        ex:valor "lineal/rotativo"@es
    ] .

ex:DiagnosticoFallo_1181
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de modo de eje rotativo (AXISMODE)"@es ;
    ex:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)."@es ;
    ex:identificador "1181" ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "AXISMODE" ;
        ex:textoExtracto "parámetro AXISMODE"@es ;
        ex:valor "linearlike/módulo"@es
    ] .

ex:ComponenteMecanico_AcoploEjes
    a ex:ComponenteMecanico ;
    rdfs:label "Acoplo de ejes maestro-esclavo"@es ;
    ex:textoExtracto "ejes maestro y esclavo del acoplo"@es ;
    ex:tieneComponente [
        a ex:ComponenteMecanico ;
        rdfs:label "Eje maestro"@es
    ], [
        a ex:ComponenteMecanico ;
        rdfs:label "Eje esclavo"@es
    ] .