@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarExistenciaYDisponibilidadDelEjeProgramado a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar existencia y disponibilidad del eje programado" ;
    ns1:solucionaFallo ns1:EjeInexistenteONoDisponible_157b9de000 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el eje programado existe en el canal y que está disponible (que no está aparcado)." .

ns1:EjeDoblementeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Eje doblemente programado" ;
    ns1:textoExtracto "'Eje doblemente programado' DETECCIÓN Durante la ejecución." .

ns1:EliminarCaracterInvalidoDelPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar carácter inválido del programa" ;
    ns1:solucionaFallo ns1:SeEsperaOperadorDeAsignacion ;
    ns1:textoExtracto "SOLUCIÓN Eliminar este carácter del programa." .

ns1:RevisarYCompletarLaProgramacionCon a ns1:TareaMantenimiento ;
    rdfs:label "Revisar y completar la programación con ']'." ;
    ns1:solucionaFallo ns1:SeEsperaEnLaExpresionOSentenciaProgramada ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EjeInexistenteONoDisponible_157b9de000 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible" ;
    ns1:textoExtracto "'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje que no existe o que no está disponible en el sistema o en el canal." .

ns1:SeEsperaEnLaExpresionOSentenciaProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera ']' en la expresión o sentencia programada" ;
    ns1:textoExtracto "'Se espera ']'' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada falta el corchete de cierre ']'" .

ns1:SeEsperaOperadorDeAsignacion a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera operador de asignación" ;
    ns1:textoExtracto "'Se espera operador de asignación' DETECCIÓN Durante la ejecución. CAUSA Falta un operador de asignación tras la variable o parámetro." .

