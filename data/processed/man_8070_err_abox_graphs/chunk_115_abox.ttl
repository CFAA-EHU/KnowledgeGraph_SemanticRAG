@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MovimientoDeEjeDoblementeProgramado a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje doblemente programado" ;
    ns1:mitigaRiesgo ns1:EjeDoblementeProgramado ;
    ns1:textoExtracto "En alguna de las siguientes funciones hay programado algún eje más de una vez." .

