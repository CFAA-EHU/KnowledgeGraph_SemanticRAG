@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1187
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1187: '#AXIS: nombre de eje repetido'"@es ;
    ex:textoExtracto "1187 '#AXIS: nombre de eje repetido' [...] CAUSA El mismo eje se ha programado más de una vez en la sentencia."@es ;
    ex:identificador "1187" .

ex:Error_1188
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1188: 'No se espera [\"'"@es ;
    ex:textoExtracto "1188 'No se espera \"[\"' [...] CAUSA Error en la sintaxis de la sentencia."@es ;
    ex:identificador "1188" .

ex:Error_1189
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'"@es ;
    ex:textoExtracto "1189 '#MPG: demasiados parámetros' [...] CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres"@es ;
    ex:identificador "1189" .

ex:Parametro_MPG
    a ex:Parametro ;
    rdfs:label "Parámetro #MPG"@es ;
    ex:textoExtracto "La sentencia #MPG admite un máximo de tres [parámetros]."@es ;
    ex:valor "máximo 3"@es .