@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:IndiceDeEjeIncorrecto,
        ns1:ValoresParaIJKDoblementeProgramados ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El índice del eje debe ser un valor entre 1 y el número máximo de ejes del sistema o del canal." .

ns1:IndiceDeEjeIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Indice de eje incorrecto" ;
    ns1:textoExtracto "'Indice de eje incorrecto' DETECCIÓN Durante la ejecución. CAUSA En las funciones G20 y G74, el índice programado junto al nombre del eje es incorrecto." .

ns1:ValoresParaIJKDoblementeProgramados a ns1:DiagnosticoFallo ;
    rdfs:label "Valores para I, J, K doblemente programados" ;
    ns1:textoExtracto "'Valores para I, J, K doblemente programados' DETECCIÓN Durante la ejecución. CAUSA Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque." .

