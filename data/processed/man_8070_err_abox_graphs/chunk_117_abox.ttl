@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:AlgunaSentenciaNoEstaProgramadaSolaEnElBloque,
        ns1:AlgunoDeLosParametrosIJKEstaProgramadoMasDeUnaVezEnElMismoBloque,
        ns1:LaSentenciaIFCondicionSoloPuedeIrSeguidaDeGOTO ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:AlgunaSentenciaNoEstaProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Alguna sentencia no está programada sola en el bloque" ;
    ns1:textoExtracto "CAUSA Alguna sentencia no está programada sola en el bloque." .

ns1:AlgunoDeLosParametrosIJKEstaProgramadoMasDeUnaVezEnElMismoBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque" ;
    ns1:textoExtracto "CAUSA Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque." .

ns1:LaSentenciaIFCondicionSoloPuedeIrSeguidaDeGOTO a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia $IF <condición> sólo puede ir seguida de $GOTO" ;
    ns1:textoExtracto "CAUSA La sentencia no está programada sola en el bloque y la información adicional no es un $GOTO." .

