@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_82be8023ba a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:NoSeEsperaELSE,
        ns1:NoSeEsperaELSEIF ;
    ns1:solucionaFallo ns1:RevisarProgramacion ;
    ns1:textoExtracto "CNC 8070" .

ns1:NoSeEsperaELSE a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera $ELSE" ;
    ns1:textoExtracto "'No se espera $ELSE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSE sin una instrucción $IF previa." .

ns1:NoSeEsperaELSEIF a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera $ELSEIF" ;
    ns1:textoExtracto "'No se espera $ELSEIF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSEIF sin" .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

