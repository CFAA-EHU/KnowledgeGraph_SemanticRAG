@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElCNCHaDetectadoUnaInstruccionCASESinUnaInstruccionSWITCHPrevia a ns1:AccionProhibida ;
    rdfs:label "El CNC ha detectado una instrucción $CASE sin una instrucción $SWITCH previa" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'No se espera $CASE'" .

ns1:ElCNCHaDetectadoUnaInstruccionDEFAULTSinUnaInstruccionSWITCHPrevia a ns1:AccionProhibida ;
    rdfs:label "El CNC ha detectado una instrucción $DEFAULT sin una instrucción $SWITCH previa" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'No se espera $DEFAULT'" .

ns1:ElCNCHaDetectadoUnaInstruccionELSEIFSinUnaInstruccionIFPrevia a ns1:AccionProhibida ;
    rdfs:label "El CNC ha detectado una instrucción $ELSEIF sin una instrucción $IF previa" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'No se espera $ELSEIF'" .

ns1:ElCNCHaDetectadoUnaInstruccionENDIFSinUnaInstruccionIFPrevia a ns1:AccionProhibida ;
    rdfs:label "El CNC ha detectado una instrucción $ENDIF sin una instrucción $IF previa" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'No se espera $ENDIF'" .

ns1:LaSentenciaNoEstaProgramadaSolaEnElBloque a ns1:AccionProhibida ;
    rdfs:label "La sentencia no está programada sola en el bloque" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'La sentencia $ELSEIF <condición> se programa sola en el bloque'" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

