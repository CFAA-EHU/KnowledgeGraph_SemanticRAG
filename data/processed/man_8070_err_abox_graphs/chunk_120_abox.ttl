@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaSentenciaDEFAULTSeProgramaSolaEnElBloque,
        ns1:LaSentenciaENDSWITCHSeProgramaSolaEnElBloque,
        ns1:NoSeEsperaENDSWITCH ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:LaSentenciaDEFAULTSeProgramaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia $DEFAULT se programa sola en el bloque" ;
    ns1:textoExtracto "'La sentencia $DEFAULT se programa sola en el bloque'" .

ns1:LaSentenciaENDSWITCHSeProgramaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia $ENDSWITCH se programa sola en el bloque" ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque'" .

ns1:NoSeEsperaENDSWITCH a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera $ENDSWITCH" ;
    ns1:textoExtracto "'No se espera $ENDSWITCH'" .

