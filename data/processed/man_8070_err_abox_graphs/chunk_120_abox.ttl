@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_1202
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1202: Demasiados parámetros en #SET IPOPOS" ;
    ex:identificador "1202" ;
    ex:textoExtracto "#SET IPOPOS: demasiados parámetros. DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene demasiados parámetros. SOLUCIÓN Revisar la programación." .

ex:Error_1203
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1203: Sentencia #SET IPOPOS no programada sola en el bloque" ;
    ex:identificador "1203" ;
    ex:textoExtracto "'La sentencia #SET IPOPOS se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ex:Error_1204
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1204: Sentencia mal programada o inexistente" ;
    ex:identificador "1204" ;
    ex:textoExtracto "'Sentencia mal programada o inexistente' DETECCIÓN Durante la ejecución. CAUSA La sentencia no existe o está mal programada. SOLUCIÓN Revisar la programación." .

ex:Parametro_IPOPOS
    a ex:Parametro ;
    rdfs:label "Parámetro IPOPOS" ;
    ex:textoExtracto "#SET IPOPOS" ;
    ex:monitoreaParametro ex:Error_1202, ex:Error_1203, ex:Error_1204 .