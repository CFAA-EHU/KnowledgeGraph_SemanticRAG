@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a178c1b461 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa." .

ns1:RevisarLaProgramacionParaENDFOR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para $ENDFOR" ;
    ns1:solucionaFallo ns1:NoSeEsperaENDFOR ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarLaProgramacionParaElContadorDeFOR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para el contador de $FOR" ;
    ns1:solucionaFallo ns1:FORVariableContadorNoValida ;
    ns1:textoExtracto "SOLUCIÓN El contador de la instrucción $FOR podrá ser una variable o parámetro aritmético." .

ns1:RevisarLaProgramacionParaWHILE a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para $WHILE" ;
    ns1:solucionaFallo ns1:WHILEDemasiadosCaracteresEnLaCondicion ;
    ns1:textoExtracto "SOLUCIÓN El máximo número de caracteres permitidos es 5000." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:InstruccionENDSWITCHSinUnaInstruccionSWITCHPrevia ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:FORVariableContadorNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "$FOR: variable contador no válida" ;
    ns1:textoExtracto "'$FOR: variable contador no válida'" .

ns1:InstruccionENDSWITCHSinUnaInstruccionSWITCHPrevia a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción $ENDSWITCH sin una instrucción $SWITCH previa" ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque'" .

ns1:NoSeEsperaENDFOR a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera $ENDFOR" ;
    ns1:textoExtracto "'No se espera $ENDFOR'" .

ns1:WHILEDemasiadosCaracteresEnLaCondicion a ns1:DiagnosticoFallo ;
    rdfs:label "$WHILE: demasiados caracteres en la condición" ;
    ns1:textoExtracto "'$WHILE: demasiados caracteres en la condición'" .

