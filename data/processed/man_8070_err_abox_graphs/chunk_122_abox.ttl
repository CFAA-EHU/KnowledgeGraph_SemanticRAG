@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error1212
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1212: '#CALL AX/#SET AX: número de eje repetido'"@es ;
    ex:identificador      "1212" ;
    ex:textoExtracto      "1212 '#CALL AX/#SET AX: número de eje repetido' DETECCIÓN Durante la ejecución. CAUSA Dos ejes intentan ocupar la mismo posición en el canal. SOLUCIÓN Revisar la programación."@es .

ex:Error1213
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1213: '#CALL AX/#SET AX: no se admite con G63 activa'"@es ;
    ex:identificador      "1213" ;
    ex:textoExtracto      "1213 '#CALL AX/#SET AX: no se admite con G63 activa' DETECCIÓN Durante la ejecución. CAUSA No se permite programar #CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ex:Error1214
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1214: '#CALL AX/#SET AX: demasiados ejes'"@es ;
    ex:identificador      "1214" ;
    ex:textoExtracto      "1214 '#CALL AX/#SET AX: demasiados ejes"@es .