@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0cd851e475 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:BREAKProgramadoSoloEnElBloque,
        ns1:BREAKSinBucleDeControlAbierto,
        ns1:CONTINUESinBucleDeControlAbierto,
        ns1:DOProgramadoSoloEnElBloque,
        ns1:ENDDOExpresionProgramadoSoloEnElBloque,
        ns1:ENDDOSinDOPrevia,
        ns1:ENDWHILESinWHILEPrevia ;
    ns1:textoExtracto "CNC 8070" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:BREAKProgramadoSoloEnElBloque,
        ns1:BREAKSinBucleDeControlAbierto,
        ns1:CONTINUESinBucleDeControlAbierto,
        ns1:DOProgramadoSoloEnElBloque,
        ns1:ENDDOExpresionProgramadoSoloEnElBloque,
        ns1:ENDDOSinDOPrevia,
        ns1:ENDWHILESinWHILEPrevia ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:BREAKProgramadoSoloEnElBloque a ns1:AccionProhibida ;
    rdfs:label "$BREAK programado solo en el bloque" ;
    ns1:textoExtracto "'La sentencia $BREAK se programa sola en el bloque'" .

ns1:BREAKSinBucleDeControlAbierto a ns1:AccionProhibida ;
    rdfs:label "$BREAK sin bucle de control abierto" ;
    ns1:textoExtracto "'No se espera $BREAK'" .

ns1:CONTINUESinBucleDeControlAbierto a ns1:AccionProhibida ;
    rdfs:label "$CONTINUE sin bucle de control abierto" ;
    ns1:textoExtracto "'No se espera $CONTINUE'" .

ns1:DOProgramadoSoloEnElBloque a ns1:AccionProhibida ;
    rdfs:label "$DO programado solo en el bloque" ;
    ns1:textoExtracto "'La sentencia $DO se programa sola en el bloque'" .

ns1:ENDDOExpresionProgramadoSoloEnElBloque a ns1:AccionProhibida ;
    rdfs:label "$ENDDO <expresión> programado solo en el bloque" ;
    ns1:textoExtracto "'La sentencia $ENDDO <expresión> se programa sola en el bloque'" .

ns1:ENDDOSinDOPrevia a ns1:AccionProhibida ;
    rdfs:label "$ENDDO sin $DO previa" ;
    ns1:textoExtracto "'No se espera $ENDDO'" .

ns1:ENDWHILESinWHILEPrevia a ns1:AccionProhibida ;
    rdfs:label "$ENDWHILE sin $WHILE previa" ;
    ns1:textoExtracto "'La sentencia $ENDWHILE se programa sola en el bloque'" .

