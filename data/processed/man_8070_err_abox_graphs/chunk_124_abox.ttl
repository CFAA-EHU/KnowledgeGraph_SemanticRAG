@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaSentenciaCONTINUESeProgramaSolaEnElBloque,
        ns1:LaSentenciaTIMESeProgramaSolaEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:LaSentenciaCONTINUESeProgramaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia $CONTINUE se programa sola en el bloque" ;
    ns1:textoExtracto "'La sentencia $CONTINUE se programa sola en el bloque'" .

ns1:LaSentenciaTIMESeProgramaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #TIME se programa sola en el bloque" ;
    ns1:textoExtracto "'La sentencia #TIME se programa sola en el bloque'" .

