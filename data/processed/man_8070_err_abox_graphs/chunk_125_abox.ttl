@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnidamientoDeSubrutinasSobrepasado_42dec42e54 a ns1:DiagnosticoFallo ;
    rdfs:label "Anidamiento de subrutinas sobrepasado" ;
    ns1:textoExtracto "'Anidamiento de subrutinas sobrepasado'" .

ns1:NoProgramarNingunBloqueEntreLaFuncionGYElPrimerBloqueDeMovimiento a ns1:TareaMantenimiento ;
    rdfs:label "No programar ningún bloque entre la función G y el primer bloque de movimiento" ;
    ns1:solucionaFallo ns1:LasFuncionesG8G36G37G38G39DebenEstarPrecedidasDeUnBloqueDeMovimiento ;
    ns1:textoExtracto "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." .

ns1:NoProgramarNingunBloqueEntreLaFuncionGYElSegundoBloqueDeMovimiento a ns1:TareaMantenimiento ;
    rdfs:label "No programar ningún bloque entre la función G y el segundo bloque de movimiento" ;
    ns1:solucionaFallo ns1:LasFuncionesG36G37G38G39DebenEstarSeguidasDeUnBloqueDeMovimiento ;
    ns1:textoExtracto "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el segundo bloque de movimiento." .

ns1:RevisarElRadioProgramadoYComprobarEmpalme a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el radio programado y comprobar empalme" ;
    ns1:solucionaFallo ns1:NoEsPosibleEjecutarG36G37G38G39Programada ;
    ns1:textoExtracto "SOLUCIÓN Revisar el radio programado. Comprobar que el empalme es realmente posible entre los bloques inicial y final." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaSentenciaNoEstaProgramadaSolaEnElBloque_e5bb232472,
        ns1:LaTrayectoriaAnteriorAG37DebeSerLineal,
        ns1:LaTrayectoriaPosteriorAG38DebeSerLineal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:LaSentenciaNoEstaProgramadaSolaEnElBloque_e5bb232472 a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia no está programada sola en el bloque" ;
    ns1:textoExtracto "'La sentencia #TIME se programa sola en el bloque'" .

ns1:LaTrayectoriaAnteriorAG37DebeSerLineal a ns1:DiagnosticoFallo ;
    rdfs:label "La trayectoria anterior a G37 debe ser lineal" ;
    ns1:textoExtracto "'La trayectoria anterior a G37 debe ser lineal'" .

ns1:LaTrayectoriaPosteriorAG38DebeSerLineal a ns1:DiagnosticoFallo ;
    rdfs:label "La trayectoria posterior a G38 debe ser lineal" ;
    ns1:textoExtracto "'La trayectoria posterior a G38 debe ser lineal'" .

ns1:LasFuncionesG36G37G38G39DebenEstarSeguidasDeUnBloqueDeMovimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Las funciones G36/G37/G38/G39 deben estar seguidas de un bloque de movimiento" ;
    ns1:textoExtracto "'Las funciones G36/G37/G38/G39 deben estar seguidas de un bloque de movimiento'" .

ns1:LasFuncionesG8G36G37G38G39DebenEstarPrecedidasDeUnBloqueDeMovimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Las funciones G8/G36/G37/G38/G39 deben estar precedidas de un bloque de movimiento" ;
    ns1:textoExtracto "'Las funciones G8/G36/G37/G38/G39 deben estar precedidas de un bloque de movimiento'" .

ns1:NoEsPosibleEjecutarG36G37G38G39Programada a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible ejecutar G36/G37/G38/G39 programada" ;
    ns1:textoExtracto "'No es posible ejecutar G36/G37/G38/G39 programada'" .

