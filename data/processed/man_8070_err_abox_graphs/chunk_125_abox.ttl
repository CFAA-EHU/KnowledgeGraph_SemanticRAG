@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1221
    a ex:Alarma ;
    rdfs:label "Error 1221: Sentencia #SET AX no programada sola en bloque"@es ;
    ex:textoExtracto "'La sentencia #SET AX se programa sola en el bloque' [...] CAUSA La sentencia no está programada sola en el bloque."@es ;
    ex:identificador "1221" .

ex:Alarma_1222
    a ex:Alarma ;
    rdfs:label "Error 1222: Bloque #COMMENT END sin apertura"@es ;
    ex:textoExtracto "'No se espera #COMMENT END' [...] CAUSA Hay un bloque de fin de comentario (#COMMENT END) pero falta el bloque de abrir comentario (#COMMENT BEGIN)."@es ;
    ex:identificador "1222" .

ex:Alarma_1223
    a ex:Alarma ;
    rdfs:label "Error 1223: Fin de fichero dentro de bloque comentario"@es ;
    ex:textoExtracto "'Carácter de fin de fichero dentro de bloque comentario' [...] CAUSA [...] falta el bloque de fin de comentario (#COMMENT END)."@es ;
    ex:identificador "1223" .

ex:Alarma_1224
    a ex:Alarma ;
    rdfs:label "Error 1224: Operador desconocido o faltante"@es ;
    ex:textoExtracto "'Falta operador u operador desconocido' [...] CAUSA Falta un operador de asignación tras la variable o parámetro."@es ;
    ex:identificador "1224" .

ex:Alarma_1225
    a ex:Alarma ;
    rdfs:label "Error 1225: División por cero"@es ;
    ex:textoExtracto "'División por cero' [...] CAUSA Una de las operaciones programadas realiza una división por cero."@es ;
    ex:identificador "1225" .

ex:Alarma_1226
    a ex:Alarma ;
    rdfs:label "Error 1226: Falta eje frontal para compensación de herramienta"@es ;
    ex:textoExtracto "No hay eje frontal en el plano para compensar el factor de forma de herramienta de torno. [...] SOLUCIÓN Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)."@es ;
    ex:identificador "1226" .

ex:Alarma_1227
    a ex:Alarma ;
    rdfs:label "Error 1227: Falta eje lateral para compensación de herramienta"@es ;
    ex:textoExtracto "No hay eje lateral en el plano para compensar el factor de forma de herramienta de torno. [...] SOLUCIÓN Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)."@es ;
    ex:identificador "1227" .

ex:Alarma_1229
    a ex:Alarma ;
    rdfs:label "Error 1229: Anidamiento de condicionales excedido"@es ;
    ex:textoExtracto "Anidamiento de sentencias condicionales sobrepasado."@es ;
    ex:identificador "1229" .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "parámetro FACEAXIS"@es ;
    ex:valor "eje_frontal" .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "parámetro LONGAXIS"@es ;
    ex:valor "eje_longitudinal" .

ex:Alarma_1226 ex:mitigaRiesgo ex:Parametro_FACEAXIS .
ex:Alarma_1227 ex:mitigaRiesgo ex:Parametro_LONGAXIS .