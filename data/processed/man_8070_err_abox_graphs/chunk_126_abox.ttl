@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirElProgramaReduciendoElNumeroDeLlamadasASubrutinasLocalesYGlob_c3f1979616 a ns1:AccionProhibida ;
    rdfs:label "Corregir el programa reduciendo el número de llamadas a subrutinas (locales y globales) que implican un nuevo nivel de imbricación" ;
    ns1:textoExtracto "SOLUCIÓN Corregir el programa reduciendo el número de llamadas a subrutinas (locales y globales) que implican un nuevo nivel de imbricación." .

ns1:NoProgramarNingunBloqueEntreLaFuncionGQueDefineLaTrayectoriaDeEmpalme_272807f84a a ns1:AccionProhibida ;
    rdfs:label "No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento" ;
    ns1:solucionaFallo ns1:AnidamientoDeSubrutinasSobrepasado_b1f4f2ee6e ;
    ns1:textoExtracto "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC permite 20 niveles de imbricación." .

ns1:AnidamientoDeSubrutinasSobrepasado_b1f4f2ee6e a ns1:DiagnosticoFallo ;
    rdfs:label "'Anidamiento de subrutinas sobrepasado'" ;
    ns1:textoExtracto "1152 'Anidamiento de subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el número de niveles de imbricación permitido." .

