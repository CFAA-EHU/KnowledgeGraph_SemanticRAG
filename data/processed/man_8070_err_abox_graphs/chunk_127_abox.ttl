@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1229
    a               ex:Alarma ;
    rdfs:label      "Anidamiento de sentencias condicionales sobrepasado"@es ;
    ex:identificador "1229" ;
    ex:textoExtracto "1229 Anidamiento de sentencias condicionales sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR, $WHILE y $DO. SOLUCIÓN Revisar la programación. El máximo número de anidamientos es 20."@es .

ex:Alarma_1233
    a               ex:Alarma ;
    rdfs:label      "El traslado programado excede el rango de datos"@es ;
    ex:identificador "1233" ;
    ex:textoExtracto "1233 'El traslado programado excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA El traslado de origen definido supera al máximo permitido. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1236
    a               ex:Alarma ;
    rdfs:label      "Nombre de macro demasiado largo"@es ;
    ex:identificador "1236" ;
    ex:textoExtracto "1236 'Nombre de macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la macro supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 30."@es .

ex:Alarma_1237
    a               ex:Alarma ;
    rdfs:label      "Se espera \"\\\" en el texto asociado a la macro"@es ;
    ex:identificador "1237" ;
    ex:textoExtracto "1237 'Se espera \"\\\" en el texto asociado a la macro' DETECCIÓN Durante la ejecución. CAUSA En el texto de sustitución de una macro, se ha incluido una macro que no comienza por el carácter \"\\\\\". SOLUCIÓN El texto de sustitución de una macro debe ir entre comillas y puede incluir otras macros, las cuales deben estar delimitadas por los caracteres \\\"; por ejemplo \"macro\"=\"\\\"macro1\\\" \\\"macro2\\\"\""@es .

ex:Alarma_1238
    a               ex:Alarma ;
    rdfs:label      "Texto de sustitución de la macro demasiado largo"@es ;
    ex:identificador "1238" ;
    ex:textoExtracto "1238 'Texto de sustitución de la macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El número de caracteres del texto de sustitución de la macro supera el máximo permitido. SOLUCIÓN El máximo número de caracteres permitidos es 140."@es .

ex:Alarma_1239
    a               ex:Alarma ;
    rdfs:label      "Número máximo de macros sobrepasado"@es ;
    ex:identificador "1239" ;
    ex:textoExtracto "1239 'Número máximo de macros sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de macros en el CNC. SOLUCIÓN El máximo es 50 macros. Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB."@es .

ex:Alarma_1240
    a               ex:Alarma ;
    rdfs:label      "Macro inexistente"@es ;
    ex:identificador "1240" ;
    ex:textoExtracto "1240 'Macro inexistente' DETECCIÓN Durante la ejecución. CAUSA La macro no está definida en el programa. SOLUCIÓN Definir la macro antes de utilizarla."@es .

ex:Parametro_LONGAXIS
    a               ex:Parametro ;
    rdfs:label      "eje longitudinal"@es ;
    ex:identificador "LONGAXIS" ;
    ex:textoExtracto "como eje longitudinal (parámetro LONGAXIS)."@es .