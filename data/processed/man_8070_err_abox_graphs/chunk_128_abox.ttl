@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:TablaMacrosCNC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de macros del CNC" ;
    ex:textoExtracto "El CNC almacena en una tabla las macros definidas desde un programa o desde el modo MDI/MDA, de manera que están disponibles para todos los programas ejecutados a continuación." ;
    ex:identificador "MACROTAB" .

ex:ErrorMacroInexistente
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1240: Macro inexistente" ;
    ex:textoExtracto "1240 'Macro inexistente' [...] CAUSA La macro no está definida en el programa." ;
    ex:identificador "1240" .

ex:SentenciaINIT_MACROTAB
    a ex:Parametro ;
    rdfs:label "Sentencia de inicialización de tabla de macros" ;
    ex:textoExtracto "Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB. [...] El CNC inicializa la tabla de macros en el arranque o mediante la sentencia" ;
    ex:identificador "#INIT MACROTAB" ;
    ex:valor "inicialización" .

ex:ModoMDI_MDA
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ex:textoExtracto "las macros definidas desde un programa o desde el modo MDI/MDA" .