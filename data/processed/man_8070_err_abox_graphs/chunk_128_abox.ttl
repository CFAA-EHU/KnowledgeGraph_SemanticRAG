@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloquesDeControlAbiertos_c018e3267e a ns1:AccionProhibida ;
    rdfs:label "Bloques de control $ abiertos" ;
    ns1:textoExtracto "'Bloques de control $ abiertos' DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado un bloque de control \"$\" que no tiene su correspondiente instrucción de cierre." .

ns1:ComprobarFuncionGODefinirSubrutinaAsociada_43b3dadb8d a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar función G o definir subrutina asociada" ;
    ns1:solucionaFallo ns1:ComprobarFuncionGODefinirSubrutinaAsociada ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que la función G es correcta o definir la subrutina asociada." .

ns1:ComprobarNombreDeSubrutinaLocalODefinirComoGlobal_3152e6844f a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar nombre de subrutina local o definir como global" ;
    ns1:solucionaFallo ns1:ComprobarNombreDeSubrutinaLocalODefinirComoGlobal ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el nombre de la subrutina local en el bloque de llamada es idéntico al nombre que aparece en su definición. Definir la subrutina local como global." .

ns1:ComprobarNombreYPathDeLaSubrutina_d2d1ae52b7 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar nombre y path de la subrutina" ;
    ns1:solucionaFallo ns1:ComprobarNombreYPathDeLaSubrutina ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el nombre y path de la subrutina son correctos." .

