    rdfs:label "Corregir bloques de control $ abiertos" ;
    ns1:solucionaFallo ns1:CorregirBloquesDeControlAbiertos ;
    ns1:textoExtracto "SOLUCIÓN Corregir los bloques de control \"$\" que no tienen su correspondiente instrucción de cierre." .

ns1:NoExisteSubrutinaAsociadaAG a ns1:AccionProhibida ;
    rdfs:label "No existe subrutina asociada a G" ;
    ns1:textoExtracto "'No existe subrutina asociada a G' DETECCIÓN Durante la ejecución. CAUSA Se ha programado un subrutina de usuario (G500-G599) o subrutina OEM (G180-G189/G380-G399) y no existe la subrutina." .

ns1:NombreDeSubrutinaLocalDemasiadoLargo a ns1:AccionProhibida ;
    rdfs:label "Nombre de subrutina local demasiado largo" ;
    ns1:textoExtracto "'Nombre de subrutina local demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la subrutina supera el número de caracteres permitido por el CNC." .

