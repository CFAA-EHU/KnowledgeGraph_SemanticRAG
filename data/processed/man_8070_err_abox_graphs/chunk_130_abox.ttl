    rdfs:label "No se espera M30/M02" ;
    ns1:textoExtracto "'1163 'No se espera M30/M02''" .

ns1:RaizDeUnNumeroNegativo a ns1:DiagnosticoFallo ;
    rdfs:label "Raíz de un número negativo" ;
    ns1:textoExtracto "'1166 'Raíz de un número negativo''" .

ns1:TerminoDesconocidoEnExpresionMatematica a ns1:DiagnosticoFallo ;
