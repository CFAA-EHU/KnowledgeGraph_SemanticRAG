@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarFinalDeProgramaYSubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar final de programa y subrutinas" ;
    ns1:solucionaFallo ns1:NoSeEsperaM17M29RET_aa75132c15 ;
    ns1:textoExtracto "'SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET.'" .

ns1:ComprobarFinalDeSubrutinasYProgramacionPrincipal a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar final de subrutinas y programación principal" ;
    ns1:solucionaFallo ns1:NoSeEsperaM30M02 ;
    ns1:textoExtracto "'SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET.'" .

ns1:IndiceDeVariableFueraDeRango_72636954da a ns1:DiagnosticoFallo ;
    rdfs:label "Indice de variable fuera de rango" ;
    ns1:textoExtracto "'1168 'Indice de variable fuera de rango''" .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:BloqueDeControlSinInstruccionDeCierre ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación.'" .

ns1:RevisarProgramacionYExpresionesMatematicas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación y expresiones matemáticas" ;
    ns1:solucionaFallo ns1:LogaritmoDeUnNumeroNegativoOCero,
        ns1:RaizDeUnNumeroNegativo ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación.'" .

ns1:RevisarProgramacionYNombresDeVariables a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación y nombres de variables" ;
    ns1:solucionaFallo ns1:VariableInexistente ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación.'" .

ns1:RevisarTerminosDeLaExpresionMatematica a ns1:TareaMantenimiento ;
    rdfs:label "Revisar términos de la expresión matemática" ;
    ns1:solucionaFallo ns1:TerminoDesconocidoEnExpresionMatematica ;
    ns1:textoExtracto "'SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc.'" .

ns1:BloqueDeControlSinInstruccionDeCierre a ns1:DiagnosticoFallo ;
    rdfs:label "Bloque de control sin instrucción de cierre" ;
    ns1:textoExtracto "'un bloque de control \"$\" que no tiene su correspondiente instrucción de cierre'" .

ns1:LogaritmoDeUnNumeroNegativoOCero a ns1:DiagnosticoFallo ;
    rdfs:label "Logaritmo de un número negativo o cero" ;
    ns1:textoExtracto "'1167 'Logaritmo de un número negativo o cero''" .

