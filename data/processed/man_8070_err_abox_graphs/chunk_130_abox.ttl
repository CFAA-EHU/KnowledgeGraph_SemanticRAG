@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1248
    a               ex:DiagnosticoFallo ;
    rdfs:label      "No se admite roscado y G192 en el mismo bloque"@es ;
    ex:identificador "1248" ;
    ex:textoExtracto "El CNC no permite programar las funciones G63 (roscado rígido) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

ex:Fallo_1249
    a               ex:DiagnosticoFallo ;
    rdfs:label      "No se admite cambio de gama con G96 activa"@es ;
    ex:identificador "1249" ;
    ex:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). SOLUCIÓN Activar el modo de velocidad de giro constante (G97)."@es .

ex:Fallo_1248_1249
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Incompatibilidad de funciones G en roscado rígido"@es ;
    ex:textoExtracto "CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). [...] 1248 'No se admite roscado y G192 en el mismo bloque' [...] 1249 'No se admite cambio de gama con G96 activa'"@es ;
    ex:solucionaFallo ex:Fallo_1248 , ex:Fallo_1249 .