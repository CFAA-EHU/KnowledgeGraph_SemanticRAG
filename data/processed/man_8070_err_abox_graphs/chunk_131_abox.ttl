@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceDeVariable a ns1:Parametro ;
    rdfs:label "Índice de variable" ;
    ns1:textoExtracto "Alguno de los índices definidos en la variable de array es incorrecto." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:IndiceDeVariableFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:IndiceDeVariableFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Indice de variable fuera de rango" ;
    ns1:textoExtracto "'Indice de variable fuera de rango'" .

