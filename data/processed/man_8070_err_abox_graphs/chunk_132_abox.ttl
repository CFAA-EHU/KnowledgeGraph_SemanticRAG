@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarCompensacionDeRadio a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar compensación de radio" ;
    ns1:solucionaFallo ns1:SentenciaNoPermitidaConCompensacionDeRadioDeHerramientaActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio para ejecutar la sentencia." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:LINKNoSePermiteDefinirUnNuevoAcoploConUnoAnteriorActivo,
        ns1:LaSentenciaUNLINKNoEstaProgramadaSolaEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacion_a8bb4bbddd a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:LaSentenciaGETIPOOFFSETNoEstaProgramadaSolaEnElBloque,
        ns1:LaSentenciaSYNCPOSNoEstaProgramadaSolaEnElBloque,
        ns1:LasSentenciasNoEstanProgramadasSolaEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:LINKNoSePermiteDefinirUnNuevoAcoploConUnoAnteriorActivo a ns1:DiagnosticoFallo ;
    rdfs:label "#LINK: no se permite definir un nuevo acoplo con uno anterior activo" ;
    ns1:textoExtracto "#LINK: no se permite definir un nuevo acoplo con uno anterior activo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero." .

ns1:LaSentenciaGETIPOOFFSETNoEstaProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #GET IPOOFFSET no está programada sola en el bloque" ;
    ns1:textoExtracto "La sentencia #GET IPOOFFSET se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque." .

ns1:LaSentenciaSYNCPOSNoEstaProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #SYNC POS no está programada sola en el bloque" ;
    ns1:textoExtracto "La sentencia #SYNC POS se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque." .

ns1:LaSentenciaUNLINKNoEstaProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #UNLINK no está programada sola en el bloque" ;
    ns1:textoExtracto "La sentencia #UNLINK se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque." .

ns1:LasSentenciasNoEstanProgramadasSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Las sentencias # no están programadas sola en el bloque" ;
    ns1:textoExtracto "Las sentencias # se programan solas en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque." .

ns1:SentenciaNoPermitidaConCompensacionDeRadioDeHerramientaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida con compensación de radio de herramienta activa" ;
    ns1:textoExtracto "Sentencia no permitida con compensación de radio de herramienta activa. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una sentencia incompatible con la compensación de radio." .

