@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnNuevoAcoploConUnoAnteriorActivo a ns1:AccionProhibida ;
    rdfs:label "definir un nuevo acoplo con uno anterior activo" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'#LINK: no se permite definir un nuevo acoplo con uno anterior activo'" .

ns1:RevisarLaProgramacionYDesactivarElPrimerAcoploAntesDeActivarElSegundo a ns1:TareaMantenimiento ;
    rdfs:label "revisar la programación y desactivar el primer acoplo antes de activar el segundo" ;
    ns1:solucionaFallo ns1:ActivacionDeSegundoAcoploSinDesactivarElPrimero ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Desactivar el primer acoplo antes de activar el segundo." .

ns1:ActivacionDeSegundoAcoploSinDesactivarElPrimero a ns1:DiagnosticoFallo ;
    rdfs:label "activación de segundo acoplo sin desactivar el primero" ;
    ns1:textoExtracto "El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

