@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1258
    a ex:Alarma ;
    rdfs:label "Paso de husillo igual cero" ;
    ex:identificador "1258" ;
    ex:textoExtracto "1258 'Paso de husillo igual cero' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca tiene valor 0. SOLUCIÓN Revisar la programación. Programar el paso de la rosca con los parámetros I J K." .

ex:Alarma_1259
    a ex:Alarma ;
    rdfs:label "Paso de husillo fuera de rango" ;
    ex:identificador "1259" ;
    ex:textoExtracto "1259 'Paso de husillo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca programado es demasiado alto. SOLUCIÓN Revisar la programación." .

ex:Alarma_1261
    a ex:Alarma ;
    rdfs:label "Tipo de cinemática desconocida" ;
    ex:identificador "1261" ;
    ex:textoExtracto "1261 'Tipo de cinemática desconocida' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una cinemática no definida en parámetros máquina. El CNC ha intentado activar la función RTCP, TLC o una transformación de coordenadas (CS/ACS) en modo 6 sin tener una cinemática activa. SOLUCIÓN Revisar la sintaxis. Activar primero la cinemática y a continuación la función deseada." .

ex:Alarma_1262
    a ex:Alarma ;
    rdfs:label "El grupo de ejes es insuficiente para la transformación" ;
    ex:identificador "1262" ;
    ex:textoExtracto "1262 'El grupo de ejes es insuficiente para la transformación' DETECCIÓN Durante la ejecución. CAUSA El canal no tiene ejes suficientes para activar la función RTCP, TLC o la transformación de coordenadas. El número de ejes necesario dependerá de la cinemática a activar. SOLUCIÓN Corregir la configuración de ejes del canal (sentencia #SET AX) para poder activar la cinemática." .

ex:Alarma_1263
    a ex:Alarma ;
    rdfs:label "Falta eje(s) rotativo para la transformación" ;
    ex:identificador "1263" ;
    ex:textoExtracto "1263 'Falta eje(s) rotativo para la transformación' DETECCIÓN Durante la ejecución. CAUSA Hay programada una sentencia #TOOL ORI, pero no hay ningún eje rotativo para poder colocar la herramienta perpendicular al plano inclinado definido. SOLUCIÓN No programar la sentencia #TOOL ORI o activar una cinemática que permita colocar la herramienta perpendicular al plano inclinado." .

ex:Alarma_1264
    a ex:Alarma ;
    rdfs:label "Programación no permitida con CS/ACS activo" ;
    ex:identificador "1264" ;
    ex:textoExtracto "1264 'Programación no permitida con CS/ACS activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas." .

ex:Parametro_G33_PasoRosca
    a ex:Parametro ;
    rdfs:label "Paso de rosca en función G33" ;
    ex:textoExtracto "el paso de la rosca tiene valor 0" ;
    ex:valor "0" .

ex:Parametro_G33_PasoRosca_Alto
    a ex:Parametro ;
    rdfs:label "Paso de rosca excesivo en función G33" ;
    ex:textoExtracto "el paso de la rosca programado es demasiado alto" .

ex:Funcion_G33 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función G33 (roscado)" ;
    ex:textoExtracto "En la función G33, el paso de la rosca tiene valor 0" ;
    ex:monitoreaParametro ex:Parametro_G33_PasoRosca .

ex:Funcion_RTCP a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función RTCP" ;
    ex:textoExtracto "activar la función RTCP, TLC o una transformación de coordenadas (CS/ACS)" .

ex:Funcion_TLC a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función TLC" ;
    ex:textoExtracto "activar la función RTCP, TLC o una transformación de coordenadas (CS/ACS)" .

ex:Funcion_CSACS a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Transformación de coordenadas (CS/ACS)" ;
    ex:textoExtracto "activar la función RTCP, TLC o una transformación de coordenadas (CS/ACS)" .

ex:Sentencia_TOOL_ORI
    a ex:Parametro ;
    rdfs:label "Sentencia #TOOL ORI" ;
    ex:textoExtracto "Hay programada una sentencia #TOOL ORI" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha intentado activar una cinemática no definida en parámetros máquina" ;
    ex:activaAlarma ex:Alarma_1258, ex:Alarma_1259, ex:Alarma_1261, ex:Alarma_1262, ex:Alarma_1263, ex:Alarma_1264 .