@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AmbosEjesDeUnAcoploDebenSerDelMismoTipo a ns1:TareaMantenimiento ;
    rdfs:label "Ambos ejes de un acoplo deben ser del mismo tipo" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDelAcoploNoSonDelMismoTipoLinealORotativo ;
    ns1:textoExtracto "SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)." .

ns1:AmbosEjesDeUnAcoploDebenSerDelMismoTipo_33883780d7 a ns1:TareaMantenimiento ;
    rdfs:label "Ambos ejes de un acoplo deben ser del mismo tipo" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDelAcoploSonRotativosPeroNoSonDelMismoTipoLinea_1b7c4d6e7a ;
    ns1:textoExtracto "SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)." .

ns1:ModoDeEje_bf5415576b a ns1:Parametro ;
    rdfs:label "Modo de eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "(parámetro AXISMODE)" .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "(parámetro AXISTYPE)" .

ns1:LosEjesMaestroYEsclavoDelAcoploNoSonDelMismoTipoLinealORotativo a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo" ;
    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo." .

ns1:LosEjesMaestroYEsclavoDelAcoploSonRotativosPeroNoSonDelMismoTipoLinea_1b7c4d6e7a a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo" ;
    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo." .

