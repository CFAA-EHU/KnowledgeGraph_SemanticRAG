@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1265
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Programación no permitida con RTCP/TLC activo"@es ;
    ex:identificador      "1265" ;
    ex:textoExtracto      "Durante la ejecución. El CNC no permite ejecutar la función programada si está activa la función RTCP o TLC. Algunas funciones incompatibles son G74, G198, G199, #KIN ID. LINK."@es .

ex:AvisoSeguridad_1266
    a                     ex:AvisoSeguridad ;
    rdfs:label            "La funcionalidad TLC se desactiva con la sentencia #TLC OFF"@es ;
    ex:identificador      "1266" ;
    ex:textoExtracto      "El CNC ha intentado modificar la función TLC mientras estaba activa. SOLUCIÓN: El CNC no permite modificar la función TLC mientras está activa. Para modificar la función TLC, hay que desactivarla y volverla a activar."@es .

ex:AvisoSeguridad_1267
    a                     ex:AvisoSeguridad ;
    rdfs:label            "La funcionalidad RTCP se desactiva con la sentencia #RTCP OFF"@es ;
    ex:identificador      "1267" ;
    ex:textoExtracto      "Con el RTCP activo, hay programada una sentencia #RTCP diferente a #RTCPOFF. SOLUCIÓN: Para desactivar la función RTCP programar #RTCPOFF. Si se desea modificar los valores del RTCP, hay que desactivarla primero."@es .

ex:AvisoSeguridad_1268
    a                     ex:AvisoSeguridad ;
    rdfs:label            "#CS ON/#ACS ON: error de sintaxis"@es ;
    ex:identificador      "1268" ;
    ex:textoExtracto      "La sintaxis de la sentencia no es correcta. SOLUCIÓN: Revisar la programación."@es .

ex:AvisoSeguridad_1269
    a                     ex:AvisoSeguridad ;
    rdfs:label            "#CS ON/#ACS ON: el ángulo programado no es válido"@es ;
    ex:identificador      "1269" ;
    ex:textoExtracto      "El ángulo programado no es válido. SOLUCIÓN: Programar un ángulo entre ±360º."@es .

ex:AvisoSeguridad_1270
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Cálculo de la transformación de coordenadas imposible"@es ;
    ex:identificador      "1270" ;
    ex:textoExtracto      "El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés. SOLUCIÓN: Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación."@es .

ex:ModoOperacion_RTCP
    a                     ex:ModoOperacion ;
    rdfs:label            "RTCP (Rotary Tool Center Point)"@es ;
    ex:textoExtracto      "función RTCP activa"@es ;
    ex:activaAlarma        ex:AvisoSeguridad_1265, ex:AvisoSeguridad_1267, ex:AvisoSeguridad_1270 .

ex:ModoOperacion_TLC
    a                     ex:ModoOperacion ;
    rdfs:label            "TLC (Tool Length Compensation)"@es ;
    ex:textoExtracto      "función TLC activa"@es ;
    ex:activaAlarma        ex:AvisoSeguridad_1265, ex:AvisoSeguridad_1266 .

ex:Parametro_AnguloCS
    a                     ex:Parametro ;
    rdfs:label            "Ángulo de #CS/#ACS"@es ;
    ex:textoExtracto      "Programar un ángulo entre ±360º"@es ;
    ex:mitigaRiesgo        ex:AvisoSeguridad_1269 .

ex:Sistema_CNC
    a                     ex:Sistema ;
    rdfs:label            "Sistema CNC"@es ;
    ex:textoExtracto      "El CNC no permite ejecutar la función programada si está activa la función RTCP o TLC"@es ;
    ex:controla           ex:ModoOperacion_RTCP, ex:ModoOperacion_TLC ;
    ex:activaAlarma        ex:AvisoSeguridad_1265, ex:AvisoSeguridad_1266, ex:AvisoSeguridad_1267, ex:AvisoSeguridad_1268, ex:AvisoSeguridad_1269, ex:AvisoSeguridad_1270 .