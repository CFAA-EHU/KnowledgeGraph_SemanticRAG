    ns1:solucionaFallo ns1:UnEjeEsEsclavoDeVariosMaestros ;
    ns1:textoExtracto "SOLUCIÓN Un eje sólo puede ser esclavo de un maestro." .

ns1:ElEjeEsclavoDeUnAcoploEstaActivoEnModoManualAditivoG201 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje esclavo de un acoplo está activo en modo manual aditivo (G201)" ;
    ns1:textoExtracto "CAUSA El eje esclavo de un acoplo está activo en modo manual aditivo (G201)." .

ns1:ElNumeroDeAcoplosQueDefinidosSuperaElMaximoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "El número de acoplos que definidos supera el máximo permitido" ;
    ns1:textoExtracto "CAUSA El número de acoplos que definidos supera el máximo permitido." .

ns1:LaSentenciaNoEstaProgramadaSolaEnElBloque_dc683663fb a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia no está programada sola en el bloque" ;
    ns1:textoExtracto "CAUSA La sentencia no está programada sola en el bloque." .

ns1:LosEjesMaestroYEsclavoDelAcoploSonElMismoEje a ns1:DiagnosticoFallo ;
