ns1:AmbosEjesDeUnAcoploDebenSerDelMismoTipoParametroAXISMODE a ns1:TareaMantenimiento ;
    rdfs:label "Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDelAcoploSonRotativosPeroNoSonDelMismoTipoLinea_1b7c4d6e7a ;
    ns1:textoExtracto "SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)." .

ns1:AnularElModoManualAditivoParaPoderAcoplarElEje a ns1:TareaMantenimiento ;
    rdfs:label "Anular el modo manual aditivo para poder acoplar el eje" ;
    ns1:solucionaFallo ns1:ElEjeEsclavoDeUnAcoploEstaActivoEnModoManualAditivoG201 ;
    ns1:textoExtracto "SOLUCIÓN Anular el modo manual aditivo para poder acoplar el eje." .

ns1:ElMaximoNumeroDeAcoplosQuePuedenEstarActivosEnUnCanalEsIgualAlNumeroD_5aca969e71 a ns1:TareaMantenimiento ;
    rdfs:label "El máximo número de acoplos que pueden estar activos en un canal es igual al número de ejes del canal menos tres" ;
    ns1:solucionaFallo ns1:ElNumeroDeAcoplosQueDefinidosSuperaElMaximoPermitido ;
    ns1:textoExtracto "SOLUCIÓN El máximo número de acoplos que pueden estar activos en un canal es igual al número de ejes del canal menos tres." .

ns1:ElMismoEjeSeHaProgramadoMasDeUnaVezEnLaSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "El mismo eje se ha programado más de una vez en la sentencia" ;
    ns1:textoExtracto "CAUSA El mismo eje se ha programado más de una vez en la sentencia." .

ns1:LosEjesMaestroYEsclavoHanDeSerDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Los ejes maestro y esclavo han de ser diferentes" ;
    ns1:solucionaFallo ns1:LosEjesMaestroYEsclavoDelAcoploSonElMismoEje ;
    ns1:textoExtracto "SOLUCIÓN Los ejes maestro y esclavo han de ser diferentes." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaSentenciaNoEstaProgramadaSolaEnElBloque_dc683663fb ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:UnEjeNoPuedeSerMaestroEnUnAcoploYEsclavoEnOtro_764b5aa03e a ns1:TareaMantenimiento ;
    rdfs:label "Un eje no puede ser maestro en un acoplo y esclavo en otro" ;
    ns1:solucionaFallo ns1:UnEjeNoPuedeSerEsclavoEnUnAcoploYMaestroEnOtro ;
    ns1:textoExtracto "SOLUCIÓN Un eje no puede ser maestro en un acoplo y esclavo en otro." .

ns1:UnEjeSoloPuedeSerEsclavoDeUnMaestro a ns1:TareaMantenimiento ;
