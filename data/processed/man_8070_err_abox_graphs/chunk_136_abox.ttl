    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son el mismo eje." .

ns1:LosEjesMaestroYEsclavoDelAcoploSonRotativosPeroNoSonDelMismoTipoLinea_1b7c4d6e7a a ns1:DiagnosticoFallo ;
