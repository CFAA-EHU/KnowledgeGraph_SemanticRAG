@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirNumeroDeParametrosEnMPG a ns1:TareaMantenimiento ;
    rdfs:label "Corregir número de parámetros en #MPG" ;
    ns1:solucionaFallo ns1:MPGDemasiadosParametros ;
    ns1:textoExtracto "La sentencia #MPG admite un máximo de tres" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:AXISNombreDeEjeRepetido,
        ns1:NoSeEspera,
        ns1:UnEjeNoPuedeSerMaestroEnUnAcoploYEsclavoEnOtro ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:AXISNombreDeEjeRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "#AXIS: nombre de eje repetido" ;
    ns1:textoExtracto "1187 '#AXIS: nombre de eje repetido'" .

ns1:MPGDemasiadosParametros a ns1:DiagnosticoFallo ;
    rdfs:label "#MPG: demasiados parámetros" ;
    ns1:textoExtracto "1189 '#MPG: demasiados parámetros'" .

ns1:NoSeEspera a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera '['" ;
    ns1:textoExtracto "1188 'No se espera '[''" .

ns1:UnEjeNoPuedeSerMaestroEnUnAcoploYEsclavoEnOtro a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje no puede ser maestro en un acoplo y esclavo en otro" ;
    ns1:textoExtracto "SOLUCIÓN Un eje no puede ser maestro en un acoplo y esclavo en otro." .

