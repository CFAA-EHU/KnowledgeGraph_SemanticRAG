@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1279
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1279: Falta de comillas en programación" ;
    ex:identificador "1279" ;
    ex:textoExtracto "'Se espera \"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada faltan las comillas. SOLUCIÓN Revisar la programación." .

ex:Error_1281
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1281: Inconsistencia entre parámetros y especificadores de formato" ;
    ex:identificador "1281" ;
    ex:textoExtracto "'No coincide el número de parámetros y de especificadores de formato' DETECCIÓN Durante la ejecución. CAUSA El número de identificadores de datos (%D ó %d) indicados en la sentencia #MSG, #ERROR ó #WARNING no coincide con el número de parámetros a visualizar. SOLUCIÓN Revisar la programación." .

ex:Error_1282
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1282: Mensaje demasiado largo" ;
    ex:identificador "1282" ;
    ex:textoExtracto "'Mensaje demasiado largo' DETECCIÓN" .