@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CONTJOGDemasiadosParametros a ns1:AvisoSeguridad ;
    rdfs:label "#CONTJOG: demasiados parámetros" ;
    ns1:mitigaRiesgo ns1:AvanceYDesplazamientoDelEjeParaCadaPosicionDelConmutadorEnJogIncremental ;
    ns1:textoExtracto "La sentencia tiene más parámetros de los permitidos." .

ns1:CONTJOGNoSePermitenVelocidadesDeJogContinuoNegativas a ns1:AvisoSeguridad ;
    rdfs:label "#CONTJOG: no se permiten velocidades de jog continuo negativas" ;
    ns1:mitigaRiesgo ns1:AvanceDelEjeCuandoElConmutadorEstaEnJogContinuo ;
    ns1:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo." .

ns1:AvanceDelEjeCuandoElConmutadorEstaEnJogContinuo a ns1:Parametro ;
    rdfs:label "avance del eje cuando el conmutador está en jog continuo" ;
    ns1:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo." .

ns1:AvanceYDesplazamientoDelEjeParaCadaPosicionDelConmutadorEnJogIncremental a ns1:Parametro ;
    rdfs:label "avance y desplazamiento del eje para cada posición del conmutador en jog incremental" ;
    ns1:textoExtracto "La sentencia #INCJOG admite un máximo de cinco grupos de parámetros. Cada uno de ellos representa el avance y el desplazamiento del eje para cada posición del conmutador en jog incremental." .

