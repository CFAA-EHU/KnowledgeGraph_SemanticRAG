@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1281
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1281: Número de parámetros no coincide"@es ;
    ex:identificador "1281" ;
    ex:textoExtracto "El número de datos (%D ó %d) indicados en la sentencia #MSG, #ERROR ó #WARNING no coincide con el número de parámetros a visualizar. SOLUCIÓN Revisar la programación."@es .

ex:Error_1282
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1282: Mensaje demasiado largo"@es ;
    ex:identificador "1282" ;
    ex:textoExtracto "En la sentencia #MSG, #ERROR o #WARNING, el texto del mensaje es demasiado largo. SOLUCIÓN El máximo número de caracteres permitidos es 69, incluidos los caracteres que sustituyen a los identificadores de datos."@es .

ex:Error_1283
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1283: Límite de especificadores de formato sobrepasado"@es ;
    ex:identificador "1283" ;
    ex:textoExtracto "En la sentencia #MSG, #ERROR o #WARNING, hay más de 5 identificadores de datos (%D ó %d). SOLUCIÓN Reducir el número de identificadores de datos."@es .

ex:Error_1284
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1284: Se espera expresión aritmética"@es ;
    ex:identificador "1284" ;
    ex:textoExtracto "En la sentencia #MSG, #ERROR o #WARNING hay identificadores de datos programados (%D ó %d) pero faltan los parámetros a visualizar. SOLUCIÓN Revisar la programación."@es .

ex:Error_1285
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1285: Doble escritura del radio de herramienta"@es ;
    ex:identificador "1285" ;
    ex:textoExtracto "El radio de la herramienta está programada más de una vez en el bloque. SOLUCIÓN Programar el radio de la herramienta una sola vez en el bloque."@es .

ex:Error_1286
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1286: Doble escritura de la longitud de herramienta"@es ;
    ex:identificador "1286" ;
    ex:textoExtracto "La longitud de la herramienta está programada más de una vez en el bloque. SOLUCIÓN Programar la longitud de la herramienta una sola vez en el bloque."@es .

ex:Error_1287
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1287: Se espera '['"@es ;
    ex:identificador "1287" ;
    ex:textoExtracto "En la expresión o sentencia programada falta el corchete de apertura '['. SOLUCIÓN Revisar la programación."@es .

ex:Error_1288
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1288: Demasiados parámetros programados en la sentencia"@es ;
    ex:identificador "1288" ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación."@es .

ex:Error_1289
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1289: Mensaje del comando #MSG demasiado largo"@es ;
    ex:identificador "1289" ;
    ex:textoExtracto "El mensaje del comando #MSG es demasiado largo."@es .

ex:Sentencia_MSG
    a ex:Parametro ;
    rdfs:label "Sentencia #MSG"@es ;
    ex:textoExtracto "Sentencia #MSG para visualización de mensajes en interfaz de usuario."@es .

ex:Sentencia_ERROR
    a ex:Parametro ;
    rdfs:label "Sentencia #ERROR"@es ;
    ex:textoExtracto "Sentencia #ERROR para visualización de errores en interfaz de usuario."@es .

ex:Sentencia_WARNING
    a ex:Parametro ;
    rdfs:label "Sentencia #WARNING"@es ;
    ex:textoExtracto "Sentencia #WARNING para visualización de advertencias en interfaz de usuario."@es .

ex:InterfazUsuario_Visualizacion
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de visualización de mensajes"@es ;
    ex:textoExtracto "Interfaz que muestra mensajes, errores y advertencias generados por sentencias #MSG, #ERROR y #WARNING."@es .

ex:Error_1281 ex:solucionaFallo ex:InterfazUsuario_Visualizacion .
ex:Error_1282 ex:solucionaFallo ex:InterfazUsuario_Visualizacion .
ex:Error_1283 ex:solucionaFallo ex:InterfazUsuario_Visualizacion .
ex:Error_1284 ex:solucionaFallo ex:InterfazUsuario_Visualizacion .
ex:Error_1289 ex:solucionaFallo ex:InterfazUsuario_Visualizacion .

ex:Sentencia_MSG ex:monitoreaParametro ex:InterfazUsuario_Visualizacion .
ex:Sentencia_ERROR ex:monitoreaParametro ex:InterfazUsuario_Visualizacion .
ex:Sentencia_WARNING ex:monitoreaParametro ex:InterfazUsuario_Visualizacion .