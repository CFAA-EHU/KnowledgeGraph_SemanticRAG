@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDelEjeEnJogContinuo a ns1:Parametro ;
    rdfs:label "avance del eje en jog continuo" ;
    ns1:textoExtracto "'#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'" .

ns1:DefinirAvanceNegativoONuloEnCONTJOG a ns1:AccionProhibida ;
    rdfs:label "Definir avance negativo o nulo en #CONTJOG" ;
    ns1:textoExtracto "La sentencia #CONTJOG intenta definir un avance negativo o nulo." .

ns1:ElLimiteDeRecorridoInferiorDelEjeParaElDesplazamientoManualTieneUnValorPositivo a ns1:DiagnosticoFallo ;
    rdfs:label "El límite de recorrido inferior del eje para el desplazamiento manual tiene un valor positivo" ;
    ns1:textoExtracto "'#SET OFFSET: offset inferior positivo'" .

ns1:ElLimiteDeRecorridoSuperiorDelEjeParaElDesplazamientoManualTieneUnValorNegativo a ns1:DiagnosticoFallo ;
    rdfs:label "El límite de recorrido superior del eje para el desplazamiento manual tiene un valor negativo" ;
    ns1:textoExtracto "'#SET OFFSET: offset superior negativo'" .

ns1:LaSentenciaTieneDemasiadosParametros a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia tiene demasiados parámetros" ;
    ns1:textoExtracto "La sentencia tiene demasiados parámetros." .

ns1:LosLimitesDeRecorridoDelEjeParaElDesplazamientoManualSonNulos a ns1:DiagnosticoFallo ;
    rdfs:label "Los límites de recorrido del eje para el desplazamiento manual son nulos" ;
    ns1:textoExtracto "'#SET OFFSET: offset superior e inferior nulos'" .

ns1:NoSePermitenVelocidadesDeJogContinuoNegativasOCero a ns1:DiagnosticoFallo ;
    rdfs:label "No se permiten velocidades de jog continuo negativas o cero" ;
    ns1:textoExtracto "'#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'" .

ns1:ProgramarSETIPOPOSEnMultiplesBloques a ns1:AccionProhibida ;
    rdfs:label "Programar #SET IPOPOS en múltiples bloques" ;
    ns1:textoExtracto "La sentencia #SET IPOPOS se programa sola en el bloque" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:DefinirDemasiadosParametrosEnSETIPOPOS,
        ns1:DefinirLimitesDeRecorridoNulosEnSETOFFSET,
        ns1:DefinirOffsetInferiorPositivoEnSETOFFSET,
        ns1:DefinirOffsetSuperiorNegativoEnSETOFFSET ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DefinirDemasiadosParametrosEnSETIPOPOS a ns1:AccionProhibida ;
    rdfs:label "Definir demasiados parámetros en #SET IPOPOS" ;
    ns1:textoExtracto "#SET IPOPOS: demasiados parámetros." .

ns1:DefinirLimitesDeRecorridoNulosEnSETOFFSET a ns1:AccionProhibida ;
    rdfs:label "Definir límites de recorrido nulos en #SET OFFSET" ;
    ns1:textoExtracto "'#SET OFFSET: offset superior e inferior nulos'" .

ns1:DefinirOffsetInferiorPositivoEnSETOFFSET a ns1:AccionProhibida ;
    rdfs:label "Definir offset inferior positivo en #SET OFFSET" ;
    ns1:textoExtracto "'#SET OFFSET: offset inferior positivo'" .

ns1:DefinirOffsetSuperiorNegativoEnSETOFFSET a ns1:AccionProhibida ;
    rdfs:label "Definir offset superior negativo en #SET OFFSET" ;
    ns1:textoExtracto "'#SET OFFSET: offset superior negativo'" .

