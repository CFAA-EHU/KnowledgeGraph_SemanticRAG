@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1288
    a ex:Alarma ;
    rdfs:label "Alarma 1288: Demasiados parámetros programados en la sentencia" ;
    ex:identificador "1288" ;
    ex:textoExtracto "1288 'Demasiados parámetros programados en la sentencia' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ex:Alarma_1289
    a ex:Alarma ;
    rdfs:label "Alarma 1289: Mensaje del comando #MSG demasiado largo" ;
    ex:identificador "1289" ;
    ex:textoExtracto "1289 El mensaje del comando #MSG es demasiado largo. DETECCIÓN Durante la ejecución. CAUSA El mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo. SOLUCIÓN La longitud máxima del texto en estas sentencias es de 70 caracteres." .

ex:Parametro_1288_SintaxisSentencia
    a ex:Parametro ;
    rdfs:label "Parámetro: Sintaxis de sentencia" ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta." ;
    ex:monitoreaParametro ex:Alarma_1288 .

ex:Parametro_1289_LongitudMensaje
    a ex:Parametro ;
    rdfs:label "Parámetro: Longitud máxima del mensaje (#MSG/#WARNING/#ERROR)" ;
    ex:valor "70" ;
    ex:textoExtracto "La longitud máxima del texto en estas sentencias es de 70 caracteres." ;
    ex:monitoreaParametro ex:Alarma_1289 .