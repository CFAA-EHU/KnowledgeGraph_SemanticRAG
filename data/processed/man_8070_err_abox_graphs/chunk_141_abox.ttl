@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "revisión de programación" ;
    ns1:solucionaFallo ns1:DemasiadosParametrosEnLaSentenciaSETIPOPOS,
        ns1:SentenciaMalProgramadaOInexistente,
        ns1:SentenciaSETIPOPOSNoProgramadaSolaEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DemasiadosParametrosEnLaSentenciaSETIPOPOS a ns1:DiagnosticoFallo ;
    rdfs:label "demasiados parámetros en la sentencia #SET IPOPOS" ;
    ns1:textoExtracto "1202 #SET IPOPOS: demasiados parámetros. DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene demasiados parámetros." .

ns1:SentenciaMalProgramadaOInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "sentencia mal programada o inexistente" ;
    ns1:textoExtracto "'Sentencia mal programada o inexistente' DETECCIÓN Durante la ejecución. CAUSA La sentencia no existe o está mal programada." .

ns1:SentenciaSETIPOPOSNoProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "sentencia #SET IPOPOS no programada sola en el bloque" ;
    ns1:textoExtracto "'La sentencia #SET IPOPOS se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque." .

