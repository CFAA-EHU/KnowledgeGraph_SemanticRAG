@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1290
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1290: Programación de coordenadas I, J, K incorrecta" ;
    ex:textoExtracto "'Programación de coordenadas I, J, K incorrecta' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los valores programados para el centro de una interpolación circular, origen polar o centro de giro del sistema de coordenadas son demasiado altos. • Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1290" .

ex:Error_1291
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1291: No se admiten más funciones S" ;
    ex:textoExtracto "'No se admiten más funciones S' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones S de las permitidas. SOLUCIÓN El máximo número de funciones S admitido en un mismo bloque es 4." ;
    ex:identificador "1291" .

ex:Error_1292
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1292: Función M doblemente programada" ;
    ex:textoExtracto "'Función M doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función M está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." ;
    ex:identificador "1292" .

ex:Error_1293
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1293: Función H doblemente programada" ;
    ex:textoExtracto "'Función H doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función H está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." ;
    ex:identificador "1293" .

ex:Error_1301
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1301: Transformación de longitud de herramienta excede formato numérico" ;
    ex:textoExtracto "'La transformación de longitud de herramienta excede el formato numérico válido' DETECCIÓN Durante la ejecución. CAUSA La transformación de longitud de herramienta excede el formato numérico válido. SOLUCIÓN Modificar los valores de la transformación de longitud o los de la herramienta." ;
    ex:identificador "1301" .

ex:Error_1302
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1302: Carácter no válido en el nombre" ;
    ex:textoExtracto "'Carácter no válido en el nombre' DETECCIÓN Durante la ejecución. CAUSA Carácter no válido en el nombre de una etiqueta, subrutina o variable. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1302" .

ex:Error_1303
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1303: Nombre de variable demasiado largo" ;
    ex:textoExtracto "'Nombre de variable demasiado largo' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable. SOLUCIÓN El máximo número de caracteres permitido es 13." ;
    ex:identificador "1303" .

ex:MensajeProgramado_LongitudExcedida
    a ex:AvisoSeguridad ;
    rdfs:label "Mensaje programado con longitud excedida" ;
    ex:textoExtracto "Durante la ejecución. CAUSA El mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo. SOLUCIÓN La longitud máxima del texto en estas sentencias es de 70 caracteres." ;
    ex:valor "70" .