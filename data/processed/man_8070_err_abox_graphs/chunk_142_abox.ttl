    ns1:textoExtracto "'#CALL AX/#SET AX: nombre de eje repetido'" .

ns1:CALLAXSETAXNumeroDeEjeRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: número de eje repetido" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: número de eje repetido'" .

ns1:CALLAXSETAXTipoDeOffsetDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: tipo de offset desconocido" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: tipo de offset desconocido'" .

ns1:IndiceDeEjeFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "'Indice de eje fuera de rango'" ;
    ns1:textoExtracto "'Indice de eje fuera de rango'" .

ns1:SeEspera_eaa4325bb9 a ns1:DiagnosticoFallo ;
    rdfs:label "'Se espera ',''" ;
    ns1:textoExtracto "'Se espera ',''" .

ns1:SentenciaMalProgramadaOInexistente_beab25f377 a ns1:DiagnosticoFallo ;
