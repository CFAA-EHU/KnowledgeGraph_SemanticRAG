@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:CALLAXSETAXIndiceDeEjeRepetido,
        ns1:CALLAXSETAXNombreDeEjeRepetido,
        ns1:CALLAXSETAXNumeroDeEjeRepetido,
        ns1:CALLAXSETAXTipoDeOffsetDesconocido,
        ns1:IndiceDeEjeFueraDeRango,
        ns1:SeEspera_eaa4325bb9,
        ns1:SentenciaMalProgramadaOInexistente_beab25f377 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:CALLAXSETAXIndiceDeEjeRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: índice de eje repetido" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: índice de eje repetido'" .

ns1:CALLAXSETAXNombreDeEjeRepetido a ns1:DiagnosticoFallo ;
