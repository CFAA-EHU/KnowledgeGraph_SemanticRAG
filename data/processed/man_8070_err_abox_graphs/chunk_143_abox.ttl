@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1304
    a               ex:Alarma ;
    rdfs:label      "Alarma 1304: Velocidad de cabezal no válida"@es ;
    ex:identificador "1304" ;
    ex:textoExtracto "1304 'Velocidad de cabezal no válida' [...] CAUSA La velocidad programada es demasiado pequeña. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1305
    a               ex:Alarma ;
    rdfs:label      "Alarma 1305: Programación no permitida con #MCS activo"@es ;
    ex:identificador "1305" ;
    ex:textoExtracto "1305 'Programación no permitida con #MCS activo' [...] CAUSA El CNC no permite ejecutar la función programada si está activa la función MCS. Algunas funciones incompatibles son las siguientes: [...] SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1306
    a               ex:Alarma ;
    rdfs:label      "Alarma 1306: Cambio de cinemática con compensación de radio activa"@es ;
    ex:identificador "1306" ;
    ex:textoExtracto "1306 'No se admite cambio de cinemática con compensación de radio activa' [...] CAUSA El CNC ha intentado cambiar la cinemática con la compensación de radio activa. SOLUCIÓN Anular la compensación para definir el nuevo plano de trabajo."@es .

ex:Alarma_1308
    a               ex:Alarma ;
    rdfs:label      "Alarma 1308: Eje esclavo en transformación cinemática activa"@es ;
    ex:identificador "1308" ;
    ex:textoExtracto "1308 'Un eje de la transformación cinemática activa no puede ser esclavo' [...] CAUSA El eje esclavo de un acoplo forma parte de la cinemática activa. SOLUCIÓN Desactivar la cinemática para poder acoplar el eje."@es .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "El CNC no permite ejecutar la función programada si está activa la función MCS."@es ;
    ex:activaAlarma  ex:Alarma_1304 , ex:Alarma_1305 , ex:Alarma_1306 , ex:Alarma_1308 .