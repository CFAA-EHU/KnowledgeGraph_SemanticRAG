@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarRoscadoG63AntesDeModificarConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar roscado G63 antes de modificar configuración" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes." .

ns1:ModificarConfiguracionDeEjesConG63Activa a ns1:AccionProhibida ;
    rdfs:label "Modificar configuración de ejes con G63 activa" ;
    ns1:textoExtracto "No se permite programar #CALL AX con la función G63 activa." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_bf26fc7a8b,
        ns1:EjeRepetido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_bf26fc7a8b a ns1:DiagnosticoFallo ;
    rdfs:label "Función G63 activa" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: no se admite con G63 activa'" .

ns1:EjeRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "Eje repetido" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: número de eje repetido'" .

