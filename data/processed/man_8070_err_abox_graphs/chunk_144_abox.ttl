@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarElRoscadoG63AntesDeModificarLaConfiguracionDeEjes a ns1:TareaMantenimiento ;
    rdfs:label "desactivar el roscado G63 antes de modificar la configuración de ejes" ;
    ns1:solucionaFallo ns1:ProgramarCALLAXConFuncionG63Activa ;
    ns1:textoExtracto "Desactivar el roscado G63 antes de modificar la configuración de ejes." .

ns1:RevisarConfiguracionDeEjes a ns1:TareaMantenimiento ;
    rdfs:label "revisar configuración de ejes" ;
    ns1:solucionaFallo ns1:DemasiadosEjesRequeridos ;
    ns1:textoExtracto "Repasar la configuración de ejaes definida para el canal." .

ns1:RevisarLaProgramacion_cfd5090cf7 a ns1:TareaMantenimiento ;
    rdfs:label "revisar la programación" ;
    ns1:solucionaFallo ns1:NombreDeEjeEnUso,
        ns1:SentenciaCALLAXSETAXNoProgramadaSolaEnElBloque ;
    ns1:textoExtracto "Revisar la programación." .

ns1:DemasiadosEjesRequeridos a ns1:DiagnosticoFallo ;
    rdfs:label "demasiados ejes requeridos" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: demasiados ejes requeridos'" .

ns1:NombreDeEjeEnUso a ns1:DiagnosticoFallo ;
    rdfs:label "nombre de eje en uso" ;
    ns1:textoExtracto "'#CALL AX/#CAX: nombre de eje en uso'" .

ns1:ProgramarCALLAXConFuncionG63Activa a ns1:AccionProhibida ;
    rdfs:label "programar #CALL AX con función G63 activa" ;
    ns1:textoExtracto "No se permite programar #CALL AX con la función G63 activa." .

ns1:SentenciaCALLAXSETAXNoProgramadaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "sentencia #CALL AX/#SET AX no programada sola en el bloque" ;
    ns1:textoExtracto "'La sentencia #CALL AX/#SET AX se programa sola en el bloque'" .

