@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularModoManualAditivoDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Anular modo manual aditivo del eje" ;
    ns1:solucionaFallo ns1:FalloEliminacionEje ;
    ns1:textoExtracto "Anular el modo manual aditivo del eje mediante la función G202 para realizar eliminar el eje del canal." .

ns1:EliminarEjeActivoEnModoManual a ns1:AccionProhibida ;
    rdfs:label "Eliminar eje activo en modo manual" ;
    ns1:textoExtracto "'#FREE AX: no se permite eliminar un eje activo en modo manual'" .

ns1:RevisarLaProgramacionDeLaSentenciaSETAX a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de la sentencia #SET AX" ;
    ns1:solucionaFallo ns1:FalloProgramacionSetAX ;
    ns1:textoExtracto "Revisar la" .

ns1:SentenciaSETAXNoProgramadaSolaEnBloque a ns1:AccionProhibida ;
    rdfs:label "Sentencia #SET AX no programada sola en bloque" ;
    ns1:textoExtracto "'La sentencia #SET AX se programa sola en el bloque'" .

ns1:FalloEliminacionEje a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede eliminar el eje del canal" ;
    ns1:textoExtracto "Un eje en modo manual aditivo (G201) no se puede eliminar del canal." .

ns1:FalloProgramacionSetAX a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #SET AX mal programada" ;
    ns1:textoExtracto "La sentencia no está programada sola en el bloque." .

