@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnidamientoDeSentenciasCondicionalesSobrepasado a ns1:AccionProhibida ;
    rdfs:label "Anidamiento de sentencias condicionales sobrepasado" ;
    ns1:textoExtracto "'Anidamiento de sentencias condicionales sobrepasado'" .

ns1:CaracterDeFinDeFicheroDentroDeBloqueComentario a ns1:AccionProhibida ;
    rdfs:label "Carácter de fin de fichero dentro de bloque comentario" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'Carácter de fin de fichero dentro de bloque comentario'" .

ns1:DivisionPorCero a ns1:AccionProhibida ;
    rdfs:label "División por cero" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'División por cero'" .

ns1:EliminarEjeDelCanal a ns1:AccionProhibida ;
    rdfs:label "Eliminar eje del canal" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'La sentencia #SET AX se programa sola en el bloque'" .

ns1:FaltaOperadorUOperadorDesconocido a ns1:AccionProhibida ;
    rdfs:label "Falta operador u operador desconocido" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'Falta operador u operador desconocido'" .

ns1:NoHayEjeFrontalEnElPlanoParaCompensarElFactorDeFormaDeHerramientaDeTorno a ns1:AccionProhibida ;
    rdfs:label "No hay eje frontal en el plano para compensar el factor de forma de herramienta de torno" ;
    ns1:solucionaFallo ns1:FactorDeFormaEjeFrontal ;
    ns1:textoExtracto "'No hay eje frontal en el plano para compensar el factor de forma de herramienta de torno'" .

ns1:NoHayEjeLateralEnElPlanoParaCompensarElFactorDeFormaDeHerramientaDeTorno a ns1:AccionProhibida ;
    rdfs:label "No hay eje lateral en el plano para compensar el factor de forma de herramienta de torno" ;
    ns1:solucionaFallo ns1:FactorDeFormaEjeLongitudinal ;
    ns1:textoExtracto "'No hay eje lateral en el plano para compensar el factor de forma de herramienta de torno'" .

ns1:NoSeEsperaCOMMENTEND a ns1:AccionProhibida ;
    rdfs:label "No se espera #COMMENT END" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "'No se espera #COMMENT END'" .

ns1:FactorDeFormaEjeFrontal a ns1:Parametro ;
    rdfs:label "Factor de forma eje frontal" ;
    ns1:textoExtracto "'Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)'" .

ns1:FactorDeFormaEjeLongitudinal a ns1:Parametro ;
    rdfs:label "Factor de forma eje longitudinal" ;
    ns1:textoExtracto "'Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)'" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

