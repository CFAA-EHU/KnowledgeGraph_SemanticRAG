@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirEjeLongitudinal a ns1:TareaMantenimiento ;
    rdfs:label "Definir eje longitudinal" ;
    ns1:solucionaFallo ns1:EjeLongitudinalNoDefinido ;
    ns1:textoExtracto "Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)." .

ns1:Parametro_6f2c8f9ffb a ns1:Parametro ;
    rdfs:label "Parámetro de definición del eje longitudinal" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "(parámetro LONGAXIS)" .

ns1:EjeLongitudinalNoDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Eje longitudinal no definido" ;
    ns1:textoExtracto "Ningún eje del plano está definido como eje longitudinal." .

