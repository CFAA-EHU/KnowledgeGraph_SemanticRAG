@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BorrarTablaDeMacros a ns1:TareaMantenimiento ;
    rdfs:label "Borrar tabla de macros" ;
    ns1:solucionaFallo ns1:NumeroMaximoDeMacrosSobrepasado ;
    ns1:textoExtracto "SOLUCIÓN El máximo es 50 macros. Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB." .

ns1:DefinirMacroAntesDeUtilizarla a ns1:TareaMantenimiento ;
    rdfs:label "Definir macro antes de utilizarla" ;
    ns1:solucionaFallo ns1:MacroInexistente_e518833e63 ;
    ns1:textoExtracto "SOLUCIÓN Definir la macro antes de utilizarla." .

ns1:NombreDeMacroDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de macro demasiado largo" ;
    ns1:textoExtracto "'Nombre de macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la macro supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 30." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:AnidamientoDeSentenciasCondicionalesSobrepasado_1b5b51be3e,
        ns1:ElTrasladoProgramadoExcedeElRangoDeDatos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:TextoDeSustitucionDeLaMacroDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Texto de sustitución de la macro demasiado largo" ;
    ns1:textoExtracto "'Texto de sustitución de la macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El número de caracteres del texto de sustitución de la macro supera el máximo permitido. SOLUCIÓN El máximo número de caracteres permitidos es 140." .

ns1:AnidamientoDeSentenciasCondicionalesSobrepasado_1b5b51be3e a ns1:DiagnosticoFallo ;
    rdfs:label "Anidamiento de sentencias condicionales sobrepasado" ;
    ns1:textoExtracto "1229 Anidamiento de sentencias condicionales sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR, $WHILE y $DO. SOLUCIÓN Revisar la programación. El máximo número de anidamientos es 20." .

ns1:ElTrasladoProgramadoExcedeElRangoDeDatos a ns1:DiagnosticoFallo ;
    rdfs:label "El traslado programado excede el rango de datos" ;
    ns1:textoExtracto "'El traslado programado excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA El traslado de origen definido supera al máximo permitido. SOLUCIÓN Revisar la programación." .

ns1:MacroInexistente_e518833e63 a ns1:DiagnosticoFallo ;
    rdfs:label "Macro inexistente" ;
    ns1:textoExtracto "'Macro inexistente' DETECCIÓN Durante la ejecución. CAUSA La macro no está definida en el programa. SOLUCIÓN Definir la macro antes de utilizarla." .

ns1:NumeroMaximoDeMacrosSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de macros sobrepasado" ;
    ns1:textoExtracto "'Número máximo de macros sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de macros en el CNC. SOLUCIÓN El máximo es 50 macros. Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB." .

