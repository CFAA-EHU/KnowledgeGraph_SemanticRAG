@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1326
    a ex:AvisoSeguridad ;
    rdfs:label "Valor erróneo para asignar a variable (Error 1326)" ;
    ex:textoExtracto "1326 'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución. CAUSA La variable tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1326" .

ex:Error_1327
    a ex:AvisoSeguridad ;
    rdfs:label "Posición del cabezal doblemente programada (Error 1327)" ;
    ex:textoExtracto "1327 Posición del cabezal doblemente programada. DETECCIÓN Durante la ejecución. CAUSA La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque. SOLUCIÓN Revisar la programación. Programar la velocidad de posicionamiento una única vez en el bloque." ;
    ex:identificador "1327" .

ex:Error_1328
    a ex:AvisoSeguridad ;
    rdfs:label "Sentencia $FOR sin $ENDFOR (Error 1328)" ;
    ex:textoExtracto "1328 'Sentencia $FOR sin $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA Hay programada una instrucción $FOR pero falta su $ENDFOR. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1328" .

ex:Error_1330
    a ex:AvisoSeguridad ;
    rdfs:label "Programación de imagen espejo incorrecta (Error 1330)" ;
    ex:textoExtracto "1330 'Programación de imagen espejo incorrecta' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la función G14 (imagen espejo). SOLUCIÓN Revisar la programación." ;
    ex:identificador "1330" .

ex:Error_1331
    a ex:AvisoSeguridad ;
    rdfs:label "#TANGFEED RMIN: radio negativo no permitido (Error 1331)" ;
    ex:textoExtracto "1331 '#TANGFEED RMIN: radio negativo no permitido' DETECCIÓN Durante la ejecución. CAUSA El radio programado es menor o igual que cero. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1331" .

ex:Error_1332
    a ex:AvisoSeguridad ;
    rdfs:label "#TOOL AX: orientación de herramienta no especificada (Error 1332)" ;
    ex:textoExtracto "1332 '#TOOL AX: se espera orientación +/- tras la designación del eje' DETECCIÓN Durante la ejecución. CAUSA Falta programar la orientación de la herramienta. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1332" .

ex:Error_1333
    a ex:AvisoSeguridad ;
    rdfs:label "Cambio de eje con compensación de radio activa (Error 1333)" ;
    ex:textoExtracto "1333 'Cambio del primer y/o segundo eje del plano con compensación de radio activa' DETECCIÓN Durante la ejecución. CAUSA Con la compensación de radio activa, el CNC ha intentado cambiar la configuración de ejes del canal y el cambio afecta a los dos primeros ejes del plano de trabajo. SOLUCIÓN Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo." ;
    ex:identificador "1333" .

ex:Error_1334
    a ex:AvisoSeguridad ;
    rdfs:label "G200: movimiento no admitido en el mismo bloque (Error 1334)" ;
    ex:textoExtracto "1334 'G200: no admite movimiento en el mismo bloque' DETECCIÓN Durante la ejecución." ;
    ex:identificador "1334" .

ex:BloqueProgramacionRepetido
    a ex:DiagnosticoFallo ;
    rdfs:label "Número de bloque repetido en programa" ;
    ex:textoExtracto "CAUSA El número de bloque 'N' está repetido en el programa. SOLUCIÓN No repetir el número de bloque." ;
    ex:solucionaFallo ex:Error_1326 .

ex:FuncionG14 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G14 (imagen espejo)" ;
    ex:textoExtracto "Programación incorrecta de la función G14 (imagen espejo)." ;
    ex:monitoreaParametro ex:Error_1330 .