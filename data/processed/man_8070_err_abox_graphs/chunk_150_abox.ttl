@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionPreviaDeMacros a ns1:AvisoSeguridad ;
    rdfs:label "Definición previa de macros" ;
    ns1:mitigaRiesgo ns1:UtilizarMacroInexistente ;
    ns1:textoExtracto "La macro puede estar definida en un programa. SOLUCIÓN Definir la macro antes de utilizarla." .

ns1:InicializacionDeTablaDeMacros a ns1:TareaMantenimiento ;
    rdfs:label "Inicialización de tabla de macros" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "El CNC inicializa la tabla de macros en el arranque o mediante la sentencia #INIT MACROTAB." .

ns1:MacroInexistente a ns1:Parametro ;
    rdfs:label "Macro inexistente" ;
    ns1:textoExtracto "'Macro inexistente' DETECCIÓN Durante la ejecución. CAUSA La macro no está definida en el programa." .

ns1:CNC8070_bf107857a2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC almacena en una tabla las macros definidas desde un programa o desde el modo MDI/MDA, de manera que están disponibles para todos los programas ejecutados a continuación." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Personal Técnico Autorizado" .

ns1:UtilizarMacroInexistente a ns1:AccionProhibida ;
    rdfs:label "Utilizar macro inexistente" ;
    ns1:mitigaRiesgo ns1:CNC8070_bf107857a2 ;
    ns1:textoExtracto "La macro no está definida en el programa. SOLUCIÓN Definir la macro antes de utilizarla." .

