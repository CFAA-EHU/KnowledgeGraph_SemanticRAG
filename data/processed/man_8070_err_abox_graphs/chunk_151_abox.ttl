@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeFrontalProximoAlCentroLaVelocidadDelCabezalEnG96HaSidoLimitada a ns1:AccionProhibida ;
    rdfs:label "Eje frontal próximo al centro: la velocidad del cabezal en G96 ha sido limitada" ;
    ns1:mitigaRiesgo ns1:SolucionVelocidadCabezalLimitada ;
    ns1:textoExtracto "'Eje frontal próximo al centro: la velocidad del cabezal en G96 ha sido limitada' DETECCIÓN Durante la ejecución. CAUSA Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal debido a la proximidad del eje frontal al centro de giro." .

ns1:FaltaElTextoDeSustitucionDeLaMacro a ns1:AccionProhibida ;
    rdfs:label "Falta el texto de sustitución de la macro" ;
    ns1:mitigaRiesgo ns1:SolucionMacroTextoSustitucionVacio ;
    ns1:textoExtracto "'Falta el texto de sustitución de la macro' DETECCIÓN Durante la ejecución. CAUSA El texto de sustitución asociado a la macro es una cadena de caracteres vacía." .

ns1:SolucionMacroTextoSustitucionVacio a ns1:DiagnosticoFallo ;
    rdfs:label "Asociar a la macro el texto de sustitución adecuado según la funcionalidad que se le quiera dar" ;
    ns1:textoExtracto "SOLUCIÓN Asociar a la macro el texto de sustitución adecuado según la funcionalidad que se le quiera dar. El texto de sustitución debe ir escrito entre comillas." .

ns1:SolucionVelocidadCabezalLimitada a ns1:DiagnosticoFallo ;
    rdfs:label "Aumentar el límite de velocidad (G192) o aceptar la limitación" ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación." .

