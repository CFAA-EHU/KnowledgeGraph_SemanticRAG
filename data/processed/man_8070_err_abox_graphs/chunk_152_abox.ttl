@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarAvanceEnFuncionDelTiempo a ns1:TareaMantenimiento ;
    rdfs:label "Activar avance en función del tiempo" ;
    ns1:solucionaFallo ns1:NoSeAdmiteRoscadoConAvanceEnG95 ;
    ns1:textoExtracto "SOLUCIÓN Activar el avance en función del tiempo (G94)." .

ns1:AumentarElLimiteDeVelocidad a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el límite de velocidad" ;
    ns1:solucionaFallo ns1:AumentarElLimiteDeVelocidadG192OAceptarLaLimitacion ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación." .

ns1:DefinirEjeFrontal a ns1:TareaMantenimiento ;
    rdfs:label "Definir eje frontal" ;
    ns1:solucionaFallo ns1:G96NoHayEjeFrontalFACEAXISDefinidoEnElPlanoActivo ;
    ns1:textoExtracto "SOLUCIÓN Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)." .

ns1:DefinirUnoDeLosEjesDelPlanoComoEjeFrontal a ns1:Parametro ;
    rdfs:label "Definir uno de los ejes del plano como eje frontal" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "SOLUCIÓN Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)." .

ns1:DesactivarG96 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar G96" ;
    ns1:solucionaFallo ns1:NoSeAdmiteRoscadoConG96Activa ;
    ns1:textoExtracto "'No se admite roscado con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante)." .

ns1:AumentarElLimiteDeVelocidadG192OAceptarLaLimitacion a ns1:DiagnosticoFallo ;
    rdfs:label "Aumentar el límite de velocidad (G192) o aceptar la limitación" ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación." .

ns1:G96NoHayEjeFrontalFACEAXISDefinidoEnElPlanoActivo a ns1:DiagnosticoFallo ;
    rdfs:label "'G96: no hay eje frontal (FACEAXIS) definido en el plano activo'" ;
    ns1:textoExtracto "'G96: no hay eje frontal (FACEAXIS) definido en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje frontal." .

ns1:NoSeAdmiteRoscadoConAvanceEnG95 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite roscado con avance en G95'" ;
    ns1:textoExtracto "'No se admite roscado con avance en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)." .

ns1:NoSeAdmiteRoscadoConG96Activa a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite roscado con G96 activa'" ;
    ns1:textoExtracto "'No se admite roscado con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante)." .

