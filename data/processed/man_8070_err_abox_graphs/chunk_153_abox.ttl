@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarElModoDeVelocidadDeGiroConstanteG97 a ns1:TareaMantenimiento ;
    rdfs:label "Activar el modo de velocidad de giro constante (G97)" ;
    ns1:solucionaFallo ns1:NoSeAdmiteCambioDeGamaConG96Activa ;
    ns1:textoExtracto "SOLUCIÓN Activar el modo de velocidad de giro constante (G97)." .

ns1:NoSeAdmiteRoscadoYG192EnElMismoBloque a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite roscado y G192 en el mismo bloque" ;
    ns1:textoExtracto "'No se admite roscado y G192 en el mismo bloque'" .

ns1:Parametro_7b32d12ce1 a ns1:Parametro ;
    rdfs:label "Función G192 (limitación de la velocidad de giro)" ;
    ns1:textoExtracto "El CNC no permite programar las funciones G63 (roscado rígido) y G192 (limitación de la velocidad de giro)" .

ns1:Parametro_8d2e87f2b4 a ns1:Parametro ;
    rdfs:label "Función G97 (velocidad de giro constante)" ;
    ns1:textoExtracto "SOLUCIÓN Activar el modo de velocidad de giro constante (G97)." .

ns1:Parametro_e370f53fa2 a ns1:Parametro ;
    rdfs:label "Función G63 (roscado rígido)",
        "Función G96 (velocidad de corte constante)" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96" .

ns1:ProgramarAmbasInstruccionesEnBloquesDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Programar ambas instrucciones en bloques diferentes" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloNoAdmiteRoscadoYG192 ;
    ns1:textoExtracto "SOLUCIÓN Programar ambas instrucciones en bloques diferentes." .

ns1:NoSeAdmiteCambioDeGamaConG96Activa a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama con G96 activa" ;
    ns1:textoExtracto "'No se admite cambio de gama con G96 activa'" .

