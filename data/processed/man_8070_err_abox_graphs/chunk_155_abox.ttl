@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_224111ee47 a ns1:Parametro ;
    rdfs:label "Función G33" ;
    ns1:textoExtracto "En la función G33, el paso de la rosca está programado más de una vez." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:DobleProgramacionDelPasoDeHusillo,
        ns1:PasoDeHusilloIgualCero ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DobleProgramacionDelPasoDeHusillo a ns1:DiagnosticoFallo ;
    rdfs:label "Doble programación del paso de husillo" ;
    ns1:textoExtracto "'Doble programación del paso de husillo' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca está programado más de una vez." .

ns1:PasoDeHusilloIgualCero a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de husillo igual cero" ;
    ns1:textoExtracto "'Paso de husillo igual cero' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca tiene valor" .

