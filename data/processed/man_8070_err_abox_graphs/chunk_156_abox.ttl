@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_7888d7a5fb a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para tipo de cinemática desconocida" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_592632d4e2 ;
    ns1:textoExtracto "'Tipo de cinemática desconocida' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una cinemática no definida en parámetros máquina. SOLUCIÓN Revisar la sintaxis. Activar primero la cinemática y a continuación la función deseada." .

ns1:AvisoSeguridad_998cdb6c2e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para el paso de husillo fuera de rango" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_cbc0f81169 ;
    ns1:textoExtracto "'Paso de husillo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca programado es demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_dd261e3cc9 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para el paso de husillo igual a cero" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_7d015db2ca ;
    ns1:textoExtracto "'Paso de husillo igual cero' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca tiene valor 0. SOLUCIÓN Revisar la programación. Programar el paso de la rosca con los parámetros I J K." .

ns1:Parametro_82e7605da8 a ns1:Parametro ;
    rdfs:label "Función G33" ;
    ns1:textoExtracto "En la función G33, el paso de la rosca tiene valor 0. En la función G33, el paso de la rosca programado es demasiado alto." .

ns1:AccionProhibida_592632d4e2 a ns1:AccionProhibida ;
    rdfs:label "Accion prohibida para tipo de cinemática desconocida" ;
    ns1:textoExtracto "El CNC ha intentado activar una cinemática no definida en parámetros máquina." .

ns1:AccionProhibida_7d015db2ca a ns1:AccionProhibida ;
    rdfs:label "Accion prohibida para paso de husillo igual a cero" ;
    ns1:textoExtracto "En la función G33, el paso de la rosca tiene valor 0." .

ns1:AccionProhibida_cbc0f81169 a ns1:AccionProhibida ;
    rdfs:label "Accion prohibida para paso de husillo fuera de rango" ;
    ns1:textoExtracto "En la función G33, el paso de la rosca programado es demasiado alto." .

