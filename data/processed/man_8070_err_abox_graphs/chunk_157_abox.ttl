@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirConfiguracionDeEjesDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Corregir configuración de ejes del canal" ;
    ns1:solucionaFallo ns1:ElGrupoDeEjesEsInsuficienteParaLaTransformacion ;
    ns1:textoExtracto "Corregir la configuración de ejes del canal (sentencia #SET AX) para poder activar la cinemática." .

ns1:NoProgramarSentenciaTOOLORIOActivarUnaCinematicaAdecuada a ns1:TareaMantenimiento ;
    rdfs:label "No programar sentencia #TOOL ORI o activar una cinemática adecuada" ;
    ns1:solucionaFallo ns1:FaltaEjeSRotativoParaLaTransformacion ;
    ns1:textoExtracto "No programar la sentencia #TOOL ORI o activar una cinemática que permita colocar la herramienta perpendicular al plano inclinado." .

ns1:RevisarSintaxisYConfiguracionDeCinematica a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis y configuración de cinemática" ;
    ns1:solucionaFallo ns1:ElGrupoDeEjesEsInsuficienteParaLaTransformacion ;
    ns1:textoExtracto "Activar primero la cinemática y a continuación la función deseada." .

ns1:FaltaEjeSRotativoParaLaTransformacion a ns1:DiagnosticoFallo ;
    rdfs:label "Falta eje(s) rotativo para la transformación" ;
    ns1:textoExtracto "'Falta eje(s) rotativo para la transformación'" .

ns1:ElGrupoDeEjesEsInsuficienteParaLaTransformacion a ns1:DiagnosticoFallo ;
    rdfs:label "El grupo de ejes es insuficiente para la transformación" ;
    ns1:textoExtracto "'El grupo de ejes es insuficiente para la transformación'" .

