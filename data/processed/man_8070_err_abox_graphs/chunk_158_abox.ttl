ns1:NoEjecutarFuncionesConTransformacionDeCoordenadasActiva a ns1:AccionProhibida ;
    rdfs:label "No ejecutar funciones con transformación de coordenadas activa" ;
    ns1:textoExtracto "El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas." .

