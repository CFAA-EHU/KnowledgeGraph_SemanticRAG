ex:Error_1369
    a               ex:DiagnosticoFallo ;
    ex:identificador "1369" ;
    rdfs:label      "#HSC: programación no permitida"@es ;
    ex:textoExtracto """
    '#HSC: programación no permitida'
    DETECCIÓN: Durante la ejecución.
    CAUSA: La sintaxis de la sentencia no es correcta.
    SOLUCIÓN: Revisar la programación."""@es ;
    ex:activaAlarma  ex:Alarma_1369 .

ex:Alarma_1369
    a               ex:Alarma ;
    rdfs:label      "Alarma 1369: Error de sintaxis en programación HSC"@es ;
    ex:textoExtracto "#HSC: programación no permitida"@es .

ex:Error_1370
    a               ex:DiagnosticoFallo ;
    ex:identificador "1370" ;
    rdfs:label      "#HSC: doble programación"@es ;
    ex:textoExtracto """
    '#HSC: doble programación'
    DETECCIÓN: Durante la ejecución.
    CAUSA: En un mismo bloque está programada la activación y desactivación del modo HSC.
    SOLUCIÓN: Revisar en el manual de"""@es ;
    ex:activaAlarma  ex:Alarma_1370 .

ex:Alarma_1370
    a               ex:Alarma ;
    rdfs:label      "Alarma 1370: Doble programación en modo HSC"@es ;
    ex:textoExtracto "#HSC: doble programación"@es .