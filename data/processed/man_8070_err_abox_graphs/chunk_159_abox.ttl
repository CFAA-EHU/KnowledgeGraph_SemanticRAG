@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1370
    a ex:Alarma ;
    rdfs:label "Alarma 1370: #HSC: doble programación" ;
    ex:textoExtracto "1370 '#HSC: doble programación' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque está programada la activación y desactivación del modo HSC. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." ;
    ex:identificador "1370" .

ex:Alarma_1371
    a ex:Alarma ;
    rdfs:label "Alarma 1371: #HSC: modo no válido" ;
    ex:textoExtracto "1371 '#HSC: modo no válido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el modo HSC con un parámetro desconocido o ha intentado cambiar el modo de trabajo sin desactivarlo previamente. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1371" .

ex:Alarma_1373
    a ex:Alarma ;
    rdfs:label "Alarma 1373: #HSC: parámetro incorrecto" ;
    ex:textoExtracto "1373 '#HSC: parámetro incorrecto' DETECCIÓN Durante la ejecución. CAUSA El parámetro FAST o el parámetro CORNER de la sentencia #HSC tienen un valor incorrecto. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1373" .

ex:Alarma_1374
    a ex:Alarma ;
    rdfs:label "Alarma 1374: Se espera M02/M30" ;
    ex:textoExtracto "1374 'Se espera M02/M30' DETECCIÓN Durante la ejecución. CAUSA Falta programar M02 o M30 al final del programa principal. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1374" .

ex:Alarma_1375
    a ex:Alarma ;
    rdfs:label "Alarma 1375: Se espera M17/M29/#RET" ;
    ex:textoExtracto "1375 'Se espera M17/M29/#RET' DETECCIÓN Durante la ejecución. CAUSA Falta programar M17, M29 o #RET al final de la subrutina. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1375" .

ex:Alarma_1376
    a ex:Alarma ;
    rdfs:label "Alarma 1376: No se ha definido nombre por defecto para el eje C" ;
    ex:textoExtracto "1376 'No se ha definido nombre por defecto para el eje C' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #CAX falta indicar el nombre del eje C y en los parámetros máquina no está indicado el nombre por defecto (parámetro CAXIS). SOLUCIÓN Indicar en la sentencia #CAX el nombre con el que identificará al eje C." ;
    ex:identificador "1376" .

ex:Alarma_1377
    a ex:Alarma ;
    rdfs:label "Alarma 1377: Escritura de parámetro con índice no válido" ;
    ex:textoExtracto "1377 'Escritura de parámetro con índice no válido' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe o está protegido contra escritura. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." ;
    ex:identificador "1377" .

ex:Parametro_FAST
    a ex:Parametro ;
    rdfs:label "Parámetro FAST de la sentencia #HSC" ;
    ex:textoExtracto "El parámetro FAST [...] de la sentencia #HSC tienen un valor incorrecto." .

ex:Parametro_CORNER
    a ex:Parametro ;
    rdfs:label "Parámetro CORNER de la sentencia #HSC" ;
    ex:textoExtracto "El parámetro [...] CORNER de la sentencia #HSC tienen un valor incorrecto." .

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro CAXIS (nombre por defecto del eje C)" ;
    ex:textoExtracto "parámetro CAXIS" ;
    ex:identificador "CAXIS" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha intentado activar el modo HSC con un parámetro desconocido" ;
    ex:monitoreaParametro ex:Parametro_FAST ;
    ex:monitoreaParametro ex:Parametro_CORNER ;
    ex:monitoreaParametro ex:Parametro_CAXIS ;
    ex:activaAlarma ex:Alarma_1370 ;
    ex:activaAlarma ex:Alarma_1371 ;
    ex:activaAlarma ex:Alarma_1373 ;
    ex:activaAlarma ex:Alarma_1374 ;
    ex:activaAlarma ex:Alarma_1375 ;
    ex:activaAlarma ex:Alarma_1376 ;
    ex:activaAlarma ex:Alarma_1377 .