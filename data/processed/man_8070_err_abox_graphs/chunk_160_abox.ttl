ns1:DesactivarLaTransformacionCambiarLaPosicionDeLosEjesYVolverAActivarLa_4d242a27a9 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación" ;
    ns1:solucionaFallo ns1:ElCNCNoHaPodidoResolverUnaTransformacionDeCoordenadasPiezaACoordenadasMaquina ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación." .

ns1:LosEjesDeLaCinematicaActivaNoPuedenExcluirseOSerModificados a ns1:AccionProhibida ;
    rdfs:label "Los ejes de la cinemática activa no pueden excluirse o ser modificados" ;
    ns1:mitigaRiesgo ns1:CNC8070_fa0ffffea7 ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados'" .

ns1:CNC8070_fa0ffffea7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado modificar la configuración de ejes de una cinemática mientras ésta" .

ns1:ElCNCNoHaPodidoResolverUnaTransformacionDeCoordenadasPiezaACoordenadasMaquina a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina" ;
    ns1:textoExtracto "CAUSA El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés." .

