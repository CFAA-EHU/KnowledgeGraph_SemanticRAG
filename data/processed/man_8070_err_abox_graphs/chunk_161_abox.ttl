@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosMaquina_1000_1999
    a ex:Tabla ;
    rdfs:label "Tabla de parámetros máquina (1000-1999)"@es ;
    ex:textoExtracto """
| Parámetros máquina. | Rango válido. |
| --- | --- |
| MINLOCP - MAXLOCP | Parámetros aritméticos locales. |
| MINGLBP - MAXGLBP | Parámetros aritméticos globales. |
| MINCOMP - MAXCOMP | Parámetros aritméticos comunes. """
    .

ex:Parametro_MINLOCP
    a ex:Parametro ;
    rdfs:label "MINLOCP" ;
    ex:identificador "MINLOCP" ;
    ex:textoExtracto "MINLOCP - MAXLOCP: Parámetros aritméticos locales."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .

ex:Parametro_MAXLOCP
    a ex:Parametro ;
    rdfs:label "MAXLOCP" ;
    ex:identificador "MAXLOCP" ;
    ex:textoExtracto "MINLOCP - MAXLOCP: Parámetros aritméticos locales."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .

ex:Parametro_MINGLBP
    a ex:Parametro ;
    rdfs:label "MINGLBP" ;
    ex:identificador "MINGLBP" ;
    ex:textoExtracto "MINGLBP - MAXGLBP: Parámetros aritméticos globales."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .

ex:Parametro_MAXGLBP
    a ex:Parametro ;
    rdfs:label "MAXGLBP" ;
    ex:identificador "MAXGLBP" ;
    ex:textoExtracto "MINGLBP - MAXGLBP: Parámetros aritméticos globales."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .

ex:Parametro_MINCOMP
    a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:identificador "MINCOMP" ;
    ex:textoExtracto "MINCOMP - MAXCOMP: Parámetros aritméticos comunes."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .

ex:Parametro_MAXCOMP
    a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:identificador "MAXCOMP" ;
    ex:textoExtracto "MINCOMP - MAXCOMP: Parámetros aritméticos comunes."@es ;
    ex:documentadoEn ex:TablaParametrosMaquina_1000_1999 .