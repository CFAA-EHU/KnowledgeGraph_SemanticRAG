ns1:LosEjesDeLaCinematicaActivaNoPuedenExcluirseOSerModificados_42377713ec a ns1:AvisoSeguridad ;
    rdfs:label "Los ejes de la cinemática activa no pueden excluirse o ser modificados" ;
