@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1386
    a ex:Alarma ;
    rdfs:label "Alarma 1386: Conflicto en programación de herramienta"@es ;
    ex:identificador "1386" ;
    ex:textoExtracto "1386 'No se admite modificar D y los offsets de la herramienta en el mismo bloque'"@es ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector."@es .

ex:Alarma_1387
    a ex:Alarma ;
    rdfs:label "Alarma 1387: Límite de funciones M"@es ;
    ex:identificador "1387" ;
    ex:textoExtracto "1387 'Límite de funciones M en un mismo bloque'"@es .

ex:Parametro_VGT
    a ex:Parametro ;
    rdfs:label "Variable V.G.TOFL.xn"@es ;
    ex:identificador "V.G.TOFL.xn" ;
    ex:textoExtracto "El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector."@es .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector."@es ;
    ex:activaAlarma ex:Alarma_1386 ;
    ex:monitoreaParametro ex:Parametro_VGT .