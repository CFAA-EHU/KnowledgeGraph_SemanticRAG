@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MensajeDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Mensaje demasiado largo" ;
    ns1:textoExtracto "'Mensaje demasiado largo' DETECCIÓN" .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:NoCoincideElNumeroDeParametrosYDeEspecificadoresDeFormato ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NoCoincideElNumeroDeParametrosYDeEspecificadoresDeFormato a ns1:DiagnosticoFallo ;
    rdfs:label "No coincide el número de parámetros y de especificadores de formato" ;
    ns1:textoExtracto "'No coincide el número de parámetros y de especificadores de formato' DETECCIÓN Durante la ejecución. CAUSA El número de identificadores de datos (%D ó %d) indicados en la sentencia #MSG, #ERROR ó #WARNING no coincide con el número de parámetros a visualizar." .

