@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:DemasiadosParametrosProgramadosEnLaSentencia ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarLongitudDelMensaje a ns1:TareaMantenimiento ;
    rdfs:label "Revisar longitud del mensaje" ;
    ns1:solucionaFallo ns1:ElMensajeDelComandoMSGEsDemasiadoLargo ;
    ns1:textoExtracto "SOLUCIÓN La longitud máxima del texto en estas sentencias es de 70 caracteres." .

ns1:DemasiadosParametrosProgramadosEnLaSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados parámetros programados en la sentencia" ;
    ns1:textoExtracto "'Demasiados parámetros programados en la sentencia' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ElMensajeDelComandoMSGEsDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "El mensaje del comando #MSG es demasiado largo" ;
    ns1:textoExtracto "1289 El mensaje del comando #MSG es demasiado largo. DETECCIÓN Durante la ejecución. CAUSA El mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo." .

