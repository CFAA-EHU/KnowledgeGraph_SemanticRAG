     a ex:Parametro ;
    rdfs:label "Función G170"@es ;
    ex:identificador "G170" ;
    ex:textoExtracto "desactivar (G170)"@es .

ex:Funcion_G171 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G171"@es ;
    ex:identificador "G171" ;
    ex:textoExtracto "activar (G171)"@es .

