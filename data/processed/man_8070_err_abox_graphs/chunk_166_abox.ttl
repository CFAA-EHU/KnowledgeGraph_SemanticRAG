@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_64d442892c a ns1:DiagnosticoFallo ;
    rdfs:label "Función M doblemente programada" ;
    ns1:textoExtracto "'Función M doblemente programada. SOLUCIÓN La misma función M está programada más de una vez en el bloque.'" .

ns1:MensajeProgramadoEnLaSentenciaMSGWARNINGERROREsDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo" ;
    ns1:textoExtracto "'El mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo. SOLUCIÓN La longitud máxima del texto en estas sentencias es de 70 caracteres.'" .

ns1:NoSeAdmitenMasFuncionesS a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten más funciones S" ;
    ns1:textoExtracto "'No se admiten más funciones S. SOLUCIÓN El máximo número de funciones S admitido en un mismo bloque es 4.'" .

ns1:ProgramarLaMismaFuncionMMasDeUnaVezEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Programar la misma función M más de una vez en el bloque" ;
    ns1:textoExtracto "'La misma función M está programada más de una vez en el bloque.'" .

ns1:ProgramarMasDe4FuncionesSEnUnMismoBloque a ns1:AccionProhibida ;
    rdfs:label "Programar más de 4 funciones S en un mismo bloque" ;
    ns1:textoExtracto "'El máximo número de funciones S admitido en un mismo bloque es 4.'" .

ns1:ProgramarMensajeConMasDe70CaracteresEnSentenciasMSGWARNINGERROR a ns1:AccionProhibida ;
    rdfs:label "Programar mensaje con más de 70 caracteres en sentencias #MSG/#WARNING/#ERROR" ;
    ns1:textoExtracto "'La longitud máxima del texto en estas sentencias es de 70 caracteres.'" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ProgramacionDeCoordenadasIJKIncorrecta ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación.'" .

ns1:ProgramacionDeCoordenadasIJKIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de coordenadas I, J, K incorrecta" ;
    ns1:textoExtracto "'Programación de coordenadas I, J, K incorrecta. SOLUCIÓN Revisar la programación.'" .

