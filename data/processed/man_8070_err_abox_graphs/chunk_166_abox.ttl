@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_1394
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1394: 'No existe la subrutina asociada a la función G'"@es ;
    ex:identificador "1394" ;
    ex:textoExtracto "1394 'No existe la subrutina asociada a la función G' [...] CAUSA Hay programada una función G180 a G189 y no existe la subrutina asociada. Hay programada una función G74 sola en el bloque y no existe la subrutina asociada."@es .

ex:Error_1395
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1395: 'La función G74 con subrutina asociada se programa sola en el bloque'"@es ;
    ex:identificador "1395" ;
    ex:textoExtracto "1395 'La función G74 con subrutina asociada se programa sola en el bloque' [...] CAUSA Si la función G74 tiene subrutina asociada, se debe programar sola en el bloque o junto a la etiqueta del bloque."@es .

ex:Error_1396
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1396: 'Programación no permitida en MDI'"@es ;
    ex:identificador "1396" ;
    ex:textoExtracto "1396 'Programación no permitida en MDI' [...] CAUSA No se permite ejecutar esa orden en MDI."@es .

ex:Error_1397
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1397: 'La posición programada para el eje Hirth es incorrecta'"@es ;
    ex:identificador "1397" ;
    ex:textoExtracto "1397 'La posición programada para el eje Hirth es incorrecta' [...] CAUSA La cota programada para el eje Hirth no se corresponde a un paso entero."@es .

ex:Parametro_HIRTH
    a ex:Parametro ;
    rdfs:label "Parámetro HIRTH"@es ;
    ex:identificador "HIRTH" ;
    ex:textoExtracto "parámetro HIRTH = NO"@es ;
    ex:valor "NO" .

ex:Error_1398
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1398: 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO'"@es ;
    ex:identificador "1398" ;
    ex:textoExtracto "1398 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO' [...] CAUSA El CNC ha intentado activar (G171) o desactivar (G170) como eje hirth un eje que no lo es (parámetro HIRTH)."@es ;
    ex:solucionaFallo ex:Parametro_HIRTH .

ex:Error_1399
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1399: 'No puede activarse el eje como Hirth'"@es ;
    ex:identificador "1399" ;
    ex:textoExtracto "1399 'No puede activarse el eje como Hirth' [...] DETECCIÓN Durante la ejecución."@es .

ex:Funcion_G74 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G74"@es ;
    ex:identificador "G74" ;
    ex:textoExtracto "función G74"@es .

