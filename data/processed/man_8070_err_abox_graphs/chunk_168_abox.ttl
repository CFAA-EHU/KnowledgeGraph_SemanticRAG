@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaVelocidadDeCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la velocidad de cabezal" ;
    ns1:solucionaFallo ns1:LaVelocidadDeCabezalNoEsValida ;
    ns1:textoExtracto "'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución. CAUSA La" .

ns1:NombreDeVariableDemasiadoLargo_b3a62a3eaa a ns1:Parametro ;
    rdfs:label "Nombre de variable demasiado largo" ;
    ns1:textoExtracto "'Nombre de variable demasiado largo' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable." .

ns1:ReducirElNombreDeLaVariableA13Caracteres a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el nombre de la variable a 13 caracteres" ;
    ns1:solucionaFallo ns1:SuperadoElMaximoNumeroDeCaracteresPermitidoParaElNombreDeLaVariable ;
    ns1:textoExtracto "SOLUCIÓN El máximo número de caracteres permitido es 13." .

ns1:VelocidadDeCabezalNoValida a ns1:Parametro ;
    rdfs:label "Velocidad de cabezal no válida" ;
    ns1:textoExtracto "'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución. CAUSA La" .

ns1:LaVelocidadDeCabezalNoEsValida a ns1:DiagnosticoFallo ;
    rdfs:label "La velocidad de cabezal no es válida" ;
    ns1:textoExtracto "'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución. CAUSA La" .

ns1:SuperadoElMaximoNumeroDeCaracteresPermitidoParaElNombreDeLaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Superado el máximo número de caracteres permitido para el nombre de la variable" ;
    ns1:textoExtracto "CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable." .

