@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeLaProgramacionIncremental a ns1:AccionProhibida ;
    rdfs:label "Activación de la programación incremental" ;
    ns1:textoExtracto "• Activación de la programación incremental (G91)." .

ns1:ActivacionDesactivacionDeGarras a ns1:AccionProhibida ;
    rdfs:label "Activación/desactivación de garras" ;
    ns1:textoExtracto "• Activación/desactivación de garras (variable \"V.G.FIX\")." .

ns1:ActivacionDesactivacionDeImagenEspejo a ns1:AccionProhibida ;
    rdfs:label "Activación/desactivación de imagen espejo" ;
    ns1:textoExtracto "• Activación/desactivación de imagen espejo (G11/G12/G13/G14)." .

ns1:ActivacionDesactivacionDeTrasladosDeOrigen a ns1:AccionProhibida ;
    rdfs:label "Activación/desactivación de traslados de origen" ;
    ns1:textoExtracto "• Activación/desactivación de traslados de origen (G54-G59, G159, G92, G158, G53)." .

ns1:ActivacionDesactivacionDelOffsetDeMedicion a ns1:AccionProhibida ;
    rdfs:label "Activación/desactivación del offset de medición" ;
    ns1:textoExtracto "• Activación/desactivación el offset de medición (G101, G102)." .

ns1:FalloProgramacionNoPermitidaConMCSActivo a ns1:DiagnosticoFallo ;
    rdfs:label "'Programación no permitida con #MCS activo'" ;
    ns1:textoExtracto "Programación no permitida con #MCS activo DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la función MCS." .

ns1:ProgramacionConMCSActivo a ns1:AccionProhibida ;
    rdfs:label "Programación con #MCS activo" ;
    ns1:textoExtracto "Programación no permitida con #MCS activo" .

ns1:ProgramacionEnRadiosDiametros a ns1:AccionProhibida ;
    rdfs:label "Programación en radios/diámetros" ;
    ns1:textoExtracto "• Programación en radios/diámetros (G151/G152)." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FalloVelocidadCabezalNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VelocidadDeCabezal_2f7e403fa9 a ns1:Parametro ;
    rdfs:label "Velocidad de cabezal" ;
    ns1:textoExtracto "'Velocidad de cabezal no válida'" .

ns1:FalloVelocidadCabezalNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "'Velocidad de cabezal no válida'" ;
    ns1:textoExtracto "'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución. CAUSA La velocidad programada es demasiado pequeña." .

