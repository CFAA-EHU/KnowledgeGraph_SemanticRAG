@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1419
    a               ex:Alarma ;
    ex:identificador "1419" ;
    rdfs:label      "'No se permite aparcar ejes acoplados, Gantry o Tandem'" ;
    ex:textoExtracto "1419 'No se permite aparcar ejes acoplados, Gantry o Tandem' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado aparcar un eje que forma parte de una pareja gantry, tándem o de un acoplo activo (#LINK)." .

ex:Alarma_1420
    a               ex:Alarma ;
    ex:identificador "1420" ;
    ex:textoExtracto "Los ejes que forman parte de una pareja gantry o tándem no se pueden aparcar." .

ex:Sistema_GantryTandem
    a               ex:Sistema ;
    rdfs:label      "Sistema de ejes Gantry/Tándem" ;
    ex:textoExtracto "eje que forma parte de una pareja gantry, tándem o de un acoplo activo (#LINK)" ;
    ex:activaAlarma ex:Alarma_1419 .

ex:AccionProhibida_AparcarEjesAcoplados
    a               ex:AccionProhibida ;
    rdfs:label      "Aparcar ejes acoplados (Gantry/Tándem)" ;
    ex:textoExtracto "No se permite aparcar ejes acoplados, Gantry o Tandem" ;
    ex:activaAlarma ex:Alarma_1419 .