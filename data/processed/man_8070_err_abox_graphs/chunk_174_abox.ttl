@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnidamientoDeSentenciasCSONACSONSobrepasado_b9d53243be a ns1:DiagnosticoFallo ;
    rdfs:label "Anidamiento de sentencias #CS ON/#ACS ON sobrepasado" ;
    ns1:textoExtracto "'Anidamiento de sentencias #CS ON/#ACS ON sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el límite de combinaciones de sistemas de coordenadas." .

ns1:EtiquetaDefinidaVariasVeces a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta definida varias veces" ;
    ns1:textoExtracto "'Etiqueta definida varias veces' DETECCIÓN Durante la ejecución. CAUSA La etiqueta del bloque está repetida en el programa." .

ns1:EtiquetaNoDefinidaEnLaMismaSubrutinaQueElGOTORPTOABORT a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta no definida en la misma subrutina que el $GOTO, #RPT ó #ABORT" ;
    ns1:textoExtracto "Etiqueta no definida en la misma subrutina que el $GOTO, #RPT ó #ABORT. DETECCIÓN Durante la ejecución. CAUSA La etiqueta programada en $GOTO, #RPT o #ABORT no existe en la subrutina o programa." .

ns1:ModificarHardware a ns1:AccionProhibida ;
    rdfs:label "Modificar hardware" ;
    ns1:textoExtracto "SOLUCIÓN El CNC permite combinar diferentes sistemas de coordenadas entre sí para construir otros nuevos." .

ns1:NombreDeEtiquetaDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de etiqueta demasiado largo" ;
    ns1:textoExtracto "'Nombre de etiqueta demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la etiqueta supera el número de caracteres permitidos." .

ns1:NumeroDeBloqueDefinidoVariasVeces a ns1:DiagnosticoFallo ;
    rdfs:label "Número de bloque definido varias veces" ;
    ns1:textoExtracto "'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque 'N' está repetido en el programa." .

ns1:NumeroMaximoDeEtiquetasSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de etiquetas sobrepasado" ;
    ns1:textoExtracto "'Número máximo de etiquetas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El programa tiene más etiquetas de bloque que las permitidas." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:GOTOEtiquetaNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:GOTOEtiquetaNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "$GOTO: Etiqueta no válida" ;
    ns1:textoExtracto "'$GOTO: Etiqueta no válida' DETECCIÓN Durante la ejecución. CAUSA Una etiqueta sólo se puede definir con una cadena de caracteres entre corchetes o con el carácter 'N' seguido de un número positivo y menor que 2147483646." .

