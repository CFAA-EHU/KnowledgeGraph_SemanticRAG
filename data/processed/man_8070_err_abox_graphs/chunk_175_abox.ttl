@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoRepetirElNumeroDeBloque a ns1:TareaMantenimiento ;
    rdfs:label "No repetir el número de bloque" ;
    ns1:solucionaFallo ns1:NumeroDeBloqueDefinidoVariasVeces ;
    ns1:textoExtracto "SOLUCIÓN No repetir el número de bloque." .

ns1:ValorErroneoParaAsignarAVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Valor erróneo para asignar a variable" ;
    ns1:textoExtracto "'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución." .

ns1:NumeroDeBloqueDefinidoVariasVeces a ns1:DiagnosticoFallo ;
    rdfs:label "Número de bloque definido varias veces" ;
    ns1:textoExtracto "'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque 'N' está repetido en el programa." .

