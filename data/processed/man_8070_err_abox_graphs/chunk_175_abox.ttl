@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error1426
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1426: Cajera con radio de herramienta incorrecto" ;
    ex:textoExtracto "1426 'La cajera fue resuelta con diferente radio de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con un radio de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera." ;
    ex:identificador "1426" .

ex:Error1427
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1427: Eje mal programado" ;
    ex:textoExtracto "1427 'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está" ;
    ex:identificador "1427" .

ex:ErrorSintaxisProgramacion
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error de sintaxis: Uso incorrecto de '/' en programación" ;
    ex:textoExtracto "CAUSA El carácter \"/\" solo se admite al comienzo de la línea de programa. SOLUCIÓN Revisar la programación." .