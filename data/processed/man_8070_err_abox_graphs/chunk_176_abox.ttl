@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1427 a ex:DiagnosticoFallo ;
    rdfs:label "Eje mal programado" ;
    ex:identificador "1427" ;
    ex:textoExtracto "Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema." .

ex:Fallo_1428 a ex:DiagnosticoFallo ;
    rdfs:label "El movimiento en el plano principal debe programarse antes de la G del ciclo" ;
    ex:identificador "1428" ;
    ex:textoExtracto "Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo. El ciclo considera las coordenadas del punto inicial como parámetros propios." .

ex:Fallo_1429 a ex:DiagnosticoFallo ;
    rdfs:label "Límite de subrutinas en un mismo bloque sobrepasado" ;
    ex:identificador "1429" ;
    ex:textoExtracto "Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque." .

ex:Fallo_1430 a ex:DiagnosticoFallo ;
    rdfs:label "Formato numérico sobrepasado" ;
    ex:identificador "1430" ;
    ex:textoExtracto "El valor asignado a un dato, variable o parámetro es superior al formato establecido." .

ex:Fallo_1431 a ex:DiagnosticoFallo ;
    rdfs:label "Posición de cabezal en M19 no válida" ;
    ex:identificador "1431" ;
    ex:textoExtracto "El valor programado para la posición de cabezal en M19 es demasiado alto." .

ex:Fallo_1432 a ex:DiagnosticoFallo ;
    rdfs:label "No se puede programar un eje esclavo de un acoplo o Gantry" ;
    ex:identificador "1432" ;
    ex:textoExtracto "En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." .

ex:Parametro_G74 a ex:Parametro ;
    rdfs:label "Orden de búsqueda de cero en G74" ;
    ex:textoExtracto "orden de la búsqueda de cero de los ejes" ;
    ex:valor "programación de ejes" .

ex:Parametro_G20 a ex:Parametro ;
    rdfs:label "Orden de ejes en G20" ;
    ex:textoExtracto "orden de los ejes en el sistema" ;
    ex:valor "programación de ejes" .

ex:Parametro_M19 a ex:Parametro ;
    rdfs:label "Posición de cabezal en M19" ;
    ex:textoExtracto "valor programado para la posición de cabezal en M19" ;
    ex:valor "límite de posición" .

ex:Fallo_1427 ex:solucionaFallo ex:Parametro_G74 ;
             ex:solucionaFallo ex:Parametro_G20 .

ex:Fallo_1431 ex:solucionaFallo ex:Parametro_M19 .