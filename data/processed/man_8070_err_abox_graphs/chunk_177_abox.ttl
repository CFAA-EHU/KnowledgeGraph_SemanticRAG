@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarLaCompensacionDeRadio a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la compensación de radio"@es ;
    ns1:solucionaFallo ns1:CambioDelPrimerYOSegundoEjeDelPlanoConCompensacionDeRadioActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación"@es ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeLaFuncionG14ImagenEspejo ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacionDeOrientacionDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de orientación de herramienta"@es ;
    ns1:solucionaFallo ns1:TOOLAXSeEsperaOrientacionTrasLaDesignacionDelEje ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacionDeRadio a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de radio"@es ;
    ns1:solucionaFallo ns1:TANGFEEDRMINRadioNegativoNoPermitido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:CambioDelPrimerYOSegundoEjeDelPlanoConCompensacionDeRadioActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio del primer y/o segundo eje del plano con compensación de radio activa"@es ;
    ns1:textoExtracto "1333 'Cambio del primer y/o segundo eje del plano con compensación de radio activa'" .

ns1:ProgramacionIncorrectaDeLaFuncionG14ImagenEspejo a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de la función G14 (imagen espejo)"@es ;
    ns1:textoExtracto "CAUSA Programación incorrecta de la función G14 (imagen espejo)." .

ns1:TANGFEEDRMINRadioNegativoNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "#TANGFEED RMIN: radio negativo no permitido"@es ;
    ns1:textoExtracto "1331 '#TANGFEED RMIN: radio negativo no permitido'" .

ns1:TOOLAXSeEsperaOrientacionTrasLaDesignacionDelEje a ns1:DiagnosticoFallo ;
    rdfs:label "#TOOL AX: se espera orientación +/- tras la designación del eje"@es ;
    ns1:textoExtracto "1332 '#TOOL AX: se espera orientación +/- tras la designación del eje'" .

