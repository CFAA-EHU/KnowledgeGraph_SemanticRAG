@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroCAXIS a ns1:Parametro ;
    rdfs:label "parámetro CAXIS" ;
    ns1:textoExtracto "(parámetro CAXIS)" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ConfiguracionErroneaDosEjesCAXIS,
        ns1:LaSeleccionNoTieneEfecto,
        ns1:NoSeHaDefinidoEjeCAXIS ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ConfiguracionErroneaDosEjesCAXIS a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración errónea: dos ejes CAXIS" ;
    ns1:textoExtracto "'Configuración errónea: dos ejes CAXIS'" .

ns1:LaSeleccionNoTieneEfecto a ns1:DiagnosticoFallo ;
    rdfs:label "La selección no tiene efecto" ;
    ns1:textoExtracto "'La selección no tiene efecto'" .

ns1:NoSeHaDefinidoEjeCAXIS a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido eje CAXIS" ;
    ns1:textoExtracto "'No se ha definido eje CAXIS'" .

