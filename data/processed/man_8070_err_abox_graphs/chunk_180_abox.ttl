@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CAXOFF_b8b84cf725 a ns1:Parametro ;
    rdfs:label "#CAX OFF" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #CAX OFF y no hay ningún cabezal trabajando como eje C." .

ns1:CNC8070_68ca8309fa a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:LaDeseleccionNoTieneEfecto,
        ns1:NoSeAdmiteCAXOFFSiAlgunaTransformacionEstaActiva,
        ns1:NoSeAdmiteCambioDePlanoDuranteElMecanizadoEnSuperficieLateral,
        ns1:NoSeAdmiteFACEOFFConElTipoDeCinematicaActiva ;
    ns1:textoExtracto "CNC 8070" .

ns1:FACEOFF a ns1:Parametro ;
    rdfs:label "#FACE OFF" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #FACE OFF y no hay activo ningún mecanizado en la superficie frontal." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaDeseleccionNoTieneEfecto,
        ns1:NoSeAdmiteCAXOFFSiAlgunaTransformacionEstaActiva,
        ns1:NoSeAdmiteCambioDePlanoDuranteElMecanizadoEnSuperficieLateral,
        ns1:NoSeAdmiteFACEOFFConElTipoDeCinematicaActiva ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:LaDeseleccionNoTieneEfecto a ns1:DiagnosticoFallo ;
    rdfs:label "La deselección no tiene efecto" ;
    ns1:textoExtracto "'La deselección no tiene efecto'" .

ns1:NoSeAdmiteCAXOFFSiAlgunaTransformacionEstaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite #CAX OFF si alguna transformación esta activa'" ;
    ns1:textoExtracto "'No se admite #CAX OFF si alguna transformación esta activa'" .

ns1:NoSeAdmiteCambioDePlanoDuranteElMecanizadoEnSuperficieLateral a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite cambio de plano durante el mecanizado en superficie lateral'" ;
    ns1:textoExtracto "'No se admite cambio de plano durante el mecanizado en superficie lateral'" .

ns1:NoSeAdmiteFACEOFFConElTipoDeCinematicaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite #FACE OFF con el tipo de cinemática activa'" ;
    ns1:textoExtracto "'No se admite #FACE OFF con el tipo de cinemática activa'" .

