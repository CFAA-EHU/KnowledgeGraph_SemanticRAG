@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1439
    a ex:Alarma ;
    rdfs:label "Alarma 1439: Los ejes de la transformación activa no pueden ser Hirth" ;
    ex:textoExtracto "'Los ejes de la transformación activa no pueden ser Hirth' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación de coordenadas (#TLC, #RTCP, #TOOL ORI, #CS o #ACS) y uno de los ejes que intervienen en la transformación es Hirth. SOLUCIÓN Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)." ;
    ex:identificador "1439" .

ex:Alarma_1440
    a ex:Alarma ;
    rdfs:label "Alarma 1440: Herramienta o filo no válido" ;
    ex:textoExtracto "'Herramienta o filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta y/o corrector indicado en la variable no existe. SOLUCIÓN Revisar la programación. Consultar las herramientas y correctores existentes." ;
    ex:identificador "1440" .

ex:Alarma_1441
    a ex:Alarma ;
    rdfs:label "Alarma 1441: No se ha activado la cinemática" ;
    ex:textoExtracto "'No se ha activado la cinemática' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA La cinemática que aplica el CNC por defecto (parámetro KINID) es desconocida o los ejes necesarios para la cinemática no son los adecuados. SOLUCIÓN Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry." ;
    ex:identificador "1441" .

ex:Alarma_1442
    a ex:Alarma ;
    rdfs:label "Alarma 1442: Se ha desactivado la cinemática" ;
    ex:textoExtracto "'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza." ;
    ex:identificador "1442" .

ex:Alarma_1439_parada_bloque
    a ex:Alarma ;
    rdfs:label "Alarma: Falta definir el bloque de parada de la búsqueda de bloque" ;
    ex:textoExtracto "'de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque. SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en el menú de softkeys aparece la opción para seleccionar el bloque parada. Seleccionar el bloque en el que se desea finalizar la búsqueda de bloque." ;
    ex:identificador "parada_bloque" .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC (menú de softkeys)" ;
    ex:textoExtracto "en el menú de softkeys aparece la opción para seleccionar el bloque parada. Seleccionar el bloque en el que se desea finalizar la búsqueda de bloque." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (control numérico)" ;
    ex:textoExtracto "El CNC ha intentado activar una transformación de coordenadas (#TLC, #RTCP, #TOOL ORI, #CS o #ACS) y uno de los ejes que intervienen en la transformación es Hirth." .

ex:Parametro_KINID
    a ex:Parametro ;
    rdfs:label "Parámetro KINID (identificador de cinemática)" ;
    ex:textoExtracto "La cinemática que aplica el CNC por defecto (parámetro KINID) es desconocida o los ejes necesarios para la cinemática no son los adecuados." ;
    ex:identificador "KINID" .

ex:DiagnosticoFallo_1439
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1439: Eje Hirth en transformación" ;
    ex:textoExtracto "Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)." ;
    ex:solucionaFallo ex:Alarma_1439 .

ex:DiagnosticoFallo_1441
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1441: Cinemática no activada" ;
    ex:textoExtracto "Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry." ;
    ex:solucionaFallo ex:Alarma_1441 .

ex:Sistema_CNC
    ex:activaAlarma ex:Alarma_1439 ;
    ex:activaAlarma ex:Alarma_1440 ;
    ex:activaAlarma ex:Alarma_1441 ;
    ex:activaAlarma ex:Alarma_1442 ;
    ex:activaAlarma ex:Alarma_1439_parada_bloque ;
    ex:tieneComponente ex:Parametro_KINID .

ex:InterfazUsuario_CNC
    ex:mitigaRiesgo ex:Alarma_1439_parada_bloque .