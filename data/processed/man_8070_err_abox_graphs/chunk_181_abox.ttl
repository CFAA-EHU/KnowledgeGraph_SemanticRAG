@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeEjesEnProgramacionG20 a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de ejes en programación G20" ;
    ns1:solucionaFallo ns1:DeteccionDeProgramacionIncorrectaEnG20 ;
    ns1:textoExtracto "SOLUCIÓN Ambos ejes han de ser diferentes y estar entre los tres primeros ejes." .

ns1:G20ProgramacionIncorrectaDeEjes a ns1:AccionProhibida ;
    rdfs:label "G20: programación incorrecta de ejes" ;
    ns1:textoExtracto "'G20: programación incorrecta de ejes'" .

ns1:NoSeAdmiteCambioDePlanoDuranteElMecanizadoEnSuperficieLateral_d470f7ed4e a ns1:AccionProhibida ;
    rdfs:label "No se admite cambio de plano durante el mecanizado en superficie lateral" ;
    ns1:textoExtracto "'No se admite cambio de plano durante el mecanizado en superficie lateral'" .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:DeteccionDelIntentoDeCambioDePlanoDuranteElMecanizado ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DeteccionDeProgramacionIncorrectaEnG20 a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de programación incorrecta en G20" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos." .

ns1:DeteccionDelIntentoDeCambioDePlanoDuranteElMecanizado a ns1:DiagnosticoFallo ;
    rdfs:label "Detección del intento de cambio de plano durante el mecanizado" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo (G17-G20) mientras está activo el mecanizado en la superficie lateral." .

