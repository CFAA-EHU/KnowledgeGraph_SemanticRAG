@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1442
    a               ex:Alarma ;
    rdfs:label      "Alarma 1442: 'Se ha desactivado la cinemática'"@es ;
    ex:identificador "1442" ;
    ex:textoExtracto "1442 'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza. CAUSA El CNC ha desactivado una cinemática, bien porque es una cinemática desconocida ó bien porque los ejes necesarios para esa cinemática no son los adecuados."@es .

ex:AvisoSeguridad_EjesCinematica
    a               ex:AvisoSeguridad ;
    rdfs:label      "Requisitos de ejes para cinemática"@es ;
    ex:textoExtracto "Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry."@es ;
    ex:mitigaRiesgo  ex:Alarma_1442 .