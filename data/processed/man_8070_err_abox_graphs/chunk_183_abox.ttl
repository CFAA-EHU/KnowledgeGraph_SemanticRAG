@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1447
    a ex:Alarma ;
    rdfs:label "Alarma 1447: Opción de software no permitida" ;
    ex:textoExtracto "'Opción de software no permitida'" ;
    ex:identificador "1447" .

ex:DiagnosticoFallo_1447_Causa1
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta de opción de software en CNC" ;
    ex:textoExtracto "El CNC no dispone de la opción de software necesaria para ejecutar la orden programada." ;
    ex:solucionaFallo ex:Alarma_1447 .

ex:DiagnosticoFallo_1447_Causa2
    a ex:DiagnosticoFallo ;
    rdfs:label "Intento de superar 550 Hz en regulador MDU" ;
    ex:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED." ;
    ex:solucionaFallo ex:Alarma_1447 .

ex:ComponenteElectrico_ReguladorMDU
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador MDU" ;
    ex:textoExtracto "regulador incluido en la lista de productos doble uso (identificados con el texto -MDU)" ;
    ex:identificador "MDU" ;
    ex:monitoreaParametro ex:Parametro_550Hz .

ex:Parametro_550Hz
    a ex:Parametro ;
    rdfs:label "Límite de frecuencia 550 Hz" ;
    ex:textoExtracto "550 Hz" ;
    ex:valor "550" ;
    ex:identificador "Hz" .