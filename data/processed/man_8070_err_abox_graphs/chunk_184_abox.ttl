@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1448
    a                       ex:DiagnosticoFallo ;
    rdfs:label               "No se puede colocar la herramienta perpendicular al plano activo"@es ;
    ex:identificador         "1448" ;
    ex:textoExtracto         "• Un cabezal angular no permite colocar la herramienta perpendicular al plano. • Colocar la herramienta perpendicular al plano activo implica sobrepasar los límites."@es .

ex:Fallo_1449
    a                       ex:DiagnosticoFallo ;
    rdfs:label               "Sentencia #PATH mal programada"@es ;
    ex:identificador         "1449" ;
    ex:textoExtracto         "La sintaxis de la sentencia #PATH no es correcta."@es .

ex:Fallo_1450
    a                       ex:DiagnosticoFallo ;
    rdfs:label               "Solución no válida de cabezal perpendicular al plano activo"@es ;
    ex:identificador         "1450" ;
    ex:textoExtracto         "El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido porque el CNC no puede colocar la herramienta perpendicular al plano activo. Causas: cabezal angular o sobrepasar límites."@es .

ex:Fallo_1451
    a                       ex:DiagnosticoFallo ;
    rdfs:label               "Variable inexistente para el tipo de eje"@es ;
    ex:identificador         "1451" ;
    ex:textoExtracto         "La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal)."@es .

ex:Regulador_MDU
    a                       ex:ComponenteElectrico ;
    rdfs:label               "Regulador de productos doble uso (MDU)"@es ;
    ex:identificador         "MDU" ;
    ex:textoExtracto         "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED."@es .

ex:Variable_VG_TOOLORIF1
    a                       ex:Parametro ;
    rdfs:label               "V.G.TOOLORIF1" ;
    ex:textoExtracto         "Variable para orientación de herramienta en cabezal (inválida si el CNC no puede colocar la herramienta perpendicular al plano activo)."@es .

ex:Variable_VG_TOOLORIF2
    a                       ex:Parametro ;
    rdfs:label               "V.G.TOOLORIF2" ;
    ex:textoExtracto         "Variable para orientación de herramienta en cabezal (inválida si el CNC no puede colocar la herramienta perpendicular al plano activo)."@es .

ex:Modo_Diagnosis
    a                       ex:ModoOperacion ;
    rdfs:label               "Modo diagnosis"@es ;
    ex:textoExtracto         "En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC."@es .

ex:Sentencia_PATH
    a                       ex:Parametro ;
    rdfs:label               "#PATH" ;
    ex:textoExtracto         "Sintaxis de programación para trayectorias en CNC."@es .