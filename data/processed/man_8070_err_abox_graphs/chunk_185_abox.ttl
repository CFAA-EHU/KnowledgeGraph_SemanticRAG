@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_3eb2f56db2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:DemasiadosValoresParaInicializarElArray,
        ns1:DetectadoUnCaracterNoValidoEnElBloque,
        ns1:ErrorEnLaLecturaDeLaVariable,
        ns1:LaVariableDeUsuarioNoExiste,
        ns1:LaVariableDefinidaYaExiste,
        ns1:NoSePuedeBorrarLaVariable ;
    ns1:textoExtracto "CNC 8070" .

ns1:ElCNCSoloPuedeBorrarVariablesDeUsuarioPrefijosPYS a ns1:AccionProhibida ;
    rdfs:label "El CNC sólo puede borrar variables de usuario (prefijos P y S)" ;
    ns1:textoExtracto "SOLUCIÓN El CNC sólo puede borrar variables de usuario (prefijos P y S)." .

ns1:LosComandosVARENDVARDELETENoPermitenEsteTipoDeVariable a ns1:AccionProhibida ;
    rdfs:label "Los comandos #VAR/#ENDVAR/#DELETE no permiten este tipo de variable" ;
    ns1:textoExtracto "Los comandos #VAR/#ENDVAR/#DELETE no permiten este tipo de variable. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC." .

ns1:RevisarLaSintaxisDelBloque a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la sintaxis del bloque" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la sintaxis del bloque. La sentencia se debe programar sola en el bloque o junto a la etiqueta del bloque. Este sentencia sólo permite variables de usuario." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:DemasiadosValoresParaInicializarElArray,
        ns1:DetectadoUnCaracterNoValidoEnElBloque,
        ns1:ErrorEnLaLecturaDeLaVariable,
        ns1:LaVariableDeUsuarioNoExiste,
        ns1:LaVariableDefinidaYaExiste,
        ns1:NoSePuedeBorrarLaVariable ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SeEsperaVariableOParametro a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera variable o parámetro" ;
    ns1:textoExtracto "'Se espera variable o parámetro' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la sentencia $IF EXIST." .

ns1:DemasiadosValoresParaInicializarElArray a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados valores para inicializar el array" ;
    ns1:textoExtracto "'Demasiados valores para inicializar el array' DETECCIÓN Durante la ejecución. CAUSA En la inicialización de una variable de array de usuario, el CNC inicializa más posiciones de las que tiene." .

ns1:DetectadoUnCaracterNoValidoEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Detectado un carácter no válido en el bloque" ;
    ns1:textoExtracto "'#DELETE: carácter no válido' DETECCIÓN Durante la ejecución. CAUSA Detectado un carácter no válido en el bloque." .

ns1:ErrorEnLaLecturaDeLaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la lectura de la variable" ;
    ns1:textoExtracto "'Error en la lectura de la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede leer la variable." .

ns1:LaVariableDeUsuarioNoExiste a ns1:AccionProhibida ;
    rdfs:label "La variable de usuario no existe" ;
    ns1:textoExtracto "'#DELETE: la variable a borrar no existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario no existe." .

ns1:LaVariableDefinidaYaExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La variable definida ya existe" ;
    ns1:textoExtracto "'#VAR/#ENDVAR: la variable definida ya existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe." .

ns1:NoSePuedeBorrarLaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede borrar la variable" ;
    ns1:textoExtracto "'No se puede borrar la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado borrar una variable del sistema." .

