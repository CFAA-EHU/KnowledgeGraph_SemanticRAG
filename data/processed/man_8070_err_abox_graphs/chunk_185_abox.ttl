ex:AccionProhibida_RevisarProgramacion_1451
    a               ex:AccionProhibida ;
    rdfs:label      "Revisar programación para alarma 1451"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación."@es ;
