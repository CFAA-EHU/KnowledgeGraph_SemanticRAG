ex:Alarma_1451
    a               ex:Alarma ;
    rdfs:label      "Variable inexistente para el tipo de eje"@es ;
    ex:identificador "1451" ;
    ex:textoExtracto "1451 'Variable inexistente para el tipo de eje' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal)."@es .

