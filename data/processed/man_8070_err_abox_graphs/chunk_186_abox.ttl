@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarElEjeCParaEjecutarLaFuncion a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el eje C para ejecutar la función" ;
    ns1:solucionaFallo ns1:NoSeAdmiteG33G63G95G96G97ConEjeCActivo ;
    ns1:textoExtracto "Desactivar el eje C para ejecutar la" .

ns1:NoSePuedenBorrarLasVariablesPredefinidasDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "No se pueden borrar las variables predefinidas del CNC" ;
    ns1:solucionaFallo ns1:NoSeAdmiteBorrarVariablesPredefinidasDelCNC ;
    ns1:textoExtracto "Estos comandos sólo son aplicables a variables con prefijo P y S." .

ns1:NoSeAdmiteBorrarVariablesPredefinidasDelCNC a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite borrar variables predefinidas del CNC" ;
    ns1:textoExtracto "Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC." .

ns1:NoSeAdmiteG33G63G95G96G97ConEjeCActivo a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G33/G63/G95/G96/G97 con eje C activo" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar una función G33/G63/G95/G96/G97 con el eje C activo." .

