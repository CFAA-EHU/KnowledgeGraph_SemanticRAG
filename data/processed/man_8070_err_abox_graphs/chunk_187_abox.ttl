@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarEjeC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar Eje C" ;
    ns1:solucionaFallo ns1:EjeCActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el eje C para ejecutar la función." .

ns1:NoSeAdmiteVelocidadDelCabezalNegativa_b68918bfba a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite velocidad del cabezal negativa" ;
    ns1:textoExtracto "'No se admite velocidad del cabezal negativa' DETECCIÓN Durante la ejecución." .

ns1:NumeroDeIndicesEnVariableDeArraySobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Número de índices en variable de array sobrepasado" ;
    ns1:textoExtracto "'Número de índices en variable de array sobrepasado' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario es un array multidimensional con más de 4 dimensiones." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Programación" ;
    ns1:solucionaFallo ns1:DeclaracionIncorrectaDeVariablesDeArray ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VerificarSintaxisVariable a ns1:TareaMantenimiento ;
    rdfs:label "Verificar Sintaxis Variable" ;
    ns1:solucionaFallo ns1:DimensionDeArrayIncorrecta ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable." .

ns1:DeclaracionIncorrectaDeVariablesDeArray a ns1:DiagnosticoFallo ;
    rdfs:label "Declaración incorrecta de variables de array" ;
    ns1:textoExtracto "'Declaración incorrecta de variables de array' DETECCIÓN Durante la ejecución. CAUSA Las variables de usuario que son array deben declararse entre las sentencias #VAR y #ENDVAR." .

ns1:DimensionDeArrayIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Dimensión de array incorrecta" ;
    ns1:textoExtracto "'Dimensión de array incorrecta' DETECCIÓN Durante la ejecución. CAUSA La variable es de array pero el número de arrays programados es incorrecto." .

ns1:EjeCActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Eje C activo" ;
    ns1:textoExtracto "'con eje C activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una función G33/G63/G95/G96/G97 con el eje C activo." .

