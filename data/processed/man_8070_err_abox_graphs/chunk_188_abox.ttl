@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacionDeInterpolacionCircular a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de interpolación circular" ;
    ns1:solucionaFallo ns1:NoSePermiteProgramarCentroYRadioDelCirculoSimultaneamente ;
    ns1:textoExtracto "SOLUCIÓN En una interpolación circular hay que programar las cotas del punto final y además el radio o el centro del círculo." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NoSeAdmiteVelocidadDelCabezalNegativa,
        ns1:NoSePermiteUnCambioDeGamaYMovimientoDelCabezalSimultaneos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NoSeAdmiteVelocidadDelCabezalNegativa a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite velocidad del cabezal negativa" ;
    ns1:textoExtracto "'No se admite velocidad del cabezal negativa'" .

ns1:NoSePermiteProgramarCentroYRadioDelCirculoSimultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite programar centro y radio del círculo simultáneamente" ;
    ns1:textoExtracto "'No se permite programar centro y radio del círculo simultáneamente'" .

ns1:NoSePermiteUnCambioDeGamaYMovimientoDelCabezalSimultaneos a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite un cambio de gama y movimiento del cabezal simultáneos" ;
    ns1:textoExtracto "'No se permite un cambio de gama y movimiento del cabezal simultáneos'" .

