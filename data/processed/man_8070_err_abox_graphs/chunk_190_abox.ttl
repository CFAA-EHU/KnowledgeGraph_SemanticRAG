@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "revisión de programación" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_3bb7d27e4a,
        ns1:ModoNoValidoHSC,
        ns1:SeEsperaM02M30 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisionDelManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "revisión del manual de programación" ;
    ns1:solucionaFallo ns1:DobleProgramacionHSC_0d05180f6d ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:DiagnosticoFallo_3bb7d27e4a a ns1:DiagnosticoFallo ;
    rdfs:label "parámetro incorrecto HSC" ;
    ns1:textoExtracto "'#HSC: parámetro incorrecto' DETECCIÓN Durante la ejecución. CAUSA El parámetro FAST o el parámetro CORNER de la sentencia #HSC tienen un valor incorrecto." .

ns1:DobleProgramacionHSC_0d05180f6d a ns1:DiagnosticoFallo ;
    rdfs:label "doble programación HSC" ;
    ns1:textoExtracto "'#HSC: doble programación' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque está programada la activación y desactivación del modo HSC." .

ns1:ModoNoValidoHSC a ns1:DiagnosticoFallo ;
    rdfs:label "modo no válido HSC" ;
    ns1:textoExtracto "'#HSC: modo no válido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el modo HSC con un parámetro desconocido o ha intentado cambiar el modo de trabajo sin desactivarlo previamente." .

ns1:SeEsperaM02M30 a ns1:DiagnosticoFallo ;
    rdfs:label "se espera M02/M30" ;
    ns1:textoExtracto "'Se espera M02/M30' DETECCIÓN Durante la ejecución. CAUSA Falta programar M02 o M30 al final del programa principal." .

