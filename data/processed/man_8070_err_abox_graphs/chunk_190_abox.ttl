@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1466
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1466: Programación inválida de G8 como segundo bloque de movimiento"@es ;
    ex:textoExtracto "No es posible tener ambas funciones activas simultáneamente. 1466 'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39'"@es ;
    ex:identificador "1466" .

ex:AvisoSeguridad_1467
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1467: Límite de POSLIMIT/NEGLIMIT excede parámetro máquina"@es ;
    ex:textoExtracto "1467 'POSLIMIT/NEGLIMIT no puede superar el valor del parámetro máquina'"@es ;
    ex:identificador "1467" .

ex:Parametro_POSLIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro máquina POSLIMIT"@es ;
    ex:textoExtracto "valor del parámetro máquina POSLIMIT"@es .

ex:Parametro_NEGLIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro máquina NEGLIMIT"@es ;
    ex:textoExtracto "valor del parámetro máquina NEGLIMIT"@es .

ex:AvisoSeguridad_1468
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1468: Origen polar incompleto en G30"@es ;
    ex:textoExtracto "1468 'G30: Programación incorrecta del origen polar'"@es ;
    ex:identificador "1468" .

ex:AvisoSeguridad_1469
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1469: Radio polar negativo o nulo"@es ;
    ex:textoExtracto "1469 'Radio negativo o nulo no permitido'"@es ;
    ex:identificador "1469" .

ex:Parametro_RadioPolar
    a ex:Parametro ;
    rdfs:label "Radio polar"@es ;
    ex:textoExtracto "radio polar"@es ;
    ex:valor ">0" .

ex:AvisoSeguridad_1470
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1470: Programación incremental inválida en eje rotativo UNIDIR"@es ;
    ex:textoExtracto "1470 'Eje rotativo UNIDIR con programación incremental incorrecta'"@es ;
    ex:identificador "1470" .

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "Parámetro UNIDIR (eje rotativo unidireccional)"@es ;
    ex:textoExtracto "parámetro UNIDIR"@es .