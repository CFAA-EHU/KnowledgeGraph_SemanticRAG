@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicarEnLaSentenciaCAXElNombreConElQueIdentificaraAlEjeC a ns1:TareaMantenimiento ;
    rdfs:label "Indicar en la sentencia #CAX el nombre con el que identificará al eje C" ;
    ns1:solucionaFallo ns1:NoSeHaDefinidoNombrePorDefectoParaElEjeC ;
    ns1:textoExtracto "SOLUCIÓN Indicar en la sentencia #CAX el nombre con el que identificará al eje C." .

ns1:ParametroCAxis a ns1:Parametro ;
    rdfs:label "Parámetro CAXIS" ;
    ns1:textoExtracto "parámetro CAXIS" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:EscrituraDeParametroConIndiceNoValido,
        ns1:FaltaProgramarM02OM30AlFinalDelProgramaPrincipal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EscrituraDeParametroConIndiceNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Escritura de parámetro con índice no válido" ;
    ns1:textoExtracto "'Escritura de parámetro con índice no válido'" .

ns1:FaltaProgramarM02OM30AlFinalDelProgramaPrincipal a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar M02 o M30 al final del programa principal" ;
    ns1:textoExtracto "'Se espera M17/M29/#RET'" .

ns1:NoSeHaDefinidoNombrePorDefectoParaElEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido nombre por defecto para el eje C" ;
    ns1:textoExtracto "'No se ha definido nombre por defecto para el eje C'" .

