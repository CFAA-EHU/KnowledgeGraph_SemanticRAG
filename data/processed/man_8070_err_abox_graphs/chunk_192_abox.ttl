@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacionYLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación y los parámetros máquina" ;
    ns1:solucionaFallo ns1:ElParametroAritmeticoNoExisteOEstaProtegidoContraEscritura ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." .

ns1:ElParametroAritmeticoNoExisteOEstaProtegidoContraEscritura a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro aritmético no existe o está protegido contra escritura" ;
    ns1:textoExtracto "CAUSA El parámetro aritmético no existe o está protegido contra escritura." .

