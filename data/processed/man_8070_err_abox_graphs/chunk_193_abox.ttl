@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1478
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo 1478: ángulo de entrada de herramienta incorrecto"@es ;
    ex:identificador "1478" ;
    ex:textoExtracto "'La cajera fue resuelta con diferente ángulo de entrada de herramienta'"@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Generar cajera con ángulo de entrada de herramienta incorrecto"@es ;
        ex:textoExtracto "El CNC generó la cajera con un ángulo de entrada de herramienta diferente al actual."@es
    ] ;
    ex:mitigaRiesgo [
        a ex:AvisoSeguridad ;
        rdfs:label "Revisión de parámetros de herramienta antes de ejecución"@es ;
        ex:textoExtracto "DETECCIÓN Durante la ejecución."@es
    ] .

ex:DiagnosticoFallo_1479
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo 1479: subrutina G74 no asociada"@es ;
    ex:identificador "1479" ;
    ex:textoExtracto "G74: falta asociar subrutina"@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Ejecutar ciclo G74 sin subrutina asociada"@es ;
        ex:textoExtracto "G74: falta asociar subrutina"@es
    ] ;
    ex:mitigaRiesgo [
        a ex:AvisoSeguridad ;
        rdfs:label "Verificación de asociación de subrutinas antes de ejecución"@es ;
        ex:textoExtracto "DETECCIÓN Durante la ejecución."@es
    ] .

ex:Parametro_AnguloEntradaHerramienta
    a ex:Parametro ;
    rdfs:label "Ángulo de entrada de herramienta"@es ;
    ex:textoExtracto "ángulo de entrada de herramienta"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1478 .

ex:Parametro_LongitudCorteHerramienta
    a ex:Parametro ;
    rdfs:label "Longitud de corte de herramienta"@es ;
    ex:textoExtracto "longitud de corte de herramienta"@es ;
    ex:monitoreaParametro [
        a ex:DiagnosticoFallo ;
        rdfs:label "Diagnóstico implícito: longitud de corte de herramienta incorrecta"@es ;
        ex:textoExtracto "El CNC generó la cajera con una longitud de corte de herramienta diferente a la actual."@es
    ] .