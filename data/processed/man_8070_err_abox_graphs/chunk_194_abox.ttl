@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1479
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "G74: falta asociar subrutina" ;
    ex:identificador      "1479" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA Hay programada una función G74 sola en el bloque y no existe la subrutina asociada. SOLUCIÓN Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB)." .

ex:Fallo_1480
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error sintaxis #EXEC" ;
    ex:identificador      "1480" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ex:Fallo_1481
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Número de canal no válido" ;
    ex:identificador      "1481" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT. SOLUCIÓN El número de canal debe estar comprendido entre 1 y 4." .

ex:Fallo_1483
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error sintaxis #WAIT/#MEET" ;
    ex:identificador      "1483" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ex:Fallo_1484
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Número de señal fuera de rango" ;
    ex:identificador      "1484" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA El número de señal programada en la sentencia #WAIT, #MEET o #SIGNAL no es correcto. SOLUCIÓN Revisar la programación." .

ex:Fallo_1485
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "#WAIT/#MEET no efectivo" ;
    ex:identificador      "1485" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución. CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias. SOLUCIÓN Revisar la programación." .

ex:Fallo_1486
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error sintaxis #SIGNAL" ;
    ex:identificador      "1486" ;
    ex:textoExtracto      "DETECCIÓN Durante la ejecución." .

ex:Fallo_Cajera
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Ángulo de entrada de herramienta incorrecto en cajera" ;
    ex:textoExtracto      "El CNC generó la cajera con un ángulo de entrada de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera." .