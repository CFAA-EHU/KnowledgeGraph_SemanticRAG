@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarEnElManualDeProgramacionLosParametrosObligatoriosYPermitidosPa_bd0e6c872d a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_6a68dd4a89,
        ns1:NoProgramadoParametroObligatorioEnCicloFijo ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:CicloFijoInexistente,
        ns1:CicloFijoMalProgramado ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:CicloFijoInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo fijo inexistente" ;
    ns1:textoExtracto "'Ciclo fijo inexistente' DETECCIÓN Durante la ejecución. CAUSA El ciclo fijo programado no existe." .

ns1:CicloFijoMalProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo fijo mal programado" ;
    ns1:textoExtracto "'Ciclo fijo mal programado' DETECCIÓN Durante la ejecución. CAUSA En el bloque de definición de un ciclo fijo, no se puede programar nada tras los parámetros del ciclo." .

ns1:DiagnosticoFallo_6a68dd4a89 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no permitido en ciclo fijo" ;
    ns1:textoExtracto "'Parámetro no permitido en ciclo fijo' DETECCIÓN Durante la ejecución. CAUSA Uno de los parámetros programados no está permitido para ese ciclo fijo." .

ns1:NoProgramadoParametroObligatorioEnCicloFijo a ns1:DiagnosticoFallo ;
    rdfs:label "No programado parámetro obligatorio en ciclo fijo" ;
    ns1:textoExtracto "'No programado parámetro obligatorio en ciclo fijo' DETECCIÓN Durante la ejecución. CAUSA Falta programar algún parámetro obligatorio del ciclo fijo." .

