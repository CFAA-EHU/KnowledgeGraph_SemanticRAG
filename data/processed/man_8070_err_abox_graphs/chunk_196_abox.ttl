@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarParametrosDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros de programación" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_65ebcb7b42,
        ns1:NoSeAdmiteModificarDYLaLongitudDeLaHerramientaEnElMismoBloque_308ccad4e3 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:NoSeAdmiteModificarDYLaLongitudDeLaHerramientaEnElMismoBloque_308ccad4e3 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SistemaCNC8070_135cf1dc42 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado escribir la variable 'V.G.TOL' en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

ns1:VariableDeToleranciaDeHerramienta a ns1:Parametro ;
    rdfs:label "Variable de tolerancia de herramienta" ;
    ns1:identificador "V.G.TOL" ;
    ns1:textoExtracto "El CNC ha intentado escribir la variable 'V.G.TOL' en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

ns1:DiagnosticoFallo_65ebcb7b42 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M no permitida con movimiento" ;
    ns1:textoExtracto "'Función M no permitida con movimiento'" .

ns1:NoSeAdmiteModificarDYLaLongitudDeLaHerramientaEnElMismoBloque_308ccad4e3 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite modificar D y la longitud de la herramienta en el mismo bloque" ;
    ns1:textoExtracto "'No se admite modificar D y la longitud de la herramienta en el mismo bloque'" .

