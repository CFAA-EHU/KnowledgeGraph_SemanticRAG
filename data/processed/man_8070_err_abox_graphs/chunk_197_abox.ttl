@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoSeAdmiteModificarDYLosOffsetsDeLaHerramientaEnElMismoBloque_1487b256e2 a ns1:AccionProhibida ;
    rdfs:label "No se admite modificar D y los offsets de la herramienta en el mismo bloque" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'No se admite modificar D y los offsets de la herramienta en el mismo bloque'" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElCNCHaIntentadoEscribirLaVariableVGTOFLXnEnElMismoBloqueEnElQueSeHaP_baab3b2a26 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElCNCHaIntentadoEscribirLaVariableVGTOFLXnEnElMismoBloqueEnElQueSeHaP_baab3b2a26 a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentado escribir la variable 'V.G.TOFL.xn' en el mismo bloque en el que se ha programado un cambio de herramienta o corrector" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

