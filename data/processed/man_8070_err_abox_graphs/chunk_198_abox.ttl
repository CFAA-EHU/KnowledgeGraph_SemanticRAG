@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarFuncionesGIncompatiblesEnElMismoBloque a ns1:AccionProhibida ;
    rdfs:label "Programar funciones G incompatibles en el mismo bloque" ;
    ns1:textoExtracto "SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FuncionesGIncompatiblesG10G11G12G13G14,
        ns1:LimiteDeFuncionesMEnUnMismoBloqueSobrepasado,
        ns1:NoSeAdmitenMasFuncionesH ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VariableDeCambioDeHerramientaOCorrector a ns1:Parametro ;
    rdfs:label "Variable de cambio de herramienta o corrector" ;
    ns1:identificador "V.G.TOFL.xn" ;
    ns1:textoExtracto "escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

ns1:FuncionesGIncompatiblesG10G11G12G13G14 a ns1:DiagnosticoFallo ;
    rdfs:label "'Funciones G incompatibles (G10/G11/G12/G13/G14)'" ;
    ns1:textoExtracto "1389 'Funciones G incompatibles (G10/G11/G12/G13/G14)' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí." .

ns1:LimiteDeFuncionesMEnUnMismoBloqueSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "'Límite de funciones M en un mismo bloque sobrepasado'" ;
    ns1:textoExtracto "1387 'Límite de funciones M en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones M de las permitidas." .

ns1:NoSeAdmitenMasFuncionesH a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admiten más funciones H'" ;
    ns1:textoExtracto "1388 'No se admiten más funciones H' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones H de las permitidas." .

