@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarLaHerramientaDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la herramienta del cabezal" ;
    ns1:solucionaFallo ns1:AccionProhibida_5c8f355f61 ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la herramienta del cabezal para que coincida con la programada." .

ns1:NoExisteLaSubrutinaAsociadaALaFuncionG a ns1:DiagnosticoFallo ;
    rdfs:label "No existe la subrutina asociada a la función G" ;
    ns1:textoExtracto "'No existe la subrutina asociada a la función G'" .

ns1:AccionProhibida_5c8f355f61 a ns1:AccionProhibida ;
    rdfs:label "Herramienta incorrecta en el cabezal" ;
    ns1:textoExtracto "Si la herramienta que hay en el cabezal es distinta y en el programa no está compensando el radio de la herramienta, el CNC va a mecanizar una pieza distinta." .

