@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarHerramientaDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar herramienta del cabezal" ;
    ns1:solucionaFallo ns1:CambioDeHerramientaIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la herramienta del cabezal para que coincida con la programada." .

ns1:RevisarLaProgramacionDeFuncionesYSubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de funciones y subrutinas" ;
    ns1:solucionaFallo ns1:LaFuncionG74ConSubrutinaAsociadaSeProgramaSolaEnElBloque,
        ns1:NoExisteLaSubrutinaAsociadaALaFuncionG ;
    ns1:textoExtracto "SOLUCIÓN Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB). Para las funciones G180 a G189 definir la subrutina asociada (parámetro OEMSUB). Revisar la programación." .

ns1:SubrutinaDeReferenciaParaG74 a ns1:Parametro ;
    rdfs:label "Subrutina de referencia para G74" ;
    ns1:textoExtracto "(parámetro REFPSUB)" .

ns1:SubrutinaOEMParaFuncionesG180G189 a ns1:Parametro ;
    rdfs:label "Subrutina OEM para funciones G180-G189" ;
    ns1:textoExtracto "(parámetro OEMSUB)" .

ns1:CambioDeHerramientaIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Cambio de herramienta incorrecto" ;
    ns1:textoExtracto "de la herramienta, el CNC va a mecanizar una pieza distinta." .

ns1:LaFuncionG74ConSubrutinaAsociadaSeProgramaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La función G74 con subrutina asociada se programa sola en el bloque" ;
    ns1:textoExtracto "'La función G74 con subrutina asociada se programa sola en el bloque'" .

ns1:NoExisteLaSubrutinaAsociadaALaFuncionG a ns1:DiagnosticoFallo ;
    rdfs:label "No existe la subrutina asociada a la función G" ;
    ns1:textoExtracto "'No existe la subrutina asociada a la función G'" .

