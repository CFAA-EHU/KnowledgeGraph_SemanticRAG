@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorLecturaHerramienta_1512
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1512: Lectura de herramienta en posición inválida" ;
    ex:textoExtracto "CAUSA: El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe. SOLUCIÓN: Sólo es posible leer la herramienta que está en una posición válida del almacén." ;
    ex:identificador "1512" .

ex:ErrorEscrituraVariable_1513
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1513: Error en la escritura de la variable" ;
    ex:textoExtracto "1513 'Error en la escritura de la variable' DETECCIÓN: Durante la ejecución. CAUSA: Las posibles causas son las siguientes: • La variable no existe. • La" ;
    ex:identificador "1513" .

ex:Variable_VTM_T
    a               ex:Parametro ;
    rdfs:label      "Variable V.TM.T" ;
    ex:textoExtracto "la variable V.TM.T" ;
    ex:identificador "V.TM.T" .

ex:ErrorLecturaHerramienta_1512
    ex:monitoreaParametro ex:Variable_VTM_T .