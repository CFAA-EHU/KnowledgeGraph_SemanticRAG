@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1518 a ex:Alarma ;
    rdfs:label "1518 'NR exige programar movimiento en el bloque'"@es ;
    ex:textoExtracto "1518 'NR exige programar movimiento en el bloque' DETECCIÓN Durante la ejecución. CAUSA Hay programada una repetición de bloques (NR) en un bloque que no implica movimiento. SOLUCIÓN La programación de la repetición de bloques con NR solo es válida con bloques que implican movimiento."@es ;
    ex:identificador "1518" .

ex:AccionProhibida_NR_SinMovimiento a ex:AccionProhibida ;
    rdfs:label "Repetición de bloques (NR) sin movimiento"@es ;
    ex:textoExtracto "Hay programada una repetición de bloques (NR) en un bloque que no implica movimiento. La programación de la repetición de bloques con NR solo es válida con bloques que implican movimiento."@es ;
    ex:activaAlarma ex:Alarma_1518 .

ex:AvisoSeguridad_ProgramacionNR a ex:AvisoSeguridad ;
    rdfs:label "Validación de programación NR"@es ;
    ex:textoExtracto "La repetición de otro tipo de bloques deberá hacerse mediante las instrucciones de control de flujo que ofrece"@es ;
    ex:mitigaRiesgo ex:AccionProhibida_NR_SinMovimiento .