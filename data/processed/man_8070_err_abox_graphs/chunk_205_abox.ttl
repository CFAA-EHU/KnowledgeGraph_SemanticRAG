@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9cd6394a14 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso sobre velocidad superior a la máxima" ;
    ns1:mitigaRiesgo ns1:ProgramarUnaVelocidadSuperiorALaMaxima ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal.'" .

ns1:CambioDeGamaAutomaticoDelCabezal a ns1:Parametro ;
    rdfs:label "Cambio de gama automático del cabezal" ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "'El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal.'" .

ns1:NumeroDeGamasDisponiblesEnElCabezal a ns1:Parametro ;
    rdfs:label "Número de gamas disponibles en el cabezal" ;
    ns1:identificador "NPARSETS" ;
    ns1:textoExtracto "'El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS).'" .

ns1:ProgramarUnaVelocidadCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Programar una velocidad correcta" ;
    ns1:solucionaFallo ns1:ProgramarUnaVelocidadSuperiorALaMaxima ;
    ns1:textoExtracto "'SOLUCIÓN Programar una'" .

ns1:ProgramarUnaVelocidadSuperiorALaMaxima a ns1:AccionProhibida ;
    rdfs:label "Programar una velocidad superior a la máxima" ;
    ns1:textoExtracto "'CAUSA El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal.'" .

