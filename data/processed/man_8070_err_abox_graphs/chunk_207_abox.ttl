@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnidamientoDeFuncionesTConSubrutinaNoPermitido a ns1:AccionProhibida ;
    rdfs:label "'Anidamiento de funciones T con subrutina no permitido'" ;
    ns1:textoExtracto "1409 'Anidamiento de funciones T con subrutina no permitido'" .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "CAUSA El CNC no puede ejecutar la función o sentencia programada si el cabezal no está controlado en posición." .

ns1:EsNecesarioQueHayaEncoderEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Es necesario que haya encoder en el cabezal" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaSiNoHayEncoderEnElCabezal ;
    ns1:textoExtracto "SOLUCIÓN Es necesario que haya encoder en el cabezal." .

ns1:VolverAEditarLaCajeraConElEditorDeCiclos a ns1:TareaMantenimiento ;
    rdfs:label "Volver a editar la cajera con el editor de ciclos" ;
    ns1:solucionaFallo ns1:AlEjecutarUnaCajera2DO3DElCNCNoHaPodidoDecodificarAlgunoDeLosDatos ;
    ns1:textoExtracto "SOLUCIÓN Volver a editar la cajera con el editor de ciclos." .

ns1:AlEjecutarUnaCajera2DO3DElCNCNoHaPodidoDecodificarAlgunoDeLosDatos a ns1:DiagnosticoFallo ;
    rdfs:label "Al ejecutar una cajera 2D ó 3D, el CNC no ha podido decodificar alguno de los datos" ;
    ns1:textoExtracto "CAUSA Al ejecutar una cajera 2D ó 3D, el CNC no ha podido decodificar alguno de los datos." .

ns1:ProgramacionNoPermitidaSiNoHayEncoderEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida si no hay encoder en el cabezal" ;
    ns1:textoExtracto "1408 G63/G74/M19/CAX: Programación no permitida si no hay encóder en el cabezal." .

