@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1530
    a               ex:Alarma ;
    ex:identificador "1530" ;
    rdfs:label      "No se permite programar G53 con coordenadas polares"@es ;
    ex:textoExtracto "1530 'No se permite programar G53 con coordenadas polares' DETECCIÓN Durante la ejecución. CAUSA En la función G53, las cotas del punto final están definidas en coordenadas polares o cilíndricas. SOLUCIÓN Programando respecto al cero máquina solo se pueden definir las cotas en coordenadas cartesianas."@es .

ex:Alarma_1531
    a               ex:Alarma ;
    ex:identificador "1531" ;
    rdfs:label      "Programar: #EXBLK [bloque, canal]"@es ;
    ex:textoExtracto "1531 'Programar: #EXBLK [bloque, canal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más"@es .