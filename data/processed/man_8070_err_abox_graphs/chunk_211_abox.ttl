@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_CabezalNoLiberado_1539
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Fallo: Cabezal no liberado (código 1539)"@es ;
    ex:textoExtracto    "Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es ;
    ex:identificador    "1539" ;
    ex:solucionaFallo   ex:Accion_LiberacionCabezal_1539 .

ex:Accion_LiberacionCabezal_1539
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Liberación explícita de cabezal con #FREE SP"@es ;
    ex:textoExtracto    "El otro canal cederá el cabezal con reset o con el inicio de otro programa. También es posible programar explícitamente la liberación del cabezal con la sentencia #FREE SP."@es .

ex:Parametro_AXISEXCH
    a                   ex:Parametro ;
    rdfs:label          "Parámetro AXISEXCH (permiso de cambio temporal de cabezal)"@es ;
    ex:textoExtracto    "parámetro AXISEXCH"@es ;
    ex:identificador    "AXISEXCH" .