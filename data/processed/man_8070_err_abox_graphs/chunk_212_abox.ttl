@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1539
    a ex:Alarma ;
    rdfs:label "Alarma 1539: Nombre de cabezal repetido en el grupo resultante"@es ;
    ex:textoExtracto "1539 'Nombre de cabezal repetido en el grupo resultante' DETECCIÓN Durante la ejecución. CAUSA La sentencia #RENAME ha intentado renombrar más de un cabezal con el mismo nombre. SOLUCIÓN Renombrar los cabezales de forma que en el canal no haya dos con el mismo nombre."@es ;
    ex:identificador "1539" .

ex:Alarma_1540
    a ex:Alarma ;
    rdfs:label "Alarma 1540: Programación no permitida sin cabezal master en el canal"@es ;
    ex:textoExtracto "1540 'Programación no permitida sin cabezal master en el canal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El CNC intenta leer o escribir una variable del cabezal master y éste no existe en el canal. • La función G o sentencia no se puede ejecutar si en el canal no existe un cabezal master. SOLUCIÓN Definir un cabezal master para el canal."@es ;
    ex:identificador "1540" .

ex:Alarma_1541
    a ex:Alarma ;
    rdfs:label "Alarma 1541: No está permitido eliminar el cabezal con eje C activo"@es ;
    ex:textoExtracto "1541 'No está permitido eliminar el cabezal con eje C activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado eliminar del canal (#FREE o #SET) un cabezal que está trabajando como eje C. SOLUCIÓN Antes de eliminar el cabezal del canal desactivar el eje C."@es ;
    ex:identificador "1541" .

ex:Alarma_1542
    a ex:Alarma ;
    rdfs:label "Alarma 1542: No está permitido intercambiar el cabezal"@es ;
    ex:textoExtracto "1542 'No está permitido intercambiar el cabezal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar un cabezal de canal (#CALL, #SET o #FREE) y el cabezal no tiene permiso de cambio (parámetro AXISEXCH). SOLUCIÓN Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso. El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC."@es ;
    ex:identificador "1542" .

ex:Parametro_AXISEXCH
    a ex:Parametro ;
    rdfs:label "Parámetro AXISEXCH: Permiso de intercambio de ejes/cabezales"@es ;
    ex:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC."@es ;
    ex:identificador "AXISEXCH" .

ex:AvisoSeguridad_1539_Solucion
    a ex:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1539: Renombrar cabezales únicos en el canal"@es ;
    ex:textoExtracto "Renombrar los cabezales de forma que en el canal no haya dos con el mismo nombre."@es ;
    ex:solucionaFallo ex:Alarma_1539 .

ex:AvisoSeguridad_1540_Solucion
    a ex:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1540: Definir cabezal master en el canal"@es ;
    ex:textoExtracto "Definir un cabezal master para el canal."@es ;
    ex:solucionaFallo ex:Alarma_1540 .

ex:AvisoSeguridad_1541_Solucion
    a ex:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1541: Desactivar eje C antes de eliminar cabezal"@es ;
    ex:textoExtracto "Antes de eliminar el cabezal del canal desactivar el eje C."@es ;
    ex:solucionaFallo ex:Alarma_1541 .

ex:AvisoSeguridad_1542_Solucion
    a ex:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1542: Configurar permiso AXISEXCH para intercambio"@es ;
    ex:textoExtracto "Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso. El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente."@es ;
    ex:solucionaFallo ex:Alarma_1542 ;
    ex:monitoreaParametro ex:Parametro_AXISEXCH .