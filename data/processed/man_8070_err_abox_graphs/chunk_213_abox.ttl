@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AXISEXCH
    a ex:Parametro ;
    rdfs:label "Parámetro AXISEXCH" ;
    ex:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC." ;
    ex:identificador "AXISEXCH" .

ex:AvisoSeguridad_1544
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1544" ;
    ex:textoExtracto "'No se admite G63 y M3/M4/M5/M19/M41-M44 en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA No se permite ninguna función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63. SOLUCIÓN Se puede hacer en el bloque anterior o posterior según el resultado que se quiera" ;
    ex:identificador "1544" .