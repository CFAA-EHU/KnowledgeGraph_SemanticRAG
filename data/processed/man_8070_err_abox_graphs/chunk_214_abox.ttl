@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GenerarDeNuevoLaCajera a ns1:TareaMantenimiento ;
    rdfs:label "Generar de nuevo la cajera" ;
    ns1:textoExtracto "SOLUCIÓN Generar de nuevo la cajera." .

ns1:LimiteDeSubrutinasEnUnMismoBloqueSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de subrutinas en un mismo bloque sobrepasado" ;
    ns1:textoExtracto "'Límite de subrutinas en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque." .

ns1:ProgramarLasCotasDeLosEjesAntesDeLaFuncionGDelCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Programar las cotas de los ejes antes de la función G del ciclo" ;
    ns1:solucionaFallo ns1:ElMovimientoEnElPlanoPrincipalDebeProgramarseAntesDeLaGDelCiclo ;
    ns1:textoExtracto "SOLUCIÓN Programar las cotas de los ejes antes de la función G del ciclo." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:EjeMalProgramado_62b50f262b ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EjeMalProgramado_62b50f262b a ns1:DiagnosticoFallo ;
    rdfs:label "Eje mal programado" ;
    ns1:textoExtracto "'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema." .

ns1:ElMovimientoEnElPlanoPrincipalDebeProgramarseAntesDeLaGDelCiclo a ns1:DiagnosticoFallo ;
    rdfs:label "El movimiento en el plano principal debe programarse antes de la G del ciclo" ;
    ns1:textoExtracto "'El movimiento en el plano principal debe programarse antes de la G del ciclo' DETECCIÓN Durante la ejecución. CAUSA Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo." .

