@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación"@es ;
    ns1:solucionaFallo ns1:FormatoNumericoSobrepasado,
        ns1:NoSePuedeProgramarUnEjeEsclavoDeUnAcoploOGantry,
        ns1:PosicionDeCabezalEnM19NoValida,
        ns1:SeHaSuperadoElMaximoNumeroDeSubrutinasQueSePuedenEjecutarEnUnMismoBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:FormatoNumericoSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "'Formato numérico sobrepasado'"@es ;
    ns1:textoExtracto "1430 'Formato numérico sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El valor asignado a un dato, variable o parámetro es superior al formato establecido. SOLUCIÓN Revisar la programación." .

ns1:NoSePuedeProgramarUnEjeEsclavoDeUnAcoploOGantry a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede programar un eje esclavo de un acoplo o Gantry'"@es ;
    ns1:textoExtracto "1432 'No se puede programar un eje esclavo de un acoplo o Gantry' DETECCIÓN Durante la ejecución. CAUSA En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." .

ns1:PosicionDeCabezalEnM19NoValida a ns1:DiagnosticoFallo ;
    rdfs:label "'Posición de cabezal en M19 no válida'"@es ;
    ns1:textoExtracto "1431 'Posición de cabezal en M19 no válida' DETECCIÓN Durante la ejecución. CAUSA El valor programado para la posición de cabezal en M19 es demasiado alto. SOLUCIÓN Programar un valor más pequeño." .

ns1:SeHaSuperadoElMaximoNumeroDeSubrutinasQueSePuedenEjecutarEnUnMismoBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque."@es ;
    ns1:textoExtracto "CAUSA Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque. SOLUCIÓN El máximo número de subrutinas que se pueden ejecutar en un mismo bloque es 5. Programar las subrutinas en bloques diferentes o utilizar la imbricación de subrutinas, según interese." .

