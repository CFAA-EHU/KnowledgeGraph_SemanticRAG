@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarAcoploActivo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar acoplo activo" ;
    ns1:solucionaFallo ns1:NoSePuedeModificarLaConfiguracionDeUnEjeAparcado ;
    ns1:textoExtracto "SOLUCIÓN Para poder operar con el eje en esas sentencias es necesario desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)." .

ns1:DeshacerParejaGantry a ns1:Parametro ;
    rdfs:label "Deshacer pareja Gantry" ;
    ns1:textoExtracto "SOLUCIÓN Para poder operar con el eje en esas sentencias es necesario desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)." .

ns1:NoSePuedeModificarLaConfiguracionDeUnEjeAparcado a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede modificar la configuración de un eje aparcado" ;
    ns1:textoExtracto "CAUSA En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." .

