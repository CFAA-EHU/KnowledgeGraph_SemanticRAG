@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1549
    a                     ex:Alarma ;
    rdfs:label            "Alarma 1549: Nombre de cajera nulo o incorrecto" ;
    ex:identificador      "1549" ;
    ex:textoExtracto      "1549 'Nombre de cajera nulo o incorrecto' [...] CAUSA Cuando se ha definido una cajera 2D ó 3D con el editor de ciclos, no se ha definido el nombre de la cajera o este nombre es incorrecto."@es .

ex:Alarma_1550
    a                     ex:Alarma ;
    rdfs:label            "Alarma 1550: No se admite programar dos ejes C en el mismo canal" ;
    ex:identificador      "1550" ;
    ex:textoExtracto      "1550 'No se admite programar dos ejes C en el mismo canal' [...] CAUSA El CNC ha intentado activar un eje C con otro activo."@es .

ex:Alarma_1551
    a                     ex:Alarma ;
    rdfs:label            "Alarma 1551: Imbricación de parámetros locales sobrepasado" ;
    ex:identificador      "1551" ;
    ex:textoExtracto      "1551 'Imbricación de parámetros locales sobrepasado' [...] CAUSA El anidamiento de llamadas a subrutinas [...] supera el máximo nivel de imbricación de parámetros locales que es 7."@es .

ex:Alarma_1552
    a                     ex:Alarma ;
    rdfs:label            "Alarma 1552: El nombre de la variable debe comenzar por 'V.'" ;
    ex:identificador      "1552" ;
    ex:textoExtracto      "1552 'El nombre de la variable debe comenzar por \"V.\"' [...] CAUSA Desde programa pieza o MDI se ha escrito el nombre de una variable sin el prefijo inicial 'V.'."@es .

ex:Alarma_1553
    a                     ex:Alarma ;
    rdfs:label            "Alarma 1553: Número de variables de usuario sobrepasado" ;
    ex:identificador      "1553" ;
    ex:textoExtracto      "1553 'Número de variables de usuario sobrepasado' [...] CAUSA El CNC ha superado el máximo número de variables de usuario (prefijos P y S) permitidas."@es .

ex:Parametro_MaxNivelImbricacion
    a                     ex:Parametro ;
    rdfs:label            "Máximo nivel de imbricación de parámetros locales" ;
    ex:valor               "7" ;
    ex:textoExtracto       "El error se da porque se supera el máximo nivel de imbricación de parámetros locales que es 7."@es .

ex:Parametro_MaxVariablesUsuario
    a                     ex:Parametro ;
    rdfs:label            "Máximo número de variables de usuario permitidas" ;
    ex:valor               "20" ;
    ex:textoExtracto       "El máximo número de variables de usuario permitido es 20."@es .

ex:Alarma_1549
    ex:solucionaFallo      ex:AccionProhibida_CederCabezalConG63_G96Activos .

ex:AccionProhibida_CederCabezalConG63_G96Activos
    a                     ex:AccionProhibida ;
    rdfs:label            "Ceder cabezal con G63 o G96 activos" ;
    ex:textoExtracto      "este cabezal mientras las funciones estén activas. SOLUCIÓN Desactivar G63 o G96 antes ceder el cabezal."@es .