@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarNombreRepetidoAUnEjeEsclavo a ns1:AccionProhibida ;
    rdfs:label "Asignar nombre repetido a un eje esclavo" ;
    ns1:mitigaRiesgo ns1:CNC8070_3f06003895 ;
    ns1:textoExtracto "El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry." .

ns1:DesactivarAcoploActivo_41bb6ad98a a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar acoplo activo" ;
    ns1:solucionaFallo ns1:NoSeHaPodidoIncluirEnLaConfiguracionUnEjeEsclavoAsociado,
        ns1:NoSePuedeModificarLaConfiguracionDeUnEjeAparcado_1a081f0ef9 ;
    ns1:textoExtracto "desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry." .

ns1:DesactivarAcoploActivo_634115cda4 a ns1:AccionProhibida ;
    rdfs:label "Desactivar acoplo activo" ;
    ns1:mitigaRiesgo ns1:CNC8070_3f06003895 ;
    ns1:textoExtracto "es necesario desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)." .

ns1:IncluirEjeEsclavoEnLasTresPosicionesPrincipalesDelCanal a ns1:AccionProhibida ;
    rdfs:label "Incluir eje esclavo en las tres posiciones principales del canal" ;
    ns1:mitigaRiesgo ns1:CNC8070_3f06003895 ;
    ns1:textoExtracto "El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry." .

ns1:RenombrarEjeEsclavo_0b971bccf6 a ns1:TareaMantenimiento ;
    rdfs:label "Renombrar eje esclavo" ;
    ns1:solucionaFallo ns1:NoSeHaPodidoAsignarNombreAUnEjeEsclavoAsociadoPorEstarRepetido ;
    ns1:textoExtracto "Renombrar el eje esclavo a incluir o el ya existente en la configuración." .

ns1:NoSeHaPodidoAsignarNombreAUnEjeEsclavoAsociadoPorEstarRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "'No se ha podido asignar nombre a un eje esclavo asociado por estar repetido'" ;
    ns1:textoExtracto "1435 'No se ha podido asignar nombre a un eje esclavo asociado por estar repetido'." .

ns1:NoSeHaPodidoIncluirEnLaConfiguracionUnEjeEsclavoAsociado a ns1:DiagnosticoFallo ;
    rdfs:label "'No se ha podido incluir en la configuración un eje esclavo asociado'" ;
    ns1:textoExtracto "1434 'No se ha podido incluir en la configuración un eje esclavo asociado'." .

ns1:NoSePuedeModificarLaConfiguracionDeUnEjeAparcado_1a081f0ef9 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede modificar la configuración de un eje aparcado" ;
    ns1:textoExtracto "1433 No se puede modificar la configuración de un eje aparcado." .

ns1:CNC8070_3f06003895 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado." .

