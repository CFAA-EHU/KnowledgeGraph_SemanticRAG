@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirBloqueDeParadaParaBusquedaDeBloque a ns1:TareaMantenimiento ;
    rdfs:label "Definir bloque de parada para búsqueda de bloque" ;
    ns1:solucionaFallo ns1:ErrorPorFaltaDeBloqueDeParadaEnBusquedaDeBloque ;
    ns1:textoExtracto "SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en" .

ns1:RenombrarEjeEsclavo a ns1:TareaMantenimiento ;
    rdfs:label "Renombrar eje esclavo" ;
    ns1:solucionaFallo ns1:ErrorPorNombreDelEjeEsclavoOcupado ;
    ns1:textoExtracto "SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración." .

ns1:ErrorPorFaltaDeBloqueDeParadaEnBusquedaDeBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Error por falta de bloque de parada en búsqueda de bloque" ;
    ns1:textoExtracto "'No se ha programado bloque de parada en búsqueda de bloque'" .

ns1:ErrorPorNombreDelEjeEsclavoOcupado a ns1:DiagnosticoFallo ;
    rdfs:label "Error por nombre del eje esclavo ocupado" ;
    ns1:textoExtracto "El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal." .

