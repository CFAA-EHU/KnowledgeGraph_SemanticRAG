@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2ddc728234 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de definición de bloque de parada" ;
    ns1:mitigaRiesgo ns1:DefinirBloqueDeParada ;
    ns1:textoExtracto "SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en el menú de softkeys aparece la opción para seleccionar el bloque parada. Seleccionar el bloque en el que se desea finalizar la búsqueda de bloque." .

ns1:AvisoSeguridad_9c35621702 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de herramienta o filo no válido" ;
    ns1:mitigaRiesgo ns1:UsarHerramientaOFiloNoValido ;
    ns1:textoExtracto "" .

ns1:AvisoSeguridad_e59befde98 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de transformación con eje Hirth" ;
    ns1:mitigaRiesgo ns1:ActivarTransformacionConEjeHirth ;
    ns1:textoExtracto "SOLUCIÓN Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)." .

ns1:ActivarTransformacionConEjeHirth a ns1:AccionProhibida ;
    rdfs:label "Activar transformación con eje Hirth" ;
    ns1:textoExtracto "'Los ejes de la transformación activa no pueden ser Hirth' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación de coordenadas y uno de los ejes que intervienen en la transformación es Hirth." .

ns1:DefinirBloqueDeParada a ns1:AccionProhibida ;
    rdfs:label "Definir bloque de parada" ;
    ns1:textoExtracto "'de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque." .

ns1:UsarHerramientaOFiloNoValido a ns1:AccionProhibida ;
    rdfs:label "Usar herramienta o filo no válido" ;
    ns1:textoExtracto "'Herramienta o filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta y/o corrector indicado en la variable no existe." .

