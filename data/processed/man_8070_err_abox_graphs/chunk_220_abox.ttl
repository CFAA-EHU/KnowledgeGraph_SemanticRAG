@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobacionDeCinematica a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de cinemática" ;
    ns1:solucionaFallo ns1:FalloCinematicaDesactivada,
        ns1:FalloCinematicaNoActivada ;
    ns1:textoExtracto "'Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal.'" .

ns1:RevisionDeProgramacion_fecd4a41c1 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_011d381c67,
        ns1:FalloCinematicaNoActivada ;
    ns1:textoExtracto "'Revisar la programación. Consultar las herramientas y correctores existentes.'" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "'Durante el arranque del CNC o la validación de los parámetros máquina.'" .

ns1:AvisoSeguridad_011d381c67 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de herramienta inexistente" ;
    ns1:textoExtracto "'La herramienta y/o corrector indicado en la variable no existe. Revisar la programación.'" .

ns1:FalloCinematicaDesactivada a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha desactivado la cinemática" ;
    ns1:identificador "1442" ;
    ns1:textoExtracto "'Se ha desactivado la cinemática'" .

ns1:FalloCinematicaNoActivada a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha activado la cinemática" ;
    ns1:identificador "1441" ;
    ns1:textoExtracto "'No se ha activado la cinemática'" .

