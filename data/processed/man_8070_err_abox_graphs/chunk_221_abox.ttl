@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1567
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1567: Radio polar programado incorrectamente" ;
    ex:identificador "1567" ;
    ex:textoExtracto "'El radio polar sólo se puede programar con R' DETECCIÓN Durante la ejecución. CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263. SOLUCIÓN Programar el radio polar con el parámetro R." ;
    ex:solucionaFallo ex:Parametro_R .

ex:Parametro_R
    a ex:Parametro ;
    rdfs:label "Parámetro R (radio polar)" ;
    ex:textoExtracto "Programar el radio polar con el parámetro R" ;
    ex:valor "R" .

ex:DiagnosticoFallo_1568
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1568: Número de almacén incorrecto" ;
    ex:identificador "1568" ;
    ex:textoExtracto "'Número de almacén incorrecto' DETECCIÓN Durante la ejecución. CAUSA El número de almacén programado en el comando MZ no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4." .

ex:DiagnosticoFallo_1569
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1569: Ejecución no permitida en canal exclusivo de PLC" ;
    ex:identificador "1569" ;
    ex:textoExtracto "'Ejecución no permitida, el canal es exclusivo de PLC' DETECCIÓN Durante la ejecución." .

ex:Parametro_R1
    a ex:Parametro ;
    rdfs:label "Parámetro R1 (radio polar inválido)" ;
    ex:textoExtracto "El radio de un movimiento en coordenadas polares está programado con el parámetro R1" ;
    ex:valor "R1" .

ex:Comando_MZ
    a ex:Parametro ;
    rdfs:label "Comando MZ (número de almacén)" ;
    ex:textoExtracto "El número de almacén programado en el comando MZ no es válido" ;
    ex:valor "MZ" .