@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_42d9242a1a a ns1:AccionProhibida ;
    rdfs:label "Aviso de Desactivación #CS/ACS" ;
    ns1:mitigaRiesgo ns1:FalloDesactivacionCSACS ;
    ns1:textoExtracto "'Se ha desactivado #CS/ACS' DETECCIÓN Tras un reset del CNC, al iniciar la ejecución de un programa pieza o durante la búsqueda de referencia." .

ns1:AccionProhibida_86fd764f91 a ns1:AccionProhibida ;
    rdfs:label "Aviso de Cinemática Incorrecta" ;
    ns1:mitigaRiesgo ns1:FalloCinematicaIncorrecta ;
    ns1:textoExtracto "para esa cinemática no son los adecuados. SOLUCIÓN Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal." .

ns1:TareaMantenimiento_047baccc17 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea Solución Desactivación #CS/ACS" ;
    ns1:solucionaFallo ns1:FalloDesactivacionCSACS ;
    ns1:textoExtracto "Para ejecutar una búsqueda de referencia hay que desactivar las funciones #CS/ACS." .

ns1:TareaSolucionCinematicaIncorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Tarea Solución Cinemática Incorrecta" ;
    ns1:solucionaFallo ns1:FalloCinematicaIncorrecta ;
    ns1:textoExtracto "Los tres primeros ejes del canal deben estar definidos, ser lineales, no estar aparcados y no ser esclavos de un acoplo o de un gantry." .

ns1:FalloCinematicaIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo Cinemática Incorrecta" ;
    ns1:textoExtracto "Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry." .

ns1:FalloDesactivacionCSACS a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo Desactivación #CS/ACS" ;
    ns1:textoExtracto "El CNC ha intentado hacer una búsqueda de referencia con la función #CS/ACS activa." .

