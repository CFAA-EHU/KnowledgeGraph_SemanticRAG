@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:CodigoError_1574
    a               ex:AvisoSeguridad ;
    ex:identificador "1574" ;
    rdfs:label      "Parámetro no modificable desde el oscilo"@es ;
    ex:textoExtracto "1574 'Parámetro no modificable desde el oscilo' [...] El usuario ha intentado modificar desde la pantalla del osciloscopio un parámetro máquina que no tiene permiso de escritura. Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina."@es .

ex:CodigoError_1575
    a               ex:AvisoSeguridad ;
    ex:identificador "1575" ;
    rdfs:label      "Sentencia sólo válida en programas con extensión FBS"@es ;
    ex:textoExtracto "1575 'Sentencia sólo válida en programas con extensión FBS' [...]"@es .

ex:ParametroMaquina_NoModificableDesdeOscilo
    a               ex:Parametro ;
    ex:textoExtracto "parámetro máquina que no tiene permiso de escritura [...] Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina"@es ;
    ex:monitoreaParametro ex:InterfazUsuario_Osciloscopio .

ex:InterfazUsuario_Osciloscopio
    a               ex:InterfazUsuario ;
    ex:textoExtracto "pantalla del osciloscopio"@es ;
    ex:mitigaRiesgo  ex:CodigoError_1574 .

ex:TablaParametrosMaquina a ex:Tabla ;
     a               ex:Tabla ;
    ex:textoExtracto "tabla de parámetros máquina"@es ;
    ex:documentadoEn ex:Manual_Principal .