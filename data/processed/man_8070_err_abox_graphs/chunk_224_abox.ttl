@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SeleccionDeOpcionDeSoftwareNoPermitida a ns1:AccionProhibida ;
    rdfs:label "Selección de opción de software no permitida" ;
    ns1:solucionaFallo ns1:CausaReguladorMDU,
        ns1:FalloOpcionSoftwareNoPermitida ;
    ns1:textoExtracto "'Opción de software no permitida'" .

ns1:SeleccionDeOtroBloqueInicial a ns1:TareaMantenimiento ;
    rdfs:label "Selección de otro bloque inicial" ;
    ns1:textoExtracto "Solución Seleccionar otro bloque inicial." .

ns1:CausaReguladorMDU a ns1:DiagnosticoFallo ;
    rdfs:label "Regulador MDU superando 550 Hz" ;
    ns1:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED." .

ns1:FalloOpcionSoftwareNoPermitida a ns1:DiagnosticoFallo ;
    rdfs:label "Opción de software no permitida" ;
    ns1:textoExtracto "'Opción de software no permitida'" .

