@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_1575
    a ex:Parametro ;
    rdfs:label "Parámetro de validación de sentencias SPLINE/BSPLINE"@es ;
    ex:identificador "1575" ;
    ex:textoExtracto "'Sentencia sólo válida en programas con extensión FBS'"@es .

ex:Parametro_1577
    a ex:Parametro ;
    rdfs:label "Parámetro de sincronización #FOLLOW"@es ;
    ex:identificador "1577" ;
    ex:textoExtracto "El parámetro que define el tipo de sincronización en la sentencia #FOLLOW es incorrecto. [...] El parámetro puede tomar los valores VEL (velocidad) y POS (posición)."@es ;
    ex:valor "VEL, POS" .

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "Parámetro UNIDIR (sentido de giro unidireccional)"@es ;
    ex:identificador "UNIDIR" ;
    ex:textoExtracto "Cuando los ejes son unidireccionales, ambos ejes deben tener el mismo sentido de giro predeterminado (parámetro UNIDIR)."@es .

ex:AvisoSeguridad_1575
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1575: Sentencias #SPLINE/#BSPLINE inválidas"@es ;
    ex:identificador "1575" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Programación de las sentencias #SPLINE o #BSPLINE. SOLUCIÓN Estas sentencias sólo son válidas en programas con extensión fbs."@es ;
    ex:mitigaRiesgo ex:Parametro_1575 .

ex:AvisoSeguridad_1576
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1576: Sintaxis incorrecta (falta ']')"@es ;
    ex:identificador "1576" ;
    ex:textoExtracto "'No se espera \"]\"'. DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación."@es .

ex:AvisoSeguridad_1577
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1577: Tipo de sincronización #FOLLOW no programado"@es ;
    ex:identificador "1577" ;
    ex:textoExtracto "Programar tipo de sincronización: VEL o POS. [...] SOLUCIÓN Revisar la programación."@es ;
    ex:mitigaRiesgo ex:Parametro_1577 .

ex:AvisoSeguridad_1578
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1578: Incompatibilidad de ejes UNIDIR en #LINK"@es ;
    ex:identificador "1578" ;
    ex:textoExtracto "#LINK: Un eje esclavo UNIDIR debe ser del mismo tipo que el maestro (UNIDIR). [...] SOLUCIÓN Cuando los ejes son unidireccionales, ambos ejes deben tener el mismo sentido de giro predeterminado (parámetro UNIDIR)."@es ;
    ex:mitigaRiesgo ex:Parametro_UNIDIR .

ex:AvisoSeguridad_1579
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1579: Búsqueda de cero en eje maestro con esclavos acoplados"@es ;
    ex:identificador "1579" ;
    ex:textoExtracto "No se permite búsqueda de cero en eje maestro con varios esclavos. [...] SOLUCIÓN Deshacer el acoplo de ejes y realizar la búsqueda de referencia de los ejes por separado."@es .

ex:AvisoSeguridad_1580
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1580: Cabezal Sercos no posicionado (M19 requerido)"@es ;
    ex:identificador "1580" ;
    ex:textoExtracto "#CAX: Necesita programación previa de M19 en Sercos de posición. [...] SOLUCIÓN El CNC ha intentado hacer activar un cabezal Sercos como eje C sin posicionarlo previamente con M19."@es .