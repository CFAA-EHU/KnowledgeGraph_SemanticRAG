@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1580
    a ex:Alarma ;
    rdfs:label "Alarma 1580: Necesita programación previa de M19 en Sercos de posición" ;
    ex:identificador "1580" ;
    ex:textoExtracto "#CAX: Necesita programación previa de M19 en Sercos de posición. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer activar un cabezal Sercos como eje C sin posicionarlo previamente con M19. SOLUCIÓN Programar M19 antes de activar el cabezal como eje C." .

ex:Alarma_1581
    a ex:Alarma ;
    rdfs:label "Alarma 1581: No está permitido eliminar un eje C activo" ;
    ex:identificador "1581" ;
    ex:textoExtracto "#CAX: 'No está permitido eliminar un eje C activo'. DETECCIÓN Durante la ejecución. CAUSA Las sentencias #SET AX y #FREE AX no pueden eliminar el eje C de la configuración si está activo. SOLUCIÓN Desactivar el eje C antes de eliminarlo de la configuración." .

ex:Alarma_1582
    a ex:Alarma ;
    rdfs:label "Alarma 1582: Doble programación del número de repeticiones" ;
    ex:identificador "1582" ;
    ex:textoExtracto "#CAX: 'NR: doble programación del número de repeticiones'. DETECCIÓN" .