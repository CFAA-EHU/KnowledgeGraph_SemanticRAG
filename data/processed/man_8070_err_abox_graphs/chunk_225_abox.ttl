@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9a345b1e1f a ns1:AvisoSeguridad ;
    rdfs:label "Herramienta no perpendicular al plano activo" ;
    ns1:mitigaRiesgo ns1:ColocarHerramientaPerpendicularAlPlanoActivo ;
    ns1:textoExtracto "'No se puede colocar la herramienta perpendicular al plano activo'" .

ns1:ConsultarOpcionesDeSoftwareEnModoDiagnosis a ns1:TareaMantenimiento ;
    rdfs:label "Consultar opciones de software en modo diagnosis" ;
    ns1:textoExtracto "'En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC.'" .

ns1:ReguladorMDUNoSupera550Hz a ns1:AvisoSeguridad ;
    rdfs:label "Regulador MDU no supera 550 Hz" ;
    ns1:mitigaRiesgo ns1:Superar550HzConReguladorMDU ;
    ns1:textoExtracto "'Los reguladores incluidos en la lista de productos doble uso (identificados con el texto -MDU) no pueden superar los 550 Hz.'" .

ns1:SolucionDefinirOtroPlano a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para no colocar herramienta perpendicular al plano activo" ;
    ns1:solucionaFallo ns1:ColocarHerramientaPerpendicularAlPlanoActivo ;
    ns1:textoExtracto "'Definir otro plano o colocar la herramienta en otro punto. Si es posible, utilizar otro cabezal.'" .

ns1:Superar550HzConReguladorMDU a ns1:AccionProhibida ;
    rdfs:label "Superar 550 Hz con regulador MDU" ;
    ns1:textoExtracto "'Los reguladores incluidos en la lista de productos doble uso (identificados con el texto -MDU) no pueden superar los 550 Hz.'" .

ns1:ColocarHerramientaPerpendicularAlPlanoActivo a ns1:AccionProhibida ;
    rdfs:label "Colocar herramienta perpendicular al plano activo" ;
    ns1:textoExtracto "'No se puede colocar la herramienta perpendicular al plano activo'" .

