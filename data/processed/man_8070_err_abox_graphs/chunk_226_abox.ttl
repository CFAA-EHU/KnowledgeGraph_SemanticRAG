@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:SentenciaPATHMalProgramada_7e325127e3 ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación.'" .

ns1:SobrepasarLimites a ns1:AccionProhibida ;
    rdfs:label "Sobrepasar límites" ;
    ns1:mitigaRiesgo ns1:CNC8070_13bc2a2ad2 ;
    ns1:textoExtracto "'Colocar la herramienta perpendicular al plano activo implica sobrepasar los límites.'" .

ns1:UtilizarCabezalAngular a ns1:AccionProhibida ;
    rdfs:label "Utilizar cabezal angular" ;
    ns1:mitigaRiesgo ns1:CNC8070_13bc2a2ad2 ;
    ns1:textoExtracto "'El tipo de cabezal no permite colocar la herramienta perpendicular al plano, como puede ser el caso de los cabezales angulares.'" .

ns1:ValorDeVariableVGTOOLORIF1 a ns1:Parametro ;
    rdfs:label "Valor de variable V.G.TOOLORIF1" ;
    ns1:textoExtracto "'El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido porque el CNC no puede colocar la herramienta perpendicular al plano activo.'" .

ns1:ValorDeVariableVGTOOLORIF2 a ns1:Parametro ;
    rdfs:label "Valor de variable V.G.TOOLORIF2" ;
    ns1:textoExtracto "'El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido porque el CNC no puede colocar la herramienta perpendicular al plano activo.'" .

ns1:VariableInexistenteParaElTipoDeEje_0d61aa8836 a ns1:AccionProhibida ;
    rdfs:label "Variable inexistente para el tipo de eje" ;
    ns1:textoExtracto "'1451 'Variable inexistente para el tipo de eje''" .

ns1:SentenciaPATHMalProgramada_7e325127e3 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #PATH mal programada" ;
    ns1:textoExtracto "'1449 'Sentencia #PATH mal programada''" .

ns1:CNC8070_13bc2a2ad2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "'el CNC no puede colocar la herramienta perpendicular al plano activo.'" .

