    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VariableInexistenteParaElTipoDeRegulador_ff53b52f5e a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente para el tipo de regulador" ;
    ns1:textoExtracto "'Variable inexistente para el tipo de regulador' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de" .

ns1:VariableInexistenteParaElTipoDeEje_ee1761a695 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente para el tipo de eje" ;
    ns1:textoExtracto "'Variable inexistente para el tipo de eje' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal). SOLUCIÓN Revisar la programación." .

