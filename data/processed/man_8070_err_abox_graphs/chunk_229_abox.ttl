@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1593
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1593: Cabezal esclavo no perteneciente al canal"@es ;
    ex:identificador "1593" ;
    ex:textoExtracto "El cabezal esclavo a desincronizar debe pertenecer al canal. DETECCIÓN Durante la ejecución. CAUSA Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal. SOLUCIÓN Cancelar la sincronización desde el canal al que pertenece el cabezal."@es .

ex:DiagnosticoFallo_1594
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1594: Valor de transmisión no válido en sincronización"@es ;
    ex:identificador "1594" ;
    ex:textoExtracto "En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero. SOLUCIÓN El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero."@es .

ex:Parametro_RelacionTransmision
    a ex:Parametro ;
    rdfs:label "Relación de transmisión (denominador)"@es ;
    ex:textoExtracto "valor del denominador de la relación de transmisión"@es ;
    ex:valor "distinto de cero"@es .

ex:Sistema_SincronizacionCabezales
    a ex:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales"@es ;
    ex:textoExtracto "sincronización de cabezales"@es ;
    ex:monitoreaParametro ex:Parametro_RelacionTransmision ;
    ex:activaAlarma ex:DiagnosticoFallo_1594 .

ex:Componente_CabezalEsclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo"@es ;
    ex:textoExtracto "cabezal esclavo a desincronizar"@es .

ex:Sistema_CanalControl
    a ex:Sistema ;
    rdfs:label "Canal de control"@es ;
    ex:textoExtracto "canal"@es ;
    ex:tieneComponente ex:Componente_CabezalEsclavo ;
    ex:activaAlarma ex:DiagnosticoFallo_1593 .