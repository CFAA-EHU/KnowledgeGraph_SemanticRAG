@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_4e7cc7b543 a ns1:Parametro ;
    rdfs:label "Parámetro final de interpolación",
        "Parámetro inicial de interpolación" ;
    ns1:textoExtracto "el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ns1:PuntoInicialNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Punto inicial no válido" ;
    ns1:textoExtracto "'#POLY: Punto inicial no válido' DETECCIÓN Durante" .

ns1:SolucionParaDemasiadosEjesProgramados a ns1:TareaMantenimiento ;
    rdfs:label "Solución para demasiados ejes programados" ;
    ns1:solucionaFallo ns1:DemasiadosEjesProgramados ;
    ns1:textoExtracto "En la interpolación polinómica sólo pueden intervenir tres ejes." .

ns1:SolucionParaParametroInvalido a ns1:TareaMantenimiento ;
    rdfs:label "Solución para parámetro inválido" ;
    ns1:solucionaFallo ns1:ValorDeParametroNoValido_ddd4d64e2f ;
    ns1:textoExtracto "Los parámetros de interpolación del polinomio deben ser positivos, el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP) y el radio de curvatura debe ser mayor que cero." .

ns1:DemasiadosEjesProgramados a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados ejes programados" ;
    ns1:textoExtracto "'#POLY: Demasiados ejes programados' DETECCIÓN Durante la ejecución." .

ns1:ValorDeParametroNoValido_ddd4d64e2f a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de parámetro no válido" ;
    ns1:textoExtracto "'#POLY: Valor de parámetro no válido' DETECCIÓN Durante la ejecución." .

