@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LasFuncionesRTCPYTLCSonIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Las funciones RTCP y TLC son incompatibles" ;
    ns1:textoExtracto "'Las funciones RTCP y TLC son incompatibles' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las funciones estando la otra activa." .

ns1:NoSePuedeProgramarG8ComoSegundoBloqueDeMovimientoParaG36G37G38G39 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39" ;
    ns1:textoExtracto "'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39' DETECCIÓN Durante la ejecución. CAUSA" .

