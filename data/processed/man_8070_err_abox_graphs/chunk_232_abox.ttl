@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9d8b236967 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:RevisarLaProgramacionIncrementalDelOrigenPolar ;
    ns1:solucionaFallo ns1:NoEsPosibleTenerAmbasFuncionesActivasSimultaneamente,
        ns1:ProgramacionIncorrectaDelOrigenPolar,
        ns1:RadioNegativoONuloNoPermitido ;
    ns1:textoExtracto "CNC 8070" .

ns1:EjeRotativoUnidireccional a ns1:Parametro ;
    rdfs:label "Eje rotativo unidireccional" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta'" .

ns1:NeglimitMaquina a ns1:Parametro ;
    rdfs:label "Neglimit Máquina" ;
    ns1:identificador "NEGLIMIT" ;
    ns1:textoExtracto "'POSLIMIT/NEGLIMIT no puede superar el valor del parámetro máquina'" .

ns1:PoslimitMaquina a ns1:Parametro ;
    rdfs:label "Poslimit Máquina" ;
    ns1:identificador "POSLIMIT" ;
    ns1:textoExtracto "'POSLIMIT/NEGLIMIT no puede superar el valor del parámetro máquina'" .

ns1:RevisarLaProgramacionDelOrigenPolar a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación del origen polar" ;
    ns1:textoExtracto "Es necesario programar las coordenadas del origen polar en los dos ejes principales." .

ns1:RevisarLaProgramacionIncrementalDelEjeRotativoUnidireccional a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación incremental del eje rotativo unidireccional" ;
    ns1:textoExtracto "La cota incremental programada para el eje rotativo unidireccional (parámetro UNIDIR) no es válida." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NoEsPosibleTenerAmbasFuncionesActivasSimultaneamente,
        ns1:ProgramacionIncorrectaDelOrigenPolar ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RadioNegativoONuloNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Radio negativo o nulo no permitido" ;
    ns1:textoExtracto "'Radio negativo o nulo no permitido'" .

ns1:RevisarLaProgramacionIncrementalDelOrigenPolar a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación incremental del origen polar" ;
    ns1:textoExtracto "En caso de programar en cotas incrementales, el valor programado podrá ser negativo o nulo pero no así el radio polar absoluto." .

ns1:NoEsPosibleTenerAmbasFuncionesActivasSimultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible tener ambas funciones activas simultáneamente" ;
    ns1:textoExtracto "'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39'" .

ns1:ProgramacionIncorrectaDelOrigenPolar a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del origen polar" ;
    ns1:textoExtracto "'G30: Programación incorrecta del origen polar'" .

