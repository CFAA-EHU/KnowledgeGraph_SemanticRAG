@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_f486c72ea5 a ns1:Parametro ;
    rdfs:label "Parámetro máquina UNIDIR del eje rotativo" ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' SOLUCIÓN Si el parámetro máquina UNIDIR del eje rotativo es POSITIVO la cota incremental programada debe ser positiva o nula. Si el parámetro máquina UNIDIR del eje rotativo es NEGATIVO la cota incremental programada debe ser negativa o nula." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' DETECCIÓN Durante la ejecución." .

ns1:SolucionParaElEjeRotativoUNIDIRConProgramacionIncrementalIncorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Solución para el eje rotativo UNIDIR con programación incremental incorrecta" ;
    ns1:solucionaFallo ns1:EjeRotativoUNIDIRConProgramacionIncrementalIncorrecta ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' SOLUCIÓN Si el parámetro máquina UNIDIR del eje rotativo es POSITIVO la cota incremental programada debe ser positiva o nula. Si el parámetro máquina UNIDIR del eje rotativo es NEGATIVO la cota incremental programada debe ser negativa o nula." .

ns1:EjeRotativoUNIDIRConProgramacionIncrementalIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Eje rotativo UNIDIR con programación incremental incorrecta" ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota incremental programada para el eje rotativo unidireccional (parámetro UNIDIR) no es válida." .

