@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:CajeraResueltaConDiferenteAnguloDeEntradaDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "cajera resuelta con diferente ángulo de entrada de herramienta" ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente ángulo de entrada de herramienta'" .

ns1:DefinirUnSoloRadioEnElBloque a ns1:TareaMantenimiento ;
    rdfs:label "definir un solo radio en el bloque" ;
    ns1:solucionaFallo ns1:RadioDoblementeProgramado ;
    ns1:textoExtracto "Definir un solo radio en el bloque." .

ns1:GenerarDeNuevoLaCajera_6614d32973 a ns1:TareaMantenimiento ;
    rdfs:label "generar de nuevo la cajera" ;
    ns1:solucionaFallo ns1:CajeraResueltaConDiferenteLongitudDeCorteDeHerramienta,
        ns1:CajeraResueltaConDiferenteRadioDeLaPuntaDeHerramienta ;
    ns1:textoExtracto "Generar de nuevo la cajera." .

ns1:Parametro_4d1201d147 a ns1:Parametro ;
    rdfs:label "parámetro máquina UNIDIR" ;
    ns1:textoExtracto "el parámetro máquina UNIDIR del eje rotativo es NEGATIVO" .

ns1:RevisarLaProgramacion_cfd5090cf7 a ns1:TareaMantenimiento ;
    rdfs:label "revisar la programación" ;
    ns1:solucionaFallo ns1:FaltaProgramarAnguloDeGiro,
        ns1:POLYNoPermitidaConGiroActivo,
        ns1:ProgramacionIncorrectaDelCentroDeGiro ;
    ns1:textoExtracto "Revisar la programación." .

ns1:CajeraResueltaConDiferenteLongitudDeCorteDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "cajera resuelta con diferente longitud de corte de herramienta" ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente longitud de corte de herramienta'" .

ns1:CajeraResueltaConDiferenteRadioDeLaPuntaDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "cajera resuelta con diferente radio de la punta de herramienta" ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente radio de la punta de herramienta'" .

ns1:FaltaProgramarAnguloDeGiro a ns1:AccionProhibida ;
    rdfs:label "falta programar ángulo de giro" ;
    ns1:textoExtracto "'G73: falta programar ángulo de giro'" .

ns1:POLYNoPermitidaConGiroActivo a ns1:AccionProhibida ;
    rdfs:label "#POLY no permitida con giro activo" ;
    ns1:textoExtracto "'Programación #POLY no permitida con giro activo'" .

ns1:ProgramacionIncorrectaDelCentroDeGiro a ns1:AccionProhibida ;
    rdfs:label "programación incorrecta del centro de giro" ;
    ns1:textoExtracto "'G73: programación incorrecta del centro de giro'" .

ns1:RadioDoblementeProgramado a ns1:AccionProhibida ;
    rdfs:label "radio doblemente programado" ;
    ns1:textoExtracto "'Radio doblemente programado'" .

