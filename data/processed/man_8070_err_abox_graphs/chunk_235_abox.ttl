@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1612
    a ex:Alarma ;
    rdfs:label "Alarma 1612: Ejes de transformación angular activa no excluibles" ;
    ex:identificador "1612" ;
    ex:textoExtracto "'Los ejes de la transformación angular activa, #ANGAX, no pueden excluirse'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado eliminar del canal los ejes que formaban la transformación angular. SOLUCIÓN Desactivar la transformación angular antes de eliminar los ejes del canal." .

ex:Alarma_1613
    a ex:Alarma ;
    rdfs:label "Alarma 1613: Transformación angular desactivada" ;
    ex:identificador "1613" ;
    ex:textoExtracto "'Se ha desactivado la transformación angular #ANGAX'" .

ex:Funcion_G20 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función G20: Cambio de eje longitudinal" ;
    ex:identificador "G20" ;
    ex:textoExtracto "Si sólo se desea cambiar el eje longitudinal, utilizar la función G20." .