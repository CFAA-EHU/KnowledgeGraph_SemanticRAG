@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:G74FaltaAsociarSubrutina a ns1:DiagnosticoFallo ;
    rdfs:label "G74: falta asociar subrutina" ;
    ns1:textoExtracto "'G74: falta asociar subrutina' DETECCIÓN Durante la ejecución." .

ns1:GenerarDeNuevoLaCajera a ns1:TareaMantenimiento ;
    rdfs:label "Generar de nuevo la cajera" ;
    ns1:solucionaFallo ns1:LaCajeraFueResueltaConDiferenteAnguloDeEntradaDeHerramienta,
        ns1:LaCajeraFueResueltaConDiferenteLongitudDeCorteDeHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Generar de nuevo la cajera." .

ns1:LaCajeraFueResueltaConDiferenteAnguloDeEntradaDeHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "La cajera fue resuelta con diferente ángulo de entrada de herramienta" ;
    ns1:textoExtracto "CAUSA El CNC generó la cajera con un ángulo de entrada de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera." .

ns1:LaCajeraFueResueltaConDiferenteLongitudDeCorteDeHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "La cajera fue resuelta con diferente longitud de corte de herramienta" ;
    ns1:textoExtracto "CAUSA El CNC generó la cajera con una longitud de corte de herramienta diferente a la actual. SOLUCIÓN Generar de nuevo la cajera." .

