@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:NumeroDeCanalNoValidoEnLaSentenciaEXECMEETOWAIT a ns1:DiagnosticoFallo ;
    rdfs:label "Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT" ;
    ns1:textoExtracto "CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:NumeroDeSenalFueraDeRango,
        ns1:WAITMEETNoEfectivo ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacion_a8bb4bbddd a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:NumeroDeSenalFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Número de señal fuera de rango" ;
    ns1:textoExtracto "CAUSA El número de señal programada en la sentencia #WAIT, #MEET o #SIGNAL no es correcto." .

ns1:WAITMEETNoEfectivo a ns1:DiagnosticoFallo ;
    rdfs:label "#WAIT/#MEET no efectivo" ;
    ns1:textoExtracto "CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias." .

