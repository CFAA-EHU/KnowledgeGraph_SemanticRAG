@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1618
    a ex:Alarma ;
    rdfs:label "Alarma 1618: 'Valor Q doblemente programado'" ;
    ex:textoExtracto "1618 'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque." ;
    ex:identificador "1618" .

ex:Alarma_1619
    a ex:Alarma ;
    rdfs:label "Alarma 1619: 'Valor Q1 doblemente programado'" ;
    ex:textoExtracto "1619 'Valor Q1 doblemente" ;
    ex:identificador "1619" .

ex:Parametro_Q
    a ex:Parametro ;
    rdfs:label "Parámetro Q (programación en polares)" ;
    ex:textoExtracto "Para la programación en polares utilizar el parámetro Q." ;
    ex:identificador "Q" .

ex:Parametro_Q1
    a ex:Parametro ;
    rdfs:label "Parámetro Q1 (función G33)" ;
    ex:textoExtracto "Para la función G33 utilizar el parámetro Q1." ;
    ex:identificador "Q1" .

ex:TareaMantenimiento_RevisionProgramacion
    a ex:TareaMantenimiento ;
    rdfs:label "Revisión de programación (parámetros Q/Q1)" ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación." ;
    ex:solucionaFallo ex:Alarma_1618, ex:Alarma_1619 .