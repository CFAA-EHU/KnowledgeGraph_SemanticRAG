@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteDeInformacionEnElBloque a ns1:Parametro ;
    rdfs:label "Límite de información en el bloque" ;
    ns1:textoExtracto "Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Parametro_70e947b322 a ns1:Parametro ;
    rdfs:label "Señal" ;
    ns1:textoExtracto "'Programar: #SIGNAL [señal, señal, señal, ...]'" .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:AccionProhibida_a6350c19a9,
        ns1:SintaxisDeLaSentenciaNoCorrectaOInformacionAdicionalEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:AccionProhibida_a6350c19a9 a ns1:AccionProhibida ;
    rdfs:label "Marca de sincronización en el mismo canal que las sentencias" ;
    ns1:textoExtracto "CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias." .

ns1:SintaxisDeLaSentenciaNoCorrectaOInformacionAdicionalEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Sintaxis de la sentencia no correcta o información adicional en el bloque" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

