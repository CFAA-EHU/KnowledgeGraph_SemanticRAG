@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1619
    a ex:Alarma ;
    rdfs:label "Valor Q doblemente programado" ;
    ex:identificador "1619" ;
    ex:textoExtracto "'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

ex:Alarma_1620
    a ex:Alarma ;
    rdfs:label "Valor Q1 doblemente programado" ;
    ex:identificador "1620" ;
    ex:textoExtracto "'Valor Q1 doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q1 está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

ex:Alarma_1621
    a ex:Alarma ;
    rdfs:label "No se admite #SERVO ON para eje o cabezal SERCOS POSICION" ;
    ex:identificador "1621" ;
    ex:textoExtracto "'No se admite #SERVO ON para eje o cabezal SERCOS POSICION' DETECCIÓN Durante la ejecución. CAUSA El eje o cabezal es Sercos posición. SOLUCIÓN Esta sentencia sólo permite ejes Sercos velocidad." .

ex:Alarma_1622
    a ex:Alarma ;
    rdfs:label "No se admite Q1 sin G33 en el bloque o G63 activa" ;
    ex:identificador "1622" ;
    ex:textoExtracto "'No se admite Q1 sin G33 en el bloque o G63 activa' DETECCIÓN Durante la ejecución. CAUSA Hay programado un parámetro Q1 sin G33 en el bloque o sin la función G63 activa. SOLUCIÓN El parámetro Q debe ir en el mismo bloque que G33. El parámetro Q sólo puede ir solo en el bloque si está activa la función G63." .

ex:Alarma_1623
    a ex:Alarma ;
    rdfs:label "Un cabezal de intercambio temporal no puede funcionar como eje C mantenido" ;
    ex:identificador "1623" ;
    ex:textoExtracto "'Un cabezal de intercambio temporal no puede funcionar como eje C mantenido' DETECCIÓN Durante la ejecución. CAUSA El CNC puede activar como eje C mantenido (parámetro PERCAX) un cabezal de intercambio temporal. SOLUCIÓN Si es posible, definir el cabezal como de intercambio mantenido; si no, utilizar otro cabezal como eje C." .

ex:Alarma_1624
    a ex:Alarma ;
    rdfs:label "Gama para sincronización SYNCSET no válida" ;
    ex:identificador "1624" ;
    ex:textoExtracto "'Gama para sincronización SYNCSET no valida' DETECCIÓN Durante la ejecución. CAUSA El parámetro SYNCSET tiene un valor no valido. SOLUCIÓN Asignar al parámetro un valor correcto." .

ex:Alarma_1625
    a ex:Alarma ;
    rdfs:label "Programar #TANGCTRL ON/OFF/SUSP [ ]" ;
    ex:identificador "1625" ;
    ex:textoExtracto "'Programar #TANGCTRL ON/OFF/SUSP [ ]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación." .

ex:Parametro_Q
    a ex:Parametro ;
    rdfs:label "Parámetro Q" ;
    ex:textoExtracto "El parámetro Q está programado más de una vez en el mismo bloque." .

ex:Parametro_Q1
    a ex:Parametro ;
    rdfs:label "Parámetro Q1" ;
    ex:textoExtracto "El parámetro Q1 está programado más de una vez en el mismo bloque." .

ex:Parametro_SYNCSET
    a ex:Parametro ;
    rdfs:label "Parámetro SYNCSET" ;
    ex:textoExtracto "El parámetro SYNCSET tiene un valor no válido." .

ex:Parametro_PERCAX
    a ex:Parametro ;
    rdfs:label "Parámetro PERCAX" ;
    ex:textoExtracto "El CNC puede activar como eje C mantenido (parámetro PERCAX) un cabezal de intercambio temporal." .

ex:Funcion_G33 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G33" ;
    ex:textoExtracto "El parámetro Q debe ir en el mismo bloque que G33." .

ex:Funcion_G63 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G63" ;
    ex:textoExtracto "El parámetro Q sólo puede ir solo en el bloque si está activa la función G63." .

ex:Alarma_1619 ex:activaAlarma ex:Parametro_Q .
ex:Alarma_1620 ex:activaAlarma ex:Parametro_Q1 .
ex:Alarma_1622 ex:activaAlarma ex:Parametro_Q1 .
ex:Alarma_1622 ex:activaAlarma ex:Funcion_G33 .
ex:Alarma_1622 ex:activaAlarma ex:Funcion_G63 .
ex:Alarma_1624 ex:activaAlarma ex:Parametro_SYNCSET .
