@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1624
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1624: Programación incorrecta de TANGCTRL"@es ;
    ex:identificador "1624" ;
    ex:textoExtracto "1624 'Programar #TANGCTRL ON/OFF/SUSP [ ]' [...] SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON/SUSP/OFF y a continuación los parámetros de llamada entre corchetes. También se permite la programación de uno de los comandos SUSP/OFF sin parámetros de llamada."@es .

ex:Fallo_1625
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1625: Configuración inválida de eje en control tangencial"@es ;
    ex:identificador "1625" ;
    ex:textoExtracto "1625 'Un eje en control tangencial activo debe ser rotativo no HIRTH y no pertenecer al triedro activo' [...] CAUSA Los ejes a activar en el control tangencial debe ser"@es .

ex:Parametro_TANGCTRL
    a               ex:Parametro ;
    rdfs:label      "Parámetro TANGCTRL"@es ;
    ex:identificador "TANGCTRL" ;
    ex:textoExtracto "Programar #TANGCTRL ON/OFF/SUSP [ ]"@es ;
    ex:solucionaFallo ex:Fallo_1624 .

ex:Sintaxis_TANGCTRL
    a               ex:InterfazUsuario ;
    rdfs:label      "Sintaxis de programación TANGCTRL"@es ;
    ex:textoExtracto "Junto a la sentencia hay que programar uno de los comandos ON/SUSP/OFF y a continuación los parámetros de llamada entre corchetes. También se permite la programación de uno de los comandos SUSP/OFF sin parámetros de llamada."@es ;
    ex:documentadoEn ex:Fallo_1624 .