@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:G63NecesitaProgramarPreviamenteM19 a ns1:DiagnosticoFallo ;
    rdfs:label "G63 necesita programar previamente M19" ;
    ns1:textoExtracto "'G63 necesita programar previamente M19' DETECCIÓN Durante la ejecución." .

ns1:RenombrarEjes a ns1:TareaMantenimiento ;
    rdfs:label "Renombrar ejes" ;
    ns1:solucionaFallo ns1:NombreDeEjeRepetidoEnElGrupoResultante ;
    ns1:textoExtracto "SOLUCIÓN Renombrar los ejes de forma que en el canal no haya dos con el mismo nombre." .

ns1:RevisarProgramacion_a8bb4bbddd a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:SintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:NombreDeEjeRepetidoEnElGrupoResultante a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de eje repetido en el grupo resultante" ;
    ns1:textoExtracto "'Nombre de eje repetido en el grupo resultante' DETECCIÓN Durante la ejecución. CAUSA La sentencia #RENAME ha intentado renombrar más de un eje con el mismo nombre." .

ns1:SintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #CLEAR [señal, señal, señal, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

