@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsociacionDeEntradaDigitalAlPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Asociación de entrada digital al palpador" ;
    ns1:solucionaFallo ns1:NoExisteEntradaDigitalAsociadaAlPalpadorPRBDI12 ;
    ns1:textoExtracto "SOLUCIÓN Asociar una entrada digital al palpador (parámetro PRBDI1 ó PRBDI2)." .

ns1:EntradaDigitalAsociadaAlPalpador1 a ns1:Parametro ;
    rdfs:label "Entrada digital asociada al palpador 1" ;
    ns1:textoExtracto "SOLUCIÓN Asociar una entrada digital al palpador (parámetro PRBDI1 ó PRBDI2)." .

ns1:EntradaDigitalAsociadaAlPalpador2 a ns1:Parametro ;
    rdfs:label "Entrada digital asociada al palpador 2" ;
    ns1:textoExtracto "SOLUCIÓN Asociar una entrada digital al palpador (parámetro PRBDI1 ó PRBDI2)." .

ns1:ProgramacionDeM19AntesDelRoscado a ns1:TareaMantenimiento ;
    rdfs:label "Programación de M19 antes del roscado" ;
    ns1:solucionaFallo ns1:G63NecesitaProgramarPreviamenteM19_be23132abf ;
    ns1:textoExtracto "SOLUCIÓN Programar M19 antes de realizar el roscado." .

ns1:VerificacionDelNumeroDePalpador a ns1:TareaMantenimiento ;
    rdfs:label "Verificación del número de palpador" ;
    ns1:solucionaFallo ns1:NumeroDePalpadorIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN El número de palpador seleccionado deber ser 1 ó 2." .

ns1:G63NecesitaProgramarPreviamenteM19_be23132abf a ns1:AccionProhibida ;
    rdfs:label "G63 necesita programar previamente M19" ;
    ns1:textoExtracto "'G63 necesita programar previamente M19' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer un roscado G63 con un cabezal Sercos sin posicionarlo previamente con M19." .

ns1:NoExisteEntradaDigitalAsociadaAlPalpadorPRBDI12 a ns1:AccionProhibida ;
    rdfs:label "No existe entrada digital asociada al palpador (PRBDI1/2)" ;
    ns1:textoExtracto "'No existe entrada digital asociada al palpador (PRBDI1/2)' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado seleccionar un palpador (#SELECT PROBE) o realizar un movimiento de palpado (G100) y no existe ninguna entrada digital asociada al palpador." .

ns1:NumeroDePalpadorIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Número de palpador incorrecto" ;
    ns1:textoExtracto "'Número de palpador incorrecto' DETECCIÓN Durante la ejecución. CAUSA El número de palpador seleccionado con la sentencia #SELECT PROBE no es correcto." .

