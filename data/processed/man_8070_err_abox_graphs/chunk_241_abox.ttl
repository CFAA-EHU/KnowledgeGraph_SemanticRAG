@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1630
    a ex:Alarma ;
    rdfs:label "Alarma 1630: Programación de perfil mediante etiquetas incorrecta"@es ;
    ex:identificador "1630" ;
    ex:textoExtracto "1630 'Programación de perfil mediante etiquetas incorrecta' DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E)."@es .

ex:Alarma_1631
    a ex:Alarma ;
    rdfs:label "Alarma 1631: Programación de perfil no permitida"@es ;
    ex:identificador "1631" ;
    ex:textoExtracto "1631 'Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]' DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E), la"@es .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "Parámetro S"@es ;
    ex:textoExtracto "parámetros que definen el comienzo [...] del perfil (parámetros S [...])."@es .

ex:Parametro_E
    a ex:Parametro ;
    rdfs:label "Parámetro E"@es ;
    ex:textoExtracto "parámetros que definen [...] el final del perfil (parámetros [...] E)."@es .

ex:Parametro_Q
    a ex:Parametro ;
    rdfs:label "Parámetro Q"@es ;
    ex:textoExtracto "Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]."@es .

ex:Parametro_P
    a ex:Parametro ;
    rdfs:label "Parámetro P"@es ;
    ex:textoExtracto "Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]."@es .

ex:Alarma_1630 ex:monitoreaParametro ex:Parametro_S .
ex:Alarma_1630 ex:monitoreaParametro ex:Parametro_E .
ex:Alarma_1631 ex:monitoreaParametro ex:Parametro_S .
ex:Alarma_1631 ex:monitoreaParametro ex:Parametro_E .
ex:Alarma_1631 ex:monitoreaParametro ex:Parametro_Q .
ex:Alarma_1631 ex:monitoreaParametro ex:Parametro_P .