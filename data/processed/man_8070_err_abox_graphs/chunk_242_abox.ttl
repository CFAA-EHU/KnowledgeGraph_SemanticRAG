@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperadorIncorrectoParaElTipoDeVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Operador incorrecto para el tipo de variable" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:ProgramarTOOLAXAntesDeEjecutarElCicloPROBE1 a ns1:TareaMantenimiento ;
    rdfs:label "Programar #TOOL AX[+] antes de ejecutar el ciclo PROBE1" ;
    ns1:solucionaFallo ns1:PROBE1ProgramacionNoPermitidaConTOOLAXActivo ;
    ns1:textoExtracto "SOLUCIÓN Programar #TOOL AX[+] antes de ejecutar el ciclo PROBE1 para orientar la herramienta en el sentido positivo del eje." .

ns1:RestaurarConfiguracionInicial a ns1:TareaMantenimiento ;
    rdfs:label "Restaurar configuración inicial" ;
    ns1:solucionaFallo ns1:PROBE1EjeNoValidoParaCicloDePalpador ;
    ns1:textoExtracto "SOLUCIÓN Restaurar la configuración inicial de los tres primeros ejes del canal." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ElNumeroDeErrorIndicadoEnLaSentenciaERROROWARNINGNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElNumeroDeErrorIndicadoEnLaSentenciaERROROWARNINGNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "El número de error indicado en la sentencia #ERROR o #WARNING no existe" ;
    ns1:textoExtracto "CAUSA El número de error indicado en la sentencia #ERROR o #WARNING no existe." .

ns1:PROBE1EjeNoValidoParaCicloDePalpador a ns1:DiagnosticoFallo ;
    rdfs:label "#PROBE1: eje no válido para ciclo de palpador" ;
    ns1:textoExtracto "CAUSA El ciclo PROBE1 da error porque los tres primeros ejes de la configuración actual no coinciden con los tres primeros ejes de la configuración inicial." .

ns1:PROBE1ProgramacionNoPermitidaConTOOLAXActivo a ns1:DiagnosticoFallo ;
    rdfs:label "#PROBE1: programación no permitida con #TOOL AX[-] activo" ;
    ns1:textoExtracto "CAUSA El CNC ha intentado ejecutar el ciclo PROBE1 teniendo la herramienta orientada en el sentido negativo del eje." .

