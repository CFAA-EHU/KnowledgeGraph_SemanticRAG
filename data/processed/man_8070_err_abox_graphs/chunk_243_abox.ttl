@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_NKINAX
    a ex:Parametro ;
    rdfs:label "Parámetro máquina NKINAX"@es ;
    ex:textoExtracto "Corregir el parámetro máquina NKINAX."@es ;
    ex:identificador "NKINAX" .

ex:DiagnosticoFallo_1636
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1636: Transformadas FACE y CYL activas simultáneamente"@es ;
    ex:textoExtracto "'No se permiten tener activas las transformadas FACE y CYL al mismo tiempo' [...] Durante la ejecución. [...] El CNC intentado activar la sentencia #FACE o #CYL con una de ellas activa."@es ;
    ex:identificador "1636" ;
    ex:monitoreaParametro ex:Parametro_NKINAX .

ex:AvisoSeguridad_1636_Solucion
    a ex:AvisoSeguridad ;
    rdfs:label "Solución para error 1636"@es ;
    ex:textoExtracto "Desactivar una de ellas antes de activar la otra."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_1636 .

ex:DiagnosticoFallo_1637
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1637: Sentido de giro del cabezal incompatible con la herramienta"@es ;
    ex:textoExtracto "'Sentido de giro del cabezal incompatible con la herramienta' [...] Durante la ejecución. [...] El sentido de giro predeterminado de la herramienta es"@es ;
    ex:identificador "1637" .