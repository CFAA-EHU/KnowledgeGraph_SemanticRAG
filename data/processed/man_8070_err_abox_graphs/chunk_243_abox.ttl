@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:EXECNoSePuedeEjecutarElProgramaEnElCanalIndicado a ns1:AvisoSeguridad ;
    rdfs:label "#EXEC: no se puede ejecutar el programa en el canal indicado" ;
    ns1:textoExtracto "'#EXEC: no se puede ejecutar el programa en el canal indicado' DETECCIÓN Durante la ejecución. CAUSA Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático." .

ns1:ElMaximoNumeroDeAnidamientosPermitidoEs20 a ns1:DiagnosticoFallo ;
    rdfs:label "El máximo número de anidamientos permitido es 20" ;
    ns1:textoExtracto "CAUSA Se considera anidamiento cuando la sentencia #RPT se programa entre dos etiquetas que definen el radio de acción de otra sentencia #RPT. El CNC da error cuando sobrepasa el número de anidamientos de sentencias RPT y subrutinas, si las hay." .

ns1:MedianteLaSentenciaEXECElCNCHaIntentadoEjecutarUnProgramaEnUnCanalQue_68a067039b a ns1:DiagnosticoFallo ;
    rdfs:label "Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático" ;
    ns1:textoExtracto "CAUSA Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático." .

ns1:NumeroDeAnidamientosDeRPTYSubrutinasSobrepasado a ns1:AvisoSeguridad ;
    rdfs:label "Número de anidamientos de #RPT y subrutinas sobrepasado" ;
    ns1:textoExtracto "'Número de anidamientos de #RPT y subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se considera anidamiento cuando la sentencia #RPT se programa entre dos etiquetas que definen el radio de acción de otra sentencia #RPT." .

ns1:OperadorIncorrectoParaElTipoDeVariable_186dcb9cd8 a ns1:AvisoSeguridad ;
    rdfs:label "Operador incorrecto para el tipo de variable" ;
    ns1:textoExtracto "'Operador incorrecto para el tipo de variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar mediante los operadores '+=', '-=', '*=' y '/=' alguna variable no numérica." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElCNCHaIntentadoModificarMedianteLosOperadoresYAlgunaVariableNoNumerica ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElCNCHaIntentadoModificarMedianteLosOperadoresYAlgunaVariableNoNumerica a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentado modificar mediante los operadores '+=', '-=', '*=' y '/=' alguna variable no numérica" ;
    ns1:textoExtracto "CAUSA El CNC ha intentado modificar mediante los operadores '+=', '-=', '*=' y '/=' alguna variable no numérica." .

