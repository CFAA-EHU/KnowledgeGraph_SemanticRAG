@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirEtiquetasInicialYFinalDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Definir etiquetas inicial y final diferentes" ;
    ns1:solucionaFallo ns1:EtiquetasRepetidasEnRPT_f79385d0f0 ;
    ns1:textoExtracto "SOLUCIÓN Definir etiquetas inicial y final diferentes." .

ns1:EsperarAQueFinaliceElProgramaEnElOtroCanalOHacerleUnReset a ns1:TareaMantenimiento ;
    rdfs:label "Esperar a que finalice el programa en el otro canal o hacerle un reset" ;
    ns1:solucionaFallo ns1:ProgramaEnOtroCanal ;
    ns1:textoExtracto "SOLUCIÓN Esperar a que finalice el programa en el otro canal o hacerle un reset." .

ns1:EtiquetasRepetidasEnRPT_f79385d0f0 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiquetas repetidas en #RPT" ;
    ns1:textoExtracto "'Etiquetas repetidas en #RPT' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #RPT la etiqueta inicial y final es la misma." .

ns1:ProgramaEnOtroCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Programa en otro canal" ;
    ns1:textoExtracto "SOLUCIÓN Esperar a que finalice el programa en el otro canal o hacerle un reset." .

