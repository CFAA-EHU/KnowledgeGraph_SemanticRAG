@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:NoSeAdmitenG201YEjeCActivoEnLosEjesDelPlanoPrincipal ;
    ns1:textoExtracto "Sistema CNC" .

ns1:UnoDeLosEjesImplicadosEnLaEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "Uno de los ejes implicados en la ejecución" ;
    ns1:textoExtracto "Las posibles causas son las siguientes: • Uno de los ejes implicados en" .

ns1:NoSeAdmitenG201YEjeCActivoEnLosEjesDelPlanoPrincipal a ns1:AccionProhibida ;
    rdfs:label "No se admiten G201 y eje C activo en los ejes del plano principal" ;
    ns1:textoExtracto "'No se admiten G201 y eje C activo en los ejes del plano principal'" .

