@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElEjeCOElModoManualAditivo a ns1:TareaMantenimiento ;
    rdfs:label "Anular el eje C o el modo manual aditivo" ;
    ns1:solucionaFallo ns1:NoSeAdmitenG201YEjeCActivoEnLosEjesDelPlanoPrincipal_f04466bf9a ;
    ns1:textoExtracto "SOLUCIÓN Anular el eje C o el modo manual aditivo." .

ns1:EjeInexistenteONoDisponibleEnElCanal_341bea3be0 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible en el canal" ;
    ns1:textoExtracto "'Eje inexistente o no disponible en el canal' DETECCIÓN Durante la ejecución." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:SETAXCALLAXLaProgramacionDeOffsetsNoTieneEfecto ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NoSeAdmitenG201YEjeCActivoEnLosEjesDelPlanoPrincipal_f04466bf9a a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten G201 y eje C activo en los ejes del plano principal" ;
    ns1:textoExtracto "'No se admiten G201 y eje C activo en los ejes del plano principal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Uno de los ejes implicados en la función G201 es eje C y forma parte de los tres primeros ejes del canal. • Uno de los ejes programados en la sentencia #FACE está en modo manual aditivo, G201." .

ns1:SETAXCALLAXLaProgramacionDeOffsetsNoTieneEfecto a ns1:DiagnosticoFallo ;
    rdfs:label "#SET AX/#CALL AX: la programación de offsets no tiene efecto" ;
    ns1:textoExtracto "'#SET AX/#CALL AX: la programación de offsets no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA Todos los ejes programados en la sentencia pertenecían ya a la configuración actual y por tanto, la sentencia sólo supone un cambio de orden. En este caso la opción de offsets programada no tiene efecto." .

