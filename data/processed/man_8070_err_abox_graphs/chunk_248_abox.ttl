@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1651
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1651: LINK mantenido con ejes temporales de otro canal" ;
    ex:identificador "1651" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL). SOLUCIÓN Acoplar los ejes en su canal." .

ex:Fallo_1653
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1653: Eje esclavo en plano inclinado" ;
    ex:identificador "1653" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado. SOLUCIÓN Desactivar el plano inclinado para poder activar el acoplo. Un eje que forma parte de un plano inclinado no puede ser el eje esclavo en un acoplo; sí puede ser el eje maestro de un acoplo." .

ex:Fallo_1654
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1654: Bus digital no preparado para lectura" ;
    ex:identificador "1654" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. El anillo Sercos no está en fase 4. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink." .

ex:Fallo_1655
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1655: Bus digital no preparado para escritura" ;
    ex:identificador "1655" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución." .

ex:Fallo_McsToPcs
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta función de coordenadas McsToPcs" ;
    ex:textoExtracto "CAUSA Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario. SOLUCIÓN Revisar el proceso de integración de cinemáticas de usuario." .

ex:Fallo_1652
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1652: Sintaxis #DEF incorrecta" ;
    ex:identificador "1652" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Sentencia mal programada. SOLUCIÓN Revisar la programación." .

ex:Parametro_AXISEXCH
    a ex:Parametro ;
    rdfs:label "Parámetro AXISEXCH (intercambio temporal de ejes)" ;
    ex:textoExtracto "parámetro AXISEXCH" .

ex:Parametro_LINKCANCEL
    a ex:Parametro ;
    rdfs:label "Parámetro LINKCANCEL (acoplos mantenidos)" ;
    ex:textoExtracto "parámetro LINKCANCEL" .

ex:Parametro_SERCOSRDY
    a ex:Parametro ;
    rdfs:label "Marca SERCOSRDY (bus Sercos listo)" ;
    ex:textoExtracto "marca SERCOSRDY en Sercos" .

ex:Parametro_MLINKRDY
    a ex:Parametro ;
    rdfs:label "Marca MLINKRDY (bus Mechatrolink listo)" ;
    ex:textoExtracto "marca MLINKRDY en Mechatrolink" .

ex:Fallo_1651 ex:solucionaFallo ex:Parametro_LINKCANCEL .
ex:Fallo_1651 ex:solucionaFallo ex:Parametro_AXISEXCH .
ex:Fallo_1654 ex:solucionaFallo ex:Parametro_SERCOSRDY .
ex:Fallo_1654 ex:solucionaFallo ex:Parametro_MLINKRDY .