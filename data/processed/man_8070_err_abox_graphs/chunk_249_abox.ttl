@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1655
    a ex:AvisoSeguridad ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable"@es ;
    ex:identificador "1655" ;
    ex:textoExtracto "1655 'Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3."@es .

ex:AvisoSeguridad_1656
    a ex:AvisoSeguridad ;
    rdfs:label "Alguno de los ejes del plano está en diámetros"@es ;
    ex:identificador "1656" ;
    ex:textoExtracto "1656 'Alguno de los ejes del plano esta en diámetros' DETECCIÓN Al simular o ejecutar en un torno un ciclo fijo de fresadora"@es .

ex:Parametro_SERCOSRDY
    a ex:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ex:textoExtracto "Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos"@es .

ex:Parametro_MLINKRDY
    a ex:Parametro ;
    rdfs:label "MLINKRDY" ;
    ex:textoExtracto "Condicionar la escritura de la variable a la marca MLINKRDY en Mechatrolink"@es .

ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Sercos" ;
    ex:monitoreaParametro ex:Parametro_SERCOSRDY ;
    ex:textoExtracto "Con bus Sercos, el anillo no está en fase 4"@es .

ex:Sistema_Mechatrolink
    a ex:Sistema ;
    rdfs:label "Mechatrolink" ;
    ex:monitoreaParametro ex:Parametro_MLINKRDY ;
    ex:textoExtracto "Con bus Mechatrolink, el bus no ha alcanzado la fase 3"@es .