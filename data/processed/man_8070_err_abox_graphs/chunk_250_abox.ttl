@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElFactorDeEscala a ns1:TareaMantenimiento ;
    rdfs:label "Anular el factor de escala" ;
    ns1:solucionaFallo ns1:NoEsPosibleEjecutarUnaCajera2D3DConG72Activo ;
    ns1:textoExtracto "SOLUCIÓN Anular el factor de escala." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ErrorEnLaEscrituraDeLaVariable_2968761e00 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:UnoOVariosEjesDeLaConfiguracionOriginalNoEstanDisponibles a ns1:DiagnosticoFallo ;
    rdfs:label "Uno o varios ejes de la configuración original no están disponibles" ;
    ns1:textoExtracto "'Uno o varios ejes de la configuración original no están disponibles' DETECCIÓN Durante la ejecución." .

ns1:ErrorEnLaEscrituraDeLaVariable_2968761e00 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la escritura de la variable" ;
    ns1:textoExtracto "'Error en la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable no existe. • La variable es de eje pero el eje no existe. • La variable es de eje pero no existe para el tipo de eje (lineal o rotativo). • La variable es de eje pero no existe para el tipo de regulador del eje. • El operador compuesto (+= -= *= /=) no está permitido para esa variable. • El valor de la variable no es válido." .

ns1:NoEsPosibleEjecutarUnaCajera2D3DConG72Activo a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible ejecutar una cajera 2D-3D con G72 activo" ;
    ns1:textoExtracto "'No es posible ejecutar una cajera 2D-3D con G72 activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la cajera con un factor de escala activo." .

