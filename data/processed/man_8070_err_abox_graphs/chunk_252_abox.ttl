@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionDeUnValorNuloEnUnaSentenciaOFuncionG a ns1:AccionProhibida ;
    rdfs:label "programación de un valor nulo en una sentencia o función G" ;
    ns1:textoExtracto "Se ha programado un valor nulo en una sentencia o función G." .

ns1:RevisarLaProgramacionDeNR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de NR" ;
    ns1:solucionaFallo ns1:RepeticionDeBloquesNREnUnBloqueQueNoImplicaMovimiento ;
    ns1:textoExtracto "La programación de la repetición de bloques con NR solo es válida con bloques que implican movimiento." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NRExigeProgramarMovimientoEnElBloque_7b8d7d4f3c ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NRExigeProgramarMovimientoEnElBloque_7b8d7d4f3c a ns1:DiagnosticoFallo ;
    rdfs:label "NR exige programar movimiento en el bloque" ;
    ns1:textoExtracto "'NR exige programar movimiento en el bloque'" .

ns1:RepeticionDeBloquesNREnUnBloqueQueNoImplicaMovimiento a ns1:AccionProhibida ;
    rdfs:label "repetición de bloques (NR) en un bloque que no implica movimiento" ;
    ns1:textoExtracto "Hay programada una repetición de bloques (NR) en un bloque que no implica movimiento." .

