@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltaProgramarTEnElBloqueConPOSYOMZ a ns1:AccionProhibida ;
    rdfs:label "Falta programar T en el bloque con POS y/o MZ" ;
    ns1:textoExtracto "Falta programar T en el bloque." .

ns1:NoSeAdmiteValorNegativoParaNR a ns1:AccionProhibida ;
    rdfs:label "No se admite valor negativo para NR" ;
    ns1:textoExtracto "'No se admite valor negativo'" .

ns1:NoSePermiteProgramarGOTOEnElMismoBloqueConNR a ns1:AccionProhibida ;
    rdfs:label "No se permite programar $GOTO en el mismo bloque con NR" ;
    ns1:textoExtracto "'NR: no se permite programar $GOTO en el mismo bloque'" .

ns1:NoSePermiteProgramarLlamadaASubrutinaEnElMismoBloqueConNR a ns1:AccionProhibida ;
    rdfs:label "No se permite programar llamada a subrutina en el mismo bloque con NR" ;
    ns1:textoExtracto "'NR: no se permite programar llamada a subrutina en el mismo bloque'" .

ns1:NoSePermiteProgramarMTDHEnElMismoBloqueConNR a ns1:AccionProhibida ;
    rdfs:label "No se permite programar M/T/D/H en el mismo bloque con NR" ;
    ns1:textoExtracto "'NR: no se permite programar M/T/D/H en el mismo bloque'" .

ns1:RevisarLaProgramacionDeTEnElBloqueConPOSYOMZ a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de T en el bloque con POS y/o MZ" ;
    ns1:solucionaFallo ns1:SeHaProgramadoPOSYOMZEnUnBloqueSinProgramarLaHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarLaProgramacionParaSolucionarFallosDeNR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para solucionar fallos de NR" ;
    ns1:solucionaFallo ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneAlgunaFuncionMTDOH,
        ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneLaInstruccionGOTO,
        ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneUnaLlamadaASubrutina,
        ns1:SeHaProgramadoUnNumeroNegativoDeRepeticionesDeBloqueNR ;
    ns1:textoExtracto "SOLUCIÓN La programación de la repetición de bloques con NR solo es válida con bloques que implican movimiento. La repetición de otro tipo de bloques deberá hacerse mediante las instrucciones de control de flujo que ofrece el control." .

ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneAlgunaFuncionMTDOH a ns1:DiagnosticoFallo ;
    rdfs:label "Hay programada una repetición de bloques (NR) en un bloque que contiene alguna función M, T, D o H" ;
    ns1:textoExtracto "CAUSA Hay programada una repetición de bloques (NR) en un bloque que contiene alguna función M, T, D o H." .

ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneLaInstruccionGOTO a ns1:DiagnosticoFallo ;
    rdfs:label "Hay programada una repetición de bloques (NR) en un bloque que contiene la instrucción $GOTO" ;
    ns1:textoExtracto "CAUSA Hay programada una repetición de bloques (NR) en un bloque que contiene la instrucción $GOTO." .

ns1:HayProgramadaUnaRepeticionDeBloquesNREnUnBloqueQueContieneUnaLlamadaASubrutina a ns1:DiagnosticoFallo ;
    rdfs:label "Hay programada una repetición de bloques (NR) en un bloque que contiene una llamada a subrutina" ;
    ns1:textoExtracto "CAUSA Hay programada una repetición de bloques (NR) en un bloque que contiene una llamada a una subrutina (L, LL, #CALL, #PCALL, #MCALL o G180-G189)." .

ns1:SeHaProgramadoPOSYOMZEnUnBloqueSinProgramarLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado POS y/o MZ en un bloque sin programar la herramienta" ;
    ns1:textoExtracto "CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta." .

ns1:SeHaProgramadoUnNumeroNegativoDeRepeticionesDeBloqueNR a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado un número negativo de repeticiones de bloque (NR)" ;
    ns1:textoExtracto "CAUSA Se ha programado un número negativo de repeticiones de bloque (NR)." .

