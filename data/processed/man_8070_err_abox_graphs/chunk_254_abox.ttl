@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltaDeProgramacionTEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de Programación T en el bloque" ;
    ns1:textoExtracto "1523 Falta programar T en el bloque. DETECCIÓN Durante la ejecución." .

ns1:ProgramacionCorrectaDePOSYMZ a ns1:TareaMantenimiento ;
    rdfs:label "Programación Correcta de POS y MZ" ;
    ns1:solucionaFallo ns1:ProgramacionDePOSYOMZSinHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta." .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de Programación" ;
    ns1:solucionaFallo ns1:NumeroNegativoDeRepeticionesDeBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NumeroNegativoDeRepeticionesDeBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Número negativo de repeticiones de bloque" ;
    ns1:textoExtracto "CAUSA Se ha programado un número negativo de repeticiones de bloque (NR). SOLUCIÓN Revisar la programación." .

ns1:ProgramacionDePOSYOMZSinHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de POS y/o MZ sin herramienta" ;
    ns1:textoExtracto "CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta." .

