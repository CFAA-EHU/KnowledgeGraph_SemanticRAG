@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstableceSiElEjeOCabezalTienePermisoParaCambiarDeCanal a ns1:Parametro ;
    rdfs:label "Establece si el eje o cabezal tiene permiso para cambiar de canal" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente" .

ns1:NoEstaPermitidoIntercambiarElEje a ns1:AccionProhibida ;
    rdfs:label "No está permitido intercambiar el eje" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'No está permitido intercambiar el eje'" .

ns1:ParaQueElCNCPuedaCambiarLosEjesYCabezalesDeCanalEstosDebenTenerPermiso a ns1:TareaMantenimiento ;
    rdfs:label "Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso" ;
    ns1:solucionaFallo ns1:FalloEjecucionCambioEje ;
    ns1:textoExtracto "Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso" .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:FalloEjecucionCambioEje a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentado cambiar un eje de canal y el eje no tiene permiso de cambio" ;
    ns1:textoExtracto "El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE) y el eje no tiene permiso de cambio (parámetro AXISEXCH)" .

