@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoSePermiteProgramarG53ConCoordenadasPolares_9ecb67160b a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite programar G53 con coordenadas polares" ;
    ns1:textoExtracto "'No se permite programar G53 con coordenadas polares' DETECCIÓN Durante la ejecución." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ElCanalIndicadoNoEsDeCNC,
        ns1:IdentificadorNoValidoTras_dd02615918,
        ns1:SeEsperaListaDeIdentificadoresOTrasComillasFinales_6b89fc219f ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElCanalIndicadoNoEsDeCNC a ns1:DiagnosticoFallo ;
    rdfs:label "El canal indicado no es de CNC" ;
    ns1:textoExtracto "'#EXEC: el canal indicado no es de CNC' DETECCIÓN Durante la ejecución. CAUSA Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que no es de CNC, sino de PLC." .

ns1:IdentificadorNoValidoTras_dd02615918 a ns1:DiagnosticoFallo ;
    rdfs:label "Identificador no válido tras %" ;
    ns1:textoExtracto "'Identificador no válido tras %' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #MSG, #ERROR, #WARNING o #WARNINGSTOP hay programado un identificador no válido." .

ns1:SeEsperaListaDeIdentificadoresOTrasComillasFinales_6b89fc219f a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera lista de identificadores o ']' tras comillas finales" ;
    ns1:textoExtracto "'Se espera lista de identificadores o ']' tras comillas finales' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #MSG, #ERROR, #WARNING o #WARNINGSTOP hay programado algún carácter no válido tras el mensaje a visualizar." .

