@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaSintaxisDeLaSentenciaEXBLK a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la sintaxis de la sentencia #EXBLK" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMas ;
    ns1:textoExtracto "SOLUCIÓN Programando respecto al cero máquina solo se pueden definir las cotas en coordenadas cartesianas." .

ns1:NoSePermiteProgramarG53ConCoordenadasPolares_10220bec81 a ns1:AccionProhibida ;
    rdfs:label "No se permite programar G53 con coordenadas polares" ;
    ns1:textoExtracto "'No se permite programar G53 con coordenadas polares'" .

ns1:ProgramandoRespectoAlCeroMaquinaSoloSePuedenDefinirLasCotasEnCoordena_5827a20eea a ns1:TareaMantenimiento ;
    rdfs:label "Programando respecto al cero máquina solo se pueden definir las cotas en coordenadas cartesianas" ;
    ns1:solucionaFallo ns1:EnLaFuncionG53LasCotasDelPuntoFinalEstanDefinidasEnCoordenadasPolares_5a5c53beef ;
    ns1:textoExtracto "SOLUCIÓN Programando respecto al cero máquina solo se pueden definir las cotas en coordenadas cartesianas." .

ns1:ProgramarEXBLKBloqueCanal a ns1:AccionProhibida ;
    rdfs:label "Programar: #EXBLK [bloque, canal]" ;
    ns1:textoExtracto "'Programar: #EXBLK [bloque, canal]'" .

ns1:EnLaFuncionG53LasCotasDelPuntoFinalEstanDefinidasEnCoordenadasPolares_5a5c53beef a ns1:DiagnosticoFallo ;
    rdfs:label "En la función G53, las cotas del punto final están definidas en coordenadas polares o cilíndricas" ;
    ns1:textoExtracto "CAUSA En la función G53, las cotas del punto final están definidas en coordenadas polares o cilíndricas." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMas a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más" .

