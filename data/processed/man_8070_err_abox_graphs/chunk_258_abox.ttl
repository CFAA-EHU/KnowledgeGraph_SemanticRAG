@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_eb9e55a532 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_41d94c0986,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_886ab25a8d,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_a4d019cc8d,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_cac2d6f81c,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_e399bdc995 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:UnCanalHaCedidoAlgunCabezalConPermisoDeCambioTemporalYNoSePuedeRecuperarlo a ns1:DiagnosticoFallo ;
    rdfs:label "Un canal ha cedido algún cabezal con permiso de cambio temporal y no se puede recuperarlo" ;
    ns1:textoExtracto "'No se puede recuperar algún cabezal del canal' DETECCIÓN Durante la ejecución. CAUSA Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_41d94c0986 a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #FREESP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_886ab25a8d a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #EXBLK [bloque, canal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_a4d019cc8d a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #MASTER <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_cac2d6f81c a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #CALLSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_e399bdc995 a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "'Programar: #SETSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

