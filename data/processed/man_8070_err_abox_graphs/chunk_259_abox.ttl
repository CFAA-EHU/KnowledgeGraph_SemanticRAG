@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CederCabezalConPermisoDeCambioTemporal a ns1:AccionProhibida ;
    rdfs:label "Ceder cabezal con permiso de cambio temporal" ;
    ns1:solucionaFallo ns1:CabezalNoRecuperado ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado." .

ns1:LiberacionDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Liberación del cabezal" ;
    ns1:solucionaFallo ns1:CabezalNoRecuperado ;
    ns1:textoExtracto "El otro canal cederá el cabezal con reset o con el inicio de otro programa. También es posible programar explícitamente la liberación del cabezal con la sentencia #FREE SP." .

ns1:PermisosDeCambioTemporalDeCabezal a ns1:Parametro ;
    rdfs:label "Permisos de cambio temporal de cabezal" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado." .

ns1:CabezalNoRecuperado a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal no recuperado" ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado." .

