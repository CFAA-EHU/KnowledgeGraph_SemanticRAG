@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_23a45b4c14 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:NoEstaPermitidoEliminarElCabezalConEjeCActivo,
        ns1:NoEstaPermitidoIntercambiarElCabezal,
        ns1:NombreDeCabezalRepetidoEnElGrupoResultante,
        ns1:ProgramacionNoPermitidaSinCabezalMasterEnElCanal ;
    ns1:textoExtracto "CNC 8070" .

ns1:DefinirUnCabezalMasterParaElCanal a ns1:TareaMantenimiento ;
    rdfs:label "Definir un cabezal master para el canal" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaSinCabezalMasterEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Definir un cabezal master para el canal." .

ns1:DesactivarEjeCAntesDeEliminarElCabezalDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar eje C antes de eliminar el cabezal del canal" ;
    ns1:solucionaFallo ns1:NoEstaPermitidoEliminarElCabezalConEjeCActivo ;
    ns1:textoExtracto "SOLUCIÓN Antes de eliminar el cabezal del canal desactivar el eje C." .

ns1:Parametro_d98a83957d a ns1:Parametro ;
    rdfs:label "Parámetro que establece si el eje o cabezal tiene permiso para cambiar de canal" ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente;" .

ns1:NoEstaPermitidoIntercambiarElCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "No está permitido intercambiar el cabezal" ;
    ns1:textoExtracto "'No está permitido intercambiar el cabezal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar un cabezal de canal (#CALL, #SET o #FREE) y el cabezal no tiene permiso de cambio (parámetro AXISEXCH)." .

ns1:NombreDeCabezalRepetidoEnElGrupoResultante a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de cabezal repetido en el grupo resultante" ;
    ns1:textoExtracto "'Nombre de cabezal repetido en el grupo resultante' DETECCIÓN Durante la ejecución. CAUSA La sentencia #RENAME ha intentado renombrar más de un cabezal con el mismo nombre." .

ns1:NoEstaPermitidoEliminarElCabezalConEjeCActivo a ns1:DiagnosticoFallo ;
    rdfs:label "No está permitido eliminar el cabezal con eje C activo" ;
    ns1:textoExtracto "'No está permitido eliminar el cabezal con eje C activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado eliminar del canal (#FREE o #SET) un cabezal que está trabajando como eje C." .

ns1:ProgramacionNoPermitidaSinCabezalMasterEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida sin cabezal master en el canal" ;
    ns1:textoExtracto "'Programación no permitida sin cabezal master en el canal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes:" .

