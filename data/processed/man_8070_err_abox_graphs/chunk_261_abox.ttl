@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoSeAdmiteG63YM3M4M5M19M41M44EnElMismoBloque a ns1:AccionProhibida ;
    rdfs:label "No se admite G63 y M3/M4/M5/M19/M41-M44 en el mismo bloque" ;
    ns1:textoExtracto "'No se admite G63 y M3/M4/M5/M19/M41-M44 en el mismo bloque'" .

ns1:PermiteCambiarDeCanalAlEjeOCabezal a ns1:Parametro ;
    rdfs:label "Permite cambiar de canal al eje o cabezal" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente;" .

ns1:SePuedeHacerEnElBloqueAnteriorOPosteriorSegunElResultadoQueSeQuiera a ns1:TareaMantenimiento ;
    rdfs:label "Se puede hacer en el bloque anterior o posterior según el resultado que se quiera" ;
    ns1:solucionaFallo ns1:NoSePermiteNingunaFuncionMAsociadaAlCabezalEnElMismoBloqueEnElQueSePr_e795b65ae4 ;
    ns1:textoExtracto "SOLUCIÓN Se puede hacer en el bloque anterior o posterior según el resultado que se quiera" .

ns1:NoSePermiteNingunaFuncionMAsociadaAlCabezalEnElMismoBloqueEnElQueSePr_e795b65ae4 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite ninguna función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63" ;
    ns1:textoExtracto "CAUSA No se permite ninguna función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63." .

