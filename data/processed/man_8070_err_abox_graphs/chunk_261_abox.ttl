@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1693
    a               ex:Alarma ;
    rdfs:label      "Alarma 1693: No se permite programar #RTCP con la actual cinemática"@es ;
    ex:identificador "1693" ;
    ex:textoExtracto "1693 'No se permite programar #RTCP con la actual cinemática. Programar #FACE o #CYL'"@es ;
    ex:activaAlarma ex:DiagnosticoFallo_1693 .

ex:DiagnosticoFallo_1693
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo de programación: Sentencia #RTCP no admitida con cinemática actual"@es ;
    ex:textoExtracto "CAUSA La sentencia no es admisible con la actual cinemática. SOLUCIÓN Programar la sentencia #FACE ó #CYL para activar dicha transformada."@es ;
    ex:solucionaFallo ex:AccionProhibida_1693_RTCP .

ex:AccionProhibida_1693_RTCP
    a               ex:AccionProhibida ;
    rdfs:label      "Programación de #RTCP con cinemática incompatible"@es ;
    ex:textoExtracto "No se permite programar #RTCP con la actual cinemática"@es .

ex:Parametro_G174
    a               ex:Parametro ;
    rdfs:label      "Parámetro G174 (cota)"@es ;
    ex:identificador "G174" ;
    ex:textoExtracto "La cota programada en G174 está fuera de rango"@es .

ex:Alarma_1694
    a               ex:Alarma ;
    rdfs:label      "Alarma 1694: Cota fuera de rango en G174"@es ;
    ex:identificador "1694" ;
    ex:textoExtracto "1694 Cota fuera de rango en G174"@es ;
    ex:activaAlarma ex:DiagnosticoFallo_1694 .

ex:DiagnosticoFallo_1694
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo de programación: Cota en G174 fuera de rango"@es ;
    ex:textoExtracto "CAUSA La cota programada en G174 está fuera de rango."@es ;
    ex:solucionaFallo ex:Parametro_G174 .