@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1694
    a ex:Alarma ;
    rdfs:label "Alarma 1694: Cota fuera de rango en G174"@es ;
    ex:textoExtracto "1694 Cota fuera de rango en G174. DETECCIÓN Durante la ejecución. CAUSA La cota programada en G174 está fuera de rango. SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647."@es ;
    ex:identificador "1694" .

ex:Alarma_1695
    a ex:Alarma ;
    rdfs:label "Alarma 1695: Sintaxis incorrecta en #SWTOUT"@es ;
    ex:textoExtracto "1695 Programar #SWTOUT ON [<TONvalor> <,TOFvalor> <,PONvalor> <,POFvalo> <,G0/G1>] /OFF. DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1695" .

ex:Alarma_1696
    a ex:Alarma ;
    rdfs:label "Alarma 1696: Borrado de subrutinas *.fst en ejecución"@es ;
    ex:textoExtracto "1696 No se pueden borrar subrutinas *.fst cuando una de ellas está en ejecución. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una subrutina fst mientras está en ejecución. SOLUCIÓN Esperar a que finaliza la ejecución del programa."@es ;
    ex:identificador "1696" .

ex:Alarma_1697
    a ex:Alarma ;
    rdfs:label "Alarma 1697: Programación incorrecta de #CSROT"@es ;
    ex:textoExtracto "1697 'Programar #CSROT [ON]/OFF' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1697" .

ex:Alarma_1698
    a ex:Alarma ;
    rdfs:label "Alarma 1698: Programación incorrecta de #DEFROT"@es ;
    ex:textoExtracto "1698 'Programar #DEFROT [actuación, criterio, ángulo]' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1698" .

ex:Alarma_1699
    a ex:Alarma ;
    rdfs:label "Alarma 1699: CSROT no aplicable a cinemáticas manuales"@es ;
    ex:textoExtracto "1699 'La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos de la cinemática tienen que ser servocontrolados de forma continua. SOLUCIÓN Desactivar la sentencia #CSROT."@es ;
    ex:identificador "1699" .

ex:Alarma_1700
    a ex:Alarma ;
    rdfs:label "Alarma 1700: Avance (F) no programado en punteado"@es ;
    ex:textoExtracto "1700 'PUNTEADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:identificador "1700" .

ex:Alarma_1701
    a ex:Alarma ;
    rdfs:label "Alarma 1701: Velocidad (S) no programada en punteado"@es ;
    ex:textoExtracto "1701 'PUNTEADO: S = 0' DETECCIÓN Durante la ejecución del ciclo."@es ;
    ex:identificador "1701" .

ex:Parametro_G174
    a ex:Parametro ;
    rdfs:label "Parámetro G174 (cota)"@es ;
    ex:textoExtracto "La cota programada en G174 está fuera de rango"@es ;
    ex:identificador "G174" ;
    ex:valor "±2147483647"^^xsd:string .

ex:Parametro_F
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ex:textoExtracto "El parámetro F tiene valor 0. No hay avance programado"@es ;
    ex:identificador "F" .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ex:textoExtracto "PUNTEADO: S = 0"@es ;
    ex:identificador "S" .

ex:DiagnosticoFallo_1694
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Cota G174 fuera de rango"@es ;
    ex:textoExtracto "CAUSA La cota programada en G174 está fuera de rango. SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647."@es ;
    ex:solucionaFallo ex:Alarma_1694 .

ex:DiagnosticoFallo_1695
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Sintaxis incorrecta en #SWTOUT"@es ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1695 .

ex:DiagnosticoFallo_1699
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: CSROT no compatible con ejes manuales"@es ;
    ex:textoExtracto "CAUSA Los ejes rotativos de la cinemática tienen que ser servocontrolados de forma continua. SOLUCIÓN Desactivar la sentencia #CSROT."@es ;
    ex:solucionaFallo ex:Alarma_1699 .