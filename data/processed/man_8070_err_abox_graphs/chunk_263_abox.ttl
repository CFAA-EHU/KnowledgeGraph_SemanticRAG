ex:DiagnosticoFallo_1701_F
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta avance programado (F=0)"@es ;
    ex:textoExtracto "CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:solucionaFallo ex:AvisoSeguridad_1701_F .

