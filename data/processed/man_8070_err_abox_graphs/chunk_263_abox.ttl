ex:AvisoSeguridad_1701_F
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1701: Punteado (F = 0)"@es ;
    ex:identificador "1701" ;
    ex:textoExtracto "1701 'PUNTEADO: S = 0' [...] CAUSA El parámetro F tiene valor 0. No hay avance programado."@es ;
    ex:monitoreaParametro ex:Parametro_F_1701 .

