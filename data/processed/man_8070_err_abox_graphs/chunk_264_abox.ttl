@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElNombreDeLaVariableDebeComenzarPorV a ns1:DiagnosticoFallo ;
    rdfs:label "'El nombre de la variable debe comenzar por \"V.\"'" ;
    ns1:solucionaFallo ns1:AnadirElPrefijoVAlNombreDeLaVariable ;
    ns1:textoExtracto "'El nombre de la variable debe comenzar por \"V.\"' DETECCIÓN Durante la ejecución. CAUSA Desde programa pieza o MDI se ha escrito el nombre de una variable sin el prefijo inicial \"V.\"" .

ns1:ImbricacionDeParametrosLocalesSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "'Imbricación de parámetros locales sobrepasado'" ;
    ns1:solucionaFallo ns1:ReducirElAnidamientoDeSubrutinasOUtilizarLasSentenciasCALLLOLLParaLlamarlas ;
    ns1:textoExtracto "'Imbricación de parámetros locales sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El anidamiento de llamadas a subrutinas mediante la sentencia #PCALL o mediante la función G180-G189 aumenta el nivel de imbricación de parámetros locales." .

ns1:NoSeAdmiteProgramarDosEjesCEnElMismoCanal a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite programar dos ejes C en el mismo canal'" ;
    ns1:solucionaFallo ns1:DesactivarUnEjeCAntesDeActivarOtro ;
    ns1:textoExtracto "'No se admite programar dos ejes C en el mismo canal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un eje C con otro activo." .

ns1:NombreDeCajeraNuloOIncorrecto_9f1e1f5887 a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de cajera nulo o incorrecto" ;
    ns1:solucionaFallo ns1:AsignarleUnNombreDistintoALaCajera ;
    ns1:textoExtracto "'Nombre de cajera nulo o incorrecto' DETECCIÓN Durante la ejecución. CAUSA Cuando se ha definido una cajera 2D ó 3D con el editor de ciclos, no se ha definido el nombre de la cajera o este nombre es incorrecto." .

ns1:NumeroDeVariablesDeUsuarioSobrepasado_2f9cf2c4d3 a ns1:DiagnosticoFallo ;
    rdfs:label "'Número de variables de usuario sobrepasado'" ;
    ns1:solucionaFallo ns1:ElMaximoNumeroDeVariablesDeUsuarioPermitidoEs20 ;
    ns1:textoExtracto "'Número de variables de usuario sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el máximo número de variables de usuario (prefijos P y S) permitidas." .

ns1:AnadirElPrefijoVAlNombreDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Añadir el prefijo \"V.\" al nombre de la variable" ;
    ns1:textoExtracto "SOLUCIÓN Añadir el prefijo \"V.\" al nombre de la variable." .

ns1:AsignarleUnNombreDistintoALaCajera a ns1:TareaMantenimiento ;
    rdfs:label "Asignarle un nombre distinto a la cajera" ;
    ns1:textoExtracto "SOLUCIÓN Asignarle un nombre distinto a la cajera." .

ns1:DesactivarUnEjeCAntesDeActivarOtro a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar un eje C antes de activar otro" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar un eje C antes de activar otro." .

ns1:ElMaximoNumeroDeVariablesDeUsuarioPermitidoEs20 a ns1:TareaMantenimiento ;
    rdfs:label "El máximo número de variables de usuario permitido es 20" ;
    ns1:textoExtracto "SOLUCIÓN El máximo número de variables de usuario permitido es 20." .

ns1:ReducirElAnidamientoDeSubrutinasOUtilizarLasSentenciasCALLLOLLParaLlamarlas a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el anidamiento de subrutinas o utilizar las sentencias #CALL, L o LL para llamarlas" ;
    ns1:textoExtracto "SOLUCIÓN Reducir el anidamiento de subrutinas o utilizar las sentencias #CALL, L o LL para llamarlas, que no aumentan el nivel de imbricación de parámetros locales." .

