@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarElProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el programa de PLC" ;
    ns1:solucionaFallo ns1:ElPLCNoHaReconocidoElSTARTEnUnaInstruccionEXEC_3d90366421 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC." .

ns1:ReducirNumeroDeVariablesDeUsuario a ns1:TareaMantenimiento ;
    rdfs:label "Reducir número de variables de usuario" ;
    ns1:solucionaFallo ns1:NumeroDeVariablesDeUsuarioSobrepasado_2f9cf2c4d3 ;
    ns1:textoExtracto "SOLUCIÓN El máximo número de variables de usuario permitido es 20." .

ns1:ElPLCNoHaReconocidoElSTARTEnUnaInstruccionEXEC_3d90366421 a ns1:DiagnosticoFallo ;
    rdfs:label "El PLC no ha reconocido el START en una instrucción #EXEC" ;
    ns1:textoExtracto "'El PLC no ha reconocido el START en una instrucción #EXEC' DETECCIÓN Durante la ejecución. CAUSA Cuando se va a dar la orden de ejecución de un programa en otro canal, el PLC debe dar el visto bueno al arranque de programa (START). Si no lo da se generará este error." .

ns1:NumeroDeVariablesDeUsuarioSobrepasado_2f9cf2c4d3 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de variables de usuario sobrepasado" ;
    ns1:textoExtracto "'Número de variables de usuario sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el máximo número de variables de usuario (prefijos P y S) permitidas." .

