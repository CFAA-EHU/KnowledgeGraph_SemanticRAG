ex:AvisoSeguridad_1713
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1713: TALADRADO 2 (P = 0)" ;
    ex:identificador "1713" ;
    ex:textoExtracto "'TALADRADO 2: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:mitigaRiesgo ex:Parametro_P_Taladrado .

