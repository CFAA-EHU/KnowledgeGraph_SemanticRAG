@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:monitoreaParametro ns1:ParametrosDeLlamadaEntreCorchetes ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaFOLLOWEsIncorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ValidarEjeEsclavo a ns1:TareaMantenimiento ;
    rdfs:label "Validar eje esclavo" ;
    ns1:solucionaFallo ns1:ElEjeEsclavoNoValido ;
    ns1:textoExtracto "SOLUCIÓN El eje debe pertenecer al canal." .

ns1:ValidarEjeMaestro a ns1:TareaMantenimiento ;
    rdfs:label "Validar eje maestro" ;
    ns1:solucionaFallo ns1:ElEjeMaestroEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN El eje debe pertenecer al canal." .

ns1:ElEjeEsclavoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "El eje esclavo no válido" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto." .

ns1:ElEjeMaestroEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "El eje maestro es incorrecto" ;
    ns1:textoExtracto "CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto." .

ns1:LaSintaxisDeLaSentenciaFOLLOWEsIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia #FOLLOW es incorrecta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia #FOLLOW es incorrecta." .

ns1:ParametrosDeLlamadaEntreCorchetes a ns1:Parametro ;
    rdfs:label "Parámetros de llamada entre corchetes" ;
    ns1:textoExtracto "junto a la sentencia hay que programar uno de los comandos ON/OFF y a continuación los parámetros de llamada entre corchetes." .

