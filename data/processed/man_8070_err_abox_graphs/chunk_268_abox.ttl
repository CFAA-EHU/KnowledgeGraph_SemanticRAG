ex:Alarma_1722
    a ex:Alarma ;
    rdfs:label "Alarma 1722: ESCARIADO P=0" ;
    ex:identificador "1722" ;
    ex:textoExtracto "1722 'ESCARIADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." ;
    ex:monitoreaParametro ex:Parametro_Profundidad_Escariado .

