@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0a75057756 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC ejecuta su subrutina asociada (parámetro REFPSUB)." .

ns1:SolucionAlFalloDeEjeAparcado a ns1:TareaMantenimiento ;
    rdfs:label "Solución al fallo de eje aparcado" ;
    ns1:solucionaFallo ns1:NoSePuedeProgramarUnEjeAparcado ;
    ns1:textoExtracto "La instrucción programada no se puede ejecutar sobre un eje aparcado." .

ns1:SolucionAlFalloDeEjeEsclavoIncorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Solución al fallo de eje esclavo incorrecto" ;
    ns1:solucionaFallo ns1:EjeEsclavoIncorrecto ;
    ns1:textoExtracto "El eje debe pertenecer al canal." .

ns1:SolucionAlFalloDeEjeMaestroIncorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Solución al fallo de eje maestro incorrecto" ;
    ns1:solucionaFallo ns1:EjeMaestroIncorrecto ;
    ns1:textoExtracto "El eje debe pertenecer al canal." .

ns1:SolucionAlFalloDeProgramacionIncorrectaDeLaFuncionG74 a ns1:TareaMantenimiento ;
    rdfs:label "Solución al fallo de programación incorrecta de la función G74" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeLaFuncionG74 ;
    ns1:textoExtracto "La función G74 se puede programar bien con los ejes cuya búsqueda de cero se quiere realizar o bien sola en el bloque." .

ns1:SubrutinaAsociadaDeLaFuncionG74 a ns1:Parametro ;
    rdfs:label "Subrutina asociada de la función G74" ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "el CNC ejecuta su subrutina asociada (parámetro REFPSUB)." .

ns1:EjeEsclavoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Eje esclavo incorrecto" ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje esclavo es incorrecto. SOLUCIÓN El eje debe pertenecer al canal." .

ns1:EjeMaestroIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Eje maestro incorrecto" ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto. SOLUCIÓN El eje debe pertenecer al canal." .

ns1:NoSePuedeProgramarUnEjeAparcado a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar un eje aparcado" ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA La instrucción programada no se puede ejecutar sobre un eje aparcado." .

ns1:ProgramacionIncorrectaDeLaFuncionG74 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de la función G74" ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la función G74. SOLUCIÓN La función G74 se puede programar bien con los ejes cuya búsqueda de cero se quiere realizar o bien sola en el bloque." .

