    ns1:identificador "1565" ;
    ns1:textoExtracto "'El cabezal no puede funcionar como eje C, CAXIS = No'" .

ns1:LaInstruccionProgramadaNoSePuedeEjecutarSobreUnEjeAparcado a ns1:DiagnosticoFallo ;
    rdfs:label "La instrucción programada no se puede ejecutar sobre un eje aparcado" ;
    ns1:textoExtracto "CAUSA La instrucción programada no se puede ejecutar sobre un eje aparcado. SOLUCIÓN Revisar la programación." .

