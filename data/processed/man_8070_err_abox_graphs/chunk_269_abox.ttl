    ns1:solucionaFallo ns1:NoSeAdmiteImagenEspejoConEjesUNIDIR ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el tipo de eje o no programar la imagen espejo." .

ns1:ElRadioPolarSoloSePuedeProgramarConR a ns1:DiagnosticoFallo ;
    rdfs:label "El radio polar sólo se puede programar con R" ;
    ns1:identificador "1567" ;
    ns1:textoExtracto "'El radio polar sólo se puede programar con R'" .

ns1:Parametro_7729406c0f a ns1:Parametro ;
    rdfs:label "parámetro UNIDIR" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "(parámetro UNIDIR)" .

ns1:RevisarLaProgramacionDelCabezal a ns1:TareaMantenimiento ;
