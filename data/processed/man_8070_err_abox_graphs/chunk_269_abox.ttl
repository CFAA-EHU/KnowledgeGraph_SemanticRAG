    ns1:solucionaFallo ns1:LaInstruccionProgramadaNoSePuedeEjecutarSobreUnEjeAparcado ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElCabezalNoPuedeFuncionarComoEjeCCAXISNo a ns1:DiagnosticoFallo ;
