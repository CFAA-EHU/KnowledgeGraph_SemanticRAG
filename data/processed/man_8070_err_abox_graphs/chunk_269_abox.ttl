@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

### Diagnósticos de fallo en ciclos de mecanizado
ex:Fallo_1729
    a ex:DiagnosticoFallo ;
    rdfs:label "TALADRADO 3: T = 0" ;
    ex:identificador "1729" ;
    ex:textoExtracto "1729 'TALADRADO 3: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_T_1729 .

ex:Fallo_1730
    a ex:DiagnosticoFallo ;
    rdfs:label "TALADRADO 3: P = 0" ;
    ex:identificador "1730" ;
    ex:textoExtracto "1730 'TALADRADO 3: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_P_1730 .

ex:Fallo_1731
    a ex:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: F = 0" ;
    ex:identificador "1731" ;
    ex:textoExtracto "1731 'MANDRINADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_F_1731 .

ex:Fallo_1732
    a ex:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: S = 0" ;
    ex:identificador "1732" ;
    ex:textoExtracto "1732 'MANDRINADO 2: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_S_1732 .

### Parámetros asociados a los fallos
ex:Parametro_T_1729
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)" ;
    ex:identificador "T" ;
    ex:valor "0" ;
    ex:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada." .

ex:Parametro_P_1730
    a ex:Parametro ;
    rdfs:label "Parámetro P (profundidad)" ;
    ex:identificador "P" ;
    ex:valor "0" ;
    ex:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." .

ex:Parametro_F_1731
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ex:identificador "F" ;
    ex:valor "0" ;
    ex:textoExtracto "El parámetro F tiene valor 0. No hay avance programado." .

ex:Parametro_S_1732
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)" ;
    ex:identificador "S" ;
    ex:valor "0" ;
    ex:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada." .