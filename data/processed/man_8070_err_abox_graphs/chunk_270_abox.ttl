    ex:valor "0" .

ex:DiagnosticoFallo_ParametroCero
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Parámetro con valor cero en ciclo" ;
    ex:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Alarma_1732, ex:Alarma_1733, ex:Alarma_1734, ex:Alarma_1735, ex:Alarma_1736 .