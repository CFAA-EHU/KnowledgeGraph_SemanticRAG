@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RadioDeMovimientoEnCoordenadasPolares a ns1:Parametro ;
    rdfs:label "Radio de movimiento en coordenadas polares" ;
    ns1:identificador "R1" ;
    ns1:textoExtracto "'El radio polar sólo se puede programar con R' CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263." .

ns1:RadioPolar a ns1:Parametro ;
    rdfs:label "Radio polar" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "'El radio polar sólo se puede programar con R' SOLUCIÓN Programar el radio polar con el parámetro R." .

ns1:SistemaCNC8070_f7c9b69ec2 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:activaAlarma ns1:FalloEjecucionCanalPLC,
        ns1:FalloNumeroAlmacen,
        ns1:FalloRadioPolar ;
    ns1:textoExtracto "Sistema CNC 8070" .

ns1:SolucionNumeroAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Solución para número de almacén incorrecto" ;
    ns1:textoExtracto "'Número de almacén incorrecto' SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4." .

ns1:FalloEjecucionCanalPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Ejecución no permitida, el canal es exclusivo de PLC" ;
    ns1:textoExtracto "'Ejecución no permitida, el canal es exclusivo de PLC' DETECCIÓN Durante la ejecución." .

ns1:FalloNumeroAlmacen a ns1:DiagnosticoFallo ;
    rdfs:label "Número de almacén incorrecto" ;
    ns1:textoExtracto "'Número de almacén incorrecto' DETECCIÓN Durante la ejecución. CAUSA El número de almacén programado en el comando MZ no es válido." .

ns1:FalloRadioPolar a ns1:DiagnosticoFallo ;
    rdfs:label "Error de radio polar" ;
    ns1:textoExtracto "'El radio polar sólo se puede programar con R' DETECCIÓN Durante la ejecución. CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263." .

