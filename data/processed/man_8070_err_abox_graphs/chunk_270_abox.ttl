@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1732
    a ex:Alarma ;
    rdfs:label "Alarma 1732: MANDRINADO 2 - S = 0" ;
    ex:textoExtracto "1732 'MANDRINADO 2: S = 0' [...] CAUSA El parámetro S tiene valor 0. No hay velocidad programada." ;
    ex:monitoreaParametro ex:Parametro_S_1732 .

ex:Parametro_S_1732
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad) en mandrinado 2" ;
    ex:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada." ;
    ex:valor "0" .

ex:Alarma_1733
    a ex:Alarma ;
    rdfs:label "Alarma 1733: MANDRINADO 2 - T = 0" ;
    ex:textoExtracto "1733 'MANDRINADO 2: T = 0' [...] CAUSA El parámetro T tiene valor 0. No hay herramienta programada." ;
    ex:monitoreaParametro ex:Parametro_T_1733 .

