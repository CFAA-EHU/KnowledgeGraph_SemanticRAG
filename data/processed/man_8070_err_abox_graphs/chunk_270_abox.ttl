ex:Alarma_1735
    a ex:Alarma ;
    rdfs:label "Alarma 1735: CAJERA RECTANGULAR - F = 0" ;
    ex:textoExtracto "1735 'CAJERA RECTANGULAR: F = 0' [...] CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." ;
    ex:monitoreaParametro ex:Parametro_F_1735 .

ex:Parametro_F_1735
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance) en cajera rectangular" ;
    ex:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." ;
    ex:valor "0" .

ex:Alarma_1736
    a ex:Alarma ;
    rdfs:label "Alarma 1736: CAJERA RECTANGULAR - S = 0" ;
    ex:textoExtracto "1736 'CAJERA RECTANGULAR: S = 0' [...] CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." ;
    ex:monitoreaParametro ex:Parametro_S_1736 .

ex:Parametro_S_1736
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad) en cajera rectangular" ;
    ex:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." ;
    ex:valor "0" .

ex:Alarma_1737
    a ex:Alarma ;
    rdfs:label "Alarma 1737: CAJERA RECTANGULAR - T = 0" ;
    ex:textoExtracto "1737 'CAJERA RECTANGULAR: T = 0' [...] CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." ;
    ex:monitoreaParametro ex:Parametro_T_1737 .

ex:Parametro_T_1737
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta) en cajera rectangular" ;
