    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta) en mandrinado 2" ;
    ex:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada." ;
    ex:valor "0" .

ex:Alarma_1734
    a ex:Alarma ;
    rdfs:label "Alarma 1734: MANDRINADO 2 - P = 0" ;
    ex:textoExtracto "1734 'MANDRINADO 2: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada." ;
    ex:monitoreaParametro ex:Parametro_P_1734 .

