@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error1738
    a               ex:AvisoSeguridad ;
    rdfs:label      "CAJERA RECTANGULAR: P = 0"@es ;
    ex:identificador "1738" ;
    ex:textoExtracto "1738 'CAJERA RECTANGULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ex:Error1739
    a               ex:AvisoSeguridad ;
    rdfs:label      "CAJERA RECTANGULAR: Diámetro de herramienta menor que DELTA"@es ;
    ex:identificador "1739" ;
    ex:textoExtracto "1739 'CAJERA RECTANGULAR: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o"@es .

ex:ParametroP
    a               ex:Parametro ;
    rdfs:label      "Profundidad de fresado (P)"@es ;
    ex:identificador "P" ;
    ex:valor         "0" ;
    ex:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ex:mitigaRiesgo  ex:Error1738 .

ex:ParametroDelta
    a               ex:Parametro ;
    rdfs:label      "Paso de fresado (Δ)"@es ;
    ex:identificador "Δ" ;
    ex:textoExtracto "el paso de fresado (parámetro Δ)"@es ;
    ex:monitoreaParametro ex:Error1739 .

ex:HerramientaFresado
    a               ex:Herramienta ;
    rdfs:label      "Herramienta de fresado"@es ;
    ex:textoExtracto "Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es ;
    ex:requiereMantenimiento [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Programación de herramienta"@es ;
        ex:textoExtracto "Programar una herramienta para la operación de desbaste o acabado."@es
    ] ;
    ex:solucionaFallo ex:Error1739 .