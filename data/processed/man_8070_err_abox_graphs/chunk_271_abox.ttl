@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeCanalParaEjecucionManual a ns1:AvisoSeguridad ;
    rdfs:label "Configuración de canal para ejecución manual" ;
    ns1:mitigaRiesgo ns1:EjecucionManualEnCanalPLC ;
    ns1:textoExtracto "Si se desea ejecutar dichas acciones en ese canal habrá que configurarlo como canal de CNC o de CNC+PLC (parámetro CHTYPE)." .

ns1:NumeroDeAlmacenNoValido_f676adec39 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de almacén no válido" ;
    ns1:textoExtracto "El número de almacén debe ser un valor entre 1 y 4." .

ns1:RevisarProgramacion_831cb0a56d a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:MovimientoDelCabezalConG74,
        ns1:UsoDelCaracterEnSubrutinaGlobal ;
    ns1:textoExtracto "Revisar la programación." .

ns1:EjecucionManualEnCanalPLC a ns1:AccionProhibida ;
    rdfs:label "Ejecución manual en canal PLC" ;
    ns1:textoExtracto "el CNC no tiene permiso para ejecutar en él programas, bloques de MDI, movimientos de jog o cualquier otra acción desde el modo manual." .

ns1:MovimientoDelCabezalConG74 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento del cabezal con G74" ;
    ns1:textoExtracto "En el mismo bloque hay programada una función M de movimiento de cabezal y la función G74 de búsqueda de cero." .

ns1:UsoDelCaracterEnSubrutinaGlobal a ns1:AccionProhibida ;
    rdfs:label "Uso del carácter '%' en subrutina global" ;
    ns1:textoExtracto "No se admite el carácter \"%\" dentro de subrutina global." .

