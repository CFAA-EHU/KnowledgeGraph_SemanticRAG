@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_5d470e10db a ns1:AvisoSeguridad ;
    rdfs:label "Parámetro no modificable desde el oscilo" ;
    ns1:textoExtracto "'Parámetro no modificable desde el oscilo' DETECCIÓN Durante la ejecución." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ResetearElControlYVolverACapturarLaTraza a ns1:TareaMantenimiento ;
    rdfs:label "Resetear el control y volver a capturar la traza" ;
    ns1:solucionaFallo ns1:ErrorCapturandoMuestrasDeLaVariable ;
    ns1:textoExtracto "SOLUCIÓN Resetear el control y volver a capturar la traza." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:NoSeAdmiteElCaracterDentroDeSubrutinaGlobal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:VariableSoloAccesibleParaSuCanal a ns1:AvisoSeguridad ;
    rdfs:label "Variable sólo accesible para su canal" ;
    ns1:textoExtracto "'Variable sólo accesible para su canal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acceder a una variable de preparación de herramienta de otro canal (prefijo \"G\" o \"A\"). SOLUCIÓN Las únicas variables de herramientas accesibles desde otro canal son las asociadas al gestor (prefijo \"TM\")." .

ns1:ErrorCapturandoMuestrasDeLaVariable a ns1:AvisoSeguridad ;
    rdfs:label "Error capturando muestras de la variable" ;
    ns1:textoExtracto "'Error capturando muestras de la variable' DETECCIÓN Durante la ejecución. CAUSA Se ha producido un error mientras el osciloscopio intentaba leer el valor de la variable asignada a uno de sus canales." .

ns1:NoSeAdmiteElCaracterDentroDeSubrutinaGlobal a ns1:AvisoSeguridad ;
    rdfs:label "No se admite el carácter '%' dentro de subrutina global" ;
    ns1:textoExtracto "'No se admite el carácter \"%\" dentro de subrutina global' DETECCIÓN Durante la ejecución. CAUSA Hay programado el carácter \"%\" dentro de una subrutina global, en una línea diferente a la de la definición del nombre de la subrutina." .

