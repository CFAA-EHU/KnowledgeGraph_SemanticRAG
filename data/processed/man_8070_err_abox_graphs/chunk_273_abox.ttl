@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarElParametroDesdeLaTablaDeParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el parámetro desde la tabla de parámetros máquina" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_d953c194e2 ;
    ns1:textoExtracto "SOLUCIÓN Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina." .

ns1:Parametro_802e53300e a ns1:Parametro ;
    rdfs:label "Parámetro máquina que no tiene permiso de escritura" ;
    ns1:identificador "Parámetro no modificable desde el oscilo" ;
    ns1:textoExtracto "'Parámetro no modificable desde el oscilo' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado modificar desde la pantalla del osciloscopio un parámetro máquina que no tiene permiso de escritura." .

ns1:SentenciaSoloValidaEnProgramasConExtensionFBS a ns1:Parametro ;
    rdfs:label "Sentencia que solo es válida en programas con extensión FBS" ;
    ns1:identificador "Sentencia sólo válida en programas con extensión FBS" ;
    ns1:textoExtracto "'Sentencia sólo válida en programas con extensión FBS' DETECCIÓN Durante la ejecución. CAUSA" .

ns1:DiagnosticoFallo_d953c194e2 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no modificable desde el oscilo" ;
    ns1:textoExtracto "'Parámetro no modificable desde el oscilo' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado modificar desde la pantalla del osciloscopio un parámetro máquina que no tiene permiso de escritura." .

