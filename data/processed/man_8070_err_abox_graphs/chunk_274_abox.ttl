@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_a713a5890e a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro sólo se puede modificar desde la tabla de parámetros máquina" ;
    ns1:textoExtracto "'Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina.'" .

ns1:LINKUnEjeEsclavoUNIDIRDebeSerDelMismoTipoQueElMaestroUNIDIR a ns1:DiagnosticoFallo ;
    rdfs:label "#LINK: Un eje esclavo UNIDIR debe ser del mismo tipo que el maestro (UNIDIR)" ;
    ns1:textoExtracto "'#LINK: Un eje esclavo UNIDIR debe ser del mismo tipo que el maestro (UNIDIR)'" .

ns1:Parametro_3609f54e2e a ns1:Parametro ;
    rdfs:label "Parámetro de tipo de sincronización en la sentencia #FOLLOW" ;
    ns1:textoExtracto "'El parámetro que define el tipo de sincronización en la sentencia #FOLLOW es incorrecto.'" .

ns1:RevisarLaProgramacion_1f58372060 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NoSeEspera_54f7320a6c,
        ns1:ProgramarTipoDeSincronizacionVELOPOS ;
    ns1:textoExtracto "Revisar la programación" .

ns1:SentenciaSoloValidaEnProgramasConExtensionFBS_c87c4f895b a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia sólo válida en programas con extensión FBS" ;
    ns1:textoExtracto "'Sentencia sólo válida en programas con extensión FBS'" .

ns1:NoSeEspera_54f7320a6c a ns1:DiagnosticoFallo ;
    rdfs:label "No se espera ']'" ;
    ns1:textoExtracto "'No se espera ']''" .

ns1:ProgramarTipoDeSincronizacionVELOPOS a ns1:DiagnosticoFallo ;
    rdfs:label "Programar tipo de sincronización: VEL o POS" ;
    ns1:textoExtracto "'Programar tipo de sincronización: VEL o POS'" .

