@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarElEjeCAntesDeEliminarloDeLaConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el eje C antes de eliminarlo de la configuración" ;
    ns1:solucionaFallo ns1:NoEstaPermitidoEliminarUnEjeCActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el eje C antes de eliminarlo de la configuración." .

ns1:ProgramarM19AntesDeActivarElCabezalComoEjeC a ns1:TareaMantenimiento ;
    rdfs:label "Programar M19 antes de activar el cabezal como eje C" ;
    ns1:solucionaFallo ns1:NecesitaProgramacionPreviaDeM19EnSercosDePosicion ;
    ns1:textoExtracto "SOLUCIÓN Programar M19 antes de activar el cabezal como eje C." .

ns1:NecesitaProgramacionPreviaDeM19EnSercosDePosicion a ns1:DiagnosticoFallo ;
    rdfs:label "Necesita programación previa de M19 en Sercos de posición" ;
    ns1:textoExtracto "'#CAX: Necesita programación previa de M19 en Sercos de posición' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer activar un cabezal Sercos como eje C sin posicionarlo previamente con M19." .

ns1:NoEstaPermitidoEliminarUnEjeCActivo a ns1:DiagnosticoFallo ;
    rdfs:label "No está permitido eliminar un eje C activo" ;
    ns1:textoExtracto "'No está permitido eliminar un eje C activo' DETECCIÓN Durante la ejecución. CAUSA Las sentencias #SET AX y #FREE AX no pueden eliminar el eje C de la configuración si está activo." .

