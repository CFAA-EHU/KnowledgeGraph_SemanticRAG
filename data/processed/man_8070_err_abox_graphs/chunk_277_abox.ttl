@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DobleProgramacionDelNumeroDeRepeticiones a ns1:AccionProhibida ;
    rdfs:label "Doble programación del número de repeticiones" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacionParaElError1582 ;
    ns1:textoExtracto "'NR: doble programación del número de repeticiones'" .

ns1:EliminarEjeCDeLaConfiguracion a ns1:AccionProhibida ;
    rdfs:label "Eliminar eje C de la configuración" ;
    ns1:solucionaFallo ns1:DesactivarEjeCAntesDeEliminarloDeLaConfiguracion ;
    ns1:textoExtracto "pueden eliminar el eje C de la configuración si está activo." .

ns1:FOLLOWONElEjeMaestroYEsclavoNoPuedenSerIguales a ns1:AccionProhibida ;
    rdfs:label "#FOLLOW ON: el eje maestro y esclavo no pueden ser iguales" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacionParaElError1583 ;
    ns1:textoExtracto "'#FOLLOW ON: el eje maestro y esclavo no pueden ser iguales'" .

ns1:FOLLOWONElNumeradorYDenominadorDebenSerNumerosEnteros a ns1:AccionProhibida ;
    rdfs:label "#FOLLOW ON: el numerador y denominador deben ser números enteros" ;
    ns1:solucionaFallo ns1:ProgramarNumerosEnterosEnLosParametrosQueDefinenElNumeradorYDenominad_8c6a5696cb ;
    ns1:textoExtracto "'#FOLLOW ON: el numerador y denominador deben ser números enteros'" .

ns1:DesactivarEjeCAntesDeEliminarloDeLaConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar eje C antes de eliminarlo de la configuración" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el eje C antes de eliminarlo de la configuración." .

ns1:ProgramarNumerosEnterosEnLosParametrosQueDefinenElNumeradorYDenominad_8c6a5696cb a ns1:TareaMantenimiento ;
    rdfs:label "Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión" ;
    ns1:textoExtracto "SOLUCIÓN Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión." .

ns1:RevisarLaProgramacionParaElError1582 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para el error 1582" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarLaProgramacionParaElError1583 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para el error 1583" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

