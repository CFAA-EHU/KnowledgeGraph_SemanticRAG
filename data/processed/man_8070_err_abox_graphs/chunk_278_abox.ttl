@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirLosEjesComoDeIntercambioMantenidoOUtilizarOtrosEjesParaLaTransformada a ns1:TareaMantenimiento ;
    rdfs:label "Definir los ejes como de intercambio mantenido o utilizar otros ejes para la transformada" ;
    ns1:solucionaFallo ns1:LosEjesDeLaTransformacionActivaNoPuedenSerEjesDeIntercambioTemporal ;
    ns1:textoExtracto "Si es posible, definir los ejes como de intercambio mantenido; si no, utilizar otros ejes para la transformada." .

ns1:FaltaProgramarElNumeroDeAlmacenMZ a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el número de almacén (MZ)" ;
    ns1:textoExtracto "'Falta programar el número de almacén (MZ)' DETECCIÓN Durante la ejecución." .

ns1:NumeroDeAlmacenMZ_068382a137 a ns1:Parametro ;
    rdfs:label "Número de almacén (MZ)" ;
    ns1:textoExtracto "'Falta programar el número de almacén (MZ)'" .

ns1:LosEjesDeLaTransformacionActivaNoPuedenSerEjesDeIntercambioTemporal a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes de la transformación activa no pueden ser ejes de intercambio temporal" ;
    ns1:textoExtracto "'Los ejes de la transformación activa no pueden ser ejes de intercambio temporal'" .

