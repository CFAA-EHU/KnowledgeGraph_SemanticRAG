@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarParametroDesdeLaPuestaAPunto a ns1:AccionProhibida ;
    rdfs:label "Modificar parámetro desde la puesta a punto" ;
    ns1:mitigaRiesgo ns1:Parametro_c40d8c1e49 ;
    ns1:textoExtracto "'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de puesta a punto." .

ns1:SincronizarCabezalEsclavoDeUnCanalDiferenteAlDelMaestro a ns1:AccionProhibida ;
    rdfs:label "Sincronizar cabezal esclavo de un canal diferente al del maestro" ;
    ns1:mitigaRiesgo ns1:ElCabezalEsclavoASincronizarDebePertenecerAlCanal ;
    ns1:textoExtracto "'El cabezal esclavo a sincronizar debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA El cabezal master de una sincronización puede ser de cualquier canal, pero el cabezal esclavo debe ser del canal en el que se programa la sincronización." .

ns1:SincronizarCabezalEsclavoDelMismoCanalQueElMaestro a ns1:AccionProhibida ;
    rdfs:label "Sincronizar cabezal esclavo del mismo canal que el maestro" ;
    ns1:mitigaRiesgo ns1:ElCabezalEsclavoNoPuedeCoincidirConElMaestro ;
    ns1:textoExtracto "'El cabezal esclavo no puede coincidir con el maestro' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el cabezal esclavo es el mismo que el maestro." .

ns1:ElCabezalEsclavoASincronizarDebePertenecerAlCanal a ns1:Parametro ;
    rdfs:label "El cabezal esclavo a sincronizar debe pertenecer al canal" ;
    ns1:identificador "1588" ;
    ns1:textoExtracto "'El cabezal esclavo a sincronizar debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA El cabezal master de una sincronización puede ser de cualquier canal, pero el cabezal esclavo debe ser del canal en el que se programa la sincronización." .

ns1:ElCabezalEsclavoNoPuedeCoincidirConElMaestro a ns1:Parametro ;
    rdfs:label "El cabezal esclavo no puede coincidir con el maestro" ;
    ns1:identificador "1589" ;
    ns1:textoExtracto "'El cabezal esclavo no puede coincidir con el maestro' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el cabezal esclavo es el mismo que el maestro." .

ns1:Parametro_c40d8c1e49 a ns1:Parametro ;
    rdfs:label "Parámetro no modificable desde la puesta a punto" ;
    ns1:identificador "1587" ;
    ns1:textoExtracto "'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de puesta a punto." .

