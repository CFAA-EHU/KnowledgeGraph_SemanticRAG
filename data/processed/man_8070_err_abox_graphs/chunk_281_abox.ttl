@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2b73d7f5f8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:EnLaSincronizacionDeCabezalesElValorDelDenominadorDeLaRelacionDeTrans_ab3047aa9b,
        ns1:EnLaSincronizacionDeCabezalesElValorDelNumeradorDeLaRelacionDeTransmi_ecad08533f,
        ns1:EnLaSincronizacionElCabezalEsclavoEsElMismoQueElMaestro,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque ;
    ns1:textoExtracto "1590 'Programar #SYNC[Sm,Ss,Nx,Dx,Ox,CLOOP/OLOOP,CANCEL/NOCANCEL]' DETECCIÓN Durante la ejecución." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:EnLaSincronizacionElCabezalEsclavoEsElMismoQueElMaestro,
        ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EnLaSincronizacionDeCabezalesElValorDelDenominadorDeLaRelacionDeTrans_ab3047aa9b a ns1:DiagnosticoFallo ;
    rdfs:label "En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero" ;
    ns1:textoExtracto "CAUSA En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero." .

ns1:EnLaSincronizacionDeCabezalesElValorDelNumeradorDeLaRelacionDeTransmi_ecad08533f a ns1:DiagnosticoFallo ;
    rdfs:label "En la sincronización de cabezales, el valor del numerador de la relación de transmisión no es válido; por ejemplo, es cero" ;
    ns1:textoExtracto "CAUSA En la sincronización de cabezales, el valor del numerador de la relación de transmisión no es válido; por ejemplo, es cero. SOLUCIÓN El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero." .

ns1:EnLaSincronizacionElCabezalEsclavoEsElMismoQueElMaestro a ns1:DiagnosticoFallo ;
    rdfs:label "En la sincronización, el cabezal esclavo es el mismo que el maestro" ;
    ns1:textoExtracto "CAUSA En la sincronización, el cabezal esclavo es el mismo que el maestro. SOLUCIÓN Revisar la programación." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación." .

