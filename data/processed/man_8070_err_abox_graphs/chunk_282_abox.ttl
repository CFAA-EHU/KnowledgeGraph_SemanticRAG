@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarValorDelDenominador a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar valor del denominador" ;
    ns1:solucionaFallo ns1:ValorDelDenominadorDeLaRelacionDeTransmisionNoValido ;
    ns1:textoExtracto "El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero." .

ns1:Canal a ns1:Componente ;
    rdfs:label "Canal" ;
    ns1:textoExtracto "Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal." .

ns1:CancelarSincronizacionDesdeElCanalCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Cancelar sincronización desde el canal correcto" ;
    ns1:solucionaFallo ns1:ElCabezalEsclavoADesincronizarDebePertenecerAlCanal ;
    ns1:textoExtracto "Cancelar la sincronización desde el canal al que pertenece el cabezal." .

ns1:ElCabezalEsclavoADesincronizarDebePertenecerAlCanal a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal esclavo a desincronizar debe pertenecer al canal" ;
    ns1:textoExtracto "'El cabezal esclavo a desincronizar debe pertenecer al canal'" .

ns1:ValorDelDenominadorDeLaRelacionDeTransmisionNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Valor del denominador de la relación de transmisión no válido" ;
    ns1:textoExtracto "En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero." .

