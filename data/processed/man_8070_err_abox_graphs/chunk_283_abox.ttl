@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_1778
    a ex:Alarma ;
    rdfs:label "Alarma 1778: Longitud de corte de herramienta insuficiente"@es ;
    ex:identificador "1778" ;
    ex:textoExtracto "'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)."@es ;
    ex:monitoreaParametro ex:parametro_P_1778 .

ex:parametro_P_1778
    a ex:Parametro ;
    rdfs:label "Parámetro P (profundidad de perfil)"@es ;
    ex:identificador "P" ;
    ex:textoExtracto "profundidad del perfil (parámetro P)"@es .

ex:diagnostico_1778
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1778"@es ;
    ex:textoExtracto "SOLUCIÓN Elegir como herramienta de acabado una herramienta de mayor longitud de corte."@es ;
    ex:solucionaFallo ex:alarma_1778 .

ex:herramienta_acabado_1778
    a ex:Herramienta ;
    rdfs:label "Herramienta de acabado (requerida para perfil)"@es ;
    ex:textoExtracto "herramienta de acabado [...] de mayor longitud de corte"@es .

ex:alarma_1779
    a ex:Alarma ;
    rdfs:label "Alarma 1779: Avance (F) no programado"@es ;
    ex:identificador "1779" ;
    ex:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ex:monitoreaParametro ex:parametro_F_1779 .

ex:parametro_F_1779
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ex:identificador "F" ;
    ex:textoExtracto "parámetro F [...] avance de desbaste, acabado o profundización en Z"@es ;
    ex:valor "0" .

ex:diagnostico_1779
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1779"@es ;
    ex:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:solucionaFallo ex:alarma_1779 .