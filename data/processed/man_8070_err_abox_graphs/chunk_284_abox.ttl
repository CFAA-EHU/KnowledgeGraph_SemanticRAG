@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_49ee53c331 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sincronización con eje C o G63 activo" ;
    ns1:mitigaRiesgo ns1:SincronizacionConEjeCOG63Activo ;
    ns1:textoExtracto "El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa." .

ns1:CNC8070_672d06a8a8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa." .

ns1:CancelarSincronizacionParaCambiarGama a ns1:TareaMantenimiento ;
    rdfs:label "Cancelar sincronización para cambiar gama" ;
    ns1:solucionaFallo ns1:CambioDeGamaEnCabezalSincronizado ;
    ns1:textoExtracto "Cancela la sincronización para poder cambiar la gama del cabezal." .

ns1:CambioDeGamaEnCabezalSincronizado a ns1:AccionProhibida ;
    rdfs:label "Cambio de gama en cabezal sincronizado" ;
    ns1:textoExtracto "Durante la sincronización de dos cabezales, el CNC no permite el cambio de gama en ninguno de ellos." .

ns1:SincronizacionConEjeCOG63Activo a ns1:AccionProhibida ;
    rdfs:label "Sincronización con eje C o G63 activo" ;
    ns1:textoExtracto "El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa." .

