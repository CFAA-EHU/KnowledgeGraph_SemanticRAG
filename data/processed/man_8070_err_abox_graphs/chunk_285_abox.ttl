@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1785
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta mayor que cajera" ;
    ex:identificador "1785" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la ranura (parámetros L ó H). SOLUCIÓN Elegir una herramienta de menor diámetro." .

ex:DiagnosticoFallo_1786
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta ACABADO menor que delta" ;
    ex:identificador "1786" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de" .

ex:Parametro_L
    a ex:Parametro ;
    rdfs:label "Parámetro L (dimensión de ranura)" ;
    ex:textoExtracto "parámetros L ó H" .

ex:Parametro_H
    a ex:Parametro ;
    rdfs:label "Parámetro H (dimensión de ranura)" ;
    ex:textoExtracto "parámetros L ó H" .

ex:Parametro_delta
    a ex:Parametro ;
    rdfs:label "Parámetro δ (demasía en paredes laterales)" ;
    ex:textoExtracto "parámetro δ" .

ex:Herramienta_Ranurado
    a ex:Herramienta ;
    rdfs:label "Herramienta de ranurado" ;
    ex:textoExtracto "herramienta de menor diámetro", "herramienta de mayor diámetro" .