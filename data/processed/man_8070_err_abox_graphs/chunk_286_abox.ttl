@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_86238b1346 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentando activar una transformación angular con dos ejes que no pertenecen al mismo canal." .

ns1:RevisarLaProgramacionDelCicloDeFresadora a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación del ciclo de fresadora" ;
    ns1:solucionaFallo ns1:ParaEjecutarUnCicloDeFresaSonNecesariosTresEjesEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Los ejes de una transformación angular deben pertenecer al mismo canal." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:LosEjesAngularYOrtogonalDebenPertenecerAlMismoCanal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:LosEjesAngularYOrtogonalDebenPertenecerAlMismoCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes angular y ortogonal deben pertenecer al mismo canal" ;
    ns1:textoExtracto "'#ANGAX: Los ejes angular y ortogonal deben pertenecer al mismo canal'" .

ns1:ParaEjecutarUnCicloDeFresaSonNecesariosTresEjesEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Para ejecutar un ciclo de fresa son necesarios tres ejes en el canal" ;
    ns1:textoExtracto "'Para ejecutar un ciclo de fresa son necesarios tres ejes en el canal'" .

