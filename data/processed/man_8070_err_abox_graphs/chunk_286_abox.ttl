@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1787
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: F = 0" ;
    ex:identificador "1787" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_F_1787 .

ex:Parametro_F_1787
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ex:identificador "F" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z" .

ex:Fallo_1788
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: S = 0" ;
    ex:identificador "1788" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_S_1788 .

ex:Parametro_S_1788
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)" ;
    ex:identificador "S" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado" .

ex:Fallo_1789
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: T = 0" ;
    ex:identificador "1789" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." ;
    ex:solucionaFallo ex:Parametro_T_1789 .

ex:Parametro_T_1789
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)" ;
    ex:identificador "T" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada" .

ex:Fallo_1790
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: P = 0" ;
    ex:identificador "1790" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_P_1790 .

ex:Parametro_P_1790
    a ex:Parametro ;
    rdfs:label "Parámetro P (profundidad)" ;
    ex:identificador "P" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada" .

ex:Fallo_1791
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta menor que DELTA" ;
    ex:identificador "1791" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." ;
    ex:solucionaFallo ex:Parametro_Delta_1791 .

ex:Parametro_Delta_1791
    a ex:Parametro ;
    rdfs:label "Parámetro Δ (paso de fresado)" ;
    ex:identificador "Δ" ;
    ex:textoExtracto "diámetro de la herramienta es menor que el paso de fresado (parámetro Δ)" .

ex:Herramienta_Acabado_1791
    a ex:Herramienta ;
    ex:textoExtracto "herramienta de acabado [...] diámetro de la herramienta es menor que las demasías en las paredes laterales (parámetro δ)" .

ex:Parametro_Demasias_1791
    a ex:Parametro ;
    rdfs:label "Parámetro δ (demasías en paredes laterales)" ;
    ex:identificador "δ" ;
    ex:textoExtracto "diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ)" .

ex:Fallo_1792
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera" ;
    ex:identificador "1792" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo." .