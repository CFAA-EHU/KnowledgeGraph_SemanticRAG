@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1792
    a               ex:DiagnosticoFallo ;
    rdfs:label      "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera"@es ;
    ex:identificador "1792" ;
    ex:textoExtracto "1792 'CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el radio de la herramienta es mayor que el radio de la cajera (parámetro R). SOLUCIÓN Elegir una herramienta de menor diámetro."@es .

ex:Fallo_1793
    a               ex:DiagnosticoFallo ;
    rdfs:label      "CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ex:identificador "1793" ;
    ex:textoExtracto "1793 'CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las"@es .

ex:Herramienta_Fresado
    a               ex:Herramienta ;
    ex:textoExtracto "herramienta de diámetro mayor", "herramienta de menor diámetro", "herramienta de acabado"@es .

ex:Parametro_R
    a               ex:Parametro ;
    rdfs:label      "Radio de cajera (R)"@es ;
    ex:textoExtracto "el radio de la cajera (parámetro R)"@es .

ex:Solucion_1792
    a               ex:TareaMantenimiento ;
    ex:textoExtracto "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor"@es ;
    ex:solucionaFallo ex:Fallo_1792 .

ex:Solucion_1793
    a               ex:TareaMantenimiento ;
    ex:textoExtracto "Elegir una herramienta de menor diámetro"@es ;
    ex:solucionaFallo ex:Fallo_1793 .