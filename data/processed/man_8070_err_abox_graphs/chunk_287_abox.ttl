@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignacionDelValorDeVariableAPn a ns1:TareaMantenimiento ;
    rdfs:label "Asignación del valor de variable a Pn" ;
    ns1:solucionaFallo ns1:Error1608NoSePuedeConsultarEstaVariable ;
    ns1:textoExtracto "Para evitar este error, asignar el valor de la variable a un parámetro aritmético local y leer este parámetro cuando sea necesario." .

ns1:Error1609ParaEjecutarUnCicloDeTornoSonNecesariosDosEjesEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1609 - Para ejecutar un ciclo de torno son necesarios dos ejes en el canal" ;
    ns1:textoExtracto "'Para ejecutar un ciclo de torno son necesarios dos ejes en el canal'" .

ns1:Parametro_efc3693ad5 a ns1:Parametro ;
    rdfs:label "Parámetro aritmético local para consulta de variables" ;
    ns1:textoExtracto "asignar el valor de la variable a un parámetro aritmético local y leer este parámetro cuando sea necesario." .

ns1:RequisitoDeTresEjesParaCiclosDeFresadora a ns1:AvisoSeguridad ;
    rdfs:label "Requisito de tres ejes para ciclos de fresadora" ;
    ns1:mitigaRiesgo ns1:EjecucionDeCiclosDeFresadoraConMenosDeTresEjes ;
    ns1:textoExtracto "Para ejecutar los ciclos de fresadora hacen falta tres ejes en el canal." .

ns1:EjecucionDeCiclosDeFresadoraConMenosDeTresEjes a ns1:AccionProhibida ;
    rdfs:label "Ejecución de ciclos de fresadora con menos de tres ejes" ;
    ns1:textoExtracto "Hay programado un ciclo de fresadora en un canal con menos de tres ejes o no existe el eje longitudinal." .

ns1:Error1608NoSePuedeConsultarEstaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1608 - No se puede consultar esta variable" ;
    ns1:textoExtracto "'No se puede consultar esta variable. Asigne el valor de variable a Pn y consulte Pn'" .

