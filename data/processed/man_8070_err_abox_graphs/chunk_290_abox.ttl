@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarUnEjeHirthQueFormaParteDeLaTransformacionAngularActiva a ns1:AccionProhibida ;
    rdfs:label "Activar un eje hirth que forma parte de la transformación angular activa" ;
    ns1:solucionaFallo ns1:NoSePuedeActivarElEjeComoHirthPorFormarParteDeLaTransformacion ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación angular para activar el eje hirth." .

ns1:CNC8070_3e1c227dee a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:G31NoPermiteLaProgramacionDelRadioPolar,
        ns1:IndiceDeQNoPermitido,
        ns1:LaTransformacionAngularEstaDesactivada,
        ns1:NoSePuedeActivarElEjeComoHirthPorFormarParteDeLaTransformacion,
        ns1:ProgramacionNoPermitidaConLaTransformacionAngularActiva,
        ns1:ValorQDoblementeProgramado_0cb39a23cd ;
    ns1:textoExtracto "CNC 8070" .

ns1:DesactivarLaTransformacionAngularAntesDeEliminarLosEjesDelCanal_4335f1f21b a ns1:AccionProhibida ;
    rdfs:label "Desactivar la transformación angular antes de eliminar los ejes del canal" ;
    ns1:solucionaFallo ns1:LaTransformacionAngularEstaDesactivada ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación angular antes de eliminar los ejes del canal." .

ns1:EjecutarFuncionesIncompatiblesConLaTransformacionAngularActiva a ns1:AccionProhibida ;
    rdfs:label "Ejecutar funciones incompatibles con la transformación angular activa" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConLaTransformacionAngularActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación angular activa para ejecutar las funciones incompatibles." .

ns1:ProgramarRadioPolarEnFuncionG31 a ns1:AccionProhibida ;
    rdfs:label "Programar radio polar en función G31" ;
    ns1:solucionaFallo ns1:G31NoPermiteLaProgramacionDelRadioPolar ;
    ns1:textoExtracto "La función G31 no admite la programación del radio polar. La función G31 sólo admite coordenadas polares de la forma G31 Q I J; es decir, programando el ángulo y una o ambas coordenadas del centro." .

ns1:ProgramarValorQDoblemente a ns1:AccionProhibida ;
    rdfs:label "Programar valor Q doblemente" ;
    ns1:solucionaFallo ns1:ValorQDoblementeProgramado_0cb39a23cd ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El índice del parámetro Q es incorrecto; sólo se admite Q o Q1." .

ns1:UtilizarIndiceIncorrectoParaParametroQ a ns1:AccionProhibida ;
    rdfs:label "Utilizar índice incorrecto para parámetro Q" ;
    ns1:solucionaFallo ns1:IndiceDeQNoPermitido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Para la programación en polares utilizar el parámetro Q. Para la función G33 utilizar el parámetro Q1." .

ns1:G31NoPermiteLaProgramacionDelRadioPolar a ns1:DiagnosticoFallo ;
    rdfs:label "G31 no permite la programación del radio polar" ;
    ns1:textoExtracto "'G31 no permite la programación del radio polar'" .

ns1:IndiceDeQNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Índice de Q no permitido" ;
    ns1:textoExtracto "'Indice de Q no permitido'" .

ns1:LaTransformacionAngularEstaDesactivada a ns1:DiagnosticoFallo ;
    rdfs:label "La transformación angular está desactivada" ;
    ns1:textoExtracto "'Se ha desactivado la transformación angular #ANGAX'" .

ns1:NoSePuedeActivarElEjeComoHirthPorFormarParteDeLaTransformacion a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar el eje como Hirth, por formar parte de la transformación" ;
    ns1:textoExtracto "'No se puede activar el eje como Hirth, por formar parte de la transformación #ANGAX'" .

ns1:ProgramacionNoPermitidaConLaTransformacionAngularActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con la transformación angular activa" ;
    ns1:textoExtracto "'Programación no permitida con la transformación angular #ANGAX activa'" .

ns1:ValorQDoblementeProgramado_0cb39a23cd a ns1:DiagnosticoFallo ;
    rdfs:label "Valor Q doblemente programado" ;
    ns1:textoExtracto "'Valor Q doblemente programado'" .

