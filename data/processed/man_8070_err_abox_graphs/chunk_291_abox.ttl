@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroQ a ns1:Parametro ;
    rdfs:label "parámetro Q" ;
    ns1:textoExtracto "Para la programación en polares utilizar el parámetro Q." .

ns1:ParametroQ1 a ns1:Parametro ;
    rdfs:label "parámetro Q1" ;
    ns1:textoExtracto "Para la función G33 utilizar el parámetro Q1." .

ns1:RevisarLaProgramacion_17e9d559bb a ns1:AccionProhibida ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FalloValorQDoblementeProgramado ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarLaProgramacion_267862cf0a a ns1:AccionProhibida ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:FalloValorQ1DoblementeProgramado ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1619 'Valor Q1 doblemente" .

ns1:FalloValorQ1DoblementeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "'Valor Q1 doblemente programado'" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1619 'Valor Q1 doblemente" .

ns1:FalloValorQDoblementeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "'Valor Q doblemente programado'" ;
    ns1:textoExtracto "'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque." .

