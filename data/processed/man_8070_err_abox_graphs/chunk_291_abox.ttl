@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1804
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "Profundidad de cajera cero"@es ;
    ex:textoExtracto   "La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D."@es ;
    ex:identificador   "1804" ;
    ex:solucionaFallo  ex:Solucion_1804 .

ex:Solucion_1804
    a                  ex:TareaMantenimiento ;
    rdfs:label         "Corrección de parámetros I, Z, D"@es ;
    ex:textoExtracto   "Corregir la programación de los parámetros I Z D."@es .

ex:Parametro_I
    a                  ex:Parametro ;
    rdfs:label         "Parámetro I (profundidad programada)"@es ;
    ex:textoExtracto   "parámetro I"@es ;
    ex:monitoreaParametro ex:Fallo_1804 .

ex:Parametro_Z
    a                  ex:Parametro ;
    rdfs:label         "Parámetro Z"@es ;
    ex:textoExtracto   "parámetro Z"@es ;
    ex:monitoreaParametro ex:Fallo_1804 .

ex:Parametro_D
    a                  ex:Parametro ;
    rdfs:label         "Parámetro D"@es ;
    ex:textoExtracto   "parámetro D"@es ;
    ex:monitoreaParametro ex:Fallo_1804 .

ex:Fallo_1805
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "G87: Diámetro de herramienta mayor que cajera"@es ;
    ex:textoExtracto   "El radio de la herramienta es mayor que las dimensiones de la cajera (parámetros)"@es ;
    ex:identificador   "1805" ;
    ex:solucionaFallo  ex:Solucion_1805 .

ex:Solucion_1805
    a                  ex:TareaMantenimiento ;
    rdfs:label         "Selección de herramienta de diámetro menor"@es ;
    ex:textoExtracto   "Seleccionar una herramienta de diámetro menor."@es .

ex:Fallo_1806
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "G87: Diámetro de herramienta menor que L"@es ;
    ex:textoExtracto   "1806 'G87: Diámetro de herramienta menor que L'"@es ;
    ex:identificador   "1806" .