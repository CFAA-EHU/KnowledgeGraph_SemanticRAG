@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorCorrecto_b892bbb8d3 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor correcto" ;
    ns1:solucionaFallo ns1:GamaParaSincronizacionSYNCSETNoValida_6491b70086 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor correcto." .

ns1:DefinirElCabezalComoDeIntercambioMantenido a ns1:TareaMantenimiento ;
    rdfs:label "Definir el cabezal como de intercambio mantenido" ;
    ns1:solucionaFallo ns1:UnCabezalDeIntercambioTemporalNoPuedeFuncionarComoEjeCMantenido_0d97339824 ;
    ns1:textoExtracto "SOLUCIÓN Si es posible, definir el cabezal como de intercambio mantenido; si no, utilizar otro cabezal como eje C." .

ns1:GamaParaSincronizacionSYNCSETNoValida_0735a861e9 a ns1:Parametro ;
    rdfs:label "Gama para sincronización SYNCSET no valida" ;
    ns1:textoExtracto "'Gama para sincronización SYNCSET no valida' DETECCIÓN Durante la ejecución. CAUSA El parámetro SYNCSET tiene un valor no valido." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:NoSeAdmiteQ1SinG33EnElBloqueOG63Activa_ed72b67f3d,
        ns1:NoSeAdmiteSERVOONParaEjeOCabezalSERCOSPOSICION_f14939f2ee,
        ns1:ProgramarTANGCTRLONOFFSUSP_fade28e9df,
        ns1:ValorQ1DoblementeProgramado_3838cc7db0,
        ns1:ValorQDoblementeProgramado_f478b818ca ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ValorQ1DoblementeProgramado_18d77a4a70 a ns1:Parametro ;
    rdfs:label "Valor Q1 doblemente programado" ;
    ns1:textoExtracto "'Valor Q1 doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q1 está programado más de una vez en el mismo bloque." .

