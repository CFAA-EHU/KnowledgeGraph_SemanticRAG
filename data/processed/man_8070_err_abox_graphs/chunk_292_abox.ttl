    rdfs:label "Gama para sincronización SYNCSET no valida" ;
    ns1:textoExtracto "'Gama para sincronización SYNCSET no valida' DETECCIÓN Durante la ejecución. CAUSA El parámetro SYNCSET tiene un valor no valido." .

ns1:NoSeAdmiteQ1SinG33EnElBloqueOG63Activa_ed72b67f3d a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite Q1 sin G33 en el bloque o G63 activa" ;
    ns1:textoExtracto "'No se admite Q1 sin G33 en el bloque o G63 activa' DETECCIÓN Durante la ejecución. CAUSA Hay programado un parámetro Q1 sin G33 en el bloque o sin la función G63 activa." .

ns1:NoSeAdmiteSERVOONParaEjeOCabezalSERCOSPOSICION_f14939f2ee a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #SERVO ON para eje o cabezal SERCOS POSICION" ;
    ns1:textoExtracto "'No se admite #SERVO ON para eje o cabezal SERCOS POSICION' DETECCIÓN Durante la ejecución. CAUSA El eje o cabezal es Sercos posición." .

ns1:ProgramarTANGCTRLONOFFSUSP_fade28e9df a ns1:DiagnosticoFallo ;
    rdfs:label "Programar #TANGCTRL ON/OFF/SUSP [ ]" ;
    ns1:textoExtracto "'Programar #TANGCTRL ON/OFF/SUSP [ ]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:UnCabezalDeIntercambioTemporalNoPuedeFuncionarComoEjeCMantenido_0d97339824 a ns1:DiagnosticoFallo ;
    rdfs:label "Un cabezal de intercambio temporal no puede funcionar como eje C mantenido" ;
    ns1:textoExtracto "'Un cabezal de intercambio temporal no puede funcionar como eje C mantenido' DETECCIÓN Durante la ejecución. CAUSA El CNC puede activar como eje C mantenido (parámetro PERCAX) un cabezal de intercambio temporal." .

