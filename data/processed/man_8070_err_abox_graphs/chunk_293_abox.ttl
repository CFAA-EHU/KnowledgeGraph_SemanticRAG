@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1812
    a ex:Alarma ;
    rdfs:label "G88: Diámetro de herramienta menor que L"@es ;
    ex:identificador "1812" ;
    ex:textoExtracto "1812 'G88: Diámetro de herramienta menor que L' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor."@es .

ex:Alarma_1813
    a ex:Alarma ;
    rdfs:label "G88: Diámetro de herramienta = 0"@es ;
    ex:identificador "1813" ;
    ex:textoExtracto "1813 'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo."@es .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "Dimensiones de la cajera (parámetro J)"@es ;
    ex:identificador "J" ;
    ex:textoExtracto "CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J)."@es .

ex:Parametro_L
    a ex:Parametro ;
    rdfs:label "Demasía de acabado (parámetro L)"@es ;
    ex:identificador "L" ;
    ex:textoExtracto "CAUSA El diámetro de la herramienta es menor que la demasía de acabado (parámetro L)."@es .

ex:Herramienta_Seleccionable
    a ex:Herramienta ;
    rdfs:label "Herramienta de diámetro ajustable"@es ;
    ex:textoExtracto "SOLUCIÓN Seleccionar una herramienta de diámetro menor. [...] SOLUCIÓN Seleccionar una herramienta de diámetro mayor."@es .