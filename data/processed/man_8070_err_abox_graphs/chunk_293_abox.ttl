@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorCorrecto a ns1:AccionProhibida ;
    rdfs:label "Asignar al parámetro un valor correcto" ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor correcto." .

ns1:ControlTangencial a ns1:Parametro ;
    rdfs:label "Control tangencial" ;
    ns1:controladoPor ns1:TareaMantenimiento_a8d5357981 ;
    ns1:textoExtracto "'Programar #TANGCTRL ON/OFF/SUSP [ ]'" .

ns1:RevisarLaProgramacion_17e9d559bb a ns1:AccionProhibida ;
    rdfs:label "Revisar la programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:FalloSintaxisSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:TareaMantenimiento_a8d5357981 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de revisión de programación" ;
    ns1:solucionaFallo ns1:FalloSintaxisSentencia ;
    ns1:textoExtracto "Junto a la sentencia hay que programar uno de los comandos ON/SUSP/OFF y a continuación los parámetros de llamada entre corchetes." .

