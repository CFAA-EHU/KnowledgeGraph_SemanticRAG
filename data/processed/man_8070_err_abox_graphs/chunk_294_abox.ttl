@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_60269b2193 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "es el CNC el encargado de orientar este eje." .

ns1:ConElControlTangencialActivoNoSePermiteProgramarDesplazamientosDelEjeTangencial a ns1:TareaMantenimiento ;
    rdfs:label "Con el control tangencial activo, no se permite programar desplazamientos del eje tangencial" ;
    ns1:solucionaFallo ns1:NoSeAdmiteProgramarUnEjeEnControlTangencial_c0ce4b2150 ;
    ns1:textoExtracto "SOLUCIÓN Con el control tangencial activo, no se permite programar desplazamientos del eje tangencial; es el CNC el encargado de orientar este eje." .

ns1:ParaEliminarEsteEjeDeLaConfiguracionCancelarElControlTangencial a ns1:TareaMantenimiento ;
    rdfs:label "Para eliminar este eje de la configuración, cancelar el control tangencial" ;
    ns1:solucionaFallo ns1:NoSePuedeEliminarDeLaConfiguracionUnEjeConControlTangencialActivo_60328db009 ;
    ns1:textoExtracto "SOLUCIÓN Para eliminar este eje de la configuración, cancelar el control tangencial." .

ns1:ProgramacionDePerfilMedianteEtiquetasIncorrecta_958b283788 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de perfil mediante etiquetas incorrecta" ;
    ns1:textoExtracto "'Programación de perfil mediante etiquetas incorrecta'" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ProgramarEjeParaTANGCTRLONOFFSUSPRESUME_b65e627a29,
        ns1:TANGCTRLProgramarValoresDeAnguloEntre0Y3599999_8315626aec,
        ns1:UnEjeEnControlTangencialActivoDebeSerRotativoNoHIRTHYNoPertenecerAlTriedroActivo_a23a0fcd19 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NoSeAdmiteProgramarUnEjeEnControlTangencial_c0ce4b2150 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite programar un eje en control tangencial" ;
    ns1:textoExtracto "'No se admite programar un eje en control tangencial'" .

ns1:NoSePuedeEliminarDeLaConfiguracionUnEjeConControlTangencialActivo_60328db009 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede eliminar de la configuración un eje con control tangencial activo" ;
    ns1:textoExtracto "'No se puede eliminar de la configuración un eje con control tangencial activo'" .

ns1:ProgramarEjeParaTANGCTRLONOFFSUSPRESUME_b65e627a29 a ns1:DiagnosticoFallo ;
    rdfs:label "Programar eje para #TANGCTRL ON/OFF/SUSP/RESUME" ;
    ns1:textoExtracto "'Programar eje para #TANGCTRL ON/OFF/SUSP/RESUME'" .

ns1:TANGCTRLProgramarValoresDeAnguloEntre0Y3599999_8315626aec a ns1:DiagnosticoFallo ;
    rdfs:label "#TANGCTRL: programar valores de ángulo entre 0 y +/-359.9999" ;
    ns1:textoExtracto "'#TANGCTRL: programar valores de ángulo entre 0 y +/-359.9999'" .

ns1:UnEjeEnControlTangencialActivoDebeSerRotativoNoHIRTHYNoPertenecerAlTriedroActivo_a23a0fcd19 a ns1:DiagnosticoFallo ;
