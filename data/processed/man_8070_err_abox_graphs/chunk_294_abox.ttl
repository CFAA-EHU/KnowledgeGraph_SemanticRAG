@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1813
    a ex:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta = 0" ;
    ex:textoExtracto "1813 'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1814
    a ex:DiagnosticoFallo ;
    rdfs:label "G88: No hay herramienta" ;
    ex:textoExtracto "1814 'G88: No hay herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal." .

ex:Fallo_1815
    a ex:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta menor que C" ;
    ex:textoExtracto "1815 'G88: Diámetro de herramienta menor que C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ex:Fallo_1816
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro X no múltiplo de I" ;
    ex:textoExtracto "1816 'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ex:Fallo_1817
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta parámetro I o K" ;
    ex:textoExtracto "1817 'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar el paso entre mecanizados (parámetro I) o el número de mecanizados (parámetro K). SOLUCIÓN Asignar un valor correcto al parámetro." .

ex:Fallo_1818
    a ex:DiagnosticoFallo ;
    rdfs:label "J = 0 en mecanizado múltiple" ;
    ex:textoExtracto "1818 'J = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0. SOLUCIÓN Asignar un valor correcto al parámetro." .

ex:Parametro_L
    a ex:Parametro ;
    rdfs:label "demasía de acabado (L)" ;
    ex:textoExtracto "es menor que la demasía de acabado (parámetro L)" .

ex:Parametro_C
    a ex:Parametro ;
    rdfs:label "paso de fresado (C)" ;
    ex:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro C)" .

ex:Parametro_X
    a ex:Parametro ;
    rdfs:label "longitud del mecanizado (X)" ;
    ex:textoExtracto "La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I)" .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "paso entre mecanizados (I)" ;
    ex:textoExtracto "paso entre mecanizados (parámetro I)" .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "número de mecanizados (K)" ;
    ex:textoExtracto "número de mecanizados (parámetro K)" .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "paso entre mecanizados en eje Y (J)" ;
    ex:textoExtracto "el parámetro J (paso entre mecanizados en el eje de ordenadas)" .

ex:Herramienta_G88
    a ex:Herramienta ;
    rdfs:label "Herramienta para ciclo G88" ;
    ex:textoExtracto "Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal" .