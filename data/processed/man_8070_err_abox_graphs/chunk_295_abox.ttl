@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "Parámetro J (paso entre mecanizados en el eje de ordenadas)"@es ;
    ex:textoExtracto "el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0"@es ;
    ex:valor "0" .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K (número de mecanizados)"@es ;
    ex:textoExtracto "el parámetro K (número de mecanizados) tiene valor 0"@es ;
    ex:valor "0" .

ex:Parametro_X
    a ex:Parametro ;
    rdfs:label "Parámetro X (longitud del mecanizado)"@es ;
    ex:textoExtracto "X (longitud del"@es .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Parámetro I"@es ;
    ex:textoExtracto "Dos de los parámetros X, I, K han de ser programados"@es .

ex:DiagnosticoFallo_1819
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1819: K = 0"@es ;
    ex:identificador "1819" ;
    ex:textoExtracto "1819 'K = 0' [...] CAUSA En un mecanizado múltiple, el parámetro K (número de mecanizados) tiene valor 0. SOLUCIÓN Asignar un valor correcto al parámetro."@es ;
    ex:solucionaFallo ex:Parametro_K .

ex:DiagnosticoFallo_1820
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1820: Parámetros X, I, K no programados"@es ;
    ex:identificador "1820" ;
    ex:textoExtracto "1820 'Dos de los parámetros X, I, K han de ser programados' [...] CAUSA Falta programar dos de los siguientes parámetros; X (longitud del"@es ;
    ex:solucionaFallo ex:Parametro_X , ex:Parametro_I , ex:Parametro_K .

ex:DiagnosticoFallo_1819_J
    a ex:DiagnosticoFallo ;
    rdfs:label "Error: Parámetro J con valor 0"@es ;
    ex:textoExtracto "CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0. SOLUCIÓN Asignar un valor correcto al parámetro."@es ;
    ex:solucionaFallo ex:Parametro_J .

ex:ModoOperacion_MecanizadoMultiple
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de mecanizado múltiple"@es ;
    ex:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple"@es ;
    ex:monitoreaParametro ex:Parametro_J , ex:Parametro_K , ex:Parametro_X , ex:Parametro_I .