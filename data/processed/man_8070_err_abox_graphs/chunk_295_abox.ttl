@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarValoresCorrectosALosParametrosSYE a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valores correctos a los parámetros S y E" ;
    ns1:solucionaFallo ns1:ParametrosSYEIncorrectos ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros S y E." .

ns1:AvisoSeguridad_77ffad83fc a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de programación de perfil no permitida" ;
    ns1:mitigaRiesgo ns1:ParametrosSYEIncorrectos ;
    ns1:textoExtracto "'Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]' DETECCIÓN Durante la ejecución." .

ns1:AvisoSeguridad_98e51b9441 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de programación de perfil incorrecta" ;
    ns1:mitigaRiesgo ns1:ParametrosSYEIncorrectos ;
    ns1:textoExtracto "'Programación de perfil mediante etiquetas incorrecta'" .

ns1:ParametrosSYEIncorrectos a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetros S y E incorrectos" ;
    ns1:textoExtracto "En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E)." .

