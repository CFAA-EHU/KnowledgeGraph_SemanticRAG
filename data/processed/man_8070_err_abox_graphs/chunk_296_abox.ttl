@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1820
    a ex:Alarma ;
    rdfs:label "Alarma 1820: Parámetros X, I, K no programados"@es ;
    ex:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados)."@es ;
    ex:identificador "1820" .

ex:Parametro_X
    a ex:Parametro ;
    rdfs:label "Parámetro X (longitud del mecanizado)"@es ;
    ex:textoExtracto "X (longitud del mecanizado)"@es ;
    ex:identificador "X" .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Parámetro I (paso entre mecanizados)"@es ;
    ex:textoExtracto "I (paso entre mecanizados)"@es ;
    ex:identificador "I" .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K (número de mecanizados)"@es ;
    ex:textoExtracto "K (número de mecanizados)"@es ;
    ex:identificador "K" .

ex:Alarma_1821
    a ex:Alarma ;
    rdfs:label "Alarma 1821: Parámetro B no múltiplo de I"@es ;
    ex:textoExtracto "'B debe ser múltiplo de I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud angular del mecanizado (parámetro B) ha de ser múltiplo del paso angular entre mecanizados (parámetro I)."@es ;
    ex:identificador "1821" .

ex:Parametro_B
    a ex:Parametro ;
    rdfs:label "Parámetro B (longitud angular del mecanizado)"@es ;
    ex:textoExtracto "B (longitud angular del mecanizado)"@es ;
    ex:identificador "B" .

ex:Alarma_1822
    a ex:Alarma ;
    rdfs:label "Alarma 1822: Parámetro Y no múltiplo de J"@es ;
    ex:textoExtracto "'El parámetro Y ha de ser múltiplo del parámetro J' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro Y) ha de ser múltiplo del paso entre mecanizados (parámetro J)."@es ;
    ex:identificador "1822" .

ex:Parametro_Y
    a ex:Parametro ;
    rdfs:label "Parámetro Y (longitud del mecanizado)"@es ;
    ex:textoExtracto "Y (longitud del mecanizado)"@es ;
    ex:identificador "Y" .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "Parámetro J (paso entre mecanizados)"@es ;
    ex:textoExtracto "J (paso entre mecanizados)"@es ;
    ex:identificador "J" .

ex:Alarma_1823
    a ex:Alarma ;
    rdfs:label "Alarma 1823: Parámetros Y, J, D no programados"@es ;
    ex:textoExtracto "'Dos de los parámetros Y, J, D han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; Y (longitud del mecanizado), J (paso entre mecanizados), D (número de mecanizados)."@es ;
    ex:identificador "1823" .

ex:Parametro_D
    a ex:Parametro ;
    rdfs:label "Parámetro D (número de mecanizados)"@es ;
    ex:textoExtracto "D (número de mecanizados)"@es ;
    ex:identificador "D" .

ex:Alarma_1824
    a ex:Alarma ;
    rdfs:label "Alarma 1824: Parámetros I, K no programados"@es ;
    ex:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar uno de los siguientes parámetros; I (paso entre mecanizados), K (número de mecanizados)."@es ;
    ex:identificador "1824" .

ex:Alarma_1825
    a ex:Alarma ;
    rdfs:label "Alarma 1825: Parámetros I, A no programados"@es ;
    ex:textoExtracto "'Uno de los parámetros I, A ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple."@es ;
    ex:identificador "1825" .

ex:Parametro_A
    a ex:Parametro ;
    rdfs:label "Parámetro A"@es ;
    ex:textoExtracto "A"@es ;
    ex:identificador "A" .

