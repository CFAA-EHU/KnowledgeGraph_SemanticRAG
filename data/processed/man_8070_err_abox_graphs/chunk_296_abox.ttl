@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DETECCIONDuranteLaEjecucionCAUSAElCNCHaIntentadoActivarElControlTange_2611ea665c a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el control tangencial en un eje rotativo de módulo distinto de 360º. SOLUCIÓN El control tangencial sólo se puede activar en ejes rotativos con módulo 360º." ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el control tangencial en un eje rotativo de módulo distinto de 360º. SOLUCIÓN El control tangencial sólo se puede activar en ejes rotativos con módulo 360º." .

ns1:DETECCIONDuranteLaEjecucionCAUSAEnLaLlamadaAlCicloSeHanDesignadoDeFor_658378f08b a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E), la subrutina que contiene el perfil (parámetro P) o el fichero que contiene el perfil (parámetro Q). SOLUCIÓN Revisar la programación." ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E), la subrutina que contiene el perfil (parámetro P) o el fichero que contiene el perfil (parámetro Q). SOLUCIÓN Revisar la programación." .

ns1:DETECCIONDuranteLaEjecucionCAUSANoSeHaProgramadoCorrectamenteElNombreDelCabezal a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA No se ha programado correctamente el nombre del cabezal." ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. Programar: #DGSPSL <nombre de cabezal>." .

ns1:LimiteInferiorDelModulo_ca1f49cc8a a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo" ;
    ns1:textoExtracto "El límite superior del módulo lo define el parámetro MODUPLIM y el límite inferior el parámetro MODLOWLIM." .

ns1:LimiteSuperiorDelModulo_a3ad6b8ff2 a ns1:Parametro ;
    rdfs:label "Límite superior del módulo" ;
    ns1:textoExtracto "El límite superior del módulo lo define el parámetro MODUPLIM y el límite inferior el parámetro MODLOWLIM." .

