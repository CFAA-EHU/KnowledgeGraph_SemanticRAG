@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirParametroMaquinaNKINAX a ns1:TareaMantenimiento ;
    rdfs:label "corregir parámetro máquina NKINAX" ;
    ns1:solucionaFallo ns1:NumeroDeEjesEnLaTransformacionExcedeElPermitido ;
    ns1:textoExtracto "SOLUCIÓN Corregir el parámetro máquina NKINAX." .

ns1:NumeroMaximoDeEjesEnLaTransformacion a ns1:Parametro ;
    rdfs:label "Número máximo de ejes en la transformación" ;
    ns1:textoExtracto "La transformación de coordenadas tiene definido en el parámetro NKINAX más ejes de los permitidos en el CNC." .

ns1:ProgramarCabezalesExceptoComoEjeC a ns1:AccionProhibida ;
    rdfs:label "programar cabezales excepto como eje C" ;
    ns1:mitigaRiesgo ns1:CNC8070_e85fbe74d2 ;
    ns1:textoExtracto "'La sentencia #MOVE sólo admite un eje y debe pertenecer al canal'" .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "revisar programación" ;
    ns1:solucionaFallo ns1:ErrorDeProgramacionEnLaSentenciaMOVE,
        ns1:ErrorDeSintaxisEnLaSentenciaDGSPSL ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:CNC8070_e85fbe74d2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La transformación de coordenadas tiene definido en el parámetro NKINAX más ejes de los permitidos en el CNC." .

ns1:ErrorDeProgramacionEnLaSentenciaMOVE a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en la sentencia #MOVE" ;
    ns1:textoExtracto "'La sentencia #MOVE sólo admite un eje y debe pertenecer al canal'" .

ns1:ErrorDeSintaxisEnLaSentenciaDGSPSL a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en la sentencia #DGSPSL" ;
    ns1:textoExtracto "'Programar: #DGSPSL <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:NumeroDeEjesEnLaTransformacionExcedeElPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Número de ejes en la transformación excede el permitido" ;
    ns1:textoExtracto "'El número de ejes en la transformación excede al permitido' DETECCIÓN Durante la ejecución. CAUSA La transformación de coordenadas tiene definido en el parámetro NKINAX más ejes de los permitidos en el CNC." .

