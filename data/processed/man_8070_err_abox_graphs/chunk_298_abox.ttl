@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1827
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetros X e Y iguales a 0" ;
    ex:textoExtracto "'Los parámetros X e Y son iguales a 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Los parámetros X Y (centro del arco de mecanizado) tienen valor 0. SOLUCIÓN Asignar un valor correcto al parámetro." ;
    ex:solucionaFallo ex:Parametro_X, ex:Parametro_Y .

ex:DiagnosticoFallo_1828
    a ex:DiagnosticoFallo ;
    rdfs:label "360 no es múltiplo del parámetro I" ;
    ex:textoExtracto "'360 ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA El paso angular (parámetro I) ha de ser submúltiplo de 360º. SOLUCIÓN Asignar un valor correcto al parámetro." ;
    ex:solucionaFallo ex:Parametro_I .

ex:DiagnosticoFallo_1829
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro I igual a 0" ;
    ex:textoExtracto "'I = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro I (paso entre mecanizados) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero." ;
    ex:solucionaFallo ex:Parametro_I .

ex:DiagnosticoFallo_1830
    a ex:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta igual a 0" ;
    ex:textoExtracto "'Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." ;
    ex:solucionaFallo ex:Parametro_DiametroHerramienta .

ex:DiagnosticoFallo_1831
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro C igual a 0 en ciclo G82" ;
    ex:textoExtracto "'G82: C = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro C (cota de aproximación) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero." ;
    ex:solucionaFallo ex:Parametro_C .

ex:DiagnosticoFallo_1832
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro I igual a 0 en desbaste" ;
    ex:textoExtracto "'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta." ;
    ex:solucionaFallo ex:Parametro_I_Desbaste .

ex:DiagnosticoFallo_1833
    a ex:DiagnosticoFallo ;
    rdfs:label "I multiplicado por K no igual a 360" ;
    ex:textoExtracto "I multiplicado por K ha de ser igual a 360' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA El paso angular entre mecanizados (parámetro I) por el número de mecanizados (parámetro K) debe ser 360º. SOLUCIÓN Asignar un valor correcto al parámetro." ;
    ex:solucionaFallo ex:Parametro_I, ex:Parametro_K .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Parámetro I (paso angular o paso entre mecanizados)" ;
    ex:textoExtracto "parámetro I (paso angular entre mecanizados / paso entre mecanizados)" .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K (número de mecanizados)" ;
    ex:textoExtracto "número de mecanizados (parámetro K)" .

ex:Parametro_X
    a ex:Parametro ;
    rdfs:label "Parámetro X (coordenada X del centro del arco)" ;
    ex:textoExtracto "parámetro X (centro del arco de mecanizado)" .

ex:Parametro_Y
    a ex:Parametro ;
    rdfs:label "Parámetro Y (coordenada Y del centro del arco)" ;
    ex:textoExtracto "parámetro Y (centro del arco de mecanizado)" .

ex:Parametro_DiametroHerramienta
    a ex:Parametro ;
    rdfs:label "Diámetro de herramienta" ;
    ex:textoExtracto "diámetro de herramienta" .

ex:Parametro_C
    a ex:Parametro ;
    rdfs:label "Parámetro C (cota de aproximación en ciclo G82)" ;
    ex:textoExtracto "parámetro C (cota de aproximación)" .

ex:Parametro_I_Desbaste
    a ex:Parametro ;
    rdfs:label "Parámetro I (paso máximo de profundización en desbaste)" ;
    ex:textoExtracto "parámetro I (paso máximo de profundización)" .