@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirParametroNKINAX a ns1:TareaMantenimiento ;
    rdfs:label "Corregir parámetro NKINAX" ;
    ns1:solucionaFallo ns1:FalloTransformadasActivas ;
    ns1:textoExtracto "SOLUCIÓN Corregir el parámetro máquina NKINAX." .

ns1:DesactivarUnaTransformadaAntesDeActivarLaOtra a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar una transformada antes de activar la otra" ;
    ns1:solucionaFallo ns1:FalloTransformadasActivas ;
    ns1:textoExtracto "SOLUCIÓN Desactivar una de ellas antes de activar la otra." .

ns1:FalloSentidoGiroCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Sentido de giro del cabezal incompatible con la herramienta" ;
    ns1:textoExtracto "'Sentido de giro del cabezal incompatible con la herramienta'" .

ns1:Parametro_0ec56002be a ns1:Parametro ;
    rdfs:label "Parámetro máquina NKINAX" ;
    ns1:identificador "NKINAX" ;
    ns1:textoExtracto "'No se permiten tener activas las transformadas FACE y CYL al mismo tiempo'" .

ns1:FalloTransformadasActivas a ns1:DiagnosticoFallo ;
    rdfs:label "Transformadas FACE y CYL activas simultáneamente" ;
    ns1:textoExtracto "'No se permiten tener activas las transformadas FACE y CYL al mismo tiempo'" .

