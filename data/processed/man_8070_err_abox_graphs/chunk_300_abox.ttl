@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_42ee965600 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CabezalEsclavo ;
    ns1:textoExtracto "El cabezal esclavo de una pareja tándem es controlado por el CNC" .

ns1:CabezalMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Maestro" ;
    ns1:textoExtracto "Para desplazar un cabezal esclavo, hay que desplazar el cabezal maestro al que se encuentra asociado." .

ns1:NoSePermiteAparcarCabezalesTANDEM_73514422c7 a ns1:AccionProhibida ;
    rdfs:label "No se permite aparcar cabezales TANDEM" ;
    ns1:mitigaRiesgo ns1:CabezalEsclavo ;
    ns1:textoExtracto "'No se permite aparcar cabezales TANDEM'" .

ns1:CabezalEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Esclavo" ;
    ns1:textoExtracto "El cabezal esclavo de una pareja tándem es controlado por el CNC, no se puede desplazar individualmente." .

