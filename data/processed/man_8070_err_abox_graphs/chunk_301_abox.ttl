ex:DiagnosticoFallo_1839
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Cajera con islas: Intersección de perfiles en XY no válida" ;
    ex:identificador "1839" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común. SOLUCIÓN Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos." .

ex:DiagnosticoFallo_1840
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Cajera con islas: Memoria insuficiente para su resolución" ;
    ex:identificador "1840" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no" .