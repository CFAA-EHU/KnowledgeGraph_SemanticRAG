@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarElProcesoDeIntegracionDeCinematicasDeUsuario a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el proceso de integración de cinemáticas de usuario" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_9f9448ee08,
        ns1:DiagnosticoFallo_b1495e0da6 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el proceso de integración de cinemáticas de usuario." .

ns1:DiagnosticoFallo_9f9448ee08 a ns1:DiagnosticoFallo ;
    rdfs:label "Función de transformación directa de usuario no encontrada" ;
    ns1:textoExtracto "'Función de transformación directa de usuario no encontrada' DETECCIÓN Durante la ejecución. CAUSA Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario." .

ns1:DiagnosticoFallo_b1495e0da6 a ns1:DiagnosticoFallo ;
    rdfs:label "Función de transformación inversa de usuario no encontrada" ;
    ns1:textoExtracto "'Función de transformación inversa de usuario no encontrada' DETECCIÓN Durante la ejecución. CAUSA Falta la función de coordenadas PcsToMcs al intentar realizar la transformación de coordenadas pieza a máquina en una cinemática de usuario." .

