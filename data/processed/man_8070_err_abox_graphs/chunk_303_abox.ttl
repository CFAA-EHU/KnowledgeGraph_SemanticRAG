@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AcoplarLosEjesEnSuCanal a ns1:TareaMantenimiento ;
    rdfs:label "Acoplar los ejes en su canal" ;
    ns1:solucionaFallo ns1:NoSeAdmiteLINKMantenidoConEjesTemporalesDeOtroCanal ;
    ns1:textoExtracto "SOLUCIÓN Acoplar los ejes en su canal." .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISEXCH" ;
    ns1:textoExtracto "El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH)" .

ns1:ParametroLINKCANCEL a ns1:Parametro ;
    rdfs:label "Parámetro LINKCANCEL" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL)." .

ns1:RevisarElProcesoDeIntegracionDeCinematicasDeUsuario a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el proceso de integración de cinemáticas de usuario" ;
    ns1:solucionaFallo ns1:FaltaLaFuncionDeCoordenadasMcsToPcs ;
    ns1:textoExtracto "SOLUCIÓN Revisar el proceso de integración de cinemáticas de usuario." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:SeEsperabaDEFMacroComandoMacroComando ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:UnEjeDeLaTransformacionDePlanoInclinadoNoPuedeSerEsclavo a ns1:DiagnosticoFallo ;
    rdfs:label "'Un eje de la transformación de plano inclinado no puede ser esclavo'" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:FaltaLaFuncionDeCoordenadasMcsToPcs a ns1:DiagnosticoFallo ;
    rdfs:label "Falta la función de coordenadas McsToPcs" ;
    ns1:textoExtracto "CAUSA Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario." .

ns1:NoSeAdmiteLINKMantenidoConEjesTemporalesDeOtroCanal a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite LINK mantenido con ejes temporales de otro canal'" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL)." .

ns1:SeEsperabaDEFMacroComandoMacroComando a ns1:DiagnosticoFallo ;
    rdfs:label "'Se esperaba #DEF \"macro\"=\"comando\" \"macro\"=\"comando\"...'" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Sentencia mal programada." .

