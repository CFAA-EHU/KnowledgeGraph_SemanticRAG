@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1846 a ex:DiagnosticoFallo ;
    rdfs:label "Radio del arco nulo"@es ;
    ex:identificador "1846" ;
    ex:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple. Las posibles causas son las siguientes: • En el perfil hay un tramo curvo con radio cero. • En un mecanizado múltiple en arco o circunferencia, ambas coordenadas del centro coinciden con el punto inicial. SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Radio del arco"@es ;
        ex:textoExtracto "En el perfil hay un tramo curvo con radio cero."@es
    ] .

ex:Fallo_1847 a ex:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Q = 0"@es ;
    ex:identificador "1847" ;
    ex:textoExtracto "Durante la ejecución del ciclo. El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Q (material a eliminar, modo rectangular)"@es ;
        ex:valor "0" ;
        ex:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0."@es
    ] .

ex:Fallo_1848 a ex:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Q = 0"@es ;
    ex:identificador "1848" ;
    ex:textoExtracto "Durante la ejecución del ciclo. El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Q (material a eliminar, modo circular)"@es ;
        ex:valor "0" ;
        ex:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0."@es
    ] .

ex:Fallo_1849 a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera"@es ;
    ex:identificador "1849" ;
    ex:textoExtracto "Durante la ejecución del ciclo. El tamaño de la cajera menos el diámetro de la herramienta es menor que las demasías de acabado laterales (dos veces el parámetro δ). SOLUCIÓN Asignar un valor correcto al parámetro."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "δ (demasía de acabado lateral)"@es ;
        ex:textoExtracto "dos veces el parámetro δ"@es
    ] .

ex:Fallo_1850 a ex:DiagnosticoFallo ;
    rdfs:label "Lx ha de ser múltiplo de Ix"@es ;
    ex:identificador "1850" ;
    ex:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple. La longitud del mecanizado (parámetro Lx) ha de ser múltiplo de la distancia entre mecanizados (parámetro Ix). SOLUCIÓN Asignar un valor correcto a los parámetros."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Lx (longitud del mecanizado)"@es ;
        ex:textoExtracto "parámetro Lx"@es
    ], [
        a ex:Parametro ;
        rdfs:label "Ix (distancia entre mecanizados)"@es ;
        ex:textoExtracto "parámetro Ix"@es
    ] .

ex:Fallo_1851 a ex:DiagnosticoFallo ;
    rdfs:label "Ly ha de ser múltiplo de Iy"@es ;
    ex:identificador "1851" ;
    ex:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Ly"@es ;
        ex:textoExtracto "parámetro Ly (implícito en contexto de mecanizado múltiple)"@es
    ], [
        a ex:Parametro ;
        rdfs:label "Iy"@es ;
        ex:textoExtracto "parámetro Iy (implícito en contexto de mecanizado múltiple)"@es
    ] .

ex:Parametro_I a ex:Parametro ;
    rdfs:label "I (diámetro de la cuerda)"@es ;
    ex:textoExtracto "el diámetro del círculo [en contexto: parámetro I]"@es .