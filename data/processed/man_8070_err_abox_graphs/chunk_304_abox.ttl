@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusDigitalSercosMechatrolinkNoPreparadoParaLaLecturaDeLaVariable a ns1:AvisoSeguridad ;
    rdfs:label "'Bus digital (Sercos/Mechatrolink) no preparado para la lectura de la variable'" ;
    ns1:mitigaRiesgo ns1:LecturaDeVariableEnBusDigitalNoPreparado ;
    ns1:solucionadoPor ns1:CondicionarEscrituraDeVariableEnBusDigital ;
    ns1:textoExtracto "'Bus digital (Sercos/Mechatrolink) no preparado para la lectura de la variable' DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:UnEjeDeLaTransformacionDePlanoInclinadoNoPuedeSerEsclavo_f8d565bf4a a ns1:AvisoSeguridad ;
    rdfs:label "Un eje de la transformación de plano inclinado no puede ser esclavo" ;
    ns1:mitigaRiesgo ns1:DefinirEjeEsclavoDeUnAcoploEnPlanoInclinado ;
    ns1:solucionadoPor ns1:DesactivarPlanoInclinadoParaActivarAcoplo ;
    ns1:textoExtracto "'Un eje de la transformación de plano inclinado no puede ser esclavo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado." .

ns1:CondicionarEscrituraDeVariableEnBusDigital a ns1:TareaMantenimiento ;
    rdfs:label "Condicionar escritura de variable en bus digital" ;
    ns1:textoExtracto "CONDICIONAR LA ESCRITURA DE LA VARIABLE A LA MARCA SERCOSRDY EN Sercos O A LA MARCA MLINKRDY EN Mechatrolink." .

ns1:DefinirEjeEsclavoDeUnAcoploEnPlanoInclinado a ns1:AccionProhibida ;
    rdfs:label "Definir eje esclavo de un acoplo en plano inclinado" ;
    ns1:textoExtracto "El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado." .

ns1:DesactivarPlanoInclinadoParaActivarAcoplo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar plano inclinado para activar acoplo" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el plano inclinado para poder activar el acoplo." .

ns1:LecturaDeVariableEnBusDigitalNoPreparado a ns1:AccionProhibida ;
    rdfs:label "Lectura de variable en bus digital no preparado" ;
    ns1:textoExtracto "Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3." .

