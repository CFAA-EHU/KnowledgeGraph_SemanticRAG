@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlgunoDeLosEjesDelPlanoEstaEnDiametros a ns1:DiagnosticoFallo ;
    rdfs:label "Alguno de los ejes del plano esta en diámetros" ;
    ns1:textoExtracto "'Alguno de los ejes del plano esta en diámetros'" .

ns1:CondicionarLaEscrituraDeLaVariableALasMarcasSERCOSRDYOMLINKRDY a ns1:TareaMantenimiento ;
    rdfs:label "Condicionar la escritura de la variable a las marcas SERCOSRDY o MLINKRDY" ;
    ns1:solucionaFallo ns1:BusDigitalSercosMechatrolinkNoPreparadoParaLaEscrituraDeLaVariable ;
    ns1:textoExtracto "Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink." .

ns1:Parametro_6dc413b796 a ns1:Parametro ;
    rdfs:label "Marca MLINKRDY para condicionar la escritura de la variable" ;
    ns1:identificador "MLINKRDY" ;
    ns1:textoExtracto "Condicionar la escritura de la variable a la marca MLINKRDY en Mechatrolink" .

ns1:Parametro_cd500cd38f a ns1:Parametro ;
    rdfs:label "Marca SERCOSRDY para condicionar la escritura de la variable" ;
    ns1:identificador "SERCOSRDY" ;
    ns1:textoExtracto "Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos" .

ns1:SimularOEjecutarUnCicloFijoDeFresadoraEnUnTornoConEjesEnDiametros a ns1:AccionProhibida ;
    rdfs:label "Simular o ejecutar un ciclo fijo de fresadora en un torno con ejes en diámetros" ;
    ns1:textoExtracto "Al simular o ejecutar en un torno un ciclo fijo de fresadora" .

ns1:BusDigitalSercosMechatrolinkNoPreparadoParaLaEscrituraDeLaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable" ;
    ns1:textoExtracto "'Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable'" .

