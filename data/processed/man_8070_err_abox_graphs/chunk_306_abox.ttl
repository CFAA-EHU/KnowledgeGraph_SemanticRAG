@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlgunoDeLosEjesDelPlanoEstaEnDiametros_1db211e6cc a ns1:AvisoSeguridad ;
    rdfs:label "Alguno de los ejes del plano esta en diámetros" ;
    ns1:textoExtracto "'Alguno de los ejes del plano esta en diámetros' DETECCIÓN Al simular o ejecutar en un torno un ciclo fijo de fresadora que contiene movimientos en los ejes del plano, CAUSA Los datos de las cotas de los ciclos fijos de fresadora se consideran en radios. Si alguno de los ejes del plano esta en diámetros, el CNC interpreta sus datos como radios, por lo que avisa al usuario por si al programarlos lo estaba haciendo en diámetros." .

ns1:ProgramarLosDatosEnRadios a ns1:TareaMantenimiento ;
    rdfs:label "Programar los datos en radios" ;
    ns1:solucionaFallo ns1:CicloPuedeEjecutarUnaGeometriaDiferenteALaEsperada ;
    ns1:textoExtracto "SOLUCIÓN Programar los datos en radios." .

ns1:VariableNoValidaParaCabezalQueNoEsEjeC_ab440f0601 a ns1:AvisoSeguridad ;
    rdfs:label "Variable no válida para cabezal que no es eje C" ;
    ns1:textoExtracto "'Variable no válida para cabezal que no es eje C' DETECCIÓN Durante la ejecución." .

ns1:CicloPuedeEjecutarUnaGeometriaDiferenteALaEsperada a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo puede ejecutar una geometria diferente a la esperada" ;
    ns1:textoExtracto "CONSECUENCIA El ciclo puede ejecutar una geometria diferente a la esperada." .

