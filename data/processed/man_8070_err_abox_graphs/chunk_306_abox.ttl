@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1853
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1853: No se ha recibido señal del palpador" ;
    ex:textoExtracto "1853 'No se ha recibido señal del palpador' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación. SOLUCIÓN Corregir la definición del ciclo fijo." ;
    ex:identificador "1853" .

ex:DiagnosticoFallo_1854
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1854: El diámetro J debe ser mayor que cero" ;
    ex:textoExtracto "1854 'El diámetro J debe ser mayor que cero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro J (diámetro teórico del agujero) tiene un valor incorrecto. SOLUCIÓN Asignar al parámetro un valor positivo." ;
    ex:identificador "1854" .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "Parámetro J (diámetro teórico del agujero)" ;
    ex:textoExtracto "El parámetro J (diámetro teórico del agujero) tiene un valor incorrecto." ;
    ex:identificador "J" .

ex:DiagnosticoFallo_1855
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1855: Diámetro de herramienta mayor que el del agujero" ;
    ex:textoExtracto "1855 'Diámetro de herramienta mayor que el del agujero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El diámetro del palpador es mayor que el diámetro del agujero a medir o que el agujero utilizado para calibrar el palpador. SOLUCIÓN Corregir la definición del ciclo fijo." ;
    ex:identificador "1855" .

ex:DiagnosticoFallo_1856
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1856: Distancia de retroceso E incorrecta" ;
    ex:textoExtracto "1856 'Distancia de retroceso E incorrecta' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro E (distancia de retroceso) tiene un valor incorrecto. SOLUCIÓN Asignar al parámetro un valor entre 0 y el diámetro del agujero." ;
    ex:identificador "1856" .

ex:Parametro_E
    a ex:Parametro ;
    rdfs:label "Parámetro E (distancia de retroceso)" ;
    ex:textoExtracto "El parámetro E (distancia de retroceso) tiene un valor incorrecto." ;
    ex:identificador "E" .

ex:DiagnosticoFallo_1857
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1857: No hay corrector seleccionado" ;
    ex:textoExtracto "1857 'No hay corrector seleccionado' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 1 o #PROBE 2. CAUSA No hay corrector de herramienta activo para el ciclo de calibración de herramienta. SOLUCIÓN Programar el corrector (función D) antes del ciclo." ;
    ex:identificador "1857" .

ex:DiagnosticoFallo_1858
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1858: Programar I = 0/1" ;
    ex:textoExtracto "1858 'Programar I = 0/1' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El parámetro I (tipo de calibración) tiene un valor incorrecto." ;
    ex:identificador "1858" .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Parámetro I (tipo de calibración)" ;
    ex:textoExtracto "El parámetro I (tipo de calibración) tiene un valor incorrecto." ;
    ex:identificador "I" .

ex:ComponenteElectrico_Palpador
    a ex:ComponenteElectrico ;
    rdfs:label "Palpador (ciclo #PROBE)" ;
    ex:textoExtracto "ciclo de palpador #PROBE. El palpador no ha tocado la pieza durante el movimiento de palpación." .

ex:Sistema_CicloPROBE
    a ex:Sistema ;
    rdfs:label "Sistema de ciclos de palpador #PROBE" ;
    ex:textoExtracto "ciclo de palpador #PROBE 1, #PROBE 2, #PROBE 9" ;
    ex:tieneComponente ex:ComponenteElectrico_Palpador ;
    ex:monitoreaParametro ex:Parametro_J, ex:Parametro_E, ex:Parametro_I .

ex:DiagnosticoFallo_1853 ex:solucionaFallo ex:ComponenteElectrico_Palpador .
ex:DiagnosticoFallo_1854 ex:solucionaFallo ex:Parametro_J .
ex:DiagnosticoFallo_1855 ex:solucionaFallo ex:ComponenteElectrico_Palpador .
ex:DiagnosticoFallo_1856 ex:solucionaFallo ex:Parametro_E .
ex:DiagnosticoFallo_1857 ex:solucionaFallo ex:Sistema_CicloPROBE .
ex:DiagnosticoFallo_1858 ex:solucionaFallo ex:Parametro_I .