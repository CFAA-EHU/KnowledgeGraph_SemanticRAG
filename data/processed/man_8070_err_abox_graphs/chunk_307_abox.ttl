    rdfs:label "Número de almacén no válido" ;
    ns1:textoExtracto "'Número de almacén no válido' DETECCIÓN Durante la ejecución. CAUSA El número de almacén no es válido." .

ns1:NumeroDeAlmacenes_68630bb203 a ns1:Parametro ;
    rdfs:label "Número de almacenes" ;
    ns1:textoExtracto "El número de almacenes está definido en el parámetro NTOOLMZ." .

ns1:ReDefinirMacroPreviamenteDefinidaMedianteDEFFIX a ns1:AccionProhibida ;
    rdfs:label "Re-definir macro previamente definida mediante #DEF FIX" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'Macro previamente definida mediante #DEF FIX' DETECCIÓN Durante la ejecución. CAUSA La macro ya existe; fue definida con el comando #DEF FIX." .

ns1:VariableNoValidaParaCabezalQueNoEsEjeC_17dd099fa0 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable no válida para cabezal que no es eje C" ;
    ns1:textoExtracto "'Variable no válida para cabezal que no es eje C' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer una variable de eje pero el cabezal no está activado como eje C." .

