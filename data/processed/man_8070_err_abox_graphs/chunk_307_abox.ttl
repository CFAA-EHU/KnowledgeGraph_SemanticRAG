@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1858
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1858: Programar I = 0/1"@es ;
    ex:textoExtracto "SOLUCIÓN Programar el corrector (función D) antes del ciclo. 1858 'Programar I = 0/1' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El parámetro I (tipo de calibración) tiene un valor incorrecto. SOLUCIÓN El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)."@es ;
    ex:identificador "1858" .

ex:Fallo_1859
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1859: Plano activo incorrecto para calibrado de palpador"@es ;
    ex:textoExtracto "1859 'El plano activo para calibrado de palpador debe ser G17, G18 o G19' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2. CAUSA A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. SOLUCIÓN Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es ;
    ex:identificador "1859" .

ex:Parametro_I
    a               ex:Parametro ;
    rdfs:label      "Parámetro I (tipo de calibración)"@es ;
    ex:textoExtracto "El parámetro I (tipo de calibración) tiene un valor incorrecto. [...] El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)."@es ;
    ex:valor         "0,1" .

ex:CicloPalpador_PROBE
    a               ex:ModoOperacion ;
    rdfs:label      "Ciclo de palpador #PROBE"@es ;
    ex:textoExtracto "Durante la ejecución de un ciclo de palpador #PROBE."@es .

ex:CicloPalpador_PROBE2
    a               ex:ModoOperacion ;
    rdfs:label      "Ciclo de palpador #PROBE 2"@es ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 2."@es .

ex:PlanoTrabajo_G20
    a               ex:Parametro ;
    rdfs:label      "Plano de trabajo G20"@es ;
    ex:textoExtracto "hay activo un plano de trabajo definido con G20."@es ;
    ex:identificador "G20" .

ex:PlanoTrabajo_G17
    a               ex:Parametro ;
    rdfs:label      "Plano principal G17"@es ;
    ex:textoExtracto "Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es ;
    ex:identificador "G17" .

ex:PlanoTrabajo_G18
    a               ex:Parametro ;
    rdfs:label      "Plano principal G18"@es ;
    ex:textoExtracto "Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es ;
    ex:identificador "G18" .

ex:PlanoTrabajo_G19
    a               ex:Parametro ;
    rdfs:label      "Plano principal G19"@es ;
    ex:textoExtracto "Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es ;
    ex:identificador "G19" .

# Relaciones entre fallos, parámetros y modos de operación
ex:Fallo_1858
    ex:solucionaFallo ex:CicloPalpador_PROBE ;
    ex:monitoreaParametro ex:Parametro_I .

ex:Fallo_1859
    ex:solucionaFallo ex:CicloPalpador_PROBE2 ;
    ex:monitoreaParametro ex:PlanoTrabajo_G20 .

ex:CicloPalpador_PROBE
    ex:requiereMantenimiento ex:Parametro_I .

ex:CicloPalpador_PROBE2
    ex:requiereMantenimiento ex:PlanoTrabajo_G17 , ex:PlanoTrabajo_G18 , ex:PlanoTrabajo_G19 .