@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltaProgramarTrasNumeroCanal_103499c2dc a ns1:AccionProhibida ;
    rdfs:label "Falta programar '.' tras [númeroCanal]" ;
    ns1:textoExtracto "'Falta programar '.' tras [númeroCanal]' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR." .

ns1:TablaDeMacros a ns1:Parametro ;
    rdfs:label "Tabla de macros" ;
    ns1:textoExtracto "Utilizar el comando #INIT MACROTAB para reiniciar la tabla de macros, el cuál borra todas las macros definidas tanto con #DEF como con #DEF FIX." .

ns1:IndiceDeArrayIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Indice de array incorrecto" ;
    ns1:mitigaRiesgo ns1:RevisarLaProgramacion_80e90c8849 ;
    ns1:textoExtracto "'Indice de array incorrecto' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR. Algún índice de array programado en la variable está fuera de rango." .

ns1:RevisarLaProgramacion_80e90c8849 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:IndiceDeArrayIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Consultar la variable y su rango de valores." .

