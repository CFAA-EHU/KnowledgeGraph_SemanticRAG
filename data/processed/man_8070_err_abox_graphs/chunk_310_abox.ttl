@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GrupoMultiejeFueraDeRango_0c227253b7 a ns1:DiagnosticoFallo ;
    rdfs:label "Grupo multieje fuera de rango" ;
    ns1:textoExtracto "'Grupo multieje fuera de rango'" .

ns1:InicializacionDeCotaMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Inicialización de cota máquina" ;
    ns1:solucionaFallo ns1:CotaMaquinaNoInicializableEnEjesDeCinematicaOTransformadasActivas ;
    ns1:textoExtracto "Para inicializar cota máquina en dicho eje, desactivar el acoplo. No se puede inicializar la cota máquina de ejes gantry o tándem." .

ns1:CotaMaquinaNoInicializableEnEjesDeCinematicaOTransformadasActivas a ns1:DiagnosticoFallo ;
    rdfs:label "Cota máquina no inicializable en ejes de cinemática o transformadas activas" ;
    ns1:textoExtracto "'G174: no se admiten ejes de la cinemática o transformadas activas'" .

