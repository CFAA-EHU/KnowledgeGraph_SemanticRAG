@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InicializarCotaMaquinaSinDesactivarLaCinematicaOTransformacionActiva a ns1:AccionProhibida ;
    rdfs:label "Inicializar cota máquina sin desactivar la cinemática o transformación activa" ;
    ns1:solucionaFallo ns1:Entity1668GrupoMultiejeFueraDeRango ;
    ns1:textoExtracto "'Para inicializar la cota máquina en dicho eje, desactivar la cinemática o transformación activa.'" .

ns1:ProgramarROTATEMZ14ConPosicionIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Programar #ROTATEMZ1-4 con posición incorrecta" ;
    ns1:solucionaFallo ns1:Entity1668GrupoMultiejeFueraDeRango ;
    ns1:textoExtracto "'Revisar la programación. Programar la posición a seleccionar en la torreta o el número de posiciones a girar.'" .

ns1:ProgramarSentenciaROTATEMZ14ConSintaxisIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Programar sentencia #ROTATEMZ1-4 con sintaxis incorrecta" ;
    ns1:textoExtracto "'La sintaxis de la sentencia no es correcta o hay más información en el bloque.'" .

ns1:RevisarProgramacionYCorregirErrores a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación y corregir errores" ;
    ns1:solucionaFallo ns1:Entity1668GrupoMultiejeFueraDeRango ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la programación. Programar adecuadamente el número del grupo multieje.'" .

ns1:VariableQueDefineElNombreDelGrupoMultieje a ns1:Parametro ;
    rdfs:label "Variable que define el nombre del grupo multieje" ;
    ns1:identificador "V.MPG.MULAXISNAMExn[grupo]" ;
    ns1:textoExtracto "'Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo].'" .

ns1:VariableQueMantieneLaPosicionDelGrupoMultieje a ns1:Parametro ;
    rdfs:label "Variable que mantiene la posición del grupo multieje" ;
    ns1:identificador "V.MPG.KEEPPOSxn[grupo]" ;
    ns1:textoExtracto "'Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo].'" .

ns1:Entity1668GrupoMultiejeFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "1668 Grupo multieje fuera de rango" ;
    ns1:textoExtracto "'1668 'Grupo multieje fuera de rango''" .

