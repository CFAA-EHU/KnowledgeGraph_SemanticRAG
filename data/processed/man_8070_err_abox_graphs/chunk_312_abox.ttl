@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1672NoSeAdmiteG74G174ParaCabezalesSincronizados a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1672 - No se admite G74-G174 para cabezales sincronizados" ;
    ns1:textoExtracto "'No se admite G74-G174 para cabezales sincronizados'" .

ns1:ReducirElNumeroDeSubrutinasLocalesOUtilizarSubrutinasGlobales a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el número de subrutinas locales o utilizar subrutinas globales" ;
    ns1:solucionaFallo ns1:Error1671DemasiadasSubrutinasLocalesEnElFichero ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de subrutinas locales; agrupar varias subrutinas en una o utilizar subrutinas globales." .

ns1:RevisarLaProgramacionYPosicionesEnTorreta a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación y posiciones en torreta" ;
    ns1:solucionaFallo ns1:Error1670ElAlmacenIndicadoDebeSerDeTipoTORRETA ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar la posición a seleccionar en la torreta o el número de posiciones a girar." .

ns1:Error1670ElAlmacenIndicadoDebeSerDeTipoTORRETA a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1670 - El almacén indicado debe ser de tipo TORRETA" ;
    ns1:textoExtracto "'El almacén indicado debe ser de tipo TORRETA'" .

ns1:Error1671DemasiadasSubrutinasLocalesEnElFichero a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1671 - Demasiadas subrutinas locales en el fichero" ;
    ns1:textoExtracto "Demasiadas subrutinas locales en el fichero." .

