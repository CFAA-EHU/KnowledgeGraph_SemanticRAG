@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarPermisosDeAccesoDeLasVariables a ns1:TareaMantenimiento ;
    rdfs:label "Consultar permisos de acceso de las variables" ;
    ns1:solucionaFallo ns1:FalloCabezalSincronizado ;
    ns1:textoExtracto "Consultar en los manuales los permisos de acceso de las variables." .

ns1:ReferenciarCabezalesAntesDeSincronizarlos a ns1:TareaMantenimiento ;
    rdfs:label "Referenciar cabezales antes de sincronizarlos" ;
    ns1:solucionaFallo ns1:NoSeAdmiteG74G174ParaCabezalesSincronizados ;
    ns1:textoExtracto "El CNC referencia los cabezales antes de sincronizarlos." .

ns1:CNC8070_b6bc634e48 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:NoSeAdmiteG74G174ParaCabezalesSincronizados ;
    ns1:textoExtracto "el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos." .

ns1:FalloCabezalSincronizado a ns1:DiagnosticoFallo ;
    rdfs:label "Variable no accesible por programa o MDI" ;
    ns1:textoExtracto "'Variable no accesible por programa o MDI'" .

ns1:NoSeAdmiteG74G174ParaCabezalesSincronizados a ns1:AccionProhibida ;
    rdfs:label "No se admite G74-G174 para cabezales sincronizados" ;
    ns1:mitigaRiesgo ns1:CNC8070_b6bc634e48 ;
    ns1:textoExtracto "'No se admite G74-G174 para cabezales sincronizados'" .

