@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccesoVariableDeTexto a ns1:AccionProhibida ;
    rdfs:label "Acceso Variable de Texto" ;
    ns1:textoExtracto "'es una variable de texto. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables.'" .

ns1:AccesoVariablePorCanal a ns1:AccionProhibida ;
    rdfs:label "Acceso Variable por Canal" ;
    ns1:textoExtracto "'Variable no accesible para su canal. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables.'" .

ns1:DesactivacionRTCPTLC a ns1:DiagnosticoFallo ;
    rdfs:label "Desactivación RTCP/TLC" ;
    ns1:textoExtracto "'Se ha desactivado #RTCP/TLC' DETECCIÓN Durante la ejecución." .

ns1:RecuperacionPlanoInclinadoActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Recuperación Plano Inclinado Activo" ;
    ns1:textoExtracto "'Se ha recuperado el plano inclinado activo' DETECCIÓN Durante la ejecución. CAUSA Tras el encendido, el CNC ha recuperado el plano inclinado que se encontraba activo al apagarlo." .

ns1:SintaxisIncorrectaOInformacionAdicional a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis Incorrecta o Información Adicional" ;
    ns1:textoExtracto "'Programar #SELECT PROBE [ Nº palpador, POS/NEG]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:VariableNoAccesibleParaCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Variable No Accesible para Canal" ;
    ns1:textoExtracto "'Variable no accesible para su canal. DETECCIÓN Durante la ejecución. CAUSA La variable no es accesible desde el canal.'" .

