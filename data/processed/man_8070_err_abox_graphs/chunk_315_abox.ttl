@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1886
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido" ;
    ex:identificador "1886" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste (parámetro β) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ex:DiagnosticoFallo_1887
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de semiacabado no válido" ;
    ex:identificador "1887" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ex:Parametro_Beta
    a ex:Parametro ;
    rdfs:label "Ángulo de profundización para desbaste (β)" ;
    ex:valor "0º-90º" ;
    ex:textoExtracto "El ángulo de profundización para el desbaste (parámetro β) no está comprendido entre 0º y 90º." ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1886 .

ex:Parametro_Theta
    a ex:Parametro ;
    rdfs:label "Ángulo de profundización para semiacabado (θ)" ;
    ex:valor "0º-90º" ;
    ex:textoExtracto "El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º." ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1887 .

ex:Herramienta_Desbaste
    a ex:Herramienta ;
    rdfs:label "Herramienta de desbaste" ;
    ex:textoExtracto "Ángulo de profundización de la herramienta de desbaste no válido" .

ex:Herramienta_Semiacabado
    a ex:Herramienta ;
    rdfs:label "Herramienta de semiacabado" ;
    ex:textoExtracto "Ángulo de profundización de la herramienta de semiacabado no válido" .