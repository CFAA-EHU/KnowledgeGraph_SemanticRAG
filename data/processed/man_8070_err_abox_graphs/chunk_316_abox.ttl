@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1888
    a ex:Alarma ;
    rdfs:label "Cajera con islas: Tipo de acabado no válido" ;
    ex:identificador "1888" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El tipo de acabado (parámetro Q) no es válido. SOLUCIÓN Asignar un valor correcto a los parámetros." ;
    ex:monitoreaParametro ex:Parametro_Q .

ex:Alarma_1889
    a ex:Alarma ;
    rdfs:label "Movimiento de vaivén: Distancia recorrida demasiado pequeña" ;
    ex:identificador "1889" ;
    ex:textoExtracto "DETECCIÓN Ejecución del movimiento de vaivén para el ajuste del momento de inercia. CAUSA La distancia programada en el movimiento de vaivén es insuficiente. SOLUCIÓN Programar una distancia mayor." .

ex:Alarma_1890
    a ex:Alarma ;
    rdfs:label "Movimiento de vaivén: Distancia recorrida demasiado grande" ;
    ex:identificador "1890" ;
    ex:textoExtracto "DETECCIÓN Ejecución del movimiento de vaivén para el ajuste del momento de inercia. CAUSA La distancia programada en el movimiento de vaivén es demasiado grande. SOLUCIÓN Programar una distancia menor." .

ex:Alarma_1891
    a ex:Alarma ;
    rdfs:label "Herramienta gastada por desgaste de longitud" ;
    ex:identificador "1891" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El ciclo ha detectado que la herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M). SOLUCIÓN Reparar la herramienta o utilizar una herramienta equivalente." ;
    ex:activaAlarma ex:Herramienta_Gastada .

ex:Alarma_1900
    a ex:Alarma ;
    rdfs:label "Dato obligatorio no programado" ;
    ex:identificador "1900" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar uno o más parámetros obligatorios. El parámetro incorrecto estará indicado en el mensaje de error. SOLUCIÓN Programar todos los parámetros obligatorios del ciclo." .

ex:Alarma_1901
    a ex:Alarma ;
    rdfs:label "Dato no válido" ;
    ex:identificador "1901" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro del ciclo tiene un valor incorrecto. El parámetro incorrecto estará indicado en el mensaje de error. SOLUCIÓN Corregir la programación." .

ex:Alarma_AnguloProfundizacion
    a ex:Alarma ;
    rdfs:label "Ángulo de profundización para el acabado no válido" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." ;
    ex:monitoreaParametro ex:Parametro_Theta .

ex:Herramienta_Gastada
    a ex:Herramienta ;
    rdfs:label "Herramienta con desgaste de longitud" ;
    ex:textoExtracto "El ciclo ha detectado que la herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M)." .

ex:Parametro_Q
    a ex:Parametro ;
    rdfs:label "Parámetro Q (tipo de acabado)" ;
    ex:identificador "Q" ;
    ex:textoExtracto "El tipo de acabado (parámetro Q) no es válido." .

ex:Parametro_Theta
    a ex:Parametro ;
    rdfs:label "Parámetro θ (ángulo de profundización)" ;
    ex:identificador "θ" ;
    ex:textoExtracto "El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º." ;
    ex:valor "0º-90º" .

ex:Parametro_M
    a ex:Parametro ;
    rdfs:label "Parámetro M (tolerancia de desgaste)" ;
    ex:identificador "M" ;
    ex:textoExtracto "El desgaste medido es mayor que la tolerancia permitida (parámetro M)." .