@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaLongitudMaximaPermitidaParaElPathEsDe120Caracteres a ns1:TareaMantenimiento ;
    rdfs:label "La longitud máxima permitida para el path es de 120 caracteres" ;
    ns1:solucionaFallo ns1:ElPathDelFicheroEsDemasiadoLargo_875b585706 ;
    ns1:textoExtracto "SOLUCIÓN La longitud máxima permitida para el path es de 120 caracteres." .

ns1:ProgramarElNumeroDePiezaDentroDelRangoP1P4 a ns1:TareaMantenimiento ;
    rdfs:label "Programar el número de pieza dentro del rango P1-P4" ;
    ns1:solucionaFallo ns1:NumeroDePiezaNoValido_3c3ded6de6 ;
    ns1:textoExtracto "SOLUCIÓN Programar el número de pieza dentro del rango P1-P4." .

ns1:ProgramarLaLlamadaALaSubrutinaLocalEnOtroBloqueDePrograma a ns1:TareaMantenimiento ;
    rdfs:label "Programar la llamada a la subrutina local en otro bloque de programa" ;
    ns1:solucionaFallo ns1:SubrutinaLocalYMTOGConSubrutinaEnElMismoBloque ;
    ns1:textoExtracto "SOLUCIÓN Programar la llamada a la subrutina local en otro bloque de programa." .

ns1:ProgramarUnUnicoNumeroDeCanalC1C4 a ns1:TareaMantenimiento ;
    rdfs:label "Programar un único número de canal C1-C4" ;
    ns1:solucionaFallo ns1:DemasiadosCanalesProgramadosEnSentencia_602406201b ;
    ns1:textoExtracto "SOLUCIÓN Programar un único número de canal C1-C4." .

ns1:ProgramarUnUnicoNumeroDePiezaP1P4 a ns1:TareaMantenimiento ;
    rdfs:label "Programar un único número de pieza P1-P4" ;
    ns1:solucionaFallo ns1:NumeroDePiezaMultiple ;
    ns1:textoExtracto "SOLUCIÓN Programar un único número de pieza P1-P4." .

ns1:RevisarLaProgramacionNoSePermiteRealizarSaltosAlInteriorDeUnBucle a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación. No se permite realizar saltos al interior de un bucle" ;
    ns1:solucionaFallo ns1:GOTOSaltoABloquesAnidadosDentroDeIFFORWHILENoPermitido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. No se permite realizar saltos al interior de un bucle." .

ns1:SoloSePermiteProgramarLaSentenciaREPOSEnLasSubrutinasDeInterrupcion a ns1:TareaMantenimiento ;
    rdfs:label "Sólo se permite programar la sentencia #REPOS en las subrutinas de interrupción" ;
    ns1:solucionaFallo ns1:LaSentenciaREPOSSoloSeAdmiteEnSubrutinasDeInterrupcion ;
    ns1:textoExtracto "SOLUCIÓN Sólo se permite programar la sentencia #REPOS en las subrutinas de interrupción." .

ns1:DemasiadosCanalesProgramadosEnSentencia_602406201b a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados canales programados en sentencia" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la sentencia #DGWZ hay programado más de un número de canal. SOLUCIÓN Programar un único número de canal C1-C4." .

ns1:ElPathDelFicheroEsDemasiadoLargo_875b585706 a ns1:DiagnosticoFallo ;
    rdfs:label "El path del fichero es demasiado largo" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El path definido es demasiado largo." .

ns1:GOTOSaltoABloquesAnidadosDentroDeIFFORWHILENoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "$GOTO:Salto a bloques anidados dentro de $IF, $FOR, $WHILE... no permitido" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La instrucción $GOTO no está dentro de un bucle pero está saltando a una etiqueta definida dentro de un bucle $IF, $FOR, etc." .

ns1:LaSentenciaREPOSSoloSeAdmiteEnSubrutinasDeInterrupcion a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #REPOS solo se admite en subrutinas de interrupción" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La instrucción #REPOS no está programada en una subrutina de interrupción. SOLUCIÓN Sólo se permite programar la sentencia #REPOS en las subrutinas de interrupción." .

ns1:NumeroDePiezaMultiple a ns1:DiagnosticoFallo ;
    rdfs:label "Número de pieza múltiple" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la sentencia #DGWZ hay programado más de un número de pieza. SOLUCIÓN Programar un único número de pieza P1-P4." .

ns1:NumeroDePiezaNoValido_3c3ded6de6 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de pieza no válido" ;
    ns1:textoExtracto "programado un número de pieza no válido. SOLUCIÓN Programar el número de pieza dentro del rango P1-P4." .

ns1:SubrutinaLocalYMTOGConSubrutinaEnElMismoBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina local y M, T, o G con subrutina en el mismo bloque" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Un mismo bloque de programa está ejecutando una llamada a una subrutina local y una función M, T o G que tienen una subrutina asociada." .

