@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaSentenciaREPOS a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la sentencia #REPOS" ;
    ns1:solucionaFallo ns1:LaSentenciaREPOSEstaMalProgramada ;
    ns1:textoExtracto "SOLUCIÓN La sentencia #REPOS puede incluir un parámetro opcional INT o INI, seguido de una secuencia de ejes y/o cabezales del canal sin un orden" .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElPathDelFicheroEsDemasiadoLargo ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElPathDelFicheroEsDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "El path del fichero es demasiado largo" ;
    ns1:textoExtracto "1686 El path del fichero es demasiado largo." .

ns1:LaSentenciaREPOSEstaMalProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia #REPOS está mal programada" ;
    ns1:textoExtracto "1687 'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' CAUSA La sentencia #REPOS está mal programada." .

