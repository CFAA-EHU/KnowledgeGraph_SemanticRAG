ex:Alarma_1914
    a ex:Alarma ;
    rdfs:label "F de desbaste no válida"@es ;
    ex:identificador "1914" ;
    ex:textoExtracto "1914 'F de desbaste no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de desbaste tiene valor 0. SOLUCIÓN Definir un avance mayor que 0."@es .

