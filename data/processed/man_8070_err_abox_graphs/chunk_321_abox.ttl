ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:BorrarSubrutinasFstCuandoUnaDeEllasEstaEnEjecucion,
        ns1:CotaFueraDeRangoEnG174_bb4d3a3016 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SolucionActivarTransformada a ns1:AccionProhibida ;
    rdfs:label "Activar transformada con sentencia #FACE ó #CYL" ;
    ns1:textoExtracto "Programar la sentencia #FACE ó #CYL para activar dicha transformada." .

ns1:SolucionEsperarFinalizacionEjecucion a ns1:AccionProhibida ;
    rdfs:label "Esperar finalización de ejecución del programa" ;
    ns1:textoExtracto "SOLUCIÓN Esperar a que finaliza la ejecución del programa." .

ns1:SolucionProgramarCotaCorrecta a ns1:AccionProhibida ;
    rdfs:label "Programar cota correcta en G174" ;
    ns1:textoExtracto "SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647." .

ns1:BorrarSubrutinasFstCuandoUnaDeEllasEstaEnEjecucion a ns1:AccionProhibida ;
    rdfs:label "Borrar subrutinas *.fst cuando una de ellas está en ejecución" ;
    ns1:textoExtracto "No se pueden borrar subrutinas *.fst cuando una de ellas está en ejecución." .

ns1:CotaFueraDeRangoEnG174_bb4d3a3016 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota fuera de rango en G174" ;
    ns1:textoExtracto "Cota fuera de rango en G174. CAUSA La cota programada en G174 está fuera de rango." .

