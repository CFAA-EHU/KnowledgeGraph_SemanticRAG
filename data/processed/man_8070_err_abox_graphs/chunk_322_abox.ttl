ns1:AsignarAlParametroUnValorMayorQue0 a ns1:AccionProhibida ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AsignarAlParametroUnValorMayorQue0EnPunteado a ns1:AccionProhibida ;
    rdfs:label "Asignar al parámetro un valor mayor que 0 en punteado" ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DesactivarLaSentenciaCSROT a ns1:AccionProhibida ;
    rdfs:label "Desactivar la sentencia #CSROT" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la sentencia #CSROT." .

ns1:DiagnosticoFallo_2a5069090f a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro F con valor 0 en punteado" ;
    ns1:textoExtracto "'PUNTEADO: F = 0'" .

ns1:LaFuncionCSROTNoEsAplicableACinematicasConEjesManualesOHirth a ns1:DiagnosticoFallo ;
    rdfs:label "La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth" ;
    ns1:textoExtracto "'La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth'" .

ns1:Parametro_0099e3c526 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado." .

ns1:Parametro_4e1e79e3ac a ns1:Parametro ;
    rdfs:label "Función CSROT" ;
    ns1:textoExtracto "'La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth'" .

ns1:ParametrosMalProgramados a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetros mal programados" ;
    ns1:textoExtracto "'Programar #CSROT [ON]/OFF' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados." .

ns1:RevisarLaProgramacionDeCSROT a ns1:AccionProhibida ;
