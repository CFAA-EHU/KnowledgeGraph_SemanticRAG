ns1:AvanceProgramado a ns1:Parametro ;
    rdfs:label "Avance programado" ;
    ns1:textoExtracto "'TALADRADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0." .

