@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroFUnValorMayorQue0 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro F un valor mayor que 0" ;
    ns1:solucionaFallo ns1:TALADRADO2F0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

