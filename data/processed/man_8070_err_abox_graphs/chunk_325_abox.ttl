ns1:TALADRADO2F0 a ns1:DiagnosticoFallo ;
    rdfs:label "TALADRADO 2: F = 0" ;
    ns1:textoExtracto "'TALADRADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado." .

