@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal." ;
    ex:valor "TRUE/FALSE" .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." ;
    ex:valor "TRUE/FALSE" .

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "CAXIS" ;
    ex:textoExtracto "Definir algún eje o cabezal del canal como eje C (parámetro CAXIS)." ;
    ex:valor "eje/cabezal" .

ex:Parametro_GEOCONFIG
    a ex:Parametro ;
    rdfs:label "GEOCONFIG" ;
    ex:textoExtracto "Definir una configuración de ejes tipo triedro en el canal (parámetro GEOCONFIG) con un eje Y." ;
    ex:valor "triedro" .

ex:Parametro_Z
    a ex:Parametro ;
    rdfs:label "Z (cota superficie pieza)" ;
    ex:textoExtracto "Falta programar la cota de la superficie de la pieza (parámetro Z)." ;
    ex:valor "coordenada Z" .

ex:Parametro_Zs
    a ex:Parametro ;
    rdfs:label "Zs (plano seguridad)" ;
    ex:textoExtracto "Falta programar el plano de seguridad (parámetro Zs)." ;
    ex:valor "coordenada Z" .

ex:AvisoSeguridad_1936
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1936: No se ha definido ningún eje como FACEAXIS en ciclo de eje C" ;
    ex:textoExtracto "1936 'No se ha definido ningún eje como FACEAXIS en ciclo de eje C' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definido ningún eje frontal en el canal. SOLUCIÓN Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." ;
    ex:identificador "1936" .

ex:AvisoSeguridad_1937
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1937: No hay definido ningún eje o cabezal para eje C" ;
    ex:textoExtracto "1937 'No hay definido ningún eje o cabezal para eje C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje C, y no hay ningún eje C en el canal. SOLUCIÓN Definir algún eje o cabezal del canal como eje C (parámetro CAXIS)." ;
    ex:identificador "1937" .

ex:AvisoSeguridad_1938
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1938: No hay definido ningún eje para eje Y" ;
    ex:textoExtracto "1938 'No hay definido ningún eje para eje Y' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje Y, y no hay ningún eje Y en el canal. SOLUCIÓN Definir una configuración de ejes tipo triedro en el canal (parámetro GEOCONFIG) con un eje Y." ;
    ex:identificador "1938" .

ex:AvisoSeguridad_1950
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1950: No programada la cota Z de la superficie de la pieza" ;
    ex:textoExtracto "1950 'No programada la cota Z de la superficie de la pieza' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación." ;
    ex:identificador "1950" .

ex:AvisoSeguridad_1951
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1951: No programada la cota Z de seguridad" ;
    ex:textoExtracto "1951 'No programada la cota Z de seguridad' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el plano de seguridad (parámetro Zs)." ;
    ex:identificador "1951" .

ex:DiagnosticoFallo_1949
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1949: La cuchilla no puede mecanizar el perfil completamente" ;
    ex:textoExtracto "1949 'La cuchilla no puede mecanizar el perfil completamente' DETECCIÓN Durante la ejecución de un ciclo fijo de desbaste seguimiento de perfil de torno. CAUSA La geometria de la herramienta no permite que ésta pueda mecanizar todo el perfil programado. CONSECUENCIA El ciclo no puede mecanizar completamente el perfil programado. SOLUCIÓN Modificar el perfil o cambiar de herramienta para que ésta pueda mecanizar el perfil." ;
    ex:identificador "1949" .

ex:AvisoSeguridad_1936 ex:solucionaFallo ex:Parametro_FACEAXIS .
ex:AvisoSeguridad_1937 ex:solucionaFallo ex:Parametro_CAXIS .
ex:AvisoSeguridad_1938 ex:solucionaFallo ex:Parametro_GEOCONFIG .
ex:AvisoSeguridad_1950 ex:solucionaFallo ex:Parametro_Z .
ex:AvisoSeguridad_1951 ex:solucionaFallo ex:Parametro_Zs .