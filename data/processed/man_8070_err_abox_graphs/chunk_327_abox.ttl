@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1951
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "No programada la cota Z de seguridad"@es ;
    ex:textoExtracto    "CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación. 1951 'No programada la cota Z de seguridad' DETECCIÓN Durante la ejecución del ciclo."@es ;
    ex:identificador    "1951" .

ex:Fallo_1952
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "No programada la profundidad de la pieza"@es ;
    ex:textoExtracto    "CAUSA Falta programar el plano de seguridad (parámetro Zs). SOLUCIÓN Corregir la programación. 1952 'No programada la profundidad de la pieza' DETECCIÓN Durante la ejecución del ciclo."@es ;
    ex:identificador    "1952" .

ex:Fallo_1953
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "No programado el paso de la pieza"@es ;
    ex:textoExtracto    "CAUSA Falta programar la profundidad de la pieza (parámetro P). SOLUCIÓN Corregir la programación. 1953 'No programado el paso de"@es ;
    ex:identificador    "1953" .

ex:Parametro_Z
    a                   ex:Parametro ;
    rdfs:label          "Cota Z de seguridad"@es ;
    ex:textoExtracto    "parámetro Z"@es ;
    ex:identificador    "Z" .

ex:Parametro_Zs
    a                   ex:Parametro ;
    rdfs:label          "Plano de seguridad"@es ;
    ex:textoExtracto    "parámetro Zs"@es ;
    ex:identificador    "Zs" .

ex:Parametro_P
    a                   ex:Parametro ;
    rdfs:label          "Profundidad de la pieza"@es ;
    ex:textoExtracto    "parámetro P"@es ;
    ex:identificador    "P" .

ex:Fallo_1951
    ex:solucionaFallo    ex:Parametro_Z .

ex:Fallo_1952
    ex:solucionaFallo    ex:Parametro_Zs .

ex:Fallo_1953
    ex:solucionaFallo    ex:Parametro_P .