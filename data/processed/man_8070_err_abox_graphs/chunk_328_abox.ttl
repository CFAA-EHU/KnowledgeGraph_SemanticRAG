@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1953
    a ex:DiagnosticoFallo ;
    rdfs:label "No programado el paso de profundidad" ;
    ex:identificador "1953" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el paso de profundización (parámetro I). SOLUCIÓN Corregir la programación." .

ex:Fallo_1954
    a ex:DiagnosticoFallo ;
    rdfs:label "No programado el paso de desbaste" ;
    ex:identificador "1954" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el paso de desbaste (parámetro D). SOLUCIÓN Corregir la programación." .

ex:Fallo_1955
    a ex:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de desbaste nulo" ;
    ex:identificador "1955" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de desbaste tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1956
    a ex:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado nulo" ;
    ex:identificador "1956" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1957
    a ex:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado nulo" ;
    ex:identificador "1957" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1958
    a ex:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de desbaste demasiado grande" ;
    ex:identificador "1958" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de desbaste es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1959
    a ex:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado demasiado grande" ;
