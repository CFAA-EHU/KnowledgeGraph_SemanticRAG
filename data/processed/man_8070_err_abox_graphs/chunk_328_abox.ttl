ns1:AvanceProgramado_6cfc5a94ff a ns1:Parametro ;
    rdfs:label "Avance programado" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "'MANDRINADO 1: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado." .

