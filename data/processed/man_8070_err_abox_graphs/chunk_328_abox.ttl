    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Parametro_P
    a ex:Parametro ;
    rdfs:label "Profundidad de la pieza" ;
    ex:identificador "P" ;
    ex:textoExtracto "Falta programar la profundidad de la pieza (parámetro P)." .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Paso de profundización" ;
    ex:identificador "I" ;
    ex:textoExtracto "Falta programar el paso de profundización (parámetro I)." .

ex:Parametro_D
    a ex:Parametro ;
    rdfs:label "Paso de desbaste" ;
    ex:identificador "D" ;
    ex:textoExtracto "Falta programar el paso de desbaste (parámetro D)." .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ex:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ex:Fallo_1953 ex:solucionaFallo ex:Parametro_P .
ex:Fallo_1954 ex:solucionaFallo ex:Parametro_D .
