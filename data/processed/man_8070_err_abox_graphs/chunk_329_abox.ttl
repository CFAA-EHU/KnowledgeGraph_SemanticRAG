@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1959
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Radio de herramienta de acabado demasiado grande"@es ;
    ex:identificador      "1959" ;
    ex:textoExtracto      "'Radio de herramienta de acabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ex:Fallo_1960
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Radio de herramienta de semiacabado demasiado grande"@es ;
    ex:identificador      "1960" ;
    ex:textoExtracto      "'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado"@es .

ex:Herramienta_Acabado
    a                     ex:Herramienta ;
    ex:textoExtracto      "herramienta de acabado"@es ;
    ex:monitoreaParametro ex:Parametro_Radio_Acabado .

ex:Herramienta_Semiacabado
    a                     ex:Herramienta ;
    ex:textoExtracto      "herramienta de semiacabado"@es ;
    ex:monitoreaParametro ex:Parametro_Radio_Semiacabado .

ex:Parametro_Radio_Acabado
    a                     ex:Parametro ;
    rdfs:label            "Radio de herramienta de acabado"@es ;
    ex:textoExtracto      "radio de la herramienta de acabado"@es .

ex:Parametro_Radio_Semiacabado
    a                     ex:Parametro ;
    rdfs:label            "Radio de herramienta de semiacabado"@es ;
    ex:textoExtracto      "radio de la herramienta de semiacabado"@es .

ex:Fallo_1959 ex:solucionaFallo ex:Herramienta_Acabado .
ex:Fallo_1960 ex:solucionaFallo ex:Herramienta_Semiacabado .