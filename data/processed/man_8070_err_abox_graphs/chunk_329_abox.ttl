@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_03c728a720 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:NoHayAvanceProgramado_0d302e68c6,
        ns1:NoHayProfundidadProgramada_d7debd68f9,
        ns1:NoHayVelocidadProgramada_808cbc9a66,
        ns1:NoHayVelocidadProgramada_e791192369 ;
    ns1:textoExtracto "Asignar al parámetro un valor mayor que 0." .

ns1:Parametro_04efeb2612 a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad en mandrinado" ;
    ns1:identificador "S" ;
    ns1:textoExtracto "El parámetro S tiene valor 0." .

ns1:Parametro_2ab95a10ab a ns1:Parametro ;
    rdfs:label "Parámetro de avance en mandrinado" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "El parámetro F tiene valor 0." .

ns1:Parametro_4ab528adae a ns1:Parametro ;
    rdfs:label "Parámetro de profundidad en taladrado" ;
    ns1:identificador "P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0." .

ns1:Parametro_9eb0d1cf51 a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad en taladrado" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "El parámetro T tiene valor 0." .

ns1:NoHayAvanceProgramado_0d302e68c6 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay avance programado" ;
    ns1:textoExtracto "'MANDRINADO 2: F = 0'" .

ns1:NoHayProfundidadProgramada_d7debd68f9 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay profundidad programada" ;
    ns1:textoExtracto "'TALADRADO 3: P = 0'" .

ns1:NoHayVelocidadProgramada_808cbc9a66 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay velocidad programada" ;
    ns1:textoExtracto "'MANDRINADO 2: S = 0'" .

ns1:NoHayVelocidadProgramada_e791192369 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay velocidad programada" ;
    ns1:textoExtracto "'TALADRADO 3: T = 0'" .

