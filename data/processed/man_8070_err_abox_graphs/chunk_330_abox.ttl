@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_56a30422b5 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:CAJERARECTANGULARF0,
        ns1:CAJERARECTANGULARS0,
        ns1:MANDRINADO2P0,
        ns1:MANDRINADO2S0_bf4746db2b,
        ns1:MANDRINADO2T0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:ProgramarUnaHerramientaParaLaOperacionDeDesbasteOAcabado a ns1:AccionProhibida ;
    rdfs:label "Programar una herramienta para la operación de desbaste o acabado" ;
    ns1:solucionaFallo ns1:CAJERARECTANGULART0 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:CAJERARECTANGULARF0 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: F = 0" ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:CAJERARECTANGULARS0 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: S = 0" ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:CAJERARECTANGULART0 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: T = 0" ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0." .

ns1:MANDRINADO2P0 a ns1:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: P = 0" ;
    ns1:textoExtracto "'MANDRINADO 2: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0." .

ns1:MANDRINADO2S0_bf4746db2b a ns1:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: S = 0" ;
    ns1:textoExtracto "'MANDRINADO 2: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0." .

ns1:MANDRINADO2T0 a ns1:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: T = 0" ;
    ns1:textoExtracto "'MANDRINADO 2: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0." .

