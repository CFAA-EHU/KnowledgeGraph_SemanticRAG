@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1967
    a ex:Alarma ;
    rdfs:label "Cota Z del plano de partida no válida" ;
    ex:identificador "1967" ;
    ex:textoExtracto "1967 'Cota Z del plano de partida no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La cota Z de comienzo del ciclo se encuentra dentro de la pieza. SOLUCIÓN La cota Z de comienzo del ciclo debe estar por encima del plano de referencia." .

ex:Alarma_1968
    a ex:Alarma ;
    rdfs:label "Cota Z de seguridad no válida" ;
    ex:identificador "1968" ;
    ex:textoExtracto "1968 'Cota Z de seguridad no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El plano de seguridad se encuentra dentro de la pieza. SOLUCIÓN Asignar un valor correcto al parámetro." .

ex:Alarma_1969
    a ex:Alarma ;
    rdfs:label "No existe el perfil en XY programado" ;
    ex:identificador "1969" ;
    ex:textoExtracto "1969 'No existe el perfil en XY programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de superficie no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ex:Alarma_1970
    a ex:Alarma ;
    rdfs:label "No existe el perfil en Z programado" ;
    ex:identificador "1970" ;
    ex:textoExtracto "1970 'No existe el perfil en Z programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de profundidad no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ex:Alarma_1971
    a ex:Alarma ;
    rdfs:label "Programado perfil en XY abierto" ;
    ex:identificador "1971" ;
    ex:textoExtracto "1971 'Programado perfil en XY abierto' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo. SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ex:Alarma_1972
    a ex:Alarma ;
    rdfs:label "Perfil en XY no válido" ;
    ex:identificador "1972" ;
    ex:textoExtracto "1972 'Perfil en XY no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de superficie no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ex:Alarma_1973
    a ex:Alarma ;
    rdfs:label "Perfil en Z no válido" ;
    ex:identificador "1973" ;
    ex:textoExtracto "1973 'Perfil en Z no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada. SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ex:Alarma_1974
    a ex:Alarma ;
    rdfs:label "Intersección de perfiles no válida" ;
    ex:identificador "1974" ;
    ex:textoExtracto "1974 'Intersección de perfiles no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ex:Parametro_CotaZ_PlanoPartida
    a ex:Parametro ;
    rdfs:label "Cota Z del plano de partida" ;
    ex:textoExtracto "La cota Z de comienzo del ciclo se encuentra dentro de la pieza. La cota Z de comienzo del ciclo debe estar por encima del plano de referencia." ;
    ex:monitoreaParametro ex:Alarma_1967 .

ex:Parametro_CotaZ_Seguridad
    a ex:Parametro ;
    rdfs:label "Cota Z de seguridad" ;
    ex:textoExtracto "El plano de seguridad se encuentra dentro de la pieza." ;
    ex:monitoreaParametro ex:Alarma_1968 .

ex:Parametro_PerfilXY
    a ex:Parametro ;
    rdfs:label "Perfil en XY" ;
    ex:textoExtracto "El perfil de superficie no existe. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." ;
    ex:monitoreaParametro ex:Alarma_1969 , ex:Alarma_1971 , ex:Alarma_1972 .

ex:Parametro_PerfilZ
    a ex:Parametro ;
    rdfs:label "Perfil en Z" ;
    ex:textoExtracto "El perfil de profundidad no existe. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." ;
    ex:monitoreaParametro ex:Alarma_1970 , ex:Alarma_1973 .

ex:DiagnosticoFallo_InterseccionPerfiles
    a ex:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no válida" ;
    ex:textoExtracto "Dos perfiles de superficie generan alguna intersección no válida." ;
    ex:solucionaFallo ex:Alarma_1974 .