ns1:AsignarAlParametroUnValorMayorQue0_56a30422b5 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2658dc6d26,
        ns1:DiagnosticoFallo_c0701278af ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Herramienta_50f5116ef9 a ns1:Herramienta ;
    rdfs:label "Herramienta de mayor diámetro para la pasada de acabado" ;
    ns1:solucionaFallo ns1:DiametroDeHerramientaDeAcabadoMenorQueDelta ;
    ns1:textoExtracto "Elegir una herramienta de mayor diámetro para la pasada de acabado." .

ns1:Herramienta_a71be7a4c6 a ns1:Herramienta ;
    rdfs:label "Herramienta de menor diámetro" ;
    ns1:solucionaFallo ns1:DiametroDeHerramientaMayorQueCajera ;
    ns1:textoExtracto "Elegir una herramienta de menor diámetro." .

ns1:Herramienta_fcdc2821bc a ns1:Herramienta ;
    rdfs:label "Herramienta de diámetro mayor" ;
    ns1:solucionaFallo ns1:DiametroDeHerramientaMenorQueElPasoDeFresado ;
    ns1:textoExtracto "Utilizar una herramienta de diámetro mayor." .

ns1:ProgramarUnaHerramientaParaLaOperacionDeDesbasteOAcabado_c1a32d9560 a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta para la operación de desbaste o acabado" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_8697c74747 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:ReducirElPasoDeFresado a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado" ;
    ns1:solucionaFallo ns1:DiametroDeHerramientaMenorQueElPasoDeFresado ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:DiagnosticoFallo_2658dc6d26 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro S tiene valor 0" ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:DiagnosticoFallo_8697c74747 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro T tiene valor 0" ;
    ns1:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." .

ns1:DiagnosticoFallo_c0701278af a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro F tiene valor 0" ;
    ns1:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:DiametroDeHerramientaDeAcabadoMenorQueDelta a ns1:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta de acabado menor que delta" ;
    ns1:textoExtracto "El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro )." .

ns1:DiametroDeHerramientaMayorQueCajera a ns1:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta mayor que cajera" ;
    ns1:textoExtracto "En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H)." .

ns1:DiametroDeHerramientaMenorQueElPasoDeFresado a ns1:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta menor que el paso de fresado" ;
    ns1:textoExtracto "En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro )." .

