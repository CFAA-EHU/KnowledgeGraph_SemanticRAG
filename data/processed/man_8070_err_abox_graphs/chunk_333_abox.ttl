@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarValorAlParametro a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor al parámetro" ;
    ns1:solucionaFallo ns1:CajeraPrevacidaP0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:CajeraPrevacidaDiametroDeHerramientaMenorQueDELTA a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera prevacida: Diámetro de herramienta menor que DELTA" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo." .

ns1:NoProgramarHerramienta_7b080bfc54 a ns1:AccionProhibida ;
    rdfs:label "No programar herramienta" ;
    ns1:textoExtracto "No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0." ;
    ns1:valor "0" .

ns1:CajeraPrevacidaP0 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera prevacida: P = 0" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

