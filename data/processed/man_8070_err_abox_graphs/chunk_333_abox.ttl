@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1974
    a ex:AvisoSeguridad ;
    rdfs:label "Intersección de perfiles no válida" ;
    ex:identificador "1974" ;
    ex:textoExtracto "1974 'Intersección de perfiles no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ex:AvisoSeguridad_1975
    a ex:AvisoSeguridad ;
    rdfs:label "No se ha producido palpación" ;
    ex:identificador "1975" ;
    ex:textoExtracto "1975 'No se ha producido palpación' DETECCIÓN Durante la ejecución" .

ex:DiagnosticoFallo_1974
    a ex:DiagnosticoFallo ;
    rdfs:label "Intersección no válida de perfiles de superficie" ;
    ex:textoExtracto "Dos perfiles de superficie generan alguna intersección no válida. SOLUCIÓN Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos." ;
    ex:solucionaFallo ex:AvisoSeguridad_1974 .

ex:DiagnosticoFallo_1975
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en palpación durante ejecución" ;
    ex:textoExtracto "No se ha producido palpación durante la ejecución del ciclo." ;
    ex:solucionaFallo ex:AvisoSeguridad_1975 .