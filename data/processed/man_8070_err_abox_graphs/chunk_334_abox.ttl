@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CAJERAPREVACIADADiametroDeHerramientaACABADOMenorQueDelta a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta ACABADO menor que delta" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Diámetro de herramienta ACABADO menor que delta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado." .

ns1:CAJERAPREVACIADADiametroDeHerramientaMayorQueCajera a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN Elegir una herramienta de menor diámetro." .

ns1:CAJERAPREVACIADADiametroDeHerramientaMenorQueDELTA_1f8e18a3e6 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:CAJERAPREVACIADARR a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: R < r" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: R < r' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r). SOLUCIÓN El radio de la cajera (radio exterior ) debe ser mayor que el radio de prevaciado (radio interior)." .

ns1:MOYURECTANGULARF0_b2b7b891f0 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: F = 0" ;
    ns1:textoExtracto "'MOYU RECTANGULAR: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:MOYURECTANGULARS0_1275bff5b5 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: S = 0" ;
    ns1:textoExtracto "'MOYU RECTANGULAR: S = 0' DETECCIÓN Durante la ejecución del ciclo." .

ns1:ParametroF a ns1:Parametro ;
    rdfs:label "Parámetro F" ;
    ns1:textoExtracto "CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:ParametroS a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "'MOYU RECTANGULAR: S = 0' DETECCIÓN Durante la ejecución del ciclo." .

ns1:PasoDeFresadoParametro a ns1:Parametro ;
    rdfs:label "Paso de fresado (parámetro )" ;
    ns1:textoExtracto "CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro )." .

ns1:RadioDeLaCajera a ns1:Parametro ;
    rdfs:label "Radio de la cajera" ;
    ns1:textoExtracto "CAUSA El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r)." .

ns1:RadioDePrevaciado a ns1:Parametro ;
    rdfs:label "Radio de prevaciado" ;
    ns1:textoExtracto "CAUSA El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r)." .

