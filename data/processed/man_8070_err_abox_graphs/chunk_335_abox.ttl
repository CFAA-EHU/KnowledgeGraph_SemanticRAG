@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1987
    a               ex:DiagnosticoFallo ;
    rdfs:label      "No hay contacto con la esfera"@es ;
    ex:identificador "1987" ;
    ex:textoExtracto "1987 'No hay contacto con la esfera' DETECCIÓN Durante la ejecución. CAUSA No ha llegado señal de palpado cuando se esperaba tocar la esfera."@es .

ex:Fallo_1988
    a               ex:DiagnosticoFallo ;
    rdfs:label      "El tipo de palpador no es válido (P6)"@es ;
    ex:identificador "1988" ;
    ex:textoExtracto "1988 'El tipo de palpador no es valido (P6)'"@es .

ex:Parametro_Cinematica
    a               ex:Parametro ;
    rdfs:label      "Parámetros de cinemática"@es ;
    ex:valor         "1 mm" ;
    ex:textoExtracto "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es ;
    ex:monitoreaParametro ex:Fallo_1987 .

ex:Tarea_RevisarProgramacion
    a               ex:TareaMantenimiento ;
    rdfs:label      "Revisar la programación del palpador"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente."@es ;
    ex:solucionaFallo ex:Fallo_1987 .

ex:Tarea_AjustarParametrosCinematicos
    a               ex:TareaMantenimiento ;
    rdfs:label      "Ajustar parámetros de cinemática"@es ;
    ex:textoExtracto "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es ;
    ex:solucionaFallo ex:Fallo_1987 .