ns1:CicloDetenidoPorDiametroDeHerramientaMenorQueDelta a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo detenido por diámetro de herramienta menor que delta" ;
    ns1:textoExtracto "'MOYU RECTANGULAR: Diámetro de herramienta menor que DELTA'" .

