    rdfs:label "Asignar valor mayor que 0 al parámetro P" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorParametroPIgualA0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AsignarValorMayorQue0AlParametroS a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor mayor que 0 al parámetro S" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorParametroSIgualA0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AsignarValorMayorQue0AlParametroT a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor mayor que 0 al parámetro T" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorParametroTIgualA0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiametroDeHerramientaDeAcabadoMenorQueDelta_15b5f451c4 a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta de acabado menor que delta" ;
    ns1:textoExtracto "El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro )." .

ns1:DiametroDeHerramientaMenorQueDelta a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta menor que delta" ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro )." .

ns1:ElegirHerramientaDeMayorDiametroParaLaPasadaDeAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Elegir herramienta de mayor diámetro para la pasada de acabado" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorDiametroDeHerramientaDeAcabadoMenorQueDelta ;
    ns1:textoExtracto "SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado." .

ns1:OperacionSinHerramientaProgramada a ns1:AccionProhibida ;
    rdfs:label "Operación sin herramienta programada" ;
    ns1:textoExtracto "No hay herramienta programada." .

ns1:ProgramarHerramientaParaLaOperacionDeDesbasteOAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Programar herramienta para la operación de desbaste o acabado" ;
    ns1:solucionaFallo ns1:CicloNoEjecutaOperacionSinHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:ReducirPasoDeFresadoOUtilizarHerramientaDeDiametroMayor a ns1:TareaMantenimiento ;
    rdfs:label "Reducir paso de fresado o utilizar herramienta de diámetro mayor" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorDiametroDeHerramientaMenorQueDelta ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:CicloDetenidoPorDiametroDeHerramientaDeAcabadoMenorQueDelta a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo detenido por diámetro de herramienta de acabado menor que delta" ;
