    rdfs:label "Asignar valor mayor que 0 al parámetro F" ;
    ns1:solucionaFallo ns1:CicloDetenidoPorParametroFIgualA0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

