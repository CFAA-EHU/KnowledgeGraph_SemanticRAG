    ns1:textoExtracto "'MOYU CIRCULAR: T = 0'" .

ns1:CicloNoEjecutaOperacionSinHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo no ejecuta operación sin herramienta" ;
    ns1:textoExtracto "Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

