@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_0d40d2dcc0 a ns1:AccionProhibida ;
    rdfs:label "Parámetro P igual a 0" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:AccionProhibida_0f73f21522 a ns1:AccionProhibida ;
    rdfs:label "Parámetro F igual a 0" ;
    ns1:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:AccionProhibida_5b54d7769f a ns1:AccionProhibida ;
    rdfs:label "Parámetro S igual a 0" ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:AccionProhibida_8a8c4c9b3c a ns1:AccionProhibida ;
    rdfs:label "Parámetro T igual a 0" ;
    ns1:textoExtracto "Algún parámetro T tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

