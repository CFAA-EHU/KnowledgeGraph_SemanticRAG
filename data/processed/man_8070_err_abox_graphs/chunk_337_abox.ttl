@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignacionDeParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de parámetros" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_9468301133,
        ns1:DiagnosticoFallo_cc360d7c69 ;
    ns1:textoExtracto "'SOLUCIÓN Asignar al parámetro un valor mayor que 0.' 'Programar una herramienta para la operación de desbaste o acabado.'" .

ns1:OperacionesSinHerramientaProgramada a ns1:AccionProhibida ;
    rdfs:label "Operaciones sin herramienta programada" ;
    ns1:textoExtracto "'CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada.'" .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "'1759 'MOYU CIRCULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P'" .

ns1:ParametroS a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "'CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado.'" .

ns1:ParametroT a ns1:Parametro ;
    rdfs:label "Parámetro T" ;
    ns1:textoExtracto "'CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada.'" .

ns1:ParametrosConValorCero a ns1:AccionProhibida ;
    rdfs:label "Parámetros con valor cero" ;
    ns1:textoExtracto "'CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado.'" .

ns1:ProgramacionDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Programación de herramientas" ;
    ns1:textoExtracto "'SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta.'" .

ns1:DiagnosticoFallo_9468301133 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro con valor cero" ;
    ns1:textoExtracto "'1758 'MOYU CIRCULAR: T = 0' DETECCIÓN Durante la ejecución del ciclo.'" .

ns1:DiagnosticoFallo_cc360d7c69 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro P con valor cero" ;
    ns1:textoExtracto "'1759 'MOYU CIRCULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo.'" .

