    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:MOYUCIRCULARDiametroDeHerramientaACABADOMenorQueDelta_1e1fdcefac a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta ACABADO menor que delta" ;
    ns1:textoExtracto "'MOYU CIRCULAR: Diámetro de herramienta ACABADO menor que delta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro )." .

ns1:MOYUCIRCULARDiametroDeHerramientaMenorQueDELTA_1468f904d9 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta menor que DELTA" ;
    ns1:textoExtracto "'MOYU CIRCULAR: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro )." .

