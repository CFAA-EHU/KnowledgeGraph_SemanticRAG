ns1:ElegirUnaHerramientaDeMayorDiametroParaLaPasadaDeAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Elegir una herramienta de mayor diámetro para la pasada de acabado" ;
    ns1:solucionaFallo ns1:MOYUCIRCULARDiametroDeHerramientaACABADOMenorQueDelta_1e1fdcefac ;
    ns1:textoExtracto "SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado." .

ns1:ParametroF a ns1:Parametro ;
    rdfs:label "Parámetro F" ;
    ns1:textoExtracto "'PLANEADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "'MOYU CIRCULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0." .

ns1:ParametroR a ns1:Parametro ;
    rdfs:label "Parámetro R" ;
    ns1:textoExtracto "'MOYU CIRCULAR: R = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro R tiene valor 0." .

ns1:ParametroS a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "'PLANEADO: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:ReducirElPasoDeFresadoOUtilizarUnaHerramientaDeDiametroMayor a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor" ;
