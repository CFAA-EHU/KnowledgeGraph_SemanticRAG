ns1:AsignarUnValorMayorQue0AlParametroS a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor mayor que 0 al parámetro S" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_7d01764b60 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Herramienta_5c531f1aea a ns1:Herramienta ;
    rdfs:label "Herramienta programada" ;
    ns1:textoExtracto "Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No" .

ns1:ParametroS a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:ParametroT a ns1:Parametro ;
    rdfs:label "Parámetro T" ;
    ns1:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0." .

ns1:ProgramarUnaHerramientaParaLaOperacionDeDesbasteOAcabado_c1a32d9560 a ns1:TareaMantenimiento ;
