    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:DiagnosticoFallo_2e16302331 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro T con valor 0" ;
    ns1:textoExtracto "CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." .

