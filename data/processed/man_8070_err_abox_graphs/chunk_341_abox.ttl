@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_56a30422b5 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:PERFILDEPUNTOSP0_effae42447 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DefinirCorrectamenteLosPuntosDelPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Definir correctamente los puntos del perfil" ;
    ns1:solucionaFallo ns1:PERFILDEPUNTOSPerfilNulo ;
    ns1:textoExtracto "SOLUCIÓN Definir correctamente los puntos del perfil. Dos puntos iguales indican el final del perfil." .

ns1:PERFILDEPUNTOSRadioDeHerramientaMayorOIgualQueRadioDeEntradaSalidaTangencial_ebeefb11da a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial" ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' DETECCIÓN Durante la ejecución del ciclo." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:PERFILDEPUNTOSP0_effae42447 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: P = 0" ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:PERFILDEPUNTOSPerfilNulo a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: Perfil nulo" ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Perfil nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA Los dos primeros puntos del perfil (P1 y P2) son iguales; el ciclo considera que no hay perfil definido." .

