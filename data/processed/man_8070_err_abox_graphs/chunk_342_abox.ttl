@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_633ab660ab a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:PERFILP0_1cbffb8fab ;
    ns1:textoExtracto "'PERFIL: P = 0' SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AsignarAlParametroUnValorMayorQue0_7561742d3c a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:PERFILF0_174e8186d8 ;
    ns1:textoExtracto "'PERFIL: F = 0' SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AsignarAlParametroUnValorMayorQue0_9bd43f8338 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:PERFILS0_547cc1067b ;
    ns1:textoExtracto "'PERFIL: S = 0' SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:AumentarElRadioDeLaEntradaSalidaTangencialOEjecutarElCicloConUnaHerra_4a5be71c9d a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el radio de la entrada/salida tangencial o ejecutar el ciclo con una herramienta de menor radio" ;
    ns1:solucionaFallo ns1:PERFILDEPUNTOSRadioDeHerramientaMayorOIgualQueRadioDeEntradaSalidaTangencial_ebeefb11da ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' SOLUCIÓN Aumentar el radio de la entrada/salida tangencial o ejecutar el ciclo con una herramienta de menor radio." .

ns1:PERFILACABADOLongitudDeCorteDeHerramientaP_262fee15a7 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: (ACABADO): Longitud de corte de herramienta < P" ;
    ns1:textoExtracto "'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)." .

ns1:ProgramarUnaHerramientaParaLaOperacionDeDesbasteOAcabado_fff136c844 a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta para la operación de desbaste o acabado" ;
    ns1:solucionaFallo ns1:PERFILT0_ac82c80c4f ;
    ns1:textoExtracto "'PERFIL: T = 0' SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:PERFILDEPUNTOSRadioDeHerramientaMayorOIgualQueRadioDeEntradaSalidaTangencial_ebeefb11da a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial" ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de una de las herramientas usadas en el ciclo es igual o mayor que el radio de la entrada tangencial (radio del punto P1) o de la salida tangencial (radio del punto P12). SOLUCIÓN Aumentar el radio de la entrada/salida tangencial o ejecutar el ciclo con una herramienta de menor radio." .

ns1:PERFILF0_174e8186d8 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: F = 0" ;
    ns1:textoExtracto "'PERFIL: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:PERFILP0_1cbffb8fab a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: P = 0" ;
    ns1:textoExtracto "'PERFIL: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:PERFILS0_547cc1067b a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: S = 0" ;
    ns1:textoExtracto "'PERFIL: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:PERFILT0_ac82c80c4f a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: T = 0" ;
    ns1:textoExtracto "'PERFIL: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

