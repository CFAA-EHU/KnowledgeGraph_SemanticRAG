@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_56a30422b5 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_dfb02e559d ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:ElegirComoHerramientaDeAcabadoUnaHerramientaDeMayorLongitudDeCorte a ns1:TareaMantenimiento ;
    rdfs:label "Elegir como herramienta de acabado una herramienta de mayor longitud de corte" ;
    ns1:solucionaFallo ns1:LongitudDeCorteDeHerramientaMenorQueP ;
    ns1:textoExtracto "SOLUCIÓN Elegir como herramienta de acabado una herramienta de mayor longitud de corte." .

ns1:ParametroF a ns1:Parametro ;
    rdfs:label "Parámetro F" ;
    ns1:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:DiagnosticoFallo_dfb02e559d a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro F tiene valor 0" ;
    ns1:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:LongitudDeCorteDeHerramientaMenorQueP a ns1:DiagnosticoFallo ;
    rdfs:label "Longitud de corte de herramienta menor que P" ;
    ns1:textoExtracto "'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)." .

