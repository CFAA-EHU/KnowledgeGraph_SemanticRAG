@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorMayorQue0_56a30422b5 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor mayor que 0."@es ;
    ns1:solucionaFallo ns1:AlgunParametroFTieneValor0FaltaProgramarElAvanceDeDesbasteAcabadoOPro_33179be60e,
        ns1:AlgunParametroSTieneValor0FaltaProgramarLaVelocidadParaElDesbasteOAcabado,
        ns1:ElParametroLTieneValor0LaRanuraNoTieneLongitud,
        ns1:ElParametroPTieneValor0NoHayProfundidadProgramada ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:ParametroF a ns1:Parametro ;
    rdfs:label "Parámetro F" ;
    ns1:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:ParametroL a ns1:Parametro ;
    rdfs:label "Parámetro L" ;
    ns1:textoExtracto "'RANURADO: L = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro L tiene valor 0. La ranura no tiene longitud." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "'RANURADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:ParametroS a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "'RANURADO: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:ParametroT a ns1:Parametro ;
    rdfs:label "Parámetro T" ;
    ns1:textoExtracto "'RANURADO: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." .

ns1:ProgramarUnaHerramientaParaLaOperacionDeDesbasteOAcabado_ac74438faa a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta para la operación de desbaste o acabado."@es ;
    ns1:solucionaFallo ns1:ElParametroTDeLasOperacionesDeDesbasteYAcabadoTieneValor0NoHayHerrami_08afa6e316 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:ReducirElPasoDeFresadoOUtilizarUnaHerramientaDeDiametroMayor a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es ;
    ns1:solucionaFallo ns1:EnLaOperacionDeDesbasteOAcabadoElDiametroDeLaHerramientaEsMenorQueElP_d9fac21636 ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:AlgunParametroFTieneValor0FaltaProgramarElAvanceDeDesbasteAcabadoOPro_33179be60e a ns1:DiagnosticoFallo ;
    rdfs:label "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ns1:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:AlgunParametroSTieneValor0FaltaProgramarLaVelocidadParaElDesbasteOAcabado a ns1:DiagnosticoFallo ;
    rdfs:label "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ns1:textoExtracto "'RANURADO: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:ElParametroLTieneValor0LaRanuraNoTieneLongitud a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro L tiene valor 0. La ranura no tiene longitud."@es ;
    ns1:textoExtracto "'RANURADO: L = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro L tiene valor 0. La ranura no tiene longitud." .

ns1:ElParametroPTieneValor0NoHayProfundidadProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:textoExtracto "'RANURADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:ElParametroTDeLasOperacionesDeDesbasteYAcabadoTieneValor0NoHayHerrami_08afa6e316 a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es ;
    ns1:textoExtracto "'RANURADO: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." .

ns1:EnLaOperacionDeDesbasteOAcabadoElDiametroDeLaHerramientaEsMenorQueElP_d9fac21636 a ns1:DiagnosticoFallo ;
    rdfs:label "En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro )."@es ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro )." .

