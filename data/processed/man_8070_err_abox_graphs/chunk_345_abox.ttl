@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiametroDeHerramientaACABADOMenorQueDelta a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta ACABADO menor que delta" ;
    ns1:solucionaFallo ns1:SolucionElegirHerramientaMayorDiametro ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta ACABADO menor que delta'" .

ns1:DiametroDeHerramientaMayorQueCajera_ef33f5b166 a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta mayor que cajera" ;
    ns1:solucionaFallo ns1:SolucionElegirHerramientaMenorDiametro ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta mayor que cajera'" .

ns1:SolucionReducirPasoFresado a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor" ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:SolucionElegirHerramientaMayorDiametro a ns1:TareaMantenimiento ;
    rdfs:label "Elegir una herramienta de mayor diámetro para la pasada" ;
    ns1:textoExtracto "SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de" .

ns1:SolucionElegirHerramientaMenorDiametro a ns1:TareaMantenimiento ;
    rdfs:label "Elegir una herramienta de menor diámetro" ;
    ns1:textoExtracto "SOLUCIÓN Elegir una herramienta de menor diámetro." .

