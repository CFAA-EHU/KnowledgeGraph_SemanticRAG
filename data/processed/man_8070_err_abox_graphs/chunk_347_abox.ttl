@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2106_HSC
    a ex:DiagnosticoFallo ;
    rdfs:label "Error interno en modo HSC (2106)" ;
    ex:identificador "2106" ;
    ex:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución. CAUSA Error en el cálculo de la trayectoria para trabajar en modo HSC. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ex:Error_2108_HSC
    a ex:DiagnosticoFallo ;
    rdfs:label "'HSC: Cambio de modo no permitido' (2108)" ;
    ex:identificador "2108" ;
    ex:textoExtracto "2108 'HSC: Cambio de modo no permitido' DETECCIÓN Durante la ejecución. CAUSA No se puede cambiar el modo HSC sin desactivar el modo anterior. SOLUCIÓN Desactivar el modo HSC antes de programar otro." .

ex:Error_2109_HSC
    a ex:DiagnosticoFallo ;
    rdfs:label "'HSC: Error de contorno demasiado pequeño' (2109)" ;
    ex:identificador "2109" ;
    ex:textoExtracto "2109 'HSC: Error de contorno demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado. SOLUCIÓN Programar la sentencia con un error de contorno superior a 20 micras." .

ex:Error_2110_HSC
    a ex:DiagnosticoFallo ;
    rdfs:label "'Límite software positivo sobrepasado en modo HSC' (2110)" ;
    ex:identificador "2110" ;
    ex:textoExtracto "2110 'Límite software positivo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ex:Error_2111_HSC
    a ex:DiagnosticoFallo ;
    rdfs:label "'Límite software negativo sobrepasado en modo HSC' (2111)" ;
    ex:identificador "2111" ;
    ex:textoExtracto "2111 'Límite software negativo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ex:Error_2112_SPLINE
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE:Tangente inicial indeterminada (2112)" ;
    ex:identificador "2112" ;
    ex:textoExtracto "2112 SPLINE:Tangente inicial indeterminada. DETECCIÓN Durante la ejecución. CAUSA El punto inicial del spline coincide con el punto anterior y queda la tangente indeterminada o bien se ha programado sólo un eje de la tangente. SOLUCIÓN Programar un punto previo al punto de entrada al spline o ambos ejes de la tangente." .

ex:Error_2113_SPLINE
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE:Tangente final indeterminada (2113)" ;
    ex:identificador "2113" ;
    ex:textoExtracto "2113 SPLINE:Tangente final indeterminada. DETECCIÓN Durante la ejecución." .

ex:ModoHSC
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación HSC" ;
    ex:textoExtracto "modo HSC" .

ex:Error_2106_HSC ex:solucionaFallo ex:ModoHSC .
ex:Error_2108_HSC ex:solucionaFallo ex:ModoHSC .
ex:Error_2109_HSC ex:solucionaFallo ex:ModoHSC .
ex:Error_2110_HSC ex:solucionaFallo ex:ModoHSC .
ex:Error_2111_HSC ex:solucionaFallo ex:ModoHSC .