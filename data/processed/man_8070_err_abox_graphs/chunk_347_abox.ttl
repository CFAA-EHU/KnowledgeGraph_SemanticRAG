@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiametroDeHerramientaAcabadoMenorQueDelta a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta acabado menor que delta" ;
    ns1:solucionaFallo ns1:ElegirUnaHerramientaDeMenorDiametro ;
    ns1:textoExtracto "'CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta'" .

ns1:DiametroDeHerramientaMayorQueCajera_91800e9152 a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta mayor que cajera" ;
    ns1:solucionaFallo ns1:ReducirElPasoDeFresadoOUtilizarUnaHerramientaDeDiametroMayor ;
    ns1:textoExtracto "'CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera'" .

ns1:ElegirUnaHerramientaDeMenorDiametro a ns1:TareaMantenimiento ;
    rdfs:label "Elegir una herramienta de menor diámetro" ;
    ns1:textoExtracto "SOLUCIÓN Elegir una herramienta de menor diámetro." .

ns1:ReducirElPasoDeFresadoOUtilizarUnaHerramientaDeDiametroMayor a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor" ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

