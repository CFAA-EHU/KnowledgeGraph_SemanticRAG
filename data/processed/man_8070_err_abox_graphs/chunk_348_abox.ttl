@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2113_Spline_TangenteFinalIndeterminada
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2113: SPLINE - Tangente final indeterminada" ;
    ex:identificador "2113" ;
    ex:textoExtracto "2113 SPLINE:Tangente final indeterminada. DETECCIÓN Durante la ejecución. CAUSA El punto final del spline coincide con el punto anterior y queda la tangente indeterminada o bien se ha programado sólo un eje de la tangente. SOLUCIÓN Programar un punto de salida posterior al punto final del spline o ambos ejes de la tangente." .

ex:Fallo_2114_Spline_ActivacionNoCompleta
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2114: SPLINE - Activación no completada" ;
    ex:identificador "2114" ;
    ex:textoExtracto "2114 SPLINE:Activación no" .