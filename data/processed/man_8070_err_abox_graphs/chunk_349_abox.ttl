@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_c96f27c03d a ns1:Componente ;
    rdfs:label "herramienta de acabado",
        "herramienta de desbaste" ;
    ns1:textoExtracto "La herramienta de desbaste o acabado tiene radio 0." .

ns1:CorregirElValorDelRadioEnLaTablaDeHerramientasOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:DiametroDeHerramienta0 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:TablaHerramientas a ns1:Esquema ;
    rdfs:label "tabla de herramientas" ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas" .

ns1:DiametroDeHerramienta0 a ns1:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta = 0" ;
    ns1:textoExtracto "'PLANEADO: Diámetro de herramienta = 0'" .

