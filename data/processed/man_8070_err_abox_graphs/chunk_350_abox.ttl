@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BetaOTheta0OBetaOTheta90 a ns1:AccionProhibida ;
    rdfs:label "Beta o theta < 0 ó Beta o theta > 90" ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera." .

ns1:BetaOTheta0OBetaOTheta90_a18ddb5e42 a ns1:AccionProhibida ;
    rdfs:label "Beta o theta < 0 ó Beta o theta > 90" ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera." .

ns1:BetaOTheta0OBetaOTheta90_e2967f7528 a ns1:AccionProhibida ;
    rdfs:label "Beta o theta < 0 ó Beta o theta > 90" ;
    ns1:textoExtracto "'CAJERA CIRCULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera." .

ns1:CorregirElAnguloDeProfundizacionLateralProgramarUnValorEntre0oY90o a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º" ;
    ns1:solucionaFallo ns1:ElAnguloDeProfundizacionLateralParaElDesbasteParametroOParaElAcabadoP_05b257c1a0 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º." .

ns1:CorregirElValorDelRadioEnLaTablaDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor del radio en la tabla de herramientas" ;
    ns1:solucionaFallo ns1:LaHerramientaDeDesbasteOAcabadoTieneRadio0 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:DiametroDeHerramienta0_dfaa70da84 a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta = 0" ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo." .

ns1:Profundidad0 a ns1:AccionProhibida ;
    rdfs:label "La profundidad resultante de la cajera es cero",
        "Profundidad = 0" ;
    ns1:textoExtracto "CAUSA La profundidad resultante de la cajera es cero." .

ns1:ElAnguloDeProfundizacionLateralParaElDesbasteParametroOParaElAcabadoP_05b257c1a0 a ns1:DiagnosticoFallo ;
    rdfs:label "El ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º" ;
    ns1:textoExtracto "CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º." .

ns1:LaHerramientaDeDesbasteOAcabadoTieneRadio0 a ns1:DiagnosticoFallo ;
    rdfs:label "La herramienta de desbaste o acabado tiene radio 0" ;
    ns1:textoExtracto "CAUSA La herramienta de desbaste o acabado tiene radio 0." .

