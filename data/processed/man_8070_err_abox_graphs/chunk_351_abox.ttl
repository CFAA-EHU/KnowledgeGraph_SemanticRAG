@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaProgramacionDeLosParametrosIZD a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación de los parámetros I Z D" ;
    ns1:solucionaFallo ns1:LaProfundidadResultanteDeLaCajeraEsCero ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación de los parámetros I Z D." .

ns1:ParametroD a ns1:Parametro ;
    rdfs:label "parámetro D" ;
    ns1:textoExtracto "la profundidad programada (parámetro I) coincide con el parámetro D." .

ns1:ParametroZ a ns1:Parametro ;
    rdfs:label "parámetro Z" ;
    ns1:textoExtracto "la suma de los parámetros Z y D" .

ns1:ProfundidadProgramada_06290256ec a ns1:Parametro ;
    rdfs:label "profundidad programada" ;
    ns1:textoExtracto "La profundidad programada (parámetro I)" .

ns1:SeleccionarUnaHerramientaDeDiametroMenor a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar una herramienta de diámetro menor" ;
    ns1:solucionaFallo ns1:G87DiametroDeHerramientaMayorQueCajera ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar una herramienta de diámetro menor." .

ns1:G87DiametroDeHerramientaMayorQueCajera a ns1:DiagnosticoFallo ;
    rdfs:label "'G87: Diámetro de herramienta mayor que cajera'" ;
    ns1:textoExtracto "1805 'G87: Diámetro de herramienta mayor que cajera' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetros)" .

ns1:LaProfundidadResultanteDeLaCajeraEsCero a ns1:DiagnosticoFallo ;
    rdfs:label "La profundidad resultante de la cajera es cero" ;
    ns1:textoExtracto "CAUSA La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D." .

