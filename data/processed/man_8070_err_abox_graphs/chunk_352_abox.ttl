@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_4d1900cc87 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso durante ejecución del ciclo" ;
    ns1:mitigaRiesgo ns1:DiametroDeHerramienta0_1761eda2fc,
        ns1:DiametroDeHerramientaMayorQueCajera_149c79b87a,
        ns1:DiametroDeHerramientaMenorQueC,
        ns1:DiametroDeHerramientaMenorQueL,
        ns1:NoHayHerramientaEnElCabezal,
        ns1:Profundidad0_13811ccf38 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo." .

ns1:CorreccionDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de herramientas" ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:NoHayHerramienta a ns1:Parametro ;
    rdfs:label "Diámetro de herramienta = 0",
        "Diámetro de herramienta menor que C",
        "Diámetro de herramienta menor que L",
        "No hay herramienta" ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "'G87: Diámetro de herramienta = 0'",
        "'G87: Diámetro de herramienta menor que C'",
        "'G87: Diámetro de herramienta menor que L'",
        "'G87: No hay herramienta'" .

ns1:Profundidad0_9aebc450c3 a ns1:Parametro ;
    rdfs:label "Diámetro de herramienta mayor que cajera",
        "Profundidad = 0" ;
    ns1:identificador "G88" ;
    ns1:textoExtracto "'G88: Diámetro de herramienta mayor que cajera'",
        "'G88: Profundidad = 0'" .

ns1:DiametroDeHerramienta0_1761eda2fc a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta = 0" ;
    ns1:textoExtracto "La herramienta tiene diámetro 0." .

ns1:DiametroDeHerramientaMayorQueCajera_149c79b87a a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta mayor que cajera" ;
    ns1:textoExtracto "El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J)." .

ns1:DiametroDeHerramientaMenorQueC a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta menor que C" ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro C)." .

ns1:DiametroDeHerramientaMenorQueL a ns1:AccionProhibida ;
    rdfs:label "Diámetro de herramienta menor que L" ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que la demasía de acabado (parámetro L)." .

ns1:NoHayHerramientaEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "No hay herramienta en el cabezal" ;
    ns1:textoExtracto "No hay herramienta en el cabezal." .

ns1:Profundidad0_13811ccf38 a ns1:AccionProhibida ;
    rdfs:label "Profundidad = 0" ;
    ns1:textoExtracto "La profundidad resultante de la cajera es cero." .

