@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiametroDeAcabado a ns1:Parametro ;
    rdfs:label "Diámetro de acabado" ;
    ns1:textoExtracto "(parámetro L)" .

ns1:ElDiametroDeHerramientaEsIgualA0 a ns1:DiagnosticoFallo ;
    rdfs:label "El diámetro de herramienta es igual a 0" ;
    ns1:textoExtracto "1813 'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo." .

ns1:ElDiametroDeLaHerramientaEsMenorQueLaDemasiaDeAcabado a ns1:DiagnosticoFallo ;
    rdfs:label "El diámetro de la herramienta es menor que la demasía de acabado" ;
    ns1:textoExtracto "CAUSA El diámetro de la herramienta es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor." .

ns1:ElRadioDeLaHerramientaEsMayorQueLasDimensionesDeLaCajera a ns1:DiagnosticoFallo ;
    rdfs:label "El radio de la herramienta es mayor que las dimensiones de la cajera" ;
    ns1:textoExtracto "CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J). SOLUCIÓN Seleccionar una herramienta de diámetro menor." .

ns1:RadioDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Radio de la herramienta" ;
    ns1:textoExtracto "(parámetro J)" .

