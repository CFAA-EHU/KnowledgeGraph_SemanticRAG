@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros" ;
    ns1:solucionaFallo ns1:ElParametroXHaDeSerMultiploDelParametroI ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:AsignarUnValorCorrectoAlParametro a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro" ;
    ns1:solucionaFallo ns1:J0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:CorregirElValorDelRadioEnLaTablaDeHerramientasOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:G88DiametroDeHerramienta0_4cc2de7280 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:LongitudDelMecanizado a ns1:Parametro ;
    rdfs:label "Longitud del mecanizado" ;
    ns1:textoExtracto "'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I)." .

ns1:NumeroDeMecanizados_ff881d3a6e a ns1:Parametro ;
    rdfs:label "Número de mecanizados" ;
    ns1:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar el paso entre mecanizados (parámetro I) o el número de mecanizados (parámetro K)." .

ns1:PasoEntreMecanizados a ns1:Parametro ;
    rdfs:label "Paso entre mecanizados" ;
    ns1:textoExtracto "'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I)." .

ns1:PasoEntreMecanizadosEnElEjeDeOrdenadas_aa01f62549 a ns1:Parametro ;
    rdfs:label "Paso entre mecanizados en el eje de ordenadas" ;
    ns1:textoExtracto "'J = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0." .

ns1:ProgramarUnaHerramientaAntesDelCicloOCargarUnaHerramientaEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal" ;
    ns1:solucionaFallo ns1:G88NoHayHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal." .

ns1:ReducirElPasoDeFresadoOUtilizarUnaHerramientaDeDiametroMayor a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor" ;
    ns1:solucionaFallo ns1:G88DiametroDeHerramientaMenorQueC ;
    ns1:textoExtracto "SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:UnoDeLosParametrosIKHaDeSerProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Uno de los parámetros I, K ha de ser programado" ;
    ns1:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar el paso entre mecanizados (parámetro I) o el número de mecanizados (parámetro K)." .

ns1:ElParametroXHaDeSerMultiploDelParametroI a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro X ha de ser múltiplo del parámetro I" ;
    ns1:textoExtracto "'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I)." .

ns1:G88DiametroDeHerramienta0_4cc2de7280 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta = 0" ;
    ns1:textoExtracto "'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0." .

ns1:G88DiametroDeHerramientaMenorQueC a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta menor que C" ;
    ns1:textoExtracto "'G88: Diámetro de herramienta menor que C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C)." .

ns1:G88NoHayHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "G88: No hay herramienta" ;
    ns1:textoExtracto "'G88: No hay herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal." .

ns1:J0 a ns1:DiagnosticoFallo ;
    rdfs:label "J = 0" ;
    ns1:textoExtracto "'J = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0." .

