@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoAlParametroJ a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro J" ;
    ns1:solucionaFallo ns1:K0 ;
    ns1:textoExtracto "'SOLUCIÓN Asignar un valor correcto al parámetro.'" .

ns1:CicloMecanizadoMultiple a ns1:Sistema ;
    rdfs:label "ciclo de mecanizado múltiple" ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple.'" .

ns1:NumeroDeMecanizados a ns1:Parametro ;
    rdfs:label "número de mecanizados" ;
    ns1:textoExtracto "'En un mecanizado múltiple, el parámetro K (número de mecanizados) tiene valor 0.'" .

ns1:PasoEntreMecanizadosEnElEjeDeOrdenadas a ns1:Parametro ;
    rdfs:label "paso entre mecanizados en el eje de ordenadas" ;
    ns1:textoExtracto "'En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0.'" .

ns1:ProgramarDosDeLosSiguientesParametrosXIK a ns1:TareaMantenimiento ;
    rdfs:label "Programar dos de los siguientes parámetros X, I, K" ;
    ns1:solucionaFallo ns1:DosDeLosParametrosXIKHanDeSerProgramados ;
    ns1:textoExtracto "'SOLUCIÓN Asignar un valor correcto al parámetro. 1820 'Dos de los parámetros X, I, K han de ser programados'" .

ns1:DosDeLosParametrosXIKHanDeSerProgramados a ns1:DiagnosticoFallo ;
    rdfs:label "Dos de los parámetros X, I, K han de ser programados" ;
    ns1:textoExtracto "'1820 'Dos de los parámetros X, I, K han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple.'" .

ns1:K0 a ns1:DiagnosticoFallo ;
    rdfs:label "K = 0" ;
    ns1:textoExtracto "'1819 'K = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple.'" .

