@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignacionDeValoresCorrectosALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de valores correctos a los parámetros" ;
    ns1:solucionaFallo ns1:BDebeSerMultiploDeI,
        ns1:DosDeLosParametrosXIKHanDeSerProgramados_73c96c4bbf,
        ns1:DosDeLosParametrosYJDHanDeSerProgramados,
        ns1:ElParametroYHaDeSerMultiploDelParametroJ,
        ns1:UnoDeLosParametrosIKHaDeSerProgramado ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:LongitudAngularDelMecanizado a ns1:Parametro ;
    rdfs:label "Longitud angular del mecanizado" ;
    ns1:textoExtracto "'B debe ser múltiplo de I' CAUSA La longitud angular del mecanizado (parámetro B) ha de ser múltiplo del paso angular entre mecanizados (parámetro I)." .

ns1:LongitudDelMecanizado_4aa5722ccc a ns1:Parametro ;
    rdfs:label "Longitud del mecanizado" ;
    ns1:textoExtracto "'El parámetro Y ha de ser múltiplo del parámetro J' CAUSA La longitud del mecanizado (parámetro Y) ha de ser múltiplo del paso entre mecanizados (parámetro J)." .

ns1:LongitudDelMecanizado_6ba9de5ab7 a ns1:Parametro ;
    rdfs:label "Longitud del mecanizado" ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados)." .

ns1:NumeroDeMecanizados_2386a3da75 a ns1:Parametro ;
    rdfs:label "Número de mecanizados" ;
    ns1:textoExtracto "'Dos de los parámetros Y, J, D han de ser programados' CAUSA Falta programar dos de los siguientes parámetros; Y (longitud del mecanizado), J (paso entre mecanizados), D (número de mecanizados)." .

ns1:NumeroDeMecanizados_b0691d414b a ns1:Parametro ;
    rdfs:label "Número de mecanizados" ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados)." .

ns1:ParametroA a ns1:Parametro ;
    rdfs:label "Parámetro A" ;
    ns1:textoExtracto "'Uno de los parámetros I, A ha de ser programado' CAUSA Falta programar uno de los siguientes parámetros; I (paso entre mecanizados), K (número de mecanizados)." .

ns1:PasoEntreMecanizados_84f6885cb6 a ns1:Parametro ;
    rdfs:label "Paso entre mecanizados" ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados)." .

ns1:PasoEntreMecanizados_ae1d92c7dc a ns1:Parametro ;
    rdfs:label "Paso entre mecanizados" ;
    ns1:textoExtracto "'El parámetro Y ha de ser múltiplo del parámetro J' CAUSA La longitud del mecanizado (parámetro Y) ha de ser múltiplo del paso entre mecanizados (parámetro J)." .

ns1:UnoDeLosParametrosIAHaDeSerProgramado_0e53f689d7 a ns1:DiagnosticoFallo ;
    rdfs:label "Uno de los parámetros I, A ha de ser programado" ;
    ns1:textoExtracto "'Uno de los parámetros I, A ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple." .

ns1:BDebeSerMultiploDeI a ns1:DiagnosticoFallo ;
    rdfs:label "B debe ser múltiplo de I" ;
    ns1:textoExtracto "'B debe ser múltiplo de I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud angular del mecanizado (parámetro B) ha de ser múltiplo del paso angular entre mecanizados (parámetro I). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:DosDeLosParametrosXIKHanDeSerProgramados_73c96c4bbf a ns1:DiagnosticoFallo ;
    rdfs:label "Dos de los parámetros X, I, K han de ser programados" ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:DosDeLosParametrosYJDHanDeSerProgramados a ns1:DiagnosticoFallo ;
    rdfs:label "Dos de los parámetros Y, J, D han de ser programados" ;
    ns1:textoExtracto "'Dos de los parámetros Y, J, D han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; Y (longitud del mecanizado), J (paso entre mecanizados), D (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:ElParametroYHaDeSerMultiploDelParametroJ a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro Y ha de ser múltiplo del parámetro J" ;
    ns1:textoExtracto "'El parámetro Y ha de ser múltiplo del parámetro J' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro Y) ha de ser múltiplo del paso entre mecanizados (parámetro J). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:UnoDeLosParametrosIKHaDeSerProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Uno de los parámetros I, K ha de ser programado" ;
    ns1:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar uno de los siguientes parámetros; I (paso entre mecanizados), K (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros." .

