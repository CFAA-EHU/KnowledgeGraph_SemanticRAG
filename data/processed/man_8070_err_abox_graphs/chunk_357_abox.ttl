@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametrosIYA a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros I y A" ;
    ns1:solucionaFallo ns1:UnoDeLosParametrosIAHaDeSerProgramado ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros. 1825 'Uno de los parámetros I, A ha de ser programado'" .

ns1:AsignarUnValorCorrectoAlParametroIYK a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro I y K" ;
    ns1:solucionaFallo ns1:ElParametroIMultiplicadoPorKHaDeSerIgualA360 ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto al parámetro. 1826 'El parámetro I multiplicado por K ha de ser igual a 360'" .

ns1:NumeroDeMecanizados_e9d9b112d8 a ns1:Parametro ;
    rdfs:label "Número de mecanizados" ;
    ns1:textoExtracto "número de mecanizados" .

ns1:PasoAngularEntreMecanizados a ns1:Parametro ;
    rdfs:label "Paso angular entre mecanizados" ;
    ns1:textoExtracto "El paso angular entre mecanizados (parámetro I)" .

ns1:ElParametroIMultiplicadoPorKHaDeSerIgualA360 a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro I multiplicado por K ha de ser igual a 360" ;
    ns1:textoExtracto "'El parámetro I multiplicado por K ha de ser igual a 360'" .

ns1:UnoDeLosParametrosIAHaDeSerProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Uno de los parámetros I, A ha de ser programado" ;
    ns1:textoExtracto "'Uno de los parámetros I, A ha de ser programado'" .

