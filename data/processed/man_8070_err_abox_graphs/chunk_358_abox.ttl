@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroUnValorDistintoDeCero a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor distinto de cero" ;
    ns1:solucionaFallo ns1:G82C0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor distinto de cero." .

ns1:AsignarAlParametroUnValorDistintoDeCeroYMenorQueLaLongitudDeCorteDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta" ;
    ns1:solucionaFallo ns1:DESBASTEI0_8d9ef64ace ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta." .

ns1:AsignarUnValorCorrectoAlParametro a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro" ;
    ns1:solucionaFallo ns1:Entity360HaDeSerMultiploDelParametroI,
        ns1:I0 ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:CentroDelArcoDeMecanizadoEnX a ns1:Parametro ;
    rdfs:label "centro del arco de mecanizado en X" ;
    ns1:textoExtracto "Los parámetros X Y (centro del arco de mecanizado) tienen valor 0." .

ns1:CentroDelArcoDeMecanizadoEnY a ns1:Parametro ;
    rdfs:label "centro del arco de mecanizado en Y" ;
    ns1:textoExtracto "Los parámetros X Y (centro del arco de mecanizado) tienen valor 0." .

ns1:CorregirElValorDelRadioEnLaTablaDeHerramientasOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:DiametroDeHerramienta0_289e8e1e83 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:CotaDeAproximacion_f5c0842b88 a ns1:Parametro ;
    rdfs:label "cota de aproximación" ;
    ns1:textoExtracto "El parámetro C (cota de aproximación) tiene valor 0." .

ns1:NumeroDeMecanizados_d27e1c85c1 a ns1:Parametro ;
    rdfs:label "número de mecanizados" ;
    ns1:textoExtracto "El paso angular entre mecanizados (parámetro I) por el número de mecanizados (parámetro K) debe ser 360º." .

ns1:PasoAngularEntreMecanizados_b9872ea219 a ns1:Parametro ;
    rdfs:label "paso angular entre mecanizados" ;
    ns1:textoExtracto "El paso angular entre mecanizados (parámetro I) por el número de mecanizados (parámetro K) debe ser 360º." .

ns1:DESBASTEI0_8d9ef64ace a ns1:DiagnosticoFallo ;
    rdfs:label "DESBASTE: I = 0" ;
    ns1:textoExtracto "'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0." .

ns1:DiametroDeHerramienta0_289e8e1e83 a ns1:DiagnosticoFallo ;
    rdfs:label "Diámetro de herramienta = 0" ;
    ns1:textoExtracto "'Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta tiene diámetro 0." .

ns1:Entity360HaDeSerMultiploDelParametroI a ns1:DiagnosticoFallo ;
    rdfs:label "360 ha de ser múltiplo del parámetro I" ;
    ns1:textoExtracto "'360 ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA El paso angular (parámetro I) ha de ser submúltiplo de 360º." .

ns1:G82C0 a ns1:DiagnosticoFallo ;
    rdfs:label "G82: C = 0" ;
    ns1:textoExtracto "'G82: C = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro C (cota de aproximación) tiene valor 0." .

ns1:I0 a ns1:DiagnosticoFallo ;
    rdfs:label "I = 0" ;
    ns1:textoExtracto "'I = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro I (paso entre mecanizados) tiene valor 0." .

