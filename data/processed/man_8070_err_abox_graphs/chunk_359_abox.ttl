@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlParametroIUnValorDistintoDeCeroYMenorQueLaLongitudDeCorteDeL_d0c0a00e3d a ns1:AccionProhibida ;
    rdfs:label "Asignar al parámetro I un valor distinto de cero y menor que la longitud de corte de la herramienta" ;
    ns1:solucionaFallo ns1:DESBASTEI0_8d9ef64ace ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta." .

ns1:NumeroDePasadasDeProfundizacion a ns1:Parametro ;
    rdfs:label "número de pasadas de profundización" ;
    ns1:identificador "N" ;
    ns1:textoExtracto "'ACABADO: N = 0 y longitud de corte de herramienta no definida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro N (número de pasadas de profundización) tiene valor 0." .

ns1:PasoMaximoDeProfundizacion a ns1:Parametro ;
    rdfs:label "paso máximo de profundización" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0." .

ns1:ProgramarElNumeroDePasadasDeProfundizacionParametroNODefinirLaLongitu_f2fc3bfdf9 a ns1:AccionProhibida ;
    rdfs:label "Programar el número de pasadas de profundización (parámetro N) o definir la longitud de corte en la tabla de herramientas" ;
    ns1:solucionaFallo ns1:ACABADON0YLongitudDeCorteDeHerramientaNoDefinida ;
    ns1:textoExtracto "SOLUCIÓN Programar el número de pasadas de profundización (parámetro N) o definir la longitud de corte en la tabla de herramientas." .

ns1:ACABADON0YLongitudDeCorteDeHerramientaNoDefinida a ns1:DiagnosticoFallo ;
    rdfs:label "'ACABADO: N = 0 y longitud de corte de herramienta no definida'" ;
    ns1:textoExtracto "'ACABADO: N = 0 y longitud de corte de herramienta no definida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro N (número de pasadas de profundización) tiene valor 0." .

ns1:DESBASTEI0_8d9ef64ace a ns1:DiagnosticoFallo ;
    rdfs:label "'DESBASTE: I = 0'" ;
    ns1:textoExtracto "'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0." .

