ns1:AsignarUnValorCorrectoAlParametro_5b263b2972 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro" ;
    ns1:solucionaFallo ns1:CajeraConIslasZDeSeguridadNoValida ;
    ns1:textoExtracto "'Cajera con islas: Z de seguridad no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El plano de seguridad (parámetro Zs) se encuentra dentro SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:ComprobarQueLaInterseccionDePerfilesEnXYSeaValida a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que la intersección de perfiles en XY sea válida" ;
    ns1:solucionaFallo ns1:CajeraConIslasInterseccionDePerfilesEnXYNoValida_80ee12955d ;
    ns1:textoExtracto "'Cajera con islas: Intersección de perfiles en XY no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común." .

ns1:ComprobarQueLosPerfilesDeProfundidadSonCorrectos a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de profundidad son correctos" ;
    ns1:solucionaFallo ns1:CajeraConIslasPerfilEnZNoValido ;
    ns1:textoExtracto "'Cajera con islas: Perfil en Z no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada." .

ns1:ComprobarQueLosPerfilesDeSuperficieNoSeCortanASiMismos a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de superficie no se cortan a sí mismos" ;
    ns1:solucionaFallo ns1:CajeraConIslasPerfilEnXYSeCortaASiMismo ;
    ns1:textoExtracto "'Cajera con islas: Perfil en XY se corta a si mismo' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie forma más de un perfil cerrado." .

ns1:ComprobarQueTodosLosPerfilesDeSuperficieSeanCerrados_4f9e72a620 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que todos los perfiles de superficie sean cerrados" ;
    ns1:solucionaFallo ns1:CajeraConIslasPerfilEnXYNoEsCerrado ;
    ns1:textoExtracto "'Cajera con islas: Perfil en XY no es cerrado' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo." .

ns1:DefinirLaLongitudDeCorteEnLaTablaDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Definir la longitud de corte en la tabla de herramientas" ;
