@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_2303 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2303: Cinemática incompatible con #CSROT"@es ;
    ex:identificador "2303" ;
    ex:textoExtracto "'La función CSROT solo es aplicable a cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa' DETECCIÓN Durante la ejecución. CAUSA El tipo de cinemática no es compatible con la función #CSROT. SOLUCIÓN Desactivar la función #CSROT."@es .

ex:Fallo_2304 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2304: Sintaxis incorrecta en #PWMOUT"@es ;
    ex:identificador "2304" ;
    ex:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF. DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el"@es .

ex:Funcion_CSROT a ex:Parametro ;
    rdfs:label "#CSROT" ;
    ex:identificador "CSROT" ;
    ex:textoExtracto "La función CSROT solo es aplicable a cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa"@es .

ex:Funcion_PWMOUT a ex:Parametro ;
    rdfs:label "#PWMOUT" ;
    ex:identificador "PWMOUT" ;
    ex:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF"@es .

ex:Fallo_2303 ex:solucionaFallo ex:Funcion_CSROT .
ex:Fallo_2304 ex:solucionaFallo ex:Funcion_PWMOUT .