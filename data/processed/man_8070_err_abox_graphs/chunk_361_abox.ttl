@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarQueLosPerfilesDeSuperficieNoTienenTramosEnComun a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de superficie no tienen tramos en común" ;
    ns1:solucionaFallo ns1:CajeraConIslasMemoriaInsuficienteParaSuResolucion_2c696870e6 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos." .

ns1:ComprobarQueTodosLosPerfilesDeSuperficieSeanCerrados a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que todos los perfiles de superficie sean cerrados" ;
    ns1:solucionaFallo ns1:CajeraConIslasInterseccionDePerfilesEnXYNoValida_22679559fc ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ns1:CajeraConIslasInterseccionDePerfilesEnXYNoValida_22679559fc a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Intersección de perfiles en XY no válida" ;
    ns1:textoExtracto "'Cajera con islas: Intersección de perfiles en XY no válida'" .

ns1:CajeraConIslasMemoriaInsuficienteParaSuResolucion_2c696870e6 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Memoria insuficiente para su resolución" ;
    ns1:textoExtracto "'Cajera con islas: Memoria insuficiente para su resolución'" .

