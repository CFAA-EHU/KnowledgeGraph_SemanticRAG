@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2310_VIRTAX a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2310: Conflicto con transformación del eje virtual de la herramienta (#VIRTAX)"@es ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una de las siguientes funciones mientras la transformación del eje virtual de la herramienta está activa. • Búsqueda de cero; G74. • Modificar los límites de software; G198 - G199. • Sentencia #OSC. SOLUCIÓN Desactivar primero la transformación del eje virtual de la herramienta (#VIRTAX), a continuación ejecutar las funciones #OSC, G74 o G198-G199, y por último volver a activar la transformación #VIRTAX. 2310 #VIRTAX: El eje virtual de la herramienta"@es ;
    ex:identificador "2310" .

ex:Funcion_G74 a ex:Parametro ;
    rdfs:label "Función G74 (Búsqueda de cero)"@es ;
    ex:textoExtracto "Búsqueda de cero; G74"@es ;
    ex:identificador "G74" .

ex:Funcion_G198 a ex:Parametro ;
    rdfs:label "Función G198 (Modificar límites de software)"@es ;
    ex:textoExtracto "Modificar los límites de software; G198"@es ;
    ex:identificador "G198" .

ex:Funcion_G199 a ex:Parametro ;
    rdfs:label "Función G199 (Modificar límites de software)"@es ;
    ex:textoExtracto "Modificar los límites de software; G199"@es ;
    ex:identificador "G199" .

ex:Funcion_OSC a ex:Parametro ;
    rdfs:label "Sentencia #OSC"@es ;
    ex:textoExtracto "Sentencia #OSC"@es ;
    ex:identificador "#OSC" .

ex:Parametro_VIRTAX a ex:Parametro ;
    rdfs:label "Transformación del eje virtual de la herramienta (#VIRTAX)"@es ;
    ex:textoExtracto "transformación del eje virtual de la herramienta (#VIRTAX)"@es ;
    ex:identificador "#VIRTAX" .

ex:Fallo_2310_VIRTAX ex:solucionaFallo ex:Parametro_VIRTAX .