ns1:CajeraConIslasMemoriaInsuficienteParaSuResolucion_9d76645ef0 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Memoria insuficiente para su resolución" ;
    ns1:textoExtracto "'Cajera con islas: Memoria insuficiente para su resolución' DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no dispone de memoria para seguir resolviendo la cajera." .

ns1:CajeraConIslasRadioDeHerramientaDeAcabadoNoValido_bc3ab8de92 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Radio de herramienta de acabado no válido" ;
