@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoAlParametro_e4c84d924e a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto al parámetro" ;
    ns1:solucionaFallo ns1:LongitudDeLaCuerdaIMayorQueDiametro ;
    ns1:textoExtracto "Asignar un valor correcto al parámetro." .

ns1:CorregirValorDelRadioEnTablaDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Corregir valor del radio en tabla de herramientas" ;
    ns1:solucionaFallo ns1:RadioDelArcoNulo ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:LaLongitudDeLaCuerdaParametroIEsMayorQueElDiametroDelCirculo a ns1:DiagnosticoFallo ;
    rdfs:label "La longitud de la cuerda (parámetro I) es mayor que el diámetro del círculo" ;
    ns1:textoExtracto "La longitud de la cuerda (parámetro I) es mayor que el diámetro del círculo." .

ns1:ParametroI a ns1:Parametro ;
    rdfs:label "Parámetro I" ;
    ns1:textoExtracto "La longitud de la cuerda (parámetro I) es mayor que el diámetro del círculo." .

ns1:LongitudDeLaCuerdaIMayorQueDiametro a ns1:AccionProhibida ;
    rdfs:label "Longitud de la cuerda (I) mayor que diámetro" ;
    ns1:textoExtracto "'G165: Longitud de la cuerda (I) mayor que diámetro'" .

ns1:RadioDelArcoNulo a ns1:AccionProhibida ;
    rdfs:label "Radio del arco nulo" ;
    ns1:textoExtracto "'Radio del arco nulo'" .

