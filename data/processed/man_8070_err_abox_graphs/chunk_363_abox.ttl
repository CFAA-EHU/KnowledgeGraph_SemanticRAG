@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2310 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2310: Eje virtual de herramienta no configurado" ;
    ex:identificador "2310" ;
    ex:textoExtracto "El CNC ha intentado activar un eje virtual de la herramienta (#VIRTAX) y no hay definido ninguno (parámetro VIRTAXISNAME), el eje es rotativo o el eje no pertenece al canal. SOLUCIÓN: Revisar la configuración. El eje virtual de la herramienta debe estar definido (parámetro VIRTAXISNAME), ser un eje lineal y pertenecer al canal." ;
    ex:solucionaFallo ex:Parametro_VIRTAXISNAME .

ex:Fallo_2311 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2311: Eje virtual de herramienta en cinemática principal" ;
    ex:identificador "2311" ;
    ex:textoExtracto "El CNC ha intentado activar la transformación del eje virtual de la herramienta (#VIRTAX) con un eje que forma parte del triedro principal ó de una cinemática. SOLUCIÓN: Revisar la programación." .

ex:Fallo_2312 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2312: Cinemática no definida" ;
    ex:identificador "2312" ;
    ex:textoExtracto "'#KIN ID[]: Programar valores comprendidos entre 0 y el parámetro máquina NKIN'. El CNC ha intentado activar una cinemática que no está definida en la tabla de cinemáticas de los parámetros máquina. SOLUCIÓN: Revisar programación." ;
    ex:solucionaFallo ex:Parametro_NKIN .

ex:Fallo_2313 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2313: Funciones G fuera de perfil ProGTL3" ;
    ex:identificador "2313" ;
    ex:textoExtracto "Las funciones G810, G811, G813, G820, G821, G840, G841, G842, G850 y G841 sólo se permiten dentro de la definición de un perfil ProGTL3. SOLUCIÓN: Programar la función G tras el inicio de un perfil con G841 o G842." .

ex:Fallo_2314 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2314: Función no permitida dentro de perfil ProGTL3" ;
    ex:identificador "2314" ;
    ex:textoExtracto "La función programada no está permitida dentro de la definición de un perfil ProGTL3." .

ex:Parametro_VIRTAXISNAME a ex:Parametro ;
    rdfs:label "Parámetro VIRTAXISNAME" ;
    ex:identificador "VIRTAXISNAME" ;
    ex:textoExtracto "parámetro VIRTAXISNAME" ;
    ex:valor "eje_lineal_perteneciente_al_canal" .

ex:Parametro_NKIN a ex:Parametro ;
    rdfs:label "Parámetro máquina NKIN" ;
    ex:identificador "NKIN" ;
    ex:textoExtracto "parámetro máquina NKIN" ;
    ex:valor "valor_máximo_cinemáticas" .

ex:Funcion_VIRTAX a ex:ModoOperacion ;
    rdfs:label "Transformación #VIRTAX" ;
    ex:identificador "VIRTAX" ;
    ex:textoExtracto "activar la transformación #VIRTAX. El eje virtual de la herramienta deben ser lineal y pertenecer al canal." .

ex:Funcion_OSC a ex:ModoOperacion ;
    rdfs:label "Función #OSC" ;
    ex:identificador "OSC" ;
    ex:textoExtracto "ejecutar las funciones #OSC" .

ex:Funcion_G74 a ex:ModoOperacion ;
    rdfs:label "Función G74" ;
    ex:identificador "G74" ;
    ex:textoExtracto "ejecutar las funciones G74" .

ex:Funcion_G198 a ex:ModoOperacion ;
    rdfs:label "Función G198" ;
    ex:identificador "G198" ;
    ex:textoExtracto "ejecutar las funciones G198-G199" .

ex:Funcion_G199 a ex:ModoOperacion ;
    rdfs:label "Función G199" ;
    ex:identificador "G199" ;
    ex:textoExtracto "ejecutar las funciones G198-G199" .

ex:Perfil_ProGTL3 a ex:ModoOperacion ;
    rdfs:label "Perfil ProGTL3" ;
    ex:identificador "ProGTL3" ;
    ex:textoExtracto "definición de un perfil ProGTL3" .

ex:Funcion_G810 a ex:ModoOperacion ;
    rdfs:label "Función G810" ;
    ex:identificador "G810" ;
    ex:textoExtracto "Las funciones G810 [...] sólo se permiten dentro de la definición de un perfil ProGTL3" ;
    ex:requiereMantenimiento ex:Perfil_ProGTL3 .

ex:Funcion_G841 a ex:ModoOperacion ;
    rdfs:label "Función G841" ;
    ex:identificador "G841" ;
    ex:textoExtracto "Programar la función G tras el inicio de un perfil con G841 o G842" ;
    ex:requiereMantenimiento ex:Perfil_ProGTL3 .