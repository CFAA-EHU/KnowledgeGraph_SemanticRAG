    rdfs:label "distancia entre mecanizados" ;
    ns1:textoExtracto "La longitud del mecanizado (parámetro Lx) ha de ser múltiplo de la distancia entre mecanizados (parámetro Ix)." .

ns1:LongitudDelMecanizadoEnY a ns1:Parametro ;
    rdfs:label "longitud del mecanizado en y" ;
    ns1:textoExtracto "'Ly ha de ser múltiplo de Iy' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple." .

