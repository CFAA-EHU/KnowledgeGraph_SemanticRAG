ns1:CAJERARECTANGULARDemasiaDeAcabadoDELTAMayorQueCajera a ns1:DiagnosticoFallo ;
    rdfs:label "'CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera'" ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera' DETECCIÓN Durante la ejecución del ciclo." .

ns1:DemasiasDeAcabadoLaterales a ns1:Parametro ;
    rdfs:label "demasías de acabado laterales" ;
    ns1:textoExtracto "El tamaño de la cajera menos el diámetro de la herramienta es menor que las demasías de acabado laterales (dos veces el parámetro )." .

