@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2314
    a ex:AvisoSeguridad ;
    rdfs:label "Programación no permitida dentro de un perfil PROGTL3"@es ;
    ex:textoExtracto "2314 Programación no permitida dentro de un perfil PROGTL3. DETECCIÓN Durante la ejecución. CAUSA La función programada no está permitida dentro de la definición de un perfil ProGTL3."@es ;
    ex:identificador "2314" .

ex:AvisoSeguridad_2315
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el proceso de resolución del perfil PROGTL3"@es ;
    ex:textoExtracto "2315 'Error en el proceso de resolución del perfil PROGTL3' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado es incorrecto o no tiene solución."@es ;
    ex:identificador "2315" .

ex:AccionProhibida_ProgramarG_en_ProGTL3
    a ex:AccionProhibida ;
    rdfs:label "Programar la función G dentro de un perfil ProGTL3"@es ;
    ex:textoExtracto "SOLUCIÓN Programar la función G tras el inicio de un perfil con G841 o G842. [...] La función programada no está permitida dentro de la definición de un perfil ProGTL3."@es ;
    ex:activaAlarma ex:AvisoSeguridad_2314 .

ex:ModoOperacion_ProGTL3
    a ex:ModoOperacion ;
    rdfs:label "Perfil ProGTL3"@es ;
    ex:textoExtracto "definición de un perfil ProGTL3"@es .