@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros" ;
    ns1:solucionaFallo ns1:LyHaDeSerMultiploDeIy ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:CabezalHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "cabezal de herramientas" ;
    ns1:textoExtracto "Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo." .

ns1:ColocarUnaHerramientaOUnPalpadorEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Colocar una herramienta o un palpador en el cabezal" ;
    ns1:solucionaFallo ns1:NoHayHerramientaProgramada_1e3a6afdfc ;
    ns1:textoExtracto "SOLUCIÓN Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo." .

ns1:DistanciaEntreMecanizados a ns1:Parametro ;
    rdfs:label "distancia entre mecanizados" ;
    ns1:textoExtracto "la distancia entre mecanizados (parámetro Iy)" .

ns1:LongitudDelMecanizado_aadc227af7 a ns1:Parametro ;
    rdfs:label "longitud del mecanizado" ;
    ns1:textoExtracto "La longitud del mecanizado (parámetro Ly)" .

ns1:NoSeHaRecibidoSenalDelPalpador a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha recibido señal del palpador" ;
    ns1:textoExtracto "'No se ha recibido señal del palpador'" .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "No hay herramienta o palpador en el cabezal para poder ejecutar el ciclo fijo." .

ns1:LyHaDeSerMultiploDeIy a ns1:DiagnosticoFallo ;
    rdfs:label "Ly ha de ser múltiplo de Iy" ;
    ns1:textoExtracto "'Ly ha de ser múltiplo de Iy'" .

ns1:NoHayHerramientaProgramada_1e3a6afdfc a ns1:DiagnosticoFallo ;
    rdfs:label "No hay herramienta programada" ;
    ns1:textoExtracto "'No hay herramienta programada'" .

