@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarPlanoPrincipalParaCalibracion a ns1:AccionProhibida ;
    rdfs:label "Activar plano principal para calibración" ;
    ns1:textoExtracto "Activar un plano principal G17, G18 o G19 para ejecutar el ciclo." .

ns1:CalibracionDobleI1 a ns1:AccionProhibida ;
    rdfs:label "Calibración doble (I = 1)" ;
    ns1:textoExtracto "El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)." .

ns1:CalibracionIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Calibración incorrecta" ;
    ns1:textoExtracto "'Programar I = 0/1'" .

ns1:CalibracionSimpleI0 a ns1:AccionProhibida ;
    rdfs:label "Calibración simple (I = 0)" ;
    ns1:textoExtracto "El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)." .

ns1:CicloDePalpadorPROBE2_feeddd9e2a a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de palpador #PROBE 2" ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 2." .

ns1:CicloPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de palpador" ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 2." .

ns1:CicloPalpador1 a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de palpador #PROBE" ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de palpador #PROBE." .

ns1:PlanoDeTrabajoIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Plano de trabajo incorrecto" ;
    ns1:textoExtracto "'El plano activo para calibrado de palpador debe ser G17, G18 o G19'" .

ns1:ProgramarI01_382f895b83 a ns1:AccionProhibida ;
    rdfs:label "Programar I = 0/1" ;
    ns1:textoExtracto "'Programar I = 0/1'" .

ns1:TipoDeCalibracion a ns1:Parametro ;
    rdfs:label "Tipo de calibración" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "El parámetro I (tipo de calibración) tiene un valor incorrecto." .

