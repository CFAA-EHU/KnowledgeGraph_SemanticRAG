@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_9a77cb567e a ns1:AccionProhibida ;
    rdfs:label "Herramienta gastada por desgaste de radio" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "La herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M)." .

ns1:EjecutarCicloDePalpadorConG20Activo a ns1:AccionProhibida ;
    rdfs:label "Ejecutar ciclo de palpador con G20 activo" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'#PROBE 1: no se admite con G20 activa'" .

ns1:Parametro_0b092ccfe1 a ns1:Parametro ;
    rdfs:label "Parámetro U (cota máxima)" ;
    ns1:identificador "U" ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas." .

ns1:Parametro_3844dc083e a ns1:Parametro ;
    rdfs:label "Parámetro B (distancia de seguridad)" ;
    ns1:identificador "B" ;
    ns1:textoExtracto "El parámetro B tiene valor negativo." .

ns1:Parametro_530f399f02 a ns1:Parametro ;
    rdfs:label "Parámetro V (cota máxima)" ;
    ns1:identificador "V" ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas." .

ns1:Parametro_ed9f1e1351 a ns1:Parametro ;
    rdfs:label "Parámetro K (eje de palpación)" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "El parámetro K sólo admite los valores 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)." .

ns1:Parametro_fc64e7c701 a ns1:Parametro ;
    rdfs:label "Parámetro W (cota máxima)" ;
    ns1:identificador "W" ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas." .

