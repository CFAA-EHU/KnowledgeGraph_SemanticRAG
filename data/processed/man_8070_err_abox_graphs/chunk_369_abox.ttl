@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotasMaximasDelPalpador a ns1:Parametro ;
    rdfs:label "Cotas máximas del palpador" ;
    ns1:textoExtracto "Los parámetros U V W hacen referencia a las cotas máximas." .

ns1:CotasMinimasDelPalpador a ns1:Parametro ;
    rdfs:label "Cotas mínimas del palpador" ;
    ns1:textoExtracto "Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W. Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador." .

ns1:DefinirLaHerramientaEnLaTablaOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir la herramienta en la tabla o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:NoExisteTDeDesbasteEnCajeraConIslas ;
    ns1:textoExtracto "SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." .

ns1:DefinirLaPosicionDelPalpadorCorrectamente a ns1:TareaMantenimiento ;
    rdfs:label "Definir la posición del palpador correctamente" ;
    ns1:solucionaFallo ns1:DefinirLaPosicionDelPalpadorIncorrectamente ;
    ns1:textoExtracto "SOLUCIÓN Definir la posición del palpador de manera que U > X, V > Y, W > Z." .

ns1:DefinirLaPosicionDelPalpadorIncorrectamente a ns1:AccionProhibida ;
    rdfs:label "Definir la posición del palpador incorrectamente" ;
    ns1:textoExtracto "Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W." .

ns1:NoExisteTDeDesbasteEnCajeraConIslas a ns1:DiagnosticoFallo ;
    rdfs:label "No existe T de desbaste en cajera con islas" ;
    ns1:textoExtracto "'Cajera con islas: No existe T de desbaste'" .

