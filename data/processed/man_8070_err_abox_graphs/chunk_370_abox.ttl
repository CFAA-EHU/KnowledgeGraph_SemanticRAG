@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnAvanceMayorQue0 a ns1:TareaMantenimiento ;
    rdfs:label "Definir un avance mayor que 0" ;
    ns1:solucionaFallo ns1:ElAvanceParaLaOperacionDeDesbasteTieneValor0 ;
    ns1:textoExtracto "SOLUCIÓN Definir un avance mayor que 0." .

ns1:DefinirUnaVelocidadMayorQue0 a ns1:TareaMantenimiento ;
    rdfs:label "Definir una velocidad mayor que 0" ;
    ns1:solucionaFallo ns1:LaVelocidadParaLaOperacionDeDesbasteTieneValor0 ;
    ns1:textoExtracto "SOLUCIÓN Definir una velocidad mayor que 0." .

ns1:SolucionCorregirPasoMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el paso de mecanizado o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:ElPasoDeMecanizadoParaElDesbasteParametroEsMayorQueElDiametroDeLaHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta." .

ns1:SolucionDefinirHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir la herramienta en la tabla o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:LaHerramientaProgramadaNoExisteEnLaTablaDeHerramientas ;
    ns1:textoExtracto "SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." .

ns1:ElAvanceParaLaOperacionDeDesbasteTieneValor0 a ns1:DiagnosticoFallo ;
    rdfs:label "El avance para la operación de desbaste tiene valor 0" ;
    ns1:textoExtracto "CAUSA El avance para la operación de desbaste tiene valor 0." .

ns1:ElPasoDeMecanizadoParaElDesbasteParametroEsMayorQueElDiametroDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "El paso de mecanizado para el desbaste (parámetro Δ) es mayor que el diámetro de la herramienta" ;
    ns1:textoExtracto "CAUSA El paso de mecanizado para el desbaste (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:LaHerramientaProgramadaNoExisteEnLaTablaDeHerramientas a ns1:DiagnosticoFallo ;
    rdfs:label "La herramienta programada no existe en la tabla de herramientas" ;
    ns1:textoExtracto "CAUSA La herramienta programada no existe en la tabla de herramientas." .

ns1:LaVelocidadParaLaOperacionDeDesbasteTieneValor0 a ns1:DiagnosticoFallo ;
    rdfs:label "La velocidad para la operación de desbaste tiene valor 0" ;
    ns1:textoExtracto "CAUSA La velocidad para la operación de desbaste tiene valor 0." .

