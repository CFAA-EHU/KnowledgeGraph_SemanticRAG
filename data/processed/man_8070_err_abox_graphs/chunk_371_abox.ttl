@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirElPasoDeMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el paso de mecanizado" ;
    ns1:solucionaFallo ns1:CajeraConIslasDemasiaLateralNoValida ;
    ns1:textoExtracto "Corregir el paso de mecanizado" .

ns1:CorregirElPasoDeMecanizadoOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el paso de mecanizado o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:CajeraConIslasPasoDeAcabadoNoValido ;
    ns1:textoExtracto "Corregir el paso de mecanizado o seleccionar otra herramienta" .

ns1:DemasiaLateralParaElAcabadoParametro a ns1:Parametro ;
    rdfs:label "demasía lateral para el acabado (parámetro )" ;
    ns1:textoExtracto "La demasía lateral para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:PasoDeMecanizadoParaElAcabadoParametro a ns1:Parametro ;
    rdfs:label "paso de mecanizado para el acabado (parámetro )" ;
    ns1:textoExtracto "el paso de mecanizado para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:PasoDeMecanizadoParaElAcabadoParametro_9a00651cce a ns1:Parametro ;
    rdfs:label "paso de mecanizado para el acabado (parámetro )" ;
    ns1:textoExtracto "el paso de mecanizado para el acabado (parámetro ) es cero." .

ns1:CajeraConIslasDemasiaLateralNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Demasía lateral no válida" ;
    ns1:textoExtracto "'Cajera con islas: Demasía lateral no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía lateral para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:CajeraConIslasPasoDeAcabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Paso de acabado no válido" ;
    ns1:textoExtracto "'Cajera con islas: Paso de acabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA En una cajera 2D, el paso de mecanizado para el acabado (parámetro ) es mayor que el diámetro de la herramienta. En una cajera 3D, el paso de mecanizado para el acabado (parámetro ) es cero." .

