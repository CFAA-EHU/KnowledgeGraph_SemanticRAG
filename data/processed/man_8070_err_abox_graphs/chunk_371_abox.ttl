@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2341
    a ex:Alarma ;
    rdfs:label "Programación de vector incorrecta" ;
    ex:identificador "2341" ;
    ex:textoExtracto "2341 'Programación de vector incorrecta' [...] SOLUCIÓN Revisar la programación. Programar las tres componentes del vector." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_Compensacion3D_VectorIncompleto .

ex:Alarma_2342
    a ex:Alarma ;
    rdfs:label "Es necesario programar el vector N[-,-,-] para la compensación 3D" ;
    ex:identificador "2342" ;
    ex:textoExtracto "2342 'Es necesario programar el vector N[-,-,-] para la compensación 3D' [...] SOLUCIÓN Revisar la programación. Con la compensación de herramienta 3D activa, es obligatorio programar un vector en cada bloque de movimiento." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_Compensacion3D_VectorFaltante .

ex:Alarma_2343
    a ex:Alarma ;
    rdfs:label "Herramienta activa no adecuada para compensación 3D" ;
    ex:identificador "2343" ;
    ex:textoExtracto "2343 'Herramienta activa no adecuada para compensación 3D' [...] SOLUCIÓN La compensación de herramienta 3D en modo 'NORMAL' sólo admite herramientas de fresado planas, tóricas o esféricas." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_Compensacion3D_HerramientaInvalida .

ex:Alarma_2344
    a ex:Alarma ;
    rdfs:label "Programar #COMP3D ON/OFF [PARAX/NORMAL]" ;
    ex:identificador "2344" ;
    ex:textoExtracto "2344 'Programar #COMP3D ON/OFF [PARAX/NORMAL]' [...] SOLUCIÓN Revisar la programación." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_Compensacion3D_SintaxisIncorrecta .

ex:Alarma_2345
    a ex:Alarma ;
    rdfs:label "Perfil doblemente definido" ;
    ex:identificador "2345" ;
    ex:textoExtracto "2345 'Perfil doblemente definido' [...] SOLUCIÓN Revisar la programación. Definir un único perfil." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_PerfilDuplicado .

ex:Alarma_2346
    a ex:Alarma ;
    rdfs:label "Superado el máximo de bloques para la visualización 2D" ;
    ex:identificador "2346" ;
    ex:textoExtracto "2346 'Superado el máximo de bloques para la visualización 2D' [...] SOLUCIÓN Modificar el programa o visualizarlo por partes." ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_Visualizacion2D_ExcesoBloques .

ex:Alarma_2347
    a ex:Alarma ;
    rdfs:label "No se admite perfil PROGTL3 con G91 activa" ;
    ex:identificador "2347" ;
    ex:textoExtracto "2347 'No se admite perfil PROGTL3 con G91 activa' [...]" ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_ConfiguracionPerfilInvalida .

ex:DiagnosticoFallo_Compensacion3D_VectorIncompleto
    a ex:DiagnosticoFallo ;
    rdfs:label "Vector N[a,b,c] con componentes incompletas en compensación 3D" ;
    ex:textoExtracto "El vector N[a,b,c] es incorrecto. SOLUCIÓN [...] Programar las tres componentes del vector." .

ex:DiagnosticoFallo_Compensacion3D_VectorFaltante
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta vector N[a,b,c] en bloque con compensación 3D activa" ;
    ex:textoExtracto "Con la compensación de herramienta 3D activa, falta el vector N[a,b,c] en algún bloque." .

ex:DiagnosticoFallo_Compensacion3D_HerramientaInvalida
    a ex:DiagnosticoFallo ;
    rdfs:label "Herramienta no plana/tórica/esférica para compensación 3D en modo NORMAL" ;
    ex:textoExtracto "La herramienta no es plana, tórica o esférica. [...] La compensación de herramienta 3D en modo 'NORMAL' sólo admite herramientas de fresado planas, tóricas o esféricas." .

ex:DiagnosticoFallo_Compensacion3D_SintaxisIncorrecta
    a ex:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en sentencia #COMP3D" ;
    ex:textoExtracto "La sintaxis de la sentencia #COMP3D ON/OFF [PARAX/NORMAL] no es correcta." .

ex:DiagnosticoFallo_PerfilDuplicado
    a ex:DiagnosticoFallo ;
    rdfs:label "Múltiples definiciones de perfil en planta o sección" ;
    ex:textoExtracto "Hay definido más de un perfil planta o más de un perfil en una sección." .

ex:DiagnosticoFallo_Visualizacion2D_ExcesoBloques
    a ex:DiagnosticoFallo ;
    rdfs:label "Exceso de bloques (máx. 500) para visualización 2D" ;
    ex:textoExtracto "Se ha sobrepasado el número de bloques máximo (500) para visualización 2D." .

ex:DiagnosticoFallo_ConfiguracionPerfilInvalida
    a ex:DiagnosticoFallo ;
    rdfs:label "Perfil PROGTL3 incompatible con G91 activa" ;
    ex:textoExtracto "No se admite perfil PROGTL3 con G91 activa." .