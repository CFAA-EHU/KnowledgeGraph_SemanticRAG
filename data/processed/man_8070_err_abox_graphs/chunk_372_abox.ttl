@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CajeraConIslasDemasiaLateralNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Demasía lateral no válida" ;
    ns1:textoExtracto "'Cajera con islas: Demasía lateral no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía lateral para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:CajeraConIslasPerfilEnXYNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no existe" ;
    ns1:textoExtracto "'Cajera con islas: Perfil en XY no existe' DETECCIÓN Durante la ejecución del ciclo. CAUSA No existe el perfil de superficie programado." .

ns1:CajeraConIslasPerfilEnXYNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no válido" ;
    ns1:textoExtracto "'Cajera con islas: Perfil en XY no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Geometría del perfil de superficie mal programada." .

ns1:CajeraConIslasPerfilEnZNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en Z no existe" ;
    ns1:textoExtracto "'Cajera con islas: Perfil en Z no existe' DETECCIÓN Durante la ejecución del ciclo. CAUSA No existe el perfil de profundidad programado." .

ns1:CajeraConIslasProfundidadNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Profundidad no válida" ;
    ns1:textoExtracto "'Cajera con islas: Profundidad no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P (profundidad de la cajera) tiene valor 0." .

ns1:CajeraConIslasRadioDeLaHerramientaDeSemiacabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Radio de la herramienta de semiacabado no válido" ;
    ns1:textoExtracto "'Cajera con islas: Radio de la herramienta de semiacabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera." .

ns1:CajeraConIslasRadioDeLaPuntaDeLaHerramientaDeAcabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Radio de la punta de la herramienta de acabado no válido" ;
    ns1:textoExtracto "'Cajera con islas: Radio de la punta de la herramienta de acabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R)." .

ns1:DemasiaLateralParaElAcabado a ns1:Parametro ;
    rdfs:label "Demasía lateral para el acabado" ;
    ns1:textoExtracto "'Cajera con islas: Demasía lateral no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía lateral para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ns1:Herramienta_6c296bbd71 a ns1:Herramienta ;
    rdfs:label "Herramienta de semiacabado" ;
    ns1:textoExtracto "'Cajera con islas: Radio de la herramienta de semiacabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera." .

ns1:Herramienta_d0dc9b61b4 a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado" ;
    ns1:textoExtracto "'Cajera con islas: Radio de la punta de la herramienta de acabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R)." .

ns1:ProfundidadDeLaCajera a ns1:Parametro ;
    rdfs:label "Profundidad de la cajera" ;
    ns1:textoExtracto "'Cajera con islas: Profundidad no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P (profundidad de la cajera) tiene valor 0." .

