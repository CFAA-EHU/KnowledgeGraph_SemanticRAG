PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2347
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 2347: Perfil PROGTL3 con G91 activa"@es ;
    ex:identificador "2347" ;
    ex:textoExtracto "No se admite perfil PROGTL3 con G91 activa. [...] No se permite iniciar un perfil con G91 activa, ni programar G91 dentro de un perfil G841-G842."@es .

ex:AvisoSeguridad_2348
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 2348: Macro"@es ;
    ex:identificador "2348" ;
    ex:textoExtracto "Macro"@es .

ex:Parametro_G91
    a               ex:Parametro ;
    rdfs:label      "Parámetro G91 (modo incremental)"@es ;
    ex:identificador "G91" ;
    ex:textoExtracto "G91 activa"@es .

ex:Parametro_G90
    a               ex:Parametro ;
    rdfs:label      "Parámetro G90 (modo absoluto)"@es ;
    ex:identificador "G90" ;
    ex:textoExtracto "Programar G90 antes del inicio del perfil"@es .

ex:Parametro_G841
    a               ex:Parametro ;
    rdfs:label      "Parámetro G841 (perfil)"@es ;
    ex:identificador "G841" ;
    ex:textoExtracto "perfil G841-G842"@es .

ex:Parametro_G842
    a               ex:Parametro ;
    rdfs:label      "Parámetro G842 (perfil)"@es ;
    ex:identificador "G842" ;
    ex:textoExtracto "perfil G841-G842"@es .

ex:ModoOperacion_PROGTL3
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de operación PROGTL3"@es ;
    ex:identificador "PROGTL3" ;
    ex:textoExtracto "perfil PROGTL3"@es .

ex:AvisoSeguridad_2347
    ex:solucionaFallo ex:ModoOperacion_PROGTL3 ;
    ex:mitigaRiesgo  ex:Parametro_G91 .