@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2348
    a ex:AvisoSeguridad ;
    rdfs:label "Macro G8735/G8736/G8725/G8726 doblemente definida" ;
    ex:identificador "2348" ;
    ex:textoExtracto "2348 'Macro G8735/G8736/G8725/G8726 doblemente definida' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir una nueva macro sin finalizar la anterior. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ex:AvisoSeguridad_2349
    a ex:AvisoSeguridad ;
    rdfs:label "Inicio de perfil G841/G842 doblemente definido" ;
    ex:identificador "2349" ;
    ex:textoExtracto "2349 'Inicio de perfil G841/G842 doblemente definido' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir un nuevo perfil sin finalizar el anterior. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de los perfiles." .

ex:AvisoSeguridad_2350
    a ex:AvisoSeguridad ;
    rdfs:label "Se espera final de macro: G8738/G8734/G8728/G8724" ;
    ex:identificador "2350" ;
    ex:textoExtracto "2350 Se espera final de macro: G8738/G8734/G8728/G8724 DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado el final del programa sin finalizar la macro definida. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ex:AvisoSeguridad_2351
    a ex:AvisoSeguridad ;
    rdfs:label "No se ha programado perfil" ;
    ex:identificador "2351" ;
    ex:textoExtracto "2351 'No se ha programado perfil' DETECCIÓN Durante la ejecución. CAUSA Falta programar algún perfil en la macro ProGTL3. SOLUCIÓN Para ejecutar correctamente la macro es obligatorio definir todos los perfiles." .

ex:AvisoSeguridad_2352
    a ex:AvisoSeguridad ;
    rdfs:label "Entidad sin inicializar" ;
    ex:identificador "2352" ;
    ex:textoExtracto "2352 'Ente sin inicializar' DETECCIÓN Durante la ejecución. CAUSA El programa ha intentado utilizar un ente no inializado. SOLUCIÓN Antes de utilizar un ente, éste debe estar previamente inicializado." .

ex:AvisoSeguridad_2353
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #LSFIT" ;
    ex:identificador "2353" ;
    ex:textoExtracto "2353 Programar #LSFIT [tipo, pLocal <,data1, data2, data3> ] DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2354
    a ex:AvisoSeguridad ;
    rdfs:label "#LSFIT, parámetro local no válido" ;
    ex:identificador "2354" ;
    ex:textoExtracto "2354 #LSFIT, parámetro local no válido. DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2355
    a ex:AvisoSeguridad ;
    rdfs:label "Error en proceso #LSFIT" ;
    ex:identificador "2355" ;
    ex:textoExtracto "2355 'Error en proceso #LSFIT' DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT." .

ex:Parametro_G90
    a ex:Parametro ;
    rdfs:label "Programación de cotas absolutas (G90)" ;
    ex:textoExtracto "SOLUCIÓN Programar G90 antes del inicio del perfil." ;
    ex:valor "G90" .

ex:Parametro_ProGTL3
    a ex:Parametro ;
    rdfs:label "Macro ProGTL3" ;
    ex:identificador "ProGTL3" ;
    ex:textoExtracto "Falta programar algún perfil en la macro ProGTL3." .

ex:Parametro_LSFIT
    a ex:Parametro ;
    rdfs:label "Función #LSFIT" ;
    ex:identificador "#LSFIT" ;
    ex:textoExtracto "Programar #LSFIT [tipo, pLocal <,data1, data2, data3> ]" .