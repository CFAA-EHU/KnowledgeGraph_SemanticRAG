@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CajeraConIslasFDeSemiacabadoNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: F de semiacabado no válida" ;
    ns1:textoExtracto "1881 'Cajera con islas: F de semiacabado no válida' DETECCIÓN" .

ns1:DefinirHerramientaEnLaTablaOSeleccionarOtraHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir herramienta en la tabla o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:CajeraConIslasNoExisteTDeSemiacabado,
        ns1:DiagnosticoFalloCajeraConIslasFDeSemiacabado ;
    ns1:textoExtracto "SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." .

ns1:CajeraConIslasNoExisteTDeSemiacabado a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: No existe T de semiacabado" ;
    ns1:textoExtracto "1880 'Cajera con islas: No existe T de semiacabado' DETECCIÓN Durante la ejecución del ciclo." .

