@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_5e00cf8db4 a ns1:AccionProhibida ;
    rdfs:label "herramienta programada no existe en la tabla de herramientas" ;
    ns1:textoExtracto "herramienta programada no existe en la tabla de herramientas." .

ns1:CorregirLaGeometriaDelPerfilDesdeElEditorDePerfiles a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la geometría del perfil desde el editor de perfiles" ;
    ns1:solucionaFallo ns1:CajeraConIslasArcoMalProgramadoEnPerfil,
        ns1:CajeraConIslasGeometriaDeLaCajeraNoValida ;
    ns1:textoExtracto "SOLUCIÓN Corregir la geometría del perfil desde el editor de perfiles." .

ns1:DefinirUnAvanceMayorQue0 a ns1:TareaMantenimiento ;
    rdfs:label "Definir un avance mayor que 0" ;
    ns1:solucionaFallo ns1:CajeraConIslasFDeSemiacabadoNoValida_a866ccc265 ;
    ns1:textoExtracto "SOLUCIÓN Definir un avance mayor que 0." .

ns1:DefinirUnaVelocidadMayorQue0 a ns1:TareaMantenimiento ;
    rdfs:label "Definir una velocidad mayor que 0" ;
    ns1:solucionaFallo ns1:CajeraConIslasSDeSemiacabadoNoValida ;
    ns1:textoExtracto "SOLUCIÓN Definir una velocidad mayor que 0." .

ns1:EsperarAQueElCNCTermineLaSimulacionOEjecucion a ns1:TareaMantenimiento ;
    rdfs:label "Esperar a que el CNC termine la simulación o ejecución" ;
    ns1:solucionaFallo ns1:CajeraConIslasCajeraYaEnEjecucion ;
    ns1:textoExtracto "SOLUCIÓN Esperar a que el CNC termine la simulación o ejecución." .

ns1:CajeraConIslasArcoMalProgramadoEnPerfil a ns1:DiagnosticoFallo ;
    rdfs:label "'Cajera con islas: Arco mal programado en perfil'" ;
    ns1:textoExtracto "'Cajera con islas: Arco mal programado en perfil' DETECCIÓN Durante la ejecución del ciclo. CAUSA En algún perfil de la cajera hay un arco mal definido o el perfil se ha modificado con otro programa diferente al editor de perfiles." .

ns1:CajeraConIslasCajeraYaEnEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "'Cajera con islas: Cajera ya en ejecución'" ;
    ns1:textoExtracto "'Cajera con islas: Cajera ya en ejecución' DETECCIÓN Durante la ejecución del ciclo. CAUSA El CNC no puede simular o ejecutar la cajera porque ésta ya se encuentra en ejecución o simulación." .

ns1:CajeraConIslasFDeSemiacabadoNoValida_a866ccc265 a ns1:DiagnosticoFallo ;
    rdfs:label "'Cajera con islas: F de semiacabado no válida'" ;
    ns1:textoExtracto "'Cajera con islas: F de semiacabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de semiacabado tiene valor 0." .

ns1:CajeraConIslasGeometriaDeLaCajeraNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "'Cajera con islas: Geometría de la cajera no válida'" ;
    ns1:textoExtracto "'Cajera con islas: Geometría de la cajera no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA En algún perfil de la cajera hay un tramo mal definido (redondeos, chaflanes, etc)." .

ns1:CajeraConIslasSDeSemiacabadoNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "'Cajera con islas: S de semiacabado no válida'" ;
    ns1:textoExtracto "'Cajera con islas: S de semiacabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad para la operación de semiacabado tiene valor 0." .

