@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2356 a ex:DiagnosticoFallo ;
    ex:identificador "2356" ;
    rdfs:label "Programar #SELECT ORI [HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]"@es ;
    ex:textoExtracto "2356 'Programar #SELECT ORI [HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación."@es .

ex:Fallo_2357 a ex:DiagnosticoFallo ;
    ex:identificador "2357" ;
    rdfs:label "Ejes rotativos seleccionados iguales o incorrectos"@es ;
    ex:textoExtracto "2357 'Ejes rotativos seleccionados iguales o incorrectos' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes rotativos seleccionados coinciden o son incorrectos. SOLUCIÓN Revisar la programación. Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ex:Fallo_2358 a ex:DiagnosticoFallo ;
    ex:identificador "2358" ;
    rdfs:label "#DGWZ CYL: El eje programado debe ser un eje lineal"@es ;
    ex:textoExtracto "2358 '#DGWZ CYL: El eje programado debe ser un eje lineal' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #DGWZ no es lineal. SOLUCIÓN Seleccionar como eje longitudinal un eje lineal."@es .

ex:Fallo_2359 a ex:DiagnosticoFallo ;
    ex:identificador "2359" ;
    rdfs:label "#DGWZ CYL: El eje programado debe pertenecer al plano o triedro"@es ;
    ex:textoExtracto "2359 '#DGWZ CYL: El eje programado debe pertenecer al plano o triedro' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #DGWZ no pertenece al plano o triedo. SOLUCIÓN Seleccionar como eje longitudinal un eje del plano o del triedro."@es .

ex:Fallo_2360 a ex:DiagnosticoFallo ;
    ex:identificador "2360" ;
    rdfs:label "La función o sentencia no permite programación de ejes"@es ;
    ex:textoExtracto "2360 'La función o sentencia no permite programación de ejes' DETECCIÓN Durante la ejecución. CAUSA En la función o sentencia hay programado un eje. SOLUCIÓN Revisar la programación."@es .

ex:Fallo_2361 a ex:DiagnosticoFallo ;
    ex:identificador "2361" ;
    rdfs:label "#DGWZ <RECT>: No se permite programar eje de rotación"@es ;
    ex:textoExtracto "2361 '#DGWZ <RECT>: No se permite programar eje de rotación. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el eje de rotación en DGWZ o DGWZ RECT. SOLUCIÓN Sólo se permite programar eje de rotación en DGWZ CYL. Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT."@es .

ex:Fallo_2362 a ex:DiagnosticoFallo ;
    ex:identificador "2362" ;
    rdfs:label "#DGWZ CYL: Eje de rotación no programado"@es ;
    ex:textoExtracto "2362 '#DGWZ CYL: Eje de rotación no programado. DETECCIÓN Durante la ejecución. CAUSA En DGWZ CYL es obligatorio programar un eje de rotación y no se ha programado."@es .

ex:ComponenteMecanico_HEAD1 a ex:ComponenteMecanico ;
    ex:identificador "HEAD1" ;
    ex:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ex:ComponenteMecanico_HEAD2 a ex:ComponenteMecanico ;
    ex:identificador "HEAD2" ;
    ex:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ex:ComponenteMecanico_TABLE1 a ex:ComponenteMecanico ;
    ex:identificador "TABLE1" ;
    ex:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ex:ComponenteMecanico_TABLE2 a ex:ComponenteMecanico ;
    ex:identificador "TABLE2" ;
    ex:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .