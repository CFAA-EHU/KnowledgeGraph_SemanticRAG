@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnguloDeProfundizacionParaElAcabado a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para el acabado" ;
    ns1:parametroMonitoradoPor ns1:SistemaCNC ;
    ns1:textoExtracto "El ángulo de profundización para el acabado (parámetro ) no está comprendido entre 0º y 90º." .

ns1:AnguloDeProfundizacionParaElDesbaste_d1286ec477 a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para el desbaste" ;
    ns1:parametroMonitoradoPor ns1:SistemaCNC ;
    ns1:textoExtracto "El ángulo de profundización para el desbaste (parámetro ) no está comprendido entre 0º y 90º." .

ns1:CorregirElAnguloDeProfundizacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el ángulo de profundización" ;
    ns1:solucionaFallo ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeDesbasteNoValido_efc0120917,
        ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeSemiacabadoNoValido_6dd9e6aaf3 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ns1:CorregirLaGeometriaDelPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la geometría del perfil" ;
    ns1:solucionaFallo ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeDesbasteNoValido_efc0120917,
        ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeSemiacabadoNoValido_6dd9e6aaf3 ;
    ns1:textoExtracto "SOLUCIÓN Corregir la geometría del perfil desde el editor de perfiles." .

ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeDesbasteNoValido_efc0120917 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido" ;
    ns1:textoExtracto "'Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste (parámetro ) no está comprendido entre 0º y 90º." .

ns1:CajeraConIslasAnguloDeProfundizacionDeLaHerramientaDeSemiacabadoNoValido_6dd9e6aaf3 a ns1:DiagnosticoFallo ;
