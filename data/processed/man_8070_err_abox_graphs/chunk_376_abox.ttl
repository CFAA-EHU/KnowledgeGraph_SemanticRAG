@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros" ;
    ns1:solucionaFallo ns1:CajeraConIslasTipoDeAcabadoNoValido ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:CorregirElAnguloDeProfundizacion_5c3b4f75e5 a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el ángulo de profundización" ;
    ns1:solucionaFallo ns1:CajeraConIslasTipoDeAcabadoNoValido ;
    ns1:textoExtracto "CAUSA El ángulo de profundización para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ns1:CorregirLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación" ;
    ns1:solucionaFallo ns1:DatoNoValido ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación." .

ns1:ProgramarTodosLosParametrosObligatoriosDelCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Programar todos los parámetros obligatorios del ciclo" ;
    ns1:solucionaFallo ns1:DatoObligatorioNoProgramado ;
    ns1:textoExtracto "SOLUCIÓN Programar todos los parámetros obligatorios del ciclo." .

ns1:ProgramarUnaDistanciaMayor a ns1:TareaMantenimiento ;
    rdfs:label "Programar una distancia mayor" ;
    ns1:solucionaFallo ns1:MovimientoDeVaivenDistanciaRecorridaDemasiadoPequena ;
    ns1:textoExtracto "SOLUCIÓN Programar una distancia mayor." .

ns1:ProgramarUnaDistanciaMenor a ns1:TareaMantenimiento ;
    rdfs:label "Programar una distancia menor" ;
    ns1:solucionaFallo ns1:MovimientoDeVaivenDistanciaRecorridaDemasiadoGrande ;
    ns1:textoExtracto "SOLUCIÓN Programar una distancia menor." .

ns1:RepararLaHerramientaOUtilizarUnaHerramientaEquivalente a ns1:TareaMantenimiento ;
    rdfs:label "Reparar la herramienta o utilizar una herramienta equivalente" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_82c14ffced ;
    ns1:textoExtracto "SOLUCIÓN Reparar la herramienta o utilizar una herramienta equivalente." .

ns1:TipoDeAcabado_f4a9feaec5 a ns1:Parametro ;
    rdfs:label "Tipo de acabado" ;
    ns1:textoExtracto "El tipo de acabado (parámetro Q) no es válido." .

ns1:ToleranciaPermitida a ns1:Parametro ;
    rdfs:label "Tolerancia permitida" ;
    ns1:textoExtracto "El desgaste medido es mayor que la tolerancia permitida (parámetro M)." .

ns1:DatoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Dato no válido" ;
    ns1:textoExtracto "'Dato no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro del ciclo tiene un valor incorrecto." .

ns1:DatoObligatorioNoProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Dato obligatorio no programado" ;
    ns1:textoExtracto "'Dato obligatorio no programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar uno o más parámetros obligatorios." .

ns1:DiagnosticoFallo_82c14ffced a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta gastada por desgaste de longitud" ;
    ns1:textoExtracto "Herramienta gastada por desgaste de longitud. DETECCIÓN Durante la ejecución. CAUSA El ciclo ha detectado que la herramienta está gastada." .

ns1:MovimientoDeVaivenDistanciaRecorridaDemasiadoGrande a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de vaivén: Distancia recorrida demasiado grande" ;
    ns1:textoExtracto "'Movimiento de vaivén: Distancia recorrida demasiado grande' DETECCIÓN Ejecución del movimiento de vaivén para el ajuste del momento de inercia. CAUSA La distancia programada en el movimiento de vaivén es demasiado grande." .

ns1:MovimientoDeVaivenDistanciaRecorridaDemasiadoPequena a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de vaivén: Distancia recorrida demasiado pequeña" ;
    ns1:textoExtracto "'Movimiento de vaivén: Distancia recorrida demasiado pequeña' DETECCIÓN Ejecución del movimiento de vaivén para el ajuste del momento de inercia. CAUSA La distancia programada en el movimiento de vaivén es insuficiente." .

ns1:CajeraConIslasTipoDeAcabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Tipo de acabado no válido" ;
    ns1:textoExtracto "'Cajera con islas: Tipo de acabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El tipo de acabado (parámetro Q) no es válido." .

