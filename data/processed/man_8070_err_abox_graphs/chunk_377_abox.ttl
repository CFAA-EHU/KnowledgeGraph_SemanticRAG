@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación" ;
    ns1:solucionaFallo ns1:DatoNoValido ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación." .

ns1:PosicionarLaHerramientaAdecuadamente a ns1:AccionProhibida ;
    rdfs:label "Posicionar la herramienta adecuadamente" ;
    ns1:solucionaFallo ns1:PosicionInicialYFactorDeFormaDeLaHerramientaIncompatibles ;
    ns1:textoExtracto "SOLUCIÓN Posicionar la herramienta adecuadamente o" .

ns1:DatoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Dato no válido" ;
    ns1:textoExtracto "'Dato no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro del ciclo tiene un valor incorrecto." .

ns1:PosicionInicialYFactorDeFormaDeLaHerramientaIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Posición inicial y factor de forma de la herramienta incompatibles" ;
    ns1:textoExtracto "'Posición inicial y factor de forma de la herramienta incompatibles' DETECCIÓN Durante la ejecución del ciclo. CAUSA La posición inicial de la herramienta no es compatible con el factor de forma y la geometría de la herramienta." .

