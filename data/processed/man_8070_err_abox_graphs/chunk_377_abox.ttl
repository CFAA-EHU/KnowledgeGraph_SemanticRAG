@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2364 a ex:DiagnosticoFallo ;
    ex:identificador "2364" ;
    rdfs:label "Punto final de movimiento inexistente" ;
    ex:textoExtracto "2364 Punto final de movimiento inexistente. DETECCIÓN Durante la ejecución. CAUSA La cota programada mediante una coordenada cartesiana y un ángulo es incorrecta. La trayectoria que parte del punto anterior no puede alcanzar el punto programado. SOLUCIÓN Programar correctamente el punto final de movimiento." .

ex:Fallo_2365 a ex:DiagnosticoFallo ;
    ex:identificador "2365" ;
    rdfs:label "G34: Doble programación del incremento/decremento del paso de husillo" ;
    ex:textoExtracto "2365 G34: Doble programación del incremento/decremento del paso de husillo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado más de una vez el incremento/decremento del paso de husillo (K1) SOLUCIÓN Programar el incremento/decremento del paso de husillo una única vez en el bloque." .

ex:Fallo_2366 a ex:DiagnosticoFallo ;
    ex:identificador "2366" ;
    rdfs:label "G34: Incremento/decremento del paso de husillo igual a cero" ;
    ex:textoExtracto "2366 G34: Incremento/decremento del paso de husillo igual a cero. DETECCIÓN Durante la ejecución. CAUSA El incremento/decremento del paso de husillo (K1) para G34 es cero. SOLUCIÓN Programar un incremento/decremento del paso de husillo (K1) para G34." .

ex:Fallo_2367 a ex:DiagnosticoFallo ;
    ex:identificador "2367" ;
    rdfs:label "G34: Incremento/decremento del paso de husillo fuera de rango" ;
    ex:textoExtracto "2367 G34: Incremento/decremento del paso de husillo fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El valor del incremento/decremento del paso de husillo en G34 es incorrecto. SOLUCIÓN Programar un valor correcto del incremento/decremento del paso de husillo (K1)." .

ex:Fallo_2368 a ex:DiagnosticoFallo ;
    ex:identificador "2368" ;
    rdfs:label "G34: Incremento/decremento del paso de husillo demasiado grande" ;
    ex:textoExtracto "2368 G34: Incremento/decremento del paso de husillo demasiado grande. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un incremento del paso de husillo superior a dos veces el paso de rosca. SOLUCIÓN Programar un valor correcto del incremento del paso de husillo (K1)." .

ex:Fallo_2369 a ex:DiagnosticoFallo ;
    ex:identificador "2369" ;
    rdfs:label "G34: Paso final de husillo negativo o nulo" ;
    ex:textoExtracto "2369 G34: Paso final de husillo negativo o nulo. DETECCIÓN Durante la ejecución. CAUSA Con el paso de husillo y el decremento de paso de husillo programados en G34, el paso final de rosca calculado por el control es negativo o cero. SOLUCIÓN Programar correctamente el paso y el decremento de paso de husillo en G34" .

ex:Fallo_2370 a ex:DiagnosticoFallo ;
    ex:identificador "2370" ;
    rdfs:label "Eje para roscar inexistente" ;
    ex:textoExtracto "2370 Eje para roscar inexistente." .

ex:Parametro_K1 a ex:Parametro ;
    rdfs:label "Incremento/decremento del paso de husillo (K1)" ;
    ex:textoExtracto "incremento/decremento del paso de husillo (K1)" ;
    ex:monitoreaParametro ex:Fallo_2365, ex:Fallo_2366, ex:Fallo_2367, ex:Fallo_2368, ex:Fallo_2369 .