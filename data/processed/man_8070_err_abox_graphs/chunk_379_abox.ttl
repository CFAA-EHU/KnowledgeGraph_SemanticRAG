    ns1:solucionaFallo ns1:FactorDeFormaNoValidoEnCicloDeDesbaste_193843a972 ;
    ns1:textoExtracto "SOLUCIÓN Corregir" .

ns1:ProgramarUnPasoDeDesbasteMenorOIgualQueLaAnchuraDeLaCuchilla a ns1:TareaMantenimiento ;
