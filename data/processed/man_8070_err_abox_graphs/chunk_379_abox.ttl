@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2370
    a ex:Alarma ;
    rdfs:label "Alarma 2370: Eje para roscar inexistente" ;
    ex:identificador "2370" ;
    ex:textoExtracto "de husillo en G34 2370 Eje para roscar inexistente. DETECCIÓN Durante la ejecución. CAUSA El eje de roscado viene definido por la letra con la que se programa el paso de husillo en el bloque. El eje programado no existe. SOLUCIÓN Programar el paso de husillo en un eje válido." .

ex:Alarma_2371
    a ex:Alarma ;
    rdfs:label "#LSFIT, el algoritmo no converge" ;
    ex:identificador "2371" ;
    ex:textoExtracto "2371 #LSFIT, el algoritmo no converge, compruebe los datos de entrada. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ex:Alarma_2372
    a ex:Alarma ;
    rdfs:label "#LSFIT, número mínimo de datos sobrepasado" ;
    ex:identificador "2372" ;
    ex:textoExtracto "2372 #LSFIT, número mínimo de datos sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El número de palpaciones o datos de entrada es mayor que el mínimo permitido. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

