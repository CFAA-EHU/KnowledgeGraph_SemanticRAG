ex:Sistema_CalibracionCinematica
    a ex:Sistema ;
    rdfs:label "Sistema de calibración de cinemáticas" ;
    ex:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." ;
    ex:activaAlarma ex:Alarma_2371, ex:Alarma_2372, ex:Alarma_2373, ex:Alarma_2374, ex:Alarma_2375, ex:Alarma_2376 .