    rdfs:label "Factor de forma no válido en ciclo de desbaste" ;
    ns1:textoExtracto "'Factor de forma no válido en ciclo de desbaste'" .

ns1:PasoDeDesbasteMayorQueLaAnchuraDeLaCuchilla a ns1:DiagnosticoFallo ;
