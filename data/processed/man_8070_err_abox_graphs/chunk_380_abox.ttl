@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2376_LSFIT
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de cálculo (LSFIT, SVBK)"@es ;
    ex:identificador "2376 #LSFIT" ;
    ex:textoExtracto "2376 #LSFIT, error de cálculo (SVBK), compruebe los datos de entrada."@es ;
    ex:textoExtracto "CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada."@es ;
    ex:textoExtracto "SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación."@es .

ex:Tarea_CorreccionDatosEntrada
    a ex:TareaMantenimiento ;
    rdfs:label "Corrección de datos de entrada para calibración cinemática"@es ;
    ex:textoExtracto "Corregir los datos de entrada o el número y/o posiciones de palpación."@es ;
    ex:solucionaFallo ex:Fallo_2376_LSFIT .