@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarElPerfilQueDefineLaGeometriaDelCicloFijo a ns1:TareaMantenimiento ;
    rdfs:label "Programar el perfil que define la geometría del ciclo fijo" ;
    ns1:solucionaFallo ns1:NoSeHaProgramadoPerfil ;
    ns1:textoExtracto "SOLUCIÓN Programar el perfil que define la geometría del ciclo fijo." .

ns1:ProgramarUnPerfilQueNoSeCorteASiMismo a ns1:TareaMantenimiento ;
    rdfs:label "Programar un perfil que no se corte a si mismo" ;
    ns1:solucionaFallo ns1:PerfilProgramadoSeCortaASiMismo_aa6461203b ;
    ns1:textoExtracto "SOLUCIÓN Programar un perfil que no se corte a si mismo." .

ns1:ProgramarUnPerfilQueNoSeaCerrado a ns1:TareaMantenimiento ;
    rdfs:label "Programar un perfil que no sea cerrado" ;
    ns1:solucionaFallo ns1:PerfilProgramadoEsCerrado_fd8c1616e3 ;
    ns1:textoExtracto "SOLUCIÓN Programar un perfil que no sea cerrado." .

ns1:NoSeHaProgramadoPerfil a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado perfil" ;
    ns1:textoExtracto "Falta programar el perfil que define la geometría del ciclo fijo." .

ns1:PerfilProgramadoEsCerrado_fd8c1616e3 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil programado es cerrado" ;
    ns1:textoExtracto "El perfil definido en el ciclo fijo no es válido porque es un perfil cerrado." .

ns1:PerfilProgramadoSeCortaASiMismo_aa6461203b a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil programado se corta a si mismo" ;
    ns1:textoExtracto "El perfil definido en el ciclo fijo no es válido porque se corta a si mismo." .

