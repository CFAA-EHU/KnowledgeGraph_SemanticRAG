@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarLaGeometriaODefinirEnElCicloQueLaGeometriaEsExterior a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la geometría o definir en el ciclo que la geometría es exterior" ;
    ns1:solucionaFallo ns1:GeometriaProgramadaNoInterior ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es exterior." .

ns1:CambiarLaGeometriaODefinirEnElCicloQueLaGeometriaEsInterior a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la geometría o definir en el ciclo que la geometría es interior" ;
    ns1:solucionaFallo ns1:GeometriaProgramadaNoExterior ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es interior." .

ns1:CorregirLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación" ;
    ns1:solucionaFallo ns1:GeometriaNoValida,
        ns1:VerticeMalProgramado ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación." .

ns1:CuchillaNoValidaParaPerfilProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Cuchilla no valida para perfil programado" ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo." .

ns1:DefinirElPerfilQueDefineLaGeometriaDelCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Definir el perfil que define la geometría del ciclo" ;
    ns1:solucionaFallo ns1:NoSeHaProgramadoPerfil_e4cd79b7e5 ;
    ns1:textoExtracto "SOLUCIÓN Definir el perfil que define la geometría del ciclo." .

ns1:EnElCicloFijoDebeEstarDefinidaLaOperacionDeDesbasteOAcabado a ns1:TareaMantenimiento ;
    rdfs:label "En el ciclo fijo debe estar definida la operación de desbaste o acabado" ;
    ns1:solucionaFallo ns1:NoProgramadoDesbasteNiAcabado ;
    ns1:textoExtracto "SOLUCIÓN En el ciclo fijo debe estar definida la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:PongaseEnContactoConFAGOR_0c45beda3f a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con FAGOR" ;
    ns1:solucionaFallo ns1:MemoriaInsuficiente ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con FAGOR." .

ns1:GeometriaNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría no valida" ;
    ns1:textoExtracto "'Geometría no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta." .

ns1:GeometriaProgramadaNoExterior a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría programada no exterior" ;
    ns1:textoExtracto "'Geometría programada no exterior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría exterior, tal y como se indica en el ciclo." .

ns1:GeometriaProgramadaNoInterior a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría programada no interior" ;
    ns1:textoExtracto "'Geometría programada no interior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría interior, tal y como se indica en el ciclo." .

ns1:MemoriaInsuficiente a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente" ;
    ns1:textoExtracto "'Memoria insuficiente' DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no dispone de memoria para seguir resolviendo la cajera." .

ns1:NoProgramadoDesbasteNiAcabado a ns1:DiagnosticoFallo ;
    rdfs:label "No programado desbaste ni acabado" ;
    ns1:textoExtracto "'No programado desbaste ni acabado' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definida ninguna operación en el ciclo fijo." .

ns1:NoSeHaProgramadoPerfil_e4cd79b7e5 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado perfil" ;
    ns1:textoExtracto "'No se ha programado perfil' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el perfil que define la geometría del ciclo fijo." .

ns1:VerticeMalProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Vértice mal programado" ;
    ns1:textoExtracto "'Vértice mal programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta." .

