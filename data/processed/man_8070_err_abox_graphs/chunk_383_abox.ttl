@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación" ;
    ns1:solucionaFallo ns1:VerticeMalProgramado ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación." .

ns1:PasoDeRanuradoMayorQueLaAnchuraDeLaCuchilla a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de ranurado mayor que la anchura de la cuchilla" ;
    ns1:textoExtracto "'Paso de ranurado mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de ranurado es mayor" .

ns1:SeleccionarOtraHerramienta_7a3a3e43e9 a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:CuchillaNoValidaParaPerfilProgramado ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar otra herramienta." .

ns1:CuchillaNoValidaParaPerfilProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Cuchilla no valida para perfil programado" ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta no es válida para la geometría del ciclo programado." .

ns1:VerticeMalProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Vértice mal programado" ;
    ns1:textoExtracto "'Vértice mal programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta." .

