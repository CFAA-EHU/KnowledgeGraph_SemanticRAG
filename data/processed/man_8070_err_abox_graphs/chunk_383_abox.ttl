    ex:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es ;
    ex:identificador "G122_K" ;
    ex:valor         "1-5" .

ex:Parametro_G123_K
    a               ex:Parametro ;
    rdfs:label      "Parámetro K en función G123 (número de zona)"@es ;
    ex:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es ;
