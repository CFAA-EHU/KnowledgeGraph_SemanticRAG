    a               ex:Parametro ;
    rdfs:label      "Parámetro K en función G121 (número de zona)"@es ;
    ex:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es ;
    ex:identificador "G121_K" ;
    ex:valor         "1-5" .

