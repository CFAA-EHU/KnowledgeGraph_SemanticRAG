ex:Parametro_G122_I
    a               ex:Parametro ;
    rdfs:label      "Parámetro I en función G122 (vigilancia de herramienta)"@es ;
    ex:textoExtracto "Programar un valor correcto en el parámetro \"I\" de la función G122. [...] Programar un valor correcto para la vigilancia de herramienta; de 0 a 2."@es ;
    ex:identificador "G122_I" ;
    ex:valor         "0-2" .

ex:Variable_PLC_G_ZONETOOLWATCH
    a               ex:Parametro ;
    rdfs:label      "Variable PLC G.ZONETOOLWATCH[zone]"@es ;
    ex:textoExtracto "Escribir desde el PLC el valor correcto en la variable \"G.ZONETOOLWATCH[zone]\". Programar un valor correcto para la vigilancia de herramienta; de 0 a 2."@es ;
    ex:identificador "G.ZONETOOLWATCH" ;
    ex:valor         "0-2" .