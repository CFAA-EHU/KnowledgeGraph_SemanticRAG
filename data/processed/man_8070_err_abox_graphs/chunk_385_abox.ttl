@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaCuchillaIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Accion Prohibida Cuchilla Incorrecta" ;
    ns1:solucionaFallo ns1:TareaMantenimientoComprobarHerramienta ;
    ns1:textoExtracto "La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada." .

ns1:AccionProhibidaLongAxis a ns1:AccionProhibida ;
    rdfs:label "Accion Prohibida Long Axis" ;
    ns1:textoExtracto "'No se ha definido ningún eje como LONGAXIS en ciclo de eje C'" .

ns1:Parametro_6f2c8f9ffb a ns1:Parametro ;
    rdfs:label "Parámetro Máquina LONGAXIS" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal." .

ns1:TareaMantenimientoComprobarHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Tarea Mantenimiento Comprobar Herramienta" ;
    ns1:textoExtracto "Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada." .

