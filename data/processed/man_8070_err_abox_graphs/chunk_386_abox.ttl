@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeEjesTipoTriedro_ed7854cff5 a ns1:Parametro ;
    rdfs:label "Configuración de ejes tipo triedro" ;
    ns1:identificador "GEOCONFIG" ;
    ns1:textoExtracto "'Definir una configuración de ejes tipo triedro en el canal (parámetro GEOCONFIG) con un eje Y.'" .

ns1:CotaZDeLaSuperficieDeLaPieza a ns1:Parametro ;
    rdfs:label "Cota Z de la superficie de la pieza" ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "'Falta programar la cota de la superficie de la pieza (parámetro Z).'" .

ns1:CotaZDeSeguridad a ns1:Parametro ;
    rdfs:label "Cota Z de seguridad" ;
    ns1:identificador "Zs" ;
    ns1:textoExtracto "'Falta programar el plano de seguridad (parámetro Zs).'" .

ns1:EjeC_492e68a811 a ns1:Parametro ;
    rdfs:label "Eje C" ;
    ns1:identificador "CAXIS" ;
    ns1:textoExtracto "'Definir algún eje o cabezal del canal como eje C (parámetro CAXIS).'" .

ns1:EjeFrontal_636c6d5818 a ns1:Parametro ;
    rdfs:label "Eje frontal" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "'Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal.'" .

ns1:EjeLongitudinal_af6cf7d0c2 a ns1:Parametro ;
    rdfs:label "Eje longitudinal" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "'Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal.'" .

ns1:LaCuchillaNoPuedeMecanizarElPerfilCompletamente a ns1:DiagnosticoFallo ;
    rdfs:label "La cuchilla no puede mecanizar el perfil completamente" ;
    ns1:textoExtracto "'La cuchilla no puede mecanizar el perfil completamente'" .

ns1:NoHayDefinidoNingunEjeOCabezalParaEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "No hay definido ningún eje o cabezal para eje C" ;
    ns1:textoExtracto "'No hay definido ningún eje o cabezal para eje C'" .

ns1:NoHayDefinidoNingunEjeParaEjeY a ns1:DiagnosticoFallo ;
    rdfs:label "No hay definido ningún eje para eje Y" ;
    ns1:textoExtracto "'No hay definido ningún eje para eje Y'" .

ns1:NoProgramadaLaCotaZDeLaSuperficieDeLaPieza a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de la superficie de la pieza" ;
    ns1:textoExtracto "'No programada la cota Z de la superficie de la pieza'" .

ns1:NoProgramadaLaCotaZDeSeguridad a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de seguridad" ;
    ns1:textoExtracto "'No programada la cota Z de seguridad'" .

ns1:NoSeHaDefinidoNingunEjeComoFACEAXISEnCicloDeEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido ningún eje como FACEAXIS en ciclo de eje C" ;
    ns1:textoExtracto "'No se ha definido ningún eje como FACEAXIS en ciclo de eje C'" .

