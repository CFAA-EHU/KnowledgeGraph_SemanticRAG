@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación" ;
    ns1:solucionaFallo ns1:NoProgramadaLaCotaZDeSeguridad,
        ns1:NoProgramadaLaProfundidadDeLaPieza ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación." .

ns1:CotaDeLaSuperficieDeLaPieza a ns1:Parametro ;
    rdfs:label "cota de la superficie de la pieza" ;
    ns1:textoExtracto "(parámetro Z)" .

ns1:PlanoDeSeguridad_c97e9aa66d a ns1:Parametro ;
    rdfs:label "plano de seguridad" ;
    ns1:textoExtracto "(parámetro Zs)" .

ns1:ProfundidadDeLaPieza a ns1:Parametro ;
    rdfs:label "profundidad de la pieza" ;
    ns1:textoExtracto "(parámetro P)" .

ns1:NoProgramadaLaCotaZDeSeguridad a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de seguridad" ;
    ns1:textoExtracto "'No programada la cota Z de seguridad'" .

ns1:NoProgramadaLaProfundidadDeLaPieza a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la profundidad de la pieza" ;
    ns1:textoExtracto "'No programada la profundidad de la pieza'" .

