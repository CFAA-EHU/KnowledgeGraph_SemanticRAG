@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2400
    a               ex:Alarma ;
    rdfs:label      "Número lógico de eje fuera de rango"@es ;
    ex:identificador "2400" ;
    ex:textoExtracto "2400 Número lógico de eje fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número lógico programado en la variable no es correcto. SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)."@es .

ex:Alarma_2401
    a               ex:Alarma ;
    rdfs:label      "'#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa'"@es ;
    ex:identificador "2401" ;
    ex:textoExtracto "2401 '#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa."@es .

ex:Parametro_NAXIS
    a               ex:Parametro ;
    rdfs:label      "Número máximo de ejes (parámetro NAXIS)"@es ;
    ex:identificador "NAXIS" ;
    ex:textoExtracto "de 1 hasta el número máximo de ejes (parámetro NAXIS)"@es .