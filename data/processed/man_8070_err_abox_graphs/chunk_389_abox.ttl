@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:ilustradoEn ns1:CorreccionDelValorDelRadioEnLaTablaDeHerramientas ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:CorreccionDelValorDelRadioEnLaTablaDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del valor del radio en la tabla de herramientas" ;
    ns1:solucionaFallo ns1:RadioDeHerramientaDeAcabadoDemasiadoGrande_363edcae4f,
        ns1:RadioDeHerramientaDeSemiacabadoDemasiadoGrande_81727391db ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:RadioDeHerramientaDeAcabadoDemasiadoGrande_363edcae4f a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado demasiado grande" ;
    ns1:textoExtracto "'Radio de herramienta de acabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado es demasiado grande para la geometría de la cajera." .

ns1:RadioDeHerramientaDeSemiacabadoDemasiadoGrande_81727391db a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado demasiado grande" ;
    ns1:textoExtracto "'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado es demasiado grande para la geometría de la cajera." .

