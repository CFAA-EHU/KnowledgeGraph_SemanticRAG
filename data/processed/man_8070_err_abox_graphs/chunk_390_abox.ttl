@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnguloDeProfundizacionEnElDesbasteNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Angulo de profundización en el desbaste no valido" ;
    ns1:textoExtracto "'Angulo de profundización en el desbaste no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste no está comprendido entre 0º y 90º." .

ns1:AnguloDeProfundizacionEnElSemiacabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Angulo de profundización en el semiacabado no valido" ;
    ns1:textoExtracto "'Angulo de profundización en el semiacabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el semiacabado no está comprendido entre 0º y 90º." .

ns1:ProgramadoPasoDeAcabadoMayorQueElDiametroDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Programado paso de acabado mayor que el diámetro de la herramienta" ;
    ns1:textoExtracto "'Programado paso de acabado mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta." .

ns1:ProgramadoPasoDeDesbasteMayorQueElDiametroDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Programado paso de desbaste mayor que el diámetro de la herramienta" ;
    ns1:textoExtracto "'Programado paso de desbaste mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el desbaste es mayor que el diámetro de la herramienta." .

ns1:RadioDeHerramientaDeSemiacabadoDemasiadoGrande_81727391db a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado demasiado grande" ;
    ns1:textoExtracto "'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado es demasiado grande para la geometría de la cajera." .

ns1:RadioDeLaPuntaDeLaHerramientaDeAcabadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de la punta de la herramienta de acabado no valido" ;
    ns1:textoExtracto "'Radio de la punta de la herramienta de acabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R)." .

ns1:TipoDeAcabadoNoValido_2aa371a5f4 a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de acabado no válido" ;
    ns1:textoExtracto "'Tipo de acabado no válido' DETECCIÓN Durante la ejecución del ciclo." .

