@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros" ;
    ns1:solucionaFallo ns1:ElTipoDeAcabadoNoEsValido ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:CorregirElPasoDeMecanizadoOSeleccionarOtraHerramienta_2fcf9ab54d a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el paso de mecanizado o seleccionar otra herramienta" ;
    ns1:solucionaFallo ns1:ElPasoDeMecanizadoParaElAcabadoEsMayorQueElDiametroDeLaHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Corrigir el paso de mecanizado o seleccionar otra herramienta." .

ns1:LaCotaZDeComienzoDelCicloSeEncuentraDentro a ns1:DiagnosticoFallo ;
    rdfs:label "La cota Z de comienzo del ciclo se encuentra dentro" ;
    ns1:identificador "1967 'Cota Z del plano de partida no valida'" ;
    ns1:textoExtracto "CAUSA La cota Z de comienzo del ciclo se encuentra dentro" .

ns1:ElPasoDeMecanizadoParaElAcabadoEsMayorQueElDiametroDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta" ;
    ns1:textoExtracto "CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta." .

ns1:ElTipoDeAcabadoNoEsValido a ns1:DiagnosticoFallo ;
    rdfs:label "El tipo de acabado no es válido" ;
    ns1:identificador "1966 'Tipo de acabado no válido'" ;
    ns1:textoExtracto "CAUSA El tipo de acabado no es válido." .

