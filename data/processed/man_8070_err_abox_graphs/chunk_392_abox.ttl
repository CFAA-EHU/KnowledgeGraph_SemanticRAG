@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorCorrectoALosParametros a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor correcto a los parámetros" ;
    ns1:solucionaFallo ns1:CotaZDeSeguridadNoValida,
        ns1:CotaZDelPlanoDePartidaNoValida_1e5155890e ;
    ns1:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:ComprobarQueLosPerfilesDeProfundidadSonCorrectos_fe7fccdcf3 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de profundidad son correctos" ;
    ns1:solucionaFallo ns1:PerfilEnZNoValido ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ns1:ComprobarQueTodosLosPerfilesDeSuperficieSeanCerrados a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que todos los perfiles de superficie sean cerrados" ;
    ns1:solucionaFallo ns1:ProgramadoPerfilEnXYAbierto ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ns1:EditarElPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Editar el perfil" ;
    ns1:solucionaFallo ns1:NoExisteElPerfilEnXYProgramado,
        ns1:NoExisteElPerfilEnZProgramado ;
    ns1:textoExtracto "SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:InterseccionDePerfilesNoValida_e0e4a05662 a ns1:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no valida" ;
    ns1:textoExtracto "'Intersección de perfiles no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ns1:PerfilEnXYNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en XY no valido" ;
    ns1:textoExtracto "'Perfil en XY no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de superficie no existe." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:CotaZDeSeguridadNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Cota Z de seguridad no valida" ;
    ns1:textoExtracto "'Cota Z de seguridad no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El plano de seguridad se encuentra dentro de la pieza." .

ns1:CotaZDelPlanoDePartidaNoValida_1e5155890e a ns1:DiagnosticoFallo ;
    rdfs:label "Cota Z del plano de partida no valida" ;
    ns1:textoExtracto "'Cota Z del plano de partida no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La cota Z de comienzo del ciclo se encuentra dentro de la pieza." .

ns1:NoExisteElPerfilEnXYProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "No existe el perfil en XY programado" ;
    ns1:textoExtracto "'No existe el perfil en XY programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de superficie no existe." .

ns1:NoExisteElPerfilEnZProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "No existe el perfil en Z programado" ;
    ns1:textoExtracto "'No existe el perfil en Z programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil de profundidad no existe." .

ns1:PerfilEnZNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en Z no valido" ;
    ns1:textoExtracto "'Perfil en Z no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada." .

ns1:ProgramadoPerfilEnXYAbierto a ns1:DiagnosticoFallo ;
    rdfs:label "Programado perfil en XY abierto" ;
    ns1:textoExtracto "'Programado perfil en XY abierto' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo." .

