@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CausaInterseccionSuperficie a ns1:DiagnosticoFallo ;
    rdfs:label "Dos perfiles de superficie generan alguna intersección no válida" ;
    ns1:textoExtracto "CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ns1:ComprobarQueLosPerfilesDeProfundidadSonCorrectos_fe7fccdcf3 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de profundidad son correctos" ;
    ns1:solucionaFallo ns1:InterseccionDePerfilesNoValida ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ns1:ComprobarQueLosPerfilesDeSuperficieNoTienenTramosEnComunLaInterseccio_96dce57c88 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos" ;
    ns1:solucionaFallo ns1:InterseccionDePerfilesNoValida ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos." .

ns1:DeteccionDuranteEjecucion a ns1:AvisoSeguridad ;
    rdfs:label "Durante la ejecución del ciclo" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo." .

ns1:NoSeHaProducidoPalpacion a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha producido palpación" ;
    ns1:textoExtracto "'No se ha producido palpación'" .

ns1:InterseccionDePerfilesNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no válida" ;
    ns1:textoExtracto "'Intersección de perfiles no valida'" .

