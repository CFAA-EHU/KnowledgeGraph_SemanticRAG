@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2417
    a ex:Alarma ;
    rdfs:label "Alarma 2417: #PWRCTRL ON - FZMIN > FZMAX" ;
    ex:textoExtracto "2417 #PWRCTRL ON: FMIN debe ser menor que FMAX. [...] En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo." ;
    ex:identificador "2417" .

ex:Alarma_2418
    a ex:Alarma ;
    rdfs:label "Alarma 2418: #PWRCTRL ON - OVRMIN > OVRMAX" ;
    ex:textoExtracto "2418 #PWRCTRL ON: OVRMIN debe ser menor que OVRMAX. [...] En la función #PWRCTRL, el override mínimo es mayor que el override máximo." ;
    ex:identificador "2418" .

ex:Parametro_FZMIN
    a ex:Parametro ;
    rdfs:label "Avance mínimo (FZMIN)" ;
    ex:textoExtracto "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ex:Parametro_FZMAX
    a ex:Parametro ;
    rdfs:label "Avance máximo (FZMAX)" ;
    ex:textoExtracto "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ex:Parametro_OVRMIN
    a ex:Parametro ;
    rdfs:label "Override mínimo (OVRMIN)" ;
    ex:textoExtracto "El override mínimo (OVRMIN) debe ser menor que el override máximo (OVRMAX)." .

ex:Parametro_OVRMAX
    a ex:Parametro ;
    rdfs:label "Override máximo (OVRMAX)" ;
    ex:textoExtracto "El override mínimo (OVRMIN) debe ser menor que el override máximo (OVRMAX)." .

ex:Alarma_2417
    ex:monitoreaParametro ex:Parametro_FZMIN ;
    ex:monitoreaParametro ex:Parametro_FZMAX .

ex:Alarma_2418
    ex:monitoreaParametro ex:Parametro_OVRMIN ;
    ex:monitoreaParametro ex:Parametro_OVRMAX .