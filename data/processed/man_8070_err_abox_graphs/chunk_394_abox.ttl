@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoProgramadoDESBASTENiACABADO a ns1:AccionProhibida ;
    rdfs:label "No programado DESBASTE ni ACABADO" ;
    ns1:solucionaFallo ns1:CausaSinOperacionDefinida ;
    ns1:textoExtracto "'No programado DESBASTE ni ACABADO' DETECCIÓN Durante la ejecución del ciclo." .

ns1:NoSeHaProducidoPalpacion_d288281d38 a ns1:AccionProhibida ;
    rdfs:label "No se ha producido palpación" ;
    ns1:solucionaFallo ns1:CausaNoSeHaTocadoPieza ;
    ns1:textoExtracto "'No se ha producido palpación' DETECCIÓN Durante la ejecución de un ciclo de palpador." .

ns1:RadioDeHerramientaDeTaladradoDemasiadoGrande a ns1:AccionProhibida ;
    rdfs:label "Radio de herramienta de taladrado demasiado grande" ;
    ns1:solucionaFallo ns1:CausaRadioHerramientaGrande ;
    ns1:textoExtracto "'Radio de herramienta de taladrado demasiado grande' DETECCIÓN Durante la ejecución." .

ns1:SolucionCorregirDefinicionCiclo a ns1:AccionProhibida ;
    rdfs:label "Corregir la definición del ciclo fijo" ;
    ns1:textoExtracto "SOLUCIÓN Corregir la definición del ciclo fijo." .

ns1:SolucionDefinirOperacionDesbasteAcabado a ns1:AccionProhibida ;
    rdfs:label "En el ciclo fijo debe estar definida la operación de desbaste o acabado" ;
    ns1:textoExtracto "SOLUCIÓN En el ciclo fijo debe estar definida la operación de desbaste o acabado." .

ns1:CausaNoSeHaTocadoPieza a ns1:AccionProhibida ;
    rdfs:label "El palpador no ha tocado la pieza durante el movimiento de palpación" ;
    ns1:textoExtracto "CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación." .

ns1:CausaRadioHerramientaGrande a ns1:AccionProhibida ;
    rdfs:label "El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera" ;
    ns1:textoExtracto "CAUSA El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera." .

ns1:CausaSinOperacionDefinida a ns1:AccionProhibida ;
    rdfs:label "No hay definida ninguna operación en el ciclo fijo" ;
    ns1:textoExtracto "CAUSA No hay definida ninguna operación en el ciclo fijo." .

