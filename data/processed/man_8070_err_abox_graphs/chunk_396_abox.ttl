@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarseDeLosParametrosDeCinematica a ns1:TareaMantenimiento ;
    rdfs:label "Asegurarse de los parámetros de cinemática" ;
    ns1:solucionaFallo ns1:NoHaLlegadoSenalDePalpadoCuandoSeEsperabaTocarLaEsfera ;
    ns1:textoExtracto "SOLUCIÓN Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm." .

ns1:ElTipoDePalpadorNoEsValidoP6 a ns1:AccionProhibida ;
    rdfs:label "El tipo de palpador no es valido (P6)" ;
    ns1:textoExtracto "'El tipo de palpador no es valido (P6)'" .

ns1:NoHayContactoConLaEsfera a ns1:AccionProhibida ;
    rdfs:label "No hay contacto con la esfera" ;
    ns1:solucionaFallo ns1:NoHaLlegadoSenalDePalpadoCuandoSeEsperabaTocarLaEsfera ;
    ns1:textoExtracto "'No hay contacto con la esfera'" .

ns1:RevisarProgramacionYPosicionDelPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación y posición del palpador" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente." .

ns1:NoHaLlegadoSenalDePalpadoCuandoSeEsperabaTocarLaEsfera a ns1:DiagnosticoFallo ;
    rdfs:label "No ha llegado señal de palpado cuando se esperaba tocar la esfera" ;
    ns1:textoExtracto "CAUSA No ha llegado señal de palpado cuando se esperaba tocar la esfera." .

