@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2423_FOLLOW_ON_MASTER
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo #FOLLOW ON [MASTER]" ;
    ex:identificador "2423" ;
    ex:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA Cuando un eje se programa para ser esclavo de la variable FLWMASTER, la sincronización solo puede ser sobre las cotas reales; no es posible sincronizar sobre las cotas teóricas. SOLUCIÓN Realizar la sincronización con las cotas reales." ;
    ex:solucionaFallo ex:Accion_SincronizacionCotasReales .

ex:Accion_SincronizacionCotasReales
    a ex:TareaMantenimiento ;
    rdfs:label "Sincronización con cotas reales" ;
    ex:textoExtracto "Realizar la sincronización con las cotas reales." .

ex:Fallo_2423_TipoCuttingPiercingNoDefinido
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo #CUTTING o #PIERCING no definido" ;
    ex:identificador "2423" ;
    ex:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA El tipo de piercing o cutting es nulo. Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T" ;
    ex:solucionaFallo ex:Accion_DefinirParametroT .

ex:Accion_DefinirParametroT
    a ex:TareaMantenimiento ;
    rdfs:label "Definir parámetro T" ;
    ex:textoExtracto "Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T" .

ex:Parametro_T
    a ex:Parametro ;
    rdfs:label "Parámetro T (tipo de cutting/piercing)" ;
    ex:textoExtracto "El tipo de piercing o cutting es nulo. Falta el parámetro T en la sentencia" .