@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegureseDeQueLosParametrosDeCinematicaTienenUnErrorMaximoDe1Mm a ns1:TareaMantenimiento ;
    rdfs:label "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm" ;
    ns1:solucionaFallo ns1:NoHaLlegadoSenalDePalpadoCuandoSeEsperabaTocarLaEsfera_d076e986f2 ;
    ns1:textoExtracto "SOLUCIÓN Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm." .

ns1:ElPalpadorDebeEstarEncimaDeLaBolaAUnaDistanciaMaximaDelDobleDeLaDista_f3b6f3dc13 a ns1:TareaMantenimiento ;
    rdfs:label "El palpador debe estar encima de la bola, a una distancia máxima del doble de la distancia de seguridad" ;
    ns1:solucionaFallo ns1:NoHayContactoConLaEsferaAsegureseQueElPalpadorEstaEncimaDeLaBolaAUnaD_01dd26222a ;
    ns1:textoExtracto "SOLUCIÓN El palpador debe estar encima de la bola, a una distancia máxima del doble de la distancia de seguridad." .

ns1:ElParametroP6SoloAdmiteValores0Y1 a ns1:TareaMantenimiento ;
    rdfs:label "El parámetro P6 sólo admite valores 0 y 1" ;
    ns1:solucionaFallo ns1:ElTipoDePalpadorNoEsValidoP6_b7d885f1f4 ;
    ns1:textoExtracto "SOLUCIÓN El parámetro P6 sólo admite valores 0 y 1." .

ns1:LaCalibracionDeEsteTipoDeCinematicaNoEstaImplementada a ns1:TareaMantenimiento ;
    rdfs:label "La calibración de este tipo de cinemática no esta implementada" ;
    ns1:textoExtracto "'No se puede calibrar este tipo de cinemática'" .

ns1:LaPosicionFinalDeLosEjesRotativosDebeSerDiferenteDeLaPosicionInicial a ns1:TareaMantenimiento ;
    rdfs:label "La posición final de los ejes rotativos debe ser diferente de la posición inicial" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloParametrizacion ;
    ns1:textoExtracto "SOLUCIÓN La posición final de los ejes rotativos debe ser diferente de la posición inicial." .

ns1:Parametro_7148aa265c a ns1:Parametro ;
    rdfs:label "Parámetro P6" ;
    ns1:identificador "P6" ;
    ns1:textoExtracto "'El tipo de palpador no es valido (P6)'" .

ns1:Parametro_8b1277228d a ns1:Parametro ;
    rdfs:label "Parámetro posición inicial y final" ;
    ns1:identificador "PosiciónInicialFinal" ;
    ns1:textoExtracto "'Error de parametrización. La posición inicial y final no pueden ser iguales'" .

ns1:Parametro_ab6a20a028 a ns1:Parametro ;
    rdfs:label "Parámetro posición de reposo" ;
    ns1:identificador "PosicionReposo" ;
    ns1:textoExtracto "'La posición de reposo de los ejes rotativos de la cinemática tiene que ser cero'" .

ns1:Parametro_d0aee77333 a ns1:Parametro ;
    rdfs:label "Parámetro V.G.POSROTx" ;
    ns1:identificador "VGPPOSROTx" ;
    ns1:textoExtracto "'La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx.'" .

ns1:PonerACeroLaPosicionDeReposoEnLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Poner a cero la posición de reposo en los parámetros máquina" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloPosicionReposo ;
    ns1:textoExtracto "SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina." .

ns1:PosicionarLosEjesRotativosEnSuPosicionDeReposo a ns1:TareaMantenimiento ;
    rdfs:label "Posicionar los ejes rotativos en su posición de reposo" ;
    ns1:solucionaFallo ns1:LosEjesRotativosDeLaCinematicaTienenQueEstarEnSuPosicionDeReposo ;
    ns1:textoExtracto "SOLUCIÓN Posicionar los ejes rotativos en su posición de reposo." .

ns1:ElTipoDePalpadorNoEsValidoP6_b7d885f1f4 a ns1:DiagnosticoFallo ;
    rdfs:label "El tipo de palpador no es valido (P6)" ;
    ns1:textoExtracto "'El tipo de palpador no es valido (P6)'" .

ns1:LosEjesRotativosDeLaCinematicaTienenQueEstarEnSuPosicionDeReposo a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes rotativos de la cinemática tienen que estar en su posición de reposo" ;
    ns1:textoExtracto "'Los ejes rotativos de la cinemática tienen que estar en su posición de reposo'" .

ns1:NoHaLlegadoSenalDePalpadoCuandoSeEsperabaTocarLaEsfera_d076e986f2 a ns1:DiagnosticoFallo ;
    rdfs:label "No ha llegado señal de palpado cuando se esperaba tocar la esfera" ;
    ns1:textoExtracto "No ha llegado señal de palpado cuando se esperaba tocar la esfera." .

ns1:NoHayContactoConLaEsferaAsegureseQueElPalpadorEstaEncimaDeLaBolaAUnaD_01dd26222a a ns1:DiagnosticoFallo ;
    rdfs:label "No hay contacto con la esfera. Asegúrese que el palpador esta encima de la bola a una distancia máxima del doble de la distancia de seguridad" ;
    ns1:textoExtracto "'No hay contacto con la esfera. Asegúrese que el palpador esta encima de la bola a una distancia máxima del doble de la distancia de seguridad'" .

