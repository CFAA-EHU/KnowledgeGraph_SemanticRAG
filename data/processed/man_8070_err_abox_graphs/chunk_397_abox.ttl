@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2424
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2424: Tabla tecnológica no activa" ;
    ex:identificador       "2424" ;
    ex:textoExtracto       "2424 No hay tabla tecnológica activa (#MATERIAL). DETECCIÓN Durante la preparación de bloques. CAUSA Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa. SOLUCIÓN Activar una tabla tecnológica desde el HMI o programar el comando #MATERIAL." .

ex:Error_2425
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2425: Sintaxis incorrecta en #PLC" ;
    ex:identificador       "2425" ;
    ex:textoExtracto       "2425 #PLC[PLCmark=0/1,PLCmark=0/1,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_2426
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2426: Marca PLC no modificable" ;
    ex:identificador       "2426" ;
    ex:textoExtracto       "2426 #PLC: marca no modificable. DETECCIÓN Durante la edición y ejecución. CAUSA La marca programada en la sentencia #PLC no es modificable. SOLUCIÓN La sentencia #PLC sólo puede activar o desactivar marcas modificables." .

ex:Error_2427
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2427: Sintaxis incorrecta en #DMC ON" ;
    ex:identificador       "2427" ;
    ex:textoExtracto       "2427 #DMC ON[<PWRSP value><,OVRMIN value><,OVRMAX value><,FZMIN value><,FZMAX value>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_2428
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2428: Sintaxis incorrecta en #DMC OFF" ;
    ex:identificador       "2428" ;
    ex:textoExtracto       "2428 #DMC OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_2429
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 2429: Parámetro DMC fuera de rango" ;
    ex:identificador       "2429" ;
    ex:textoExtracto       "2429 Parámetro DMC fuera de rango DETECCIÓN Durante la edición y ejecución. CAUSA Algún comando de la sentencia #DMC tiene un valor no válido." .

ex:Error_PiercingNoDefinido
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error: #PIERCING no definido" ;
    ex:textoExtracto       "o #PIERCING no definido. DETECCIÓN Durante la preparación de bloques. CAUSA El tipo de piercing o cutting es nulo. Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T (tipo). SOLUCIÓN Activar una tabla tecnológica, programar el comando material o programar el comando #PIERCING o #CUTTING que está dando el error con un parámetro T correcto (valor entre 1 y 10)." .

ex:Parametro_T
    a                     ex:Parametro ;
    rdfs:label            "Parámetro T (tipo de piercing/cutting)" ;
    ex:valor               "1-10" ;
    ex:textoExtracto       "Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T (tipo). SOLUCIÓN [...] programar el comando #PIERCING o #CUTTING [...] con un parámetro T correcto (valor entre 1 y 10)." .

ex:TablaTecnologica a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla tecnológica (#MATERIAL)" ;
    ex:textoExtracto       "2424 No hay tabla tecnológica activa (#MATERIAL). [...] SOLUCIÓN Activar una tabla tecnológica desde el HMI o programar el comando #MATERIAL." .

ex:Comando_MATERIAL
    a                     ex:Parametro ;
    rdfs:label            "Comando #MATERIAL" ;
    ex:textoExtracto       "SOLUCIÓN [...] programar el comando #MATERIAL." .

ex:Comando_PIERCING
    a                     ex:Parametro ;
    rdfs:label            "Comando #PIERCING" ;
    ex:textoExtracto       "Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa." .

ex:Comando_CUTTING
    a                     ex:Parametro ;
    rdfs:label            "Comando #CUTTING" ;
    ex:textoExtracto       "Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa." .

ex:Comando_PLC
    a                     ex:Parametro ;
    rdfs:label            "Comando #PLC" ;
    ex:textoExtracto       "2425 #PLC[PLCmark=0/1,PLCmark=0/1,...] [...] La sintaxis de la sentencia no es correcta." .

ex:Comando_DMC_ON
    a                     ex:Parametro ;
    rdfs:label            "Comando #DMC ON" ;
    ex:textoExtracto       "2427 #DMC ON[<PWRSP value><,OVRMIN value><,OVRMAX value><,FZMIN value><,FZMAX value>] [...] La sintaxis de la sentencia no es correcta." .

ex:Comando_DMC_OFF
    a                     ex:Parametro ;
    rdfs:label            "Comando #DMC OFF" ;
    ex:textoExtracto       "2428 #DMC OFF [...] La sintaxis de la sentencia no es correcta." .

ex:InterfazHMI
    a                     ex:InterfazUsuario ;
    rdfs:label            "HMI (Interfaz Humano-Máquina)" ;
    ex:textoExtracto       "SOLUCIÓN Activar una tabla tecnológica desde el HMI o programar el comando #MATERIAL." .