@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PonerACeroLaPosicionDeReposo a ns1:TareaMantenimiento ;
    rdfs:label "Poner a cero la posición de reposo" ;
    ns1:solucionaFallo ns1:VariablesNoCeroDuranteEjecucion ;
    ns1:textoExtracto "SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina." .

ns1:PosicionDeReposoDelEjeF a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje F" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

ns1:PosicionDeReposoDelEjeO a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje O" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

ns1:PosicionDeReposoDelEjeRotativoManual a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo manual" ;
    ns1:textoExtracto "La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx." .

ns1:PosicionDeReposoDelEjeS a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje S" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

ns1:PosicionDeReposoDelEjeT a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje T" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

ns1:VariablesNoCeroDuranteEjecucion a ns1:AccionProhibida ;
    rdfs:label "Variables no cero durante ejecución" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

