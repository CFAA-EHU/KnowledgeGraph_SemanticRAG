@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElegirUnEjeParaLaCalibracion a ns1:TareaMantenimiento ;
    rdfs:label "Elegir un eje para la calibración" ;
    ns1:solucionaFallo ns1:NoSeHaElegidoNingunEjeParaLaCalibracion ;
    ns1:textoExtracto "SOLUCIÓN Elegir un eje." .

ns1:EstablecerElValorDeLasVariablesVGPOSROTFVGPOSROTSVGPOSROTOEnCero a ns1:TareaMantenimiento ;
    rdfs:label "Establecer el valor de las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTO en cero" ;
    ns1:solucionaFallo ns1:LasVariablesVGPOSROTFVGPOSROTSVGPOSROTODeLosEjesRotativosManualesNoSonCero ;
    ns1:textoExtracto "El valor de estas variables debe ser cero." .

ns1:SeleccionarOtroCOMPID a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar otro COMPID" ;
    ns1:solucionaFallo ns1:ElCOMPIDEstaSiendoUtilizadoPorOtroKINID ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar otro COMPID." .

ns1:ElCOMPIDEstaSiendoUtilizadoPorOtroKINID a ns1:DiagnosticoFallo ;
    rdfs:label "El COMPID está siendo utilizado por otro KINID" ;
    ns1:textoExtracto "El COMPID está siendo utilizado por otro KINID." .

ns1:LasVariablesVGPOSROTFVGPOSROTSVGPOSROTODeLosEjesRotativosManualesNoSonCero a ns1:DiagnosticoFallo ;
    rdfs:label "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTO de los ejes rotativos manuales no son cero" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero." .

ns1:NoSeHaElegidoNingunEjeParaLaCalibracion a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha elegido ningún eje para la calibración" ;
    ns1:textoExtracto "No se ha elegido ningún eje para la calibración." .

