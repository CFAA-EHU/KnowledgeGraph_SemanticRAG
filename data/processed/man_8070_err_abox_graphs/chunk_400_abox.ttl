@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2436
    a ex:Alarma ;
    rdfs:label "Alarma 2436: Programación no permitida fuera de una macro G8777" ;
    ex:textoExtracto "2436 Programación no permitida fuera de una macro G8777. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777. SOLUCIÓN Revisar la programación. Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777." ;
    ex:identificador "2436" .

ex:Alarma_2437
    a ex:Alarma ;
    rdfs:label "Alarma 2437: Perfil poligonal en macro G8077" ;
    ex:textoExtracto "2437 El perfil de la macro G8077 es poligonal. DETECCIÓN Durante la ejecución. CAUSA El perfil debe estar construido con tramos rectos. SOLUCIÓN Modificar el perfil." ;
    ex:identificador "2437" .

ex:AccionProhibida_ProgramacionFueraMacroG8777
    a ex:AccionProhibida ;
    rdfs:label "Programar funciones G8778, G8701 o G8702 fuera de macro G8777" ;
    ex:textoExtracto "Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777." ;
    ex:activaAlarma ex:Alarma_2436 .

ex:AccionProhibida_PerfilPoligonalMacroG8077
    a ex:AccionProhibida ;
    rdfs:label "Perfil poligonal en macro G8077" ;
    ex:textoExtracto "El perfil debe estar construido con tramos rectos." ;
    ex:activaAlarma ex:Alarma_2437 .