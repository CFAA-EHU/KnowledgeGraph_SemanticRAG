@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElUltimoBloqueDeCompensacionDeRadioDebeSerLineal_94bbe6875f a ns1:TareaMantenimiento ;
    rdfs:label "El último bloque de compensación de radio debe ser lineal" ;
    ns1:solucionaFallo ns1:ElUltimoBloqueDeCompensacionDeRadioDebeSerLineal_e257835e3a ;
    ns1:textoExtracto "SOLUCIÓN La compensación de radio no puede acabar en un bloque circular." .

ns1:LaCompensacionDeRadioDebeEmpezarEnUnBloqueDeMovimientoLineal a ns1:TareaMantenimiento ;
    rdfs:label "La compensación de radio debe empezar en un bloque de movimiento lineal" ;
    ns1:solucionaFallo ns1:ElPrimerBloqueDeCompensacionDeRadioDebeSerLineal ;
    ns1:textoExtracto "SOLUCIÓN La compensación de radio debe empezar en un bloque de movimiento lineal. Por lo tanto, el bloque de movimiento que vaya a continuación de G41-G42 debe ser un bloque de movimiento lineal." .

ns1:ReducirElNumeroDeBloquesDeNoMovimientoProgramados a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el número de bloques de no movimiento programados" ;
    ns1:solucionaFallo ns1:DemasiadosBloquesSinMovimientoEntreDosBloquesConCompensacionDeRadio ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de bloques de no movimiento programados; por ejemplo, agrupar varios de estos bloques en uno solo." .

ns1:UsarUnaHerramientaDeMenorRadio a ns1:TareaMantenimiento ;
    rdfs:label "Usar una herramienta de menor radio" ;
    ns1:solucionaFallo ns1:PerfilDanadoPorCompensacionDeRadio,
        ns1:RadioDeHerramientaDemasiadoGrandeEnArcosConsecutivos,
        ns1:RadioDeHerramientaMayorQueRadioDelArco ;
    ns1:textoExtracto "SOLUCIÓN Usar una herramienta de menor radio." .

ns1:DemasiadosBloquesSinMovimientoEntreDosBloquesConCompensacionDeRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados bloques sin movimiento entre dos bloques con compensación de radio" ;
    ns1:textoExtracto "'Demasiados bloques sin movimiento entre dos bloques con compensación de radio' DETECCIÓN Durante la ejecución. CAUSA Con la compensación de radio activa, hay demasiados bloques de no movimiento (asignaciones de parámetros P, variables, etc) entre dos bloques de movimiento." .

ns1:ElPrimerBloqueDeCompensacionDeRadioDebeSerLineal a ns1:DiagnosticoFallo ;
    rdfs:label "El primer bloque de compensación de radio debe ser lineal" ;
    ns1:textoExtracto "'El primer bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA Después de activar la compensación de radio (G41 o G42), el siguiente bloque de movimiento es un bloque circular." .

ns1:ElUltimoBloqueDeCompensacionDeRadioDebeSerLineal_e257835e3a a ns1:DiagnosticoFallo ;
    rdfs:label "El último bloque de compensación de radio debe ser lineal" ;
    ns1:textoExtracto "'El último bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA Después de desactivar la compensación de radio (G40), el siguiente bloque de movimiento es un bloque circular." .

ns1:PerfilDanadoPorCompensacionDeRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil dañado por compensación de radio" ;
    ns1:textoExtracto "'Perfil dañado por compensación de radio' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el perfil programado; la herramienta daña el perfil." .

ns1:RadioDeHerramientaDemasiadoGrandeEnArcosConsecutivos a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta demasiado grande en arcos consecutivos" ;
    ns1:textoExtracto "'Radio de herramienta demasiado grande en arcos consecutivos' DETECCIÓN Durante la ejecución. CAUSA En el mecanizado de dos arcos consecutivos que forman un bucle (ambos arco se cortan), el radio de la herramienta es demasiado grande para poder mecanizar el interior del bucle." .

ns1:RadioDeHerramientaMayorQueRadioDelArco a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta mayor que radio del arco" ;
    ns1:textoExtracto "'Radio de herramienta mayor que radio del arco' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es mayor que el radio del arco que se intenta mecanizar." .

