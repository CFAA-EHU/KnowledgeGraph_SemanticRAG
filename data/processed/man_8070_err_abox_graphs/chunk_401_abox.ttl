@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElUltimoBloqueDeCompensacionDeRadioDebeSerLineal a ns1:AccionProhibida ;
    rdfs:label "El último bloque de compensación de radio debe ser lineal" ;
    ns1:solucionaFallo ns1:LaCompensacionDeRadioNoPuedeAcabarEnUnBloqueCircular ;
    ns1:textoExtracto "'El último bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA Después de desactivar la compensación de radio (G40), el siguiente bloque de movimiento es un bloque circular." .

ns1:LaCompensacionDeRadioNoPuedeAcabarEnUnBloqueCircular a ns1:DiagnosticoFallo ;
    rdfs:label "La compensación de radio no puede acabar en un bloque circular" ;
    ns1:textoExtracto "La compensación de radio no puede acabar en un bloque circular. SOLUCIÓN La compensación de radio debe acabar en un" .

