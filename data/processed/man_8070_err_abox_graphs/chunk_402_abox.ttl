@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2442
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Programación no permitida fuera de macro G8754"@es ;
    ex:textoExtracto "Programar una única vez #FINALSUB. 2442 Programación no permitida fuera de una macro G8754. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8753 programada fuera de una macro G8754. SOLUCIÓN Revisar la programación. Las funciones G8753 se deben programar a continuación de la macro G8754."@es ;
    ex:identificador "2442" .

ex:Fallo_2443
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Reinicio necesario tras cambios en fichero de material"@es ;
    ex:textoExtracto "2443 Para asumir cambios en el fichero de material es necesario reiniciar el CNC. DETECCIÓN Durante la ejecución del comando #MATERIAL o al activar/validar una tabla tecnológica. CAUSA Se ha cambiado el"@es ;
    ex:identificador "2443" .

ex:Macro_G8754
    a               ex:Parametro ;
    rdfs:label      "Macro G8754"@es ;
    ex:textoExtracto "macro G8754"@es ;
    ex:identificador "G8754" .

ex:Funcion_G8753 a ex:Tabla ;
     a               ex:Parametro ;
    rdfs:label      "Función G8753"@es ;
    ex:textoExtracto "función G8753"@es ;
    ex:identificador "G8753" .

ex:Comando_MATERIAL
    a               ex:Parametro ;
    rdfs:label      "Comando #MATERIAL"@es ;
    ex:textoExtracto "comando #MATERIAL"@es ;
    ex:identificador "#MATERIAL" .

ex:TablaTecnologica a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla tecnológica"@es ;
    ex:textoExtracto "tabla tecnológica"@es .