@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceptarLaModificacionPropuestaYContinuarConLaEjecucion a ns1:TareaMantenimiento ;
    rdfs:label "Aceptar la modificación propuesta y continuar con la ejecución" ;
    ns1:solucionaFallo ns1:SeHaEliminadoUnBloqueDeTransicionNoRelevante ;
    ns1:textoExtracto "SOLUCIÓN Aceptar la modificación propuesta y continuar con la ejecución." .

ns1:ConLaCompensacionDeRadioActivaNoCambiarElRadioDeLaHerramientaDuranteL_4f8c361452 a ns1:TareaMantenimiento ;
    rdfs:label "Con la compensación de radio activa, no cambiar el radio de la herramienta durante la ejecución de un arco" ;
    ns1:solucionaFallo ns1:DiferenteRadioDeHerramientaEntreLaTrayectoriaAnteriorYUnaCircular_c9bd7ddc02 ;
    ns1:textoExtracto "SOLUCIÓN Con la compensación de radio activa, no cambiar el radio de la herramienta durante la ejecución de un arco." .

ns1:RevisarProgramacionDelArco a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación del arco" ;
    ns1:solucionaFallo ns1:DiferenciaEntreElRadioInicialYFinalDelArcoDemasiadoGrande_b37ba8b923 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación del arco." .

ns1:UsarUnaHerramientaDeMenorRadio_89cdbc60e9 a ns1:TareaMantenimiento ;
    rdfs:label "Usar una herramienta de menor radio" ;
    ns1:solucionaFallo ns1:NoHayInterseccionEntreLineaYArcoRadioDeHerramientaDemasiadoGrande_4c4b1c3d20 ;
    ns1:textoExtracto "SOLUCIÓN Usar una herramienta de menor." .

ns1:UtilizarHerramientaDeMenorRadio a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar herramienta de menor radio" ;
    ns1:solucionaFallo ns1:MovimientoDeCompensacionEnTrayectoriaCircularPerfilDanado_eeae6d04b9,
        ns1:RadioDeHerramientaDemasiadoGrandeAlCalcularCompensacionEntreArcos_711499e2b0 ;
    ns1:textoExtracto "SOLUCIÓN Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande." .

ns1:DiferenciaEntreElRadioInicialYFinalDelArcoDemasiadoGrande_b37ba8b923 a ns1:DiagnosticoFallo ;
    rdfs:label "Diferencia entre el radio inicial y final del arco demasiado grande" ;
    ns1:textoExtracto "'Diferencia entre el radio inicial y final del arco demasiado grande' DETECCIÓN Durante la ejecución. CAUSA En el arco programado, la diferencia entre el radio inicial y el radio final es mayor que la tolerancia permitida." .

ns1:DiferenteRadioDeHerramientaEntreLaTrayectoriaAnteriorYUnaCircular_c9bd7ddc02 a ns1:DiagnosticoFallo ;
    rdfs:label "Diferente radio de herramienta entre la trayectoria anterior y una circular" ;
    ns1:textoExtracto "'Diferente radio de herramienta entre la trayectoria anterior y una circular' DETECCIÓN Durante la ejecución. CAUSA Al mecanizar un arco con la compensación de radio activa, el radio de la herramienta ha cambiado respecto al bloque anterior." .

ns1:MovimientoDeCompensacionEnTrayectoriaCircularPerfilDanado_eeae6d04b9 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de compensación en trayectoria circular (perfil dañado)" ;
    ns1:textoExtracto "'Movimiento de compensación en trayectoria circular (perfil dañado)' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el arco programado." .

ns1:NoHayInterseccionEntreLineaYArcoRadioDeHerramientaDemasiadoGrande_4c4b1c3d20 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay intersección entre línea y arco: radio de herramienta demasiado grande" ;
    ns1:textoExtracto "'No hay intersección entre línea y arco: radio de herramienta demasiado grande' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada." .

ns1:RadioDeHerramientaDemasiadoGrandeAlCalcularCompensacionEntreArcos_711499e2b0 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta demasiado grande al calcular compensación entre arcos" ;
    ns1:textoExtracto "'Radio de herramienta demasiado grande al calcular compensación entre arcos' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el arco programado." .

ns1:SeHaEliminadoUnBloqueDeTransicionNoRelevante a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha eliminado un bloque de transición no relevante" ;
    ns1:textoExtracto "'Se ha eliminado un bloque de transición no relevante' DETECCIÓN Durante la ejecución. CAUSA La compensación de radio ha eliminado un bloque innecesario." .

