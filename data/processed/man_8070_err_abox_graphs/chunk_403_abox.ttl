@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2444 a ex:Alarma ;
    rdfs:label "Alarma 2444: #OPEN/#CLOSE/#WRITE - valor de handle de fichero fuera de rango"@es ;
    ex:textoExtracto "2444 #OPEN/#CLOSE/#WRITE:valor de handle de fichero fuera de rango. [...] SOLUCIÓN: El identificador de fichero (comando F) debe tener un valor entre 1 y 4."@es ;
    ex:identificador "2444" .

ex:Alarma_2445 a ex:Alarma ;
    rdfs:label "Alarma 2445: #OPEN/#CLOSE/#WRITE - doble programación"@es ;
    ex:textoExtracto "2445 #OPEN/#CLOSE/#WRITE:doble programación. [...] SOLUCIÓN: Programar una única vez cada parámetro de la sentencia."@es ;
    ex:identificador "2445" .

ex:Alarma_2446 a ex:Alarma ;
    rdfs:label "Alarma 2446: Prefijo de variable inexistente"@es ;
    ex:textoExtracto "2446 Prefijo de variable inexistente. [...] SOLUCIÓN: Consulte en la documentación la lista de variables permitidas."@es ;
    ex:identificador "2446" .

ex:Alarma_2447 a ex:Alarma ;
    rdfs:label "Alarma 2447: #PARALAX - ejes paralelos deben pertenecer al mismo canal"@es ;
    ex:textoExtracto "2447 #PARALAX: Los ejes paralelos deben pertenecer al mismo canal. [...] SOLUCIÓN: Los ejes programados deben pertenecer al mismo canal."@es ;
    ex:identificador "2447" .

ex:Alarma_2448 a ex:Alarma ;
    rdfs:label "Alarma 2448: Programación no permitida con transformación #PARALAX activa"@es ;
    ex:textoExtracto "2448 Programación no permitida con la transformación #PARALAX activa. [...] SOLUCIÓN: Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones."@es ;
    ex:identificador "2448" .

ex:Alarma_2449 a ex:Alarma ;
    rdfs:label "Alarma 2449: Eje Hirth no compatible con transformación #PARALAX"@es ;
    ex:textoExtracto "2449 No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. [...] SOLUCIÓN: Los ejes programados no pueden ser Hirth."@es ;
    ex:identificador "2449" .

ex:Parametro_HandleFichero a ex:Parametro ;
    rdfs:label "Parámetro: Handle de fichero (comando F)"@es ;
    ex:textoExtracto "El identificador de fichero (comando F) debe tener un valor entre 1 y 4."@es ;
    ex:valor "1-4" .

ex:Parametro_TransformacionPARALAX a ex:Parametro ;
    rdfs:label "Parámetro: Transformación #PARALAX (ejes paralelos)"@es ;
    ex:textoExtracto "Los ejes paralelos deben pertenecer al mismo canal. [...] Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones."@es .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "Para asumir cambios en el fichero de material es necesario reiniciar el CNC. [...] Para que el CNC tenga en cuenta el nuevo formato es necesario reiniciar."@es ;
    ex:activaAlarma ex:Alarma_2444, ex:Alarma_2445, ex:Alarma_2446, ex:Alarma_2447, ex:Alarma_2448, ex:Alarma_2449 ;
    ex:tieneComponente ex:Parametro_HandleFichero, ex:Parametro_TransformacionPARALAX .

ex:Tabla_Tecnologica a ex:Tabla ;
    rdfs:label "Tabla tecnológica (fichero de material)"@es ;
    ex:textoExtracto "Durante la ejecución del comando #MATERIAL o al activar/validar una tabla tecnológica. [...] Se ha cambiado el formato de la tabla (unidades, nuevas variables, rango de tipo enumerado, etc)."@es ;
    ex:documentadoEn ex:Sistema_CNC .