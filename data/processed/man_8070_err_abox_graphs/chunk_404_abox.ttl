@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarSplinesAntesActivarElControlTangencial a ns1:TareaMantenimiento ;
    rdfs:label "desactivar splines antes activar el control tangencial" ;
    ns1:solucionaFallo ns1:ProgramacionDeSplinesYControlTangencialIncompatibles_279b218684 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar los splines antes activar el control tangencial o viceversa." .

ns1:LimiteSoftwarePositivoSobrepasadoEnG5G60OHSC_a5829e7166 a ns1:DiagnosticoFallo ;
    rdfs:label "límite software positivo sobrepasado en G5, G60 o HSC" ;
    ns1:textoExtracto "'Límite software positivo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución." .

ns1:ModificarPerfilProgramado a ns1:TareaMantenimiento ;
    rdfs:label "modificar perfil programado" ;
    ns1:solucionaFallo ns1:PerfilModificadoParaEvitarColision ;
    ns1:textoExtracto "SOLUCIÓN Dependiendo de la colisión detectada su solución puede ser utilizar una herramienta de radio menor, programar el perfil de otra forma o simplemente aceptar la modificación propuesta por el proceso de detección de colisiones." .

ns1:NoActivarDeteccionDeColisiones a ns1:TareaMantenimiento ;
    rdfs:label "no activar detección de colisiones" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConDeteccionDeColisionesActiva ;
    ns1:textoExtracto "SOLUCIÓN No activar la detección de colisiones si hay alguno de estos procesos programado." .

ns1:NoHayInterseccionEntreArcoYLinea a ns1:DiagnosticoFallo ;
    rdfs:label "no hay intersección entre arco y línea" ;
    ns1:textoExtracto "2015 No hay intersección entre arco y línea: radio de herramienta demasiado grande. DETECCIÓN Durante la ejecución." .

ns1:SimplificarModeloDeMaquina a ns1:TareaMantenimiento ;
    rdfs:label "simplificar modelo de máquina" ;
    ns1:solucionaFallo ns1:SobrecargaDeCPUEnElCalculoDeDeteccionDeColisiones ;
    ns1:textoExtracto "SOLUCIÓN Simplificar el modelo de la máquina." .

ns1:UsarUnaHerramientaDeMenorRadio a ns1:TareaMantenimiento ;
    rdfs:label "usar una herramienta de menor radio" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_552c493f87 ;
    ns1:textoExtracto "SOLUCIÓN Usar una herramienta de menor radio." .

ns1:DiagnosticoFallo_552c493f87 a ns1:DiagnosticoFallo ;
    rdfs:label "herramienta demasiado grande" ;
    ns1:textoExtracto "herramienta demasiado grande. DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada." .

ns1:PerfilModificadoParaEvitarColision a ns1:DiagnosticoFallo ;
    rdfs:label "perfil modificado para evitar colisión" ;
    ns1:textoExtracto "'Se ha modificado el perfil para evitar una colisión' DETECCIÓN Durante la ejecución." .

ns1:ProgramacionDeSplinesYControlTangencialIncompatibles_279b218684 a ns1:DiagnosticoFallo ;
    rdfs:label "programación de splines y control tangencial incompatibles" ;
    ns1:textoExtracto "'Programación de splines y control tangencial incompatibles' DETECCIÓN Durante la ejecución." .

ns1:ProgramacionNoPermitidaConDeteccionDeColisionesActiva a ns1:DiagnosticoFallo ;
    rdfs:label "programación no permitida con detección de colisiones activa" ;
    ns1:textoExtracto "'Programación no permitida con detección de colisiones activa' DETECCIÓN Durante la ejecución." .

ns1:SobrecargaDeCPUEnElCalculoDeDeteccionDeColisiones a ns1:DiagnosticoFallo ;
    rdfs:label "sobrecarga de CPU en el cálculo de detección de colisiones" ;
    ns1:textoExtracto "2021 Sobrecarga de CPU en el cálculo de detección de colisiones. DETECCIÓN Durante la preparación de bloques." .

