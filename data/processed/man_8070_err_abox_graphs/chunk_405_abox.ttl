@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2450
    a ex:Alarma ;
    rdfs:label "Alarma 2450: Ejes de transformación activa no excluibles (#PARALAX)"@es ;
    ex:identificador "2450" ;
    ex:textoExtracto "ser Hirth. 2450 #PARALAX: Los ejes de la transformación activa, no pueden excluirse. DETECCIÓN Durante la ejecución. CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una transformación de ejes paralelos. SOLUCIÓN Desactivar la transformación antes de cambiar los ejes del canal."@es .

ex:Alarma_2451
    a ex:Alarma ;
    rdfs:label "Alarma 2451: Transformación de ejes paralelos desactivada (#PARALAX)"@es ;
    ex:identificador "2451" ;
    ex:textoExtracto "2451 Se ha desactivado la transformación de ejes paralelos #PARALAX. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los ejes necesarios para la transformación no son adecuados. • Se ha intentando hacer una búsqueda de cero con la función #PARALAX activa. SOLUCIÓN Las posibles soluciones son las siguientes: • Los ejes de una transformación deben ser lineales, pertenecer al canal, no estar aparcados y no ser esclavos de un acoplo o eje gantry. • Desactivar la transformación antes de hacer una búsqueda de referencia."@es .

ex:Alarma_2452
    a ex:Alarma ;
    rdfs:label "Alarma 2452: Ejes de transformación paralela deben ser lineales (#PARALAX)"@es ;
    ex:identificador "2452" ;
    ex:textoExtracto "2452 Los ejes de la transformación paralela, #PARALAX, deben ser lineales. DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes programados es un eje rotativo. SOLUCIÓN Los ejes programados deben ser lineales."@es .

ex:Alarma_2453
    a ex:Alarma ;
    rdfs:label "Alarma 2453: Falta carácter de cierre '}' en programación de vector"@es ;
    ex:identificador "2453" ;
    ex:textoExtracto "2453 Se espera \"}\", programación de fin de vector. DETECCIÓN Durante la preparación de bloques. CAUSA Falta el carácter de cierre \"}\" en la programa de un vector. SOLUCIÓN Revisar la programación. Programar el vector de la forma V{i, j, k}."@es .

ex:Alarma_2454
    a ex:Alarma ;
    rdfs:label "Alarma 2454: Memoria insuficiente para variables de calibración de cinemáticas"@es ;
    ex:identificador "2454" ;
    ex:textoExtracto "2454 No hay memoria para variables de usuario asociadas a la calibración de cinemáticas. DETECCIÓN Durante la preparación de bloques. CAUSA Las variables de usuario asociadas a la calibración de cinemáticas sólo existen si está activa la opción de software \"Calibración de cinemáticas\". SOLUCIÓN Contratar la correspondiente opción de software."@es .

ex:Alarma_2455
    a ex:Alarma ;
    rdfs:label "Alarma 2455: Error en gestión del árbol de variables"@es ;
    ex:identificador "2455" ;
    ex:textoExtracto "2455 Error en la gestión del árbol de variables. DETECCIÓN Durante la preparación de bloques. CAUSA Error al crear una nueva variable de usuario. SOLUCIÓN Contacte con Fagor Automation."@es .

ex:Sistema_TransformacionEjesParalelos
    a ex:Sistema ;
    rdfs:label "Sistema de transformación de ejes paralelos (#PARALAX)"@es ;
    ex:identificador "#PARALAX" ;
    ex:textoExtracto "transformación de ejes paralelos #PARALAX"@es ;
    ex:activaAlarma ex:Alarma_2450, ex:Alarma_2451, ex:Alarma_2452 .

ex:Funcion_SETAX a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función #SETAX (cambio de ejes)"@es ;
    ex:identificador "#SETAX" ;
    ex:textoExtracto "Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una transformación de ejes paralelos"@es .

ex:Funcion_FREEAX a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función #FREEAX (liberación de ejes)"@es ;
    ex:identificador "#FREEAX" ;
    ex:textoExtracto "Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una transformación de ejes paralelos"@es .

ex:OpcionSoftware_CalibracionCinematicas
    a ex:Parametro ;
    rdfs:label "Opción de software: Calibración de cinemáticas"@es ;
    ex:textoExtracto "Las variables de usuario asociadas a la calibración de cinemáticas sólo existen si está activa la opción de software \"Calibración de cinemáticas\""@es .