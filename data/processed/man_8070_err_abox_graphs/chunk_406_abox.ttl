@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error2455
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2455: Error en la gestión del árbol de variables"@es ;
    ex:identificador "2455" ;
    ex:textoExtracto "2455 Error en la gestión del árbol de variables. DETECCIÓN Durante la preparación de bloques. CAUSA Error al crear una nueva variable de usuario."@es .

ex:Error2456
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2456: Restricción con #GAPPOS activo"@es ;
    ex:identificador "2456" ;
    ex:textoExtracto "2456 Con #GAPPOS activo no se permite cambiar los tres primeros ejes. DETECCIÓN Durante la preparación de bloques."@es .

ex:Solucion2455
    a ex:AccionProhibida ;
    rdfs:label "Solución para Error 2455: Contactar con Fagor Automation"@es ;
    ex:textoExtracto "SOLUCIÓN Contacte con Fagor Automation."@es ;
    ex:solucionaFallo ex:Error2455 .

ex:Solucion2456
    a ex:AccionProhibida ;
    rdfs:label "Solución para Error 2456: Contratar opción de software"@es ;
    ex:textoExtracto "SOLUCIÓN Contratar la correspondiente opción de software."@es ;
    ex:solucionaFallo ex:Error2456 .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Contacte con Fagor Automation."@es .