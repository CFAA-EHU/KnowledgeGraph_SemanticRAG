@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorInternoEnModoHSC a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno en modo HSC" ;
    ns1:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución. CAUSA Error en el" .

ns1:ProgramarPuntoDeSalidaDiferenteAlPuntoFinalDelHSC a ns1:TareaMantenimiento ;
    rdfs:label "Programar punto de salida diferente al punto final del HSC" ;
    ns1:solucionaFallo ns1:TangenteFinalIndeterminadaEnHSC ;
    ns1:textoExtracto "SOLUCIÓN Programar un punto de salida diferente al punto final del #HSC y ambos ejes de la tangente." .

ns1:TangenteFinalIndeterminadaEnHSC a ns1:DiagnosticoFallo ;
    rdfs:label "Tangente final indeterminada en HSC" ;
    ns1:textoExtracto "2105 #HSC: tangente final indeterminada. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El punto para finalizar el #HSC coincide con el punto anterior y la tangente queda indeterminada. • Se ha programado sólo un eje de la tangente." .

