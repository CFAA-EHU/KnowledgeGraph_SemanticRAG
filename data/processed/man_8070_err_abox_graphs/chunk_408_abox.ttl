@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_dd4f8bc992 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ErrorDeContornoDemasiadoPequeno ;
    ns1:textoExtracto "CNC 8070" .

ns1:CambioDeModoNoPermitido a ns1:AccionProhibida ;
    rdfs:label "Cambio de modo no permitido" ;
    ns1:textoExtracto "'HSC: Cambio de modo no permitido' DETECCIÓN Durante la ejecución. CAUSA No se puede cambiar el modo HSC sin desactivar el modo anterior." .

ns1:DesactivarElModoHSC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el modo HSC" ;
    ns1:solucionaFallo ns1:ErrorInternoEnModoHSC,
        ns1:LimiteSoftwareNegativoSobrepasadoEnModoHSC,
        ns1:LimiteSoftwarePositivoSobrepasadoEnModoHSC ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ns1:ProgramarUnPuntoDeSalidaDiferenteAlPuntoFinalDelHSC a ns1:TareaMantenimiento ;
    rdfs:label "Programar un punto de salida diferente al punto final del #HSC" ;
    ns1:textoExtracto "SOLUCIÓN Programar un punto de salida diferente al punto final del #HSC y ambos ejes de la tangente." .

ns1:ProgramarUnPuntoPrevioAlPuntoDeEntradaAlSpline a ns1:TareaMantenimiento ;
    rdfs:label "Programar un punto previo al punto de entrada al spline" ;
    ns1:textoExtracto "SOLUCIÓN Programar un punto previo al punto de entrada al spline o ambos ejes de la tangente." .

ns1:TangenteFinalIndeterminada_470f94ad8a a ns1:DiagnosticoFallo ;
    rdfs:label "Tangente final indeterminada" ;
    ns1:textoExtracto "SPLINE:Tangente final indeterminada. DETECCIÓN Durante la ejecución." .

ns1:TangenteInicialIndeterminada_131208d6b9 a ns1:DiagnosticoFallo ;
    rdfs:label "Tangente inicial indeterminada" ;
    ns1:textoExtracto "SPLINE:Tangente inicial indeterminada. DETECCIÓN Durante la ejecución. CAUSA El punto inicial del spline coincide con el punto anterior y queda la tangente indeterminada o bien se ha programado sólo un eje de la tangente." .

ns1:ErrorDeContornoDemasiadoPequeno a ns1:AccionProhibida ;
    rdfs:label "Error de contorno demasiado pequeño" ;
    ns1:textoExtracto "'HSC: Error de contorno demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado." .

ns1:ErrorInternoEnModoHSC a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno en modo HSC" ;
    ns1:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución. CAUSA Error en el cálculo de la trayectoria para trabajar en modo HSC." .

ns1:LimiteSoftwareNegativoSobrepasadoEnModoHSC a ns1:AccionProhibida ;
    rdfs:label "Límite software negativo sobrepasado en modo HSC" ;
    ns1:textoExtracto "'Límite software negativo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos." .

ns1:LimiteSoftwarePositivoSobrepasadoEnModoHSC a ns1:AccionProhibida ;
    rdfs:label "Límite software positivo sobrepasado en modo HSC" ;
    ns1:textoExtracto "'Límite software positivo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos." .

