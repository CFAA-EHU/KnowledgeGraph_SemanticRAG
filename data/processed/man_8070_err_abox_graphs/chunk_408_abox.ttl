@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_2462 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2462: Eje no pertenece al plano o triedro"@es ;
    ex:textoExtracto "El eje programado debe pertenecer al plano o triedro. [...] CAUSA El eje no pertenece al plano principal o triedro. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2462" .

ex:Fallo_2463 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2463: #LEAP incompatible con GAP3D"@es ;
    ex:textoExtracto "#LEAP incompatible con GAP3D. [...] CAUSA El comando #LEAP no es compatible con el control de gap en varios ejes. SOLUCIÓN No programar #LEAP o realizar el control de gap sobre una superficie."@es ;
    ex:identificador "2463" .

ex:Fallo_2464 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 2464: Movimiento no permitido en selección de piercing con G92"@es ;
    ex:textoExtracto "Movimiento no permitido en selección de piercing con G92. Programar #MOVE. [...] CAUSA En la selección de piercing, se ha elegido la opción de repetir el programa en"@es ;
    ex:identificador "2464" .