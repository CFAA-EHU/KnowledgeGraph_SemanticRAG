@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionNo a ns1:AccionProhibida ;
    rdfs:label "Activación no" ;
    ns1:textoExtracto "2114 SPLINE:Activación no" .

ns1:ElPuntoFinalDelSplineCoincideConElPuntoAnteriorYQuedaLaTangenteIndeterminada a ns1:AccionProhibida ;
    rdfs:label "El punto final del spline coincide con el punto anterior y queda la tangente indeterminada" ;
    ns1:textoExtracto "El punto final del spline coincide con el punto anterior y queda la tangente indeterminada." .

ns1:ProgramarUnPuntoDeSalidaPosteriorAlPuntoFinalDelSplineOAmbosEjesDeLaTangente a ns1:TareaMantenimiento ;
    rdfs:label "Programar un punto de salida posterior al punto final del spline o ambos ejes de la tangente" ;
    ns1:solucionaFallo ns1:SPLINETangenteFinalIndeterminada_78ac181053 ;
    ns1:textoExtracto "SOLUCIÓN Programar un punto de salida posterior al punto final del spline o ambos ejes de la tangente." .

ns1:ProgramarUnPuntoPrevioAlPuntoDeEntradaAlSplineOAmbosEjesDeLaTangente a ns1:TareaMantenimiento ;
    rdfs:label "Programar un punto previo al punto de entrada al spline o ambos ejes de la tangente" ;
    ns1:solucionaFallo ns1:SPLINETangenteFinalIndeterminada_78ac181053 ;
    ns1:textoExtracto "SOLUCIÓN Programar un punto previo al punto de entrada al spline o ambos ejes de la tangente." .

ns1:SPLINETangenteFinalIndeterminada_78ac181053 a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE:Tangente final indeterminada" ;
    ns1:textoExtracto "2113 SPLINE:Tangente final indeterminada." .

