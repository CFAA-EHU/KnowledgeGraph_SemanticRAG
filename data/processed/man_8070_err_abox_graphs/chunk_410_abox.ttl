@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ASPLINEParametroNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "#ASPLINE: parámetro no válido" ;
    ns1:solucionaFallo ns1:ConsultarEnElManualDeProgramacionElFormatoCorrecto ;
    ns1:textoExtracto "2115 #ASPLINE:parámetro no válido. DETECCIÓN Durante la ejecución. CAUSA El tipo de tangencia no es válido." .

ns1:CNC8070_9ce5d58512 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ConsultarEnElManualDeProgramacionElFormatoCorrecto,
        ns1:DesactivarElModoSplineActivoAntesDeDefinirUnoNuevo ;
    ns1:textoExtracto "CNC 8070" .

ns1:NoSeAdmitenBloquesPolinomicosConSplinesActivos a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten bloques polinómicos con splines activos" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2122 'No se admiten bloques polinómicos con splines activos' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento polinómico con el modo spline activo." .

ns1:NoSeAdmitenTrayectoriasCircularesConSplinesActivos a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten trayectorias circulares con splines activos" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2121 'No se admiten trayectorias circulares con splines activos' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento circular con el modo spline activo." .

ns1:ProgramacionNoPermitidaConSplinesActivos_f81d21805f a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con splines activos" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2123 'Programación no permitida con splines activos' DETECCIÓN Durante la ejecución. CAUSA Con el modo spline activo, hay programado un cambio de sistema de coordenadas o sentencias que detienen la preparación de bloques." .

ns1:SPLINEActivacionNoPermitida a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Activación no permitida" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2114 SPLINE:Activación no permitida. DETECCIÓN Durante la ejecución. CAUSA No se puede activar el modo spline sin terminar un spline previo." .

ns1:SPLINEErrorEnLaActivacion a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Error en la activación" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2116 SPLINE: Error en la activación. DETECCIÓN Durante la ejecución. CAUSA No se puede activar un modo spline sin desactivar el modo anterior." .

ns1:SPLINENoSeAdmiteCambiarElTipoConSplinesActivados a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: No se admite cambiar el tipo con splines activados" ;
    ns1:solucionaFallo ns1:DesactivarElModoSplineAntesDeProgramar ;
    ns1:textoExtracto "2119 'SPLINE: No se admite cambiar el tipo con splines activados' DETECCIÓN Durante la ejecución. CAUSA Hay programado un cambio de tipo de spline sin anular el spline." .

ns1:SPLINETipoDeSplineNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Tipo de spline no válido" ;
    ns1:solucionaFallo ns1:ConsultarEnElManualDeProgramacionElFormatoCorrecto ;
    ns1:textoExtracto "2118 'SPLINE: Tipo de spline no válido' DETECCIÓN Durante la ejecución. CAUSA Hay programado un tipo de spline no permitido." .

ns1:DesactivarElModoSplineActivoAntesDeDefinirUnoNuevo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el modo spline activo antes de definir uno nuevo" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el modo spline activo antes de definir uno nuevo." .

ns1:ConsultarEnElManualDeProgramacionElFormatoCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en el manual de programación el formato correcto" ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual de programación el formato correcto." .

ns1:DesactivarElModoSplineAntesDeProgramar a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el modo spline antes de programar" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el modo spline activo antes de activar otro." .

