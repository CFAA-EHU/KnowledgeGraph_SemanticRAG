ex:AvisoSeguridad_2475
    a ex:AvisoSeguridad ;
    rdfs:label "Variable inexistente sin material activo con tabla Cutting"@es ;
    ex:identificador "2475" ;
    ex:textoExtracto "Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting. SOLUCIÓN Activar un fichero de material que tenga una tabla de Cutting."@es .

ex:AvisoSeguridad_2476
    a ex:AvisoSeguridad ;
    rdfs:label "Tabla inexistente en el fichero de material activo"@es ;
    ex:identificador "2476" ;
    ex:textoExtracto "Tabla inexistente en el fichero de material activo."@es .