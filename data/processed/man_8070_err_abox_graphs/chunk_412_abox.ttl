@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarElCanalConDosEjesOProgramarLosMovimientosSinModoSpline a ns1:TareaMantenimiento ;
    rdfs:label "Configurar el canal con dos ejes o programar los movimientos sin modo spline" ;
    ns1:solucionaFallo ns1:SPLINESonNecesariosAlMenosDosEjesPrincipales ;
    ns1:textoExtracto "SOLUCIÓN Configurar el canal con dos ejes o programar los movimientos sin modo spline." .

ns1:DesactivarElModoSplineEnElBloqueOBloquesQueProvocanElError a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar el modo spline en el bloque o bloques que provocan el error" ;
    ns1:solucionaFallo ns1:LimiteSoftwareNegativoSobrepasadoEnElSpline,
        ns1:LimiteSoftwarePositivoSobrepasadoEnElSpline ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el modo spline en el bloque o bloques que provocan el error." .

ns1:ErrorEnLaTransformacionDeRTCP_b2c532fd1d a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la transformación de RTCP" ;
    ns1:textoExtracto "'Error en la transformación de RTCP'" .

ns1:ProgramarElPuntoFinalCompatibleConElPasoYLaProfundidadSiLaTrayectoria_b3408422ca a ns1:TareaMantenimiento ;
    rdfs:label "Programar el punto final compatible con el paso y la profundidad. Si la trayectoria helicoidal son vueltas enteras, programar el paso y la profundidad" ;
    ns1:solucionaFallo ns1:TrayectoriaHelicoidalMalProgramada ;
    ns1:textoExtracto "SOLUCIÓN Programar el punto final compatible con el paso y la profundidad. Si la trayectoria helicoidal son vueltas enteras, programar el paso y la profundidad." .

ns1:ProgramarPuntosDistintos a ns1:TareaMantenimiento ;
    rdfs:label "Programar puntos distintos" ;
    ns1:solucionaFallo ns1:SPLINEErrorEnElCalculoDeLaTangente ;
    ns1:textoExtracto "SOLUCIÓN Programar puntos distintos." .

ns1:LimiteSoftwareNegativoSobrepasadoEnElSpline a ns1:DiagnosticoFallo ;
    rdfs:label "Límite software negativo sobrepasado en el spline" ;
    ns1:textoExtracto "'Límite software negativo sobrepasado en el spline'" .

ns1:LimiteSoftwarePositivoSobrepasadoEnElSpline a ns1:DiagnosticoFallo ;
    rdfs:label "Límite software positivo sobrepasado en el spline" ;
    ns1:textoExtracto "'Límite software positivo sobrepasado en el spline'" .

ns1:SPLINEErrorEnElCalculoDeLaTangente a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Error en el cálculo de la tangente" ;
    ns1:textoExtracto "'SPLINE: Error en el cálculo de la tangente'" .

ns1:SPLINESonNecesariosAlMenosDosEjesPrincipales a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Son necesarios al menos dos ejes principales" ;
    ns1:textoExtracto "'SPLINE: Son necesarios al menos dos ejes principales'" .

ns1:TrayectoriaHelicoidalMalProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria helicoidal mal programada" ;
    ns1:textoExtracto "'Trayectoria helicoidal mal programada'" .

