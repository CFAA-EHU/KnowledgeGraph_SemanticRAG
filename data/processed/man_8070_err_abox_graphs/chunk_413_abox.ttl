@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDelCanalConEjesNecesarios a ns1:TareaMantenimiento ;
    rdfs:label "Configuración del Canal con Ejes Necesarios" ;
    ns1:solucionaFallo ns1:ErrorEnLaTransformacionDeRTCP_c79a5f02af ;
    ns1:textoExtracto "SOLUCIÓN Antes de activar la transformación RTCP, configurar el canal con los ejes necesarios." .

ns1:ErrorEnLaTransformacionDePlanoInclinado_8a9dc1fe82 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la transformación de plano inclinado" ;
    ns1:textoExtracto "'Error en la transformación de plano inclinado' DETECCIÓN" .

ns1:ErrorEnLaTransformacionDeRTCP_c79a5f02af a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la transformación de RTCP" ;
    ns1:textoExtracto "'Error en la transformación de RTCP' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una transformación RTCP y no están en el canal todos los ejes necesarios." .

