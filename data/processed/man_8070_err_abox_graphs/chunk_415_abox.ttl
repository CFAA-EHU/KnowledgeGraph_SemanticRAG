@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_c7af37e70e a ns1:Parametro ;
    rdfs:label "Parámetro máquina FACEAXIS" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." .

ns1:PonerElParametroMaquinaFACEAXISATRUEParaElEjeQueSeaElEjeFrontal a ns1:TareaMantenimiento ;
    rdfs:label "Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal" ;
    ns1:solucionaFallo ns1:NoSeHaDefinidoFACEAXIS ;
    ns1:textoExtracto "SOLUCIÓN Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." .

ns1:ProgramarElRoscadoConLosEjesDisponiblesOConfigurarLosEjesDelCanalPara_0e160b4bb1 a ns1:TareaMantenimiento ;
    rdfs:label "Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar" ;
    ns1:solucionaFallo ns1:NoSeHaDefinidoEjeDeRoscado ;
    ns1:textoExtracto "SOLUCIÓN Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar." .

ns1:ProgramarLaVelocidadDeCorte a ns1:TareaMantenimiento ;
    rdfs:label "Programar la velocidad de corte" ;
    ns1:solucionaFallo ns1:EnVelocidadDeCorteConstanteNoSeHaProgramadoLaVelocidadDeCorte ;
    ns1:textoExtracto "SOLUCIÓN Programar la velocidad de corte." .

ns1:EnVelocidadDeCorteConstanteNoSeHaProgramadoLaVelocidadDeCorte a ns1:DiagnosticoFallo ;
    rdfs:label "En velocidad de corte constante no se ha programado la velocidad de corte" ;
    ns1:textoExtracto "CAUSA En velocidad de corte constante no se ha programado la velocidad de corte." .

ns1:NoSeHaDefinidoEjeDeRoscado a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido eje de roscado" ;
    ns1:textoExtracto "2138 No se ha definido eje de roscado. DETECCIÓN Durante la ejecución." .

ns1:NoSeHaDefinidoFACEAXIS a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido FACEAXIS" ;
    ns1:textoExtracto "2137 No se ha definido FACEAXIS. DETECCIÓN Durante la ejecución." .

