@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarCanalConAlMenosDosEjes a ns1:TareaMantenimiento ;
    rdfs:label "Configurar canal con al menos dos ejes" ;
    ns1:solucionaFallo ns1:TrayectoriaCircularNoPermitidaSinDosEjesEnElPlanoPrincipal ;
    ns1:textoExtracto "SOLUCIÓN Configurar el canal con al menos dos ejes." .

ns1:ConsultarEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en el manual de programación" ;
    ns1:solucionaFallo ns1:ParametroSLOPE ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual de programación el formato correcto." .

ns1:ProgramarElRoscadoConLosEjesDisponiblesOConfigurarLosEjesDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Programar el roscado con los ejes disponibles o configurar los ejes del canal" ;
    ns1:solucionaFallo ns1:EjeDeRoscadoNoEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar la rosca." .

ns1:ProgramarMovimientoParaElEjeDeRoscado a ns1:TareaMantenimiento ;
    rdfs:label "Programar movimiento para el eje de roscado" ;
    ns1:solucionaFallo ns1:MovimientoNuloEnRoscado ;
    ns1:textoExtracto "SOLUCIÓN Programar el movimiento para el eje de roscado." .

ns1:EjeDeRoscadoNoEnElCanal a ns1:AccionProhibida ;
    rdfs:label "Eje de roscado no en el canal" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El eje de roscado no se encuentra en el canal." .

ns1:MovimientoNuloEnRoscado a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento nulo en roscado" ;
    ns1:textoExtracto "'Movimiento nulo en roscado' DETECCIÓN Durante la ejecución. CAUSA No hay movimiento programado para el eje de roscado." .

ns1:ParametroSLOPE a ns1:Parametro ;
    rdfs:label "Parámetro SLOPE" ;
    ns1:textoExtracto "2140 SLOPE:Parámetro no válido. DETECCIÓN Durante la ejecución. CAUSA Algún parámetro de la sentencia de programación #SLOPE es incorrecto." .

ns1:TrayectoriaCircularNoPermitidaSinDosEjesEnElPlanoPrincipal a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria circular no permitida sin dos ejes en el plano principal" ;
    ns1:textoExtracto "2141 Trayectoria circular no permitida sin dos ejes en el plano principal. DETECCIÓN Durante la ejecución." .

