@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error2487
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2487: Cinemática incompatible en #FACE/#CYL" ;
    ex:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado. SOLUCIÓN Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43." ;
    ex:identificador "2487" .

ex:Error2488
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2488: Falta carga de GAPTABLE" ;
    ex:textoExtracto "2488 Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina" ;
    ex:identificador "2488" .

ex:ErrorRenombrarEjeC
    a ex:AvisoSeguridad ;
    rdfs:label "Error: Renombrado no permitido del eje C" ;
    ex:textoExtracto "CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C." .