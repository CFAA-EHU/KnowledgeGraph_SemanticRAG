@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarElCanalConAlMenosDosEjes a ns1:TareaMantenimiento ;
    rdfs:label "Configurar el canal con al menos dos ejes" ;
    ns1:solucionaFallo ns1:NoSePermitenTrayectoriasCircularesSiNoHayAlMenosDosEjesEnElCanal ;
    ns1:textoExtracto "SOLUCIÓN Configurar el canal con al menos dos ejes." .

ns1:DeseleccionarElSplineEnOtroPuntoOProgramarOtraTangente a ns1:TareaMantenimiento ;
    rdfs:label "Deseleccionar el spline en otro punto o programar otra tangente" ;
    ns1:solucionaFallo ns1:NoSePuedeCalcularLaTangenteParaDeseleccionarElSpline ;
    ns1:textoExtracto "SOLUCIÓN Deseleccionar el spline en otro punto o programar otra tangente." .

ns1:FinalDelProgramaSinDesactivarSplines a ns1:DiagnosticoFallo ;
    rdfs:label "Final del programa sin desactivar splines" ;
    ns1:textoExtracto "'Final del programa sin desactivar splines'" .

ns1:ProgramarUnMovimientoAntesDeActivarElSpline a ns1:TareaMantenimiento ;
    rdfs:label "Programar un movimiento antes de activar el spline" ;
    ns1:solucionaFallo ns1:ErrorEnLaGeneracionDelSpline ;
    ns1:textoExtracto "SOLUCIÓN Programar un movimiento antes de activar el spline." .

ns1:RevisarProgramacion_3592ae1a5f a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConEjeSHirth ;
    ns1:textoExtracto "SOLUCIÓN Revisar programación." .

ns1:ErrorEnLaGeneracionDelSpline a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la generación del spline" ;
    ns1:textoExtracto "'Error en la generación del spline'" .

ns1:NoSePermitenTrayectoriasCircularesSiNoHayAlMenosDosEjesEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "No se permiten trayectorias circulares si no hay al menos dos ejes en el canal" ;
    ns1:textoExtracto "CAUSA No se permiten trayectorias circulares si no hay al menos dos ejes en el canal." .

ns1:NoSePuedeCalcularLaTangenteParaDeseleccionarElSpline a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede calcular la tangente para deseleccionar el spline" ;
    ns1:textoExtracto "'No se puede calcular la tangente al spline'" .

ns1:ProgramacionNoPermitidaConEjeSHirth a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con eje(s) Hirth" ;
    ns1:textoExtracto "'Programación no permitida con eje(s) Hirth'" .

