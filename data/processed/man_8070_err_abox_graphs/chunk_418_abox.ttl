@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElSplineAntesDeFinalizarElPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Anular el spline antes de finalizar el programa" ;
    ns1:solucionaFallo ns1:ElCNCHaAlcanzadoElFinalDelProgramaConElModoSplineActivo ;
    ns1:textoExtracto "SOLUCIÓN Anular el spline antes de finalizar el programa." .

ns1:CNC8070_728588280a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:NoEsPosibleLaDesactivacionDelSpline,
        ns1:ProgramacionDeSplinesNoPermitidaEnModoHSC ;
    ns1:textoExtracto "CNC 8070" .

ns1:NoProgramarElSplineParaEjecutarUnSoloBloque a ns1:AccionProhibida ;
    rdfs:label "No programar el spline para ejecutar un solo bloque" ;
    ns1:textoExtracto "SOLUCIÓN No programar el spline para ejecutar un solo bloque." .

ns1:NoSePermiteActivarElSplineConElModoHSC a ns1:AccionProhibida ;
    rdfs:label "No se permite activar el spline con el modo HSC" ;
    ns1:textoExtracto "CAUSA No se permite activar el spline con el" .

ns1:NumeroInsuficienteDeBloquesParaDesactivarElSpline a ns1:DiagnosticoFallo ;
    rdfs:label "Número insuficiente de bloques para desactivar el spline" ;
    ns1:textoExtracto "CAUSA Número insuficiente de bloques para desactivar el spline." .

ns1:ElCNCHaAlcanzadoElFinalDelProgramaConElModoSplineActivo a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha alcanzado el final del programa con el modo spline activo" ;
    ns1:textoExtracto "CAUSA El CNC ha alcanzado el final del programa con el modo spline activo." .

ns1:NoEsPosibleLaDesactivacionDelSpline a ns1:Alarma ;
    rdfs:label "'No es posible la desactivación del spline'" ;
    ns1:textoExtracto "2146 'No es posible la desactivación del spline'" .

ns1:ProgramacionDeSplinesNoPermitidaEnModoHSC a ns1:Alarma ;
    rdfs:label "'Programación de splines no permitida en modo HSC'" ;
    ns1:textoExtracto "2147 'Programación de splines no permitida en modo HSC'" .

