@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error2494
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2494: Sintaxis incorrecta en #DMC ON"@es ;
    ex:textoExtracto "2494 #DMC ON [<PWRSP> <,OVRMIN> <,OVRMAX> <,FZMIN> <,FZMAX> <,ENTRYOVR> <,ENTRYDIST>] [...] CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2494" .

ex:Error2495
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2495: Sintaxis incorrecta en #GRAPHCMD"@es ;
    ex:textoExtracto "2495 #GRAPHCMD command <Pi>. [...] CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2495" .

ex:Error2496
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2496: Comando desconocido en #GRAPHCMD"@es ;
    ex:textoExtracto "2496 Comando desconocido. [...] CAUSA Se ha programado un comando desconocido en la sentencia #GRAPHCMD. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2496" .

ex:Error2497
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2497: Múltiples comandos en #GRAPHCMD"@es ;
    ex:textoExtracto "2497 Sólo se permite programar un comando. [...] CAUSA Se han programado demasiados comandos en la sentencia #GRAPHCMD. SOLUCIÓN Revisar la programación. La sentencia #GRAPHCMD sólo admite un comando."@es ;
    ex:identificador "2497" .

ex:Error2498
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2498: Valor de GAP inferior a GAPSMINLEVEL"@es ;
    ex:textoExtracto "2498 El gap programado debe ser superior al parámetro máquina GAPSMINLEVEL. [...] CAUSA El valor programado del gap es inferior o igual al parámetro máquina GAPSMINLEVEL. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2498" .

ex:Error2499
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2499: Simulación de GAP con SIMMODE=FALSE"@es ;
    ex:textoExtracto "2499 No es posible simulación de GAP con el parámetro SIMMODE = FALSE. [...] CAUSA Se ha programado el control de gap (#GRAPCTRL) en un eje que tiene el parámetro SIMMODE=False. SOLUCIÓN El gap sólo se puede activar en ejes con SIMMODE=True."@es ;
    ex:identificador "2499" .

ex:Error2500
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2500: Movimiento rotativo con RTCP STATIC y compensación G41/G42"@es ;
    ex:textoExtracto "2500 Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio activa (G41/G42). [...] CAUSA Se ha intentado mover un eje rotativo de la cinemática, con RTCP STATIC y compensación de radio activa."@es ;
    ex:identificador "2500" .

ex:Error2493
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2493: Origen de eje C no programado en #FACECYL"@es ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se ha programado el origen del eje C en la instrucción #FACECYL. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "2493" .

ex:Parametro_GAPSMINLEVEL
    a ex:Parametro ;
    rdfs:label "GAPSMINLEVEL"@es ;
    ex:textoExtracto "parámetro máquina GAPSMINLEVEL"@es ;
    ex:identificador "GAPSMINLEVEL" .

ex:Parametro_SIMMODE
    a ex:Parametro ;
    rdfs:label "SIMMODE"@es ;
    ex:textoExtracto "parámetro SIMMODE"@es ;
    ex:identificador "SIMMODE" ;
    ex:valor "TRUE" , "FALSE" .

ex:Instruccion_FACECYL
    a ex:Componente ;
    rdfs:label "#FACECYL"@es ;
    ex:textoExtracto "instrucción #FACECYL"@es ;
    ex:identificador "#FACECYL" .

ex:Instruccion_GRAPHCMD
    a ex:Componente ;
    rdfs:label "#GRAPHCMD"@es ;
    ex:textoExtracto "sentencia #GRAPHCMD"@es ;
    ex:identificador "#GRAPHCMD" .

ex:Instruccion_GRAPCTRL
    a ex:Componente ;
    rdfs:label "#GRAPCTRL"@es ;
    ex:textoExtracto "control de gap (#GRAPCTRL)"@es ;
    ex:identificador "#GRAPCTRL" .

ex:Instruccion_DMC_ON
    a ex:Componente ;
    rdfs:label "#DMC ON"@es ;
    ex:textoExtracto "#DMC ON [<PWRSP> <,OVRMIN> <,OVRMAX> <,FZMIN> <,FZMAX> <,ENTRYOVR> <,ENTRYDIST>]"@es ;
    ex:identificador "#DMC ON" .

ex:EjeC
    a ex:ComponenteMecanico ;
    rdfs:label "Eje C"@es ;
    ex:textoExtracto "origen del eje C"@es ;
    ex:identificador "Eje_C" .

ex:Compensacion_G41_G42
    a ex:Parametro ;
    rdfs:label "Compensación de radio (G41/G42)"@es ;
    ex:textoExtracto "compensación de radio activa (G41/G42)"@es ;
    ex:identificador "G41/G42" .

ex:Modo_RTCP_STATIC
    a ex:ModoOperacion ;
    rdfs:label "RTCP STATIC"@es ;
    ex:textoExtracto "RTCP STATIC activo"@es ;
    ex:identificador "RTCP_STATIC" .

# Relaciones entre diagnósticos y componentes/parámetros
ex:Error2493 ex:solucionaFallo ex:Instruccion_FACECYL .
ex:Error2494 ex:solucionaFallo ex:Instruccion_DMC_ON .
ex:Error2495 ex:solucionaFallo ex:Instruccion_GRAPHCMD .
ex:Error2496 ex:solucionaFallo ex:Instruccion_GRAPHCMD .
ex:Error2497 ex:solucionaFallo ex:Instruccion_GRAPHCMD .
ex:Error2498 ex:monitoreaParametro ex:Parametro_GAPSMINLEVEL .
ex:Error2499 ex:monitoreaParametro ex:Parametro_SIMMODE .
ex:Error2499 ex:solucionaFallo ex:Instruccion_GRAPCTRL .
ex:Error2500 ex:monitoreaParametro ex:Compensacion_G41_G42 .
ex:Error2500 ex:monitoreaParametro ex:Modo_RTCP_STATIC .
ex:Error2493 ex:monitoreaParametro ex:EjeC .