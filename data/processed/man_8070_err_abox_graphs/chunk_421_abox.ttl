@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarLaTrayectoriaDeMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la trayectoria de mecanizado" ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la trayectoria de mecanizado." .

ns1:CicloDeCalibracionDePalpadorPROBE2_0a6f6793ef a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de calibración de palpador (#PROBE 2)" ;
    ns1:solucionaFallo ns1:RetardoDelPalpadorMalAjustado ;
    ns1:textoExtracto "También puede utilizar ciclo de calibración de palpador (#PROBE 2) para calcular el valor correcto." .

ns1:DefinirElParametroPROBEDELAYConElValorIndicadoEnElMensaje a ns1:TareaMantenimiento ;
    rdfs:label "Definir el parámetro PROBEDELAY con el valor indicado en el mensaje" ;
    ns1:solucionaFallo ns1:RetardoDelPalpadorMalAjustado ;
    ns1:textoExtracto "Definir el parámetro PROBEDELAY con el valor indicado en el mensaje." .

ns1:DesactivarLaFuncionCSROTOCambiarDeOrientacion_ddbb98511b a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la función #CSROT o cambiar de orientación" ;
    ns1:textoExtracto "Desactivar la función #CSROT o cambiar de orientación." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:RetrasoDelPalpador ;
    ns1:textoExtracto "Durante la ejecución." .

ns1:SolucionDeOrientacionCSROTNoValidaONoEncontrada a ns1:DiagnosticoFallo ;
    rdfs:label "'Solución de orientación #CSROT no válida ó no encontrada'" ;
    ns1:textoExtracto "'Solución de orientación #CSROT no válida ó no encontrada'." .

ns1:RetrasoDelPalpador a ns1:Parametro ;
    rdfs:label "Retraso del palpador" ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "Parametrizar PROBEDELAY %f." .

ns1:RetardoDelPalpadorMalAjustado a ns1:DiagnosticoFallo ;
    rdfs:label "Retardo del palpador mal ajustado" ;
    ns1:textoExtracto "Retardo del palpador mal ajustado. Parametrizar PROBEDELAY %f." .

