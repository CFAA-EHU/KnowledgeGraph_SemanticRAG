@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2507
    a ex:Alarma ;
    rdfs:label "Alarma 2507: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas"@es ;
    ex:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución. CAUSA No es posible programar las cotas de un bloque en G107 con coordenadas polares o mediante coordenadas cartesianas y ángulo."@es ;
    ex:identificador "2507" .

ex:DiagnosticoFallo_2507
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2507: Coordenadas no permitidas en G107"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Programar las cotas en coordenadas cartesianas."@es ;
    ex:solucionaFallo ex:Alarma_2507 .

ex:Alarma_2508
    a ex:Alarma ;
    rdfs:label "Alarma 2508: Valor de escritura fuera de rango"@es ;
    ex:textoExtracto "2508 Valor de escritura fuera de rango. DETECCIÓN Durante la ejecución. CAUSA No es posible escribir ese valor en la variable."@es ;
    ex:identificador "2508" .

ex:DiagnosticoFallo_2508
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2508: Valor fuera de rango"@es ;
    ex:textoExtracto "SOLUCIÓN Modificar el valor a escribir."@es ;
    ex:solucionaFallo ex:Alarma_2508 .

ex:Alarma_2509
    a ex:Alarma ;
    rdfs:label "Alarma 2509: Sintaxis #ORBIT incorrecta"@es ;
    ex:textoExtracto "2509 #ORBIT ON[Rvalor, Jvalor ,Kvalor]."@es ;
    ex:identificador "2509" .