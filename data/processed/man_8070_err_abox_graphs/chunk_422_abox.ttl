@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AumentarElValorDelAnguloDefinidoEnDEFROT a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el valor del ángulo definido en #DEFROT" ;
    ns1:solucionaFallo ns1:SolucionDeOrientacionCSROTDiscontinuaRespectoLoProgramadoRotativoPrin_f983447a7b ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el valor del ángulo definido en #DEFROT." .

ns1:DesactivarLaFuncionCSROTOCambiarDeOrientacion a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la función #CSROT o cambiar de orientación" ;
    ns1:solucionaFallo ns1:SolucionDeOrientacionCSROTNoEncontradaSegunCriterioDefinidoEnDEFROT_6dbea2c3d2 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la función #CSROT o cambiar de orientación." .

ns1:ValorDelAnguloDefinido a ns1:Parametro ;
    rdfs:label "Valor del ángulo definido" ;
    ns1:identificador "#DEFROT" ;
    ns1:textoExtracto "Aumentar el valor del ángulo definido en #DEFROT." .

ns1:SolucionDeOrientacionCSROTDiscontinuaRespectoLoProgramadoRotativoPrin_f983447a7b a ns1:DiagnosticoFallo ;
    rdfs:label "Solución de orientación #CSROT discontinua respecto lo programado. Rotativo principal / Rotativo secundario" ;
    ns1:textoExtracto "'Solución de orientación #CSROT discontinua respecto lo programado. Rotativo principal / Rotativo secundario'" .

ns1:SolucionDeOrientacionCSROTNoEncontradaSegunCriterioDefinidoEnDEFROT_6dbea2c3d2 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución de orientación #CSROT no encontrada según criterio definido en #DEFROT" ;
    ns1:textoExtracto "'Solución de orientación #CSROT no encontrada según criterio definido en #DEFROT'" .

