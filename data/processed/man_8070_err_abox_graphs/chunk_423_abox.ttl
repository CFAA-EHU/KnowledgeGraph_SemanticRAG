@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2509
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #ORBIT ON" ;
    ex:identificador "2509" ;
    ex:textoExtracto "#ORBIT ON[Rvalor, Jvalor ,Kvalor]. DETECCIÓN Durante la edición o preparación de bloques. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2510
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #ORBIT OFF" ;
    ex:identificador "2510" ;
    ex:textoExtracto "#ORBIT OFF. DETECCIÓN Durante la edición o preparación de bloques. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2511
    a ex:AvisoSeguridad ;
    rdfs:label "Parámetro ORBIT fuera de rango" ;
    ex:identificador "2511" ;
    ex:textoExtracto "Parámetro ORBIT fuera de rango. DETECCIÓN Durante la edición o preparación de bloques. CAUSA Alguno de los parámetros de la sentencia #ORBIT tiene un valor incorrecto. SOLUCIÓN El valor de R/J debe ser positivo y no nulo. El valor de R debe ser mayor que el diámetro de la herramienta. El valor de K debe ser 1 o 2." .

ex:AvisoSeguridad_2512
    a ex:AvisoSeguridad ;
    rdfs:label "Anchura de ranura insuficiente en #ORBIT" ;
    ex:identificador "2512" ;
    ex:textoExtracto "#ORBIT: la anchura de la ranura debe ser mayor que el doble del radio de la herramienta activa. DETECCIÓN Durante la edición o preparación de bloques. CAUSA La anchura de la ranura (R) es menor o igual que el diámetro de la herramienta. SOLUCIÓN Programar una anchura mayor que el radio de la herramienta." .

ex:AvisoSeguridad_2513
    a ex:AvisoSeguridad ;
    rdfs:label "#ORBIT ON ya activo" ;
    ex:identificador "2513" ;
    ex:textoExtracto "#ORBIT ON ya activo. DETECCIÓN Durante la edición o preparación de bloques. CAUSA Se ha intentado activar #ORBITON estando ya activa. SOLUCIÓN Para modificar algún parámetro de la sentencia #ORBIT, es necesario desactivarla primero." .

ex:AvisoSeguridad_2514
    a ex:AvisoSeguridad ;
    rdfs:label "Movimiento G0 no permitido con #ORBIT ON" ;
    ex:identificador "2514" ;
    ex:textoExtracto "#ORBIT ON: movimiento en G0 no permitido. DETECCIÓN Durante la edición o preparación de bloques. CAUSA Se ha programado un movimiento en G0 con #ORBIT activo. SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT." .

ex:AvisoSeguridad_2515
    a ex:AvisoSeguridad ;
    rdfs:label "Movimiento de eje perpendicular no permitido con #ORBIT ON" ;
    ex:identificador "2515" ;
    ex:textoExtracto "#ORBIT ON: movimiento del eje perpendicular al plano no permitido. DETECCIÓN Durante la edición o preparación de bloques." .

ex:Parametro_ORBIT_R
    a ex:Parametro ;
    rdfs:label "Parámetro R (radio) de #ORBIT" ;
    ex:textoExtracto "El valor de R debe ser mayor que el diámetro de la herramienta." .

ex:Parametro_ORBIT_J
    a ex:Parametro ;
    rdfs:label "Parámetro J de #ORBIT" ;
    ex:textoExtracto "El valor de R/J debe ser positivo y no nulo." .

ex:Parametro_ORBIT_K
    a ex:Parametro ;
    rdfs:label "Parámetro K de #ORBIT" ;
    ex:textoExtracto "El valor de K debe ser 1 o 2." .

ex:InterfazUsuario_ORBIT
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación #ORBIT" ;
    ex:textoExtracto "#ORBIT ON[Rvalor, Jvalor ,Kvalor]... #ORBIT OFF." ;
    ex:tieneComponente ex:Parametro_ORBIT_R, ex:Parametro_ORBIT_J, ex:Parametro_ORBIT_K .

ex:AvisoSeguridad_2509 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2510 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2511 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2512 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2513 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2514 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .
ex:AvisoSeguridad_2515 ex:mitigaRiesgo ex:InterfazUsuario_ORBIT .