@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AumentarElValorDelAnguloDefinidoEnDEFROT a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el valor del ángulo definido en #DEFROT" ;
    ns1:solucionaFallo ns1:FalloCompatibilidadCinematica ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el valor del ángulo definido en #DEFROT." .

ns1:CorregirLaSintaxisDeLaSentenciaPWMOUT a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la sintaxis de la sentencia #PWMOUT" ;
    ns1:solucionaFallo ns1:FalloSintaxisSentencia ;
    ns1:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF." .

ns1:DesactivarLaFuncionCSROT a ns1:AccionProhibida ;
    rdfs:label "Desactivar la función #CSROT" ;
    ns1:mitigaRiesgo ns1:FalloCompatibilidadCinematica ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la función #CSROT." .

ns1:ProgramarPWMOUTONFREQFValorDUTYDValorOFF a ns1:AccionProhibida ;
    rdfs:label "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF" ;
    ns1:textoExtracto "2304 Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF." .

ns1:FalloSintaxisSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el" .

ns1:FalloCompatibilidadCinematica a ns1:DiagnosticoFallo ;
    rdfs:label "El tipo de cinemática no es compatible con la función #CSROT" ;
    ns1:textoExtracto "CAUSA El tipo de cinemática no es compatible con la función #CSROT." .

