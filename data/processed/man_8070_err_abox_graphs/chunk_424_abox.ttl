@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirSalidaDigitalLocalAsociadaAlPWM a ns1:TareaMantenimiento ;
    rdfs:label "Definir salida digital local asociada al PWM" ;
    ns1:solucionaFallo ns1:ElParametroMaquinaPWMOUTPUTEs0 ;
    ns1:textoExtracto "Definir en los parámetros máquinas cuál es la salida digital local asociada al PWM (parámetro PWMOUTPUT)." .

ns1:DesactivarLaFuncionCSROT_382bffc4aa a ns1:AccionProhibida ;
    rdfs:label "Desactivar la función #CSROT" ;
    ns1:textoExtracto "Desactivar la función #CSROT." .

ns1:NoSePuedeActivarElEjeComoHirthPorFormarParteDeLaTransformacionVIRTAX a ns1:AccionProhibida ;
    rdfs:label "No se puede activar el eje como Hirth, por formar parte de la transformación #VIRTAX" ;
    ns1:textoExtracto "'No se puede activar el eje como Hirth, por formar parte de la transformación #VIRTAX'" .

ns1:RevisarProgramacionParaSolucionarError2304 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación para solucionar error 2304" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_c362209e2f ;
    ns1:textoExtracto "Revisar la programación." .

ns1:RevisarProgramacionParaSolucionarError2305 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación para solucionar error 2305" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_f55d5b717b ;
    ns1:textoExtracto "Revisar la programación." .

ns1:SalidaDigitalLocalAsociadaAlPWM_7092004790 a ns1:Parametro ;
    rdfs:label "Salida digital local asociada al PWM" ;
    ns1:textoExtracto "Definir en los parámetros máquinas cuál es la salida digital local asociada al PWM (parámetro PWMOUTPUT)." .

ns1:DiagnosticoFallo_f55d5b717b a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro PWM fuera de rango" ;
    ns1:textoExtracto "Alguno de los comandos de la sentencia #PWMOUT tiene un valor incorrecto." .

ns1:ElParametroMaquinaPWMOUTPUTEs0 a ns1:DiagnosticoFallo ;
    rdfs:label "El parámetro máquina PWMOUTPUT es 0" ;
    ns1:textoExtracto "El CNC ha intentado activar el PWM, pero no tiene ninguna salida digital local asignada." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrectaOHayMasInformacionEnElBloque_c362209e2f a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta o hay más información en el bloque" ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

