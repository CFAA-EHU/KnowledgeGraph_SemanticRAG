@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarPrimeroLaTransformacionDelEjeVirtualDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar primero la transformación del eje virtual de la herramienta" ;
    ns1:solucionaFallo ns1:DeteccionDuranteLaEjecucion ;
    ns1:textoExtracto "SOLUCIÓN Desactivar primero la transformación del eje virtual de la herramienta (#VIRTAX), a continuación ejecutar las funciones #OSC, G74 o G198-G199, y por último volver a activar la transformación #VIRTAX." .

ns1:ProgramacionNoPermitidaConElEjeVirtualDeLaHerramientaActivo a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida con el eje virtual de la herramienta activo" ;
    ns1:mitigaRiesgo ns1:CNC8070_ac942796db ;
    ns1:textoExtracto "#VIRTAX: Programación no permitida con el eje virtual de la herramienta activo." .

ns1:CNC8070_ac942796db a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar una de las siguientes funciones mientras la transformación del eje virtual de la herramienta está activa." .

ns1:DeteccionDuranteLaEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "Detección durante la ejecución" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una de las siguientes funciones mientras la transformación del eje virtual de la herramienta está activa." .

