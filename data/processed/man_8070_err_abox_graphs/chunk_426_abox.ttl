@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3005
    a ex:AvisoSeguridad ;
    rdfs:label "Error del control de posición en la inicialización del proceso de palpador"@es ;
    ex:identificador "3005" ;
    ex:textoExtracto "3005 'Error del control de posición en la inicialización del proceso de palpador' DETECCIÓN En la inicialización del proceso de palpado. CAUSA Es una seguridad de habilitación del proceso de palpado. Algún eje programado no es válido o no está disponible. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados."@es .

ex:ProcesoPalpado
    a ex:ModoOperacion ;
    rdfs:label "Proceso de palpado"@es ;
    ex:textoExtracto "inicialización del proceso de palpado"@es ,
                     "proceso de palpado"@es ,
                     "proceso de palpado"@es .

ex:EjesProgramados
    a ex:ComponenteMecanico ;
    rdfs:label "Ejes programados"@es ;
    ex:textoExtracto "Algún eje programado no es válido o no está disponible"@es ,
                     "Comprobar la validez y disponibilidad de los ejes programados"@es .

ex:Error_3005
    ex:mitigaRiesgo ex:ProcesoPalpado ;
    ex:controla ex:EjesProgramados .