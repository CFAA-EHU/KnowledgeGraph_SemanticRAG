ns1:ElCNCHaIntentandoActivarLaTransformacionDelEjeVirtualDeLaHerramientaV_fa37dfae11 a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentando activar la transformación del eje virtual de la herramienta (#VIRTAX) con un eje que forma parte del triedro principal ó de una cinemática."@es ;
    ns1:textoExtracto "CAUSA El CNC ha intentando activar la transformación del eje virtual de la herramienta (#VIRTAX) con un eje que forma parte del triedro principal ó de una cinemática." .

ns1:ElCNCHaIntentandoActivarUnEjeVirtualDeLaHerramientaVIRTAXYNoHayDefini_1f4b5fbfe4 a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentando activar un eje virtual de la herramienta (#VIRTAX) y no hay definido ninguno (parámetro VIRTAXISNAME), el eje es rotativo o el eje no pertenece al canal."@es ;
    ns1:textoExtracto "CAUSA El CNC ha intentando activar un eje virtual de la herramienta (#VIRTAX) y no hay definido ninguno (parámetro VIRTAXISNAME), el eje es rotativo o el eje no pertenece al canal." .

ns1:ElCNCHaIntentandoActivarUnaCinematicaQueNoEstaDefinidaEnLaTablaDeCine_ae6cff95fe a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha intentando activar una cinemática que no está definida en la tabla de cinemáticas de los parámetros máquina."@es ;
    ns1:textoExtracto "CAUSA El CNC ha intentando activar una cinemática que no está definida en la tabla de cinemáticas de los parámetros máquina." .

ns1:LaFuncionProgramadaNoEstaPermitidaDentroDeLaDefinicionDeUnPerfilProGTL3 a ns1:DiagnosticoFallo ;
    rdfs:label "La función programada no está permitida dentro de la definición de un perfil ProGTL3."@es ;
    ns1:textoExtracto "CAUSA La función programada no está permitida dentro de la definición de un perfil ProGTL3." .

ns1:LasFuncionesG810G811G813G820G821G840G841G842G850YG841SoloSePermitenDe_2ed376a0e9 a ns1:DiagnosticoFallo ;
    rdfs:label "Las funciones G810, G811, G813, G820, G821, G840, G841, G842, G850 y G841 sólo se permiten dentro de la definición de un perfil ProGTL3."@es ;
    ns1:textoExtracto "CAUSA Las funciones G810, G811, G813, G820, G821, G840, G841, G842, G850 y G841 sólo se permiten dentro de la definición de un perfil ProGTL3." .

ns1:NombreDelEjeVirtualDeLaHerramienta a ns1:Parametro ;
