@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionError2314 a ns1:TareaMantenimiento ;
    rdfs:label "Solución Error 2314" ;
    ns1:solucionaFallo ns1:Error2314ProgramacionNoPermitidaDentroDeUnPerfilPROGTL3 ;
    ns1:textoExtracto "SOLUCIÓN Eliminar dicha función, sustituirla por una equivalente permitida o finalizar la definición del perfil." .

ns1:SolucionErrorEnElProcesoDeResolucionDelPerfilPROGTL3 a ns1:TareaMantenimiento ;
    rdfs:label "Solución Error en el proceso de resolución del perfil PROGTL3" ;
    ns1:solucionaFallo ns1:ErrorEnElProcesoDeResolucionDelPerfilPROGTL3_853376c5b6 ;
    ns1:textoExtracto "SOLUCIÓN" .

ns1:Error2314ProgramacionNoPermitidaDentroDeUnPerfilPROGTL3 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2314 Programación no permitida dentro de un perfil PROGTL3" ;
    ns1:textoExtracto "2314 Programación no permitida dentro de un perfil PROGTL3. DETECCIÓN Durante la ejecución. CAUSA La función programada no está permitida dentro de la definición de un perfil ProGTL3." .

ns1:ErrorEnElProcesoDeResolucionDelPerfilPROGTL3_853376c5b6 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el proceso de resolución del perfil PROGTL3" ;
    ns1:textoExtracto "'Error en el proceso de resolución del perfil PROGTL3' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado es incorrecto o no tiene solución." .

