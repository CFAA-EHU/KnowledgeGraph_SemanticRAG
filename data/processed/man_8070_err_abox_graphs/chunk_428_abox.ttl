@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_3015
    a ex:AvisoSeguridad ;
    rdfs:label "Búsqueda de referencia máquina omitida en búsqueda de bloque"@es ;
    ex:identificador "3015" ;
    ex:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida'"@es ;
    ex:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: Durante una búsqueda de bloque, el CNC ha encontrado una búsqueda de referencia y la ha ignorado. SOLUCIÓN: Hacer la búsqueda de referencia máquina fuera del programa."@es .

ex:AvisoSeguridad_3016
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 3016 (en búsqueda de bloque)"@es ;
    ex:identificador "3016" ;
    ex:textoExtracto "'En búsqueda de'"@es .

ex:DiagnosticoFallo_3015
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para error 3015: búsqueda de referencia ignorada"@es ;
    ex:identificador "3015" ;
    ex:solucionaFallo ex:AvisoSeguridad_3015 ;
    ex:textoExtracto "SOLUCIÓN: Hacer la búsqueda de referencia máquina fuera del programa."@es .

ex:DiagnosticoFallo_3015_Alternativo
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución alternativa para error de seguimiento"@es ;
    ex:textoExtracto "SOLUCIÓN: Disminuir el avance de palpado o disminuir el error de seguimiento."@es .