@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_3016 a ex:Alarma ;
    rdfs:label "En búsqueda de bloque el modo manual es omitido" ;
    ex:textoExtracto "3016 'En búsqueda de bloque el modo manual es omitido' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado activar el modo manual durante una búsqueda de bloque y el CNC lo ha ignorado. SOLUCIÓN El CNC no permite activar el modo manual durante la búsqueda de bloque." ;
    ex:identificador "3016" .

ex:alarma_3017 a ex:Alarma ;
    rdfs:label "Búsqueda de bloque ya activada" ;
    ex:textoExtracto "3017 'Búsqueda de bloque ya activada' DETECCIÓN Durante la búsqueda de bloque. CAUSA El CNC ha intentado activar una búsqueda de bloque estando con otra activa. SOLUCIÓN Póngase en contacto con su proveedor." ;
    ex:identificador "3017" .

ex:alarma_3018 a ex:Alarma ;
    rdfs:label "No se ha alcanzado aún la velocidad de corte constante" ;
    ex:textoExtracto "3018 'No se ha alcanzado aún la velocidad de corte constante' DETECCIÓN Durante la ejecución. CAUSA El cabezal no ha tenido tiempo para alcanzar la velocidad programada. SOLUCIÓN Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad." ;
    ex:identificador "3018" .

ex:alarma_3019 a ex:Alarma ;
    rdfs:label "Avance programado en G95 demasiado pequeño" ;
    ex:textoExtracto "3019 'Avance programado en G95 demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El avance resultante es muy pequeño para la velocidad programada. SOLUCIÓN Aumentar el avance o aumentar las revoluciones del cabezal." ;
    ex:identificador "3019" .

ex:alarma_3020 a ex:Alarma ;
    rdfs:label "No se ha programado S en G96" ;
    ex:textoExtracto "3020 'No se ha programado S en G96' DETECCIÓN Durante la ejecución. CAUSA La velocidad del cabezal es igual a cero. SOLUCIÓN Programar una velocidad." ;
    ex:identificador "3020" .

ex:alarma_3021 a ex:Alarma ;
    rdfs:label "Máxima velocidad de corte constante igual a cero" ;
    ex:textoExtracto "3021 'Máxima velocidad de corte constante igual a cero' DETECCIÓN Durante la ejecución. CAUSA La velocidad máxima del cabezal es igual a cero. SOLUCIÓN Programar una velocidad." ;
    ex:identificador "3021" .

ex:alarma_3022 a ex:Alarma ;
    rdfs:label "Error al inicializar las cotas de los ejes" ;
    ex:textoExtracto "3022 'Error al inicializar las cotas de los ejes' DETECCIÓN Durante la ejecución. CAUSA No coinciden las cotas de algún eje. SOLUCIÓN Póngase en contacto con Fagor." ;
    ex:identificador "3022" .

ex:alarma_3023 a ex:Alarma ;
    rdfs:label "Falta eje(s) en el nuevo sistema de coordenadas" ;
    ex:textoExtracto "3023 'Falta eje(s) en el nuevo sistema de coordenadas' DETECCIÓN Durante la ejecución." ;
    ex:identificador "3023" .

ex:diagnostico_3016 a ex:DiagnosticoFallo ;
    rdfs:label "Modo manual ignorado durante búsqueda de bloque" ;
    ex:textoExtracto "El usuario ha intentado activar el modo manual durante una búsqueda de bloque y el CNC lo ha ignorado. El CNC no permite activar el modo manual durante la búsqueda de bloque." ;
    ex:solucionaFallo ex:alarma_3016 .

ex:diagnostico_3018 a ex:DiagnosticoFallo ;
    rdfs:label "Velocidad de corte no alcanzada" ;
    ex:textoExtracto "El cabezal no ha tenido tiempo para alcanzar la velocidad programada. Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad." ;
    ex:solucionaFallo ex:alarma_3018 .

ex:diagnostico_3019 a ex:DiagnosticoFallo ;
    rdfs:label "Avance insuficiente en G95" ;
    ex:textoExtracto "El avance resultante es muy pequeño para la velocidad programada. Aumentar el avance o aumentar las revoluciones del cabezal." ;
    ex:solucionaFallo ex:alarma_3019 .

ex:diagnostico_3020 a ex:DiagnosticoFallo ;
    rdfs:label "Velocidad de cabezal no programada en G96" ;
    ex:textoExtracto "La velocidad del cabezal es igual a cero. Programar una velocidad." ;
    ex:solucionaFallo ex:alarma_3020 .

ex:diagnostico_3021 a ex:DiagnosticoFallo ;
    rdfs:label "Velocidad máxima de cabezal no configurada" ;
    ex:textoExtracto "La velocidad máxima del cabezal es igual a cero. Programar una velocidad." ;
    ex:solucionaFallo ex:alarma_3021 .

ex:componente_cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal de la máquina" ;
    ex:textoExtracto "El cabezal no ha tenido tiempo para alcanzar la velocidad programada." .

ex:empresa_fagor a ex:Empresa ;
    rdfs:label "Fagor" ;
    ex:textoExtracto "Póngase en contacto con Fagor." ;
    ex:identificador "Fagor" .