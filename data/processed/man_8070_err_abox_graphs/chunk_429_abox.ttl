@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AntesDeUtilizarUnEnteEsteDebeEstarPreviamenteDefinido a ns1:TareaMantenimiento ;
    rdfs:label "Antes de utilizar un ente, éste debe estar previamente definido" ;
    ns1:solucionaFallo ns1:EnteGeometricoNoDefinido_c239fefc0b ;
    ns1:textoExtracto "SOLUCIÓN Antes de utilizar un ente, éste debe estar previamente definido." .

ns1:ElPuntoInicialNoPerteneceAlCirculo_74d5b7a569 a ns1:DiagnosticoFallo ;
    rdfs:label "El punto inicial no pertenece al círculo" ;
    ns1:textoExtracto "'El punto inicial no pertenece al círculo' DETECCIÓN Durante la ejecución." .

ns1:ModificarElEnteOUtilizarVarios a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el ente o utilizar varios" ;
    ns1:solucionaFallo ns1:NoSeAdmitenMasElementosEnLaDefinicionDelEnteGeometrico_d94795302e ;
    ns1:textoExtracto "SOLUCIÓN Modificar el ente o utilizar varios." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElArcoNoEsPosible_6701565398,
        ns1:ElElementoNoEsTangente_069693aa7b,
        ns1:ElElementoNoEsValido_6c13da1140,
        ns1:ErrorEnElProcesoDeResolucionDelPerfilPROGTL3_853376c5b6,
        ns1:FinalizadoPerfilPROGTL3NoResuelto_9aa1466446,
        ns1:LaTangenciaNoEsPosible_5676c1a7d9,
        ns1:NoSeAdmitenMasPuntosEnLaFuncionG809G820_1f5dff172b ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElArcoNoEsPosible_6701565398 a ns1:DiagnosticoFallo ;
    rdfs:label "El arco no es posible" ;
    ns1:textoExtracto "'El arco no es posible' DETECCIÓN Durante la ejecución. CAUSA El arco programado no es posible con los datos dados." .

ns1:ElElementoNoEsTangente_069693aa7b a ns1:DiagnosticoFallo ;
    rdfs:label "El elemento no es tangente" ;
    ns1:textoExtracto "'El elemento no es tangente' DETECCIÓN Durante la ejecución. CAUSA El elemento indicado no es tangente al anterior." .

ns1:ElElementoNoEsValido_6c13da1140 a ns1:DiagnosticoFallo ;
    rdfs:label "El elemento no es válido" ;
    ns1:textoExtracto "'El elemento no es válido' DETECCIÓN Durante la ejecución. CAUSA El elemento indicado está mal programado." .

ns1:EnteGeometricoNoDefinido_c239fefc0b a ns1:DiagnosticoFallo ;
    rdfs:label "Ente geométrico no definido" ;
    ns1:textoExtracto "'Ente geométrico no definido' DETECCIÓN Durante la ejecución. CAUSA El ente programado no está definido o inicializado." .

ns1:ErrorEnElProcesoDeResolucionDelPerfilPROGTL3_853376c5b6 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el proceso de resolución del perfil PROGTL3" ;
    ns1:textoExtracto "'Error en el proceso de resolución del perfil PROGTL3' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado es incorrecto o no tiene solución." .

ns1:FinalizadoPerfilPROGTL3NoResuelto_9aa1466446 a ns1:DiagnosticoFallo ;
    rdfs:label "Finalizado perfil PROGTL3 no resuelto" ;
    ns1:textoExtracto "'Finalizado perfil PROGTL3 no resuelto' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado finaliza sin resolverse por completo." .

ns1:LaTangenciaNoEsPosible_5676c1a7d9 a ns1:DiagnosticoFallo ;
    rdfs:label "La tangencia no es posible" ;
    ns1:textoExtracto "'La tangencia no es posible' DETECCIÓN Durante la ejecución. CAUSA El elemento programado no puede ser tangente al anterior." .

ns1:NoSeAdmitenMasElementosEnLaDefinicionDelEnteGeometrico_d94795302e a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten más elementos en la definición del ente geométrico" ;
    ns1:textoExtracto "'No se admiten más elementos en la definición del ente geométrico' DETECCIÓN Durante la ejecución. CAUSA Se ha sobrepasado el número máximo de elementos que se admiten para definir un ente geométrico." .

ns1:NoSeAdmitenMasPuntosEnLaFuncionG809G820_1f5dff172b a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten más puntos en la función G809-G820" ;
    ns1:textoExtracto "'No se admiten más puntos en la función G809-G820' DETECCIÓN Durante la ejecución. CAUSA En las función G809 o G820 hay programados más puntos de los permitidos." .

