ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElArcoNoEsPosible_6701565398,
        ns1:ElPuntoFinalNoPerteneceAlCirculo,
        ns1:ElPuntoInicialNoPerteneceAlCirculo_420fa1b5a1 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElArcoNoEsPosible_6701565398 a ns1:DiagnosticoFallo ;
    rdfs:label "El arco no es posible" ;
    ns1:textoExtracto "'El arco no es posible' DETECCIÓN Durante la ejecución. CAUSA El arco programado no es posible con los datos dados." .

ns1:ElPuntoFinalNoPerteneceAlCirculo a ns1:DiagnosticoFallo ;
    rdfs:label "El punto final no pertenece al círculo" ;
    ns1:textoExtracto "'El punto final no pertenece al círculo' DETECCIÓN Durante la ejecución. CAUSA El punto final no pertenece al círculo." .

ns1:ElPuntoInicialNoPerteneceAlCirculo_420fa1b5a1 a ns1:DiagnosticoFallo ;
    rdfs:label "El punto inicial no pertenece al círculo" ;
    ns1:textoExtracto "'El punto inicial no pertenece al círculo' DETECCIÓN Durante la ejecución. CAUSA El punto inicial no pertenece al círculo." .

