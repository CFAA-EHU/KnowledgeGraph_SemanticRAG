ex:Fallo_3020
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "No coinciden las cotas de algún eje"@es ;
    ex:textoExtracto        "CAUSA No coinciden las cotas de algún eje. SOLUCIÓN Póngase en contacto con Fagor."@es ;
