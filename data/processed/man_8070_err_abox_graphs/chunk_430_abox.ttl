ex:Fallo_3023
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Falta eje(s) en el nuevo sistema de coordenadas"@es ;
    ex:identificador        "3023" ;
    ex:textoExtracto        "3023 'Falta eje(s) en el nuevo sistema de coordenadas' [...] CAUSA No existe alguno de los tres primeros ejes del nuevo sistema de coordenadas."@es ;
    ex:solucionaFallo       ex:Accion_DefinirEjes .
ex:Accion_DefinirEjes
    a                       ex:TareaMantenimiento ;
    rdfs:label              "Definir los tres primeros ejes del canal mediante #SET AX"@es ;
    ex:textoExtracto        "SOLUCIÓN Definir los tres primeros del canal mediante la sentencia #SET AX."@es .

