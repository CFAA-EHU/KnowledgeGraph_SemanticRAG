@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacionLasFuncionesG8737OG8738SeDebenProgramarAContinua_3790d8bd6a a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación. Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." ;
    ns1:solucionaFallo ns1:HayAlgunaFuncionG8737OG8738ProgramadaFueraDeUnaMacroG8736 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." .

ns1:RevisarLaProgramacionProgramarElElementoAnterior a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación. Programar el elemento anterior." ;
    ns1:solucionaFallo ns1:SeHaProgramadoUnaG808YNoHayProgramadoNingunElementoAnterior,
        ns1:SeHaProgramadoUnaG808YNoHayProgramadoNingunPuntoAnterior,
        ns1:SeHaProgramadoUnaG809YNoHayProgramadoNingunPuntoAnterior ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar el elemento anterior." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ElElementoAnteriorAUnaG802G803DebeSerUnCirculo,
        ns1:ElEnteProgramadoNoEsValido,
        ns1:ElPuntoFinalNoPerteneceAlCirculo_30b6aa6850,
        ns1:FaltaPuntoFinalEnG802G803,
        ns1:FaltanDatosEnLaProgramacionDelEnte ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ElElementoAnteriorAUnaG802G803DebeSerUnCirculo a ns1:DiagnosticoFallo ;
    rdfs:label "El elemento anterior a una G802/G803 debe ser un círculo" ;
    ns1:textoExtracto "'G802/G803 XY elemento anterior debe ser un círculo'" .

ns1:ElEnteProgramadoNoEsValido a ns1:DiagnosticoFallo ;
    rdfs:label "El ente programado no es válido" ;
    ns1:textoExtracto "'Ente no válido'" .

ns1:ElPuntoFinalNoPerteneceAlCirculo_30b6aa6850 a ns1:DiagnosticoFallo ;
    rdfs:label "El punto final no pertenece al círculo" ;
    ns1:textoExtracto "'El punto final no pertenece al círculo'" .

ns1:FaltaPuntoFinalEnG802G803 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta punto final en G802/G803" ;
    ns1:textoExtracto "'Falta punto final en G802/G803'" .

ns1:FaltanDatosEnLaProgramacionDelEnte a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan datos en la programación del ente" ;
    ns1:textoExtracto "'Faltan datos para definir correctamente el ente'" .

ns1:HayAlgunaFuncionG8737OG8738ProgramadaFueraDeUnaMacroG8736 a ns1:DiagnosticoFallo ;
    rdfs:label "Hay alguna función G8737 o G8738 programada fuera de una macro G8736" ;
    ns1:textoExtracto "'Programación no permitida fuera de una macro G8736'" .

ns1:SeHaProgramadoUnaG808YNoHayProgramadoNingunElementoAnterior a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado una G808 y no hay programado ningún elemento anterior" ;
    ns1:textoExtracto "'G808 sin elemento anterior'" .

ns1:SeHaProgramadoUnaG808YNoHayProgramadoNingunPuntoAnterior a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado una G808 y no hay programado ningún punto anterior" ;
    ns1:textoExtracto "'G808 punto anterior sin definir'" .

ns1:SeHaProgramadoUnaG809YNoHayProgramadoNingunPuntoAnterior a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado una G809 y no hay programado ningún punto anterior" ;
    ns1:textoExtracto "'G809 punto anterior sin definir'" .

