@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:_3031_Alarma
    a ex:Alarma ;
    rdfs:label "Compensación (RTCP/TLC) no permitida en el estado actual"@es ;
    ex:textoExtracto "3031 'Compensación (RTCP/TLC) no permitida en el estado actual' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las compensaciones RTCP o TLC estando la otra activa. SOLUCIÓN Ambas compensaciones no pueden estar activas simultáneamente; desactivar una de ellas (#RTCP OFF / TLC OFF) antes de activar la otra."@es ;
    ex:identificador "3031" .

ex:RTCP_Parametro
    a ex:Parametro ;
    rdfs:label "RTCP"@es ;
    ex:textoExtracto "compensaciones RTCP"@es .

ex:TLC_Parametro
    a ex:Parametro ;
    rdfs:label "TLC"@es ;
    ex:textoExtracto "compensaciones TLC"@es .

ex:_3031_Alarma
    ex:monitoreaParametro ex:RTCP_Parametro ;
    ex:monitoreaParametro ex:TLC_Parametro .