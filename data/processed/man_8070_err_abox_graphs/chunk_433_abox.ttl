@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_78696f3f9d a ns1:AccionProhibida ;
    rdfs:label "función G8734 programada fuera de una macro G8735" ;
    ns1:textoExtracto "Hay alguna función G8734 programada fuera de una macro G8735." .

ns1:AccionProhibida_dbe2880d22 a ns1:AccionProhibida ;
    rdfs:label "función G8724 programada fuera de una macro G8725" ;
    ns1:textoExtracto "Hay alguna función G8724 programada fuera de una macro G8725." .

ns1:ActivarCompensacionDeRadioMientrasEstaActivaLaCompensacionDeHerramienta3D a ns1:AccionProhibida ;
    rdfs:label "activar compensación de radio mientras está activa la compensación de herramienta 3D" ;
    ns1:textoExtracto "El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa." .

ns1:FuncionesG8727OG8728ProgramadasFueraDeUnaMacroG8726 a ns1:AccionProhibida ;
    rdfs:label "funciones G8727 o G8728 programadas fuera de una macro G8726" ;
    ns1:textoExtracto "Hay alguna función G8727 o G8728 programada fuera de una macro G8726." .

ns1:MezclaDeLenguajesProGTL3EISOEnUnPerfil a ns1:AccionProhibida ;
    rdfs:label "mezcla de lenguajes ProGTL3 e ISO en un perfil" ;
    ns1:textoExtracto "El perfil de la macro está escrito en dos lenguajes, ProGTL3 e ISO." .

ns1:ProgramacionDeHEnBloquesNoPermitidos a ns1:AccionProhibida ;
    rdfs:label "programación de H en bloques no permitidos" ;
    ns1:textoExtracto "Sólo se permite programar H en los bloques del perfil plano definido en G8736 o como parámetro de G8737." .

ns1:RevisarLaProgramacionParaCompensacionesIncompatibles a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para compensaciones incompatibles" ;
    ns1:solucionaFallo ns1:CompensacionDeRadioActivaYLa3DIncompatibles ;
    ns1:textoExtracto "Revisar la programación. Ambos tipos de compensación son incompatibles." .

ns1:RevisarLaProgramacionParaFuncionG8724 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para función G8724" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8725 ;
    ns1:textoExtracto "Revisar la programación. La función G8724 se debe programar a continuación de la macro G8725." .

ns1:RevisarLaProgramacionParaFuncionG8734 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para función G8734" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8735_5383136476 ;
    ns1:textoExtracto "Revisar la programación. La función G8734 se debe programar a continuación de la macro G8735." .

ns1:RevisarLaProgramacionParaFuncionesG8727YG8728 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para funciones G8727 y G8728" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8726 ;
    ns1:textoExtracto "Revisar la programación. Las funciones G8727 o G8728 se deben programar a continuación de la macro G8726." .

ns1:RevisarLaProgramacionParaMezclaDeLenguajes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para mezcla de lenguajes" ;
    ns1:solucionaFallo ns1:MezclaDeLenguajesProGTL3EISOEnUnPerfil_97bfceecf5 ;
    ns1:textoExtracto "Los perfiles de las macros se pueden definir en lenguaje ProGTL3 o ISO, pero no se permite mezclar ambos en un mismo perfil. Programar el perfil para la macro en un único lenguaje ProGTL3 o ISO." .

ns1:RevisarLaProgramacionParaSeccionH a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para sección H" ;
    ns1:solucionaFallo ns1:ProgramacionDeHFueraDelPerfilPlanoDefinido ;
    ns1:textoExtracto "Revisar la programación. No programar H en otros bloques." .

ns1:CompensacionDeRadioActivaYLa3DIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "compensación de radio activa y la 3D incompatibles" ;
    ns1:textoExtracto "'No es compatible la compensación de radio activa y la 3D'" .

ns1:MezclaDeLenguajesProGTL3EISOEnUnPerfil_97bfceecf5 a ns1:DiagnosticoFallo ;
    rdfs:label "mezcla de lenguajes ProGTL3 e ISO en un perfil" ;
    ns1:textoExtracto "'Programación PROGTL3 no permitida en un perfil ISO'" .

ns1:ProgramacionDeHFueraDelPerfilPlanoDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "programación de H fuera del perfil plano definido" ;
    ns1:textoExtracto "'No se admite programar sección H'" .

ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8725 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8725" ;
    ns1:textoExtracto "'Programación no permitida fuera de una macro G8725'" .

ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8726 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8726" ;
    ns1:textoExtracto "'Programación no permitida fuera de una macro G8726'" .

ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8735_5383136476 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8735" ;
    ns1:textoExtracto "'Programación no permitida fuera de una macro G8735'" .

