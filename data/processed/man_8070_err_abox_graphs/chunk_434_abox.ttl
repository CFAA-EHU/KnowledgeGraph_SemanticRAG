@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionDeVectorIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de vector incorrecta" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:RevisionDeProgramacion_1527e7b998 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:VectorDoblementeDefinido ;
    ns1:textoExtracto "Revisar la programación. Programar un único vector por bloque." .

ns1:RevisionDeProgramacion_a5cd17c336 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:CompensacionDeRadioIncompatibilidad ;
    ns1:textoExtracto "Revisar la programación. Ambos tipos de compensación son incompatibles." .

ns1:CompensacionDeRadioIncompatibilidad a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación de radio incompatibilidad" ;
    ns1:textoExtracto "El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa." .

ns1:VectorDoblementeDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Vector doblemente definido" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Compensación de herramienta 3D. En el mismo bloque hay programados dos vectores N[a,b,c]." .

