@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnicoPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Definir único perfil" ;
    ns1:solucionaFallo ns1:PerfilDoblementeDefinido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Definir un único perfil." .

ns1:LaCompensacionDeHerramienta3DEnModoNORMALSoloAdmiteHerramientasDeFres_7c2ed652dc a ns1:AvisoSeguridad ;
    rdfs:label "La compensación de herramienta 3D en modo 'NORMAL' sólo admite herramientas de fresado planas, tóricas o esféricas" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_7832615eae ;
    ns1:textoExtracto "SOLUCIÓN La compensación de herramienta 3D en modo 'NORMAL' sólo admite herramientas de fresado planas, tóricas o esféricas." .

ns1:ModificarPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Modificar programa" ;
    ns1:solucionaFallo ns1:SuperadoElMaximoDeBloquesParaLaVisualizacion2D ;
    ns1:textoExtracto "SOLUCIÓN Modificar el programa o visualizarlo por partes." .

ns1:RevisarProgramacionParaCompensacion3D a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación para compensación 3D" ;
    ns1:solucionaFallo ns1:EsNecesarioProgramarElVectorNParaLaCompensacion3D ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Con la compensación de herramienta 3D activa, es obligatorio programar un vector en cada bloque de movimiento." .

ns1:RevisarProgramacion_56086e53ac a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ProgramacionDeVectorIncorrecta_e487272f9b ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar un único vector por bloque." .

ns1:RevisarSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis" ;
    ns1:solucionaFallo ns1:ProgramarCOMP3DONOFFPARAXNORMAL ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_7832615eae a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta activa no adecuada para compensación 3D" ;
    ns1:textoExtracto "'Herramienta activa no adecuada para compensación 3D' DETECCIÓN Durante la ejecución. CAUSA La herramienta no es plana, tórica o esférica." .

ns1:EsNecesarioProgramarElVectorNParaLaCompensacion3D a ns1:DiagnosticoFallo ;
    rdfs:label "Es necesario programar el vector N[-,-,-] para la compensación 3D" ;
    ns1:textoExtracto "'Es necesario programar el vector N[-,-,-] para la compensación 3D' DETECCIÓN Durante la ejecución. CAUSA Con la compensación de herramienta 3D activa, falta el vector N[a,b,c] en algún bloque." .

ns1:PerfilDoblementeDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil doblemente definido" ;
    ns1:textoExtracto "'Perfil doblemente definido' DETECCIÓN Durante la ejecución. CAUSA Hay definido más de un perfil planta o más de un perfil en una sección." .

ns1:ProgramacionDeVectorIncorrecta_e487272f9b a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de vector incorrecta" ;
    ns1:textoExtracto "'Programación de vector incorrecta' DETECCIÓN Durante la ejecución. CAUSA Compensación de herramienta 3D. El vector N[a,b,c] es incorrecto." .

ns1:ProgramarCOMP3DONOFFPARAXNORMAL a ns1:DiagnosticoFallo ;
    rdfs:label "Programar #COMP3D ON/OFF [PARAX/NORMAL]" ;
    ns1:textoExtracto "'Programar #COMP3D ON/OFF [PARAX/NORMAL]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:SuperadoElMaximoDeBloquesParaLaVisualizacion2D a ns1:DiagnosticoFallo ;
    rdfs:label "Superado el máximo de bloques para la visualización 2D" ;
    ns1:textoExtracto "'Superado el máximo de bloques para la visualización 2D' DETECCIÓN Durante la ejecución. CAUSA La memoria reservada para la visualización 2D del programa es insuficiente en este programa o se ha sobrepasado el número de bloques máximo (500)." .

