@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirTodosLosPerfiles a ns1:TareaMantenimiento ;
    rdfs:label "Definir todos los perfiles" ;
    ns1:solucionaFallo ns1:NoSeHaProgramadoPerfil_c8f2f5dcc4 ;
    ns1:textoExtracto "SOLUCIÓN Para ejecutar correctamente la macro es obligatorio definir todos los perfiles." .

ns1:ErrorEnProcesoLSFIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error en proceso #LSFIT" ;
    ns1:textoExtracto "'Error en proceso #LSFIT' DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT." .

ns1:FinalizarCorrectamenteLaDefinicionDeLasMacros a ns1:TareaMantenimiento ;
    rdfs:label "Finalizar correctamente la definición de las macros" ;
    ns1:solucionaFallo ns1:SeEsperaFinalDeMacro ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ns1:InicializarEntesAntesDeSuUso a ns1:TareaMantenimiento ;
    rdfs:label "Inicializar entes antes de su uso" ;
    ns1:solucionaFallo ns1:EnteSinInicializar ;
    ns1:textoExtracto "SOLUCIÓN Antes de utilizar un ente, éste debe estar previamente inicializado." .

ns1:Parametro_f5e5bae5ee a ns1:Parametro ;
    rdfs:label "#LSFIT" ;
    ns1:textoExtracto "Programar #LSFIT [tipo, pLocal <,data1, data2, data3> ] DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisarParametrosDeLSFIT a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros de #LSFIT" ;
    ns1:solucionaFallo ns1:LSFITParametroLocalNoValido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarProgramacionDeMacros a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de macros" ;
    ns1:solucionaFallo ns1:MacroG8735G8736G8725G8726DoblementeDefinida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ns1:RevisarProgramacionDePerfiles a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de perfiles" ;
    ns1:solucionaFallo ns1:InicioDePerfilG841G842DoblementeDefinido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de los perfiles." .

ns1:RevisarSintaxisDeLSFIT a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de #LSFIT" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloSintaxisLSFIT ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EnteSinInicializar a ns1:DiagnosticoFallo ;
    rdfs:label "Ente sin inicializar" ;
    ns1:textoExtracto "'Ente sin inicializar' DETECCIÓN Durante la ejecución. CAUSA El programa ha intentado utilizar un ente no inializado." .

ns1:InicioDePerfilG841G842DoblementeDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Inicio de perfil G841/G842 doblemente definido" ;
    ns1:textoExtracto "'Inicio de perfil G841/G842 doblemente definido' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir un nuevo perfil sin finalizar el anterior." .

ns1:LSFITParametroLocalNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, parámetro local no válido" ;
    ns1:textoExtracto "#LSFIT, parámetro local no válido. DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido." .

ns1:MacroG8735G8736G8725G8726DoblementeDefinida a ns1:DiagnosticoFallo ;
    rdfs:label "Macro G8735/G8736/G8725/G8726 doblemente definida" ;
    ns1:textoExtracto "'Macro G8735/G8736/G8725/G8726 doblemente definida' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir una nueva macro sin finalizar la anterior." .

ns1:NoSeHaProgramadoPerfil_c8f2f5dcc4 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado perfil" ;
    ns1:textoExtracto "'No se ha programado perfil' DETECCIÓN Durante la ejecución. CAUSA Falta programar algún perfil en la macro ProGTL3." .

ns1:SeEsperaFinalDeMacro a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera final de macro" ;
    ns1:textoExtracto "'Se espera final de macro: G8738/G8734/G8728/G8724 DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado el final del programa sin finalizar la macro definida." .

