@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3048
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 3048: 'La gama programada no existe'"@es ;
    ex:textoExtracto "3048 'La gama programada no existe' [...] Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una función M asociada a una gama que no existe en el cabezal."@es ;
    ex:identificador "3048" .

ex:Fallo_G63_Incompatible
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo por incompatibilidad G63 con funciones M3-M5/M19/M41-M44"@es ;
    ex:textoExtracto "Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ex:Modo_MHFS
    a ex:ModoOperacion ;
    rdfs:label "Modo MHFS"@es ;
    ex:textoExtracto "cambiar al modo MHFS"@es .

ex:Funcion_G63 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G63"@es ;
    ex:textoExtracto "G63 activa"@es ;
    ex:identificador "G63" .

ex:Funcion_M3 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función M3"@es ;
    ex:textoExtracto "función M3"@es ;
    ex:identificador "M3" .

ex:Funcion_M4 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función M4"@es ;
    ex:textoExtracto "función M4"@es ;
    ex:identificador "M4" .

ex:Funcion_M5 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función M5"@es ;
    ex:textoExtracto "función M5"@es ;
    ex:identificador "M5" .

ex:Funcion_M19 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función M19"@es ;
    ex:textoExtracto "función M19"@es ;
    ex:identificador "M19" .

ex:RangoFunciones_M41_M44
    a ex:Parametro ;
    rdfs:label "Funciones M41 a M44"@es ;
    ex:textoExtracto "funciones M41 a M44"@es ;
    ex:identificador "M41-M44" .

ex:Solucion_DesactivarG63
    a ex:TareaMantenimiento ;
    rdfs:label "Desactivar función G63 o esperar su finalización"@es ;
    ex:textoExtracto "Desactivar la función G63 o esperar a que finalice esta función antes de interrumpir el programa."@es ;
    ex:solucionaFallo ex:Fallo_G63_Incompatible .