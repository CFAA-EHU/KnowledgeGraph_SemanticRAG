@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSintaxisEnSentenciaSELECTORI a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #SELECT ORI" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:ErrorEnParametroTIPODeLaSentenciaLSFIT,
        ns1:ErrorInternoGenericoDelProcesoLSFIT ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ErrorEnParametroTIPODeLaSentenciaLSFIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error en parámetro TIPO de la sentencia #LSFIT" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido." .

ns1:ErrorInternoGenericoDelProcesoLSFIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno genérico del proceso #LSFIT" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT." .

