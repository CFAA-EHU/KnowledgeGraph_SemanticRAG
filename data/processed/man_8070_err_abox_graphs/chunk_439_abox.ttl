ns1:EliminarElEjeDeRotacionDeLaProgramacionDeDGWZODGWZRECT a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT" ;
    ns1:solucionaFallo ns1:SOLUCIONEliminarElEjeDeRotacionDeLaProgramacionDeDGWZODGWZRECT ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT." .

ns1:ProgramarUnEjeDeRotacion a ns1:TareaMantenimiento ;
    rdfs:label "Programar un eje de rotación" ;
    ns1:solucionaFallo ns1:SOLUCIONProgramarUnEjeDeRotacion ;
    ns1:textoExtracto "SOLUCIÓN Programar un eje de rotación." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:SOLUCIONRevisarLaProgramacion,
        ns1:SOLUCIONRevisarLaProgramacion_101f05b6c1,
        ns1:SOLUCIONRevisarLaProgramacion_c5b9d6acae ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SeleccionarComoEjeLongitudinalUnEjeDelPlanoODelTriedro a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar como eje longitudinal un eje del plano o del triedro" ;
    ns1:solucionaFallo ns1:SOLUCIONSeleccionarComoEjeLongitudinalUnEjeDelPlanoODelTriedro ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar como eje longitudinal un eje del plano o del triedro." .

ns1:SeleccionarComoEjeLongitudinalUnEjeLineal a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar como eje longitudinal un eje lineal" ;
    ns1:solucionaFallo ns1:SOLUCIONSeleccionarComoEjeLongitudinalUnEjeLineal ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar como eje longitudinal un eje lineal." .

ns1:SOLUCIONEliminarElEjeDeRotacionDeLaProgramacionDeDGWZODGWZRECT a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT" ;
    ns1:textoExtracto "'#DGWZ <RECT>: No se permite programar eje de rotación' DETECCIÓN Durante la ejecución. CAUSA Se ha programado el eje de rotación en DGWZ o DGWZ RECT." .

ns1:SOLUCIONProgramarUnEjeDeRotacion a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Programar un eje de rotación" ;
    ns1:textoExtracto "'#DGWZ CYL: Eje de rotación no programado' DETECCIÓN Durante la ejecución. CAUSA En DGWZ CYL es obligatorio programar un eje de rotación y no se ha programado." .

ns1:SOLUCIONRevisarLaProgramacion a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Revisar la programación" ;
    ns1:textoExtracto "'Ejes rotativos seleccionados iguales o incorrectos' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes rotativos seleccionados coinciden o son incorrectos." .

ns1:SOLUCIONRevisarLaProgramacion_101f05b6c1 a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Revisar la programación" ;
    ns1:textoExtracto "'Programar #SELECT ORI [HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:SOLUCIONRevisarLaProgramacion_c5b9d6acae a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Revisar la programación" ;
    ns1:textoExtracto "'La función o sentencia no permite programación de ejes' DETECCIÓN Durante la ejecución. CAUSA En la función o sentencia hay programado un eje." .

ns1:SOLUCIONSeleccionarComoEjeLongitudinalUnEjeDelPlanoODelTriedro a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Seleccionar como eje longitudinal un eje del plano o del triedro" ;
    ns1:textoExtracto "'#DGWZ CYL: El eje programado debe pertenecer al plano o triedro' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #DGWZ no pertenece al plano o triedo." .

ns1:SOLUCIONSeleccionarComoEjeLongitudinalUnEjeLineal a ns1:DiagnosticoFallo ;
    rdfs:label "SOLUCIÓN Seleccionar como eje longitudinal un eje lineal" ;
    ns1:textoExtracto "'#DGWZ CYL: El eje programado debe ser un eje lineal' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #DGWZ no es lineal." .

