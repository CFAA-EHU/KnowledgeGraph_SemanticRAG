@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3057
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error en el cálculo de la transformada directa del eje inclinado #ANGAX"@es ;
    ex:identificador      "3057" ;
    ex:textoExtracto      "3057 'Error en el cálculo de la transformada directa del eje inclinado #ANGAX' DETECCIÓN Durante la ejecución. CAUSA En una transformación angular, el eje inclinado y el ortogonal forma un ángulo de 90º. SOLUCIÓN Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular. Anular la transformación angular (#ANGAX OFF) o definir un ángulo diferente de 90º."@es ;
    .

ex:Parametro_ANGAX
    a                     ex:Parametro ;
    rdfs:label            "Transformación angular del eje inclinado (#ANGAX)"@es ;
    ex:identificador      "#ANGAX" ;
    ex:textoExtracto      "transformación angular (#ANGAX OFF)"@es ;
    .