@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarEjeDeRotacionParaDGWZCYL a ns1:TareaMantenimiento ;
    rdfs:label "Programar eje de rotación para DGWZ CYL" ;
    ns1:solucionaFallo ns1:EjeDeRotacionNoProgramado ;
    ns1:textoExtracto "SOLUCIÓN Programar eje de rotación para DGWZ CYL." .

ns1:ProgramarElPuntoFinalDelArco a ns1:TareaMantenimiento ;
    rdfs:label "Programar el punto final del arco" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDelPuntoFinalDelArco ;
    ns1:textoExtracto "SOLUCIÓN Programar el punto final del arco." .

ns1:PuntoFinalDeMovimientoInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Punto final de movimiento inexistente" ;
    ns1:textoExtracto "2364 Punto final de movimiento inexistente." .

ns1:EjeDeRotacionNoProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Eje de rotación no programado" ;
    ns1:textoExtracto "Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT. 2362 #DGWZ CYL: Eje de rotación no programado." .

ns1:ProgramacionIncorrectaDelPuntoFinalDelArco a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del punto final del arco" ;
    ns1:textoExtracto "2363 G8/G9: Programación incorrecta del punto final del arco." .

