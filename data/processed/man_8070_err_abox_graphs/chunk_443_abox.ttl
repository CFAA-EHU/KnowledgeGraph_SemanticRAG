@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLosDatosDeEntradaOElNumeroYOPosicionesDePalpacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos de entrada o el número y/o posiciones de palpación" ;
    ns1:solucionaFallo ns1:LSFITElAlgoritmoNoConverge_719a910f57,
        ns1:LSFITErrorDeCalculoRadio0_0f2f5512b7,
        ns1:LSFITErrorDeCalculoSVBK_8605c39548,
        ns1:LSFITErrorDeCalculoSVD_e5c2895334,
        ns1:LSFITNumeroDeDatosInsuficiente_bd7f343bac ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:ProgramarElPasoDeHusilloEnUnEjeValido a ns1:TareaMantenimiento ;
    rdfs:label "Programar el paso de husillo en un eje válido" ;
    ns1:solucionaFallo ns1:EjeParaRoscarInexistente_4d4bb38525 ;
    ns1:textoExtracto "SOLUCIÓN Programar el paso de husillo en un eje válido." .

ns1:EjeParaRoscarInexistente_4d4bb38525 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje para roscar inexistente" ;
    ns1:textoExtracto "El eje de roscado viene definido por la letra con la que se programa el paso de husillo en el bloque. El eje programado no existe." .

ns1:LSFITElAlgoritmoNoConverge_719a910f57 a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, el algoritmo no converge" ;
    ns1:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:LSFITErrorDeCalculoRadio0_0f2f5512b7 a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, error de cálculo (radio=0)" ;
    ns1:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:LSFITErrorDeCalculoSVBK_8605c39548 a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, error de cálculo (SVBK)" ;
    ns1:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:LSFITErrorDeCalculoSVD_e5c2895334 a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, error de cálculo (SVD)" ;
    ns1:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:LSFITNumeroDeDatosInsuficiente_bd7f343bac a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, número de datos insuficiente" ;
    ns1:textoExtracto "Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

