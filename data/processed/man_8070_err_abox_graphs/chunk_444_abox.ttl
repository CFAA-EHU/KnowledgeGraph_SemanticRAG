@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error3066
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el seguimiento del eje tangencial sobre la trayectoria"@es ;
    ex:identificador "3066" ;
    ex:textoExtracto "3066 'Error en el seguimiento del eje tangencial sobre la trayectoria' DETECCIÓN Durante la ejecución. CAUSA El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo."@es ;
    ex:solucionaFallo ex:FalloSeguimientoEjeTangencial .

ex:FalloSeguimientoEjeTangencial
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de seguimiento del eje tangencial"@es ;
    ex:textoExtracto "El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo."@es .

ex:Error3067
    a ex:AvisoSeguridad ;
    rdfs:label "G33/G34: Programación no permitida sin cabezal controlado en posición"@es ;
    ex:identificador "3067" ;
    ex:textoExtracto "3067 'G33/G34:Programación no permitida sin cabezal controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste"@es ;
    ex:solucionaFallo ex:FalloControlCabezalG33_G34 .

ex:FalloControlCabezalG33_G34
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de control del cabezal en funciones G33/G34"@es ;
    ex:textoExtracto "La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición."@es .