@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AdvertenciaDeCorreccionDeDatos a ns1:AvisoSeguridad ;
    rdfs:label "advertencia de corrección de datos" ;
    ns1:mitigaRiesgo ns1:CalibracionIncorrectaDeCinematicas ;
    ns1:textoExtracto "Compruebe los datos de entrada durante la ejecución." .

ns1:CorreccionDeDatos a ns1:TareaMantenimiento ;
    rdfs:label "corrección de datos" ;
    ns1:solucionaFallo ns1:ErrorDeCalculoSVBK ;
    ns1:textoExtracto "Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:CalibracionIncorrectaDeCinematicas a ns1:AccionProhibida ;
    rdfs:label "calibración incorrecta de cinemáticas" ;
    ns1:textoExtracto "El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:ErrorDeCalculoSVBK a ns1:DiagnosticoFallo ;
    rdfs:label "error de cálculo (SVBK)"@es ;
    ns1:textoExtracto "#LSFIT, error de cálculo (SVBK), compruebe los datos de entrada." .

