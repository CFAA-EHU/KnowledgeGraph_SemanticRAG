@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirDatosDeEntradaONumeroYOPosicionesDePalpacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir datos de entrada o número y/o posiciones de palpación" ;
    ns1:solucionaFallo ns1:CalibracionDeCinematicas_20e7dcbbd5 ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:DefinirEntradaAnalogicaParaElSensorDelGap a ns1:TareaMantenimiento ;
    rdfs:label "Definir entrada analógica para el sensor del gap" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_776b30101e ;
    ns1:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:EntradaAnalogicaAsociadaAlSensorDelGap a ns1:Parametro ;
    rdfs:label "Entrada analógica asociada al sensor del gap" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:ProgramarEjeYOGAPEnGAPCTRL a ns1:TareaMantenimiento ;
    rdfs:label "Programar eje y/o GAP en #GAPCTRL" ;
    ns1:solucionaFallo ns1:GAPCTRLFaltaProgramarElEjeOElGAP ;
    ns1:textoExtracto "SOLUCIÓN Programar el eje y/o el GAP." .

ns1:RevisarProgramacionDeLSFIT a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de #LSFIT" ;
    ns1:solucionaFallo ns1:InstruccionLSFITNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:CalibracionDeCinematicas_20e7dcbbd5 a ns1:DiagnosticoFallo ;
    rdfs:label "Calibración de cinemáticas" ;
    ns1:textoExtracto "El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:DiagnosticoFallo_776b30101e a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro máquina GAPANAINID nulo o sin asignar" ;
    ns1:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:GAPCTRLFaltaProgramarElEjeOElGAP a ns1:AccionProhibida ;
    rdfs:label "#GAPCTRL: Falta programar el eje o el GAP" ;
    ns1:textoExtracto "#GAPCTRL: Falta programar el eje o el GAP." .

ns1:InstruccionLSFITNoValida a ns1:AccionProhibida ;
    rdfs:label "Instrucción #LSFIT no válida" ;
    ns1:textoExtracto "#LSFIT, la instrucción no es válida." .

