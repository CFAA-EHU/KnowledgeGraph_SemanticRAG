@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarValorCorrectoAlParametroGAPANAINID a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor correcto al parámetro GAPANAINID" ;
    ns1:solucionaFallo ns1:NoSeHaDefinidoLaEntradaAnalogicaALaQueEstaAsociadoElSensorDelGap ;
    ns1:textoExtracto "SOLUCIÓN Asignar el valor correcto al parámetro máquina GAPANAINID." .

ns1:CorregirLaSintaxisDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la sintaxis de la sentencia" ;
    ns1:solucionaFallo ns1:ISOONConSintaxisIncorrecta ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

ns1:CorregirLosDatosDeEntradaOElNumeroYOPosicionesDePalpacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir los datos de entrada o el número y/o posiciones de palpación" ;
    ns1:solucionaFallo ns1:CalibracionDeCinematicasDatosIncoherentesEnElCiclo ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:EntradaAnalogicaAsociadaAlSensorDelGap a ns1:Parametro ;
    rdfs:label "Entrada analógica asociada al sensor del gap" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:ProgramarABORTOFF a ns1:TareaMantenimiento ;
    rdfs:label "Programar #ABORT OFF" ;
    ns1:solucionaFallo ns1:ABORTOFFNoProgramadoEnLaMismaSubrutinaQueABORT ;
    ns1:textoExtracto "SOLUCIÓN Programar #ABORT OFF." .

ns1:ABORTOFFNoProgramadoEnLaMismaSubrutinaQueABORT a ns1:AccionProhibida ;
    rdfs:label "#ABORT OFF no programado en la misma subrutina que #ABORT" ;
    ns1:textoExtracto "2381 #ABORT OFF no programado en la misma subrutina que #ABORT." .

ns1:CalibracionDeCinematicasDatosIncoherentesEnElCiclo a ns1:DiagnosticoFallo ;
    rdfs:label "Calibración de cinemáticas. Datos incoherentes en el ciclo" ;
    ns1:textoExtracto "2380 #LSFIT, error interno. CAUSA Calibración de cinemáticas. Datos incoherentes en el ciclo." .

ns1:ISOONConSintaxisIncorrecta a ns1:AccionProhibida ;
    rdfs:label "#ISO ON[] con sintaxis incorrecta" ;
    ns1:textoExtracto "2382 #ISO ON[]. Sintaxis incorrecta." .

ns1:NoSeHaDefinidoLaEntradaAnalogicaALaQueEstaAsociadoElSensorDelGap a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido la entrada analógica a la que está asociado el sensor del gap" ;
    ns1:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap" .

