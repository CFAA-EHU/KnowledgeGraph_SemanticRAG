@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MovimientoConCicloModalActivoYLlamadaASubrutinaEnElMismoBloque a ns1:AccionProhibida ;
    rdfs:label "Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque. DETECCIÓN Durante la ejecución." .

ns1:NombreDeFicheroNoValido a ns1:AccionProhibida ;
    rdfs:label "Nombre de fichero no valido" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:solucionaFallo ns1:SeleccionarUnaCarpetaQueExistaYUnNombreDeFicheroCorrecto ;
    ns1:textoExtracto "Nombre de fichero no valido. DETECCIÓN Durante la ejecución. CAUSA La carpeta destino no existe o el nombre del fichero es incorrecto." .

ns1:SintaxisIncorrecta_fe93dba7e5 a ns1:AccionProhibida ;
    rdfs:label "Sintaxis incorrecta" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeLaSentencia ;
    ns1:textoExtracto "Sintaxis incorrecta. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisarSintaxisDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de la sentencia" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:SeleccionarUnaCarpetaQueExistaYUnNombreDeFicheroCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar una carpeta que exista y un nombre de fichero correcto" ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar una carpeta que exista y un nombre de fichero correcto." .

