@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3073
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de velocidad esquina sobrepasada" ;
    ex:identificador "3073" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha sobrepasado la dinámica de algún eje, durante la transición entre dos bloques. SOLUCIÓN Póngase en contacto con Fagor." .

ex:Fallo_3074
    a ex:DiagnosticoFallo ;
    rdfs:label "Función no compatible con Motion Control activo" ;
    ex:identificador "3074" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar el sistema de coordenadas o la transformación de coordenadas teniendo alguna función de motion control activa y el parámetro IMOVEMACH deshabilitado. SOLUCIÓN Deshabilitar las funciones de motion control antes de cambiar el sistema de coordenadas o la transformación de coordenadas." .

ex:Fallo_3075
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje múltiple desactivado" ;
    ex:identificador "3075" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El eje no se puede mover porque pertenece a un grupo multieje y está desactivado. SOLUCIÓN Activar el eje para poder moverlo (marca SWITCH del PLC)." .

ex:Fallo_3076
    a ex:DiagnosticoFallo ;
    rdfs:label "No es posible salir de MHFS con Retrace activo" ;
    ex:identificador "3076" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado salir del modo MHFS mientras la marca RETRACE del PLC está activa. SOLUCIÓN Desactivar la marca RETRACE del PLC antes de salir del modo MHFS." .

ex:Fallo_3077
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite Bloque a Bloque en este proceso de RETRACE" ;
    ex:identificador "3077" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos. SOLUCIÓN Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas." .

ex:Parametro_G33_G34
    a ex:Parametro ;
    rdfs:label "Parámetro de función G33/G34 (rosca)" ;
    ex:textoExtracto "Revisar la programación de la función G33/G34. Para mantener el paso programado, modificar la velocidad programada o, si es posible, aumentar desde el PLC el avance máximo del canal." .

ex:Parametro_AvanceMaximo
    a ex:Parametro ;
    rdfs:label "Avance máximo de ejes" ;
    ex:textoExtracto "revisar los parámetros máquina relacionados con el avance máximo de los ejes implicados en la rosca." .

ex:Parametro_IMOVEMACH
    a ex:Parametro ;
    rdfs:label "Parámetro IMOVEMACH" ;
    ex:textoExtracto "el parámetro IMOVEMACH deshabilitado." .

ex:Modo_MHFS
    a ex:ModoOperacion ;
    rdfs:label "Modo MHFS" ;
    ex:textoExtracto "El usuario ha intentado salir del modo MHFS mientras la marca RETRACE del PLC está activa." .

ex:Modo_Retrace
    a ex:ModoOperacion ;
    rdfs:label "Modo RETRACE" ;
    ex:textoExtracto "marca RETRACE del PLC [...] Desactivar la marca RETRACE del PLC antes de salir del modo MHFS." .

ex:Modo_BloqueABloque
    a ex:ModoOperacion ;
    rdfs:label "Modo Bloque a Bloque" ;
    ex:textoExtracto "Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha sobrepasado la dinámica de algún eje [...] El CNC ha intentado modificar el sistema de coordenadas [...] Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas." ;
    ex:tieneComponente ex:Eje_Multiple .

ex:Eje_Multiple
    a ex:ComponenteMecanico ;
    rdfs:label "Eje múltiple" ;
    ex:textoExtracto "El eje no se puede mover porque pertenece a un grupo multieje y está desactivado." .

ex:PLC
    a ex:ComponenteElectrico ;
    rdfs:label "PLC (Controlador Lógico Programable)" ;
    ex:textoExtracto "aumentar desde el PLC el avance máximo del canal [...] marca SWITCH del PLC [...] marca RETRACE del PLC." .