@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3078
    a               ex:DiagnosticoFallo ;
    rdfs:label      "El cabezal master de la sincronización no pasa a lazo abierto"@es ;
    ex:identificador "3078" ;
    ex:textoExtracto "3078 'El cabezal master de la sincronización no pasa a lazo abierto'"@es .

ex:Fallo_ModoBloqueABloque
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Saturación de recursos al activar modo bloque a bloque"@es ;
    ex:textoExtracto "CAUSA Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos. SOLUCIÓN Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas."@es .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "el CNC no permite la función bloque a bloque en este tipo de programas"@es ;
    ex:solucionaFallo ex:Fallo_ModoBloqueABloque .