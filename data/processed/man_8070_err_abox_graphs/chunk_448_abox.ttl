@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjecutarUnCicloFijoDentroDeOtroCicloFijo a ns1:AccionProhibida ;
    rdfs:label "Ejecutar un ciclo fijo dentro de otro ciclo fijo" ;
    ns1:mitigaRiesgo ns1:MovimientoConCicloModalActivoYLlamadaASubrutinaEnElMismoBloque_66a2494f1f ;
    ns1:textoExtracto "No es posible ejecutar un ciclo fijo dentro de otro ciclo fijo." .

ns1:NumeroDeZona a ns1:Parametro ;
    rdfs:label "Número de zona" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5." .

ns1:RevisarProgramacion_3511de441b a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:MovimientoConCicloModalActivoYLlamadaASubrutinaEnElMismoBloque_66a2494f1f ;
    ns1:textoExtracto "Revisar programación. Anular el ciclo modal o programar la llamada a subrutina en un bloque posterior." .

ns1:ZonaDeTrabajoInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Zona de trabajo inexistente" ;
    ns1:textoExtracto "El número de zona programado en G120/G121/G122/G123 no tiene un valor correcto." .

ns1:ZonaDeTrabajoNoProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Zona de trabajo no programada" ;
    ns1:textoExtracto "No se ha programado el número de zona en G120/G121/G122/G123." .

ns1:MovimientoConCicloModalActivoYLlamadaASubrutinaEnElMismoBloque_66a2494f1f a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque" ;
    ns1:textoExtracto "Hay programada una llamada a subrutina y un ciclo modal en el mismo bloque, o se ha intentado ejecutar un ciclo fijo dentro durante la ejecución de otro ciclo fijo." .

