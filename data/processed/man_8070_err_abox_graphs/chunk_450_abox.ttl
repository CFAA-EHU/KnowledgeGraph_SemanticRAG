@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaZonaDeTrabajoProgramado a ns1:Parametro ;
    rdfs:label "Estado de la zona de trabajo programado" ;
    ns1:identificador "G122" ;
    ns1:textoExtracto "El valor programado en G122 no es correcto." .

ns1:EstadoDeZonaDeTrabajo a ns1:Parametro ;
    rdfs:label "Estado de zona de trabajo" ;
    ns1:identificador "G.ZONETOOLWATCH" ;
    ns1:textoExtracto "escribir desde el PLC el valor correcto en la variable \"G.ZONETOOLWATCH[zone]\"." .

ns1:ProgramarUnValorCorrectoParaElEstadoDeLaZona a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor correcto para el estado de la zona" ;
    ns1:solucionaFallo ns1:EstadoDeZonaDeTrabajoNoValido_9c2b90bb0d ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor correcto para el estado de la zona; de 0" .

ns1:EstadoDeZonaDeTrabajoNoValido_9c2b90bb0d a ns1:DiagnosticoFallo ;
    rdfs:label "Estado de zona de trabajo no válido" ;
    ns1:textoExtracto "2388 Estado de zona de trabajo no válido." .

