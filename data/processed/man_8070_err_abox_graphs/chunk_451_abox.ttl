@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirElCentroDeLaZonaCircularConDosEjesDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Definir el centro de la zona circular con dos ejes del canal" ;
    ns1:textoExtracto "SOLUCIÓN El centro de la zona circular G123 se debe definir con dos ejes del canal. La función G123 sólo admite dos ejes, que deben ser diferentes, y pertenecer al canal en el que se activa la zona." .

ns1:DiagnosticoFallo_81461b3ee6 a ns1:DiagnosticoFallo ;
    rdfs:label "'Función E doblemente programada'" ;
    ns1:textoExtracto "'Función E doblemente programada' DETECCIÓN Durante la preparación de bloques. CAUSA El parámetro \"E\" está programado más de una vez en el bloque." .

ns1:ElRadioSoloSePuedeProgramarConR a ns1:DiagnosticoFallo ;
    rdfs:label "'El radio sólo se puede programar con R'" ;
    ns1:textoExtracto "'El radio sólo se puede programar con R' DETECCIÓN Durante la preparación de bloques. CAUSA La instrucción programada sólo permite programar el radio con \"R\"; no admite \"R1\" ni G263." .

ns1:ElValorRecuperadoTrasAlgunProcesoDeRecuperacionDeDatosNoEsCorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "El valor recuperado tras algún proceso de recuperación de datos no es correcto" ;
    ns1:textoExtracto "El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto." .

ns1:EscribirDesdeElPLCElValorCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Escribir desde el PLC el valor correcto" ;
    ns1:textoExtracto "escribir desde el PLC el valor correcto en la variable \"G.ZONEST[zone]\"." .

ns1:FaltaProgramarElRadio a ns1:DiagnosticoFallo ;
    rdfs:label "'Falta programar el radio'" ;
    ns1:textoExtracto "'Falta programar el radio' DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el radio." .

ns1:ModificarLosLimitesInferioresOSuperioresDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Modificar los límites inferiores o superiores del eje" ;
    ns1:textoExtracto "SOLUCIÓN En una zona lineal,el límite inferior del eje debe ser menor que límite superior. Modificar el límite inferior (G120) o superior (G121) del eje." .

ns1:Parametro_6167dc95c7 a ns1:Parametro ;
    rdfs:label "Parámetro E de la función G122" ;
    ns1:identificador "E" ;
    ns1:textoExtracto "programar un valor correcto en el parámetro \"E\" de la función G122." .

ns1:ProgramarElRadio a ns1:TareaMantenimiento ;
    rdfs:label "Programar el radio" ;
    ns1:textoExtracto "SOLUCIÓN Programar el radio." .

ns1:ProgramarElRadioConR a ns1:TareaMantenimiento ;
    rdfs:label "Programar el radio con R" ;
    ns1:textoExtracto "SOLUCIÓN Programar el radio con \"R\"." .

ns1:ProgramarUnValorCorrectoParaElEstadoDeLaZona_9ad11c9941 a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor correcto para el estado de la zona" ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor correcto para el estado de la zona; de 0 a 2." .

ns1:ZonaCircularEsObligatorioProgramarElCentroConDosEjesDelCanal a ns1:DiagnosticoFallo ;
    rdfs:label "'Zona circular: Es obligatorio programar el centro con dos ejes del canal'" ;
    ns1:textoExtracto "'Zona circular: Es obligatorio programar el centro con dos ejes del canal' DETECCIÓN Durante la preparación de bloques. CAUSA En la función G123 no se ha programado correctamente el centro de la zona circular." .

ns1:ZonaLinealLimiteInferiorDebeSerMenorQueLimiteSuperiorEnCadaEje a ns1:DiagnosticoFallo ;
    rdfs:label "'Zona lineal: Límite inferior debe ser menor que límite superior en cada eje'" ;
    ns1:textoExtracto "'Zona lineal: Límite inferior debe ser menor que límite superior en cada eje' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado habilitar una zona de trabajo donde el límite inferior en un eje es mayor que el límite superior." .

