@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarGAPCTRLONMientrasEstaActivoEnOtroCanal a ns1:AccionProhibida ;
    rdfs:label "Activar GAPCTRL ON mientras está activo en otro canal" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "#GAPCTRL ON activo. #GAPCTRL OFF necesario para cambiar parámetros." .

ns1:ControlDelGapEnOtroCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Control del gap en otro canal" ;
    ns1:solucionaFallo ns1:TareaMantenimientoDesactivarGapCtrl ;
    ns1:textoExtracto "#GAPCTRL programado en otro canal. DETECCIÓN Durante la ejecución." .

ns1:EstadoDeLaZonaDeTrabajo a ns1:Parametro ;
    rdfs:label "Estado de la zona de trabajo" ;
    ns1:textoExtracto "\"Programar el estado de la zona de trabajo en el parámetro 'E'; de 0 a 2.\"" .

ns1:EstadoDeLaZonaDeTrabajoNoProgramado_f7fde79c66 a ns1:DiagnosticoFallo ;
    rdfs:label "Estado de la zona de trabajo no programado" ;
    ns1:solucionaFallo ns1:TareaMantenimientoConfigurarParametroE ;
    ns1:textoExtracto "\"DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el estado de la zona de trabajo en G122.\"" .

ns1:ProgramarCentroConEjesRotativosTipoModulo a ns1:AccionProhibida ;
    rdfs:label "Programar centro con ejes rotativos tipo módulo" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'No se permite programar el centro con ejes rotativos tipo módulo'" .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

