@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DETECCIONDuranteLaEjecucionCAUSAElNumeroLogicoProgramadoEnLaVariableNoEsCorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA El número lógico programado en la variable no es correcto."@es ;
    ns1:textoExtracto "Número lógico de eje fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número lógico programado en la variable no es correcto." .

ns1:DesactivarGAPCTRLAntesDeModificarSusParametros a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar #GAPCTRL antes de modificar sus parámetros"@es ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaEjecucionCAUSASeHaIntentadoModificarLosParametrosDe_ef90628cc1 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar #GAPCTRL antes de modificar sus parámetros." .

ns1:LaPrimeraVezQueSeProgramaLEAPEsObligatorioProgramarElComandoPOSLIMIT a ns1:TareaMantenimiento ;
    rdfs:label "La primera vez que se programa #LEAP es obligatorio programar el comando POSLIMIT"@es ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaEjecucionCAUSAEnElComandoLEAPFaltaProgramarElComandoPOSLIMIT ;
    ns1:textoExtracto "SOLUCIÓN La primera vez que se programa #LEAP es obligatorio programar el comando POSLIMIT." .

ns1:Parametro_54944bd501 a ns1:Parametro ;
    rdfs:label "#LEAP"@es,
        "POSLIMIT"@es ;
    ns1:textoExtracto "#LEAP:falta programación de POSLIMIT. DETECCIÓN Durante la ejecución." .

ns1:Parametro_d686f60dee a ns1:Parametro ;
    rdfs:label "#GAPCTRL"@es ;
    ns1:textoExtracto "#GAPCTRL ON activo.#GAPCTRL OFF necesario para cambiar parámetros." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación"@es ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaEjecucionCAUSAUnaVezProgramadaLaCotaFinalDelSaltoLE_0682f61a44 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DETECCIONDuranteLaEjecucionCAUSAEnElComandoLEAPFaltaProgramarElComandoPOSLIMIT a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA En el comando #LEAP falta programar el comando POSLIMIT."@es ;
    ns1:textoExtracto "#LEAP:falta programación de POSLIMIT. DETECCIÓN Durante la ejecución. CAUSA En el comando #LEAP falta programar el comando POSLIMIT." .

ns1:DETECCIONDuranteLaEjecucionCAUSASeHaIntentadoModificarLosParametrosDe_ef90628cc1 a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado modificar los parámetros de #GAPCTRL mientras está activo."@es ;
    ns1:textoExtracto "#GAPCTRL ON activo.#GAPCTRL OFF necesario para cambiar parámetros. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado modificar los parámetros de #GAPCTRL mientras está activo." .

ns1:DETECCIONDuranteLaEjecucionCAUSAUnaVezProgramadaLaCotaFinalDelSaltoLE_0682f61a44 a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la ejecución. CAUSA Una vez programada la cota final del salto (#LEAP[POS]), no se permite cambiarla con #LEAP activo."@es ;
    ns1:textoExtracto "#LEAP activo. No se puede alterar POS, posición final del salto. DETECCIÓN Durante la ejecución. CAUSA Una vez programada la cota final del salto (#LEAP[POS]), no se permite cambiarla con #LEAP activo." .

