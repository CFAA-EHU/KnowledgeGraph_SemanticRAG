@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sensor_3094
    a ex:Sensor ;
    rdfs:label "Sensor de control de gap"@es ;
    ex:textoExtracto "El sensor detecta distancia negativa. [...] Revisar la calibración del sensor."@es ;
    ex:monitoreaParametro ex:Parametro_DistanciaGap ;
    ex:activaAlarma ex:Alarma_3094 .

ex:Parametro_DistanciaGap
    a ex:Parametro ;
    rdfs:label "Distancia de gap"@es ;
    ex:textoExtracto "Con el control de gap activo, el sensor muestra distancia negativa."@es .

ex:Alarma_3094
    a ex:Alarma ;
    ex:identificador "3094" ;
    rdfs:label "Sensor detecta distancia negativa"@es ;
    ex:textoExtracto "3094 El sensor detecta distancia negativa. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el sensor muestra distancia negativa. SOLUCIÓN Revisar la calibración del sensor."@es .

ex:Alarma_3095
    a ex:Alarma ;
    ex:identificador "3095" ;
    rdfs:label "Punto final mal programado en #GAPCTRL o #LEAP"@es ;
    ex:textoExtracto "3095 Punto final mal programado en #GAPCTRL o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Durante la sentencia #GAPCTRL o #LEAP, el CNC no puede corregir la posición tras recibir la señal del sensor. SOLUCIÓN Comprobar que el punto final indicado en las sentencias #GAPCTRL o #LEAP es correcto."@es .

ex:Alarma_3096
    a ex:Alarma ;
    ex:identificador "3096" ;
    rdfs:label "PWRCTRL DUTY activado en otro canal"@es ;
    ex:textoExtracto "3096 PWRCTRL DUTY activado en otro canal. [...] SOLUCIÓN El #PWRCTRL DUTY sólo puede estar activo en un canal."@es .

ex:Alarma_3097
    a ex:Alarma ;
    ex:identificador "3097" ;
    rdfs:label "PWRCTRL OUT activado en otro canal"@es ;
    ex:textoExtracto "3097 PWRCTRL OUT activado en otro canal. [...] SOLUCIÓN El #PWRCTRL OUT sólo puede estar activo en un canal."@es .

ex:Alarma_3098
    a ex:Alarma ;
    ex:identificador "3098" ;
    rdfs:label "PWRCTRL DUTY requiere PWM activo en el mismo canal"@es ;
    ex:textoExtracto "3098 PWRCTRL DUTY requiere PWM activo en el mismo canal. [...] SOLUCIÓN Activar el PWM antes de activar #PWRCTRL DUTY."@es .

ex:Alarma_3099
    a ex:Alarma ;
    ex:identificador "3099" ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo"@es ;
    ex:textoExtracto "3099 LEAP no activado por altura de salto inferior a un mínimo. [...] SOLUCIÓN Revisar la programación."@es .