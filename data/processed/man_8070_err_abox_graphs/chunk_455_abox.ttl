@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FREESETAX a ns1:AccionProhibida ;
    rdfs:label "#FREE/SET AX" ;
    ns1:textoExtracto "'#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa'" .

ns1:FREESETAX_9b018670b1 a ns1:AccionProhibida ;
    rdfs:label "#FREE/SET AX" ;
    ns1:textoExtracto "El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa." .

ns1:NumeroMaximoDeEjes a ns1:Parametro ;
    rdfs:label "Número máximo de ejes" ;
    ns1:textoExtracto "Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)." .

ns1:ProgramarEjeLogicoCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Programar eje lógico correcto" ;
    ns1:solucionaFallo ns1:NumeroLogicoIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)." .

ns1:NumeroLogicoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Número lógico incorrecto" ;
    ns1:textoExtracto "El número lógico programado en la variable no es correcto." .

