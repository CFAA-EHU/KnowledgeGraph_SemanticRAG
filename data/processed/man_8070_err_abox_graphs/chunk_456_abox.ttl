@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlterarIndiceEnCanalDelEjeControlado a ns1:AccionProhibida ;
    rdfs:label "Alterar índice en canal del eje controlado" ;
    ns1:textoExtracto "Se ha alterado el índice en el canal del eje controlado." .

ns1:DesactivarZonaDeTrabajoAntesDeLiberarElEje a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar zona de trabajo antes de liberar el eje" ;
    ns1:solucionaFallo ns1:AparcarEjeDeZonaDeTrabajoActiva,
        ns1:QuitarEjeDeZonaDeTrabajoActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la zona de trabajo antes de liberar el eje." .

ns1:DesaparcarEjeAntesDeActivarLaZonaDeTrabajo a ns1:TareaMantenimiento ;
    rdfs:label "Desaparcar eje antes de activar la zona de trabajo" ;
    ns1:solucionaFallo ns1:ActivarZonaConEjeAparcado_cc46ef6297 ;
    ns1:textoExtracto "SOLUCIÓN Desaparcar el eje antes de activar la zona de trabajo." .

ns1:ActivarZonaConEjeAparcado_cc46ef6297 a ns1:AccionProhibida ;
    rdfs:label "Activar zona con eje aparcado" ;
    ns1:textoExtracto "El CNC ha intentado activar una zona de trabajo, pero uno de los ejes que la definen está aparcado." .

ns1:AparcarEjeDeZonaDeTrabajoActiva a ns1:AccionProhibida ;
    rdfs:label "Aparcar eje de zona de trabajo activa" ;
    ns1:textoExtracto "El CNC ha intentado aparcar un eje que forma parte de una zona de trabajo activa." .

ns1:QuitarEjeDeZonaDeTrabajoActiva a ns1:AccionProhibida ;
    rdfs:label "Quitar eje de zona de trabajo activa" ;
    ns1:textoExtracto "El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa." .

