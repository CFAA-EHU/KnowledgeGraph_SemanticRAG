@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificacionDelIndiceConGAPCTRLActivo a ns1:AccionProhibida ;
    rdfs:label "Modificación del índice con #GAPCTRL activo" ;
    ns1:textoExtracto "No es posible modificar la posición de los ejes en el canal con el control de gap activo." .

ns1:MovimientoDeEjeConGAPCTRLActivo a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje con #GAPCTRL activo" ;
    ns1:textoExtracto "Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL." .

ns1:Parametro_bcc326b219 a ns1:Parametro ;
    rdfs:label "Parámetro máquina GAPCTRLCANCEL" ;
    ns1:identificador "GAPCTRLCANCEL" ;
    ns1:textoExtracto "Si el parámetro máquina GAPCTRLCANCEL tiene valor \"NO\", el eje sigue controlado después de acabar el programa o tras un reset." .

ns1:SolucionDelError2404 a ns1:TareaMantenimiento ;
    rdfs:label "Solución del error 2404" ;
    ns1:solucionaFallo ns1:FalloError2404 ;
    ns1:textoExtracto "No es posible modificar la posición de los ejes en el canal con el control de gap activo." .

ns1:SolucionDelError2405 a ns1:TareaMantenimiento ;
    rdfs:label "Solución del error 2405" ;
    ns1:solucionaFallo ns1:FalloError2405 ;
    ns1:textoExtracto "Programar #GAPCTRL OFF." .

ns1:FalloError2404 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha alterado el índice en el canal del eje controlado" ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques." .

ns1:FalloError2405 a ns1:DiagnosticoFallo ;
    rdfs:label "Bloque de movimiento anulado por tener un eje con #GAPCTRL" ;
    ns1:textoExtracto "DETECCIÓN Durante la inspección de herramienta o modo MDI." .

