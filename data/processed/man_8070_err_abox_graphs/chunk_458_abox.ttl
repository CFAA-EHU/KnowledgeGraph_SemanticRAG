PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_Colision_3104
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Colisión detectada durante ejecución o simulación"@es ;
    ex:textoExtracto "3104 Se ha detectado una colisión. DETECCIÓN Durante la ejecución o la simulación de un programa pieza."@es ;
    ex:identificador "3104" .

ex:Aviso_ProgramacionPotenciaObjetivo
    a               ex:AvisoSeguridad ;
    rdfs:label      "Advertencia de programación de potencia objetivo no realista"@es ;
    ex:textoExtracto "Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío."@es .