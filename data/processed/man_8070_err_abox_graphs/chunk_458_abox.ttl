@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HayUnEjeControladoMedianteLaInstruccionGAPCTRLONEnEstaSituacionSeHaPr_8667ce210d a ns1:DiagnosticoFallo ;
    rdfs:label "Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación se ha programado la instrucción #LEAP para ejecutar un salto cuya cota inicial y final" ;
    ns1:textoExtracto "CAUSA Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación se ha programado la instrucción #LEAP para ejecutar un salto cuya cota inicial y final" .

ns1:LEAPConGAPCTRLON a ns1:Parametro ;
    rdfs:label "#LEAP con #GAPCTRL ON" ;
    ns1:textoExtracto "2406 #LEAP con #GAPCTRL ON: El salto debe empezar y acabar en la misma cota." .

ns1:ProgramarGAPCTRLOFF a ns1:TareaMantenimiento ;
    rdfs:label "Programar #GAPCTRL OFF" ;
    ns1:solucionaFallo ns1:SeHaIntentadoMoverEnMDIUnEjeQueEstaSiendoControladoMedianteElComandoGAPCTRL ;
    ns1:textoExtracto "SOLUCIÓN Programar #GAPCTRL OFF." .

ns1:SeHaIntentadoMoverEnMDIUnEjeQueEstaSiendoControladoMedianteElComandoGAPCTRL a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL" ;
    ns1:textoExtracto "CAUSA Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL." .

