@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularControlDelGapGAPCTRLOFF a ns1:AccionProhibida ;
    rdfs:label "Anular control del gap (#GAPCTRL OFF)" ;
    ns1:textoExtracto "#GAPCTRL OFF" .

ns1:AnularControlDelGapGAPCTRLOFF_e79a62938c a ns1:TareaMantenimiento ;
    rdfs:label "Anular control del gap (#GAPCTRL OFF)" ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaPreparacionDeBloquesCAUSAHayUnEjeControladoMediante_f00a75b664 ;
    ns1:textoExtracto "#GAPCTRL OFF" .

ns1:NoProgramarPOSEnElComandoLEAP a ns1:AccionProhibida ;
    rdfs:label "No programar POS en el comando #LEAP" ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaPreparacionDeBloquesCAUSAHayUnEjeControladoMediante_f00a75b664 ;
    ns1:textoExtracto "No programar POS en el comando #LEAP" .

ns1:PosicionInicialYFinalDelSalto a ns1:Parametro ;
    rdfs:label "Posición inicial y final del salto" ;
    ns1:textoExtracto "parámetro POS de la instrucción #LEAP" .

ns1:ProgramarPOSLIMITEnElComandoLEAPConUnaCotaSuperiorALaPosicionInicialDelSalto a ns1:TareaMantenimiento ;
    rdfs:label "Programar POSLIMIT en el comando #LEAP con una cota superior a la posición inicial del salto" ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaPreparacionDeBloquesCAUSAHayUnEjeControladoMediante_f00a75b664 ;
    ns1:textoExtracto "programar POSLIMIT en el comando #LEAP con una cota superior a la posición inicial del salto" .

ns1:ValorMaximoDelSalto a ns1:Parametro ;
    rdfs:label "Valor máximo del salto" ;
    ns1:textoExtracto "programar POSLIMIT en el comando #LEAP con una cota superior a la posición inicial del salto" .

ns1:DETECCIONDuranteLaPreparacionDeBloquesCAUSAHayUnEjeControladoMediante_f00a75b664 a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la preparación de bloques. CAUSA Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación, se ha programado la instrucción #LEAP con POSLIMIT (valor máximo del salto) inferior a las cotas inicial y final del salto." ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación, se ha programado la instrucción #LEAP con POSLIMIT (valor máximo del salto) inferior a las cotas inicial y final del salto." .

