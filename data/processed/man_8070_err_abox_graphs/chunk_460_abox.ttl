@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElControlDelGap a ns1:AccionProhibida ;
    rdfs:label "Anular el control del gap" ;
    ns1:textoExtracto "#GAPCTRL OFF. 2408 #LEAP, #GAPCTRL ON #SWTOUT ON: Los tres comandos no pueden estar activos." .

ns1:DesactivarUnoDeLosOtrosDosComandosActivos a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar uno de los otros dos comandos activos" ;
    ns1:solucionaFallo ns1:LosComandosLEAPGAPCTRLONYSWTOUTONNoPuedenEstarActivosSimultaneamente ;
    ns1:textoExtracto "SOLUCIÓN Desactivar uno de los otros dos comandos activos." .

ns1:NoProgramarElEjeEsclavoDeFOLLOWMASTER a ns1:TareaMantenimiento ;
    rdfs:label "No programar el eje esclavo de #FOLLOW [MASTER]" ;
    ns1:solucionaFallo ns1:ElNombreDeEjeEsclavoEnFOLLOWONMASTEREjeEsclavoCoincideConElParametroM_7c9159134b ;
    ns1:textoExtracto "SOLUCIÓN No programar el eje esclavo de #FOLLOW [MASTER]." .

ns1:NoSePuedeProgramarElEjeEsclavoLASERFOLLOWAXIS a ns1:AccionProhibida ;
    rdfs:label "No se puede programar el eje esclavo 'LASER FOLLOW AXIS'" ;
    ns1:textoExtracto "2409 No se puede programar el eje esclavo 'LASER FOLLOW AXIS'. DETECCIÓN Durante la preparación de bloques. CAUSA El nombre de eje esclavo en #FOLLOW ON [MASTER, eje esclavo] coincide con el parámetro máquina LASERFOLLOWAXIS." .

ns1:PWRCTRLONOFF a ns1:AccionProhibida ;
    rdfs:label "#PWRCTRL ON/OFF" ;
    ns1:textoExtracto "#PWRCTRL ON/OFF [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>] DETECCIÓN Durante la edición y ejecución." .

ns1:ElNombreDeEjeEsclavoEnFOLLOWONMASTEREjeEsclavoCoincideConElParametroM_7c9159134b a ns1:DiagnosticoFallo ;
    rdfs:label "El nombre de eje esclavo en #FOLLOW ON [MASTER, eje esclavo] coincide con el parámetro máquina LASERFOLLOWAXIS" ;
    ns1:textoExtracto "CAUSA El nombre de eje esclavo en #FOLLOW ON [MASTER, eje esclavo] coincide con el parámetro máquina LASERFOLLOWAXIS." .

ns1:LosComandosLEAPGAPCTRLONYSWTOUTONNoPuedenEstarActivosSimultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "Los comandos #LEAP, #GAPCTRL ON y #SWTOUT ON no pueden estar activos simultáneamente" ;
    ns1:textoExtracto "CAUSA Los comandos #LEAP, #GAPCTRL ON y #SWTOUT ON no pueden estar activos simultáneamente." .

