@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_d60931db93 a ns1:AccionProhibida ;
    rdfs:label "Parámetro PWRCTRL fuera de rango" ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeLaSentencia ;
    ns1:textoExtracto "2412 Parámetro PWRCTRL fuera de rango. DETECCIÓN Durante la edición y ejecución. CAUSA Algún comando de la sentencia #PERCTRL tiene un valor no válido." .

ns1:EsObligatorioProgramarDUTYOUT a ns1:AccionProhibida ;
    rdfs:label "Es obligatorio programar DUTY/OUT" ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeLaSentencia ;
    ns1:textoExtracto "2413 Es obligatorio programar DUTY/OUT. DETECCIÓN Durante la edición y ejecución. CAUSA Falta programar el comando DUTY/OUT en la función #PWRCTRL." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:PWCTRLDUTYNoPermitidoSiNoHayOpcionDeSoftwarePWM a ns1:AccionProhibida ;
    rdfs:label "PWCTRL DUTY no permitido si no hay opción de software PWM" ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeLaSentencia ;
    ns1:textoExtracto "2414 PWCTRL DUTY no permitido si no hay opción de software PWM. DETECCIÓN Durante la ejecución. CAUSA Para activar el control del duty del PWM, es necesario disponer de la opción de software \"PWM\"." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_21fd4293f0 a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarSintaxisDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de la sentencia" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_21fd4293f0 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

