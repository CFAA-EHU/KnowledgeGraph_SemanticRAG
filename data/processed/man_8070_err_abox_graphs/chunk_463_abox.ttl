@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarControlDePotenciaSinCabezalMaster a ns1:AccionProhibida ;
    rdfs:label "Activar control de potencia sin cabezal master" ;
    ns1:textoExtracto "2415 PWCTRL OUT no permitido sin cabezal master en el canal." .

ns1:RevisarSintaxisEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis en el manual de programación" ;
    ns1:solucionaFallo ns1:SintaxisIncorrectaEnPWRCTRL ;
    ns1:textoExtracto "2416 #PWRCTRL ON [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>] SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:SeleccionarCabezalMasterAntesDeActivarControlDePotencia a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar cabezal master antes de activar control de potencia" ;
    ns1:solucionaFallo ns1:ControlDePotenciaSinCabezalMaster ;
    ns1:textoExtracto "2415 PWCTRL OUT no permitido sin cabezal master en el canal. SOLUCIÓN Seleccionar un cabezal master (#MASTER) antes de activar el control de potencia." .

ns1:UsoIncorrectoDeLaSintaxisPWRCTRL a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de la sintaxis #PWRCTRL" ;
    ns1:textoExtracto "2416 #PWRCTRL ON [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ControlDePotenciaSinCabezalMaster a ns1:DiagnosticoFallo ;
    rdfs:label "Control de potencia sin cabezal master" ;
    ns1:textoExtracto "2415 PWCTRL OUT no permitido sin cabezal master en el canal. DETECCIÓN Durante la ejecución. CAUSA El control de potencia se aplica al cabezal master. Se ha intentado activar el control de potencia y no hay un cabezal master activo." .

ns1:SintaxisIncorrectaEnPWRCTRL a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #PWRCTRL" ;
    ns1:textoExtracto "2416 #PWRCTRL ON [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

