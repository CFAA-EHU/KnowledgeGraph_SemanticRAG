@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeFZMINMenorQueFZMAX a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de FZMIN menor que FZMAX" ;
    ns1:solucionaFallo ns1:EnLaFuncionPWRCTRLElAvanceMinimoEsMayorQueElAvanceMaximo ;
    ns1:textoExtracto "SOLUCIÓN El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ns1:CorreccionDeOVRMINMenorQueOVRMAX a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de OVRMIN menor que OVRMAX" ;
    ns1:solucionaFallo ns1:EnLaFuncionPWRCTRLElOverrideMinimoEsMayorQueElOverrideMaximo ;
    ns1:textoExtracto "SOLUCIÓN El override mínimo debe ser menor que el override máximo." .

ns1:RevisionDeSintaxisEnManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis en manual de programación" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:EnLaFuncionPWRCTRLElAvanceMinimoEsMayorQueElAvanceMaximo a ns1:DiagnosticoFallo ;
    rdfs:label "En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo" ;
    ns1:textoExtracto "CAUSA En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo." .

ns1:EnLaFuncionPWRCTRLElOverrideMinimoEsMayorQueElOverrideMaximo a ns1:DiagnosticoFallo ;
    rdfs:label "En la función #PWRCTRL, el override mínimo es mayor que el override máximo" ;
    ns1:textoExtracto "CAUSA En la función #PWRCTRL, el override mínimo es mayor que el override máximo." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

