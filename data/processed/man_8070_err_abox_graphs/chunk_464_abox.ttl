@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloSincronizacion_3413
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo 3413: Sincronización con ratio inválido"@es ;
    ex:identificador "3413" ;
    ex:textoExtracto "No se puede sincronizar en posición con módulo y ratio diferente de 1"@es ;
    ex:textoExtracto "En la sincronización, el denominador del ratio de transmisión tiene valor cero"@es ;
    ex:textoExtracto "En la sincronización en posición, el eje maestro tiene módulo y el ratio de transmisión es diferente de 1"@es .

ex:Parametro_RatioTransmision
    a               ex:Parametro ;
    rdfs:label      "Ratio de transmisión"@es ;
    ex:textoExtracto "ratio de transmisión"@es ;
    ex:textoExtracto "denominador del ratio de transmisión tiene valor cero"@es ;
    ex:valor         "0"^^xsd:string .  # Valor inválido citado en el texto

ex:Parametro_RatioUnidad
    a               ex:Parametro ;
    rdfs:label      "Ratio igual a 1"@es ;
    ex:textoExtracto "ratio diferente de 1"@es ;
    ex:valor         "1"^^xsd:string .  # Valor válido citado en el texto

ex:SistemaSincronizacionPosicion
    a               ex:Sistema ;
    rdfs:label      "Sistema de sincronización en posición"@es ;
    ex:textoExtracto "sincronización en posición"@es ;
    ex:monitoreaParametro ex:Parametro_RatioTransmision ;
    ex:monitoreaParametro ex:Parametro_RatioUnidad .

ex:DiagnosticoFallo_3413
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Solución para fallo 3413: Ratio de transmisión inválido"@es ;
    ex:textoExtracto "El denominador del ratio no puede valer cero"@es ;
    ex:solucionaFallo ex:FalloSincronizacion_3413 .