@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3502
    a ex:Alarma ;
    rdfs:label "Alarma 3502: Aceleración lineal del tramo 2 menor o igual a cero" ;
    ex:identificador "3502" ;
    ex:textoExtracto "'Aceleración lineal del tramo 2 menor o igual a cero' DETECCIÓN Durante el arranque o durante la ejecución. CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración." ;
    .

ex:Alarma_3503
    a ex:Alarma ;
    rdfs:label "Alarma 3503: Aceleración lineal del tramo 2 mayor que la máxima" ;
    ex:identificador "3503" ;
    ex:textoExtracto "'Aceleración lineal del tramo 2 mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La aceleración programada es mayor que la máxima. SOLUCIÓN Programar un valor menor que el máximo para la aceleración." ;
    .

ex:Parametro_AceleracionLineal_Tramo2
    a ex:Parametro ;
    rdfs:label "Aceleración lineal del tramo 2" ;
    ex:textoExtracto "Aceleración lineal del tramo 2" ;
    .

ex:Alarma_3502
    ex:monitoreaParametro ex:Parametro_AceleracionLineal_Tramo2 ;
    .

ex:Alarma_3503
    ex:monitoreaParametro ex:Parametro_AceleracionLineal_Tramo2 ;
    .