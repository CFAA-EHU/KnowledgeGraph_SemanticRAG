@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroT a ns1:Parametro ;
    rdfs:label "Parámetro T" ;
    ns1:textoExtracto "Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T" .

ns1:RealizarLaSincronizacionConLasCotasReales a ns1:TareaMantenimiento ;
    rdfs:label "Realizar la sincronización con las cotas reales" ;
    ns1:solucionaFallo ns1:SincronizacionSobreLasCotasTeoricas ;
    ns1:textoExtracto "Realizar la sincronización con las cotas reales." .

ns1:TipoDeCuttingOPiercingNoDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de Cutting o Piercing no definido" ;
    ns1:textoExtracto "2423 Tipo de #CUTTING o #PIERCING no definido." .

ns1:SincronizacionSobreLasCotasTeoricas a ns1:AccionProhibida ;
    rdfs:label "Sincronización sobre las cotas teóricas" ;
    ns1:textoExtracto "la sincronización solo puede ser sobre las cotas reales; no es posible sincronizar sobre las cotas teóricas." .

