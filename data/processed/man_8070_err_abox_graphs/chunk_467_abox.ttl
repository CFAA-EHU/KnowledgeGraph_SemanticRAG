@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarTablaTecnologica a ns1:TareaMantenimiento ;
    rdfs:label "Activar tabla tecnológica" ;
    ns1:solucionaFallo ns1:FalloPreparacionBloques ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla tecnológica, programar el comando material o programar el comando #PIERCING o #CUTTING que está dando el error con un parámetro T correcto (valor entre 1 y 10)." .

ns1:ActivarTablaTecnologicaDesdeElHMI a ns1:TareaMantenimiento ;
    rdfs:label "Activar tabla tecnológica desde el HMI" ;
    ns1:solucionaFallo ns1:FalloNoTablaTecnologica ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla tecnológica desde el HMI o programar el comando #MATERIAL." .

ns1:CorregirSintaxisDelComandoPLC a ns1:TareaMantenimiento ;
    rdfs:label "Corregir sintaxis del comando PLC" ;
    ns1:solucionaFallo ns1:FalloSintaxisIncorrectaPLC ;
    ns1:textoExtracto "#PLC[PLCmark=0/1,PLCmark=0/1,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:NoDefinirPIERCING a ns1:AccionProhibida ;
    rdfs:label "No definir #PIERCING" ;
    ns1:solucionaFallo ns1:FalloPreparacionBloques ;
    ns1:textoExtracto "o #PIERCING no definido. DETECCIÓN Durante la preparación de bloques. CAUSA El tipo de piercing o cutting es nulo." .

ns1:NoTenerTablaTecnologicaActiva a ns1:AccionProhibida ;
    rdfs:label "No tener tabla tecnológica activa" ;
    ns1:solucionaFallo ns1:FalloNoTablaTecnologica ;
    ns1:textoExtracto "2424 No hay tabla tecnológica activa (#MATERIAL). DETECCIÓN Durante la preparación de bloques. CAUSA Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa." .

ns1:ProgramarComandoCUTTING a ns1:TareaMantenimiento ;
    rdfs:label "Programar comando #CUTTING" ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla tecnológica, programar el comando material o programar el comando #PIERCING o #CUTTING que está dando el error con un parámetro T correcto (valor entre 1 y 10)." .

ns1:ProgramarComandoMaterial a ns1:TareaMantenimiento ;
    rdfs:label "Programar comando material" ;
    ns1:solucionaFallo ns1:FalloPreparacionBloques ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla tecnológica, programar el comando material o programar el comando #PIERCING o #CUTTING que está dando el error con un parámetro T correcto (valor entre 1 y 10)." .

ns1:ProgramarComandoPIERCING a ns1:TareaMantenimiento ;
    rdfs:label "Programar comando #PIERCING" ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla tecnológica, programar el comando material o programar el comando #PIERCING o #CUTTING que está dando el error con un parámetro T correcto (valor entre 1 y 10)." .

ns1:UsoIncorrectoDelComandoPLC a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto del comando PLC" ;
    ns1:solucionaFallo ns1:FalloSintaxisIncorrectaPLC ;
    ns1:textoExtracto "#PLC[PLCmark=0/1,PLCmark=0/1,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:FalloNoTablaTecnologica a ns1:DiagnosticoFallo ;
    rdfs:label "Error por falta de tabla tecnológica" ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa." .

ns1:FalloSintaxisIncorrectaPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error por sintaxis incorrecta del comando PLC" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:FalloPreparacionBloques a ns1:DiagnosticoFallo ;
    rdfs:label "Error durante la preparación de bloques" ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA El tipo de piercing o cutting es nulo." .

