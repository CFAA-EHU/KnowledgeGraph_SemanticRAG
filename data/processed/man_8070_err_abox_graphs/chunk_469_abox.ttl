@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlgunComandoDeLaSentenciaDMCTieneUnValorNoValido a ns1:AccionProhibida ;
    rdfs:label "Algún comando de la sentencia #DMC tiene un valor no válido" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 ;
    ns1:textoExtracto "CAUSA Algún comando de la sentencia #DMC tiene un valor no válido." .

ns1:EnLaFuncionDMCElAvanceMinimoEsMayorQueElAvanceMaximo a ns1:AccionProhibida ;
    rdfs:label "En la función #DMC, el avance mínimo es mayor que el avance máximo" ;
    ns1:solucionaFallo ns1:ElAvanceMinimoFZMINDebeSerMenorQueElAvanceMaximoFZMAX ;
    ns1:textoExtracto "CAUSA En la función #DMC, el avance mínimo es mayor que el avance máximo." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta a ns1:AccionProhibida ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Parametro_2c9fda9fe6 a ns1:Parametro ;
    rdfs:label "Parámetro DMC fuera de rango" ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango DETECCIÓN Durante la edición y ejecución." .

ns1:ElAvanceMinimoFZMINDebeSerMenorQueElAvanceMaximoFZMAX a ns1:TareaMantenimiento ;
    rdfs:label "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)" ;
    ns1:textoExtracto "SOLUCIÓN El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

