@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3511
    a ex:Alarma ;
    rdfs:label "Cancelada M3 o M4 de PLC en G96 sin S programada" ;
    ex:textoExtracto "3511 Cancelada M3 o M4 de PLC en G96 sin S programada. DETECCIÓN Durante la ejecución. CAUSA Se ha solicitado giro de cabezal M3/M4 en G96 sin S programada. El CNC ignora las funciones M3/M4. SOLUCIÓN Revisar programación de G96 y S." ;
    ex:identificador "3511" .

ex:Alarma_3600
    a ex:Alarma ;
    rdfs:label "'Velocidad de cabezal nula'" ;
    ex:textoExtracto "3600 'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA No existe una velocidad de posicionamiento de cabezal programada. SOLUCIÓN Revisar la programación y que los parámetros REFFEED2 y G00FEED de la gama activa del cabezal sean distintos de cero." ;
    ex:identificador "3600" .

ex:Alarma_3601
    a ex:Alarma ;
    rdfs:label "'Velocidad de cabezal programada superior al límite máximo'" ;
    ex:textoExtracto "3601 'Velocidad de cabezal programada superior al límite máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad programada para el cabezal supera la velocidad máxima definida en los parámetros máquina para la gama activa. SOLUCIÓN Revisar el parámetro G00FEED del cabezal." ;
    ex:identificador "3601" .

ex:Alarma_3602
    a ex:Alarma ;
    rdfs:label "'No se puede mover el cabezal en modo visualizador'" ;
    ex:textoExtracto "3602 'No se puede mover el cabezal en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta controlar un cabezal que se encuentra en modo visualizador. SOLUCIÓN El CNC no puede controlar los cabezales activos en modo visualizador. Para desplazar el eje, desactivar el modo visualizador (marca DRO(axis) del PLC) y comprobar el estado de la marca SERVOON del cabezal." ;
    ex:identificador "3602" .

ex:Alarma_3603
    a ex:Alarma ;
    rdfs:label "'La posición del cabezal comandada excede el rango de módulo'" ;
    ex:textoExtracto "3603 'La posición del cabezal comandada excede el rango de módulo' DETECCIÓN Durante la ejecución. CAUSA El CNC está intentando posicionar el cabezal en una cota que está fuera del rango permitido (parámetros MODUPLIM y MODLOWLIM). SOLUCIÓN Revisar los parámetros MODUPLIM y MODLOWLIM." ;
    ex:identificador "3603" .

ex:Alarma_3604
    a ex:Alarma ;
    rdfs:label "'Sentido del posicionamiento de cabezal contrario al de parámetro máquina'" ;
    ex:textoExtracto "3604 'Sentido del posicionamiento de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución." ;
    ex:identificador "3604" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "Revisar la programación y que los parámetros REFFEED2 y G00FEED de la gama activa del cabezal sean distintos de cero." .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "Revisar la programación y que los parámetros REFFEED2 y G00FEED de la gama activa del cabezal sean distintos de cero." .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "El CNC está intentando posicionar el cabezal en una cota que está fuera del rango permitido (parámetros MODUPLIM y MODLOWLIM)." .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "El CNC está intentando posicionar el cabezal en una cota que está fuera del rango permitido (parámetros MODUPLIM y MODLOWLIM)." .

ex:Componente_CNC
    a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC ignora las funciones M3/M4.", "El CNC intenta controlar un cabezal que se encuentra en modo visualizador." .

ex:Componente_Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ex:textoExtracto "Se ha solicitado giro de cabezal M3/M4 en G96 sin S programada.", "El CNC intenta controlar un cabezal que se encuentra en modo visualizador." .

ex:Componente_PLC
    a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Cancelada M3 o M4 de PLC en G96 sin S programada.", "desactivar el modo visualizador (marca DRO(axis) del PLC)" .

ex:Componente_MarcaDRO_axis
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DRO(axis)" ;
    ex:textoExtracto "desactivar el modo visualizador (marca DRO(axis) del PLC)" .

ex:Componente_MarcaSERVOON
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SERVOON" ;
    ex:textoExtracto "comprobar el estado de la marca SERVOON del cabezal." .

ex:Componente_Cabezal
    ex:monitoreaParametro ex:Parametro_REFFEED2 ;
    ex:monitoreaParametro ex:Parametro_G00FEED ;
    ex:monitoreaParametro ex:Parametro_MODUPLIM ;
    ex:monitoreaParametro ex:Parametro_MODLOWLIM ;
    ex:controla ex:Alarma_3511 ;
    ex:controla ex:Alarma_3600 ;
    ex:controla ex:Alarma_3601 ;
    ex:controla ex:Alarma_3602 ;
    ex:controla ex:Alarma_3603 ;
    ex:controla ex:Alarma_3604 .

ex:Componente_CNC
    ex:controla ex:Componente_Cabezal ;
    ex:activaAlarma ex:Alarma_3511 ;
    ex:activaAlarma ex:Alarma_3600 ;
    ex:activaAlarma ex:Alarma_3601 ;
    ex:activaAlarma ex:Alarma_3602 ;
    ex:activaAlarma ex:Alarma_3603 ;
    ex:activaAlarma ex:Alarma_3604 .