@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_3604
    a ex:AvisoSeguridad ;
    rdfs:label "Sentido del posicionamiento de cabezal contrario al de parámetro máquina"@es ;
    ex:identificador "3604" ;
    ex:textoExtracto "3604 'Sentido del posicionamiento de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución. CAUSA El posicionamiento programado requiere un movimiento del cabezal en sentido contrario al indicado por parámetro máquina con UNIDIR."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_3604 .

ex:DiagnosticoFallo_3604
    a ex:DiagnosticoFallo ;
    ex:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "UNIDIR" ;
    ex:textoExtracto "parámetro máquina con UNIDIR"@es .

ex:AvisoSeguridad_3605
    a ex:AvisoSeguridad ;
    rdfs:label "Sentido del giro de cabezal contrario al de parámetro máquina"@es ;
    ex:identificador "3605" ;
    ex:textoExtracto "3605 'Sentido del giro de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución. CAUSA El giro programado"@es .