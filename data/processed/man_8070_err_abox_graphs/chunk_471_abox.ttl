@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElPerfilDeLaMacroG8077EsPoligonal a ns1:AccionProhibida ;
    rdfs:label "El perfil de la macro G8077 es poligonal" ;
    ns1:textoExtracto "2437 El perfil de la macro G8077 es poligonal." .

ns1:ModificarElPerfil a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el perfil" ;
    ns1:solucionaFallo ns1:ElPerfilDebeEstarConstruidoConTramosRectos ;
    ns1:textoExtracto "SOLUCIÓN Modificar el perfil." .

ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8777 a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida fuera de una macro G8777" ;
    ns1:textoExtracto "2436 Programación no permitida fuera de una macro G8777." .

ns1:RevisarLaProgramacion_0878e70f3f a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:HayAlgunaFuncionG8778G8701OG8702ProgramadaFueraDeUnaMacroG8777 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777." .

ns1:ElPerfilDebeEstarConstruidoConTramosRectos a ns1:DiagnosticoFallo ;
    rdfs:label "El perfil debe estar construido con tramos rectos" ;
    ns1:textoExtracto "CAUSA El perfil debe estar construido con tramos rectos." .

ns1:HayAlgunaFuncionG8778G8701OG8702ProgramadaFueraDeUnaMacroG8777 a ns1:DiagnosticoFallo ;
    rdfs:label "Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777" ;
    ns1:textoExtracto "CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777." .

