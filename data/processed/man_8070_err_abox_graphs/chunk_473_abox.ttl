@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionNoPermitidaFueraDeUnaMacroG8754_0e4137eabc a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8754" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:ProgramarUnNodoEntre1Y32 a ns1:TareaMantenimiento ;
    rdfs:label "Programar un nodo entre 1 y 32" ;
    ns1:solucionaFallo ns1:NodoInexistente,
        ns1:NumeroDeNodoIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Programar un nodo entre 1 y 32." .

ns1:ProgramarUnaUnicaVezFINALSUB a ns1:TareaMantenimiento ;
    rdfs:label "Programar una única vez #FINALSUB" ;
    ns1:solucionaFallo ns1:DobleProgramacionDeFINALSUB ;
    ns1:textoExtracto "SOLUCIÓN Programar una única vez #FINALSUB." .

ns1:DobleProgramacionDeFINALSUB a ns1:DiagnosticoFallo ;
    rdfs:label "Doble programación de #FINALSUB" ;
    ns1:textoExtracto "En el programa principal se ha programado más de una vez el comando #FINALSUB. Solo se permite una única programación." .

ns1:NodoInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Nodo inexistente" ;
    ns1:textoExtracto "La variable del regulador (DRV) asociada al nodo Sercos (regulador o RCS-S) es incorrecta. El nodo no existe." .

ns1:NumeroDeNodoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Número de nodo incorrecto" ;
    ns1:textoExtracto "La variable del regulador (DRV) asociada al nodo Sercos (regulador o RCS-S) es incorrecta. No se ha programado el nodo." .

