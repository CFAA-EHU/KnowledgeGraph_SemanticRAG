    ex:textoExtracto "fallo en el módulo de contaje" .

ex:ReguladorSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ex:textoExtracto "fallo en el regulador Sercos" .

ex:SistemaCaptacion
    a ex:Sistema ;
    rdfs:label "Sistema de captación" ;
    ex:textoExtracto "fallo en el sistema de captación" .

