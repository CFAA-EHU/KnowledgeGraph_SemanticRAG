    ex:textoExtracto "parámetro máquina LIMIT-" .

ex:Parametro_INPOMAX
    a ex:Parametro ;
    rdfs:label "INPOMAX" ;
    ex:textoExtracto "parámetro INPOMAX" .

ex:Variable_V.A.RTPOSLIMIT.xn
    a ex:Parametro ;
    rdfs:label "V.A.RTPOSLIMIT.xn" ;
    ex:textoExtracto "variable V.A.RTPOSLIMIT.xn" .

ex:Variable_V.A.RTNEGLIMIT.xn
    a ex:Parametro ;
    rdfs:label "V.A.RTNEGLIMIT.xn" ;
    ex:textoExtracto "variable V.A.RTNEGLIMIT.xn" .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC ha perdido la referencia del cabezal en la transición de lazo abierto a lazo cerrado" .

ex:ModuloContaje
    a ex:ComponenteElectrico ;
