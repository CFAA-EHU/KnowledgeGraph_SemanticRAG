@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3709
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en el refresco de las entradas analógicas"@es ;
    ex:identificador "3709" ;
    ex:textoExtracto "3709 'Error en el refresco de las entradas analógicas' DETECCIÓN Durante la lectura de entradas analógicas. CAUSA Fallo en el proceso cíclico de lectura de entradas analógicas."@es ;
    ex:solucionaFallo [
        a               ex:Parametro ;
        rdfs:label      "INPOMAX" ;
        ex:identificador "INPOMAX" ;
        ex:textoExtracto "SOLUCIÓN Ajustar el parámetro INPOMAX."@es
    ] .

ex:ModuloEntradasAnalogicas
    a               ex:ComponenteElectrico ;
    rdfs:label      "módulo de entradas analógicas"@es ;
    ex:textoExtracto "módulo de entradas analógicas"@es ;
    ex:monitoreaParametro ex:Error_3709 .

ex:BusCAN
    a               ex:ComponenteElectrico ;
    rdfs:label      "bus CAN"@es ;
    ex:textoExtracto "bus CAN"@es ;
    ex:monitoreaParametro ex:Error_3709 .

ex:COMPCI
    a               ex:ComponenteElectrico ;
    rdfs:label      "COMPCI" ;
    ex:identificador "COMPCI" ;
    ex:textoExtracto "COMPCI"@es ;
    ex:monitoreaParametro ex:Error_3709 .