@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsulteEnLaDocumentacionLaListaDeVariablesPermitidas a ns1:TareaMantenimiento ;
    rdfs:label "Consulte en la documentación la lista de variables permitidas" ;
    ns1:solucionaFallo ns1:PrefijoDeVariableInexistente ;
    ns1:textoExtracto "SOLUCIÓN Consulte en la documentación la lista de variables permitidas." .

ns1:DesactivarLaTransformacionDeEjesParalelosParaPoderEjecutarElRestoDeFunciones a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConLaTransformacionPARALAXActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones." .

ns1:LosEjesProgramadosDebenPertenecerAlMismoCanal a ns1:TareaMantenimiento ;
    rdfs:label "Los ejes programados deben pertenecer al mismo canal" ;
    ns1:solucionaFallo ns1:PARALAXLosEjesParalelosDebenPertenecerAlMismoCanal ;
    ns1:textoExtracto "SOLUCIÓN Los ejes programados deben pertenecer al mismo canal." .

ns1:NoSePuedeActivarElEjeComoHirthPorFormarParteDeLaTransformacionPARALAX a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX" ;
    ns1:textoExtracto "2449 No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX." .

ns1:PARALAXLosEjesParalelosDebenPertenecerAlMismoCanal a ns1:DiagnosticoFallo ;
    rdfs:label "#PARALAX: Los ejes paralelos deben pertenecer al mismo canal" ;
    ns1:textoExtracto "2447 #PARALAX: Los ejes paralelos deben pertenecer al mismo canal." .

ns1:PrefijoDeVariableInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Prefijo de variable inexistente" ;
    ns1:textoExtracto "2446 Prefijo de variable inexistente." .

ns1:ProgramacionNoPermitidaConLaTransformacionPARALAXActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con la transformación #PARALAX activa" ;
    ns1:textoExtracto "2448 Programación no permitida con la transformación #PARALAX activa." .

