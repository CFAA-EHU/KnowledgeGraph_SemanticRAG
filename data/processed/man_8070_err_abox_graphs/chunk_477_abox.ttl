@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VerificarQueLasSentenciasSETAXOFREEAXNoIntentenCambiarLosEjeIncluidos_738ede0d33 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar que las sentencias #SETAX o #FREEAX no intenten cambiar los eje incluidos en una transformación" ;
    ns1:solucionaFallo ns1:EjesDeLaTransformacionActivaNoPuedenExcluirse ;
    ns1:textoExtracto "CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una" .

ns1:VerificarQueLosEjesProgramadosNoSeanHirth a ns1:TareaMantenimiento ;
    rdfs:label "Verificar que los ejes programados no sean Hirth" ;
    ns1:solucionaFallo ns1:EjeHirthNoPuedeSerActivado ;
    ns1:textoExtracto "SOLUCIÓN Los ejes programados no pueden ser Hirth." .

ns1:EjeHirthNoPuedeSerActivado a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Hirth no puede ser activado" ;
    ns1:textoExtracto "No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX." .

ns1:EjesDeLaTransformacionActivaNoPuedenExcluirse a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes de la transformación activa no pueden excluirse" ;
    ns1:textoExtracto "#PARALAX: Los ejes de la transformación activa, no pueden excluirse." .

