@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContacteConFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Contacte con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorEnLaGestionDelArbolDeVariables ;
    ns1:textoExtracto "SOLUCIÓN Contacte con Fagor Automation." .

ns1:ContratarOpcionDeSoftware a ns1:TareaMantenimiento ;
    rdfs:label "Contratar opción de software" ;
    ns1:textoExtracto "SOLUCIÓN Contratar la correspondiente opción de software." .

ns1:ModificacionDeEjesConGAPPOSActivo a ns1:AccionProhibida ;
    rdfs:label "Modificación de ejes con #GAPPOS activo" ;
    ns1:textoExtracto "2456 Con #GAPPOS activo no se permite cambiar los tres primeros ejes." .

ns1:ErrorEnLaGestionDelArbolDeVariables a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la gestión del árbol de variables" ;
    ns1:textoExtracto "2455 Error en la gestión del árbol de variables." .

