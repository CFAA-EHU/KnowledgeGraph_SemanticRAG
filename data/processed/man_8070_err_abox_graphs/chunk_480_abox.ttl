@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloEncoderVelocidadMaxima
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo por exceso de velocidad en encoder de eje/cabezal"@es ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El encóder del eje o cabezal ha superado la velocidad de giro máxima permitida. Al superar este límite, el eje o cabezal ha perdido el punto de referencia, por lo que las cotas leídas no son correctas."@es ;
    ex:solucionaFallo ex:TareaBusquedaReferenciaMaquina .

ex:TareaBusquedaReferenciaMaquina
    a ex:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina para lazo cerrado"@es ;
    ex:textoExtracto "SOLUCIÓN Realizar una búsqueda de referencia máquina para trabajar en lazo cerrado."@es .

ex:FalloAparcamientoEjeActivo
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo al aparcar eje en movimiento (cinemática activa)"@es ;
    ex:identificador "3718" ;
    ex:textoExtracto "3718 'RESET para aparcar ejes en movimiento o de la transformación/acoplo activo' [...] CAUSA El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática"@es .

ex:AccionResetAparcamiento
    a ex:AccionProhibida ;
    rdfs:label "RESET durante aparcamiento de ejes activos"@es ;
    ex:identificador "3718" ;
    ex:textoExtracto "3718 'RESET para aparcar ejes en movimiento o de la transformación/acoplo activo'"@es .