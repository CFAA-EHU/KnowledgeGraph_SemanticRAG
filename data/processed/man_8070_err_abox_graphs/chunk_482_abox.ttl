@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElValorDeLaEtiquetaNYElNumeroDeRepeticionesDebenSerNumerosEnteros a ns1:TareaMantenimiento ;
    rdfs:label "El valor de la etiqueta N y el número de repeticiones deben ser números enteros" ;
    ns1:textoExtracto "SOLUCIÓN El valor de la etiqueta N y el número de repeticiones deben ser números enteros." .

ns1:ProgramarParaLaEtiquetaNOParaElNumeroDeRepeticionesUnValorNoEntero a ns1:AccionProhibida ;
    rdfs:label "Programar para la etiqueta N o para el número de repeticiones un valor no entero" ;
    ns1:solucionaFallo ns1:RPTLaEtiquetaNYElNumeroDeRepeticionesDebenSerNumerosEnteros_beba24cfea ;
    ns1:textoExtracto "En la sentencia #RPT se ha programado para la etiqueta N o para el número de repeticiones un valor no entero." .

ns1:RealizarOtraSeleccionDePiercingOSustituirElMovimientoPorUnMovimientoI_270531f438 a ns1:TareaMantenimiento ;
    rdfs:label "Realizar otra selección de piercing o sustituir el movimiento por un movimiento independiente (#MOVE)" ;
    ns1:textoExtracto "SOLUCIÓN Realizar otra selección de piercing o sustituir el movimiento por un movimiento independiente (#MOVE)." .

ns1:RepetirProgramaEnElMismoPuntoQueLaEjecucionAnteriorConPreseleccionG92 a ns1:AccionProhibida ;
    rdfs:label "Repetir programa en el mismo punto que la ejecución anterior con preselección (G92)" ;
    ns1:solucionaFallo ns1:MovimientoNoPermitidoEnSeleccionDePiercingConG92_3c1d349cc9 ;
    ns1:textoExtracto "En la selección de piercing, se ha elegido la opción de repetir el programa en el mismo punto que la ejecución anterior, y el programa realiza una preselección (G92) en los bloques iniciales." .

ns1:MovimientoNoPermitidoEnSeleccionDePiercingConG92_3c1d349cc9 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento no permitido en selección de piercing con G92" ;
    ns1:textoExtracto "Movimiento no permitido en selección de piercing con G92. Programar #MOVE." .

ns1:RPTLaEtiquetaNYElNumeroDeRepeticionesDebenSerNumerosEnteros_beba24cfea a ns1:DiagnosticoFallo ;
    rdfs:label "#RPT: la etiqueta N y el número de repeticiones deben ser números enteros" ;
    ns1:textoExtracto "2465 #RPT: la etiqueta N y el número de repeticiones deben ser números enteros." .

