@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_3722
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 3722: Límite de ventana de palpado PLC"@es ;
    ex:identificador       "3722" ;
    ex:textoExtracto       "Error en los límites de la ventana de palpado desde PLC. DETECCIÓN Durante la ejecución. CAUSA En el palpado desde PLC están mal definidos los límites de la ventana de palpado (límite inferior > límite superior). SOLUCIÓN Revisar la programación del comando TOUCHPROBE en el programa PLC."@es .

ex:Error_3723
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 3723: G174 no admitido en modo visualizador"@es ;
    ex:identificador       "3723" ;
    ex:textoExtracto       "'No se admite G174 para eje en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca"@es .

ex:Comando_TOUCHPROBE
    a                     ex:Parametro ;
    rdfs:label            "TOUCHPROBE" ;
    ex:textoExtracto       "Revisar la programación del comando TOUCHPROBE en el programa PLC."@es ;
    ex:monitoreaParametro ex:Error_3722 .

ex:Funcion_G174 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "G174" ;
    ex:textoExtracto       "El CNC ha detectado la función G174 para un eje que está en modo visualizador"@es ;
    ex:monitoreaParametro ex:Error_3723 .