@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirDosSubrutinasLocalesConElMismoNombre a ns1:AccionProhibida ;
    rdfs:label "Definir dos subrutinas locales con el mismo nombre" ;
    ns1:mitigaRiesgo ns1:SubrutinaLocalYaExistente ;
    ns1:textoExtracto "En un programa no puede haber dos subrutinas locales con el mismo nombre." .

ns1:DefinirElInicioDeLaSubrutinaLocal a ns1:TareaMantenimiento ;
    rdfs:label "Definir el inicio de la subrutina local" ;
    ns1:solucionaFallo ns1:SeEsperaNombreDeSubrutina_90d32f42d8 ;
    ns1:textoExtracto "Definir el inicio de la subrutina local con \"%L nombre\"." .

ns1:ProgramacionHEADNoPermitidaEnCinematicasSinCabezal_6f5752c5f4 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación HEAD no permitida en cinemáticas sin cabezal" ;
    ns1:textoExtracto "Programación HEAD no permitida en cinemáticas sin cabezal." .

ns1:ProgramarRTCPSinGiroDelSistemaDeCoordenadasEnCinematicasCabezalMesa a ns1:AccionProhibida ;
    rdfs:label "Programar RTCP sin giro del sistema de coordenadas en cinemáticas cabezal-mesa" ;
    ns1:mitigaRiesgo ns1:ProgramacionCOROTFIXNoPermitidaEnCinematicasCabezalMesaTYPE1316 ;
    ns1:textoExtracto "Este tipo de cinemática no admite esa programación. Programar el RTCP con giro del sistema de coordenadas o redefinir la cinemática como vectorial (TYPE 52)." .

ns1:ProgramacionCOROTFIXNoPermitidaEnCinematicasCabezalMesaTYPE1316 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación COROT=FIX no permitida en cinemáticas cabezal-mesa, TYPE=13..16" ;
    ns1:textoExtracto "Se ha programado un RTCP sin giro del sistema de coordenadas para una cinemática cabezal+mesa (TYPE=13..16)." .

ns1:SeEsperaNombreDeSubrutina_90d32f42d8 a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera nombre de subrutina" ;
    ns1:textoExtracto "Se ha programado una subrutina local (%L) sin definir su nombre." .

ns1:SubrutinaLocalYaExistente a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina local ya existente" ;
    ns1:textoExtracto "Hay definidas más de una subrutina local (%L) con el mismo nombre." .

