@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionHEADNoPermitidaEnCinematicasSinCabezal a ns1:AccionProhibida ;
    rdfs:label "Programación HEAD no permitida en cinemáticas sin cabezal" ;
    ns1:textoExtracto "2469 Programación HEAD no permitida en cinemáticas sin cabezal." .

ns1:ProgramacionTABLEOCOROTNoPermitidaEnCinematicasSinMesa a ns1:AccionProhibida ;
    rdfs:label "Programación TABLE o COROT no permitida en cinemáticas sin mesa" ;
    ns1:textoExtracto "2470 Programación TABLE o COROT no permitida en cinemáticas sin mesa." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:SeHaProgramadoUnRTCPConLaOpcionHEADParaUnaCinematicaSinCabezal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SeHaProgramadoUnRTCPConLaOpcionHEADParaUnaCinematicaSinCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal" ;
    ns1:textoExtracto "CAUSA Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal." .

