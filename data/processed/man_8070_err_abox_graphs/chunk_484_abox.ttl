@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3727
    a ex:Alarma ;
    rdfs:label "No se permite desactivar un eje múltiple sin entrar en posición"@es ;
    ex:textoExtracto "3727 'No se permite desactivar un eje múltiple sin entrar en posición'"@es ;
    ex:identificador "3727" .

ex:Alarma_3728
    a ex:Alarma ;
    rdfs:label "Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido"@es ;
    ex:textoExtracto "3728 'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido'"@es ;
    ex:identificador "3728" .

ex:DiagnosticoFallo_3727
    a ex:DiagnosticoFallo ;
    rdfs:label "Desactivación de eje múltiple con movimiento pendiente"@es ;
    ex:textoExtracto "Al desactivar la marca SWITCH del eje. CAUSA El CNC ha intentado desactivar un eje de un grupo múltiple, antes de que el eje esté en posición, es decir, con movimiento pendiente."@es ;
    ex:activaAlarma ex:Alarma_3727 .

ex:DiagnosticoFallo_3728
    a ex:DiagnosticoFallo ;
    rdfs:label "Comando en ejecución en eje múltiple durante desactivación"@es ;
    ex:textoExtracto "Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido"@es ;
    ex:activaAlarma ex:Alarma_3728 .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC para control de ejes múltiples"@es ;
    ex:textoExtracto "En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_3727 ;
    ex:solucionaFallo ex:DiagnosticoFallo_3728 .