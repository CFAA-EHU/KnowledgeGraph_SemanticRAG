@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarUnFicheroDeMaterial a ns1:TareaMantenimiento ;
    rdfs:label "Activar un fichero de material" ;
    ns1:solucionaFallo ns1:NoHayFicheroDeMaterialActivo ;
    ns1:textoExtracto "SOLUCIÓN Activar un fichero de material." .

ns1:ActivarUnFicheroDeMaterialConTablaCutting a ns1:TareaMantenimiento ;
    rdfs:label "Activar un fichero de material con tabla Cutting" ;
    ns1:solucionaFallo ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaCutting ;
    ns1:textoExtracto "SOLUCIÓN Activar un fichero de material que tenga una tabla de Cutting." .

ns1:ActivarUnFicheroDeMaterialConTablaPiercing a ns1:TareaMantenimiento ;
    rdfs:label "Activar un fichero de material con tabla Piercing" ;
    ns1:solucionaFallo ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaPiercing ;
    ns1:textoExtracto "SOLUCIÓN Activar un fichero de material que tenga una tabla de Piercing." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:EsObligatorioProgramarElNombreDelFicheroDeMaterialYOLaTablaSeleccionada,
        ns1:NumeroDeSetFueraDeRango,
        ns1:ProgramacionConOpcionHEADParaCinematicaSinCabezal,
        ns1:ProgramacionTABLEOCOROTNoPermitidaEnCinematicasSinMesa_dec792e1aa ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EsObligatorioProgramarElNombreDelFicheroDeMaterialYOLaTablaSeleccionada a ns1:DiagnosticoFallo ;
    rdfs:label "Es obligatorio programar el nombre del fichero de material y/o la tabla seleccionada" ;
    ns1:textoExtracto "2471 Es obligatorio programar el nombre del fichero de material y/o la tabla seleccionada. DETECCIÓN Durante la ejecución." .

ns1:NoHayFicheroDeMaterialActivo a ns1:DiagnosticoFallo ;
    rdfs:label "No hay fichero de material activo" ;
    ns1:textoExtracto "2472 No hay fichero de material activo. DETECCIÓN Durante la ejecución." .

ns1:NumeroDeSetFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Número de set fuera de rango" ;
    ns1:textoExtracto "2473 Número de set fuera de rango. DETECCIÓN Durante la ejecución." .

ns1:ProgramacionConOpcionHEADParaCinematicaSinCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Programación con opción HEAD para cinemática sin cabezal" ;
    ns1:textoExtracto "con la opción HEAD para una cinemática sin cabezal. SOLUCIÓN Revisar la programación." .

ns1:ProgramacionTABLEOCOROTNoPermitidaEnCinematicasSinMesa_dec792e1aa a ns1:DiagnosticoFallo ;
    rdfs:label "Programación TABLE o COROT no permitida en cinemáticas sin mesa" ;
    ns1:textoExtracto "2470 Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución." .

ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaCutting a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente sin un material activo que tenga tabla Cutting" ;
    ns1:textoExtracto "2475 Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución." .

ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaPiercing a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente sin un material activo que tenga tabla Piercing" ;
    ns1:textoExtracto "2474 Variable inexistente sin un material activo que tenga tabla Piercing. DETECCIÓN Durante la ejecución." .

