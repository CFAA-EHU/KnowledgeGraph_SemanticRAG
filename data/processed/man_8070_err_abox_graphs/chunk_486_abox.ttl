@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarUnFicheroDeMaterialQueTengaUnaTablaDeCutting a ns1:TareaMantenimiento ;
    rdfs:label "Activar un fichero de material que tenga una tabla de Cutting" ;
    ns1:solucionaFallo ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaCutting ;
    ns1:textoExtracto "SOLUCIÓN Activar un fichero de material que tenga una tabla de Cutting." .

ns1:TablaInexistenteEnElFicheroDeMaterialActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Tabla inexistente en el fichero de material activo" ;
    ns1:textoExtracto "2476 Tabla inexistente en el fichero de material activo. DETECCIÓN" .

ns1:VariableInexistenteSinUnMaterialActivoQueTengaTablaCutting a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente sin un material activo que tenga tabla Cutting" ;
    ns1:textoExtracto "2475 Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting." .

