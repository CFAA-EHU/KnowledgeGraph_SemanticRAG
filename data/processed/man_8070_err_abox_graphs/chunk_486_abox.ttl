@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3732
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ex:identificador "3732" ;
    ex:textoExtracto "3732 Error en el refresco de contajes locales. DETECCIÓN En la lectura de los contajes analógicos locales desde el lazo de posición. CAUSA Alarma en alguna de las entradas de captación locales." .

ex:Error_3733
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de entradas analógicas locales" ;
    ex:identificador "3733" ;
    ex:textoExtracto "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas" .

ex:Parametro_G174
    a ex:Parametro ;
    rdfs:label "Parámetro G174" ;
    ex:identificador "G174" ;
    ex:textoExtracto "SOLUCIÓN Modificar el valor programado en la G174." ;
    ex:solucionaFallo ex:Error_3732 .

ex:EntradasCaptacionLocales
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas de captación locales" ;
    ex:textoExtracto "Alarma en alguna de las entradas de captación locales." ;
    ex:activaAlarma ex:Error_3732 .

ex:ContajesLocales
    a ex:ComponenteElectrico ;
    rdfs:label "Contajes analógicos locales" ;
    ex:textoExtracto "En la lectura de los contajes analógicos locales desde el lazo de posición." ;
    ex:monitoreaParametro ex:Parametro_G174 .