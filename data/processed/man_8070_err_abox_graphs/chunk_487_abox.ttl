@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3733
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3733: Error en el refresco de entradas analógicas locales" ;
    ex:textoExtracto "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas analógicas locales desde el lazo de posición. CAUSA Alarma en una entrada analógica local. SOLUCIÓN Revisar el conexionado de las entradas y la sonda conectada." ;
    ex:identificador "3733" .

ex:Error_3734
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3734: Opción de software PWM no permitida" ;
    ex:textoExtracto "3734 'Opción de software PWM no permitida' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no tiene activa la opción de software para la prestación PWM. SOLUCIÓN Contratar la correspondiente opción." ;
    ex:identificador "3734" .

ex:Error_3735
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3735: Error en la activación/desactivación del PWM" ;
    ex:textoExtracto "3735 'Error en la activación/desactivación del PWM' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA La parametrización del PWM es incorrecta. SOLUCIÓN Verificar las siguientes condiciones: • El parámetro NLOCOUT debe ser 8. • El parámetro PWMOUTPUT no puede ser superior a 2 (1, 2)." ;
    ex:identificador "3735" .

ex:Parametro_NLOCOUT
    a ex:Parametro ;
    rdfs:label "Parámetro NLOCOUT" ;
    ex:textoExtracto "El parámetro NLOCOUT debe ser 8." ;
    ex:valor "8" ;
    ex:documentadoEn ex:Error_3735 .

ex:Parametro_PWMOUTPUT
    a ex:Parametro ;
    rdfs:label "Parámetro PWMOUTPUT" ;
    ex:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (1, 2)." ;
    ex:valor "1-2" ;
    ex:documentadoEn ex:Error_3735 .

ex:Error_3736
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3736: El parámetro máquina PWMOUTPUT es 0" ;
    ex:textoExtracto "3736 'El parámetro máquina PWMOUTPUT es 0' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA El parámetro PWMOUTPUT no puede tomar valor 0. SOLUCIÓN Asignar al parámetro PWMOUTPUT un valor dentro de rango (1-2)." ;
    ex:identificador "3736" ;
    ex:solucionaFallo ex:Parametro_PWMOUTPUT .

ex:Error_3737
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3737: Placa de expansión no compatible con PWM" ;
    ex:textoExtracto "3737 'Placa de expansión no compatible con PWM' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA El hardware no está preparado para la prestación PWM. SOLUCIÓN Verificar que existe una placa de expansión tipo Sercos, con las 2 primeras salidas locales preparadas para conmutación rápida. El ID software de la FPGA expansión debe ser igual o superior a 1.3, y su ID hardware igual o superior a 1.2." ;
    ex:identificador "3737" .

ex:PlacaExpansion_Sercos
    a ex:ComponenteElectrico ;
    rdfs:label "Placa de expansión tipo Sercos" ;
    ex:textoExtracto "placa de expansión tipo Sercos, con las 2 primeras salidas locales preparadas para conmutación rápida. El ID software de la FPGA expansión debe ser igual o superior a 1.3, y su ID hardware igual o superior a 1.2." ;
    ex:identificador "Sercos" ;
    ex:documentadoEn ex:Error_3737 .

ex:Error_3738
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3738: El eje se ha movido con el CNC apagado" ;
    ex:textoExtracto "3738 'El eje se ha movido con el CNC apagado' DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del regulador no se corresponde con la cota salvada en la última sesión de CNC. El eje se ha movido más de lo indicado en el parámetro MAXDIFREF." ;
    ex:identificador "3738" .

ex:Parametro_MAXDIFREF
    a ex:Parametro ;
    rdfs:label "Parámetro MAXDIFREF" ;
    ex:textoExtracto "El eje se ha movido más de lo indicado en el parámetro MAXDIFREF." ;
    ex:documentadoEn ex:Error_3738 .