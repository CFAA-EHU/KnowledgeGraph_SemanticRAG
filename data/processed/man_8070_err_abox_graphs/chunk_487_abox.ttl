@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaSentenciaTECHTABLEPermiteActivarUnaTablaTecnologicaGenerica a ns1:AvisoSeguridad ;
    rdfs:label "La sentencia #TECHTABLE permite activar una tabla tecnológica genérica" ;
    ns1:mitigaRiesgo ns1:LaSentenciaTECHTABLEHaIntentadoActivarLasTablasDePiercingYCutting ;
    ns1:textoExtracto "SOLUCIÓN La sentencia #TECHTABLE permite activar una tabla tecnológica genérica." .

ns1:NombreDeTablaNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de tabla no permitido" ;
    ns1:textoExtracto "2478 Sentencia no permitida sin tabla PIERCING en el fichero de material activo." .

ns1:RevisarProgramacionYQueTablasExisten a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación y qué tablas existen" ;
    ns1:solucionaFallo ns1:TablaInexistenteEnElFicheroDeMaterialActivo_414261e299 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación y qué tablas existen." .

ns1:SentenciaNoPermitidaSinTablaPIERCINGEnElFicheroDeMaterialActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida sin tabla PIERCING en el fichero de material activo" ;
    ns1:textoExtracto "2478 Sentencia no permitida sin tabla PIERCING en el fichero de material activo." .

ns1:LaSentenciaTECHTABLEHaIntentadoActivarLasTablasDePiercingYCutting a ns1:AccionProhibida ;
    rdfs:label "La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting" ;
    ns1:textoExtracto "CAUSA La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting." .

ns1:TablaInexistenteEnElFicheroDeMaterialActivo_414261e299 a ns1:DiagnosticoFallo ;
