@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CargarUnFicheroDeMaterialConTablaDeCutting a ns1:TareaMantenimiento ;
    rdfs:label "Cargar un fichero de material con tabla de Cutting" ;
    ns1:solucionaFallo ns1:ErrorDeSentenciaCUTTINGSinTablaCUTTING ;
    ns1:textoExtracto "SOLUCIÓN Cargar un fichero de material con tabla de Cutting." .

ns1:CargarUnFicheroDeMaterialConTablaDePiercing a ns1:TareaMantenimiento ;
    rdfs:label "Cargar un fichero de material con tabla de Piercing" ;
    ns1:solucionaFallo ns1:ErrorDeSentenciaPIERCINGSinTablaPIERCING ;
    ns1:textoExtracto "SOLUCIÓN Cargar un fichero de material con tabla de Piercing." .

ns1:RepetirElProcesoInterrupcionDelProgramaYSeleccionarTipoDeContinuacion a ns1:TareaMantenimiento ;
    rdfs:label "Repetir el proceso (interrupción del programa y seleccionar tipo de continuación)" ;
    ns1:solucionaFallo ns1:ErrorEnSTARTParaContinuarPerfilPorDatosNoValidos ;
    ns1:textoExtracto "SOLUCIÓN Repetir el proceso (interrupción del programa y seleccionar tipo de continuación)." .

ns1:STARTParaContinuarPerfilPorDatosNoValidos a ns1:AccionProhibida ;
    rdfs:label "START para continuar perfil por datos no válidos" ;
    ns1:textoExtracto "No se admite START para continuar perfil por datos no válidos." .

ns1:SentenciaNoPermitidaSinTablaCUTTING a ns1:AccionProhibida ;
    rdfs:label "Sentencia no permitida sin tabla CUTTING" ;
    ns1:textoExtracto "Sentencia no permitida sin tabla CUTTING en el fichero de material activo." .

ns1:SentenciaNoPermitidaSinTablaPIERCING a ns1:AccionProhibida ;
    rdfs:label "Sentencia no permitida sin tabla PIERCING" ;
    ns1:textoExtracto "Sentencia no permitida sin tabla PIERCING en el fichero de material activo." .

ns1:ErrorDeSentenciaCUTTINGSinTablaCUTTING a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sentencia #CUTTING sin tabla CUTTING" ;
    ns1:textoExtracto "Se ha programado la sentencia #CUTTING pero el fichero de material activo no tiene tabla de Cutting." .

ns1:ErrorDeSentenciaPIERCINGSinTablaPIERCING a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sentencia #PIERCING sin tabla PIERCING" ;
    ns1:textoExtracto "Se ha programado la sentencia #PIERCING pero el fichero de material activo no tiene tabla de Piercing." .

ns1:ErrorEnSTARTParaContinuarPerfilPorDatosNoValidos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en START para continuar perfil por datos no válidos" ;
    ns1:textoExtracto "Error en el fichero que guardan los datos para continuar." .

