@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacionParaEvitarElMovimientoDeEjeRotativoConKINIDTIPAc_c0b1400ab6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación para evitar el movimiento de eje rotativo con KIN ID TIP activo y compensación de radio activa" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar un origen distinto del activo." .

ns1:RevisarLaProgramacionYProgramarUnOrigenDistintoDelActivo a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación y programar un origen distinto del activo" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar un origen distinto del activo." .

ns1:RevisarLaProgramacion_54bf067257 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:KINORGNoSeAdmiteElOrigenActivo,
        ns1:MovimientoDeEjeRotativoNoPermitidoConKINIDTIPActivoYCompensacionDeRad_bc6e1162eb,
        ns1:SeHaProgramadoLaSentenciaKINIDConUnValorDeTIPNoValido,
        ns1:SeHaProgramadoLaSentenciaKINORGConUnOrigenNoValido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. El rango de valores admitido para TIP es 0/1." .

ns1:KINORGNoSeAdmiteElOrigenActivo a ns1:DiagnosticoFallo ;
    rdfs:label "#KINORG: no se admite el origen activo" ;
    ns1:textoExtracto "CAUSA En la sentencia #KINORG no se permite programar el origen activo." .

ns1:MovimientoDeEjeRotativoNoPermitidoConKINIDTIPActivoYCompensacionDeRad_bc6e1162eb a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42)" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42)." .

ns1:SeHaProgramadoLaSentenciaKINIDConUnValorDeTIPNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado la sentencia #KINID con un valor de TIP no válido" ;
    ns1:textoExtracto "CAUSA Se ha programado la sentencia #KINID con un valor de TIP no válido." .

ns1:SeHaProgramadoLaSentenciaKINORGConUnOrigenNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado la sentencia #KINORG con un origen no válido" ;
    ns1:textoExtracto "CAUSA Se ha programado la sentencia #KINORG con un origen no válido." .

