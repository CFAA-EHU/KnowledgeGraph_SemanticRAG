@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error2486NoSeAdmiteRENAMEDelCabezalEnModoEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2486 - No se admite #RENAME del cabezal en modo eje C" ;
    ns1:textoExtracto "No se admite #RENAME del cabezal en modo eje C." .

ns1:MoverEjeRotativoConCompensacionDeRadioActiva a ns1:AccionProhibida ;
    rdfs:label "Mover eje rotativo con compensación de radio activa" ;
    ns1:mitigaRiesgo ns1:DesactivarCompensacionDeRadioParaMoverElEjeRotativo ;
    ns1:textoExtracto "Se ha intentado mover un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP] y la compensación de radio (G41/G42)." .

ns1:ProgramarEjeLinealYRotativoEnElMismoBloqueConKINIDTIPActivo a ns1:AccionProhibida ;
    rdfs:label "Programar eje lineal y rotativo en el mismo bloque con KIN ID TIP activo" ;
    ns1:mitigaRiesgo ns1:MoverEjeRotativoYEjeLinealIndividualmente ;
    ns1:textoExtracto "No se permite programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo." .

ns1:RENAMEDelCabezalEnModoEjeC a ns1:AccionProhibida ;
    rdfs:label "#RENAME del cabezal en modo eje C" ;
    ns1:textoExtracto "No se admite #RENAME del cabezal en modo eje C." .

ns1:DesactivarCompensacionDeRadioParaMoverElEjeRotativo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar compensación de radio para mover el eje rotativo" ;
    ns1:solucionaFallo ns1:Error2485NoSePermiteProgramarEnElMismoBloqueEjeLinealYRotativoConKINIDTIPActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo." .

ns1:MoverEjeRotativoYEjeLinealIndividualmente a ns1:TareaMantenimiento ;
    rdfs:label "Mover eje rotativo y eje lineal individualmente" ;
    ns1:solucionaFallo ns1:Error2485NoSePermiteProgramarEnElMismoBloqueEjeLinealYRotativoConKINIDTIPActivo ;
    ns1:textoExtracto "SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:Error2485NoSePermiteProgramarEnElMismoBloqueEjeLinealYRotativoConKINIDTIPActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2485 - No se permite programar en el mismo bloque eje lineal y rotativo con KIN ID TIP activo" ;
    ns1:textoExtracto "No se permite programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo." .

