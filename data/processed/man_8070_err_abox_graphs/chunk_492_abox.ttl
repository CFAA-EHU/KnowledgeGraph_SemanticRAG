@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElCNCHaIntentadoActivarFACECYLConUnTipoDeCinematicaQueNoSeCorresponde a ns1:AccionProhibida ;
    rdfs:label "El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde" ;
    ns1:mitigaRiesgo ns1:ActivarFACECYLSinCinematicaOConUnaCinematicaDelTipo414243 ;
    ns1:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado. SOLUCIÓN Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43." .

ns1:NoSeAdmiteRENAMEDelCabezalEnModoEjeC a ns1:AccionProhibida ;
    rdfs:label "No se admite #RENAME del cabezal en modo eje C" ;
    ns1:mitigaRiesgo ns1:NoSePermiteRenombrarElEjeActivoComoEjeC ;
    ns1:textoExtracto "2486 No se admite #RENAME del cabezal en modo eje C. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C." .

ns1:ProgramarLOADGAPTABLEAntesDeGAPCTRLONOLEAP a ns1:AccionProhibida ;
    rdfs:label "Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP" ;
    ns1:mitigaRiesgo ns1:ProgramarLOADGAPTABLEAntesDeGAPCTRLONOLEAP_6fcb0d2c97 ;
    ns1:textoExtracto "2488 Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina." .

ns1:ActivarFACECYLSinCinematicaOConUnaCinematicaDelTipo414243 a ns1:TareaMantenimiento ;
    rdfs:label "Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43" ;
    ns1:solucionaFallo ns1:LaCinematicaProgramadaEnLasSentenciasFACECYLNoEsDelTipoAdecuado ;
    ns1:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado. SOLUCIÓN Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43." .

ns1:LaCinematicaProgramadaEnLasSentenciasFACECYLNoEsDelTipoAdecuado a ns1:DiagnosticoFallo ;
    rdfs:label "La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado" ;
    ns1:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado." .

ns1:NoSePermiteRenombrarElEjeActivoComoEjeC a ns1:TareaMantenimiento ;
    rdfs:label "No se permite renombrar el eje activo como eje C" ;
    ns1:solucionaFallo ns1:SeHaIntentadoRenombrarElCabezalQueEstaTrabajandoComoEjeC ;
    ns1:textoExtracto "2486 No se admite #RENAME del cabezal en modo eje C. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C." .

ns1:PorParametroMaquina a ns1:DiagnosticoFallo ;
    rdfs:label "Por parámetro máquina" ;
    ns1:textoExtracto "2488 Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina." .

ns1:ProgramarLOADGAPTABLEAntesDeGAPCTRLONOLEAP_6fcb0d2c97 a ns1:TareaMantenimiento ;
    rdfs:label "Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP" ;
    ns1:solucionaFallo ns1:PorParametroMaquina ;
    ns1:textoExtracto "2488 Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina." .

ns1:SeHaIntentadoRenombrarElCabezalQueEstaTrabajandoComoEjeC a ns1:DiagnosticoFallo ;
