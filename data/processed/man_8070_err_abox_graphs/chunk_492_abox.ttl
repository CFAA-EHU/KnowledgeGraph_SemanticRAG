@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3750
    a               ex:DiagnosticoFallo ;
    ex:identificador "3750" ;
    rdfs:label      "Contaje de eje no inhibible"@es ;
    ex:textoExtracto "El contaje de este eje no es susceptible de ser inhibido. [...] SOLUCIÓN Cambiar la posición de acercamiento a la pieza."@es ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Inhibición manual del contaje de eje sin captación RCS-S"@es ;
        ex:textoExtracto "Sólo puede inhibirse un contaje del módulo RCS-S. Revisar el bit 0x80000000 de AXISOPTION del eje involucrado en la maniobra de desactivación."@es
    ] ;
    ex:mitigaRiesgo [
        a               ex:AvisoSeguridad ;
        rdfs:label      "Desactivación de eje sin captación RCS-S"@es ;
        ex:textoExtracto "DETECCIÓN Al desactivar un eje. CAUSA El eje que se desactiva no tiene una captación en el módulo RCS-S."@es
    ] .

ex:Fallo_3751
    a               ex:DiagnosticoFallo ;
    ex:identificador "3751" ;
    rdfs:label      "Drive Feedback no válido"@es ;
    ex:textoExtracto "Drive Feedback no válido. DETECCIÓN Durante el arranque del CNC o tras un reset."@es .

ex:Modulo_RCS_S
    a               ex:Sistema ;
    rdfs:label      "Módulo RCS-S"@es ;
    ex:textoExtracto "módulo RCS-S"@es ;
    ex:monitoreaParametro [
        a               ex:Parametro ;
        ex:identificador "AXISOPTION" ;
        ex:valor         "0x80000000" ;
        ex:textoExtracto "bit 0x80000000 de AXISOPTION del eje involucrado"@es
    ] .

ex:Parametro_3750_AXISOPTION
    a               ex:Parametro ;
    ex:identificador "AXISOPTION" ;
    ex:valor         "0x80000000" ;
    ex:textoExtracto "bit 0x80000000 de AXISOPTION"@es ;
    ex:monitoreaParametro ex:Modulo_RCS_S .