@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarTablaDeCalibracionGap a ns1:TareaMantenimiento ;
    rdfs:label "Activar Tabla de Calibración Gap" ;
    ns1:solucionaFallo ns1:Error2488 ;
    ns1:textoExtracto "SOLUCIÓN Activar una tabla de calibración del gap mediante el comando #LOAD GAPTABLE." .

ns1:RevisarComodinFueraSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Comodín Fuera Subrutina" ;
    ns1:solucionaFallo ns1:Error2492 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Dentro de la subrutina, programar #CAX sin parámetros." .

ns1:RevisarProgramacionRTCP a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Programación RTCP" ;
    ns1:solucionaFallo ns1:Error2489 ;
    ns1:textoExtracto "SOLUCIÓN Mantener en el sistema #KIN ID [TIP] o #RTCP durante la inspección de herramienta." .

ns1:RevisarProgramacionSubrutinaCAX a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Programación Subrutina CAX" ;
    ns1:solucionaFallo ns1:Error2491 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Dentro de la subrutina, programar #CAX sin parámetros." .

ns1:RevisarSecuenciaRTCP a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Secuencia RTCP" ;
    ns1:solucionaFallo ns1:Error2490 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar la secuencia correcta." .

ns1:Error2488 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2488" ;
    ns1:textoExtracto "Se ha intentado usar la sonda del gap (#GAPCTRL ON o #LEAP) sin activar dicha tabla." .

ns1:Error2489 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2489" ;
    ns1:textoExtracto "No se permite programar #RTCP en INSPECCIÓN, con KINID TIP activo." .

ns1:Error2490 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2490" ;
    ns1:textoExtracto "La secuencia de activación y desactivación del RTCP y CS/ACS, en las cinemáticas de mesas sin giro del sistema de coordenadas, es fija." .

ns1:Error2491 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2491" ;
    ns1:textoExtracto "Se ha programado la sentencia #CAX con parámetros de llamada, dentro de la subrutina asociada a #CAX." .

ns1:Error2492 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2492" ;
    ns1:textoExtracto "Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

