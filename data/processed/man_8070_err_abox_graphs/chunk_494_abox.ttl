@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionIncorrectaDelOrigenDelEjeCEnLaInstruccionFACECYL a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta del origen del eje C en la instrucción #FACE/CYL" ;
    ns1:textoExtracto "No se ha programado el origen del eje C en la instrucción #FACECYL." .

ns1:RevisionDeProgramacionParaComodinesSOCFueraDeSubrutinaCAX a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para comodines @S o @C fuera de subrutina #CAX" ;
    ns1:solucionaFallo ns1:DeteccionDeComodinNoPermitidoFueraDeLaSubrutinaAsociadaACAX ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. No se permite el uso de estos comodines fuera de la subrutina asociada a #CAX." .

ns1:RevisionDeProgramacionParaInstruccionFACECYL a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para instrucción #FACE/CYL" ;
    ns1:solucionaFallo ns1:DeteccionDeErrorEnLaProgramacionDelOrigenDelEjeC ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SubrutinaAsociadaACAX a ns1:Parametro ;
    rdfs:label "Subrutina asociada a #CAX" ;
    ns1:textoExtracto "(parámetro máquina CAXSUB)." .

ns1:UsoDeComodinesSOCFueraDeLaSubrutinaAsociadaACAX a ns1:AccionProhibida ;
    rdfs:label "Uso de comodines @S o @C fuera de la subrutina asociada a #CAX" ;
    ns1:textoExtracto "Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

ns1:DeteccionDeComodinNoPermitidoFueraDeLaSubrutinaAsociadaACAX a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de comodín no permitido fuera de la subrutina asociada a #CAX" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:DeteccionDeErrorEnLaProgramacionDelOrigenDelEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de error en la programación del origen del eje C" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

