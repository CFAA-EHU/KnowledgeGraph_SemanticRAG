@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3755
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Parámetro máquina PLOOPRESOL incompatible con versión del regulador"@es ;
    ex:textoExtracto "3755 Parámetro máquina PLOOPRESOL incompatible con versión del regulador. DETECCIÓN Durante el arranque del CNC o validación de los parámetros máquina. CAUSA El regulador no tiene la versión adecuada para el valor de PLOOPRESOL."@es ;
    ex:identificador "3755" .

ex:Parametro_PLOOPRESOL
    a               ex:Parametro ;
    rdfs:label      "PLOOPRESOL" ;
    ex:textoExtracto "Parámetro máquina PLOOPRESOL incompatible con versión del regulador"@es ;
    ex:identificador "PLOOPRESOL" .

ex:Sensor_GAPCTRL
    a               ex:Sensor ;
    rdfs:label      "Sensor de control de gap"@es ;
    ex:textoExtracto "Con el control de gap en n ejes activo (#GAPCTRL), el ángulo programado para la compensación del gap es incompatible con la dirección del sensor."@es ;
    ex:identificador "#GAPCTRL" .

ex:Fallo_GAPCTRL
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Ángulo de compensación de gap incompatible con dirección del sensor"@es ;
    ex:textoExtracto "Con el control de gap en n ejes activo (#GAPCTRL), el ángulo programado para la compensación del gap es incompatible con la dirección del sensor. SOLUCIÓN Cambiar el ángulo de programación."@es ;
    ex:identificador "Fallo_GAPCTRL" .

ex:Fallo_GAPCTRL
    ex:solucionaFallo ex:Sensor_GAPCTRL .

ex:Fallo_3755
    ex:solucionaFallo ex:Parametro_PLOOPRESOL .