@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_3759_RPS
    a                   ex:DiagnosticoFallo ;
    ex:identificador    "3759" ;
    rdfs:label          "RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor"@es ;
    ex:textoExtracto    "3759 RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Sobrecorriente en la salida del freno-contactor. SOLUCIÓN Las posibles soluciones son las siguientes: • Revisar el cableado del conector X12 y del contactor de potencia. • Falta la alimentación de 24 Vdc en el conector X12 o es superior a 26 Vdc. • Contactor estropeado."@es ;
    ex:solucionaFallo   ex:ComponenteElectrico_X12 , ex:ContactorPotencia_RPS ;
    .

ex:Fallo_3760_RPS
    a                   ex:DiagnosticoFallo ;
    ex:identificador    "3760" ;
    rdfs:label          "RPS, tensión de bus por debajo de la deseada"@es ;
    ex:textoExtracto    "3760 RPS, tensión de bus por debajo de la deseada. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Caída inesperada de la"@es ;
    .

ex:ComponenteElectrico_X12
    a                   ex:ComponenteElectrico ;
    ex:identificador    "X12" ;
    rdfs:label          "Conector X12 (freno-contactor)"@es ;
    ex:textoExtracto    "Revisar el cableado del conector X12 [...] Falta la alimentación de 24 Vdc en el conector X12 o es superior a 26 Vdc."@es ;
    .

ex:ContactorPotencia_RPS
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Contactor de potencia (freno-contactor RPS)"@es ;
    ex:textoExtracto    "fallo en el control del contactor [...] Revisar el cableado [...] del contactor de potencia. [...] Contactor estropeado."@es ;
    .

ex:Sistema_RPS
    a                   ex:Sistema ;
    ex:identificador    "RPS" ;
    rdfs:label          "Sistema RPS"@es ;
    ex:textoExtracto    "maniobra de la RPS con las marcas PWSENAF y PWSENAS"@es ;
    ex:tieneComponente  ex:ComponenteElectrico_X12 , ex:ContactorPotencia_RPS ;
    .