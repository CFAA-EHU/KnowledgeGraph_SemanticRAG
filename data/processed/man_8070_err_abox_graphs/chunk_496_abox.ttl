@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDelGapSoloEnEjesConSIMMODETrue a ns1:TareaMantenimiento ;
    rdfs:label "Activación del gap solo en ejes con SIMMODE=True" ;
    ns1:textoExtracto "SOLUCIÓN El gap sólo se puede activar en ejes con SIMMODE=True." .

ns1:GapProgramadoMenorQueGAPSMINLEVEL a ns1:DiagnosticoFallo ;
    rdfs:label "Gap programado menor que GAPSMINLEVEL" ;
    ns1:textoExtracto "El gap programado debe ser superior al parámetro máquina GAPSMINLEVEL. DETECCIÓN Durante la ejecución. CAUSA El valor programado del gap es inferior o igual al parámetro máquina GAPSMINLEVEL." .

ns1:LimiteMinimoDelGap a ns1:Parametro ;
    rdfs:label "Límite mínimo del gap" ;
    ns1:identificador "GAPSMINLEVEL" ;
    ns1:textoExtracto "El gap programado debe ser superior al parámetro máquina GAPSMINLEVEL." .

ns1:ModoDeSimulacion a ns1:Parametro ;
    rdfs:label "Modo de simulación" ;
    ns1:identificador "SIMMODE" ;
    ns1:textoExtracto "No es posible simulación de GAP con el parámetro SIMMODE = FALSE." .

ns1:MovimientoDeEjeRotativoConRTCPSTATICYG41G42 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de eje rotativo con RTCP STATIC y G41/G42" ;
    ns1:textoExtracto "Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio activa (G41/G42)." .

ns1:ProgramacionDeMultiplesComandosEnGRAPHCMD a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de múltiples comandos en #GRAPHCMD" ;
    ns1:textoExtracto "Sólo se permite programar un comando. DETECCIÓN Durante la ejecución. CAUSA Se han programado demasiados comandos en la sentencia #GRAPHCMD." .

ns1:RevisionDeGapProgramado a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de gap programado" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisionDeMovimientoDeEjeRotativoConRTCPSTATICYG41G42 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de movimiento de eje rotativo con RTCP STATIC y G41/G42" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisionDeProgramacionEnGRAPHCMD a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación en #GRAPHCMD" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. La sentencia #GRAPHCMD sólo admite un comando." .

ns1:SimulacionDeGAPConSIMMODEFalse a ns1:DiagnosticoFallo ;
    rdfs:label "Simulación de GAP con SIMMODE=False" ;
    ns1:textoExtracto "No es posible simulación de GAP con el parámetro SIMMODE = FALSE. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el control de gap (#GRAPCTRL) en un eje que tiene el parámetro SIMMODE=False." .

