@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarLaCompensacionDeRadioParaMoverElEjeRotativo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la compensación de radio para mover el eje rotativo" ;
    ns1:solucionaFallo ns1:SeHaIntentadoMoverUnEjeRotativoDeLaCinematicaConRTCPSTATICYCompensaci_1366919ede ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo." .

ns1:MoverElEjeRotativoYElEjeLinealIndividualmente a ns1:TareaMantenimiento ;
    rdfs:label "Mover el eje rotativo y el eje lineal individualmente" ;
    ns1:solucionaFallo ns1:SeHaIntentadoMoverUnEjeLinealJuntoAUnEjeRotativoDeLaCinematicaConRTCP_3efb686d00 ;
    ns1:textoExtracto "SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:MovimientoDeEjeRotativoNoPermitidoConRTCPSTATICActivoYCompensacionDeRadio a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio" ;
    ns1:textoExtracto "2500 Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio activa (G41/G42). DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje rotativo de la cinemática, con RTCP STATIC y compensación de radio activa. SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo." .

ns1:NoSePermiteProgramarEnElMismoBloqueEjeLinealYRotativoConRTCPSTATICActivo a ns1:AccionProhibida ;
    rdfs:label "No se permite programar en el mismo bloque eje lineal y rotativo, con RTCP STATIC activo" ;
    ns1:textoExtracto "2501 No se permite programar en el mismo bloque eje lineal y rotativo, con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:SeHaIntentadoMoverUnEjeLinealJuntoAUnEjeRotativoDeLaCinematicaConRTCP_3efb686d00 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo" ;
    ns1:textoExtracto "CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo." .

ns1:SeHaIntentadoMoverUnEjeRotativoDeLaCinematicaConRTCPSTATICYCompensaci_1366919ede a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha intentado mover un eje rotativo de la cinemática, con RTCP STATIC y compensación de radio activa" ;
    ns1:textoExtracto "CAUSA Se ha intentado mover un eje rotativo de la cinemática, con RTCP STATIC y compensación de radio activa." .

