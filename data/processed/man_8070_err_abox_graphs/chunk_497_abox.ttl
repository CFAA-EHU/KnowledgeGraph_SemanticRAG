@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3760
    a ex:Alarma ;
    rdfs:label "Alarma 3760: RPS, tensión de bus por debajo de la deseada" ;
    ex:textoExtracto "3760 RPS, tensión de bus por debajo de la deseada. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Caída inesperada de la linea de red que alimenta la maniobra. SOLUCIÓN Revisar la instalación y la maniobra." ;
    ex:identificador "3760" .

ex:Alarma_3761
    a ex:Alarma ;
    rdfs:label "Alarma 3761: RPS, tensión de red alta, alcanza a la consigna de bus DC" ;
    ex:textoExtracto "3761 RPS, tensión de red alta, alcanza a la consigna de bus DC. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Subida de tensión de red, que al ser rectificada, alcanza la consigna del bus DC. SOLUCIÓN Subir la tensión de consigna del bus DC." ;
    ex:identificador "3761" .

ex:Alarma_3762
    a ex:Alarma ;
    rdfs:label "Alarma 3762: Error en el comando de latcheo de I0" ;
    ex:textoExtracto "3762 Error en el comando de latcheo de I0. DETECCIÓN Durante el proceso de referenciar el eje/cabezal. CAUSA El comando de latcheo del I0 ha dado un error. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "3762" .

ex:Alarma_3763
    a ex:Alarma ;
    rdfs:label "Alarma 3763: Error en el comando de reseteo de errores del regulador" ;
    ex:textoExtracto "3763 Error en el comando de reseteo de errores del regulador. DETECCIÓN Tras un reset del CNC. error. CAUSA El comando de resetear errores del regulador ha dado un error. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "3763" .

ex:Alarma_3764
    a ex:Alarma ;
    rdfs:label "Alarma 3764: Error en el comando de establecer nueva referencia de posición" ;
    ex:textoExtracto "3764 Error en el comando de establecer nueva referencia de posición. DETECCIÓN Durante el proceso de búsqueda de I0 o G174. CAUSA El comando de establecer nueva referencia de posición ha dado error. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "3764" .

ex:Alarma_3800
    a ex:Alarma ;
    rdfs:label "Alarma 3800: Velocidad en jog continuo igual a cero" ;
    ex:textoExtracto "3800 'Velocidad en jog continuo igual a cero' DETECCIÓN Durante la ejecución o al cambiar el modo a jog continuo. CAUSA El avance para el modo jog continuo es cero. No hay programado ningún avance para el modo manual y el parámetro máquina JOGFEED es cero. SOLUCIÓN Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED." ;
    ex:identificador "3800" .

ex:Alarma_3801
    a ex:Alarma ;
    rdfs:label "Alarma 3801: Distancia o velocidad en jog incremental igual a cero" ;
    ex:textoExtracto "3801 'Distancia o velocidad en jog incremental igual a cero' DETECCIÓN Durante la ejecución." ;
    ex:identificador "3801" .

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "Parámetro máquina JOGFEED" ;
    ex:textoExtracto "el parámetro máquina JOGFEED es cero" ;
    ex:identificador "JOGFEED" .

ex:ComponenteElectrico_Contactor
    a ex:ComponenteElectrico ;
    rdfs:label "Contactor (26 Vdc)" ;
    ex:textoExtracto "Contactor estropeado. a 26 Vdc." .

ex:AvisoSeguridad_3760
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para alarma 3760" ;
    ex:textoExtracto "Revisar la instalación y la maniobra." ;
    ex:solucionaFallo ex:Alarma_3760 .

ex:AvisoSeguridad_3761
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para alarma 3761" ;
    ex:textoExtracto "Subir la tensión de consigna del bus DC." ;
    ex:solucionaFallo ex:Alarma_3761 .

ex:AvisoSeguridad_3800
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para alarma 3800" ;
    ex:textoExtracto "Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED." ;
    ex:solucionaFallo ex:Alarma_3800 .