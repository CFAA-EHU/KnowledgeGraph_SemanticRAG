@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:textoExtracto "Revisar el parámetro máquina de ejes JOGFEED." ;
    ex:identificador "3801" .

ex:Parametro_INCJOGFEED
    a ex:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ex:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED e INCJOGDIST." .

ex:Parametro_INCJOGDIST
    a ex:Parametro ;
    rdfs:label "INCJOGDIST" ;
    ex:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED e INCJOGDIST." .

ex:Alarma_3801
    a ex:Alarma ;
    rdfs:label "Distancia o velocidad en jog incremental igual a cero" ;
    ex:identificador "3801" ;
    ex:textoExtracto "3801 'Distancia o velocidad en jog incremental igual a cero' DETECCIÓN Durante la ejecución. CAUSA El avance o la distancia a moverse en jog incremental es cero." ;
    ex:activaAlarma ex:Parametro_JOGFEED ;
    ex:activaAlarma ex:Parametro_INCJOGFEED ;
    ex:activaAlarma ex:Parametro_INCJOGDIST .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "Definir un nuevo avance desde el modo manual." .