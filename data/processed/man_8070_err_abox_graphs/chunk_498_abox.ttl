@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarFuncionalidadDeRTCPSTATIC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar funcionalidad de RTCP STATIC" ;
    ns1:solucionaFallo ns1:MovimientoDeEjeRotativoNoPermitidoEnInspeccionRTCPSTATICActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la funcionalidad de RTCP STATIC para poder mover el eje rotativo." .

ns1:G107FaltaProgramarElSegundoPuntoXYZ a ns1:DiagnosticoFallo ;
    rdfs:label "G107: Falta programar el segundo punto (XYZ)" ;
    ns1:textoExtracto "G107: Falta programar el segundo punto (XYZ)." .

ns1:MoverElEjeRotativoYElEjeLinealIndividualmente a ns1:TareaMantenimiento ;
    rdfs:label "Mover el eje rotativo y el eje lineal individualmente" ;
    ns1:solucionaFallo ns1:MovimientoDeEjeRotativoNoPermitidoJuntoConEjeLinealRTCPSTATICActivo ;
    ns1:textoExtracto "SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:RevisarLaProgramacionYUsarComandoI a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación y usar comando 'I'" ;
    ns1:solucionaFallo ns1:G36373839ElRadioSeProgramaConI ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar el radio o chaflán con el comando \"I\"." .

ns1:G36373839ElRadioSeProgramaConI a ns1:DiagnosticoFallo ;
    rdfs:label "G36/37/38/39: El radio se programa con I" ;
    ns1:textoExtracto "Se ha programado incorrectamente el radio del redondeo (G36), chaflán (G39) o entrada/salida tangencial (G37/G38)." .

ns1:MovimientoDeEjeRotativoNoPermitidoEnInspeccionRTCPSTATICActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de eje rotativo no permitido en inspección, RTCP STATIC activo" ;
    ns1:textoExtracto "Durante la inspección de herramienta, se ha intentado mover un eje rotativo de la cinemática RTCP STATIC activo." .

ns1:MovimientoDeEjeRotativoNoPermitidoJuntoConEjeLinealRTCPSTATICActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de eje rotativo no permitido junto con eje lineal, RTCP STATIC activo" ;
    ns1:textoExtracto "Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo." .

