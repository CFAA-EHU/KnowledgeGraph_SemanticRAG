@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación"@es ;
    ns1:solucionaFallo ns1:FaltaProgramarElPrimerPuntoIJK,
        ns1:FaltaProgramarElSegundoPuntoXYZ,
        ns1:G107IncompatibleConG106YSPLINEON ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:FaltaProgramarElPrimerPuntoIJK a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el primer punto (IJK)"@es ;
    ns1:textoExtracto "2505 G107: Falta programar el primer punto (IJK). CAUSA Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107." .

ns1:FaltaProgramarElSegundoPuntoXYZ a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el segundo punto (XYZ)"@es ;
    ns1:textoExtracto "2504 G107: Falta programar el segundo punto (XYZ). CAUSA Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107." .

ns1:G107IncompatibleConG106YSPLINEON a ns1:DiagnosticoFallo ;
    rdfs:label "G107 incompatible con G106 y #SPLINE ON"@es ;
    ns1:textoExtracto "2506 G107 incompatible con G106 y #SPLINE ON. CAUSA No es posible programar splines con G107 activa." .

