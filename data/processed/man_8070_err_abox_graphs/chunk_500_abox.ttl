@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarElValorAEscribir a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el valor a escribir" ;
    ns1:solucionaFallo ns1:ValorDeEscrituraFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor a escribir." .

ns1:ORBITONRvalorJvalorKvalor a ns1:Parametro ;
    rdfs:label "#ORBIT ON[Rvalor, Jvalor ,Kvalor]" ;
    ns1:identificador "2509" ;
    ns1:textoExtracto "2509 #ORBIT ON[Rvalor, Jvalor ,Kvalor]." .

ns1:ProgramarLasCotasEnCoordenadasCartesianas a ns1:TareaMantenimiento ;
    rdfs:label "Programar las cotas en coordenadas cartesianas" ;
    ns1:solucionaFallo ns1:NoEsPosibleProgramarLasCotasDeUnBloqueEnG107ConCoordenadasPolaresOMed_6f8532a5ce ;
    ns1:textoExtracto "SOLUCIÓN Programar las cotas en coordenadas cartesianas." .

ns1:NoEsPosibleProgramarLasCotasDeUnBloqueEnG107ConCoordenadasPolaresOMed_6f8532a5ce a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible programar las cotas de un bloque en G107 con coordenadas polares o mediante coordenadas cartesianas y ángulo" ;
    ns1:textoExtracto "CAUSA No es posible programar las cotas de un bloque en G107 con coordenadas polares o mediante coordenadas cartesianas y ángulo." .

ns1:ValorDeEscrituraFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de escritura fuera de rango" ;
    ns1:identificador "2508" ;
    ns1:textoExtracto "2508 Valor de escritura fuera de rango." .

