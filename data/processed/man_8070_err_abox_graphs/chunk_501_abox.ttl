@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarElValorAEscribir a ns1:TareaMantenimiento ;
    rdfs:label "modificar el valor a escribir" ;
    ns1:solucionaFallo ns1:DeteccionDeEscrituraFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor a escribir." .

ns1:Parametro_3ca34d22f2 a ns1:Parametro ;
    rdfs:label "parámetro ORBIT" ;
    ns1:identificador "ORBIT" ;
    ns1:textoExtracto "Parámetro ORBIT fuera de rango." .

ns1:Parametro_ed9f1e1351 a ns1:Parametro ;
    rdfs:label "parámetro K de ORBIT" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "El valor de K debe ser 1 o 2." .

ns1:Parametro_ee0a746269 a ns1:Parametro ;
    rdfs:label "parámetro R de ORBIT" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "El valor de R/J debe ser positivo y no nulo. El valor de R debe ser mayor que el diámetro de la herramienta." .

ns1:Parametro_ff5a113b44 a ns1:Parametro ;
    rdfs:label "parámetro J de ORBIT" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "El valor de R/J debe ser positivo y no nulo. El valor de R debe ser mayor que el diámetro de la herramienta." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "revisar la programación" ;
    ns1:solucionaFallo ns1:DeteccionDeSintaxisIncorrectaEnSentenciaORBIT ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DeteccionDeEscrituraFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "detección de escritura fuera de rango" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No es posible escribir ese valor en la variable." .

ns1:DeteccionDeSintaxisIncorrectaEnSentenciaORBIT a ns1:DiagnosticoFallo ;
    rdfs:label "detección de sintaxis incorrecta en sentencia #ORBIT" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o preparación de bloques. CAUSA La sintaxis de la sentencia no es correcta." .

