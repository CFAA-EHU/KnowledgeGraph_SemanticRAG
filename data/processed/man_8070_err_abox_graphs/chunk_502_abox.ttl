@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarORBITParaModificarAlgunParametroDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar #ORBIT para modificar algún parámetro de la sentencia" ;
    ns1:solucionaFallo ns1:SeHaIntentadoActivarORBITONEstandoYaActiva ;
    ns1:textoExtracto "SOLUCIÓN Para modificar algún parámetro de la sentencia #ORBIT, es necesario desactivarla primero." .

ns1:EliminarElBloqueEnG0ODesactivarORBIT a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el bloque en G0 o desactivar #ORBIT" ;
    ns1:solucionaFallo ns1:SeHaProgramadoUnMovimientoEnG0ConORBITActivo ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT." .

ns1:ProgramarUnaAnchuraMayorQueElRadioDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Programar una anchura mayor que el radio de la herramienta" ;
    ns1:solucionaFallo ns1:LaAnchuraDeLaRanuraREsMenorOIgualQueElDiametroDeLaHerramienta ;
    ns1:textoExtracto "SOLUCIÓN Programar una anchura mayor que el radio de la herramienta." .

ns1:LaAnchuraDeLaRanuraREsMenorOIgualQueElDiametroDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "La anchura de la ranura (R) es menor o igual que el diámetro de la herramienta" ;
    ns1:textoExtracto "La anchura de la ranura (R) es menor o igual que el diámetro de la herramienta." .

ns1:SeHaIntentadoActivarORBITONEstandoYaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha intentado activar #ORBITON estando ya activa" ;
    ns1:textoExtracto "CAUSA Se ha intentado activar #ORBITON estando ya activa." .

ns1:SeHaProgramadoUnMovimientoEnG0ConORBITActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado un movimiento en G0 con #ORBIT activo" ;
    ns1:textoExtracto "CAUSA Se ha programado un movimiento en G0 con #ORBIT activo." .

