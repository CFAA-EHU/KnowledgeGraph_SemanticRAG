@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminarBloqueEnG0ODesactivarORBIT a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar bloque en G0 o desactivar #ORBIT" ;
    ns1:solucionaFallo ns1:MovimientoEnG0ConORBITActivo ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT." .

ns1:EliminarMovimientoEnElEjePerpendicularODesactivarORBIT a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar movimiento en el eje perpendicular o desactivar #ORBIT" ;
    ns1:solucionaFallo ns1:MovimientoDelEjePerpendicularAlPlanoDeTrabajoConORBITActivo ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el movimiento en el eje perpendicular o desactivar #ORBIT." .

ns1:MovimientoDelEjePerpendicularAlPlanoDeTrabajoConORBITActivo a ns1:AccionProhibida ;
    rdfs:label "Movimiento del eje perpendicular al plano de trabajo con #ORBIT activo" ;
    ns1:solucionaFallo ns1:Entity2515ORBITONMovimientoDelEjePerpendicularAlPlanoNoPermitido ;
    ns1:textoExtracto "Se ha programado un movimiento en el eje perpendicular al plano de trabajo con #ORBIT activo." .

ns1:MovimientoEnG0ConORBITActivo a ns1:AccionProhibida ;
    rdfs:label "Movimiento en G0 con #ORBIT activo" ;
    ns1:solucionaFallo ns1:Entity2515ORBITONMovimientoDelEjePerpendicularAlPlanoNoPermitido ;
    ns1:textoExtracto "Se ha programado un movimiento en G0 con #ORBIT activo." .

ns1:Entity2515ORBITONMovimientoDelEjePerpendicularAlPlanoNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "2515 #ORBIT ON: movimiento del eje perpendicular al plano no permitido" ;
    ns1:textoExtracto "#ORBIT ON: movimiento del eje perpendicular al plano no permitido." .

