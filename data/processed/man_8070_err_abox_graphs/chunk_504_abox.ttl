@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarQueLosLimitesDeSoftwareSonCorrectos a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que los límites de software son correctos" ;
    ns1:solucionaFallo ns1:LimiteNegativoDeSoftwareSobrepasado_10e8bb5f9e,
        ns1:LimitePositivoDeSoftwareSobrepasado_39f12b277a ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:ErrorDelControlDePosicionEnLaInicializacionDelProcesoDePalpador_6800fb3186 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del control de posición en la inicialización del proceso de palpador" ;
    ns1:textoExtracto "'Error del control de posición en la inicialización del proceso de palpador' DETECCIÓN En la inicialización del proceso de palpado. CAUSA Es una seguridad de habilitación del proceso de palpado." .

ns1:NoSePuedeMoverUnEjeEnModoVisualizador_c6222a5da5 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede mover un eje en modo visualizador" ;
    ns1:textoExtracto "'No se puede mover un eje en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta desplazar un eje que se encuentra en modo visualizador." .

ns1:NoSePuedeProgramarUnaTrayectoriaCircularConUnEjeEsclavo_cee81fc802 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar una trayectoria circular con un eje esclavo" ;
    ns1:textoExtracto "'No se puede programar una trayectoria circular con un eje esclavo' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover individualmente el eje esclavo de un acoplo o de un eje gantry." .

ns1:LimiteNegativoDeSoftwareSobrepasado_10e8bb5f9e a ns1:DiagnosticoFallo ;
    rdfs:label "Límite negativo de software sobrepasado" ;
    ns1:textoExtracto "'Límite negativo de software sobrepasado' DETECCIÓN Durante la reposición de un eje. CAUSA Durante el movimiento de reposicionamiento, el eje ha alcanzado los límites de software." .

ns1:LimitePositivoDeSoftwareSobrepasado_39f12b277a a ns1:DiagnosticoFallo ;
    rdfs:label "Límite positivo de software sobrepasado" ;
    ns1:textoExtracto "'Límite positivo de software sobrepasado' DETECCIÓN Durante la reposición de un eje. CAUSA Durante el movimiento de reposicionamiento, el eje ha alcanzado los límites de software." .

