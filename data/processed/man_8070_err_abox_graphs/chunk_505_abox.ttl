@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDelControlDePosicionEnLaInicializacionDelProcesoDePalpador_6800fb3186 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del control de posición en la inicialización del proceso de palpador" ;
    ns1:solucionaFallo ns1:ComprobarValidezYDisponibilidadDeLosEjesProgramados ;
    ns1:textoExtracto "'Error del control de posición en la inicialización del proceso de palpador' DETECCIÓN En la inicialización del proceso de palpado. CAUSA Es una seguridad de habilitación del proceso de palpado." .

ns1:RecepcionDeSenalDelPalpadorAntesDeLaInicializacion a ns1:AccionProhibida ;
    rdfs:label "Recepción de señal del palpador antes de la inicialización" ;
    ns1:textoExtracto "'Se ha recibido señal del palpador antes del" .

ns1:ComprobarValidezYDisponibilidadDeLosEjesProgramados a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar validez y disponibilidad de los ejes programados" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados." .

