@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DemasiadosEjesProgramadosComoPalpador_98b189262d a ns1:AvisoSeguridad ;
    rdfs:label "Demasiados ejes programados como palpador"@es ;
    ns1:solucionaFallo ns1:CorregirLaProgramacionDelBloqueDePalpado ;
    ns1:textoExtracto "'Demasiados ejes programados como palpador' DETECCIÓN Durante la ejecución. CAUSA El número de ejes programados en el movimiento de palpación supera el máximo de ejes del canal." .

ns1:DistanciaDeFrenadoMayorQueElParametroPROBERANGE_880fde1e35 a ns1:AvisoSeguridad ;
    rdfs:label "Distancia de frenado mayor que el parámetro PROBERANGE"@es ;
    ns1:solucionaFallo ns1:DisminuirElAvanceDePalpado ;
    ns1:textoExtracto "'Distancia de frenado mayor que el parámetro PROBERANGE' DETECCIÓN Durante la ejecución. CAUSA La distancia necesaria para frenar con el avance activo es mayor que la distancia máxima admisible (parámetro PROBERANGE), probablemente debido al error de seguimiento." .

ns1:ElEjeNoSeHaDefinidoComoPalpadorPROBEAXIS_518403ddd5 a ns1:AvisoSeguridad ;
    rdfs:label "El eje no se ha definido como palpador (PROBEAXIS)"@es ;
    ns1:solucionaFallo ns1:Parametro_a3b1bc2990 ;
    ns1:textoExtracto "'El eje no se ha definido como palpador (PROBEAXIS)' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de palpado en un eje que no está definido como eje participante en un movimiento con palpador." .

ns1:Parametro_e13ab14522 a ns1:Parametro ;
    rdfs:label "Parámetro que define la distancia máxima admisible para frenado"@es ;
    ns1:textoExtracto "La distancia necesaria para frenar con el avance activo es mayor que la distancia máxima admisible (parámetro PROBERANGE), probablemente debido al error de seguimiento." .

ns1:CorregirLaProgramacionDelBloqueDePalpado a ns1:AccionProhibida ;
    rdfs:label "Corregir la programación del bloque de palpado"@es ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación del bloque de palpado." .

ns1:DisminuirElAvanceDePalpado a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el avance de palpado"@es ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el avance de palpado o disminuir el error de seguimiento." .

ns1:Parametro_a3b1bc2990 a ns1:Parametro ;
    rdfs:label "Parámetro que establece si el eje puede participar en movimientos con palpador"@es ;
    ns1:textoExtracto "El parámetro PROBEAXIS establece si el eje puede participar en movimientos con palpador." .

