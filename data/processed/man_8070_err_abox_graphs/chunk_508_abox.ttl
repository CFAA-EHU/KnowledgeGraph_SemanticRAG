@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaIgnoradaDuranteUnaBusquedaDeBloque a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de referencia ignorada durante una búsqueda de bloque" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida'" .

ns1:HacerLaBusquedaDeReferenciaMaquinaFueraDelPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Hacer la búsqueda de referencia máquina fuera del programa" ;
    ns1:solucionaFallo ns1:DisminuirElAvanceDePalpadoODisminuirElErrorDeSeguimiento ;
    ns1:textoExtracto "SOLUCIÓN Hacer la búsqueda de referencia máquina fuera del programa." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:DisminuirElAvanceDePalpadoODisminuirElErrorDeSeguimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Disminuir el avance de palpado o disminuir el error de seguimiento" ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el avance de palpado o disminuir el error de seguimiento." .

