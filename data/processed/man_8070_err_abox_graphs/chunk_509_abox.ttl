@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_e7fbe13c36 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:ActivarModoManualDuranteBusquedaDeBloque ;
    ns1:solucionaFallo ns1:FalloBusquedaBloqueYaActivada,
        ns1:FalloReferenciaIgnoradaDuranteBusquedaBloque ;
    ns1:textoExtracto "CNC 8070" .

ns1:DisminuirElAvance a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el avance" ;
    ns1:solucionaFallo ns1:FalloNoAlcanzadaVelocidadCorte ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad." .

ns1:DisminuirLaVelocidadDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir la velocidad del cabezal" ;
    ns1:solucionaFallo ns1:FalloNoAlcanzadaVelocidadCorte ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad." .

ns1:ProgramarLaVelocidadAntes a ns1:TareaMantenimiento ;
    rdfs:label "Programar la velocidad antes" ;
    ns1:solucionaFallo ns1:FalloNoAlcanzadaVelocidadCorte ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad." .

ns1:ActivarModoManualDuranteBusquedaDeBloque a ns1:AccionProhibida ;
    rdfs:label "Activar modo manual durante búsqueda de bloque" ;
    ns1:textoExtracto "El usuario ha intentado activar el modo manual durante una búsqueda de bloque y el CNC lo ha ignorado." .

ns1:FalloBusquedaBloqueYaActivada a ns1:DiagnosticoFallo ;
    rdfs:label "Búsqueda de bloque ya activada" ;
    ns1:textoExtracto "CAUSA El CNC ha intentado activar una búsqueda de bloque estando con otra activa." .

ns1:FalloReferenciaIgnoradaDuranteBusquedaBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Búsqueda de referencia ignorada durante búsqueda de bloque" ;
    ns1:textoExtracto "CAUSA Durante una búsqueda de bloque, el CNC ha encontrado una búsqueda de referencia y la ha ignorado." .

ns1:FalloNoAlcanzadaVelocidadCorte a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha alcanzado la velocidad de corte constante" ;
    ns1:textoExtracto "CAUSA El cabezal no ha tenido tiempo para alcanzar la velocidad programada." .

