@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AumentarElAvanceOAumentarLasRevolucionesDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el avance o aumentar las revoluciones del cabezal" ;
    ns1:solucionaFallo ns1:AvanceProgramadoEnG95DemasiadoPequeno_33aca58fb5 ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el avance o aumentar las revoluciones del cabezal." .

ns1:FaltaEjeSEnElNuevoSistemaDeCoordenadas_9a81d5c048 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta eje(s) en el nuevo sistema de coordenadas" ;
    ns1:textoExtracto "'Falta eje(s) en el nuevo sistema de coordenadas' DETECCIÓN Durante la ejecución." .

ns1:PongaseEnContactoConFAGOR a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor" ;
    ns1:solucionaFallo ns1:ErrorAlInicializarLasCotasDeLosEjes_6792452feb ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor." .

ns1:ProgramarUnaVelocidad a ns1:TareaMantenimiento ;
    rdfs:label "Programar una velocidad" ;
    ns1:solucionaFallo ns1:MaximaVelocidadDeCorteConstanteIgualACero_374f187666,
        ns1:NoSeHaProgramadoSEnG96_d656d80d85 ;
    ns1:textoExtracto "SOLUCIÓN Programar una velocidad." .

ns1:AvanceProgramadoEnG95DemasiadoPequeno_33aca58fb5 a ns1:DiagnosticoFallo ;
    rdfs:label "Avance programado en G95 demasiado pequeño" ;
    ns1:textoExtracto "'Avance programado en G95 demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El avance resultante es muy pequeño para la velocidad programada." .

ns1:ErrorAlInicializarLasCotasDeLosEjes_6792452feb a ns1:DiagnosticoFallo ;
    rdfs:label "Error al inicializar las cotas de los ejes" ;
    ns1:textoExtracto "'Error al inicializar las cotas de los ejes' DETECCIÓN Durante la ejecución. CAUSA No coinciden las cotas de algún eje." .

ns1:MaximaVelocidadDeCorteConstanteIgualACero_374f187666 a ns1:DiagnosticoFallo ;
    rdfs:label "Máxima velocidad de corte constante igual a cero" ;
    ns1:textoExtracto "'Máxima velocidad de corte constante igual a cero' DETECCIÓN Durante la ejecución. CAUSA La velocidad máxima del cabezal es igual a cero." .

ns1:NoSeHaProgramadoSEnG96_d656d80d85 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado S en G96" ;
    ns1:textoExtracto "'No se ha programado S en G96' DETECCIÓN Durante la ejecución. CAUSA La velocidad del cabezal es igual a cero." .

