@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarLimitesDeSoftware a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar límites de software" ;
    ns1:solucionaFallo ns1:LimiteNegativoDeSoftwareSobrepasado_896b2f1b94,
        ns1:LimitePositivoDeSoftwareSobrepasado_fe3b85dbea ;
    ns1:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:LimiteNegativoDeSoftwareSobrepasado_896b2f1b94 a ns1:AvisoSeguridad ;
    rdfs:label "Límite negativo de software sobrepasado" ;
    ns1:mitigaRiesgo ns1:CNC8070_c0492d9d4a ;
    ns1:textoExtracto "'Límite negativo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los limites de software." .

ns1:LimitePositivoDeSoftwareSobrepasado_fe3b85dbea a ns1:AvisoSeguridad ;
    rdfs:label "Límite positivo de software sobrepasado" ;
    ns1:mitigaRiesgo ns1:CNC8070_c0492d9d4a ;
    ns1:textoExtracto "'Límite positivo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los limites de software." .

ns1:CNC8070_c0492d9d4a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los limites de software." .

