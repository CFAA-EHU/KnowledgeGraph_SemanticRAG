@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_4010
    a ex:DiagnosticoFallo ;
    ex:identificador "4010" ;
    rdfs:label "'No se puede escribir parámetro en el regulador'" ;
    ex:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Fallo genérico en la escritura del parámetro. SOLUCIÓN: Revisar el estado de la comunicación con el regulador, versión de software y opciones de parametrización permitidas." ;
    ex:solucionaFallo ex:Parametro_Regulador_4010 .

ex:Parametro_Regulador_4010
    a ex:Parametro ;
    rdfs:label "Parámetro del regulador (4010)" ;
    ex:textoExtracto "Parámetro del regulador afectado por fallo genérico de escritura durante inicialización del anillo Sercos." .

ex:DiagnosticoFallo_4011
    a ex:DiagnosticoFallo ;
    ex:identificador "4011" ;
    rdfs:label "'No se puede escribir parámetro en el regulador: No IDN'" ;
    ex:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: No existe el parámetro en el regulador. SOLUCIÓN: Actualizar versión de software del regulador." ;
    ex:solucionaFallo ex:Parametro_Regulador_4011 .

ex:Parametro_Regulador_4011
    a ex:Parametro ;
    rdfs:label "Parámetro no existente en regulador (4011)" ;
    ex:textoExtracto "Parámetro no definido (IDN ausente) en el regulador durante escritura." .

ex:DiagnosticoFallo_4012
    a ex:DiagnosticoFallo ;
    ex:identificador "4012" ;
    rdfs:label "'No se puede escribir parámetro en el regulador: Fuera de rango'" ;
    ex:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: El valor del parámetro máquina está fuera del rango permitido. SOLUCIÓN: Corregir el valor del parámetro en el CNC." ;
    ex:solucionaFallo ex:Parametro_Regulador_4012 .

ex:Parametro_Regulador_4012
    a ex:Parametro ;
    rdfs:label "Parámetro fuera de rango (4012)" ;
    ex:textoExtracto "Parámetro del regulador con valor fuera del rango permitido." ;
    ex:valor "Fuera de rango" .

ex:DiagnosticoFallo_4013
    a ex:DiagnosticoFallo ;
    ex:identificador "4013" ;
    rdfs:label "'No se puede escribir parámetro en el regulador: Protegido'" ;
    ex:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Parámetro protegido contra escritura. SOLUCIÓN: Revisar los permisos y el nivel de acceso en el regulador." ;
    ex:solucionaFallo ex:Parametro_Regulador_4013 .

ex:Parametro_Regulador_4013
    a ex:Parametro ;
    rdfs:label "Parámetro protegido (4013)" ;
    ex:textoExtracto "Parámetro del regulador con protección contra escritura." .

ex:DiagnosticoFallo_4014
    a ex:DiagnosticoFallo ;
    ex:identificador "4014" ;
    rdfs:label "'Error en la inicialización del SERCON'" ;
    ex:textoExtracto "DETECCIÓN: Al inicializar el chip de Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Número de ejes Sercos o tiempos de Sercos erróneos." ;
    ex:solucionaFallo ex:Sistema_SERCON_4014 .

ex:Sistema_SERCON_4014
    a ex:Sistema ;
    rdfs:label "Sistema SERCON (4014)" ;
    ex:textoExtracto "Chip de Sercos con error en inicialización debido a configuración incorrecta de ejes o tiempos." .