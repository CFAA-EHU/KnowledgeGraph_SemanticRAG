@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarQueTodosLosEjesSeanDelMismoTipo a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que todos los ejes sean del mismo tipo" ;
    ns1:solucionaFallo ns1:TodosLosEjesDebenSerDelMismoTipoEnMedicionConPalpador ;
    ns1:textoExtracto "Todos los ejes que intervienen en un proceso de medición con palpador deben ser del mismo tipo." .

ns1:DesactivarUnaCompensacionAntesDeActivarLaOtra a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar una compensación antes de activar la otra" ;
    ns1:solucionaFallo ns1:CompensacionRTCPTLCNoPermitidaEnElEstadoActual_343e4105e1 ;
    ns1:textoExtracto "Ambas compensaciones no pueden estar activas simultáneamente; desactivar una de ellas (#RTCP OFF / TLC OFF) antes de activar la otra." .

ns1:NoSeAdmiteBusquedaDeCeroEnModo_a20b4f55a2 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite búsqueda de cero en modo" ;
    ns1:textoExtracto "'No se admite búsqueda de cero en modo'" .

ns1:CompensacionRTCPTLCNoPermitidaEnElEstadoActual_343e4105e1 a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación (RTCP/TLC) no permitida en el estado actual" ;
    ns1:textoExtracto "'Compensación (RTCP/TLC) no permitida en el estado actual'" .

ns1:TodosLosEjesDebenSerDelMismoTipoEnMedicionConPalpador a ns1:DiagnosticoFallo ;
    rdfs:label "Todos los ejes deben ser del mismo tipo en medición con palpador" ;
    ns1:textoExtracto "Todos los ejes que intervienen en un proceso de medición con palpador deben ser del mismo tipo." .

