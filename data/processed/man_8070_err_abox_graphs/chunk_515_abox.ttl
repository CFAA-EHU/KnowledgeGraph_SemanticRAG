@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AmbasCompensacionesNoPuedenEstarActivasSimultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "Ambas compensaciones no pueden estar activas simultáneamente" ;
    ns1:textoExtracto "SOLUCIÓN Ambas compensaciones no pueden estar activas simultáneamente; desactivar una de ellas (#RTCP OFF / TLC OFF) antes de activar la otra." .

ns1:DiferenciaDeErroresDeSeguimientoDeEjesAcopladosDemasiadoGrande a ns1:DiagnosticoFallo ;
    rdfs:label "Diferencia de errores de seguimiento de ejes acoplados demasiado grande" ;
    ns1:textoExtracto "SOLUCIÓN Ajustar de forma similar el comportamiento dinámico ambos ejes o aumentar error permitido." .

ns1:EjeBloqueado_7f11ac7145 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje bloqueado" ;
    ns1:textoExtracto "CAUSA El CNC intenta mover un eje, pero el PLC no ha puesto la señal SERVO(axis)ON." .

ns1:NoSeAdmiteBusquedaDeCeroEnModoVisualizador a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite búsqueda de cero en modo visualizador" ;
    ns1:textoExtracto "SOLUCIÓN El CNC no permite realizar una búsqueda de referencia de un eje visualizador." .

ns1:NoSeAdmiteElPasoAModoManualSiElEjeEstaEnElCentroDeGiro a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite el paso a modo manual si el eje esta en el centro de giro" ;
    ns1:textoExtracto "SOLUCIÓN Activar el modo manual con los ejes en una posición distinta a la del centro de giro." .

ns1:NumeroDeGamaNoValido_e476019353 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama no válido" ;
    ns1:textoExtracto "SOLUCIÓN El número de set debe estar comprendido entre 1 y el parámetro NPARSET." .

ns1:ProcesoDeCambioDeGamaIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Proceso de cambio de gama incorrecto" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC." .

