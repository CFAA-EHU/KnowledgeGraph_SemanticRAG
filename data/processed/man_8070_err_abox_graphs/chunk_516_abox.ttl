@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteDelParametroDWELL a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del parámetro DWELL" ;
    ns1:solucionaFallo ns1:EjeBloqueado ;
    ns1:textoExtracto "aumentar el valor del parámetro DWELL del eje." .

ns1:CNC8070_720fe85a78 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC intenta mover un eje, pero el PLC no ha puesto la señal SERVO(axis)ON." .

ns1:ComprobarProgramaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar programa PLC" ;
    ns1:solucionaFallo ns1:EjeBloqueado ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Comprobar en el programa de PLC el tratamiento de la señal SERVO(axis)ON o aumentar el valor del parámetro DWELL del eje." .

ns1:ValorDelParametroDWELL a ns1:Parametro ;
    rdfs:label "Valor del parámetro DWELL" ;
    ns1:textoExtracto "aumentar el valor del parámetro DWELL del eje." .

ns1:EjeBloqueado a ns1:AccionProhibida ;
    rdfs:label "Eje bloqueado" ;
    ns1:textoExtracto "'Eje bloqueado' DETECCIÓN Durante la ejecución." .

