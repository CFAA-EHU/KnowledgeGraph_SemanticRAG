@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_501a0e57cb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:PongaseEnContactoConFagor ;
    ns1:textoExtracto "CNC 8070" .

ns1:CerrarLasAplicacionesQueNoEstanRelacionadasConElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Cerrar las aplicaciones que no están relacionadas con el CNC" ;
    ns1:solucionaFallo ns1:DemasiadosParametrosPendientesDeReportar ;
    ns1:textoExtracto "SOLUCIÓN Cerrar las aplicaciones que no están relacionadas con el CNC." .

ns1:EjeHirth a ns1:ComponenteMecanico ;
    rdfs:label "Eje Hirth" ;
    ns1:solucionaFallo ns1:ReposicionarElEjeHirth ;
    ns1:textoExtracto "El eje hirth no se encuentra posicionado en un número múltiplo de su paso." .

ns1:TiempoDeEsperaDelEje a ns1:Parametro ;
    rdfs:label "Tiempo de espera del eje" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "de la señal SERVO(axis)ON o aumentar el valor del parámetro DWELL del eje." .

ns1:DemasiadosParametrosPendientesDeReportar a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados parámetros pendientes de reportar" ;
    ns1:textoExtracto "3038 'Demasiados parámetros pendientes de reportar' DETECCIÓN Durante la ejecución. CAUSA El sistema está sobrecargado." .

ns1:EjeHirthNoPosicionadoCorrectamente a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Hirth no posicionado correctamente" ;
    ns1:textoExtracto "3040 'Eje Hirth no posicionado correctamente' DETECCIÓN Durante la ejecución. CAUSA El eje hirth no se encuentra posicionado en un número múltiplo de su paso." .

ns1:PongaseEnContactoConFagor a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor." .

ns1:ReposicionarElEjeHirth a ns1:TareaMantenimiento ;
    rdfs:label "Reposicionar el eje Hirth" ;
    ns1:solucionaFallo ns1:EjeHirthNoPosicionadoCorrectamente ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el bloque de parada." .

