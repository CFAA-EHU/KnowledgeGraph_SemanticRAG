@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_4019
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos por Reset de contadora" ;
    ex:identificador "4019" ;
    ex:textoExtracto "Error en el anillo Sercos debido a un Reset de contadora. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha producido un reset de en el módulo RCS-S, bien por causa física (caída de alimentación, etc) o interna del software del nodo. SOLUCIÓN Subsanar la causa del problema. Si el error persiste, póngase en contacto con Fagor." .

ex:Error_4020
    a ex:DiagnosticoFallo ;
    rdfs:label "Parametrización inconsistente" ;
    ex:identificador "4020" ;
    ex:textoExtracto "Parametrización inconsistente. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Parametrización incorrecta del módulo RCS-S o sus recursos. SOLUCIÓN Corregir la parametrización." .

ex:Error_4022
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos por Reset de contadora (Watchdog)" ;
    ex:identificador "4022" ;
    ex:textoExtracto "Error en el anillo Sercos debido a un Reset de contadora por Watchdog. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha producido un reset por watchdog en el módulo RCS-S, por una causa interna del software del nodo. SOLUCIÓN Póngase en contacto con Fagor." .

ex:Error_4023
    a ex:DiagnosticoFallo ;
    rdfs:label "Configuración fallida de traza programada en Sercos" ;
    ex:identificador "4023" ;
    ex:textoExtracto "No puede configurarse la traza programada en Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Error durante la configuración de los telegramas AT-MDT para capturar la traza programada. La traza programada no puede hacerse efectiva, bien porque se trata de un regulador no-Fagor o bien porque no hay hueco disponible para ella. SOLUCIÓN Reducir el número de variables en el telegrama. Si el ancho de banda está limitado, subir la frecuencia SERBRATE o eliminar reguladores del anillo." .

ex:Error_4024
    a ex:DiagnosticoFallo ;
    rdfs:label "Versión no válida del Regulador para eje TANDEM" ;
    ex:identificador "4024" ;
    ex:textoExtracto "Versión no válida del Regulador para eje TANDEM en posición o para REFMODE CNC." .

ex:Parametro_FEEDBACKTYPE
    a ex:Parametro ;
    rdfs:label "Tipo de captación (FEEDBACKTYPE)" ;
    ex:identificador "FEEDBACKTYPE" ;
    ex:textoExtracto "el tipo de captación (parámetro FEEDBACKTYPE) no es igual en todos lo sets. SOLUCIÓN Corregir la parametrización." .

ex:Modulo_RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "módulo RCS-S" ;
    ex:monitoreaParametro ex:Parametro_FEEDBACKTYPE .

ex:BusSercos
    a ex:Sistema ;
    rdfs:label "Bus Sercos" ;
    ex:textoExtracto "bus Sercos" ;
    ex:tieneComponente ex:Modulo_RCS_S .

ex:Solucion_4019
    a ex:TareaMantenimiento ;
    rdfs:label "Subsanar causa del reset en RCS-S" ;
    ex:textoExtracto "Subsanar la causa del problema. Si el error persiste, póngase en contacto con Fagor." ;
    ex:solucionaFallo ex:Error_4019 .

ex:Solucion_4020
    a ex:TareaMantenimiento ;
    rdfs:label "Corregir parametrización del módulo RCS-S" ;
    ex:textoExtracto "Corregir la parametrización." ;
    ex:solucionaFallo ex:Error_4020 .

ex:Solucion_4023
    a ex:TareaMantenimiento ;
    rdfs:label "Ajustar configuración de telegramas AT-MDT" ;
    ex:textoExtracto "Reducir el número de variables en el telegrama. Si el ancho de banda está limitado, subir la frecuencia SERBRATE o eliminar reguladores del anillo." ;
    ex:solucionaFallo ex:Error_4023 .

ex:Parametro_SERBRATE
    a ex:Parametro ;
    rdfs:label "Frecuencia SERBRATE" ;
    ex:identificador "SERBRATE" ;
    ex:textoExtracto "subir la frecuencia SERBRATE" .