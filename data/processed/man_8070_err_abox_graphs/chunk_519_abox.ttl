@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "CAUSA Hay una función G33, G34 o G95 activa y el valor del registro SYNC del PLC no es válido." .

ns1:SolucionCabezalEnM5AlActivarRoscadoElectronico a ns1:TareaMantenimiento ;
    rdfs:label "Solución cabezal en M5 al activar roscado electrónico" ;
    ns1:solucionaFallo ns1:CabezalEnM5AlActivarRoscadoElectronico ;
    ns1:textoExtracto "SOLUCIÓN El cabezal" .

ns1:ValorDelRegistroSYNCDelPLC a ns1:Parametro ;
    rdfs:label "Valor del registro SYNC del PLC" ;
    ns1:identificador "SYNC" ;
    ns1:textoExtracto "El valor del registro SYNC del PLC debe ser un valor comprendido entre 1 y el número de cabezales del sistema. También puede tener valor cero." .

ns1:CabezalEnM5AlActivarRoscadoElectronico a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal en M5 al activar roscado electrónico" ;
    ns1:textoExtracto "'Cabezal en M5 al activar roscado electrónico' DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34." .

