@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_4024
    a               ex:Alarma ;
    rdfs:label      "Alarma 4024: Versión no válida del regulador para eje TANDEM"@es ;
    ex:identificador "4024" ;
    ex:textoExtracto "4024 Versión no válida del Regulador para eje TANDEM en posición o para REFMODE CNC."@es ;
    ex:textoExtracto "DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset."@es ;
    ex:textoExtracto "CAUSA La versión de un regulador no soporta el tandem con control de par o el modo de referencia CNC."@es .

ex:Parametro_SERBRATE
    a               ex:Parametro ;
    rdfs:label      "Frecuencia SERBRATE"@es ;
    ex:textoExtracto "Si el ancho de banda está limitado, subir la frecuencia SERBRATE"@es .

ex:Parametro_RefModeCNC
    a               ex:Parametro ;
    rdfs:label      "Modo de referencia CNC (REFMODE)"@es ;
    ex:textoExtracto "versión no válida del Regulador [...] para REFMODE CNC"@es .

ex:ComponenteElectrico_ReguladorTandem
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador para eje TANDEM"@es ;
    ex:textoExtracto "versión de un regulador no soporta el tandem con control de par"@es ;
    ex:activaAlarma  ex:Alarma_4024 ;
    ex:monitoreaParametro ex:Parametro_RefModeCNC .