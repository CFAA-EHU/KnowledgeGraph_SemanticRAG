@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsociarLaFuncionAlCabezalCorrectoAccederAlCabezalDesdeElCanalEnElQueSeEncuentra a ns1:DiagnosticoFallo ;
    rdfs:label "Asociar la función al cabezal correcto. Acceder al cabezal desde el canal en el que se encuentra" ;
    ns1:textoExtracto "Asociar la función al cabezal correcto. Acceder al cabezal desde el canal en el que se encuentra." .

ns1:ElCabezalUtilizadoParaElRoscadoElectronicoDebeEstarEnMarchaPonerEnMar_662882253c a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal utilizado para el roscado electrónico debe estar en marcha. Poner en marcha el cabezal en un bloque anterior o en el mismo bloque que G33/G34." ;
    ns1:textoExtracto "El cabezal utilizado para el roscado electrónico debe estar en marcha. Poner en marcha el cabezal en un bloque anterior o en el mismo bloque que G33/G34." .

ns1:ElCabezalUtilizadoParaUnRoscadoElectronicoEstaParadoOSeHaProgramadoUn_3e2d6c68eb a ns1:AccionProhibida ;
    rdfs:label "El cabezal utilizado para un roscado electrónico está parado o se ha programado una M5 en el mismo bloque que G33/G34" ;
    ns1:textoExtracto "El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34." .

ns1:NoSePermiteBusquedaDeCeroDeUnEjeActivoComoEjeIndependiente_5adf00823c a ns1:AccionProhibida ;
    rdfs:label "No se permite búsqueda de cero de un eje activo como eje independiente" ;
    ns1:textoExtracto "El CNC intenta realizar la búsqueda de referencia de un eje independiente." .

ns1:PulsarResetYEjecutarM6DesdeElModoMDI a ns1:DiagnosticoFallo ;
    rdfs:label "Pulsar reset y ejecutar M6 desde el modo MDI" ;
    ns1:textoExtracto "Pulsar reset y ejecutar M6 desde el modo MDI." .

ns1:SiElEjeTienePendienteAlgunMovimientoIndependienteEsperarAQueTermineOA_e26d1d032f a ns1:DiagnosticoFallo ;
    rdfs:label "Si el eje tiene pendiente algún movimiento independiente, esperar a que termine o abortar el movimiento desde el PLC (marca IABORT) o con reset en el canal. Si el eje está sincronizado, anular la sincronización o realizar un reset en el canal." ;
    ns1:textoExtracto "Si el eje tiene pendiente algún movimiento independiente, esperar a que termine o abortar el movimiento desde el PLC (marca IABORT) o con reset en el canal. Si el eje está sincronizado, anular la sincronización o realizar un reset en el canal." .

ns1:TrasInterrumpirUnProgramaConG63ActivaYCambiarAlModoMHFSElUsuarioHaEdi_43b8f54659 a ns1:AccionProhibida ;
    rdfs:label "Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63" ;
    ns1:textoExtracto "No se admite M3/M4/M5/M19/M41-M44 con G63 activa." .

ns1:TrasInterrumpirUnProgramaYCambiarAlModoMHFSElUsuarioHaEditadoUnaM6NoPermitida a ns1:AccionProhibida ;
    rdfs:label "Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M6 no permitida" ;
    ns1:textoExtracto "El cambio de herramienta no permite continuar la ejecución del programa interrumpido." .

ns1:TrasInterrumpirUnProgramaYCambiarAlModoMHFSElUsuarioHaEditadoUnaMOUna_07d3d40389 a ns1:AccionProhibida ;
    rdfs:label "Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M o una S referida a un cabezal que no existe en el canal o en el sistema" ;
    ns1:textoExtracto "Asociar la función al cabezal correcto. Acceder al cabezal desde el canal en el que se encuentra." .

