@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarLaFuncionG63OEsperarAQueFinaliceEstaFuncionAntesDeInterrump_3c51490452 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la función G63 o esperar a que finalice esta función antes de interrumpir el programa" ;
    ns1:solucionaFallo ns1:LaFuncionM3M4M5M19OM41AM44NoEsPermitidaParaG63 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la función G63 o esperar a que finalice esta función antes de interrumpir el programa." .

ns1:LaGamaProgramadaNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La gama programada no existe" ;
    ns1:textoExtracto "'La gama programada no existe'" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:AvisoSeguridad_83dca89e4a ;
    ns1:textoExtracto "Sistema CNC" .

ns1:AvisoSeguridad_83dca89e4a a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad por gama no existente" ;
    ns1:mitigaRiesgo ns1:EditarUnaFuncionMAsociadaAUnaGamaQueNoExisteEnElCabezal ;
    ns1:textoExtracto "'La gama programada no existe'" .

ns1:EditarUnaFuncionMAsociadaAUnaGamaQueNoExisteEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Editar una función M asociada a una gama que no existe en el cabezal" ;
    ns1:textoExtracto "el usuario ha editado una función M asociada a una gama que no existe en el cabezal." .

ns1:LaFuncionM3M4M5M19OM41AM44NoEsPermitidaParaG63 a ns1:DiagnosticoFallo ;
    rdfs:label "La función M3, M4, M5, M19 ó M41 a M44 no es permitida para G63" ;
    ns1:textoExtracto "Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63." .

