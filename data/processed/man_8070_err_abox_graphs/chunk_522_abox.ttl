@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_4029
    a ex:DiagnosticoFallo ;
    rdfs:label "Variable DRV con atributos ilegibles" ;
    ex:textoExtracto "4029 Variable DRV cuyos atributos no pueden ser leídos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA La inicialización del bus Sercos ha fallado porque no se pueden leer los atributos de una variable DRVVAR." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de tabla DRVVAR" ;
        ex:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización."
    ] ;
    .

ex:Fallo_4030
    a ex:DiagnosticoFallo ;
    rdfs:label "Numeración errónea de nodos Sercos" ;
    ex:textoExtracto "4030 Numeración errónea de los nodos Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA La parametrización de nodos Sercos (reguladores y contadoras) no es coherente." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de parametrización de ejes y contadoras Sercos" ;
        ex:textoExtracto "Revisar la parametrización de ejes y contadoras Sercos, y corregir la parametrización."
    ] ;
    .

ex:Fallo_4031
    a ex:DiagnosticoFallo ;
    rdfs:label "Encóderes FeeDat/EnDat incrementales no soportados" ;
    ex:textoExtracto "4031 No se soportan encóderes FeeDat/EnDat incrementales. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha parametrizado algún encóder FeeDat/EnDat de contadora Sercos como incremental." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de encóderes absolutos FeeDat/EnDat" ;
        ex:textoExtracto "Revisar la parametrización de los encóderes FeeDat/EnDat de la contadora Sercos, garantizando que todos sean absolutos."
    ] ;
    .

ex:Fallo_4032
    a ex:DiagnosticoFallo ;
    rdfs:label "Reajuste recomendado de time-scheduling Sercos" ;
    ex:textoExtracto "4032 Se recomienda reajustar el time-scheduling de Sercos (modo Diagnosis). DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. Sólo en modo Setup." ;
    .

ex:Fallo_IDN_DRVVAR
    a ex:DiagnosticoFallo ;
    rdfs:label "Variable DRVVAR con IDN incorrecto" ;
    ex:textoExtracto "ha fallado porque una variable DRVVAR tiene IDN incorrecto. SOLUCIÓN Revisar la tabla DRVVAR y corregir la parametrización. No se completa correctamente la inicialización del bus Sercos mientras la parametrización no sea coherente." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Corrección de IDN en tabla DRVVAR" ;
        ex:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización."
    ] ;
    .

ex:Tabla_DRVVAR a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla DRVVAR" ;
    ex:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización." ;
    .

ex:Parametro_IDN
    a ex:Parametro ;
    rdfs:label "IDN de variable DRVVAR" ;
    ex:textoExtracto "una variable DRVVAR tiene IDN incorrecto" ;
    .

ex:Bus_Sercos
    a ex:Sistema ;
    rdfs:label "Bus Sercos" ;
    ex:textoExtracto "inicialización del bus Sercos" ;
    .

ex:Modo_Diagnosis
    a ex:ModoOperacion ;
    rdfs:label "Modo Diagnosis" ;
    ex:textoExtracto "modo Diagnosis" ;
    .

ex:Modo_Setup
    a ex:ModoOperacion ;
    rdfs:label "Modo Setup" ;
    ex:textoExtracto "modo Setup" ;
    .