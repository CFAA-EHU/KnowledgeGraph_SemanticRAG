@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DecidirCualEsLaFuncionMAEjecutarOEjecutarAmbasDeFormaSucesivaPeroNoSimultanea a ns1:TareaMantenimiento ;
    rdfs:label "Decidir cuál es la función M a ejecutar o ejecutar ambas de forma sucesiva pero no simultánea" ;
    ns1:solucionaFallo ns1:MsIncompatiblesParaElMismoCabezal ;
    ns1:textoExtracto "'Ms incompatibles para el mismo cabezal' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado algunas funciones M3, M4, M5, M19 ó M41 a M44 incompatibles para el mismo cabezal. SOLUCIÓN Decidir cuál es la función M a ejecutar o ejecutar ambas de forma sucesiva pero no simultánea." .

ns1:ProgramarLaGamaCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Programar la gama correcta" ;
    ns1:solucionaFallo ns1:ProgramadaNoExiste ;
    ns1:textoExtracto "'programada no existe' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una función M asociada a una gama que no existe en el cabezal. SOLUCIÓN Programar la gama correcta." .

ns1:ProgramarUnAvanceFParaElEjeCODesactivarElEjeC a ns1:TareaMantenimiento ;
    rdfs:label "Programar un avance F para el eje C o desactivar el eje C" ;
    ns1:solucionaFallo ns1:NoSeAdmiteCambioDeSSiElCabezalTrabajaComoEjeC ;
    ns1:textoExtracto "'No se admite cambio de S si el cabezal trabaja como eje C' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado cambiar la velocidad de un cabezal que está activo como eje C. SOLUCIÓN Programar un avance F para el eje C o desactivar el eje C (#CAX) para programar una velocidad." .

ns1:ProgramarUnNuevoCambioDeEstadoDelCabezalDeManeraQueEsteQuedeEnElMismo_0643309d10 a ns1:TareaMantenimiento ;
    rdfs:label "Programar un nuevo cambio de estado del cabezal, de manera que este quede en el mismo estado que antes de la interrupción" ;
    ns1:solucionaFallo ns1:ElEstadoDelCabezalDebeCoincidirConElDelMomentoDeLaInterrupcion ;
    ns1:textoExtracto "'El estado del cabezal debe coincidir con el del momento de la interrupción' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario intenta salir de este modo con el cabezal en un estado M3, M4, M5 o M19 diferente al inicial. SOLUCIÓN Programar un nuevo cambio de estado del cabezal, de manera que este quede en el mismo estado que antes de la interrupción." .

ns1:SiLosEjesFormanUnAnguloDe90oNoEsNecesariaLaTransformacionAngular a ns1:TareaMantenimiento ;
    rdfs:label "Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular" ;
    ns1:solucionaFallo ns1:ErrorEnElCalculoDeLaTransformadaInversaDelEjeInclinadoANGAX ;
    ns1:textoExtracto "'Error en el cálculo de la transformada inversa del eje inclinado #ANGAX' DETECCIÓN Durante la ejecución. CAUSA En una transformación angular, el eje inclinado y el ortogonal forma un ángulo de 90º. SOLUCIÓN Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular." .

ns1:ElEstadoDelCabezalDebeCoincidirConElDelMomentoDeLaInterrupcion a ns1:DiagnosticoFallo ;
    rdfs:label "El estado del cabezal debe coincidir con el del momento de la interrupción" ;
    ns1:textoExtracto "'El estado del cabezal debe coincidir con el del momento de la interrupción' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario intenta salir de este modo con el cabezal en un estado M3, M4, M5 o M19 diferente al inicial. SOLUCIÓN Programar un nuevo cambio de estado del cabezal, de manera que este quede en el mismo estado que antes de la interrupción." .

ns1:ErrorEnElCalculoDeLaTransformadaInversaDelEjeInclinadoANGAX a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada inversa del eje inclinado #ANGAX" ;
    ns1:textoExtracto "'Error en el cálculo de la transformada inversa del eje inclinado #ANGAX' DETECCIÓN Durante la ejecución. CAUSA En una transformación angular, el eje inclinado y el ortogonal forma un ángulo de 90º. SOLUCIÓN Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular." .

ns1:MsIncompatiblesParaElMismoCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Ms incompatibles para el mismo cabezal" ;
    ns1:textoExtracto "'Ms incompatibles para el mismo cabezal' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado algunas funciones M3, M4, M5, M19 ó M41 a M44 incompatibles para el mismo cabezal. SOLUCIÓN Decidir cuál es la función M a ejecutar o ejecutar ambas de forma sucesiva pero no simultánea." .

ns1:NoSeAdmiteCambioDeSSiElCabezalTrabajaComoEjeC a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de S si el cabezal trabaja como eje C" ;
    ns1:textoExtracto "'No se admite cambio de S si el cabezal trabaja como eje C' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado cambiar la velocidad de un cabezal que está activo como eje C. SOLUCIÓN Programar un avance F para el eje C o desactivar el eje C (#CAX) para programar una velocidad." .

ns1:ProgramadaNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "programada no existe" ;
    ns1:textoExtracto "'programada no existe' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una función M asociada a una gama que no existe en el cabezal. SOLUCIÓN Programar la gama correcta." .

