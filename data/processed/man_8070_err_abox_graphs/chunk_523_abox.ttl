@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnulacionDeLaTransformacionAngular a ns1:TareaMantenimiento ;
    rdfs:label "Anulación de la transformación angular" ;
    ns1:solucionaFallo ns1:ErrorEnElCalculoDeLaTransformadaDirectaDelEjeInclinadoANGAX ;
    ns1:textoExtracto "Anular la transformación angular (#ANGAX OFF) o definir un ángulo diferente de 90º." .

ns1:AvisoSeguridad_f1224f61c0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de detección del ángulo de 90º" ;
    ns1:mitigaRiesgo ns1:TransformacionAngularInnecesaria ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:ErrorEnElCalculoDeLaTransformadaDirectaDelEjeInclinadoANGAX a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada directa del eje inclinado #ANGAX" ;
    ns1:textoExtracto "'Error en el cálculo de la transformada directa del eje inclinado #ANGAX'" .

ns1:TransformacionAngularInnecesaria a ns1:AccionProhibida ;
    rdfs:label "Transformación angular innecesaria" ;
    ns1:textoExtracto "Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular." .

