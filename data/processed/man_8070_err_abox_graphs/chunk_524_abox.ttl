@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_4033
    a ex:DiagnosticoFallo ;
    ex:identificador "4033" ;
    rdfs:label "Parametrizado Gap Control en un regulador que no lo soporta"@es ;
    ex:textoExtracto "4033 Parametrizado Gap Control en un regulador que no lo soporta. DETECCIÓN Al inicializar el bus Sercos. CAUSA El parámetro GAPANAINID indica un regulador Fagor cuya versión no soporta control de gap o el regulador no es Fagor. SOLUCIÓN Utilizar un regulador Fagor con versión de software v9.03 o superior, o anular el control de gap interno del regulador."@es ;
    ex:solucionaFallo ex:Parametro_GAPANAINID .

ex:DiagnosticoFallo_4034
    a ex:DiagnosticoFallo ;
    ex:identificador "4034" ;
    rdfs:label "Para Gap Control, el regulador debe ser Sercos Posición"@es ;
    ex:textoExtracto "4034 Para Gap Control, el regulador debe ser Sercos Posición. DETECCIÓN Al inicializar el bus Sercos. CAUSA El regulador seleccionado para el control de gap no es Sercos posición. SOLUCIÓN Parametrizar correctamente el regulador que debe hacer el control de gap."@es .

ex:DiagnosticoFallo_4035
    a ex:DiagnosticoFallo ;
    ex:identificador "4035" ;
    rdfs:label "Para Gap Control, el regulador debe tener REFMODE = Regulador"@es ;
    ex:textoExtracto "4035 Para Gap Control, el regulador debe tener REFMODE = Regulador. DETECCIÓN Al inicializar el bus Sercos. CAUSA El eje seleccionado para el control de gap tiene su parámetro REFMODE definido como \"CNC\", no como \"Regulador\". SOLUCIÓN Definir el parámetro REFMODE del eje como \"Regulador\"."@es ;
    ex:solucionaFallo ex:Parametro_REFMODE .

ex:DiagnosticoFallo_4036
    a ex:DiagnosticoFallo ;
    ex:identificador "4036" ;
    rdfs:label "Para Gap Control, el regulador debe tener su captación externa libre"@es ;
    ex:textoExtracto "4036 Para Gap Control, el regulador debe tener su captación externa libre. DETECCIÓN Al inicializar el bus Sercos. CAUSA El regulador seleccionado para el control de gap no tiene tarjeta de control de gap instalada (conector X3). SOLUCIÓN Instalar una tarjeta de control de gap en el regulador (conector X3)."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_TarjetaGap_X3 .

ex:DiagnosticoFallo_4037
    a ex:DiagnosticoFallo ;
    ex:identificador "4037" ;
    rdfs:label "El regulador no soporta la escritura síncrona de la variable DRV FFGAIN"@es ;
    ex:textoExtracto "4037 El regulador no soporta la escritura síncrona de la variable DRV FFGAIN. DETECCIÓN Al inicializar el bus Sercos. CAUSA En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona, y el regulador no es AXD o la versión de software es incompatible."@es ;
    ex:solucionaFallo ex:Parametro_FFGAIN .

ex:DiagnosticoFallo_Setup
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagrama de tiempos de Sercos no óptimo"@es ;
    ex:textoExtracto "Setup. CAUSA El diagrama de tiempos de Sercos no es bastante óptimo para garantizar el sincronismo del sistema. SOLUCIÓN Desde la página de diagnosis Sercos, realizar el reajuste de tiempos y aceptar el nuevo diagrama propuesto."@es .

ex:Parametro_GAPANAINID
    a ex:Parametro ;
    ex:identificador "GAPANAINID" ;
    ex:textoExtracto "El parámetro GAPANAINID indica un regulador Fagor cuya versión no soporta control de gap o el regulador no es Fagor."@es .

ex:Parametro_REFMODE
    a ex:Parametro ;
    ex:identificador "REFMODE" ;
    ex:textoExtracto "El eje seleccionado para el control de gap tiene su parámetro REFMODE definido como \"CNC\", no como \"Regulador\"."@es .

ex:Parametro_FFGAIN
    a ex:Parametro ;
    ex:identificador "FFGAIN" ;
    ex:textoExtracto "En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona."@es .

ex:ComponenteElectrico_TarjetaGap_X3
    a ex:ComponenteElectrico ;
    ex:identificador "X3" ;
    ex:textoExtracto "tarjeta de control de gap instalada (conector X3)."@es .

ex:InterfazUsuario_PaginaDiagnosisSercos
    a ex:InterfazUsuario ;
    rdfs:label "Página de diagnosis Sercos"@es ;
    ex:textoExtracto "Desde la página de diagnosis Sercos, realizar el reajuste de tiempos y aceptar el nuevo diagrama propuesto."@es .