@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularTransformacionAngular a ns1:TareaMantenimiento ;
    rdfs:label "Anular transformación angular" ;
    ns1:solucionaFallo ns1:TransformacionAngularNoNecesaria ;
    ns1:textoExtracto "Anular la transformación angular (#ANGAX OFF) o definir un ángulo diferente de 90º." .

ns1:CambiarVelocidadOGamaProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar velocidad o gama programada" ;
    ns1:solucionaFallo ns1:SSuperiorALaGamaProgramada ;
    ns1:textoExtracto "Cambiar la velocidad o la gama programada, o programar sólo uno de ellas para que no resulten contradictorias." .

ns1:ContinuarEjecucionHastaFinalizarM19OG74 a ns1:TareaMantenimiento ;
    rdfs:label "Continuar ejecución hasta finalizar M19 o G74" ;
    ns1:solucionaFallo ns1:FuncionesM3M4M5M19M41M44ConM19OG74Activas ;
    ns1:textoExtracto "Continuar la ejecución hasta que finalice la función M19 o G74. A continuación interrumpir el programa y enviar las funciones deseadas al cabezal." .

ns1:EnviarFuncionesNecesariasAlPLC a ns1:TareaMantenimiento ;
    rdfs:label "Enviar funciones necesarias al PLC" ;
    ns1:solucionaFallo ns1:FuncionesDelCabezalNoEnviadasAlPLC ;
    ns1:textoExtracto "Con el programa interrumpido, cambiar al modo MHFS y enviar las funciones necesarias al PLC." .

ns1:RealizarBusquedaDeReferenciaDelCabezalMaster a ns1:TareaMantenimiento ;
    rdfs:label "Realizar búsqueda de referencia del cabezal master" ;
    ns1:solucionaFallo ns1:SincronizacionEnLazoCerradoConCabezalMasterNoReferenciado ;
    ns1:textoExtracto "Realizar una búsqueda de referencia del cabezal master antes de sincronizar los cabezales." .

ns1:FuncionesDelCabezalNoEnviadasAlPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones del cabezal no enviadas al PLC" ;
    ns1:textoExtracto "Tras una búsqueda de bloque y antes de continuar con la ejecución del programa, el CNC ha detectado que alguna función del cabezal no ha sido enviada al PLC." .

ns1:FuncionesM3M4M5M19M41M44ConM19OG74Activas a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones M3/M4/M5/M19/M41-M44 con M19 o G74 activas" ;
    ns1:textoExtracto "El usuario ha interrumpido el programa durante la ejecución de M19 o G74 en un cabezal. El CNC no puede enviar las funciones M3, M4, M5, M19 ó M41a M44 al cabezal." .

ns1:SSuperiorALaGamaProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "S superior a la gama programada" ;
    ns1:textoExtracto "Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha programado una velocidad y una gama nueva, y la velocidad supera la máxima de la gama." .

ns1:SincronizacionEnLazoCerradoConCabezalMasterNoReferenciado a ns1:DiagnosticoFallo ;
    rdfs:label "Sincronización en lazo cerrado con cabezal master no referenciado" ;
    ns1:textoExtracto "El CNC no puede sincronizar en lazo cerrado un cabezal master, si éste no ha sido previamente referenciado." .

ns1:TransformacionAngularNoNecesaria a ns1:DiagnosticoFallo ;
    rdfs:label "Transformación angular no necesaria" ;
    ns1:textoExtracto "Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular. Anular la transformación angular (#ANGAX OFF) o definir un ángulo diferente de 90º." .

