@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_733593772b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si el CNC selecciona otro cabezal (marca SYNC)" .

ns1:RealizarUnaBusquedaDeReferenciaDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Realizar una búsqueda de referencia del cabezal" ;
    ns1:solucionaFallo ns1:FalloSuperacionUmbral ;
    ns1:textoExtracto "realizar una búsqueda de referencia del cabezal." .

ns1:SuperarElUmbralDeVelocidadDelEncoder a ns1:AccionProhibida ;
    rdfs:label "Superar el umbral de velocidad del encóder" ;
    ns1:mitigaRiesgo ns1:CabezalMaestro ;
    ns1:textoExtracto "'Velocidad de giro de cabezal programada para G33/G34 supera el umbral del encóder'" .

ns1:CabezalMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Maestro del Canal" ;
    ns1:textoExtracto "Si el CNC utiliza el cabezal master del canal" .

ns1:FalloSuperacionUmbral a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la lectura del contaje del cabezal" ;
    ns1:textoExtracto "Superar el umbral de velocidad del encóder supone un error en la lectura del contaje del cabezal." .

