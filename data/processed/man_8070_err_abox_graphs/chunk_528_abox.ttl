ns1:CNC8070_7692f2c362 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CabezalControladoPosicion ;
    ns1:solucionaFallo ns1:PongaseEnContactoConFAGOR ;
