ns1:ErrorEnElSeguimientoDelEjeTangencialSobreLaTrayectoria_b362279856 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el seguimiento del eje tangencial sobre la trayectoria" ;
    ns1:textoExtracto "'Error en el seguimiento del eje tangencial sobre la trayectoria' DETECCIÓN Durante la ejecución. CAUSA El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo." .

ns1:G33G34ProgramacionNoPermitidaSinCabezalControladoEnPosicion_110f7400de a ns1:DiagnosticoFallo ;
    rdfs:label "G33/G34: Programación no permitida sin cabezal controlado en posición" ;
    ns1:textoExtracto "'G33/G34:Programación no permitida sin cabezal controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición." .

ns1:CabezalControladoPosicion a ns1:ComponenteMecanico ;
    rdfs:label "cabezal controlado en posición" ;
    ns1:textoExtracto "'G33/G34:Programación no permitida sin cabezal controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición." .

ns1:PongaseEnContactoConFAGOR a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con FAGOR" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con FAGOR." .

