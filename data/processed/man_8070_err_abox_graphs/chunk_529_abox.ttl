    a ex:Parametro ;
    rdfs:label "SERBRATE" ;
    ex:textoExtracto "parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc."@es ;
    ex:documentadoEn ex:AvisoSeguridad_4209 .

ex:Parametro_OPMODE
    a ex:Parametro ;
