@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeGamaIncorrectoElReguladorNoResponde a ns1:AccionProhibida ;
    rdfs:label "Cambio de gama incorrecto, el regulador no responde" ;
    ns1:solucionaFallo ns1:ComprobarEstadoDelRegulador_3f234e27f9 ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA El CNC no ha finalizado correctamente el cambio de gama de un eje o cabezal porque el regulador no responde a la petición de cambio de gama.'" .

ns1:ControladoEnPosicion a ns1:AccionProhibida ;
    rdfs:label "controlado en posición" ;
    ns1:solucionaFallo ns1:ElCabezalNecesitaUnEncoder ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste no dispone de encóder.'" .

ns1:RETRACEFinalizadoDesactivarMarcaParaContinuar a ns1:AccionProhibida ;
    rdfs:label "RETRACE finalizado, desactivar marca para continuar" ;
    ns1:solucionaFallo ns1:ElPLCDebeDesactivarLaMarcaRETRACEParaQueElProgramaContinue ;
    ns1:textoExtracto "'DETECCIÓN Durante la ejecución. CAUSA Tras finalizar la ejecución en retrace, la marca RETRACE del PLC sigue activa.'" .

ns1:ComprobarEstadoDelRegulador_3f234e27f9 a ns1:DiagnosticoFallo ;
    rdfs:label "Comprobar estado del regulador" ;
    ns1:textoExtracto "'SOLUCIÓN Comprobar estado del regulador.'" .

ns1:ElCabezalNecesitaUnEncoder a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal necesita un encóder" ;
    ns1:textoExtracto "'SOLUCIÓN El cabezal necesita un encóder. Póngase en contacto con su proveedor.'" .

ns1:ElPLCDebeDesactivarLaMarcaRETRACEParaQueElProgramaContinue a ns1:DiagnosticoFallo ;
    rdfs:label "El PLC debe desactivar la marca RETRACE para que el programa continúe" ;
    ns1:textoExtracto "'SOLUCIÓN El PLC debe desactivar la marca RETRACE para que el programa continúe.'" .

