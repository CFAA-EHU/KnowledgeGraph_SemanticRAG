    ex:documentadoEn ex:AvisoSeguridad_4207 .

ex:Parametro_DriveID
    a ex:Parametro ;
    rdfs:label "DriveID (Selector de nodo del regulador)"@es ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID)"@es ;
    ex:documentadoEn ex:AvisoSeguridad_4209 .

