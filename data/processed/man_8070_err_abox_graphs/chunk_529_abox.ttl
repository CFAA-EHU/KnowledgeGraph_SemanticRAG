    a ex:Parametro ;
    rdfs:label "DRSTAF (Drive Status A)"@es ;
    ex:textoExtracto "Vigilancia DRSTAF, DRSTAS o del tandem"@es ;
    ex:documentadoEn ex:AvisoSeguridad_4207 .

