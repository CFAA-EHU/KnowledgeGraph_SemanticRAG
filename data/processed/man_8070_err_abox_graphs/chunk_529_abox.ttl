ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Sistema SERCOS"@es ;
    ex:textoExtracto "Error en el bus Sercos que provoca pérdida de fase 4"@es ;
    ex:documentadoEn ex:Pagina_162 .

ex:ComponenteElectrico_FibraOptica
    a ex:ComponenteElectrico ;
    rdfs:label "Fibra óptica del anillo SERCOS"@es ;
    ex:textoExtracto "Garantizar el buen conexionado e integridad de la fibra óptica"@es ;
    ex:documentadoEn ex:AvisoSeguridad_4209 ;
    ex:tieneComponente ex:Sistema_Sercos .