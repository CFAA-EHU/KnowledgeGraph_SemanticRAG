@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0x00000200
    a ex:AvisoSeguridad ;
    rdfs:label "Pérdida de MSTs (0x00000200)" ;
    ex:textoExtracto "0x00000200 | Pérdida de MSTs." ;
    ex:identificador "0x00000200" ;
    ex:solucionaFallo ex:Fallo_4210 .

ex:Fallo_4210
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (MST perdido)" ;
    ex:textoExtracto "'Error en el anillo Sercos (MST perdido)' [...] Pérdida de un mensaje de sincronismo, que provoca pérdida de fase 4." ;
    ex:identificador "4210" ;
    ex:tieneComponente ex:AnilloSercos .

ex:AnilloSercos
    a ex:Sistema ;
    rdfs:label "Anillo Sercos (fibra óptica, master y esclavos)" ;
    ex:textoExtracto "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." ;
    ex:compuestoPor ex:FibraOptica, ex:MasterSercos, ex:EsclavosSercos .

ex:FibraOptica
    a ex:ComponenteElectrico ;
    rdfs:label "Fibra óptica del anillo Sercos" ;
    ex:textoExtracto "fibra óptica" .

ex:MasterSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Master del anillo Sercos" ;
    ex:textoExtracto "master" .

ex:EsclavosSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Esclavos del anillo Sercos" ;
    ex:textoExtracto "esclavos" .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." ;
    ex:identificador "LOOPTIME" ;
    ex:monitoreaParametro ex:SistemaRegulador .

ex:Parametro_SERPOWSE
    a ex:Parametro ;
    rdfs:label "SERPOWSE" ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." ;
    ex:identificador "SERPOWSE" ;
    ex:monitoreaParametro ex:SistemaRegulador .

ex:Parametro_SERBRATE
    a ex:Parametro ;
    rdfs:label "SERBRATE" ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." ;
    ex:identificador "SERBRATE" ;
    ex:monitoreaParametro ex:SistemaRegulador .

ex:Parametro_OPMODE
    a ex:Parametro ;
    rdfs:label "OPMODE" ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." ;
    ex:identificador "OPMODE" ;
    ex:monitoreaParametro ex:SistemaRegulador .

ex:SistemaRegulador
    a ex:Sistema ;
    rdfs:label "Selector de nodo del regulador (DriveID)" ;
    ex:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." ;
    ex:tieneComponente ex:Parametro_LOOPTIME, ex:Parametro_SERPOWSE, ex:Parametro_SERBRATE, ex:Parametro_OPMODE .

ex:Fallo_4211
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (2 ATs perdidos)" ;
    ex:textoExtracto "'Error en el anillo Sercos (2 ATs perdidos)' [...] EJE Número lógico del eje." ;
    ex:identificador "4211" ;
    ex:tieneComponente ex:AnilloSercos .