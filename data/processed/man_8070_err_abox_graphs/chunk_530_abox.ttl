@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarEstadoDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar estado del regulador" ;
    ns1:solucionaFallo ns1:VelocidadDelCabezalAsociadoAG33G34G95Nula ;
    ns1:textoExtracto "SOLUCIÓN Comprobar estado del regulador." .

ns1:ContinuarLaEjecucionHastaQueFinaliceElCambioDeGama a ns1:TareaMantenimiento ;
    rdfs:label "Continuar la ejecución hasta que finalice el cambio de gama" ;
    ns1:solucionaFallo ns1:NoSeAdmitenSNiFuncionesMOHConProcesoDeCambioDeGamaActivo ;
    ns1:textoExtracto "SOLUCIÓN Continuar la ejecución hasta que finalice el cambio de gama." .

ns1:NoSeAdmitenSNiFuncionesMOHConProcesoDeCambioDeGamaActivo a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten S, ni funciones M o H con proceso de cambio de gama activo" ;
    ns1:textoExtracto "'No se admiten S, ni funciones M o H con proceso de cambio de gama activo'" .

ns1:VelocidadDelCabezalAsociadoAG33G34G95Nula a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad del cabezal asociado a G33/G34/G95 nula" ;
    ns1:textoExtracto "'Velocidad del cabezal asociado a G33/G34/G95 nula'" .

