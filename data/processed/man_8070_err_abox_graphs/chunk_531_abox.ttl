@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_93a3d98b6e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de paso y velocidad superando avance máximo" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'Paso y S de cabezal programados para G33/G34 superan avance máximo permitido'" .

ns1:TareaMantenimiento_5aa737e1ed a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de revisión de programación G33/G34" ;
    ns1:solucionaFallo ns1:FalloAvanceMaximoSuperado ;
    ns1:textoExtracto "Revisar la programación de la función G33/G34." .

ns1:FalloAvanceMaximoSuperado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por avance máximo superado" ;
    ns1:textoExtracto "El paso y la velocidad programados implican un avance que supera el máximo permitido." .

