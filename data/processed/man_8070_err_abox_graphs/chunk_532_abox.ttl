@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionModificarParametroMaquina a ns1:AccionProhibida ;
    ns1:mitigaRiesgo ns1:CNC8070_c3d8ff2444 ;
    ns1:textoExtracto "En caso necesario, revisar los parámetros máquina relacionados con el avance máximo de los ejes implicados en la rosca." .

ns1:Parametro_038c29c8bc a ns1:Parametro ;
    rdfs:label "Parámetro que habilita/deshabilita funciones de Motion Control" ;
    ns1:textoExtracto "El CNC ha intentado modificar el sistema de coordenadas o la transformación de coordenadas teniendo alguna función de motion control activa y el parámetro IMOVEMACH deshabilitado." .

ns1:PongaseEnContactoConFAGOR_0c45beda3f a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor." .

ns1:RevisionDeProgramacion_8f5d6c3a50 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_99ee135a65,
        ns1:LimiteDeVelocidadEsquinaSobrepasada_05434dec15 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación de la función G33/G34. Para mantener el paso programado, modificar la velocidad programada o, si es posible, aumentar desde el PLC el avance máximo del canal." .

ns1:CNC8070_c3d8ff2444 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:DiagnosticoFallo_99ee135a65,
        ns1:LimiteDeVelocidadEsquinaSobrepasada_05434dec15 ;
    ns1:textoExtracto "CNC 8070" .

ns1:DiagnosticoFallo_99ee135a65 a ns1:DiagnosticoFallo ;
    rdfs:label "Función no compatible con Motion Control activo" ;
    ns1:textoExtracto "3074 'Función no compatible con Motion Control activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar el sistema de coordenadas o la transformación de coordenadas teniendo alguna función de motion control activa y el parámetro IMOVEMACH deshabilitado." .

ns1:LimiteDeVelocidadEsquinaSobrepasada_05434dec15 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de velocidad esquina sobrepasada" ;
    ns1:textoExtracto "3073 'Límite de velocidad esquina sobrepasada' DETECCIÓN Durante la ejecución. CAUSA El CNC ha sobrepasado la dinámica de algún eje, durante la transición entre dos bloques." .

