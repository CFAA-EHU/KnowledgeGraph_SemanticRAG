@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorTransmisionATs_0x00008000
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error en la transmisión de ATs (0x00008000)"@es ;
    ex:identificador "0x00008000" ;
    ex:textoExtracto "Error en la transmisión de ATs. ( Fibra óptica o regulador reseteado)"@es .

ex:FibraOptica_ATs
    a               ex:ComponenteElectrico ;
    rdfs:label      "Fibra óptica (sistema ATs)"@es ;
    ex:textoExtracto "Fibra óptica"@es ;
    ex:activaAlarma  ex:ErrorTransmisionATs_0x00008000 .

ex:Regulador_ATs
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador (sistema ATs)"@es ;
    ex:textoExtracto "regulador reseteado"@es ;
    ex:activaAlarma  ex:ErrorTransmisionATs_0x00008000 .