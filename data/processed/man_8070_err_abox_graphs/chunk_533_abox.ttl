@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarEjeParaPoderMoverlo a ns1:AccionProhibida ;
    rdfs:label "Activar eje para poder moverlo" ;
    ns1:solucionaFallo ns1:EjeMultipleDesactivado ;
    ns1:textoExtracto "SOLUCIÓN Activar el eje para poder moverlo (marca SWITCH del PLC)." .

ns1:DesactivarBloqueABloqueDuranteElRetrace a ns1:AccionProhibida ;
    rdfs:label "Desactivar Bloque a Bloque durante el retrace" ;
    ns1:solucionaFallo ns1:NoSeAdmiteBloqueABloqueEnEsteProcesoDeRETRACE ;
    ns1:textoExtracto "SOLUCIÓN Desactivar Bloque a Bloque antes de salir del modo MHFS." .

ns1:DesactivarMarcaRETRACEDelPLCAntesDeSalirDelModoMHFS a ns1:AccionProhibida ;
    rdfs:label "Desactivar marca RETRACE del PLC antes de salir del modo MHFS" ;
    ns1:solucionaFallo ns1:NoEsPosibleSalirDeMHFSConRetraceActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la marca RETRACE del PLC antes de salir del modo MHFS." .

ns1:DeshabilitarFuncionesDeMotionControlAntesDeCambiarElSistemaDeCoordena_44268cfe70 a ns1:AccionProhibida ;
    rdfs:label "Deshabilitar funciones de motion control antes de cambiar el sistema de coordenadas o la transformación de coordenadas" ;
    ns1:solucionaFallo ns1:EjeMultipleDesactivado ;
    ns1:textoExtracto "SOLUCIÓN Deshabilitar las funciones de motion control antes de cambiar el sistema de coordenadas o la transformación de coordenadas." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Durante la ejecución. multieje y está desactivado." .

ns1:NoEsPosibleSalirDeMHFSConRetraceActivo a ns1:DiagnosticoFallo ;
    rdfs:label "'No es posible salir de MHFS con Retrace activo'" ;
    ns1:textoExtracto "3076 'No es posible salir de MHFS con Retrace activo. Desactivar' DETECCIÓN Durante la ejecución." .

ns1:NoSeAdmiteBloqueABloqueEnEsteProcesoDeRETRACE a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite Bloque a Bloque en este proceso de RETRACE'" ;
    ns1:textoExtracto "3077 'No se admite Bloque a Bloque en este proceso de RETRACE; desactivar Bloque a Bloque' DETECCIÓN Durante la ejecución." .

ns1:EjeMultipleDesactivado a ns1:DiagnosticoFallo ;
    rdfs:label "'Eje múltiple desactivado'" ;
    ns1:textoExtracto "3075 'Eje múltiple desactivado' DETECCIÓN Durante la ejecución. multieje y está desactivado." .

