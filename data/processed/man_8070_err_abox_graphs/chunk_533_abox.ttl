@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4213
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en contadora Sercos" ;
    ex:identificador "4213" ;
    ex:textoExtracto "4213 'Error en contadora Sercos' [...] CAUSA La contadora reporta error. SOLUCIÓN Analizar códigos de error (ver manual de la contadora)." ;
    ex:solucionaFallo ex:ErrorContadoraSercos .

ex:ErrorContadoraSercos
    a ex:AvisoSeguridad ;
    ex:textoExtracto "La contadora reporta error." ;
    ex:identificador "NODO_ID_Sercos" .

ex:Error4214
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en búsqueda de I0 de contadora Sercos" ;
    ex:identificador "4214" ;
    ex:textoExtracto "4214 'Error en búsqueda de I0 de contadora Sercos' [...] CAUSA Error durante la búsqueda de I0 de un eje con captación remota Sercos. SOLUCIÓN Analizar la parametrización del proceso; en concreto, el parámetro REFPULSE." ;
    ex:solucionaFallo ex:ErrorBusquedaI0Sercos .

ex:ErrorBusquedaI0Sercos
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Error durante la búsqueda de I0 de un eje con captación remota Sercos." ;
    ex:valor "REFPULSE" .

ex:Error4215
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (Recepción de MDT)" ;
    ex:identificador "4215" ;
    ex:textoExtracto "4215 Error en el anillo Sercos (Recepción de MDT). [...] CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." ;
    ex:solucionaFallo ex:ErrorAnilloSercosMDT .

ex:ErrorAnilloSercosMDT
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ex:Error4216
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (sincronismo)" ;
    ex:identificador "4216" ;
    ex:textoExtracto "4216 Error en el anillo Sercos (sincronismo). [...] CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." ;
    ex:solucionaFallo ex:ErrorAnilloSercosSync .

ex:ErrorAnilloSercosSync
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ex:Error4217
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (Escritura de MDT, buffer 0)" ;
    ex:identificador "4217" ;
    ex:textoExtracto "4217 Error en el anillo Sercos (Escritura de MDT, buffer 0). [...] CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." ;
    ex:solucionaFallo ex:ErrorAnilloSercosEscritura .

ex:ErrorAnilloSercosEscritura
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ex:ErrorBusSercosPerdidaFase
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el bus Sercos (pérdida de fase)" ;
    ex:textoExtracto "Error en el bus Sercos que provoca pérdida de fase." ;
    ex:identificador "4" .

ex:DiagnosticoErrorBusSercos
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error en bus Sercos (pérdida de fase)" ;
    ex:textoExtracto "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." ;
    ex:solucionaFallo ex:ErrorBusSercosPerdidaFase .

ex:SistemaSercos
    a ex:Sistema ;
    rdfs:label "Sistema Sercos (anillo, fibra óptica, master/esclavos)" ;
    ex:textoExtracto "bus Sercos que provoca pérdida de fase [...] anillo (fibra óptica, master y esclavos)." .

ex:PlacasSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Placas de Sercos" ;
    ex:textoExtracto "problemas en las placas de Sercos" ;
    ex:tieneComponente ex:SistemaSercos .