@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElCabezalMasterDeLaSincronizacionNoPasaALazoAbierto_07ae769382 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización no pasa a lazo abierto" ;
    ns1:textoExtracto "'El cabezal master de la sincronización no pasa a lazo abierto'" .

ns1:EvitarSaturarLosRecursosDelSistema a ns1:AvisoSeguridad ;
    rdfs:label "Evitar saturar los recursos del sistema" ;
    ns1:mitigaRiesgo ns1:ActivarModoBloqueABloqueDuranteElRetrace ;
    ns1:textoExtracto "Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas." .

ns1:ActivarModoBloqueABloqueDuranteElRetrace a ns1:AccionProhibida ;
    rdfs:label "Activar modo bloque a bloque durante el retrace" ;
    ns1:mitigaRiesgo ns1:CNC8070_165a09f487 ;
    ns1:textoExtracto "Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos." .

ns1:CNC8070_165a09f487 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC no permite la función bloque a bloque en este tipo de programas." .

