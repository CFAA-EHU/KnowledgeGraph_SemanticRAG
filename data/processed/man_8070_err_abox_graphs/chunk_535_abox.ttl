@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_dae475ad31 a ns1:AccionProhibida ;
    rdfs:label "función bloque a bloque" ;
    ns1:textoExtracto "Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas." .

ns1:AnticipacionParaActivarLaSalidaDigital a ns1:AccionProhibida ;
    rdfs:label "anticipación para activar la salida digital" ;
    ns1:textoExtracto "'No es posible tanta anticipación para activar la salida digital' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada)." .

ns1:AsumirElOffsetDelEjeNoReposicionado a ns1:AccionProhibida ;
    rdfs:label "asumir el offset del eje no reposicionado" ;
    ns1:textoExtracto "'No es posible asumir el offset del eje no reposicionado' DETECCIÓN Durante la ejecución." .

ns1:ElCabezalMasterDeLaSincronizacionNoPasaALazoAbierto_cbb06bf0d5 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización no pasa a lazo abierto" ;
    ns1:textoExtracto "'El cabezal master de la sincronización no pasa a lazo abierto' DETECCIÓN Durante la ejecución." .

