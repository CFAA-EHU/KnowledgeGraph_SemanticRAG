@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DisminuirElTiempoDeCicloOElValorDeLosParametrosDeAnticipacion a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación" ;
    ns1:solucionaFallo ns1:ElRetardoCalculadoParaElLaserEsNegativo ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación." .

ns1:DisminuirLaVelocidadOElTiempoDeCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir la velocidad o el tiempo de ciclo" ;
    ns1:solucionaFallo ns1:LaVelocidadDeCorteEsDemasiadoAltaParaElTamanoDeLaRejilla ;
    ns1:textoExtracto "SOLUCIÓN Disminuir la velocidad o el tiempo de ciclo." .

ns1:ElRetardoCalculadoParaElLaserEsNegativo a ns1:DiagnosticoFallo ;
    rdfs:label "El retardo calculado para el láser es negativo" ;
    ns1:textoExtracto "CAUSA El retardo calculado para el láser es negativo; es decir, no queda margen suficiente de ciclos para la anticipación. SOLUCIÓN Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación." .

ns1:LaVelocidadDeCorteEsDemasiadoAltaParaElTamanoDeLaRejilla a ns1:DiagnosticoFallo ;
    rdfs:label "La velocidad de corte es demasiado alta para el tamaño de la rejilla" ;
    ns1:textoExtracto "CAUSA La velocidad de corte es demasiado alta para el tamaño de la rejilla. SOLUCIÓN Disminuir la velocidad o el tiempo de ciclo." .

