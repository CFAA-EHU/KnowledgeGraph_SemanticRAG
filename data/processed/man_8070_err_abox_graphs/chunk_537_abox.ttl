@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DisminuirElTiempoDeCicloOElValorDeLosParametrosDeAnticipacion a ns1:TareaMantenimiento ;
    rdfs:label "Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación" ;
    ns1:textoExtracto "SOLUCIÓN Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación." .

ns1:ParametroNLOCOUT a ns1:Parametro ;
    rdfs:label "Parámetro NLOCOUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8." .

ns1:ParametroTOF a ns1:Parametro ;
    rdfs:label "Parámetro TOF" ;
    ns1:textoExtracto "Revisar el valor de los parámetros de anticipación TON / TOF." .

ns1:ParametroTON a ns1:Parametro ;
    rdfs:label "Parámetro TON" ;
    ns1:textoExtracto "Revisar el valor de los parámetros de anticipación TON / TOF." .

ns1:RevisarElValorDeLosParametrosDeAnticipacionTONTOF a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el valor de los parámetros de anticipación TON / TOF" ;
    ns1:solucionaFallo ns1:NoEsPosibleTantoRetardoParaActivarLaSalidaDigital ;
    ns1:textoExtracto "SOLUCIÓN Revisar el valor de los parámetros de anticipación TON / TOF." .

ns1:VerificarLasCondicionesParaLaActivacionDesactivacionDelLaser a ns1:TareaMantenimiento ;
    rdfs:label "Verificar las condiciones para la activación/desactivación del láser" ;
    ns1:solucionaFallo ns1:ErrorDelDriverEnLaActivacionDesactivacionDelLaser ;
    ns1:textoExtracto "SOLUCIÓN Verificar las siguientes condiciones: • Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2. • El parámetro NLOCOUT debe ser 8." .

ns1:ErrorDelDriverEnLaActivacionDesactivacionDelLaser a ns1:DiagnosticoFallo ;
    rdfs:label "Error del driver en la activación/desactivación del láser" ;
    ns1:textoExtracto "'Error del driver en la activación/desactivación del láser' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser." .

ns1:NoEsPosibleTantoRetardoParaActivarLaSalidaDigital a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible tanto retardo para activar la salida digital" ;
    ns1:textoExtracto "'No es posible tanto retardo para activar la salida digital' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA El retardo programado para el láser es excesivo." .

