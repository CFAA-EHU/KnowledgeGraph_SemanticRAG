@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_4301
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4301: Acceso a variables Sercos" ;
    ex:textoExtracto "4301 No se puede acceder a las variables Sercos. DETECCIÓN Desde el interface. CAUSA Desde el interface se ha pedido una variable de regulador Sercos, pero el servidor de variables no ha sido inicializado correctamente y no puede acceder a la información de las variables Sercos. SOLUCIÓN Comprobar si el CNC arranco correctamente." ;
    ex:identificador "4301" .

ex:AvisoSeguridad_4302
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4302: Variable Sercos no identificada" ;
    ex:textoExtracto "4302 Variable Sercos no identificada. DETECCIÓN Desde el interface. CAUSA Desde el interface se ha pedido una variable de regulador Sercos, pero la variable es desconocida. SOLUCIÓN Comprobar si el nombre de la variable Sercos es correcto." ;
    ex:identificador "4302" .

ex:AvisoSeguridad_4303
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4303: Variable Sercos sin sets" ;
    ex:textoExtracto "'La variable Sercos no tiene sets' DETECCIÓN En el osciloscopio. CAUSA En un canal del osciloscopio hay definida una variable Sercos, en cuya sintaxis se indica el set pero la variable no tiene sets. SOLUCIÓN Eliminar del nombre de la variable el indicativo del set." ;
    ex:identificador "4303" .

ex:AvisoSeguridad_4500
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4500: Inicialización de Mechatrolink" ;
    ex:textoExtracto "4500 'Error en la inicialización del Hw de Mechatrolink' DETECCIÓN Durante el arranque del CNC. CAUSA No se pudo completar con éxito la fase de inicialización de la comunicación Mechatrolink. SOLUCIÓN Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc) y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." ;
    ex:identificador "4500" .

ex:AvisoSeguridad_4501
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4501: Comando Mechatrolink" ;
    ex:textoExtracto "4501 'Error en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado. SOLUCIÓN Identificar el comando que ha producido el error y el esclavo relacionado." ;
    ex:identificador "4501" .

ex:InterfazUsuario_Osciloscopio
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de osciloscopio" ;
    ex:textoExtracto "DETECCIÓN En el osciloscopio. CAUSA En un canal del osciloscopio hay definida una variable Sercos..." .

ex:InterfazUsuario_Interface
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario" ;
    ex:textoExtracto "DETECCIÓN Desde el interface. CAUSA Desde el interface se ha pedido una variable de regulador Sercos..." .

ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ex:textoExtracto "variable de regulador Sercos... servidor de variables Sercos..." .

ex:Sistema_Mechatrolink
    a ex:Sistema ;
    rdfs:label "Sistema Mechatrolink" ;
    ex:textoExtracto "inicialización del Hw de Mechatrolink... comunicación Mechatrolink... comando Mechatrolink desde el master a un esclavo..." .

ex:Parametro_VariableSercos
    a ex:Parametro ;
    rdfs:label "Variable Sercos" ;
    ex:textoExtracto "variable Sercos... nombre de la variable Sercos..." .

ex:Parametro_ComandoMechatrolink
    a ex:Parametro ;
    rdfs:label "Comando Mechatrolink" ;
    ex:textoExtracto "comando Mechatrolink... comando que ha producido el error..." .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "CNC arrancó correctamente... arranque del CNC... ejecución del CNC..." .

# Relaciones
ex:AvisoSeguridad_4301
    ex:documentadoEn ex:InterfazUsuario_Interface ;
    ex:solucionaFallo ex:Sistema_Sercos .

ex:AvisoSeguridad_4302
    ex:documentadoEn ex:InterfazUsuario_Interface ;
    ex:solucionaFallo ex:Parametro_VariableSercos .

ex:AvisoSeguridad_4303
    ex:documentadoEn ex:InterfazUsuario_Osciloscopio ;
    ex:solucionaFallo ex:Parametro_VariableSercos .

ex:AvisoSeguridad_4500
    ex:solucionaFallo ex:Sistema_Mechatrolink ;
    ex:documentadoEn ex:Maquina_CNC .

ex:AvisoSeguridad_4501
    ex:solucionaFallo ex:Parametro_ComandoMechatrolink ;
    ex:documentadoEn ex:Maquina_CNC .