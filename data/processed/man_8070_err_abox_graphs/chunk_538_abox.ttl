@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4501
    a                   ex:AvisoSeguridad ;
    rdfs:label          "Error en comando Mechatrolink"@es ;
    ex:identificador    "4501" ;
    ex:textoExtracto    "4501 'Error en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado."@es ;
    ex:solucionaFallo   ex:FalloComandoMechatrolink_4501 .

ex:FalloComandoMechatrolink_4501
    a                   ex:DiagnosticoFallo ;
    ex:textoExtracto    "Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado."@es .

ex:Motor_4501
    a                   ex:ComponenteElectrico ;
    ex:textoExtracto    "Verificar [...] conexionado del motor"@es .

ex:SistemaMechatrolink
    a                   ex:Sistema ;
    rdfs:label          "Sistema Mechatrolink"@es ;
    ex:textoExtracto    "Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado"@es ;
    ex:tieneComponente  ex:Motor_4501 ;
    ex:activaAlarma     ex:Error4501 .