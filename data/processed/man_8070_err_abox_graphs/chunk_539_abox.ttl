@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_4502
    a ex:Alarma ;
    rdfs:label "Time out en la inicialización de Mechatrolink" ;
    ex:identificador "4502" ;
    ex:textoExtracto "4502 'Time out en la inicialización de Mechatrolink' DETECCIÓN Durante el arranque del CNC. CAUSA No se ha completado la inicialización de la comunicación Mechatrolink. SOLUCIÓN Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc) y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ex:Alarma_4503
    a ex:Alarma ;
    rdfs:label "Alarma del comando Mechatrolink" ;
    ex:identificador "4503" ;
    ex:textoExtracto "4503 'Alarma del comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA La ejecución de un comando Mechatrolink desde el master a un determinado esclavo provoca una situación de alarma en dicho dispositivo. SOLUCIÓN Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ex:Alarma_4504
    a ex:Alarma ;
    rdfs:label "Error de comunicación en el Bus Mechatrolink" ;
    ex:identificador "4504" ;
    ex:textoExtracto "4504 'Error de comunicación en el Bus Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en el trasvase de información cíclica entre el master Mechatrolink y algún esclavo. SOLUCIÓN Revisar el hardware del master y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ex:AvisoSeguridad_4505
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso en comando Mechatrolink" ;
    ex:identificador "4505" ;
    ex:textoExtracto "4505 'Aviso en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA La ejecución de un comando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo. SOLUCIÓN Identificar el código del warning reportado y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ex:Alarma_4506
    a ex:Alarma ;
    rdfs:label "Falta potencia en esclavo Mechatrolink" ;
    ex:identificador "4506" ;
    ex:textoExtracto "4506 'Falta potencia en esclavo Mechatrolink' DETECCIÓN Durante la ejecución del CNC, una vez que ha entrado en estado de movimiento interpolado. CAUSA Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia." .

ex:Sistema_Mechatrolink
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación Mechatrolink" ;
    ex:textoExtracto "protocolo, tamaño de los datos, número de ejes Mechatrolink, integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación)" ;
    ex:tieneComponente ex:ComponenteElectrico_BusMechatrolink .

ex:ComponenteElectrico_BusMechatrolink
    a ex:ComponenteElectrico ;
    rdfs:label "Bus Mechatrolink (cableado y resistencias terminadoras)" ;
    ex:textoExtracto "integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación)" .

ex:ComponenteElectrico_Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ex:textoExtracto "conexionado del motor" .