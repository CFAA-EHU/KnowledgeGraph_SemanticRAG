@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnElCalculoDeLaTransformadaInversaDelEjeVirtualDeLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada inversa del eje virtual de la herramienta" ;
    ns1:textoExtracto "'Error en el cálculo de la transformada inversa del eje virtual de la herramienta, #VIRTAX'" .

ns1:NoSeCumplenLasCondicionesHardwareODeParametrizacionNecesariasParaPode_b00d527fcc a ns1:AccionProhibida ;
    rdfs:label "No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser" ;
    ns1:mitigaRiesgo ns1:DebenExistirUnaPlacaDeExpansionTipoSercosConIDSoftwareIgualOSuperiorA12,
        ns1:VerificarLosParametrosNLOCOUTYPWMOUTPUT ;
    ns1:textoExtracto "CAUSA No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser." .

ns1:Parametro_908f763f24 a ns1:Parametro ;
    rdfs:label "Parámetro NLOCOUT debe ser 8" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8." .

ns1:Parametro_e39c869f10 a ns1:Parametro ;
    rdfs:label "Parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)" ;
    ns1:identificador "PWMOUTPUT" ;
    ns1:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)." .

ns1:DebenExistirUnaPlacaDeExpansionTipoSercosConIDSoftwareIgualOSuperiorA12 a ns1:AccionProhibida ;
    rdfs:label "Deben existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2" ;
    ns1:textoExtracto "Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2." .

ns1:VerificarLosParametrosNLOCOUTYPWMOUTPUT a ns1:AccionProhibida ;
    rdfs:label "Verificar los parámetros NLOCOUT y PWMOUTPUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8. El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)." .

