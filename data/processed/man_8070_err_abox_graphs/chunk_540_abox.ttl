@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FaltaPotenciaEsclavoMechatrolink_4506
    a               ex:AvisoSeguridad ;
    ex:identificador "4506" ;
    rdfs:label      "Falta potencia en esclavo Mechatrolink"@es ;
    ex:textoExtracto
        "4506 'Falta potencia en esclavo Mechatrolink' DETECCIÓN Durante la ejecución del CNC, una vez que ha entrado en estado de movimiento interpolado. CAUSA Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia."@es .

ex:DiagnosticoFallo_4506
    a               ex:DiagnosticoFallo ;
    ex:solucionaFallo ex:FaltaPotenciaEsclavoMechatrolink_4506 ;
    ex:textoExtracto
        "SOLUCIÓN Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los"@es .