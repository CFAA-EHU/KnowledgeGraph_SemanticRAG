@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnElCalculoDeLaTransformadaDirectaDelEjeVirtualDeLaHerramienta a ns1:Alarma ;
    rdfs:label "'Error en el cálculo de la transformada directa del eje virtual de la herramienta'" ;
    ns1:textoExtracto "3090 'Error en el cálculo de la transformada directa del eje virtual de la herramienta, #VIRTAX' DETECCIÓN Durante la ejecución. CAUSA La transformación de coordenadas máquina a pieza es imposible de ejecutar." .

ns1:ErrorEnElCalculoDeLaTransformadaInversaDelEjeVirtualDeLaHerramienta_507fcb3aad a ns1:Alarma ;
    rdfs:label "'Error en el cálculo de la transformada inversa del eje virtual de la herramienta'" ;
    ns1:textoExtracto "3089 'Error en el cálculo de la transformada inversa del eje virtual de la herramienta, #VIRTAX' DETECCIÓN Durante la ejecución. CAUSA La transformación de coordenadas pieza a máquina es imposible de ejecutar." .

ns1:NoSeHaDetectadoSenalDelSensor a ns1:Alarma ;
    rdfs:label "'No se ha detectado señal del sensor'" ;
    ns1:textoExtracto "3091 No se ha detectado señal del sensor. DETECCIÓN Durante la ejecución. CAUSA Durante el bloque de aproximación a la distancia (GAP) programada en la sentencia #GAPCTRL, el CNC no ha recibido la señal del sensor." .

ns1:Parametro_908f763f24 a ns1:Parametro ;
    rdfs:label "parámetro NLOCOUT" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "parámetro NLOCOUT debe ser 8." ;
    ns1:valor "8" .

ns1:Parametro_e39c869f10 a ns1:Parametro ;
    rdfs:label "parámetro PWMOUTPUT" ;
    ns1:identificador "PWMOUTPUT" ;
    ns1:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)." .

ns1:PongaseEnContactoConFAGOR a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor." .

