@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_815abb8aec a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha intentado desplazar un eje a una cota que se encuentra fuera de una zona de trabajo de no salida." .

ns1:LimiteDeZonaDeTrabajoSobrepasado_bfb4643048 a ns1:AccionProhibida ;
    rdfs:label "Límite de zona de trabajo sobrepasado" ;
    ns1:textoExtracto "'Límite de zona de trabajo sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra fuera de una zona de trabajo de no salida." .

ns1:PuntoDentroDeZonaProhibida_4db912d890 a ns1:AccionProhibida ;
    rdfs:label "Punto dentro de zona prohibida" ;
    ns1:textoExtracto "'Punto dentro de zona prohibida' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra dentro de una zona de trabajo de no entrada." .

ns1:SolucionLimiteDeZonaDeTrabajoSobrepasado a ns1:TareaMantenimiento ;
    rdfs:label "Solución límite de zona de trabajo sobrepasado" ;
    ns1:solucionaFallo ns1:LimiteDeZonaDeTrabajoSobrepasado_f46fd6e8df ;
    ns1:textoExtracto "SOLUCIÓN Mantener los ejes dentro de los límites de la zona de trabajo de no salida. Si algún eje está fuera de los límites, moverlo en el sentido adecuado mediante el teclado de jog." .

ns1:SolucionPuntoDentroDeZonaProhibida a ns1:TareaMantenimiento ;
    rdfs:label "Solución punto dentro de zona prohibida" ;
    ns1:solucionaFallo ns1:PuntoDentroDeZonaProhibida_81ca54acda ;
    ns1:textoExtracto "SOLUCIÓN Mantener los ejes dentro de los límites de la zona de trabajo de no salida. Si algún eje está fuera de los límites, moverlo en el sentido adecuado mediante el teclado de jog." .

