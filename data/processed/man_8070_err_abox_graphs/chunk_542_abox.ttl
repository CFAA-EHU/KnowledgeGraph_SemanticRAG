@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaEnZonaProhibida a ns1:AccionProhibida ;
    rdfs:label "entrada en zona prohibida" ;
    ns1:mitigaRiesgo ns1:MantenerEjesFueraDeLosLimitesDeLaZonaDeTrabajo ;
    ns1:textoExtracto "Si la herramienta está dentro de la zona prohibida, desactivar temporalmente dicha zona, mover el eje en el sentido adecuado mediante el" .

ns1:MantenerEjesFueraDeLosLimitesDeLaZonaDeTrabajo a ns1:TareaMantenimiento ;
    rdfs:label "mantener ejes fuera de los límites de la zona de trabajo" ;
    ns1:textoExtracto "SOLUCIÓN Mantener los ejes fuera de los límites de la zona de trabajo de no entrada." .

