@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_2fd30adc2b a ns1:DiagnosticoFallo ;
    rdfs:label "Sensor detecta distancia negativa" ;
    ns1:solucionadoPor ns1:RevisarCalibracionDelSensor ;
    ns1:textoExtracto "El sensor muestra distancia negativa durante la ejecución con el control de gap activo." .

ns1:MoverEjeFueraDeZonaNoEntrada a ns1:AccionProhibida ;
    rdfs:label "Mover eje fuera de zona no entrada" ;
    ns1:textoExtracto "Si la herramienta está dentro de la zona prohibida, desactivar temporalmente dicha zona, mover el eje en el sentido adecuado mediante el teclado de jog hasta que salga de la zona prohibida y volver a activar la zona de no entrada." .

ns1:PWRCTRLDUTYActivadoEnOtroCanal_ed13d719d0 a ns1:AccionProhibida ;
    rdfs:label "PWRCTRL DUTY activado en otro canal" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:PuntoFinalMalProgramadoEnGAPCTRLOLEAP a ns1:DiagnosticoFallo ;
    rdfs:label "Punto final mal programado en #GAPCTRL o #LEAP" ;
    ns1:solucionadoPor ns1:ComprobarPuntoFinalIndicadoEnLasSentenciasGAPCTRLOLEAP ;
    ns1:textoExtracto "Durante la sentencia #GAPCTRL o #LEAP, el CNC no puede corregir la posición tras recibir la señal del sensor." .

ns1:ComprobarPuntoFinalIndicadoEnLasSentenciasGAPCTRLOLEAP a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar punto final indicado en las sentencias #GAPCTRL o #LEAP" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el punto final indicado en las sentencias #GAPCTRL o #LEAP es correcto." .

ns1:RevisarCalibracionDelSensor a ns1:TareaMantenimiento ;
    rdfs:label "Revisar calibración del sensor" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la calibración del sensor." .

