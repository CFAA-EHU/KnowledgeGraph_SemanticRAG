@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LEAPNoActivadoPorAlturaDeSaltoInferiorAUnMinimo_6cf80adb4d a ns1:DiagnosticoFallo ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo" ;
    ns1:textoExtracto "3099 LEAP no activado por altura de salto inferior a un mínimo. DETECCIÓN Durante la ejecución." .

ns1:PWRCTRLDUTYActivadoEnOtroCanal_be5bfb06fa a ns1:DiagnosticoFallo ;
    rdfs:label "El #PWRCTRL DUTY sólo puede estar activo en un canal",
        "PWRCTRL DUTY activado en otro canal" ;
    ns1:solucionaFallo ns1:ActivarElPWMAntesDeActivarPWRCTRLDUTY ;
    ns1:textoExtracto "SOLUCIÓN El #PWRCTRL DUTY sólo puede estar activo en un canal." .

ns1:PWRCTRLOUTActivadoEnOtroCanal_df92df5a20 a ns1:DiagnosticoFallo ;
    rdfs:label "Activar el PWM antes de activar #PWRCTRL DUTY",
        "El #PWRCTRL OUT sólo puede estar activo en un canal",
        "PWRCTRL OUT activado en otro canal" ;
    ns1:solucionaFallo ns1:ActivarElPWMAntesDeActivarPWRCTRLDUTY ;
    ns1:textoExtracto "3097 PWRCTRL OUT activado en otro canal. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar #PWRCTRL OUT en un canal mientras está activo en otro." .

ns1:ActivarElPWMAntesDeActivarPWRCTRLDUTY a ns1:TareaMantenimiento ;
    rdfs:label "Activar el PWM antes de activar #PWRCTRL DUTY" ;
    ns1:textoExtracto "SOLUCIÓN Activar el PWM antes de activar #PWRCTRL DUTY." .

