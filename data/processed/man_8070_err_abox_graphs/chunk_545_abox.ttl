@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4606
    a ex:AvisoSeguridad ;
    rdfs:label "Error en comando de preparación del bus" ;
    ex:identificador "4606" ;
    ex:textoExtracto "4606 Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la preparación de los parámetros del bus SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Error4607
    a ex:AvisoSeguridad ;
    rdfs:label "Error en comando de actualización del bus" ;
    ex:identificador "4607" ;
    ex:textoExtracto "4607 Error en comando de actualización del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la activación de los parámetros del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Error4608
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la inicialización de la captación" ;
    ex:identificador "4608" ;
    ex:textoExtracto "4608 Error en la inicialización de la captación. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante el reconocimiento de las captaciones. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Error4609
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el reset del bus" ;
    ex:identificador "4609" ;
    ex:textoExtracto "4609 Error en el reset del bus. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error interno durante el proceso de reset del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Error4610
    a ex:AvisoSeguridad ;
    rdfs:label "Error bus sin conexión" ;
    ex:identificador "4610" ;
    ex:textoExtracto "4610 Error bus sin conexión. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Se ha perdido la conexión física en el bus Sercos III; cable desconectado o esclavo apagado sin alimentación. y los esclavos. SOLUCIÓN Revisar el cableado, conexionado y alimentación del CNC" .

ex:Error4611
    a ex:AvisoSeguridad ;
    rdfs:label "Error Bus, mensaje de bus no válido en fase 0" ;
    ex:identificador "4611" ;
    ex:textoExtracto "4611 Error Bus, mensaje de bus no valido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la comunicación con los esclavos en el bus SercosIII. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error4612
    a ex:AvisoSeguridad ;
    rdfs:label "Error bus mensaje no recibido en fase 0" ;
    ex:identificador "4612" ;
    ex:textoExtracto "4612 Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado." .

ex:BusSercosIII
    a ex:ComponenteElectrico ;
    rdfs:label "Bus Sercos III" ;
    ex:textoExtracto "bus Sercos III" .

ex:Error4610
    ex:mitigaRiesgo ex:BusSercosIII .

ex:Error4611
    ex:mitigaRiesgo ex:BusSercosIII .

ex:Error4612
    ex:mitigaRiesgo ex:BusSercosIII .