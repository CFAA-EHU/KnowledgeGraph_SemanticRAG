@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LEAPNoActivadoPorAlturaDeSaltoInferiorAUnMinimo_8982b472a8 a ns1:AvisoSeguridad ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo" ;
    ns1:mitigaRiesgo ns1:FalloAlturaSalto ;
    ns1:textoExtracto "3099 LEAP no activado por altura de salto inferior a un mínimo. DETECCIÓN Durante la ejecución." .

ns1:PotenciaExcesivaEnElCabezalDetectadaDuranteDMC_bb98b1d75a a ns1:AvisoSeguridad ;
    rdfs:label "'Potencia excesiva en el cabezal detectada durante DMC'" ;
    ns1:mitigaRiesgo ns1:FalloPotenciaExcesivaCabezal ;
    ns1:textoExtracto "'Potencia excesiva en el cabezal detectada durante DMC' DETECCIÓN Durante la ejecución." .

ns1:FalloAlturaSalto a ns1:DiagnosticoFallo ;
    rdfs:label "La altura máxima del salto es muy cercana a la posición inicial" ;
    ns1:textoExtracto "CAUSA La altura máxima del salto es muy cercana a la posición inicial. SOLUCIÓN Revisar la programación." .

ns1:FalloPotenciaExcesivaCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo" ;
    ns1:textoExtracto "CAUSA El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo." .

