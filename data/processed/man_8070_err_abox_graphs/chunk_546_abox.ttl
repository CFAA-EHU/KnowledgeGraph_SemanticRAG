@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorBus_4612
    a                   ex:DiagnosticoFallo ;
    ex:identificador    "4612" ;
    rdfs:label          "Error bus mensaje no recibido en fase 0"@es ;
    ex:textoExtracto    "4612 Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado."@es ;
    ex:solucionaFallo   ex:TareaMantenimiento_RevisarCableadoBusSercos .

ex:ErrorBus_4613
    a                   ex:DiagnosticoFallo ;
    ex:identificador    "4613" ;
    rdfs:label          "Error bus número de nodos detectados incorrectos"@es ;
    ex:textoExtracto    "4613 Error bus número de nodos detectados incorrectos. DETECCIÓN Durante el arranque del CNC."@es .

ex:TareaMantenimiento_RevisarCableadoBusSercos
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Revisar cableado, conexionado y alimentación de esclavos en bus Sercos III"@es ;
    ex:textoExtracto    "SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos."@es .

ex:BusSercosIII
    a                   ex:Sistema ;
    rdfs:label          "Bus Sercos III"@es ;
    ex:textoExtracto    "error durante la detección de esclavos en el bus Sercos III"@es ;
    ex:tieneComponente   ex:ComponenteElectrico_EsclavosBusSercos .

ex:ComponenteElectrico_EsclavosBusSercos
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Esclavos del bus Sercos III"@es ;
    ex:textoExtracto    "Alguno de los esclavos se encuentra en error o desconectado"@es .