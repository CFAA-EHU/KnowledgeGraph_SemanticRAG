ns1:AvisoSeguridad_a7614c01c3 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de potencia excesiva en el cabezal" ;
    ns1:mitigaRiesgo ns1:ColisionDeHerramientaConPieza ;
    ns1:textoExtracto "'Potencia excesiva en el cabezal detectada durante DMC.Pulse MARCHA para continuar'" .

