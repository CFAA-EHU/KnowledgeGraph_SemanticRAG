ns1:ColisionDeHerramientaConPieza a ns1:AccionProhibida ;
    rdfs:label "colisión de herramienta con pieza" ;
    ns1:textoExtracto "Esto puede indicar que la herramienta ha colisionado con la pieza, por lo que el CNC detiene los ejes manteniendo el giro del cabezal." .

