@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarQueLaPotenciaObjetivoSeaAlMenosUn20DeLaPotenciaEnVacio a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que la potencia objetivo sea al menos un 20 % de la potencia en vacío" ;
    ns1:solucionaFallo ns1:PotenciaObjetivoInsuficienteParaFuncionamientoCorrectoConDMC ;
    ns1:textoExtracto "La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío." .

ns1:EjecutarSentenciaHSCOSWTEnEjeConMovimientoIndependiente a ns1:AccionProhibida ;
    rdfs:label "Ejecutar sentencia #HSC o #SWT en eje con movimiento independiente" ;
    ns1:textoExtracto "No se pueden programar esas sentencias en un eje con movimiento independiente." .

ns1:FuncionamientoConPotenciaObjetivoInsuficiente a ns1:AccionProhibida ;
    rdfs:label "Funcionamiento con potencia objetivo insuficiente" ;
    ns1:textoExtracto "Los valores de la potencia en vacío y la potencia objetivo durante el mecanizado son similares." .

ns1:NoProgramarSentenciasHSCOSWTEnEjesConMovimientoIndependiente a ns1:TareaMantenimiento ;
    rdfs:label "No programar sentencias #HSC o #SWT en ejes con movimiento independiente" ;
    ns1:solucionaFallo ns1:SentenciaNoCompatibleConMovimientoIndependienteActivo ;
    ns1:textoExtracto "No se pueden programar esas sentencias en un eje con movimiento independiente." .

ns1:PotenciaObjetivoInsuficienteParaFuncionamientoCorrectoConDMC a ns1:DiagnosticoFallo ;
    rdfs:label "Potencia objetivo insuficiente para funcionamiento correcto con DMC" ;
    ns1:textoExtracto "Los valores de la potencia en vacío y la potencia objetivo durante el mecanizado son similares." .

ns1:SentenciaNoCompatibleConMovimientoIndependienteActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia no compatible con movimiento independiente activo" ;
    ns1:textoExtracto "Se ha intentado ejecutar la sentencia #HSC o #SWT en un eje con movimiento independiente." .

