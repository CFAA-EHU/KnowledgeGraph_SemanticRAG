@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarFuncionDMC_93674008a8 a ns1:AccionProhibida ;
    rdfs:label "Desactivar función DMC" ;
    ns1:solucionaFallo ns1:DeteccionDeColisionDuranteEjecucionOSimulacion ;
    ns1:textoExtracto "En este caso se recomienda desactivar la función DMC en este mecanizado." .

ns1:DeteccionDeColisionDuranteEjecucionOSimulacion a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de colisión durante ejecución o simulación" ;
    ns1:textoExtracto "3104 Se ha detectado una colisión. DETECCIÓN Durante la ejecución o la simulación de un programa pieza." .

