@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_7f5e3cde8e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de colisión" ;
    ns1:mitigaRiesgo ns1:FalloColision ;
    ns1:textoExtracto "Se ha detectado una colisión. DETECCIÓN Durante la ejecución o la simulación de un programa pieza." .

ns1:AvisoSeguridad_85bf30258c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de roscado interrumpido" ;
    ns1:mitigaRiesgo ns1:FalloRoscadoInterrumpido ;
    ns1:textoExtracto "Tapping o roscado rígido interrumpido. Retirada permitida en modo manual." .

ns1:MovimientoManualDelEjeDeRoscado a ns1:TareaMantenimiento ;
    rdfs:label "Movimiento manual del eje de roscado" ;
    ns1:solucionaFallo ns1:FalloRoscadoInterrumpido ;
    ns1:textoExtracto "Entrar en modo manual y mover el eje de roscado hasta sacar la herramienta." .

ns1:RevisionYModificacionDelProgramaPieza a ns1:TareaMantenimiento ;
    rdfs:label "Revisión y modificación del programa pieza" ;
    ns1:solucionaFallo ns1:FalloColision ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación y modificar el programa pieza." .

ns1:FalloColision a ns1:DiagnosticoFallo ;
    rdfs:label "Colisión detectada por FCAS" ;
    ns1:textoExtracto "FCAS(Fagor Collision Avoidance System) ha detectado una colisión en alguno de los movimientos que va a ejecutar o simular." .

ns1:FalloRoscadoInterrumpido a ns1:DiagnosticoFallo ;
    rdfs:label "Roscado interrumpido por apagado o error grave" ;
    ns1:textoExtracto "Se ha producido un apagado o un error grave durante la ejecución de un roscado con macho o un roscado rígido." .

