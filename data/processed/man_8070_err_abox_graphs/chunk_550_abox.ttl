@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarEjeIndependienteACanalOEsperarFinalizacionDeIntercambio a ns1:TareaMantenimiento ;
    rdfs:label "Asignar eje independiente a canal o esperar finalización de intercambio" ;
    ns1:solucionaFallo ns1:FalloEjeIndependienteInexistente ;
    ns1:textoExtracto "SOLUCIÓN Asignar el eje independiente a cualquier canal o esperar a que el CNC finalice el intercambio de eje." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:EntrarEnModoManualYMoverElEjeDeRoscadoHastaSacarLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Entrar en modo manual y mover el eje de roscado hasta sacar la herramienta" ;
    ns1:solucionaFallo ns1:OperacionDeEjeIndependienteNoDisponible ;
    ns1:textoExtracto "SOLUCIÓN Entrar en modo manual y mover el eje de roscado hasta sacar la herramienta." .

ns1:EsperarFinalizacionDeOperacionesPendientes a ns1:TareaMantenimiento ;
    rdfs:label "Esperar finalización de operaciones pendientes" ;
    ns1:solucionaFallo ns1:FalloTablaLlena ;
    ns1:textoExtracto "El CNC intenta ejecutar una operación de eje independiente pero ya hay dos operaciones pendientes." .

ns1:NoSeAdmitenMasOperacionesConEjesIndependientes a ns1:AccionProhibida ;
    rdfs:label "No se admiten más operaciones con ejes independientes" ;
    ns1:textoExtracto "No se admiten mas operaciones con ejes independientes. Tabla llena." .

ns1:NoSeAdmitenMasOperacionesConEjesIndependientesTablaLlena_0768368022 a ns1:AccionProhibida ;
    rdfs:label "No se admiten más operaciones con ejes independientes. Tabla llena." ;
    ns1:textoExtracto "No se admiten mas operaciones con ejes independientes. Tabla llena." .

ns1:ProgramarLevaCorrectaODefinirLaLevaEnLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Programar leva correcta o definir la leva en los parámetros máquina" ;
    ns1:solucionaFallo ns1:LevaInexistenteONoDisponible_bb74248323 ;
    ns1:textoExtracto "SOLUCIÓN Programar una leva correcta o definir la leva en los parámetros máquina." .

ns1:FalloEjeIndependienteInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Eje independiente inexistente o no disponible" ;
    ns1:textoExtracto "'Eje independiente inexistente o no disponible'" .

ns1:FalloTablaLlena a ns1:DiagnosticoFallo ;
