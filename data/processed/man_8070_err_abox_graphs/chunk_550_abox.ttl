@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_4638
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Nodo no detectado" ;
    ex:identificador "4638" ;
    ex:textoExtracto "Nodo no detectado. DETECCIÓN Durante el arranque del CNC. CAUSA No se ha detectado un nodo de la topología durante el arranque del CNC." ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Actualización incorrecta de topología" ;
        ex:textoExtracto "Actualizar la topología de acuerdo con los nodos conectados (eliminar nodo de la topología) o revisar cableado, conexionado y alimentación de los esclavos del bus."
    ] .

ex:Fallo_4639
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Nodo encontrado no definido" ;
    ex:identificador "4639" ;
    ex:textoExtracto "Nodo encontrado no definido." .

ex:Empresa_FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation" ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation." .