@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_f14059db06 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de cota programada inferior al límite negativo" ;
    ns1:mitigaRiesgo ns1:FalloEjesFueraDeLimitesSoftware ;
    ns1:textoExtracto "'Cota programada para eje independiente inferior al límite negativo'" .

ns1:ModificacionDeLimitesDeSoftwareDesdeProgramaPiezaOPLC a ns1:AccionProhibida ;
    rdfs:label "Modificación de límites de software desde programa pieza o PLC" ;
    ns1:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:FalloEjesFueraDeLimitesSoftware a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes fuera de los límites de software" ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software." .

