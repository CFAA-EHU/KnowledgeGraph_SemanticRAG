ex:Error4662
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de checksum Hiperface" ;
    ex:identificador "4662" ;
    ex:textoExtracto "4662 Error de checksum Hiperface. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno de checksum en la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation." .

