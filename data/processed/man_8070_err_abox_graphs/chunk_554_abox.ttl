@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4673
    a ex:AvisoSeguridad ;
    rdfs:label "Error scknowledge feedback SSI" ;
    ex:identificador "4673" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Error de acknowledge en un feedback SSI. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Error4674
    a ex:AvisoSeguridad ;
    rdfs:label "Error leyendo los parámetros del encóder digital" ;
    ex:identificador "4674" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Error durante la lectura de parámetros de" .

ex:EncoderDigital
    a ex:Sensor ;
    rdfs:label "Encóder digital" ;
    ex:textoExtracto "Error leyendo los parámetros del encóder digital" ;
    ex:monitoreaParametro ex:ParametrosEncoder .

ex:ParametrosEncoder
    a ex:Parametro ;
    rdfs:label "Parámetros del encóder digital" ;
    ex:textoExtracto "Error durante la lectura de parámetros de" .

ex:SistemaFeedbackSSI
    a ex:Sistema ;
    rdfs:label "Sistema de feedback SSI" ;
    ex:textoExtracto "Error de acknowledge en un feedback SSI" ;
    ex:tieneComponente ex:EncoderDigital .