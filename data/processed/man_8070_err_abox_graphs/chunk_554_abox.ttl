@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1033d8cf9d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre ejes acoplados" ;
    ns1:mitigaRiesgo ns1:UsoDeEjesAcopladosEnOperacionesIndependientes ;
    ns1:textoExtracto "Desactivar el acoplo o las transformaciones existentes." .

ns1:AvisoSeguridad_32aa31ba57 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre límites de software" ;
    ns1:mitigaRiesgo ns1:ModificacionDeLimitesDeSoftware ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:ElEjeNoEsValidoComoEjeIndependiente a ns1:DiagnosticoFallo ;
    rdfs:label "El eje no es válido como eje independiente" ;
    ns1:textoExtracto "'El eje no es válido como eje independiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente en la que interviene un eje que depende de otros o del que dependen otros (por ejemplo ejes gantry, acoplados o que forman parte de una transformación) o bien porque es un eje visualizador, o es módulo y el límite inferior del módulo es negativo." .

ns1:ElValorEstaInferiorAlLimiteNegativo a ns1:DiagnosticoFallo ;
    rdfs:label "El valor está inferior al límite negativo" ;
    ns1:textoExtracto "'inferior al límite negativo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los limites de software." .

ns1:SeHaSuperadoElTiempoMaximoPermitidoParaSincronizar_2afda93146 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha superado el tiempo máximo permitido para sincronizar" ;
    ns1:textoExtracto "'Se ha superado el tiempo máximo permitido para sincronizar' DETECCIÓN Durante la ejecución." .

ns1:ModificacionDeLimitesDeSoftware a ns1:AccionProhibida ;
    rdfs:label "Modificación de límites de software" ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:UsoDeEjesAcopladosEnOperacionesIndependientes a ns1:AccionProhibida ;
    rdfs:label "Uso de ejes acoplados en operaciones independientes" ;
    ns1:textoExtracto "Desactivar el acoplo o las transformaciones existentes." .

