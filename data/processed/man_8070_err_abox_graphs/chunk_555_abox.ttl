@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4674
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4674: Error leyendo los parámetros del encóder digital"@es ;
    ex:textoExtracto "4674 Error leyendo los parámetros del encóder digital. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante la lectura de parámetros de un encóder digital o los datos leídos no son correctos."@es ;
    ex:identificador "4674" .

ex:Error4675
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4675: Encóder digital no soportado"@es ;
    ex:textoExtracto "4675 Encóder digital no soportado. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un encóder digital no soportado o con protocolo digital no soportado."@es ;
    ex:identificador "4675" .

ex:Error4680
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4680: Error configurando referencia"@es ;
    ex:textoExtracto "4680 Error configurando referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la configuración de una referencia."@es ;
    ex:identificador "4680" .

ex:Error4681
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4681: Error de comunicaciones con referencia"@es ;
    ex:textoExtracto "4681 Error de comunicaciones con referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error de comunicación con una referencia."@es ;
    ex:identificador "4681" .

ex:Error4682
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4682: Error de identificación de referencia"@es ;
    ex:textoExtracto "4682 Error de identificación de referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado una referencia no soportada."@es ;
    ex:identificador "4682" .

ex:Error4683
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4683: Error en la actualización de SW de los dispositivos PwC conectados al bus"@es ;
    ex:textoExtracto "4683 Error en la actualización de SW de los dispositivos PwC conectados al bus. DETECCIÓN Durante la ejecución. CAUSA La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo."@es ;
    ex:identificador "4683" .

ex:Error4684
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4684: SW de regulador asociado a la referencia no coincide con el tipo de motor conectado"@es ;
    ex:textoExtracto "4684 SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es ;
    ex:identificador "4684" .

ex:EncoderDigital
    a ex:ComponenteElectrico ;
    rdfs:label "Encóder digital"@es ;
    ex:textoExtracto "Error durante la lectura de parámetros de un encóder digital o los datos leídos no son correctos."@es .

ex:Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor"@es ;
    ex:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es .

ex:Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador"@es ;
    ex:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es .

ex:DispositivoPwC
    a ex:ComponenteElectrico ;
    rdfs:label "Dispositivo PwC"@es ;
    ex:textoExtracto "Error en la actualización de SW de los dispositivos PwC conectados al bus."@es .

ex:BusMechatrolink
    a ex:InterfazUsuario ;
    rdfs:label "Bus Mechatrolink"@es ;
    ex:textoExtracto "La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo."@es .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation."@es .

ex:Error4680 ex:solucionaFallo ex:ErrorConfiguracionReferencia .
ex:ErrorConfiguracionReferencia
    a ex:DiagnosticoFallo ;
    rdfs:label "Error interno de configuración de referencia"@es ;
    ex:textoExtracto "Se ha producido un error interno durante la configuración de una referencia."@es .

ex:Error4681 ex:solucionaFallo ex:ErrorComunicacionReferencia .
ex:ErrorComunicacionReferencia
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de comunicación con referencia"@es ;
    ex:textoExtracto "Se ha producido un error de comunicación con una referencia."@es .

ex:Error4682 ex:solucionaFallo ex:ReferenciaNoSoportada .
ex:ReferenciaNoSoportada
    a ex:DiagnosticoFallo ;
    rdfs:label "Referencia no soportada"@es ;
    ex:textoExtracto "Se ha detectado una referencia no soportada."@es .

ex:Error4684 ex:solucionaFallo ex:IncompatibilidadSWMotor .
ex:IncompatibilidadSWMotor
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre SW de regulador y tipo de motor"@es ;
    ex:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es .

ex:Regulador ex:controla ex:Motor .