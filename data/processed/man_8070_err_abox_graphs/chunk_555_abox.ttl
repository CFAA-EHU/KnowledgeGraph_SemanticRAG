@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AumentarElTiempoDeSincronizacionComenzarLaSincronizacionAVelocidadesM_60331ac874 a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar el tiempo de sincronización, comenzar la sincronización a velocidades más parecidas o aumentar la aceleración del esclavo" ;
    ns1:solucionaFallo ns1:SeHaSuperadoElTiempoMaximoPermitidoParaSincronizar_2afda93146 ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el tiempo de sincronización, comenzar la sincronización a velocidades más parecidas o aumentar la aceleración del esclavo." .

ns1:ElDenominadorDelRatioNoPuedeValerCero a ns1:TareaMantenimiento ;
    rdfs:label "El denominador del ratio no puede valer cero" ;
    ns1:solucionaFallo ns1:NoSePuedeProgramarDenominador0EnSincronizacion_b3069c0c06 ;
    ns1:textoExtracto "SOLUCIÓN El denominador del ratio no puede valer cero." .

ns1:SiLaVelocidadDelEjeMaestroEsAltaHayQueProgramarElMovimientoAdicionalC_bf041a0b80 a ns1:TareaMantenimiento ;
    rdfs:label "Si la velocidad del eje maestro es alta, hay que programar el movimiento adicional con una velocidad más pequeña" ;
    ns1:solucionaFallo ns1:SeIntentaSuperarLaVelocidadMaximaMAXFEED_615c29beff ;
    ns1:textoExtracto "SOLUCIÓN Si la velocidad del eje maestro es alta, hay que programar el movimiento adicional con una velocidad más pequeña." .

ns1:NoSePuedeProgramarDenominador0EnSincronizacion_b3069c0c06 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar denominador 0 en sincronización" ;
    ns1:textoExtracto "'No se puede programar denominador 0 en sincronización' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el denominador del ratio de transmisión tiene valor cero." .

ns1:SeHaSuperadoElTiempoMaximoPermitidoParaSincronizar_2afda93146 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha superado el tiempo máximo permitido para sincronizar" ;
    ns1:textoExtracto "'Se ha superado el tiempo máximo permitido para sincronizar' DETECCIÓN Durante la ejecución. CAUSA La sincronización no alcanza la posición deseada en el tiempo definido." .

ns1:SeIntentaSuperarLaVelocidadMaximaMAXFEED_615c29beff a ns1:DiagnosticoFallo ;
    rdfs:label "Se intenta superar la velocidad máxima MAXFEED" ;
    ns1:textoExtracto "'Se intenta superar la velocidad máxima MAXFEED' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de eje independiente con una sincronización activa y la suma de ambas componentes de velocidad supera la máxima permitida del eje." .

