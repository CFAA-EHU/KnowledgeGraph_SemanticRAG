@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDelDenominadorDelRatioDeTransmision a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del denominador del ratio de transmisión" ;
    ns1:solucionaFallo ns1:NoSePuedeSincronizarEnPosicionConModuloYRatioDiferenteDe1 ;
    ns1:textoExtracto "El denominador del ratio no puede valer cero." .

ns1:CorreccionDelEjeMaestroConModuloYRatioDiferenteDe1 a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del eje maestro con módulo y ratio diferente de 1" ;
    ns1:solucionaFallo ns1:EjeMaestroConModuloYRatioDeTransmisionDiferenteDe1 ;
    ns1:textoExtracto "En una sincronización en posición donde el eje" .

ns1:EjeMaestroConModuloYRatioDeTransmisionDiferenteDe1 a ns1:AccionProhibida ;
    rdfs:label "Eje maestro con módulo y ratio de transmisión diferente de 1" ;
    ns1:textoExtracto "En la sincronización en posición, el eje maestro tiene módulo y el ratio de transmisión es diferente de 1." .

ns1:NoSePuedeSincronizarEnPosicionConModuloYRatioDiferenteDe1 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede sincronizar en posición con módulo y ratio diferente de 1" ;
    ns1:textoExtracto "'No se puede sincronizar en posición con módulo y ratio diferente de 1'" .

