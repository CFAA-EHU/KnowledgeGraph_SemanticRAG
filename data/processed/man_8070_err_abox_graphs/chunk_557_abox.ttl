@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaNoSePuedeProgramarLevaParaEjesConDiferenteValorDeModulo a ns1:TareaMantenimiento ;
    ns1:solucionaFallo ns1:NoSePuedeProgramarLevaParaEjesConDiferenteValorDeModulo ;
    ns1:textoExtracto "Ambos ejes deben tener el mismo módulo (parámetros MODUPLIM y MODLOWLIM iguales)." .

ns1:AceleracionLinealDelTramo1MayorQueLaMaxima a ns1:AccionProhibida ;
    rdfs:label "Aceleración lineal del tramo 1 mayor que la máxima" ;
    ns1:solucionaFallo ns1:ProgramarUnValorMenorQueElMaximoParaLaAceleracion ;
    ns1:textoExtracto "'Aceleración lineal del tramo 1 mayor que la máxima'" .

ns1:AceleracionLinealDelTramo1MenorOIgualACero a ns1:AccionProhibida ;
    rdfs:label "Aceleración lineal del tramo 1 menor o igual a cero" ;
    ns1:solucionaFallo ns1:ProgramarUnValorPositivoParaLaAceleracion ;
    ns1:textoExtracto "'Aceleración lineal del tramo 1 menor o igual a cero'" .

ns1:AceleracionLinealDelTramo2MenorOIgualACero_8eaed11eb2 a ns1:AccionProhibida ;
    rdfs:label "Aceleración lineal del tramo 2 menor o igual a cero" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_2963a9c5da ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 menor o igual a cero'" .

ns1:BusquedaDeCeroIndependienteNoPermitidaEnEjecucion a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de cero independiente no permitida en ejecución" ;
    ns1:textoExtracto "'Búsqueda de cero independiente no permitida en ejecución'" .

ns1:LEAPFROGNoPosibleConLasCotasDadas a ns1:AccionProhibida ;
    rdfs:label "LEAPFROG no posible con las cotas dadas" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_ba32351030 ;
    ns1:textoExtracto "LEAPFROG no posible con las cotas dadas." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controladoPor ns1:SistemaCNC8070_9698f8a3c5 ;
    ns1:textoExtracto "El PLC intenta realizar una búsqueda de referencia mientras el CNC está ejecutado otra." .

ns1:NoSePuedeProgramarLevaParaEjesConDiferenteValorDeModulo a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar leva para ejes con diferente valor de módulo" ;
    ns1:textoExtracto "'No se puede programar leva para ejes con diferente valor de módulo'" .

ns1:ProgramarUnValorMenorQueElMaximoParaLaAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor menor que el máximo para la aceleración" ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor menor que el máximo para la aceleración." .

ns1:ProgramarUnValorPositivoParaLaAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor positivo para la aceleración" ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:RevisarLaProgramacion_2963a9c5da a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:SistemaCNC8070_9698f8a3c5 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:textoExtracto "El PLC debe esperar a que el CNC termine su búsqueda de referencia." .

