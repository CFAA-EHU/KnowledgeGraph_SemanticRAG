@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarUnValorMenorQueElMaximoParaLaAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor menor que el máximo para la aceleración" ;
    ns1:solucionaFallo ns1:AceleracionLinealDelTramo2MayorQueLaMaxima_1d1b6c14a5 ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor menor que el máximo para la aceleración." .

ns1:ProgramarUnValorPositivoParaLaAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Programar un valor positivo para la aceleración" ;
    ns1:solucionaFallo ns1:AceleracionLinealDelTramo2MenorOIgualACero_ae97863ce0 ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:AceleracionLinealDelTramo2MayorQueLaMaxima_1d1b6c14a5 a ns1:DiagnosticoFallo ;
    rdfs:label "Aceleración lineal del tramo 2 mayor que la máxima" ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La aceleración programada es mayor que la máxima." .

ns1:AceleracionLinealDelTramo2MenorOIgualACero_ae97863ce0 a ns1:DiagnosticoFallo ;
    rdfs:label "Aceleración lineal del tramo 2 menor o igual a cero" ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 menor o igual a cero' DETECCIÓN Durante el arranque o durante la ejecución. CAUSA La aceleración programada tiene valor cero." .

