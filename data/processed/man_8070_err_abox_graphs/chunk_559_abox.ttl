ns1:AceleracionProgramadaEsMayorQueLaMaxima a ns1:DiagnosticoFallo ;
    rdfs:label "aceleración programada es mayor que la máxima" ;
    ns1:textoExtracto "'Velocidad de cambio de aceleración mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La aceleración programada es mayor que la máxima." .

