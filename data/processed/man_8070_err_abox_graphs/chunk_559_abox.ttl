    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ElLimiteDeJerkSeVaASobrepasar_c041468619 a ns1:DiagnosticoFallo ;
    rdfs:label "El límite de jerk se va a sobrepasar" ;
    ns1:textoExtracto "'El límite de jerk se va a sobrepasar' DETECCIÓN Durante la ejecución del comando de análisis de frecuencias. CAUSA La frecuencia es demasiado grande para la amplitud programada." .

ns1:ElMovimientoProgramadoVaAColisionarConLaSondaDePalpado a ns1:DiagnosticoFallo ;
    rdfs:label "El movimiento programado va a colisionar con la sonda de palpado" ;
    ns1:textoExtracto "'El movimiento programado va a colisionar con la sonda de palpado' DETECCIÓN Durante la ejecución. CAUSA El movimiento del eje va a superar los límites fijados por el movimiento de palpado anterior." .

ns1:FrecuenciaDemasiadoGrandeParaLaVelocidadProgramada_31ff3472aa a ns1:DiagnosticoFallo ;
    rdfs:label "Frecuencia demasiado grande para la velocidad programada" ;
    ns1:textoExtracto "'Frecuencia demasiado grande para la velocidad programada' DETECCIÓN Durante la ejecución del comando de análisis de frecuencias. CAUSA La velocidad aditiva es menor que la resultante para la frecuencia máxima." .

ns1:ModificarLasCondicionesDeMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Modificar las condiciones de mecanizado" ;
    ns1:solucionaFallo ns1:LimiteDeErrorSobrepasadoEnModoHSC_77dd5368f9 ;
    ns1:textoExtracto "La precisión de la pieza mecanizada puede ser inferior a la tolerancia programada. Modificar las condiciones de mecanizado." .

