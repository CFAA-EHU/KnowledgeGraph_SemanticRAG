ns1:VelocidadDeCabezalNula_8f1a7b072a a ns1:DiagnosticoFallo ;
    rdfs:label "'Velocidad de cabezal nula'" ;
    ns1:textoExtracto "3600 'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA No existe una velocidad de posicionamiento de cabezal programada." .

