@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_5020
    a ex:Alarma ;
    rdfs:label "CNCEX: Ejecución no finalizada" ;
    ex:identificador "5020" ;
    ex:textoExtracto "5020 'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La instrucción CNCEX no puede ejecutar el bloque en el canal indicado. SOLUCIÓN Comprobar el estado del canal programado en la instrucción CNCEX." .

ex:Alarma_5021
    a ex:Alarma ;
    rdfs:label "CNCEX: El canal indicado no es de PLC" ;
    ex:identificador "5021" ;
    ex:textoExtracto "5021 'CNCEX: El canal indicado no es de PLC' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no es de PLC. SOLUCIÓN Comprobar la sintaxis de la instrucción. Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ex:Parametro_CHTYPE
    a ex:Parametro ;
    rdfs:label "Tipo de canal (CHTYPE)" ;
    ex:identificador "CHTYPE" ;
    ex:textoExtracto "Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .