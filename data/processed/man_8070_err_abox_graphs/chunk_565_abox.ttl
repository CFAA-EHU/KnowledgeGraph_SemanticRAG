@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElCabezalEstaEnM19 a ns1:AccionProhibida ;
    rdfs:label "El cabezal está en M19" ;
    ns1:textoExtracto "Si el cabezal está en M19, la sentencia #SERVO OFF no puede abrir el lazo;" .

ns1:ProgramarM3M4M5OHacerUnReset a ns1:TareaMantenimiento ;
    rdfs:label "Programar M3, M4, M5 o hacer un reset" ;
    ns1:solucionaFallo ns1:ElCabezalSeMantieneEnLazoCerrado ;
    ns1:textoExtracto "para abrir el lazo, programar M3, M4, M5 o hacer un reset." .

ns1:ElCabezalSeMantieneEnLazoCerrado a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal se mantiene en lazo cerrado" ;
    ns1:textoExtracto "La sentencia #SERVO OFF cancela la sentencia #SERVO ON y si puede abre el lazo." .

