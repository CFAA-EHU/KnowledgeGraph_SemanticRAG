@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarLaGamaDelCabezalMaestroYOEsclavoEnSuCanalOPasarElCabezalMaestr_4b0af6d41c a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la gama del cabezal maestro y/o esclavo en su canal o pasar el cabezal maestro al canal del esclavo para que el cambio de gama sea automático"@es ;
    ns1:solucionaFallo ns1:ElCabezalMasterDeLaSincronizacionNoEstaEnLaGamaAdecuadaSYNCSETOCAXSET ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la gama del cabezal maestro y/o esclavo en su canal o pasar el cabezal maestro al canal del esclavo para que el cambio de gama sea automático." .

ns1:DesactivarLaMarcaSPDLEREVDelPLC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar la marca SPDLEREV del PLC"@es ;
    ns1:solucionaFallo ns1:NoSeAdmiteSPDLEREVSiElCabezalEstaSincronizadoOEnM19 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la marca SPDLEREV del PLC." .

ns1:Parametro_1be0883943 a ns1:Parametro ;
    rdfs:label "Parámetro SYNCSET"@es ;
    ns1:identificador "SYNCSET" ;
    ns1:textoExtracto "parámetro SYNCSET o parámetro CAXSET si el cabezal maestro está como eje C." .

ns1:Parametro_968c5b1cdb a ns1:Parametro ;
    rdfs:label "Parámetro CAXSET"@es ;
    ns1:identificador "CAXSET" ;
    ns1:textoExtracto "parámetro SYNCSET o parámetro CAXSET si el cabezal maestro está como eje C." .

ns1:ElCabezalMasterDeLaSincronizacionNoEstaEnLaGamaAdecuadaSYNCSETOCAXSET a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización no está en la gama adecuada (SYNCSET ó CAXSET)"@es ;
    ns1:textoExtracto "'El cabezal master de la sincronización no está en la gama adecuada (SYNCSET ó CAXSET)' DETECCIÓN Durante la ejecución. CAUSA El cabezal maestro o esclavo no están en la gama adecuada, parámetro SYNCSET o parámetro CAXSET si el cabezal maestro está como eje C." .

ns1:NoSeAdmiteSPDLEREVSiElCabezalEstaSincronizadoOEnM19 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite SPDLEREV si el cabezal está sincronizado o en M19"@es ;
    ns1:textoExtracto "3612 No se admite SPDLEREV si el cabezal está sincronizado o en M19. DETECCIÓN Durante la ejecución. CAUSA El PLC ha activado la marca SPDLEREV en un cabezal que está sincronizado, ya sea como maestro o como esclavo." .

