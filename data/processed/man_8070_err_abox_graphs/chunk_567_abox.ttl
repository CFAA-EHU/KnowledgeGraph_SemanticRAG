@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorConfiguracionRouter_5033
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5033: Configuración incorrecta del router de recursos remotos" ;
    ex:textoExtracto "5033 Error en la configuración del router de recursos remotos. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún módulo remoto está utilizando un canal que no existe." ;
    ex:identificador "5033" .

ex:ErrorInicializacionModulosRemotos
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de inicialización: Orden incorrecto de comandos en router de recursos" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos." .