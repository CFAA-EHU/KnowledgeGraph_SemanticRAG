@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaAjusteInadecuadoEje a ns1:AccionProhibida ;
    ns1:textoExtracto "Puede ser debido a un ajuste inadecuado del eje" .

ns1:AccionProhibidaFallaSistemaCaptacionMotor a ns1:AccionProhibida ;
    ns1:textoExtracto "en el sistema de captación y/o en la mecánica" .

ns1:AccionProhibidaFaltaHabilitarEje a ns1:AccionProhibida ;
    ns1:textoExtracto "a que falta habilitar el eje" .

ns1:DiagnosticoFalloMotor a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "algún fallo en el motor" .

ns1:DiagnosticoFalloRegulador a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "algún fallo en el regulador" .

ns1:LimitePositivoDefinidoPorMaquina a ns1:Parametro ;
    rdfs:label "Límite positivo definido por máquina" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "parámetro máquina LIMIT+" .

ns1:RevisionDeParametrosYAjustes a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros y ajustes" ;
    ns1:solucionaFallo ns1:LimiteDeSoftwarePositivoSobrepasado_60358c061a ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina, el ajuste del eje, el conexionado, el estado del regulador y el sistema captación-motor." .

ns1:VariableDePosicionLimite a ns1:Parametro ;
    rdfs:label "Variable de posición límite" ;
    ns1:identificador "V.A.RTPOSLIMIT.xn" ;
    ns1:textoExtracto "variable V.A.RTPOSLIMIT.xn" .

ns1:LimiteDeSoftwarePositivoSobrepasado_60358c061a a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de software positivo sobrepasado" ;
    ns1:textoExtracto "'Límite de software positivo sobrepasado'" .

