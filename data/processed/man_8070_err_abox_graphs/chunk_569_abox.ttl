@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InicializacionDelPalpador a ns1:AccionProhibida ;
    rdfs:label "Inicialización del palpador" ;
    ns1:solucionaFallo ns1:ErrorEnLaOperacionConPalpador_e6a1b0867b ;
    ns1:textoExtracto "'Error en la operación con palpador' DETECCIÓN Durante la inicialización del palpador." .

ns1:LimiteDeSoftwareNegativo_79dc7258de a ns1:Parametro ;
    rdfs:label "Límite de software negativo" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "El eje ha superado la cota definida por el parámetro máquina LIMIT- o por la variable V.A.RTNEGLIMIT.xn." .

ns1:LimiteDeSoftwarePositivo_bde359a446 a ns1:Parametro ;
    rdfs:label "Límite de software positivo" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn." .

ns1:PongaseEnContactoConSuProveedor_2838cf5bcf a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con su proveedor" ;
    ns1:solucionaFallo ns1:EsNecesariaLaBusquedaDeCero_be02f45030 ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con su proveedor." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:solucionaFallo ns1:LimiteDeSoftwareNegativoSobrepasado_ccfd8e7928,
        ns1:LimiteDeSoftwarePositivoSobrepasado_f32550ebac ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ErrorEnLaOperacionConPalpador_e6a1b0867b a ns1:Alarma ;
    rdfs:label "Error en la operación con palpador" ;
    ns1:textoExtracto "'Error en la operación con palpador' DETECCIÓN Durante la inicialización del palpador. CAUSA La entrada digital asignada al palpador no es válida." .

ns1:EsNecesariaLaBusquedaDeCero_be02f45030 a ns1:Alarma ;
    rdfs:label "Es necesaria la búsqueda de cero" ;
    ns1:textoExtracto "'Es necesaria la búsqueda de cero' DETECCIÓN Durante la ejecución. CAUSA El CNC ha perdido la referencia del cabezal en la transición de lazo abierto a lazo cerrado." .

ns1:LimiteDeSoftwareNegativoSobrepasado_ccfd8e7928 a ns1:Alarma ;
    rdfs:label "Límite de software negativo sobrepasado" ;
    ns1:textoExtracto "'Límite de software negativo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT- o por la variable V.A.RTNEGLIMIT.xn." .

ns1:LimiteDeSoftwarePositivoSobrepasado_f32550ebac a ns1:Alarma ;
    rdfs:label "Límite de software positivo sobrepasado" ;
    ns1:textoExtracto "'software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn." .

