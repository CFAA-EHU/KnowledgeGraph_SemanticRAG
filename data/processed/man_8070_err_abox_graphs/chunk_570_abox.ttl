@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarElParametroINPOMAX a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar el parámetro INPOMAX" ;
    ns1:solucionaFallo ns1:TiempoMaximoParaEntrarEnBandaDeMuerteSuperado ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el parámetro INPOMAX." .

ns1:ParametrizacionInadecuadaDelEjeFalloEnElModuloDeContajeOReguladorSercos a ns1:AccionProhibida ;
    rdfs:label "Parametrización inadecuada del eje, fallo en el módulo de contaje o regulador Sercos" ;
    ns1:textoExtracto "Puede ser debido a una parametrización inadecuada del eje, a un fallo en el módulo de contaje o en el regulador Sercos, en el sistema de captación o a un error en el conexionado." .

ns1:Parametro_384d14f58c a ns1:Parametro ;
    rdfs:label "Parámetro de tiempo máximo para entrar en banda de muerte" ;
    ns1:identificador "INPOMAX" ;
    ns1:textoExtracto "El tiempo que necesita el eje para entrar en la banda de muerte, para que el CNC considere que está en posición, supera al definido en el parámetro INPOMAX." .

ns1:RevisarLosParametrosDelPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros del palpador" ;
    ns1:solucionaFallo ns1:EntradaDigitalAsignadaAlPalpadorNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros del palpador." .

ns1:RevisarLosParametrosRelacionadosConLaBusquedaDeReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros relacionados con la búsqueda de referencia" ;
    ns1:solucionaFallo ns1:ErrorEnLaBusquedaDeCero ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros relacionados con la búsqueda de referencia, el estado del módulo de contaje o del regulador Sercos, el sistema de captación o el conexionado." .

ns1:EntradaDigitalAsignadaAlPalpadorNoValida a ns1:AccionProhibida ;
    rdfs:label "Entrada digital asignada al palpador no válida" ;
    ns1:textoExtracto "La entrada digital asignada al palpador no es válida." .

ns1:ErrorEnLaBusquedaDeCero a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la búsqueda de cero" ;
    ns1:identificador "3707" ;
    ns1:textoExtracto "'Error en la búsqueda de cero'" .

ns1:TiempoMaximoParaEntrarEnBandaDeMuerteSuperado a ns1:AccionProhibida ;
    rdfs:label "Tiempo máximo para entrar en banda de muerte superado" ;
    ns1:identificador "3708" ;
    ns1:textoExtracto "'Tiempo máximo para entrar en banda de muerte superado'" .

