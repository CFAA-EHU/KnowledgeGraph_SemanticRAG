@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarParametroINPOMAX a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar parámetro INPOMAX" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeLasEntradasAnalogicas ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el parámetro INPOMAX." .

ns1:Parametro_384d14f58c a ns1:Parametro ;
    rdfs:label "Parámetro de ajuste para la entrada analógica máxima" ;
    ns1:identificador "INPOMAX" ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el parámetro INPOMAX." .

ns1:RevisarEstadoDelBusCANYModulosDeEntradasAnalogicas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar estado del bus CAN y módulos de entradas analógicas" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeLasEntradasAnalogicas ;
    ns1:textoExtracto "SOLUCIÓN Revisar el estado del bus CAN, de los módulos de entradas analógicas," .

ns1:ErrorEnElRefrescoDeLasEntradasAnalogicas a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de las entradas analógicas" ;
    ns1:textoExtracto "'Error en el refresco de las entradas analógicas'" .

