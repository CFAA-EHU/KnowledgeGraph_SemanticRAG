@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_5047 a ex:DiagnosticoFallo ;
    rdfs:label "Error desconocido en entrada analógica remota"@es ;
    ex:identificador "5047" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas tiene un error."@es ;
    ex:solucionaFallo ex:Accion_RevisarModuloRemoto_5047 .

ex:Fallo_5048 a ex:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en sensor de temperatura remoto"@es ;
    ex:identificador "5048" ;
    ex:textoExtracto "Error de circuito abierto en un sensor de temperatura remoto. DETECCIÓN Durante el funcionamiento del PLC."@es ;
    ex:solucionaFallo ex:Accion_RevisarModuloRemoto_5048 .

ex:Accion_RevisarModuloRemoto_5047 a ex:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto (fallo 5047)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar módulo remoto."@es .

ex:Accion_RevisarModuloRemoto_5048 a ex:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto (fallo 5048)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar módulo remoto."@es .

ex:SensorTemperatura_5048 a ex:Sensor ;
    rdfs:label "Sensor de temperatura remoto (circuito abierto)"@es ;
    ex:textoExtracto "Error de circuito abierto en un sensor de temperatura remoto."@es .