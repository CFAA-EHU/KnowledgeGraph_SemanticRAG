@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ModuloDeEntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas analógicas" ;
    ns1:textoExtracto "Puede ser debido a problemas en la COMPCI, el bus CAN, el módulo de entradas analógicas, etc." .

ns1:RevisarEstadoDelBusCAN a ns1:TareaMantenimiento ;
    rdfs:label "Revisar estado del bus CAN" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeContajesCAN ;
    ns1:textoExtracto "SOLUCIÓN Revisar el estado del bus CAN, de los módulos de entradas analógicas, el conexionado, etc." .

ns1:RevisarLaLecturaDeLosContajes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la lectura de los contajes" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeContajesCAN ;
    ns1:textoExtracto "SOLUCIÓN Revisar el estado del bus CAN, de los módulos de entradas analógicas, el conexionado, etc." .

ns1:RevisarModuloDeEntradasAnalogicas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar módulo de entradas analógicas" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeContajesCAN ;
    ns1:textoExtracto "SOLUCIÓN Revisar el estado del bus CAN, de los módulos de entradas analógicas, el conexionado, etc." .

ns1:RevisarParametrizacionDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parametrización del eje" ;
    ns1:solucionaFallo ns1:RangoDeValoresDeLaConsignaDePosicionSobrepasados ;
    ns1:textoExtracto "SOLUCIÓN Revisar la parametrización del eje." .

ns1:SistemaCAN a ns1:Sistema ;
    rdfs:label "Sistema CAN" ;
    ns1:textoExtracto "El error puede ser debido a un error en el bus CAN, a un fallo en algún contaje, en el módulo de contaje o a la saturación del bus CAN." .

ns1:RangoDeValoresDeLaConsignaDePosicionSobrepasados a ns1:DiagnosticoFallo ;
    rdfs:label "Rango de valores de la consigna de posición sobrepasados" ;
    ns1:textoExtracto "'Rango de valores de la consigna de posición sobrepasados' DETECCIÓN Durante la ejecución. CAUSA Overflow en la variable de la consigna de posición." .

ns1:ErrorEnElRefrescoDeContajesCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de contajes CAN" ;
    ns1:textoExtracto "'Error en el refresco de contajes CAN' DETECCIÓN Durante la lectura de los contajes de ejes analógicos. CAUSA Si el error muestra el nombre de un eje, el CNC no completó la lectura de los contajes de ese eje." .

