@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error5048
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5048: Circuito abierto en sensor de temperatura remoto" ;
    ex:textoExtracto "5048 Error de circuito abierto en un sensor de temperatura remoto. [...] SOLUCIÓN Revisar el conexionado del sensor de temperatura remoto." ;
    ex:identificador "5048" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5049
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5049: Rango mínimo excedido en sensor de temperatura remoto" ;
    ex:textoExtracto "5049 Un sensor de temperatura remoto ha detectado un error de rango mínimo excedido. [...] SOLUCIÓN Revisar el conexionado del sensor de temperatura remoto." ;
    ex:identificador "5049" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5050
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5050: Fallo de conversión en sensor de temperatura remoto" ;
    ex:textoExtracto "5050 Un sensor de temperatura remoto ha detectado un error conversión. [...] SOLUCIÓN Revisar el conexionado del sensor de temperatura remoto." ;
    ex:identificador "5050" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5051
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5051: Configuración incorrecta en sensor de temperatura remoto" ;
    ex:textoExtracto "5051 Un sensor de temperatura remoto esta configurado incorrectamente. [...] SOLUCIÓN Revisar la configuración del sensor de temperatura remoto." ;
    ex:identificador "5051" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5052
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5052: Fallo de alimentación en sensor de temperatura remoto" ;
    ex:textoExtracto "5052 Un sensor de temperatura remoto ha detectado un error de alimentación. [...] SOLUCIÓN Revisar la alimentación del sensor de temperatura remoto." ;
    ex:identificador "5052" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5053
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5053: Fallo en módulo remoto del sensor de temperatura" ;
    ex:textoExtracto "5053 Un sensor de temperatura remoto ha detectado un error en el módulo. [...] SOLUCIÓN Revisar el módulo remoto del sensor de temperatura." ;
    ex:identificador "5053" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:Error5054
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 5054: Error desconocido en módulo remoto del sensor de temperatura" ;
    ex:textoExtracto "5054 Un sensor de temperatura remoto ha detectado un error desconocido. [...] SOLUCIÓN Revisar el módulo remoto del sensor de temperatura." ;
    ex:identificador "5054" ;
    ex:solucionaFallo ex:SensorTemperaturaRemoto .

ex:SensorTemperaturaRemoto
    a ex:Sensor ;
    rdfs:label "Sensor de temperatura remoto" ;
    ex:textoExtracto "sensor de temperatura remoto" .