@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarPosicionDeLosMicrosDeLosEjesGantry a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar posición de los micros de los ejes gantry" ;
    ns1:solucionaFallo ns1:MicroDelMaestroPulsadoDuranteLaBusquedaDeCeroDelEsclavo ;
    ns1:textoExtracto "SOLUCIÓN Ajustar posición de los micros de los ejes gantry; el eje esclavo debe ser el primero en pulsar el micro." .

ns1:AumentarParametroLOOPTIME a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar parámetro LOOPTIME" ;
    ns1:solucionaFallo ns1:SaturacionEnElBusCAN ;
    ns1:textoExtracto "Revisar la conexión y configuración del bus CAN, el módulo de contaje o aumentar el parámetro LOOPTIME en caso de saturación en el bus." .

ns1:DefinirYValidarParametrosMaquinaDelEjeTandem_cddccdcecc a ns1:TareaMantenimiento ;
    rdfs:label "Definir y validar parámetros máquina del eje tándem" ;
    ns1:solucionaFallo ns1:ElControlTandemNoSeEncuentraActivo ;
    ns1:textoExtracto "SOLUCIÓN Definir y validar los parámetros máquina del eje tándem o habilitar el eje esclavo y reseatear el CNC." .

ns1:HabilitarEjeEsclavoYReseatearCNC a ns1:TareaMantenimiento ;
    rdfs:label "Habilitar eje esclavo y reseatear CNC" ;
    ns1:solucionaFallo ns1:ElControlTandemNoSeEncuentraActivo ;
    ns1:textoExtracto "SOLUCIÓN Definir y validar los parámetros máquina del eje tándem o habilitar el eje esclavo y reseatear el CNC." .

ns1:ParametroLOOPTIME a ns1:Parametro ;
    rdfs:label "Parámetro LOOPTIME" ;
    ns1:textoExtracto "Revisar la conexión y configuración del bus CAN, el módulo de contaje o aumentar el parámetro LOOPTIME en caso de saturación en el bus." .

ns1:RevisarLaConexionYConfiguracionDelBusCAN a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión y configuración del bus CAN" ;
    ns1:solucionaFallo ns1:SaturacionEnElBusCAN ;
    ns1:textoExtracto "SOLUCIÓN Revisar la conexión y configuración del bus CAN, el módulo de contaje o aumentar el parámetro LOOPTIME en caso de saturación en el bus." .

ns1:MicroDelMaestroPulsadoDuranteLaBusquedaDeCeroDelEsclavo a ns1:DiagnosticoFallo ;
    rdfs:label "Micro del maestro pulsado durante la búsqueda de cero del esclavo" ;
    ns1:textoExtracto "'Micro del maestro pulsado durante la búsqueda de cero del esclavo'" .

ns1:ElControlTandemNoSeEncuentraActivo a ns1:DiagnosticoFallo ;
    rdfs:label "El control tándem no se encuentra activo" ;
    ns1:textoExtracto "'El control tándem no se encuentra activo'" .

ns1:SaturacionEnElBusCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Saturación en el bus CAN" ;
    ns1:textoExtracto "Revisar la conexión y configuración del bus CAN, el módulo de contaje o aumentar el parámetro LOOPTIME en caso de saturación en el bus." .

