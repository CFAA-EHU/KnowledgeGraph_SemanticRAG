@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_5055
    a ex:Alarma ;
    rdfs:label "Alarma 5055: Error de rango excedido en sensor de temperatura remoto" ;
    ex:textoExtracto "5055 Un sensor de temperatura remoto ha detectado un error de rango excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La temperatura del sensor de temperatura es menor que el rango permitido." ;
    ex:identificador "5055" ;
    ex:activaAlarma ex:Sensor_Temperatura_Remoto .

ex:Sensor_Temperatura_Remoto
    a ex:Sensor ;
    rdfs:label "Sensor de temperatura remoto" ;
    ex:textoExtracto "módulo remoto del sensor de temperatura. 5055 Un sensor de temperatura remoto ha detectado un error de rango excedido." .

ex:Alarma_5056
    a ex:Alarma ;
    rdfs:label "Alarma 5056: Error de ejecución en salida analógica remota" ;
    ex:textoExtracto "5056 Error de ejecución en el tratamiento de una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos." ;
    ex:identificador "5056" .

ex:Alarma_5057
    a ex:Alarma ;
    rdfs:label "Alarma 5057: Error de ejecución en entrada analógica remota" ;
    ex:textoExtracto "5057 Error de ejecución en el tratamiento de una entrada analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos." ;
    ex:identificador "5057" .