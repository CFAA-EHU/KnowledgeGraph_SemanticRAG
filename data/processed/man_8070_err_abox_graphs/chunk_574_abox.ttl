@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SOLUCIONLas a ns1:TareaMantenimiento ;
    rdfs:label "SOLUCIÓN Las" ;
    ns1:solucionaFallo ns1:ElPLCIntentaAparcarUnEjeQueFormaParteDeUnaParejaGantryUnEjeOCabezalQu_abe17e256c ;
    ns1:textoExtracto "SOLUCIÓN Las" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:activaAlarma ns1:NoSePuedenAparcarEjesGantryOTandemNiEjesHabilitadosConDRENAOSPENA ;
    ns1:textoExtracto "desde PLC." .

ns1:ElPLCIntentaAparcarUnEjeQueFormaParteDeUnaParejaGantryUnEjeOCabezalQu_abe17e256c a ns1:DiagnosticoFallo ;
    rdfs:label "El PLC intenta aparcar un eje que forma parte de una pareja gantry, un eje o cabezal que forma parte de una pareja tándem o un eje habilitado (DRENA/SPENA)" ;
    ns1:textoExtracto "CAUSA El PLC intenta aparcar un eje que forma parte de una pareja gantry, un eje o cabezal que forma parte de una pareja tándem o un eje habilitado (DRENA/SPENA)." .

ns1:NoSePuedenAparcarEjesGantryOTandemNiEjesHabilitadosConDRENAOSPENA a ns1:AccionProhibida ;
    rdfs:label "No se pueden aparcar ejes gantry o tándem ni ejes habilitados con DRENA o SPENA" ;
    ns1:textoExtracto "No se pueden aparcar ejes gantry o tándem ni ejes habilitados con DRENA o SPENA DETECCIÓN Aparcando un eje o cabezal desde PLC." .

