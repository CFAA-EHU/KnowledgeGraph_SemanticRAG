@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_6003
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Emergencia externa activada" ;
    ex:identificador        "6003" ;
    ex:textoExtracto        "6003 'Emergencia externa activada' DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC. CAUSA La marca _EMERGEN del PLC está desactivada." ;
    ex:solucionaFallo       ex:Accion_ComprobarPulsadoresEmergencia ,
                            ex:Accion_ComprobarLogicaPLC .

ex:Fallo_6004
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Error en la inicialización del Bus CAN" ;
    ex:identificador        "6004" ;
    ex:textoExtracto        "6004 'Error en la inicialización del Bus CAN' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la inicialización del bus CAN que tiene" .

ex:Accion_ComprobarPulsadoresEmergencia
    a                       ex:TareaMantenimiento ;
    rdfs:label              "Comprobar el estado de los pulsadores de emergencia" ;
    ex:textoExtracto        "Comprobar el estado de los pulsadores de emergencia." .

ex:Accion_ComprobarLogicaPLC
    a                       ex:TareaMantenimiento ;
    rdfs:label              "Comprobar la lógica de la señal _EMERGEN en el programa de PLC" ;
    ex:textoExtracto        "Comprobar la lógica de la señal _EMERGEN en el programa de PLC." .

ex:Accion_PonerMarchaPLC
    a                       ex:TareaMantenimiento ;
    rdfs:label              "Poner en marcha el programa PLC" ;
    ex:textoExtracto        "SOLUCIÓN Poner en marcha el programa PLC. Si es necesario, compilar el programa de PLC." .