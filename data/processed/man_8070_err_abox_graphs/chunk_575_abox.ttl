@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AparcarEjeGantryOTandem a ns1:AccionProhibida ;
    rdfs:label "Aparcar eje gantry o tándem" ;
    ns1:textoExtracto "Los ejes gantry y tándem no se pueden aparcar, ni desde el PLC ni desde el CNC." .

ns1:AparcarEjeHabilitadoDRENASPENA a ns1:AccionProhibida ;
    rdfs:label "Aparcar eje habilitado (DRENA/SPENA)" ;
    ns1:textoExtracto "Deshabilitar el eje antes de aparcarlo (señales DRENA/SPENA)." .

ns1:BusquedaDeReferenciaMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina" ;
    ns1:solucionaFallo ns1:FalloSobrepasamientoCompensacionModulo ;
    ns1:textoExtracto "Realizar una búsqueda de referencia máquina." .

ns1:CNC8070_41c5511041 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:EjeRotativo ;
    ns1:textoExtracto "CNC 8070" .

ns1:EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo o cabezal" ;
    ns1:textoExtracto "Durante el movimiento de un eje rotativo o cabezal." .

ns1:FalloSobrepasamientoCompensacionModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrepasamiento en la compensación de módulo" ;
    ns1:textoExtracto "'Sobrepasamiento en la compensación de módulo'" .

