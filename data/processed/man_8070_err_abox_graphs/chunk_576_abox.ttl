@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_EMERGEN
    a               ex:Sensor ;
    rdfs:label      "Señal _EMERGEN"@es ;
    ex:textoExtracto "la lógica de la señal _EMERGEN en el programa de PLC"@es ;
    ex:identificador "_EMERGEN" .

ex:Error_6004
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 6004: Error en la inicialización del Bus CAN"@es ;
    ex:identificador "6004" ;
    ex:textoExtracto "6004 'Error en la inicialización del Bus CAN' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la inicialización del bus CAN que tiene lugar en el arranque, con objeto de poner en marcha el teclado de CAN."@es .

ex:Bus_CANopen
    a               ex:ComponenteElectrico ;
    rdfs:label      "Bus CANopen"@es ;
    ex:textoExtracto "Códigos de error para el bus CANopen."@es ;
    ex:activaAlarma  ex:Error_6004 .

ex:Bus_CANfagor
    a               ex:ComponenteElectrico ;
    rdfs:label      "Bus CANfagor"@es ;
    ex:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen."@es ;
    ex:activaAlarma  ex:Error_6004 .

ex:Teclado_CAN
    a               ex:InterfazUsuario ;
    rdfs:label      "Teclado de CAN"@es ;
    ex:textoExtracto "poner en marcha el teclado de CAN"@es .