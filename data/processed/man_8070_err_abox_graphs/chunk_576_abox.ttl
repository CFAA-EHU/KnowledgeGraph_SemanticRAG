@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloUmbralContajeEncoderSuperado a ns1:DiagnosticoFallo ;
    rdfs:label "Superado umbral de contaje del encoder. Buscar cero para recuperar cota." ;
    ns1:textoExtracto "'Superado umbral de contaje del encoder. Buscar cero para recuperar cota.'" .

ns1:LimitarVelocidadMaxima a ns1:TareaMantenimiento ;
    rdfs:label "Limitar velocidad máxima" ;
    ns1:solucionaFallo ns1:FalloMaximaConsignaVelocidadSuperada ;
    ns1:textoExtracto "Limitar la velocidad máxima (parámetro G00FEED) al valor que indica el warning para evitar el sobrepasamiento." .

ns1:MaximaConsignaDeVelocidadSuperada a ns1:AccionProhibida ;
    rdfs:label "Máxima consigna de velocidad superada" ;
    ns1:textoExtracto "'Máxima consigna de velocidad superada'" .

ns1:Parametro_6e8777ebf2 a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "Limitar la velocidad máxima (parámetro G00FEED) al valor que indica el warning para evitar el sobrepasamiento." .

ns1:Parametro_7072aa59ad a ns1:Parametro ;
    rdfs:label "INPUTREV",
        "OUTPUTREV",
        "PITCH",
        "PROGAIN" ;
    ns1:textoExtracto "Revisar los parámetros máquina PITCH, INPUTREV, OUTPUTREV y PROGAIN." .

ns1:RevisarParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros máquina" ;
    ns1:solucionaFallo ns1:FalloMaximaConsignaVelocidadSuperada ;
    ns1:textoExtracto "Revisar los parámetros máquina PITCH, INPUTREV, OUTPUTREV y PROGAIN." .

ns1:SuperadoUmbralDeContajeDelEncoderBuscarCeroParaRecuperarCota a ns1:AccionProhibida ;
    rdfs:label "Superado umbral de contaje del encoder. Buscar cero para recuperar cota." ;
    ns1:textoExtracto "'Superado umbral de contaje del encoder. Buscar cero para recuperar cota.'" .

ns1:FalloMaximaConsignaVelocidadSuperada a ns1:DiagnosticoFallo ;
    rdfs:label "Máxima consigna de velocidad superada" ;
    ns1:textoExtracto "'Máxima consigna de velocidad superada'" .

