@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_6006
    a               ex:DiagnosticoFallo ;
    ex:identificador "6006" ;
    rdfs:label      "'Uno o varios nodos CAN no responden'"@es ;
    ex:textoExtracto
        "6006 'Uno o varios nodos CAN no responden' DETECCIÓN Durante la ejecución. CAUSA Uno o varios nodos remotos dejan de responder por reset, cortocircuitos, mal funcionamiento, etc."@es .

ex:Sistema_BusCANfagor
    a               ex:Sistema ;
    rdfs:label      "Bus CANfagor"@es ;
    ex:textoExtracto
        "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen."@es .

ex:Sistema_BusCANopen
    a               ex:Sistema ;
    rdfs:label      "Bus CANopen"@es ;
    ex:textoExtracto
        "Para el bus CANopen, la ventana de error indica cuál es el módulo provoca el error."@es .

ex:Interfaz_VentanaErrorCANopen
    a               ex:InterfazUsuario ;
    rdfs:label      "Ventana de error CANopen"@es ;
    ex:textoExtracto
        "la ventana de error indica cuál es el módulo provoca el error"@es ;
    ex:monitoreaParametro ex:Sistema_BusCANopen .