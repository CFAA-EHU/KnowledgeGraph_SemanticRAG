@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AparcarCabezalEnSituacionNoPermitida a ns1:AccionProhibida ;
    rdfs:label "Aparcar cabezal en situacion no permitida" ;
    ns1:textoExtracto "El PLC no puede aparcar el cabezal en esa situación." .

ns1:DefinirLimitesDeVentanaDePalpadoDesdePLCIncorrectamente a ns1:AccionProhibida ;
    rdfs:label "Definir límites de ventana de palpado desde PLC incorrectamente" ;
    ns1:textoExtracto "Error en los límites de la ventana de palpado desde PLC." .

ns1:DiagnosticoFallo_28515c4749 a ns1:DiagnosticoFallo ;
    rdfs:label "Palpador no disponible. Ocupado por otro proceso" ;
    ns1:identificador "3720" ;
    ns1:textoExtracto "'Palpador no disponible. Ocupado por otro proceso'" .

ns1:EjecutarPalpacionMientrasOtroProcesoEstaEnCurso a ns1:AccionProhibida ;
    rdfs:label "Ejecutar palpación mientras otro proceso está en curso" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar una palpación pero el palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE)." .

ns1:ErrorEnLosLimitesDeLaVentanaDePalpadoDesdePLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error en los límites de la ventana de palpado desde PLC" ;
    ns1:identificador "3722" ;
    ns1:textoExtracto "Error en los límites de la ventana de palpado desde PLC." .

ns1:InicializarPalpadorConParametrosNoCoherentes a ns1:AccionProhibida ;
    rdfs:label "Inicializar palpador con parámetros no coherentes" ;
    ns1:textoExtracto "Los parámetros del palpador no son coherentes." .

ns1:RevisarParametrosDelPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros del palpador" ;
    ns1:solucionaFallo ns1:ErrorEnLaInicializacionDelPalpador ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ns1:ErrorEnLaInicializacionDelPalpador a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del palpador" ;
    ns1:identificador "3721" ;
    ns1:textoExtracto "Error en la inicialización del palpador." .

