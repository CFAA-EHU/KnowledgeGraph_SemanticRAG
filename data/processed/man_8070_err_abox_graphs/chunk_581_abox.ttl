@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_203b4a964d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca DRO)." .

ns1:TareaMantenimiento_0b3a20a69a a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de comprobación de marca SWITCH" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3dc0ce2512 ;
    ns1:textoExtracto "Al desactivar la marca SWITCH del eje." .

ns1:TareaMantenimiento_2e18661336 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de condición del permiso de movimiento" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_a3ea2625b4 ;
    ns1:textoExtracto "En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados." .

ns1:TareaMantenimiento_ca5d4b30ae a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de revisión de programación" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_60712c9103,
        ns1:AvisoSeguridad_9013412e0e,
        ns1:AvisoSeguridad_e98bf43cbc ;
    ns1:textoExtracto "Revisar la programación." .

ns1:AvisoSeguridad_3dc0ce2512 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad por desactivación de un eje múltiple sin entrar en posición" ;
    ns1:textoExtracto "'No se permite desactivar un eje múltiple sin entrar en posición'" .

ns1:AvisoSeguridad_60712c9103 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para G174 para un eje sincronizado" ;
    ns1:textoExtracto "'No se permite G174 para un eje que está sincronizado'" .

ns1:AvisoSeguridad_9013412e0e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para G174 si el eje no está en posición" ;
    ns1:textoExtracto "'No se permite G174 si el eje no está en posición'" .

ns1:AvisoSeguridad_a3ea2625b4 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad por falta de Drive Status Ready del eje esclavo" ;
    ns1:textoExtracto "'Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem'" .

ns1:AvisoSeguridad_e98bf43cbc a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para G174 en modo visualizador" ;
    ns1:textoExtracto "'No se admite G174 para eje en modo visualizador'" .

