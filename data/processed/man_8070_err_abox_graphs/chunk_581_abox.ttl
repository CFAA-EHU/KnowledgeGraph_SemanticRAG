@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosErrorCAN a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de error CAN"@es ;
    ex:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 1 | Overrun en el controlador de CAN. Posible pérdida de mensajes recibidos. |
| 2 | BusOFF. El nodo detecta que cae el bus. |
| 3 | Overrun en la fifo de recepción. Posible pérdida de mensajes recibidos. |
| 4 | Warning. Contador de tramas de error supera el nivel 1 (96). |
| 11 | El nodo informa que la COMPCI no responde a los controles de presencia. |
| 12 | Reset del nodo (problemas de alimentación, cortos, watchdog, etc). |
| 13 | Fallo en la transmisión de un mensaje.
"""@es ;
    ex:documentadoEn ex:Manual_6000_6999 .

ex:ErrorCAN_OverrunControlador
    a ex:AvisoSeguridad ;
    rdfs:label "Overrun en el controlador de CAN"@es ;
    ex:identificador "1" ;
    ex:textoExtracto "Overrun en el controlador de CAN. Posible pérdida de mensajes recibidos."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_BusOFF
    a ex:AvisoSeguridad ;
    rdfs:label "BusOFF"@es ;
    ex:identificador "2" ;
    ex:textoExtracto "BusOFF. El nodo detecta que cae el bus."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_OverrunFIFO
    a ex:AvisoSeguridad ;
    rdfs:label "Overrun en la FIFO de recepción"@es ;
    ex:identificador "3" ;
    ex:textoExtracto "Overrun en la fifo de recepción. Posible pérdida de mensajes recibidos."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_WarningTramas
    a ex:AvisoSeguridad ;
    rdfs:label "Warning por contador de tramas de error"@es ;
    ex:identificador "4" ;
    ex:textoExtracto "Warning. Contador de tramas de error supera el nivel 1 (96)."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_COMPCINoResponde
    a ex:AvisoSeguridad ;
    rdfs:label "COMPCI no responde"@es ;
    ex:identificador "11" ;
    ex:textoExtracto "El nodo informa que la COMPCI no responde a los controles de presencia."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_ResetNodo
    a ex:AvisoSeguridad ;
    rdfs:label "Reset del nodo CAN"@es ;
    ex:identificador "12" ;
    ex:textoExtracto "Reset del nodo (problemas de alimentación, cortos, watchdog, etc)."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:ErrorCAN_FalloTransmision
    a ex:AvisoSeguridad ;
    rdfs:label "Fallo en transmisión de mensaje CAN"@es ;
    ex:identificador "13" ;
    ex:textoExtracto "Fallo en la transmisión de un mensaje."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .

ex:Sistema_CANfagor
    a ex:Sistema ;
    rdfs:label "Bus CANfagor"@es ;
    ex:textoExtracto "Tipo de módulo que genera el error para el bus CANfagor."@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorCAN .