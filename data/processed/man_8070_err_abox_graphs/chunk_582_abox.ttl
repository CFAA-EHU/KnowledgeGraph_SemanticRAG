@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CondicionarElPermisoDelMovimientoAQueAmbosEjesDelTandemEstenHabilitados a ns1:TareaMantenimiento ;
    rdfs:label "Condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados" ;
    ns1:solucionaFallo ns1:FalloEjeMultipleConComandoEnEjecucion ;
    ns1:textoExtracto "En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados." .

ns1:CondicionarLaDesactivacionDelEjeAQueEsteSeEncuentreEnPosicion a ns1:TareaMantenimiento ;
    rdfs:label "Condicionar la desactivación del eje a que éste se encuentre en posición" ;
    ns1:textoExtracto "En la maniobra del PLC, condicionar la desactivación del eje a que éste se encuentre en posición; es decir, que no esté en movimiento." .

ns1:NoSePermiteDesactivarUnEjeMultipleSinEntrarEnPosicion a ns1:AccionProhibida ;
    rdfs:label "No se permite desactivar un eje múltiple sin entrar en posición" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "'No se permite desactivar un eje múltiple sin entrar en posición'" .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:FalloEjeMultipleConComandoEnEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido" ;
    ns1:textoExtracto "'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido'" .

