@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1d1916af68 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para eje múltiple con comando en ejecución" ;
    ns1:mitigaRiesgo ns1:FalloEjeMultipleConComandoEnEjecucion ;
    ns1:textoExtracto "'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido'" .

ns1:AvisoSeguridad_7f4e3b8140 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para TOUCHPROBE con flanco diferente" ;
    ns1:mitigaRiesgo ns1:FalloTouchProbeFlancoDiferente ;
    ns1:textoExtracto "'TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo'" .

ns1:AvisoSeguridad_cb6473493a a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para refresco de contajes locales" ;
    ns1:mitigaRiesgo ns1:FalloRefrescoContajesLocales ;
    ns1:textoExtracto "Error en el refresco de contajes locales." .

ns1:AvisoSeguridad_f678b683cf a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para más de un eje del grupo múltiple activo" ;
    ns1:mitigaRiesgo ns1:FalloMultiplesEjesActivos ;
    ns1:textoExtracto "'No se permite más de un eje del grupo múltiple activo'" .

ns1:AvisoSeguridad_fe9813bb8c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para desplazamiento no válido" ;
    ns1:mitigaRiesgo ns1:FalloDesplazamientoNoValido ;
    ns1:textoExtracto "'G174: Desplazamiento no válido, valor demasiado grande'" .

ns1:TareaMantenimiento_ee2cf707a2 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de condición para desactivación del eje" ;
    ns1:solucionaFallo ns1:FalloDesplazamientoNoValido,
        ns1:FalloEjeMultipleConComandoEnEjecucion,
        ns1:FalloMultiplesEjesActivos,
        ns1:FalloRefrescoContajesLocales,
        ns1:FalloTouchProbeFlancoDiferente ;
    ns1:textoExtracto "condicionar la desactivación del eje a que éste se encuentre en posición; es decir, que no esté en movimiento." .

ns1:FalloDesplazamientoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Error de desplazamiento no válido" ;
    ns1:textoExtracto "'G174: Desplazamiento no válido, valor demasiado grande'" .

ns1:FalloEjeMultipleConComandoEnEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "Error de eje múltiple con comando en ejecución" ;
    ns1:textoExtracto "'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido'" .

ns1:FalloMultiplesEjesActivos a ns1:DiagnosticoFallo ;
    rdfs:label "Error de más de un eje del grupo múltiple activo" ;
    ns1:textoExtracto "'No se permite más de un eje del grupo múltiple activo'" .

ns1:FalloRefrescoContajesLocales a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ns1:textoExtracto "Error en el refresco de contajes locales." .

ns1:FalloTouchProbeFlancoDiferente a ns1:DiagnosticoFallo ;
    rdfs:label "Error de TOUCHPROBE con flanco diferente" ;
    ns1:textoExtracto "'TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo'" .

