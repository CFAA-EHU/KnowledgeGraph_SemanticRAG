@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorCANopen_EmergenciaExterna
    a ex:AvisoSeguridad ;
    rdfs:label "Emergencia externa (CANopen)" ;
    ex:textoExtracto "Report de nodo CANopen:Emergencia externa." ;
    ex:identificador "3" .

ex:ErrorCANopen_EmergenciaFabricante
    a ex:AvisoSeguridad ;
    rdfs:label "Emergencia específica de fabricante (CANopen)" ;
    ex:textoExtracto "Report de nodo CANopen:Emergencia específica de fabricante." ;
    ex:identificador "3" .

ex:Parametro_NumeroNodoCANopen
    a ex:Parametro ;
    rdfs:label "Número de nodo CANopen" ;
    ex:textoExtracto "VALOR 1 Número de nodo." ;
    ex:valor "1" .

ex:Parametro_CodigosErrorCANopen
    a ex:Parametro ;
    rdfs:label "Códigos de error para el bus CANopen" ;
    ex:textoExtracto "VALOR 2 Códigos de error para el bus CANopen (codificación en base a bits)." ;
    ex:valor "2" .

ex:Sistema_CANopen
    a ex:Sistema ;
    rdfs:label "Sistema CANopen" ;
    ex:textoExtracto "nodo CANopen ha enviado un mensaje de emergencia" ;
    ex:activaAlarma ex:ErrorCANopen_EmergenciaExterna ;
    ex:activaAlarma ex:ErrorCANopen_EmergenciaFabricante ;
    ex:monitoreaParametro ex:Parametro_NumeroNodoCANopen ;
    ex:monitoreaParametro ex:Parametro_CodigosErrorCANopen .