@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContratarLaCorrespondienteOpcion a ns1:TareaMantenimiento ;
    rdfs:label "Contratar la correspondiente opción" ;
    ns1:solucionaFallo ns1:OpcionDeSoftwarePWMNoPermitida_3c1822583c ;
    ns1:textoExtracto "SOLUCIÓN Contratar la correspondiente opción." .

ns1:NumeroDeSalidasLocales a ns1:Parametro ;
    rdfs:label "Número de salidas locales" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8." .

ns1:OpcionDeSoftwarePWMNoPermitida a ns1:AccionProhibida ;
    rdfs:label "Opción de software PWM no permitida" ;
    ns1:textoExtracto "'Opción de software PWM no permitida' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no tiene activa la opción de software para la prestación PWM." .

ns1:RevisarElConexionadoDeLasEntradasYLaSondaConectada a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado de las entradas y la sonda conectada" ;
    ns1:solucionaFallo ns1:ErrorEnLaActivacionDesactivacionDelPWM ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de las entradas y la sonda conectada." .

ns1:RevisarElConexionadoDeLosContajesLocalesYElNivelDeLasSenales a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado de los contajes locales y el nivel de las señales" ;
    ns1:solucionaFallo ns1:ErrorEnElRefrescoDeEntradasAnalogicasLocales_28b76d5a20 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de los contajes locales y el nivel de las señales." .

ns1:SalidaPWM a ns1:Parametro ;
    rdfs:label "Salida PWM" ;
    ns1:identificador "PWMOUTPUT" ;
    ns1:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (1, 2)." .

ns1:VerificarLasCondicionesDeParametrizacionDelPWM a ns1:TareaMantenimiento ;
    rdfs:label "Verificar las condiciones de parametrización del PWM" ;
    ns1:solucionaFallo ns1:ErrorEnLaActivacionDesactivacionDelPWM_7e793f4d80 ;
    ns1:textoExtracto "SOLUCIÓN Verificar las siguientes condiciones: • El parámetro NLOCOUT debe ser 8. • El parámetro PWMOUTPUT no puede ser superior a 2 (1, 2)." .

ns1:ErrorEnElRefrescoDeEntradasAnalogicasLocales_28b76d5a20 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de entradas analógicas locales" ;
    ns1:textoExtracto "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas analógicas locales desde el lazo de posición." .

ns1:ErrorEnLaActivacionDesactivacionDelPWM a ns1:AccionProhibida ;
    rdfs:label "Error en la activación/desactivación del PWM" ;
    ns1:textoExtracto "'Error en la activación/desactivación del PWM' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA La parametrización del PWM es incorrecta." .

ns1:ErrorEnLaActivacionDesactivacionDelPWM_7e793f4d80 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la activación/desactivación del PWM" ;
    ns1:textoExtracto "'Error en la activación/desactivación del PWM' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA La parametrización del PWM es incorrecta." .

ns1:OpcionDeSoftwarePWMNoPermitida_3c1822583c a ns1:DiagnosticoFallo ;
    rdfs:label "Opción de software PWM no permitida" ;
    ns1:textoExtracto "3734 'Opción de software PWM no permitida' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no tiene activa la opción de software para la prestación PWM." .

