@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElEjeSeHaMovidoConElCNCApagado a ns1:AvisoSeguridad ;
    rdfs:label "El eje se ha movido con el CNC apagado" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'El eje se ha movido con el CNC apagado' DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del regulador no se corresponde con la cota salvada en la última sesión de CNC." .

ns1:ErrorEnLaSenalDeLaSondaDuranteElProcesoDeGAPCTRL a ns1:AvisoSeguridad ;
    rdfs:label "Error en la señal de la sonda durante el proceso de #GAPCTRL" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "3739 Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible." .

ns1:ErrorEnLaSenalDeLaSondaDuranteElProcesoDeGAPCTRL_c622637fa4 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la señal de la sonda durante el proceso de #GAPCTRL" ;
    ns1:textoExtracto "3739 Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible." .

ns1:MaximaDiferenciaDeReferencia a ns1:Parametro ;
    rdfs:label "Máxima diferencia de referencia" ;
    ns1:identificador "MAXDIFREF" ;
    ns1:textoExtracto "El eje se ha movido más de lo indicado en el parámetro MAXDIFREF." .

ns1:VerificarPosicionDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Verificar posición del eje" ;
    ns1:solucionaFallo ns1:ElEjeSeHaMovidoConElCNCApagado_ce4fff5cc0 ;
    ns1:textoExtracto "SOLUCIÓN Verificar que la posición del eje es correcta." .

ns1:ElEjeSeHaMovidoConElCNCApagado_ce4fff5cc0 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje se ha movido con el CNC apagado" ;
    ns1:textoExtracto "'El eje se ha movido con el CNC apagado' DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del regulador no se corresponde con la cota salvada en la última sesión de CNC." .

