@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AcercarLaSondaAlGapProgramado a ns1:TareaMantenimiento ;
    rdfs:label "Acercar la sonda al gap programado" ;
    ns1:solucionaFallo ns1:ENABLEGAPNoSePuedeActivarGAPCTRLPorEstarAlejadoDelGAPProgramado ;
    ns1:textoExtracto "3740 ENABLEGAP: No se puede activar #GAPCTRL por estar alejado del GAP programado. DETECCIÓN Durante la ejecución. CAUSA El control del gap está activo (#GAPCTRL) pero deshabilitado por PLC (marca ENABLEGAP). El CNC no puede habilitar el control del gap porque la sonda está fuera del gap. SOLUCIÓN Acercar la sonda al gap programado." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ComprobarQueNoHayNingunObstaculoEnElRecorridoDeLosEjes_1ae49347d4 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que no hay ningún obstáculo en el recorrido de los ejes" ;
    ns1:solucionaFallo ns1:ColisionDePalpador_728c8a109f ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba. SOLUCIÓN Comprobar que no hay ningún obstáculo en el recorrido de los ejes." .

ns1:RevisarLaConexionYLaParametrizacionDeLaSonda a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión y la parametrización de la sonda" ;
    ns1:solucionaFallo ns1:ErrorEnLaSenalDeLaSondaDuranteElProcesoDeGAPCTRL_c622637fa4 ;
    ns1:textoExtracto "3739 Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible (parámetro GAPDISTLIMIT). Las posibles causas son las siguientes: • La sonda funciona mal. • La señal que recibe el CNC no es de la sonda (sonda mal conectada). • La sonda esté mal parametrizada (parámetros GAPDISTLIMIT y GAPVOLTLIMIT). SOLUCIÓN Revisar la conexión y la parametrización de la sonda. Si el error persiste, póngase en contacto con su proveedor." .

ns1:RevisarLaProgramacionCambiarElValorDelParametroGAPERRORCANCELParaQueE_5cd57240ee a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación. Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error" ;
    ns1:solucionaFallo ns1:GAPCTRLFueraDelRangoGAPMAXGAPMIN ;
    ns1:textoExtracto "3741 #GAPCTRL: fuera del rango [GAPMAX - GAPMIN]. DETECCIÓN Durante la ejecución. CAUSA El gap ha sobrepasado los valores máximo o mínimo permitido, fijado por GAPMAX o GAPMIN. Es posible que el sensor no de una lectura correcta. SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error." .

ns1:RevisarLaProgramacionCambiarElValorDelParametroGAPTOLCANCELParaQueElCNCNoDeError a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación. Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error" ;
    ns1:solucionaFallo ns1:GAPCTRLFueraDelRangoGAPTOL ;
    ns1:textoExtracto "3742 #GAPCTRL: fuera del rango GAPTOL. DETECCIÓN Durante la ejecución. CAUSA La diferencia entre la señal del gap y el gap programado es superior a la tolerancia permitida (parámetro GAPTOL). SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error." .

ns1:ColisionDePalpador_728c8a109f a ns1:DiagnosticoFallo ;
    rdfs:label "Colisión de palpador" ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba. SOLUCIÓN Comprobar que no hay ningún obstáculo en el recorrido de los ejes." .

ns1:ENABLEGAPNoSePuedeActivarGAPCTRLPorEstarAlejadoDelGAPProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "ENABLEGAP: No se puede activar #GAPCTRL por estar alejado del GAP programado" ;
    ns1:textoExtracto "3740 ENABLEGAP: No se puede activar #GAPCTRL por estar alejado del GAP programado. DETECCIÓN Durante la ejecución. CAUSA El control del gap está activo (#GAPCTRL) pero deshabilitado por PLC (marca ENABLEGAP). El CNC no puede habilitar el control del gap porque la sonda está fuera del gap. SOLUCIÓN Acercar la sonda al gap programado." .

ns1:ErrorEnLaSenalDeLaSondaDuranteElProcesoDeGAPCTRL_c622637fa4 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la señal de la sonda durante el proceso de #GAPCTRL" ;
    ns1:textoExtracto "3739 Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible (parámetro GAPDISTLIMIT). Las posibles causas son las siguientes: • La sonda funciona mal. • La señal que recibe el CNC no es de la sonda (sonda mal conectada). • La sonda esté mal parametrizada (parámetros GAPDISTLIMIT y GAPVOLTLIMIT). SOLUCIÓN Revisar la conexión y la parametrización de la sonda. Si el error persiste, póngase en contacto con su proveedor." .

ns1:GAPCTRLFueraDelRangoGAPMAXGAPMIN a ns1:DiagnosticoFallo ;
    rdfs:label "#GAPCTRL: fuera del rango [GAPMAX - GAPMIN]" ;
    ns1:textoExtracto "3741 #GAPCTRL: fuera del rango [GAPMAX - GAPMIN]. DETECCIÓN Durante la ejecución. CAUSA El gap ha sobrepasado los valores máximo o mínimo permitido, fijado por GAPMAX o GAPMIN. Es posible que el sensor no de una lectura correcta. SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error." .

ns1:GAPCTRLFueraDelRangoGAPTOL a ns1:DiagnosticoFallo ;
    rdfs:label "#GAPCTRL: fuera del rango GAPTOL" ;
    ns1:textoExtracto "3742 #GAPCTRL: fuera del rango GAPTOL. DETECCIÓN Durante la ejecución. CAUSA La diferencia entre la señal del gap y el gap programado es superior a la tolerancia permitida (parámetro GAPTOL). SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error." .

