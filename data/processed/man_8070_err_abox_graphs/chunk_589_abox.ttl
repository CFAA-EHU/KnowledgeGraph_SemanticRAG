@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5faedea9a5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC calcula la distancia." .

ns1:ComprobarQueNoHayNingunObstaculoEnElRecorridoDeLosEjes a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar que no hay ningún obstáculo en el recorrido de los ejes" ;
    ns1:mitigaRiesgo ns1:ColisionDePalpador ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que no hay ningún obstáculo en el recorrido de los ejes." .

ns1:Parametro_2a2307fc2b a ns1:Parametro ;
    rdfs:label "#GAPCTRL" ;
    ns1:textoExtracto "#GAPCTRL: No hay señal de la sonda. DETECCIÓN Durante la ejecución. CAUSA No hay señal del sensor, a partir de la cual el CNC calcula la distancia." .

ns1:Sensor_4d3072ec8c a ns1:Sensor ;
    rdfs:label "sensor de palpado" ;
    ns1:textoExtracto "Ha llegado señal de la sonda de palpado cuando no se esperaba." .

ns1:VerificarQueLasConexionesDeLaSondaYLosParametrosMaquinaRelacionadosConLaSonda a ns1:AvisoSeguridad ;
    rdfs:label "Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda" ;
    ns1:mitigaRiesgo ns1:NoHaySenalDeLaSonda ;
    ns1:textoExtracto "SOLUCIÓN Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda." .

ns1:ColisionDePalpador a ns1:AccionProhibida ;
    rdfs:label "Colisión de palpador" ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba." .

ns1:NoHaySenalDeLaSonda a ns1:AccionProhibida ;
    rdfs:label "No hay señal de la sonda" ;
    ns1:textoExtracto "3744 #GAPCTRL: No hay señal de la sonda. DETECCIÓN Durante la ejecución. CAUSA No hay señal del sensor, a partir de la cual el CNC calcula la distancia." .

