@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorCAN_6015
    a ex:AvisoSeguridad ;
    ex:identificador "6015" ;
    rdfs:label "Contador de errores CAN sobrepaso nivel 1"@es ;
    ex:textoExtracto "6015 'Contador de errores CAN sobrepaso nivel 1' DETECCIÓN Durante la ejecución. CAUSA El contador de tramas de error (Rx/Tx) supera el nivel 1 (96). SOLUCIÓN Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es ;
    ex:monitoreaParametro ex:ParametroCAN_6015_RxTx .

ex:ParametroCAN_6015_RxTx
    a ex:Parametro ;
    rdfs:label "Contador de tramas de error CAN (Rx/Tx)"@es ;
    ex:textoExtracto "contador de tramas de error (Rx/Tx) supera el nivel 1 (96)"@es ;
    ex:valor "96" .