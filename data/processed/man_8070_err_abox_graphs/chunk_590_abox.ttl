@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ColisionDelSensor a ns1:AccionProhibida ;
    rdfs:label "Colisión del sensor" ;
    ns1:mitigaRiesgo ns1:SondaHaColisionado ;
    ns1:textoExtracto "La sonda ha colisionado." .

ns1:HardwareNoCompatibleConSWT a ns1:AccionProhibida ;
    rdfs:label "Hardware no compatible con SWT" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del corte en rejilla." .

ns1:ModoDeColisionDelSensor a ns1:Parametro ;
    rdfs:label "Modo de colisión del sensor" ;
    ns1:identificador "GAPCOLLISIONMODE" ;
    ns1:textoExtracto "Si el error continua, el OEM tendrá que modificar el parámetro máquina GAPCOLLISIONMODE." .

ns1:PosicionInicialFueraDeRango a ns1:AccionProhibida ;
    rdfs:label "Posición inicial fuera de rango" ;
    ns1:mitigaRiesgo ns1:PosicionInicialFueraDeRango_6beb8c8c23 ;
    ns1:textoExtracto "Posición inicial fuera de rango. DETECCIÓN En el arranque o recuperación de la fase operativa del bus." .

ns1:RevisarParametrosPITCHNPULSESINPUTREVOUTPUTREVYABSOFF a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros PITCH, NPULSES, INPUTREV, OUTPUTREV y ABSOFF" ;
    ns1:solucionaFallo ns1:PosicionInicialFueraDeRango_6beb8c8c23 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros PITCH, NPULSES, INPUTREV, OUTPUTREV y ABSOFF." .

ns1:VerificarConexionesDeLaSondaYParametrosRelacionados a ns1:TareaMantenimiento ;
    rdfs:label "Verificar conexiones de la sonda y parámetros relacionados" ;
    ns1:solucionaFallo ns1:SondaHaColisionado ;
    ns1:textoExtracto "SOLUCIÓN Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda (GAPANAINTYPE y GAPAANAINID)." .

ns1:PosicionInicialFueraDeRango_6beb8c8c23 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición inicial fuera de rango" ;
    ns1:identificador "3746" ;
    ns1:textoExtracto "Posición inicial fuera de rango. DETECCIÓN En el arranque o recuperación de la fase operativa del bus." .

ns1:SondaHaColisionado a ns1:DiagnosticoFallo ;
    rdfs:label "Sonda ha colisionado" ;
    ns1:identificador "3745" ;
    ns1:textoExtracto "La sonda ha colisionado. DETECCIÓN Durante la ejecución. CAUSA El PLC ha indicado mediante la marca GAPCOLLISION que se ha producido una colisión en el sensor." .

