@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarLaPosicionDeAcercamientoALaPieza_9eb98bcc2d a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar la posición de acercamiento a la pieza" ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la posición de acercamiento a la pieza." .

ns1:DiferenciaDePosicionMayorQueMAXDIFREF_f986fb5097 a ns1:AvisoSeguridad ;
    rdfs:label "Diferencia de posición mayor que MAXDIFREF" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del captador no se corresponde con la cota salvada en la última sesión del CNC." .

ns1:DriveFeedbackNoValido_d9a2d86fab a ns1:DiagnosticoFallo ;
    rdfs:label "Drive Feedback no válido" ;
    ns1:solucionaFallo ns1:RevisarElConexionadoYParametrizacionDeLosFeedbacks ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA No se ha podido calcular correctamente el feedback de posición para el eje. El regulador no está inicializado correctamente." .

ns1:GapFueraDeRangoEnElLimiteDePosicion_d81550aea6 a ns1:AvisoSeguridad ;
    rdfs:label "Gap fuera de rango en el límite de posición" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Durante #GAPCTRL o #LEAP, el eje ha alcanzado el punto de acercamiento sin recibir la señal de sonda." .

ns1:PulsarENTERRESETParaConfirmar a ns1:TareaMantenimiento ;
    rdfs:label "Pulsar ENTER + RESET para confirmar" ;
    ns1:textoExtracto "Pulsar ENTER + RESET para confirmar." .

ns1:RevisarElBit0x80000000DeAXISOPTION a ns1:AvisoSeguridad ;
    rdfs:label "Revisar el bit 0x80000000 de AXISOPTION" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "RCS-S. Revisar el bit 0x80000000 de AXISOPTION del eje involucrado en la maniobra de desactivación." .

ns1:RevisarElConexionadoYParametrizacionDeLosFeedbacks a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado y parametrización de los feedbacks" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y parametrización de los feedbacks, y reiniciar el sistema." .

