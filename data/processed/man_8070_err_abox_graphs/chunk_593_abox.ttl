@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_6025_EntradaVolanteInexistente
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error: Entrada de volante no existe"@es ;
    ex:textoExtracto "CAUSA La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error."@es ;
    ex:identificador "6025" .

ex:Error_6025_ChecksumCOMPCI
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error de checksum en la COMPCI"@es ;
    ex:textoExtracto "6025 'Error de checksum en la COMPCI' [...] CAUSA Error en el cheksum de los datos"@es ;
    ex:identificador "6025" .

ex:ParametrosMaquina
    a               ex:Parametro ;
    rdfs:label      "Parámetros máquina"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar los parámetros máquina."@es .

ex:ServicioAsistenciaTecnica
    a               ex:Personal ;
    rdfs:label      "Servicio de asistencia técnica"@es ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ex:Error_6025_ChecksumCOMPCI
    ex:solucionaFallo ex:ParametrosMaquina ;
    ex:solucionaFallo ex:ServicioAsistenciaTecnica .

ex:Error_6025_EntradaVolanteInexistente
    ex:solucionaFallo ex:ParametrosMaquina ;
    ex:solucionaFallo ex:ServicioAsistenciaTecnica .