@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IncompatibilidadEntreLaDireccionDelSensorYLaDeCompensacionDelGap a ns1:AccionProhibida ;
    rdfs:label "Incompatibilidad entre la dirección del sensor y la de compensación del gap" ;
    ns1:textoExtracto "Incompatibilidad entre la dirección del sensor y la de compensación del gap." .

ns1:ReiniciarCNCConPosicionEsperada a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar CNC con posición esperada" ;
    ns1:solucionaFallo ns1:CotaAbsolutaIncorrecta ;
    ns1:textoExtracto "Si la posición que debería tener el eje no es \"Cota Actual\" sino \"Cota Esperada\", quitar el error pulsando [ENTER] y luego [RESET]. A continuación, ejecutar G174 con la posición indicada en \"Cota Esperada\" y finalmente reiniciar el CNC para recuperar dicha posición." .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor Gap" ;
    ns1:textoExtracto "Incompatibilidad entre la dirección del sensor y la de compensación del gap." .

ns1:VerificarPosicionEjeYQuitarError a ns1:TareaMantenimiento ;
    rdfs:label "Verificar posición eje y quitar error" ;
    ns1:solucionaFallo ns1:CotaAbsolutaIncorrecta ;
    ns1:textoExtracto "Verificar que la posición del eje indicada en \"Cota Actual\" es correcta. Si es así, pulsar [ENTER] y luego [RESET] para quitar el error y continuar." .

ns1:CotaAbsolutaIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Cota absoluta incorrecta" ;
    ns1:textoExtracto "La cota absoluta del captador no se corresponde con la cota salvada en la última sesión del CNC." .

