@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizarRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar regulador" ;
    ns1:solucionaFallo ns1:UsarVersionInadecuadaDeRegulador ;
    ns1:textoExtracto "SOLUCIÓN" .

ns1:CambiarAnguloDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar ángulo de programación" ;
    ns1:solucionaFallo ns1:ProgramarAnguloIncompatiblesConSensor ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el ángulo de programación." .

ns1:ResolucionDelBucleDeControl a ns1:Parametro ;
    rdfs:label "Resolución del bucle de control" ;
    ns1:identificador "PLOOPRESOL" ;
    ns1:textoExtracto "Parámetro máquina PLOOPRESOL incompatible con versión del regulador." .

ns1:ProgramarAnguloIncompatiblesConSensor a ns1:AccionProhibida ;
    rdfs:label "Programar ángulo incompatibles con sensor" ;
    ns1:textoExtracto "Con el control de gap en n ejes activo (#GAPCTRL), el ángulo programado para la compensación del gap es incompatible con la dirección del sensor." .

ns1:UsarVersionInadecuadaDeRegulador a ns1:AccionProhibida ;
    rdfs:label "Usar versión inadecuada de regulador" ;
    ns1:textoExtracto "El regulador no tiene la versión adecuada para el valor de PLOOPRESOL." .

