@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosSalidas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de salidas"@es ;
    ex:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 1 | Salidas analógicas. |
| 3 | Salidas digitales.
"""@es ;
    ex:tieneComponente ex:CodigoSalida_1 ;
    ex:tieneComponente ex:CodigoSalida_3 .

ex:CodigoSalida_1
    a ex:ComponenteElectrico ;
    rdfs:label "Código 1: Salidas analógicas"@es ;
    ex:identificador "1" ;
    ex:textoExtracto "Salidas analógicas."@es .

ex:CodigoSalida_3
    a ex:ComponenteElectrico ;
    rdfs:label "Código 3: Salidas digitales"@es ;
    ex:identificador "3" ;
    ex:textoExtracto "Salidas digitales."@es .