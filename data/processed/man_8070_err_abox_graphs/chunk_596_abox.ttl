@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error6026
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de hardware en la COMPCI" ;
    ex:identificador "6026" ;
    ex:textoExtracto "Error de hardware en la COMPCI. DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de la COMPCI. En el arranque se realizan los siguientes test; Flash, RAM común, RAM externa, RAM interna y controlador CAN." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar con el servicio de asistencia técnica" ;
        ex:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica."
    ] .

ex:Error6027
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de hardware en nodo remoto CAN" ;
    ex:identificador "6027" ;
    ex:textoExtracto "Error de hardware en nodo remoto CAN. DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de los nodos remotos. En el arranque se realizan los siguientes test; Flash, RAM y controlador CAN." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar con el servicio de asistencia técnica" ;
        ex:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica."
    ] .

ex:Error6028
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en accesos a la RAM del SERCON" ;
    ex:identificador "6028" ;
    ex:textoExtracto "Error en accesos a la RAM del SERCON. DETECCIÓN Durante el arranque del sistema o durante la ejecución. CAUSA Fallo en el test de la RAM común del SERCON (accesos R/W en modos Byte/Word)." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar con el servicio de asistencia técnica" ;
        ex:textoExtracto "SOLUCIÓN Problema de hardware de la chepa Sercos o conexionado al Bus PCI. Consultar con el servicio de asistencia técnica."
    ] .

ex:Error6029
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el CNC" ;
    ex:identificador "6029" ;
    ex:textoExtracto "Límite de incremento de posición superado en el CNC. DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico. Fallo de hardware del nodo contadora, accesos a la COMPCI (conexionado), etc." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar con el servicio de asistencia técnica" ;
        ex:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica."
    ] .

ex:Error6030
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el nodo contadora de CAN" ;
    ex:identificador "6030" ;
    ex:textoExtracto "Límite de incremento de posición superado en el nodo contadora de CAN. DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico. Fallo de hardware del nodo contadora." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar con el servicio de asistencia técnica" ;
        ex:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica."
    ] .

ex:ModoDiagnosis
    a ex:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ex:textoExtracto "En el modo diagnosis se presenta información detallada sobre el tipo de error." ;
    ex:monitoreaParametro ex:Error6026, ex:Error6027 .

ex:COMPCI
    a ex:ComponenteElectrico ;
    rdfs:label "COMPCI" ;
    ex:textoExtracto "Error en el test de hardware de la COMPCI. En el arranque se realizan los siguientes test; Flash, RAM común, RAM externa, RAM interna y controlador CAN." ;
    ex:tieneComponente [
        a ex:ComponenteElectrico ;
        rdfs:label "Flash de COMPCI" ;
        ex:textoExtracto "Flash"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "RAM común de COMPCI" ;
        ex:textoExtracto "RAM común"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "RAM externa de COMPCI" ;
        ex:textoExtracto "RAM externa"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "RAM interna de COMPCI" ;
        ex:textoExtracto "RAM interna"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "Controlador CAN de COMPCI" ;
        ex:textoExtracto "controlador CAN"
    ] .

ex:NodoRemotoCAN
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo remoto CAN" ;
    ex:textoExtracto "Error en el test de hardware de los nodos remotos. En el arranque se realizan los siguientes test; Flash, RAM y controlador CAN." ;
    ex:tieneComponente [
        a ex:ComponenteElectrico ;
        rdfs:label "Flash de nodo remoto CAN" ;
        ex:textoExtracto "Flash"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "RAM de nodo remoto CAN" ;
        ex:textoExtracto "RAM"
    ], [
        a ex:ComponenteElectrico ;
        rdfs:label "Controlador CAN de nodo remoto" ;
        ex:textoExtracto "controlador CAN"
    ] .

ex:SERCON
    a ex:ComponenteElectrico ;
    rdfs:label "SERCON" ;
    ex:textoExtracto "Fallo en el test de la RAM común del SERCON (accesos R/W en modos Byte/Word)." ;
    ex:tieneComponente [
        a ex:ComponenteElectrico ;
        rdfs:label "RAM común de SERCON" ;
        ex:textoExtracto "RAM común del SERCON"
    ] .

ex:NodoContadora
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo contadora" ;
    ex:textoExtracto "Fallo de hardware del nodo contadora, accesos a la COMPCI (conexionado), etc." .