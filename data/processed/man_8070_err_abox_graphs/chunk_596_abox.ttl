ns1:ErrorDeVersionDelRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error de versión del regulador" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o validación de los parámetros máquina. CAUSA El regulador no tiene la versión adecuada para el valor de PLOOPRESOL." .

ns1:ErrorEnLaEjecucionDelComandoDeSincronizacionDeLaPlacaSense a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la ejecución del comando de sincronización de la placa sense" ;
    ns1:textoExtracto "DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA No se detecta tensión en alguna de las ramas de la placa sense durante el comando de sincronización." .

ns1:ReguladorEnErrorOEnUnEstadoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Regulador en error o en un estado incorrecto" ;
    ns1:textoExtracto "DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA El regulador se encuentra en error o en un estado no esperado por el CNC." .

ns1:TiempoDeParametroSSTIMEAlcanzadoSinTensionDeBusEstable a ns1:DiagnosticoFallo ;
    rdfs:label "Tiempo de parámetro SSTIME alcanzado sin tensión de bus estable" ;
    ns1:textoExtracto "DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA No se carga la tensión de bus en el tiempo estimado." .

