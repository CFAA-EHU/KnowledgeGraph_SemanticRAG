    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y la parametrización del regulador." .

ns1:VerificarElValorDelParametroPLOOPRESOLYLaVersionDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Verificar el valor del parámetro PLOOPRESOL y la versión del regulador" ;
    ns1:solucionaFallo ns1:ErrorDeVersionDelRegulador ;
    ns1:textoExtracto "SOLUCIÓN Verificar el valor del parámetro PLOOPRESOL y la versión del regulador." .

ns1:VerificarLaTensionDeRedEnElEquipoQueRealizaElSoftstartDelBusDC a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la tensión de red en el equipo que realiza el softstart del bus DC" ;
    ns1:solucionaFallo ns1:TiempoDeParametroSSTIMEAlcanzadoSinTensionDeBusEstable ;
    ns1:textoExtracto "SOLUCIÓN Las posibles soluciones son las siguientes: • Verificar la tensión de red en el equipo que realiza el softstart del bus DC." .

ns1:VerificarQueLlegaLaSenalDeSoftstartALaRPS a ns1:TareaMantenimiento ;
