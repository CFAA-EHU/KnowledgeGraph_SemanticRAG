    ns1:textoExtracto "Revisar el conexionado, la placa sense, el conector X60 (captación de la tensión de línea) y el conector X11 (cable de potencia X11)." .

ns1:ConectorX60_84b4c24cc6 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X60" ;
    ns1:textoExtracto "Revisar el conexionado, la placa sense, el conector X60 (captación de la tensión de línea) y el conector X11 (cable de potencia X11)." .

ns1:FalloEnElControlDelContactorSobrecorrienteEnLaSalidaX12FrenoContactor a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor" ;
    ns1:textoExtracto "DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Sobrecorriente en la salida del freno-contactor." .

