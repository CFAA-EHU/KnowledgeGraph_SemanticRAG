@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConectorX12 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X12" ;
    ns1:textoExtracto "Revisar el cableado del conector X12 y del contactor de potencia." .

ns1:ContactorPotencia a ns1:ComponenteElectrico ;
    rdfs:label "Contactor de potencia" ;
    ns1:textoExtracto "Revisar el cableado del conector X12 y del contactor de potencia." .

ns1:ReemplazarContactorEstropeado a ns1:AccionProhibida ;
    rdfs:label "Reemplazar contactor estropeado" ;
    ns1:textoExtracto "• Contactor estropeado." .

ns1:RevisarCableadoDelConectorX12YDelContactorDePotencia a ns1:AccionProhibida ;
    rdfs:label "Revisar cableado del conector X12 y del contactor de potencia" ;
    ns1:textoExtracto "• Revisar el cableado del conector X12 y del contactor de potencia." .

ns1:TareaMantenimiento_7e9c283e47 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de revisión del cableado del conector X12 y del contactor de potencia" ;
    ns1:solucionaFallo ns1:FalloSobrecorrienteRPS ;
    ns1:textoExtracto "• Revisar el cableado del conector X12 y del contactor de potencia." .

ns1:TareaMantenimiento_a88fdee0af a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de verificación de alimentación en el conector X12" ;
    ns1:solucionaFallo ns1:FalloSobrecorrienteRPS ;
    ns1:textoExtracto "• Falta la alimentación de 24 Vdc en el conector X12 o es superior a 26 Vdc." .

ns1:TareaMantenimiento_ad226ba057 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de reemplazo del contactor estropeado" ;
    ns1:solucionaFallo ns1:FalloSobrecorrienteRPS ;
    ns1:textoExtracto "• Contactor estropeado." .

ns1:VerificarAlimentacionDe24VdcEnElConectorX12 a ns1:AccionProhibida ;
    rdfs:label "Verificar alimentación de 24 Vdc en el conector X12" ;
    ns1:textoExtracto "• Falta la alimentación de 24 Vdc en el conector X12 o es superior a 26 Vdc." .

ns1:FalloSobrecorrienteRPS a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en la salida del freno-contactor de RPS" ;
    ns1:textoExtracto "3759 RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor." .

