@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnNuevoAvanceDesdeElModoManual_8431119bba a ns1:TareaMantenimiento ;
    rdfs:label "Definir un nuevo avance desde el modo manual" ;
    ns1:solucionaFallo ns1:VelocidadEnJogContinuoIgualACero_fce7dff6de ;
    ns1:textoExtracto "SOLUCIÓN Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED." .

ns1:DistanciaOVelocidadEnJogIncrementalIgualACero_7ba8fcd478 a ns1:DiagnosticoFallo ;
    rdfs:label "'Distancia o velocidad en jog incremental igual a cero'" ;
    ns1:textoExtracto "3801 'Distancia o velocidad en jog incremental igual a cero' DETECCIÓN Durante la ejecución." .

ns1:PongaseEnContactoConFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorEnElComandoDeEstablecerNuevaReferenciaDePosicion_83f021890e,
        ns1:ErrorEnElComandoDeLatcheoDeI0_23f204779e,
        ns1:ErrorEnElComandoDeReseteoDeErroresDelRegulador_78e39dcd69 ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:RevisarLaInstalacionYLaManiobra a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la instalación y la maniobra" ;
    ns1:solucionaFallo ns1:RPSTensionDeBusPorDebajoDeLaDeseada_d8c1dbd584 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la instalación y la maniobra." .

ns1:SubirLaTensionDeConsignaDelBusDC a ns1:TareaMantenimiento ;
    rdfs:label "Subir la tensión de consigna del bus DC" ;
    ns1:solucionaFallo ns1:RPSTensionDeRedAltaAlcanzaALaConsignaDeBusDC ;
    ns1:textoExtracto "SOLUCIÓN Subir la tensión de consigna del bus DC." .

ns1:ErrorEnElComandoDeEstablecerNuevaReferenciaDePosicion_83f021890e a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el comando de establecer nueva referencia de posición" ;
    ns1:textoExtracto "3764 Error en el comando de establecer nueva referencia de posición. DETECCIÓN Durante el proceso de búsqueda de I0 o G174. CAUSA El comando de establecer nueva referencia de posición ha dado error. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:ErrorEnElComandoDeLatcheoDeI0_23f204779e a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el comando de latcheo de I0" ;
    ns1:textoExtracto "3762 Error en el comando de latcheo de I0. DETECCIÓN Durante el proceso de referenciar el eje/cabezal. CAUSA El comando de latcheo del I0 ha dado un error. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:ErrorEnElComandoDeReseteoDeErroresDelRegulador_78e39dcd69 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el comando de reseteo de errores del regulador" ;
    ns1:textoExtracto "3763 Error en el comando de reseteo de errores del regulador. DETECCIÓN Tras un reset del CNC. error. CAUSA El comando de resetear errores del regulador ha dado un SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:RPSTensionDeBusPorDebajoDeLaDeseada_d8c1dbd584 a ns1:DiagnosticoFallo ;
    rdfs:label "RPS, tensión de bus por debajo de la deseada" ;
    ns1:textoExtracto "3760 RPS, tensión de bus por debajo de la deseada. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Caída inesperada de la linea de red que alimenta la maniobra. SOLUCIÓN Revisar la instalación y la maniobra." .

ns1:RPSTensionDeRedAltaAlcanzaALaConsignaDeBusDC a ns1:DiagnosticoFallo ;
    rdfs:label "RPS, tensión de red alta, alcanza a la consigna de bus DC" ;
    ns1:textoExtracto "3761 RPS, tensión de red alta, alcanza a la consigna de bus DC. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Subida de tensión de red, que al ser rectificada, alcanza la consigna del bus DC. SOLUCIÓN Subir la tensión de consigna del bus DC." .

ns1:VelocidadEnJogContinuoIgualACero_fce7dff6de a ns1:DiagnosticoFallo ;
    rdfs:label "'Velocidad en jog continuo igual a cero'" ;
    ns1:textoExtracto "3800 'Velocidad en jog continuo igual a cero' DETECCIÓN Durante la ejecución o al cambiar el modo a jog continuo. CAUSA El avance para el modo jog continuo es cero. No hay programado ningún avance para el modo manual y el parámetro máquina JOGFEED es cero. SOLUCIÓN Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED." .

