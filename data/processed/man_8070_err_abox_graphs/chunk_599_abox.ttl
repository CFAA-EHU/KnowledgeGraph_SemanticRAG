@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnNuevoAvanceDesdeElModoManual a ns1:AccionProhibida ;
    rdfs:label "Definir un nuevo avance desde el modo manual" ;
    ns1:solucionaFallo ns1:FalloAvanceCero ;
    ns1:textoExtracto "Definir un nuevo avance desde el modo manual." .

ns1:IncrementalJogDistance a ns1:Parametro ;
    rdfs:label "Incremental Jog Distance" ;
    ns1:identificador "INCJOGDIST" ;
    ns1:textoExtracto "El parámetro máquina INCJOGDIST es cero." .

ns1:IncrementalJogFeedRate a ns1:Parametro ;
    rdfs:label "Incremental Jog Feed Rate" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "Revisar el parámetro máquina de ejes INCJOGFEED." .

ns1:FalloAvanceCero a ns1:DiagnosticoFallo ;
    rdfs:label "Distancia o velocidad en jog incremental igual a cero" ;
    ns1:textoExtracto "'Distancia o velocidad en jog incremental igual a cero'" .

