@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirUnNuevoAvanceDesdeElModoManual_cec2b40dbe a ns1:TareaMantenimiento ;
    rdfs:label "Definir un nuevo avance desde el modo manual" ;
    ns1:solucionaFallo ns1:VelocidadEnJogIncrementalDemasiadoPequena ;
    ns1:textoExtracto "SOLUCIÓN Definir un nuevo avance desde el modo manual." .

ns1:IncrementoDeAvanceEnModoManual a ns1:Parametro ;
    rdfs:label "Incremento de avance en modo manual" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "el parámetro máquina INCJOGFEED es cero." .

ns1:IncrementoDeDistanciaEnModoManual a ns1:Parametro ;
    rdfs:label "Incremento de distancia en modo manual" ;
    ns1:identificador "INCJOGDIST" ;
    ns1:textoExtracto "el parámetro máquina INCJOGDIST es cero." .

ns1:ResolucionDelVolante a ns1:Parametro ;
    rdfs:label "Resolución del volante" ;
    ns1:identificador "MPGRESOL" ;
    ns1:textoExtracto "Revisar el parámetro máquina de ejes MPGRESOL." .

ns1:RevisarElParametroMaquinaDeEjesMPGRESOL a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el parámetro máquina de ejes MPGRESOL" ;
    ns1:solucionaFallo ns1:NoSeAdmiteResolucionDeVolanteCero ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro máquina de ejes MPGRESOL." .

ns1:RevisarLosParametrosMaquinaDeEjes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros máquina de ejes" ;
    ns1:solucionaFallo ns1:VelocidadEnJogIncrementalDemasiadoPequena ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina de ejes INCJOGFEED y LOOPTIME." .

ns1:TiempoDeBucle a ns1:Parametro ;
    rdfs:label "Tiempo de bucle" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED y LOOPTIME." .

ns1:NoSeAdmiteResolucionDeVolanteCero a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite resolución de volante cero'" ;
    ns1:textoExtracto "3803 'No se admite resolución de volante cero' DETECCIÓN Durante un cambio en la resolución del volante desde el panel de mando." .

ns1:VelocidadEnJogIncrementalDemasiadoPequena a ns1:DiagnosticoFallo ;
    rdfs:label "'Velocidad en jog incremental demasiado pequeña'" ;
    ns1:textoExtracto "3802 'Velocidad en jog incremental demasiado pequeña' DETECCIÓN Durante la ejecución. CAUSA El incremento de posición calculado para un ciclo de PLC es demasiado pequeño." .

