@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceDeVolanteFueraDeRangoPosicionesDelConmutador13 a ns1:Parametro ;
    rdfs:label "Indice de volante fuera de rango (posiciones del conmutador 1-3)"@es ;
    ns1:textoExtracto "'Indice de volante fuera de rango (posiciones del conmutador 1-3)'" .

ns1:Parametro_09fec1fa38 a ns1:Parametro ;
    rdfs:label "Parámetro máquina de ejes INCJOGDIST"@es,
        "Parámetro máquina de ejes INCJOGFEED"@es ;
    ns1:textoExtracto "'Revisar los parámetros máquina de ejes INCJOGDIST e INCJOGFEED.'" .

ns1:RevisionDeLosParametrosINCJOGDISTEINCJOGFEED a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de los parámetros INCJOGDIST e INCJOGFEED"@es ;
    ns1:solucionaFallo ns1:FalloVelocidadDeJogIncrementalMayorQueValorMaximo ;
    ns1:textoExtracto "'SOLUCIÓN Revisar los parámetros máquina de ejes INCJOGDIST e INCJOGFEED.'" .

ns1:RevisionDelParametroMPGRESOL a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del parámetro MPGRESOL"@es ;
    ns1:solucionaFallo ns1:FalloIndiceVolanteFueraRango ;
    ns1:textoExtracto "'SOLUCIÓN Revisar el parámetro máquina de ejes MPGRESOL.'" .

ns1:RevisionDelParametroPLCMPGIDX a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del parámetro PLC.MPGIDX"@es ;
    ns1:solucionaFallo ns1:FalloVelocidadOdistanciaCeroEnModoJogIncremental ;
    ns1:textoExtracto "'SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.MPGIDX.'" .

ns1:VariablePLCMPGIDXParaLaPosicionDeVolante a ns1:Parametro ;
    rdfs:label "Variable PLC.MPGIDX para la posición de volante"@es ;
    ns1:textoExtracto "'Velocidad o distancia cero en modo jog incremental'" .

ns1:FalloIndiceVolanteFueraRango a ns1:DiagnosticoFallo ;
    rdfs:label "Índice de volante fuera de rango"@es ;
    ns1:textoExtracto "'3804 'Indice de volante fuera de rango (posiciones del conmutador 1-3)'" .

ns1:FalloVelocidadDeJogIncrementalMayorQueValorMaximo a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog incremental mayor que valor máximo"@es ;
    ns1:textoExtracto "'3806 'Velocidad de jog incremental mayor que valor máximo'" .

ns1:FalloVelocidadOdistanciaCeroEnModoJogIncremental a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad o distancia cero en modo jog incremental"@es ;
    ns1:textoExtracto "'3805 'Velocidad o distancia cero en modo jog incremental'" .

