@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_6043
    a ex:DiagnosticoFallo ;
    ex:identificador "6043" ;
    rdfs:label "'Alarma de cable roto'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado una alarma genérica de cable roto en la entrada local de captación. CAUSA El contaje local del CNC tiene alguna de sus señales rota. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6043 .

ex:Alarma_6043
    a ex:Alarma ;
    rdfs:label "'Alarma de cable roto'" ;
    ex:textoExtracto "El lazo ha detectado una alarma genérica de cable roto en la entrada local de captación." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:Sensor_CaptacionLocalCNC
    a ex:Sensor ;
    rdfs:label "Sensor de captación local del CNC" ;
    ex:textoExtracto "captación local del CNC" ;
    ex:monitoreaParametro ex:Parametro_SenalA ,
        ex:Parametro_SenalB ,
        ex:Parametro_SenalI0 ,
        ex:Parametro_SenalAL .

ex:Parametro_SenalA
    a ex:Parametro ;
    rdfs:label "Señal A del contaje local del CNC" ;
    ex:textoExtracto "señal A del contaje local" ;
    ex:valor "Señal A" .

ex:Parametro_SenalB
    a ex:Parametro ;
    rdfs:label "Señal B del contaje local del CNC" ;
    ex:textoExtracto "señal B del contaje local" ;
    ex:valor "Señal B" .

ex:Parametro_SenalI0
    a ex:Parametro ;
    rdfs:label "Señal I0 del contaje local del CNC" ;
    ex:textoExtracto "señal I0 del contaje local" ;
    ex:valor "Señal I0" .

ex:Parametro_SenalAL
    a ex:Parametro ;
    rdfs:label "Señal AL del contaje local del CNC" ;
    ex:textoExtracto "señal AL del contaje local" ;
    ex:valor "Señal AL" .

ex:DiagnosticoFallo_6044
    a ex:DiagnosticoFallo ;
    ex:identificador "6044" ;
    rdfs:label "'Alarma de cable roto en señal A'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado cable roto en la señal A del contaje local. CAUSA El contaje local del CNC no recibe la señal A. SOLUCIÓN Revisar la señal A de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6044 .

ex:Alarma_6044
    a ex:Alarma ;
    rdfs:label "'Alarma de cable roto en señal A'" ;
    ex:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje local." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:DiagnosticoFallo_6045
    a ex:DiagnosticoFallo ;
    ex:identificador "6045" ;
    rdfs:label "'Alarma de cable roto en señal B'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado cable roto en la señal B del contaje local. CAUSA El contaje local del CNC no recibe la señal B. SOLUCIÓN Revisar la señal B de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6045 .

ex:Alarma_6045
    a ex:Alarma ;
    rdfs:label "'Alarma de cable roto en señal B'" ;
    ex:textoExtracto "El lazo ha detectado cable roto en la señal B del contaje local." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:DiagnosticoFallo_6046
    a ex:DiagnosticoFallo ;
    ex:identificador "6046" ;
    rdfs:label "'Alarma de cable roto en señal I0'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado cable roto en la señal I0 del contaje local. CAUSA El contaje local del CNC no recibe la señal I0. SOLUCIÓN Revisar la señal I0 de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6046 .

ex:Alarma_6046
    a ex:Alarma ;
    rdfs:label "'Alarma de cable roto en señal I0'" ;
    ex:textoExtracto "El lazo ha detectado cable roto en la señal I0 del contaje local." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:DiagnosticoFallo_6047
    a ex:DiagnosticoFallo ;
    ex:identificador "6047" ;
    rdfs:label "'Alarma de cable roto en señal AL'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado cable roto en la señal AL del contaje local. CAUSA El contaje local del CNC no recibe la señal AL. SOLUCIÓN Revisar la señal AL de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6047 .

ex:Alarma_6047
    a ex:Alarma ;
    rdfs:label "'Alarma de cable roto en señal AL'" ;
    ex:textoExtracto "El lazo ha detectado cable roto en la señal AL del contaje local." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:DiagnosticoFallo_6048
    a ex:DiagnosticoFallo ;
    ex:identificador "6048" ;
    rdfs:label "'Alarma externa del captador'" ;
    ex:textoExtracto "DETECCIÓN El lazo ha detectado alarma externa en el contaje local. CAUSA El captador conectado al contaje local reporta alarma. SOLUCIÓN Revisar el captador conectado a la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_6048 .

ex:Alarma_6048
    a ex:Alarma ;
    rdfs:label "'Alarma externa del captador'" ;
    ex:textoExtracto "El lazo ha detectado alarma externa en el contaje local." ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .

ex:DiagnosticoFallo_CortocircuitoCNC
    a ex:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en el contaje local del CNC" ;
    ex:textoExtracto "CAUSA Cortocircuito en el contaje local del CNC. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." ;
    ex:solucionaFallo ex:Alarma_CortocircuitoCNC .

ex:Alarma_CortocircuitoCNC
    a ex:Alarma ;
    rdfs:label "Alarma por cortocircuito en el contaje local del CNC" ;
    ex:textoExtracto "Cortocircuito en el contaje local del CNC" ;
    ex:activaAlarma ex:Sensor_CaptacionLocalCNC .