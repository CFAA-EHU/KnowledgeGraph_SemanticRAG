@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeInexistenteONoDisponible_d7aede7065 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible" ;
    ns1:textoExtracto "'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución." .

ns1:IndiceDeJogIncrementalEnElProgramaDePLC a ns1:Parametro ;
    rdfs:label "Indice de jog incremental en el programa de PLC" ;
    ns1:identificador "PLC.INCJOGIDX" ;
    ns1:textoExtracto "'Indice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado seleccionar una posición de jog incremental que está fuera rango permitido. SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX." .

ns1:ReparacionDeIndiceDeJogIncremental a ns1:TareaMantenimiento ;
    rdfs:label "Reparación de índice de jog incremental" ;
    ns1:solucionaFallo ns1:IndiceDeJogIncrementalFueraDeRangoPosicionesDelConmutador15_70654d0260 ;
    ns1:textoExtracto "'Indice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado seleccionar una posición de jog incremental que está fuera rango permitido. SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX." .

ns1:ReparacionDeVelocidadDeJogIncremental a ns1:TareaMantenimiento ;
    rdfs:label "Reparación de velocidad de jog incremental" ;
    ns1:solucionaFallo ns1:VelocidadDeJogIncrementalMayorQueValorMaximo ;
    ns1:textoExtracto "'Velocidad de jog incremental mayor que valor máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad definida en parámetros máquina para jog incremental es mayor que la máxima permitida SOLUCIÓN Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." .

ns1:VelocidadDefinidaEnParametrosMaquinaParaJogIncremental a ns1:Parametro ;
    rdfs:label "Velocidad definida en parámetros máquina para jog incremental" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "'Velocidad de jog incremental mayor que valor máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad definida en parámetros máquina para jog incremental es mayor que la máxima permitida SOLUCIÓN Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." .

ns1:IndiceDeJogIncrementalFueraDeRangoPosicionesDelConmutador15_70654d0260 a ns1:DiagnosticoFallo ;
    rdfs:label "Indice de jog incremental fuera de rango (posiciones del conmutador 1-5)" ;
    ns1:textoExtracto "'Indice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado seleccionar una posición de jog incremental que está fuera rango permitido. SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX." .

ns1:VelocidadDeJogIncrementalMayorQueValorMaximo a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog incremental mayor que valor máximo" ;
    ns1:textoExtracto "'Velocidad de jog incremental mayor que valor máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad definida en parámetros máquina para jog incremental es mayor que la máxima permitida SOLUCIÓN Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." .

