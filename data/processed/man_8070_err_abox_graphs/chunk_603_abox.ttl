@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EscrituraDeLaVariablePLCINCJOGIDX a ns1:Parametro ;
    rdfs:label "Escritura de la variable PLC.INCJOGIDX" ;
    ns1:identificador "PLC.INCJOGIDX" ;
    ns1:textoExtracto "Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX." .

ns1:FalloVelocidadProgramadaNula a ns1:DiagnosticoFallo ;
    rdfs:label "'Velocidad programada de cabezal nula en G95'" ;
    ns1:textoExtracto "3809 'Velocidad programada de cabezal nula en G95' DETECCIÓN Durante la ejecución." .

ns1:ProgramarFuncionesG101YG102ParaElEjeMaestro a ns1:TareaMantenimiento ;
    rdfs:label "Programar funciones G101 y G102 para el eje maestro" ;
    ns1:solucionaFallo ns1:FalloEjeInexistente ;
    ns1:textoExtracto "• Las funciones G101 y G102 se deben programar para el eje maestro de la pareja gantry." .

ns1:PulsarResetParaSalirDelModoManual a ns1:TareaMantenimiento ;
    rdfs:label "Pulsar reset para salir del modo manual" ;
    ns1:solucionaFallo ns1:FalloEjeInexistente ;
    ns1:textoExtracto "SOLUCIÓN Las posibles soluciones son las siguientes: • Pulsar reset para poder salir del modo manual." .

ns1:RevisarEscrituraDeVariablePLCINCJOGIDX a ns1:TareaMantenimiento ;
    rdfs:label "Revisar escritura de variable PLC.INCJOGIDX" ;
    ns1:solucionaFallo ns1:FalloEjeInexistente ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX." .

ns1:RevisarProgramacionDeSentenciaTANGCTRLON a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de sentencia #TANGCTRLON" ;
    ns1:solucionaFallo ns1:FalloEjeInexistente ;
    ns1:textoExtracto "• Revisar la programación de la sentencia #TANGCTRLON." .

ns1:FalloEjeInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "'Eje inexistente o no disponible'" ;
    ns1:textoExtracto "3808 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución." .

