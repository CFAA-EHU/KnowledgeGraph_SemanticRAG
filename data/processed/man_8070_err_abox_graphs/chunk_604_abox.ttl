@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDelIncrementoDeVolante a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del incremento de volante" ;
    ns1:textoExtracto "SOLUCIÓN No se proporciona una solución explícita, pero implica corregir el incremento demasiado grande en el contaje de volante." .

ns1:LimiteDeIncrementoDeVolanteSuperado_989c75b624 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de volante superado" ;
    ns1:textoExtracto "'Límite de incremento de volante superado' DETECCIÓN En modo manual, durante la lectura del contaje de un volante. CAUSA Incremento demasiado grande en el contaje de volante." .

ns1:NoEstaPermitidoMoverEnModoVolanteUnEjeHirth a ns1:AccionProhibida ;
    rdfs:label "No está permitido mover en modo volante un eje Hirth" ;
    ns1:solucionaFallo ns1:ModoVolanteNoPermitidoConEjeHirth_0086b882a6 ;
    ns1:textoExtracto "SOLUCIÓN No está permitido mover en modo volante un eje Hirth; puede moverse en modo jog continuo y jog incremental." .

ns1:ProgramarUnaVelocidadParaElCabezalMasterDelCanalOParaElCabezalUtiliza_06214d7f62 a ns1:TareaMantenimiento ;
    rdfs:label "Programar una velocidad para el cabezal master del canal o para el cabezal utilizado para la sincronización" ;
    ns1:solucionaFallo ns1:VelocidadProgramadaDeCabezalNulaEnG95_c3b487e645 ;
    ns1:textoExtracto "SOLUCIÓN Programar una velocidad para el cabezal master del canal o para el cabezal utilizado para la sincronización (registro SYNC)." .

ns1:ModoVolanteNoPermitidoConEjeHirth_0086b882a6 a ns1:DiagnosticoFallo ;
    rdfs:label "Modo Volante no permitido con eje Hirth" ;
    ns1:textoExtracto "'Modo Volante no permitido con eje Hirth' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado seleccionar en eje Hirth para desplazarlo en modo volante." .

ns1:VelocidadProgramadaDeCabezalNulaEnG95_c3b487e645 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad programada de cabezal nula en G95" ;
    ns1:textoExtracto "'Velocidad programada de cabezal nula en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado mover un eje en jog continuo o incremental con la función G95 activa y velocidad cero en el cabezal utilizado para la sincronización." .

