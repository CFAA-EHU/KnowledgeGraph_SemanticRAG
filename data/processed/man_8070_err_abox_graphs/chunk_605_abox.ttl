@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarCaptacionConectadaEnLaEntradaDeVolante a ns1:TareaMantenimiento ;
    rdfs:label "Revisar captación conectada en la entrada de volante" ;
    ns1:solucionaFallo ns1:FalloLecturaIncorrectaVolante ;
    ns1:textoExtracto "SOLUCIÓN Revisar la captación conectada en la entrada de volante; niveles de señal, frecuencia, etc." .

ns1:RevisarCoherenciaYNivelDeComunicacionDelBusCorrespondienteAsiComoLaPa_38246b38f8 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar coherencia y nivel de comunicación del bus correspondiente, así como la parametrización y conexión de la entrada" ;
    ns1:solucionaFallo ns1:ErrorEnRefrescoDeVolantes ;
    ns1:textoExtracto "revisar la coherencia y el nivel de comunicación del bus correspondiente, así como la parametrización y conexión de la entrada de" .

ns1:ErrorEnRefrescoDeVolantes a ns1:DiagnosticoFallo ;
    rdfs:label "Error en refresco de volantes" ;
    ns1:textoExtracto "'Error en refresco de volantes'" .

ns1:FalloLecturaIncorrectaVolante a ns1:DiagnosticoFallo ;
    rdfs:label "Lectura incorrecta del volante" ;
    ns1:textoExtracto "CAUSA Lectura incorrecta del volante." .

