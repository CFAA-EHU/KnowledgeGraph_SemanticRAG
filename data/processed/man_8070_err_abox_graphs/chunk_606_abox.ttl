@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloRCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoVolante ;
    ns1:textoExtracto "módulo RCS-S" .

ns1:TareaMantenimiento_edba6b2857 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de revisar la coherencia y el nivel de comunicación del bus correspondiente" ;
    ns1:textoExtracto "revisar la coherencia y el nivel de comunicación del bus correspondiente, así como la parametrización y conexión de la entrada de captación" .

ns1:SistemaHidraulicoVolante a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico de Volante" ;
    ns1:textoExtracto "de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

