@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_6058
    a ex:Alarma ;
    rdfs:label "Alarma 6058: Algún nodo CANopen no se encuentra en fase operacional" ;
    ex:identificador "6058" ;
    ex:textoExtracto "6058 'Algún nodo CANopen no se encuentra en fase operacional' DETECCIÓN Tras un reset del CNC. CAUSA En la reinicialización de CANopen que se hace durante el reset de CNC, alguno de los nodos no ha conseguido llegar a fase operacional. SOLUCIÓN Revisar el conexionado y configuración de los nodos CANopen." .

ex:Alarma_6059
    a ex:Alarma ;
    rdfs:label "Alarma 6059: Error en la configuración de una entrada analógica" ;
    ex:identificador "6059" ;
    ex:textoExtracto "6059 Error en la configuración de una entrada analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen, no se ha conseguido configurar correctamente alguna de las entradas parametrizadas en corriente. SOLUCIÓN Revisar la parametrización de entradas analógicas en corriente." .

ex:Alarma_6060
    a ex:Alarma ;
    rdfs:label "Alarma 6060: Error en la configuración de una salida analógica" ;
    ex:identificador "6060" ;
    ex:textoExtracto "6060 Error en la configuración de una salida analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen no se ha conseguido configurar correctamente alguna de las salidas parametrizadas en corriente. SOLUCIÓN Revisar la parametrización de salidas analógicas en corriente." .

ex:Alarma_6061
    a ex:Alarma ;
    rdfs:label "Alarma 6061: Nodos CANopen no Fagor. Opción de software no permitida" ;
    ex:identificador "6061" ;
    ex:textoExtracto "6061 Nodos CANopen no Fagor. Opción de software no permitida. DETECCIÓN En la inicialización del bus CANopen, durante el arranque del CNC o tras un reset. CAUSA Durante la inicialización del bus CANopen, se han detectado nodos de terceros sin disponer de la correspondiente opción de software. SOLUCIÓN Desconectar del bus CANopen aquellos nodos que no sean Fagor, o comprar la opción de software que permita su empleo." .

ex:Alarma_6062
    a ex:Alarma ;
    rdfs:label "Alarma 6062: Relé de emergencia abierto por error en reinicialización de bus" ;
    ex:identificador "6062" ;
    ex:textoExtracto "6062 Relé de emergencia abierto por error en reinicialización de bus. DETECCIÓN Tras un reset del CNC o durante la validación de parámetros máquina. CAUSA En reset o validación de parámetros máquina, no se ha conseguido finalizar correctamente la ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos." .

ex:Alarma_6000
    a ex:Alarma ;
    rdfs:label "Alarma de captación en volante conectado al contaje local" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de captación en volante conectado al contaje local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." .

ex:Sistema_CANopen
    a ex:Sistema ;
    rdfs:label "Bus CANopen" ;
    ex:textoExtracto "reinicialización de CANopen", "inicialización del bus CANopen", "nodos CANopen", "configuración de entradas analógicas en corriente", "configuración de salidas analógicas en corriente" .

ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Anillo Sercos" ;
    ex:textoExtracto "error durante el rearme del bus CAN o del anillo Sercos" .

ex:ComponenteElectrico_VolantesLocales
    a ex:ComponenteElectrico ;
    rdfs:label "Volantes locales conectados al contaje" ;
    ex:textoExtracto "Alarma de captación en volante conectado al contaje local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." .

ex:ComponenteElectrico_Rel_Emergencia
    a ex:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ex:textoExtracto "Relé de emergencia abierto por error en reinicialización de bus" .

ex:Parametro_EntradasAnalogicas
    a ex:Parametro ;
    rdfs:label "Entradas analógicas parametrizadas en corriente" ;
    ex:textoExtracto "no se ha conseguido configurar correctamente alguna de las entradas parametrizadas en corriente" .

ex:Parametro_SalidasAnalogicas
    a ex:Parametro ;
    rdfs:label "Salidas analógicas parametrizadas en corriente" ;
    ex:textoExtracto "no se ha conseguido configurar correctamente alguna de las salidas parametrizadas en corriente" .

ex:Parametro_Maquina
    a ex:Parametro ;
    rdfs:label "Parámetros máquina" ;
    ex:textoExtracto "durante la validación de parámetros máquina" .

# Relaciones entre alarmas y componentes/sistemas
ex:Alarma_6000 ex:activaAlarma ex:ComponenteElectrico_VolantesLocales .
ex:Alarma_6058 ex:activaAlarma ex:Sistema_CANopen .
ex:Alarma_6059 ex:activaAlarma ex:Sistema_CANopen ;
             ex:monitoreaParametro ex:Parametro_EntradasAnalogicas .
ex:Alarma_6060 ex:activaAlarma ex:Sistema_CANopen ;
             ex:monitoreaParametro ex:Parametro_SalidasAnalogicas .
ex:Alarma_6061 ex:activaAlarma ex:Sistema_CANopen .
ex:Alarma_6062 ex:activaAlarma ex:Sistema_CANopen , ex:Sistema_Sercos ;
             ex:activaAlarma ex:ComponenteElectrico_Rel_Emergencia .