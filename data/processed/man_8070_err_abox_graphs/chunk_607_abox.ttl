@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarPlacaSercos a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar placa Sercos" ;
    ns1:solucionaFallo ns1:ErrorEnLaInicializacionDelAnilloSercosCLASE0_38ed7e832e ;
    ns1:textoExtracto "Comprobar que la placa está instalada y que el CNC la detecta correctamente." .

ns1:ConsultarManualDelRegulador a ns1:AccionProhibida ;
    rdfs:label "Consultar manual del regulador" ;
    ns1:textoExtracto "Consultar el manual del regulador." .

ns1:ErrorEnLaInicializacionDelAnilloSercosCLASE1_fa3c5dc269 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos CLASE 1" ;
    ns1:textoExtracto "'Error en la inicialización del anillo Sercos' CLASE 1. TRANSICIÓN 0. CAUSA Timeout en la petición de inicialización del anillo Sercos." .

ns1:ErrorEnLaInicializacionDelAnilloSercosEJE a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos EJE" ;
    ns1:textoExtracto "'Error en la inicialización del anillo Sercos' EJE Nombre del eje que da error. TRANSICIÓN 1 ID Sercos que provoca el error." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorEnLaInicializacionDelAnilloSercosCLASE0_38ed7e832e a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos CLASE 0" ;
    ns1:textoExtracto "'Error en la inicialización del anillo Sercos' CLASE 0. CAUSA Error en la fase inicialización del chip." .

