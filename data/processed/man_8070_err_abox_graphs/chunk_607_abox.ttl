@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_607
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error en Sercos durante rearme de bus CAN"@es ;
    ex:textoExtracto      "Tras un reset del CNC o durante la validación de parámetros máquina... Como consecuencia, el relé de emergencia ha quedado abierto. VALOR 1 Error en Sercos durante un proceso"@es ;
    ex:identificador      "1" .

ex:ComponenteElectrico_ReleEmergencia_607
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Relé de emergencia"@es ;
    ex:textoExtracto      "el relé de emergencia ha quedado abierto"@es .

ex:Sistema_BusCAN_607
    a                     ex:Sistema ;
    rdfs:label            "Bus CAN"@es ;
    ex:textoExtracto      "error durante el rearme del bus CAN"@es .

ex:Sistema_AnilloSercos_607
    a                     ex:Sistema ;
    rdfs:label            "Anillo Sercos"@es ;
    ex:textoExtracto      "error durante el rearme del... anillo Sercos"@es .

ex:Fallo_607
    ex:solucionaFallo      ex:ComponenteElectrico_ReleEmergencia_607 ;
    ex:monitoreaParametro ex:Sistema_BusCAN_607 ,
                        ex:Sistema_AnilloSercos_607 .