@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_7007
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7007: 'En modo carga: T0 no admitida'"@es ;
    ex:textoExtracto "'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0. SOLUCIÓN Programar la herramienta a cargar en el almacén."@es ;
    ex:identificador "7007" .

ex:AvisoSeguridad_7008
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7008: 'En modo carga: Esta herramienta ya está cargada'"@es ;
    ex:textoExtracto "'En modo carga:Esta herramienta ya esta cargada' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. La herramienta programada ya está en el almacén. SOLUCIÓN Programar una herramienta que no esté ya cargada."@es ;
    ex:identificador "7008" .

ex:AvisoSeguridad_7009
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7009: 'En modo carga: M6 sin T'"@es ;
    ex:textoExtracto "'En modo carga:M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar una M6 sin herramienta. SOLUCIÓN Programar la herramienta a cargar y a continuación la función M6."@es ;
    ex:identificador "7009" .

ex:AvisoSeguridad_7010
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7010: 'En modo carga: T con dos M6'"@es ;
    ex:textoExtracto "'En modo carga:T con dos M6' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. Hay programadas dos M6 consecutivas sin herramienta. SOLUCIÓN Programar la herramienta a cargar y a continuación la función M6."@es ;
    ex:identificador "7010" .

ex:AvisoSeguridad_7011
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7011: 'En modo carga: D sola no admitida'"@es ;
    ex:textoExtracto "'En modo carga:D sola no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación."@es ;
    ex:identificador "7011" .

ex:AvisoSeguridad_7012
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7012: 'En modo carga: La herramienta está gastada o rechazada'"@es ;
    ex:textoExtracto "'En modo carga:La herramienta esta gastada o rechazada' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. La herramienta a cargar en el almacén está gastada o rechazada. SOLUCIÓN Programar una herramienta válida."@es ;
    ex:identificador "7012" .

ex:AvisoSeguridad_7013
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7013: 'En modo carga: Posición inválida o no hay sitio en el almacén'"@es ;
    ex:textoExtracto "'En modo carga:Posición inválida o no hay sitio en el almacén' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. El almacén está lleno o la posición especificada está ocupada. SOLUCIÓN Si no hay sitio en el almacén habrá que descargar previamente alguna herramienta. Si la posición especificada está ocupada, habrá que elegir otra ubicación."@es ;
    ex:identificador "7013" .

ex:AvisoSeguridad_7014
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7014: 'En modo descarga: T no está en el almacén'"@es ;
    ex:textoExtracto "'En modo descarga:T no esta en el almacén' DETECCIÓN Durante la ejecución."@es ;
    ex:identificador "7014" .

ex:ModoOperacion_Carga
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación: Carga"@es ;
    ex:textoExtracto "Almacén en modo carga."@es .

ex:ModoOperacion_Descarga
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación: Descarga"@es ;
    ex:textoExtracto "En modo descarga"@es .

ex:AvisoSeguridad_7007 ex:mitigaRiesgo ex:ModoOperacion_Carga .
