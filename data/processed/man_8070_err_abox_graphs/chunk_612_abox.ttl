@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_7014
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo 7014: Herramienta T no está en el almacén"@es ;
    ex:identificador "7014" ;
    ex:textoExtracto "'En modo descarga:T no esta en el almacén' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. La herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida."@es .

ex:Fallo_7015
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo 7015: Combinación no admitida (D y T)"@es ;
    ex:identificador "7015" ;
    ex:textoExtracto "'En modo descarga:D no admitida junto con T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga."@es .

ex:ModoDescarga
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de descarga del almacén"@es ;
    ex:textoExtracto "Almacén en modo descarga"@es ;
    ex:activaAlarma  ex:Fallo_7014 , ex:Fallo_7015 .