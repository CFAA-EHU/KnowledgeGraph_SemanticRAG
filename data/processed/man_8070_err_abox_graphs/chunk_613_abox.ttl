@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error7015 a ex:DiagnosticoFallo ;
    ex:identificador "7015" ;
    rdfs:label "'En modo descarga:D no admitida junto con T'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar el corrector junto a la herramienta. SOLUCIÓN No se admite esta programación." .

ex:Error7016 a ex:DiagnosticoFallo ;
    ex:identificador "7016" ;
    rdfs:label "'En modo descarga:D sola no admitida'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ex:Error7017 a ex:DiagnosticoFallo ;
    ex:identificador "7017" ;
    rdfs:label "'En modo descarga:M6 sin T'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar una M6 sin herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ex:Error7018 a ex:DiagnosticoFallo ;
    ex:identificador "7018" ;
    rdfs:label "'En modo descarga:T con dos M6'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. Hay programadas dos M06 consecutivas para una misma herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ex:Error7019 a ex:DiagnosticoFallo ;
    ex:identificador "7019" ;
    rdfs:label "'En modo setting:T0 no admitida'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar T0. SOLUCIÓN Programar una herramienta diferente de 0." .

ex:Error7020 a ex:DiagnosticoFallo ;
    ex:identificador "7020" ;
    rdfs:label "'En modo setting:D obligatoria'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. Falta programar el corrector. SOLUCIÓN Programar el corrector." .

ex:Error7021 a ex:DiagnosticoFallo ;
    ex:identificador "7021" ;
    rdfs:label "'En modo setting:D sola no admitida'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ex:Error7022 a ex:DiagnosticoFallo ;
    ex:identificador "7022" ;
    rdfs:label "'En modo setting:M6 no admitida'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar M06. SOLUCIÓN No se admite esta programación." .

ex:Error7023 a ex:DiagnosticoFallo ;
    ex:identificador "7023" ;
    rdfs:label "'En modo carga:M6 obligatoria'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga." .

ex:ModoDescarga a ex:ModoOperacion ;
    rdfs:label "Modo descarga" ;
    ex:textoExtracto "Almacén en modo descarga." .

ex:ModoSetting a ex:ModoOperacion ;
    rdfs:label "Modo setting" ;
    ex:textoExtracto "Almacén en modo setting." .

ex:ModoCarga a ex:ModoOperacion ;
    rdfs:label "Modo carga" ;
    ex:textoExtracto "Almacén en modo carga." .

ex:Herramienta a ex:Herramienta ;
    ex:textoExtracto "herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida." .

ex:Error7015 ex:solucionaFallo ex:Herramienta .
ex:Error7017 ex:solucionaFallo ex:Herramienta .
ex:Error7018 ex:solucionaFallo ex:Herramienta .
ex:Error7019 ex:solucionaFallo ex:Herramienta .