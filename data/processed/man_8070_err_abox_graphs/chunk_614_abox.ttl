@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PonerEnMismoValorEnElCNCYElRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Poner en mismo valor en el CNC y el regulador" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_74e7eed6f8,
        ns1:DiagnosticoFallo_e66ce3c962 ;
    ns1:textoExtracto "SOLUCIÓN Poner en mismo valor en el CNC y el regulador." .

ns1:ValorDelParametroAXISMODE a ns1:Parametro ;
    rdfs:label "Valor del parámetro AXISMODE" ;
    ns1:monitoreaParametro ns1:CNC8070_1a9088e7e5,
        ns1:Regulador ;
    ns1:textoExtracto "VALOR Valor del parámetro en el CNC." .

ns1:CNC8070_1a9088e7e5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:Regulador ;
    ns1:textoExtracto "CNC 8070" .

ns1:DiagnosticoFallo_74e7eed6f8 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro AXISMODE diferente en CNC y regulador" ;
    ns1:textoExtracto "'Parámetro AXISMODE diferente en CNC y regulador'" .

ns1:DiagnosticoFallo_e66ce3c962 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro G00FEED mayor en CNC que en Regulador" ;
    ns1:textoExtracto "'Parámetro G00FEED mayor en CNC que en Regulador'" .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "regulador" .

