@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8cd36c09d5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "'Parámetro G00FEED mayor en CNC que en Regulador'" .

ns1:ConsignaAdicionalDelRegulador a ns1:Parametro ;
    rdfs:label "Consigna adicional del regulador" ;
    ns1:identificador "SP100" ;
    ns1:textoExtracto "'Parámetro SP100 del regulador debe ser 0'" .

ns1:DefinirLaKVDelReguladorConUnValorDistintoDe0 a ns1:AccionProhibida ;
    rdfs:label "Definir la KV del regulador con un valor distinto de 0" ;
    ns1:textoExtracto "Cabezal Sercos necesita una ganancia distinta de 0" .

ns1:ParametroG00FEED a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED" ;
    ns1:textoExtracto "'Parámetro G00FEED mayor en CNC que en Regulador'" .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ReguladorHidraulico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Hidráulico" ;
    ns1:textoExtracto "'Vigilancia de error de seguimiento no activa en el regulador'" .

ns1:RevisarYAjustarParametrosDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar y ajustar parámetros del regulador" ;
    ns1:solucionaFallo ns1:FalloErrorSercosReset ;
    ns1:textoExtracto "Descartar reset voluntarios del regulador desde botón de reset, WinDDS (grabación de versión, soft reset) o problemas hardware en el regulador." .

ns1:VigilanciaDeErrorDeSeguimiento a ns1:Parametro ;
    rdfs:label "Vigilancia de error de seguimiento" ;
    ns1:identificador "PP159" ;
    ns1:textoExtracto "'Vigilancia de error de seguimiento no activa en el regulador'" .

ns1:FalloErrorSercosReset a ns1:DiagnosticoFallo ;
    rdfs:label "Error+ en el anillo Sercos debido a un reset del regulador" ;
    ns1:textoExtracto "'Error+ en el anillo Sercos debido a un reset del regulador'" .

