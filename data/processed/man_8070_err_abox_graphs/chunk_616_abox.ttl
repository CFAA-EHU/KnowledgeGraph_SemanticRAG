@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_M6sinT
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo M6 sin herramienta (7030)"@es ;
    ex:identificador "7030" ;
    ex:textoExtracto "7030 'M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta."@es .

ex:Parametro_ComportamientoM6
    a ex:Parametro ;
    rdfs:label "Parámetro de comportamiento ante M06 sin herramienta"@es ;
    ex:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no"@es ;
    ex:valor "error/warning/ninguno" .

ex:Tarea_CorreccionPLC
    a ex:TareaMantenimiento ;
    rdfs:label "Corrección de maniobra de cambio de herramienta en PLC"@es ;
    ex:textoExtracto "SOLUCIÓN Corregir en el programa de PLC la maniobra de cambio de herramienta."@es ;
    ex:solucionaFallo ex:Fallo_M6sinT .

ex:Aviso_EmergenciaSETTMEM
    a ex:AvisoSeguridad ;
    rdfs:label "Señal de emergencia SETTMEM activada por PLC"@es ;
    ex:textoExtracto "Si el PLC ha activado la marca SETTMEM, corregir la causa por la que el PLC ha puesto la señal de emergencia."@es .