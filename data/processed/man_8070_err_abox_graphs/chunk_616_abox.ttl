@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirMasDe67VariablesSincronasParaUnMismoEje a ns1:AccionProhibida ;
    rdfs:label "Definir más de 6/7 variables síncronas para un mismo eje" ;
    ns1:solucionaFallo ns1:SuperadoElNumeroDeVariablesPermitidasEnUnTelegramaSercos ;
    ns1:textoExtracto "En la tabla de variables Sercos hay definidas más de 6/7 variables de lectura escritura síncrona para un mismo eje." .

ns1:SolucionReducirVariablesSincronas a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el número de variables síncronas y definir algunas como asíncronas" ;
    ns1:textoExtracto "Reducir el número de variables síncronas a tratar en ese eje. Definir algunas de dichas variables como de acceso asíncrono." .

ns1:SuperadoElNumeroDeVariablesPermitidasEnUnTelegramaSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Superado el número de variables permitidas en un telegrama Sercos" ;
    ns1:textoExtracto "'Superado el número de variables permitidas en un telegrama Sercos'" .

