@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizarVersionDeSoftwareDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar versión de software del regulador" ;
    ns1:solucionaFallo ns1:NoExisteElParametroEnElRegulador ;
    ns1:textoExtracto "SOLUCIÓN Actualizar versión de software del regulador." .

ns1:CorregirElValorDelParametroEnElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el valor del parámetro en el CNC" ;
    ns1:solucionaFallo ns1:ElValorDelParametroMaquinaEstaFueraDelRangoPermitido ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del parámetro en el CNC." .

ns1:RevisarElNumeroDeEjesSercosOTiemposDeSercos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el número de ejes Sercos o tiempos de Sercos" ;
    ns1:solucionaFallo ns1:ErrorEnLaInicializacionDelSERCON_4240efadda ;
    ns1:textoExtracto "CAUSA Número de ejes Sercos o tiempos de Sercos erróneos." .

ns1:RevisarEstadoDeLaComunicacionConElReguladorVersionDeSoftwareYOpciones_04a7965afe a ns1:TareaMantenimiento ;
    rdfs:label "Revisar estado de la comunicación con el regulador, versión de software y opciones de parametrización permitidas" ;
    ns1:solucionaFallo ns1:NoSePuedeEscribirParametroEnElRegulador ;
    ns1:textoExtracto "SOLUCIÓN Revisar el estado de la comunicación con el regulador, versión de software y opciones de parametrización permitidas." .

ns1:RevisarLosPermisosYElNivelDeAccesoEnElRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los permisos y el nivel de acceso en el regulador" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_6d1d831ce9 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los permisos y el nivel de acceso en el regulador." .

ns1:DiagnosticoFallo_6d1d831ce9 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro protegido contra escritura" ;
    ns1:textoExtracto "'No se puede escribir parámetro en el regulador:Protegido'" .

ns1:ElValorDelParametroMaquinaEstaFueraDelRangoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "El valor del parámetro máquina está fuera del rango permitido" ;
    ns1:textoExtracto "'No se puede escribir parámetro en el regulador:Fuera de rango'" .

ns1:ErrorEnLaInicializacionDelSERCON_4240efadda a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del SERCON" ;
    ns1:textoExtracto "'Error en la inicialización del SERCON'" .

ns1:NoExisteElParametroEnElRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "No existe el parámetro en el regulador" ;
    ns1:textoExtracto "'No se puede escribir parámetro en el regulador:No IDN'" .

ns1:NoSePuedeEscribirParametroEnElRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede escribir parámetro en el regulador" ;
    ns1:textoExtracto "'No se puede escribir parámetro en el regulador'" .

