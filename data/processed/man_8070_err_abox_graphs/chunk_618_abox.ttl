@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_7037
    a                     ex:DiagnosticoFallo ;
    ex:identificador       "7037" ;
    ex:textoExtracto       "'El cabezal tiene que estar vacío para los modos CARGA o DESCARGA'" ;
    rdfs:label            "Fallo 7037: Cabezal no vacío en modo CARGA/DESCARGA" .

ex:DiagnosticoFallo_7039
    a                     ex:DiagnosticoFallo ;
    ex:identificador       "7039" ;
    ex:textoExtracto       "'No puede"@es ;
    rdfs:label            "Fallo 7039: Condición no cumplida (incompleto)"@es .

ex:ModoOperacion_CARGA
    a                     ex:ModoOperacion ;
    ex:identificador       "CARGA" ;
    ex:textoExtracto       "modo carga"@es ;
    rdfs:label            "Modo CARGA"@es .

ex:ModoOperacion_DESCARGA
    a                     ex:ModoOperacion ;
    ex:identificador       "DESCARGA" ;
    ex:textoExtracto       "modo descarga"@es ;
    rdfs:label            "Modo DESCARGA"@es .

ex:Componente_Cabezal
    a                     ex:Componente ;
    ex:textoExtracto       "el cabezal tiene que estar vacío"@es ;
    rdfs:label            "Cabezal del almacén"@es .

ex:Componente_Brazos
    a                     ex:Componente ;
    ex:textoExtracto       "los brazos en los almacenes donde proceda"@es ;
    rdfs:label            "Brazos del almacén"@es .

ex:TareaMantenimiento_VaciarCabezal
    a                     ex:TareaMantenimiento ;
    ex:textoExtracto       "Vaciar el cabezal y los brazos"@es ;
    rdfs:label            "Vaciar cabezal y brazos"@es ;
    ex:solucionaFallo      ex:DiagnosticoFallo_7037 .

ex:TareaMantenimiento_DescargarHerramienta
    a                     ex:TareaMantenimiento ;
    ex:textoExtracto       "Descargar primero la herramienta"@es ;
    rdfs:label            "Descargar herramienta del almacén"@es .

ex:AccionProhibida_CambioFamiliaHerramientaAlmacenada
    a                     ex:AccionProhibida ;
    ex:textoExtracto       "no se puede cambiar la familia de una herramienta que está en el almacén"@es ;
    rdfs:label            "Cambiar familia de herramienta almacenada"@es .

ex:AvisoSeguridad_DescargaPreviaHerramienta
    a                     ex:AvisoSeguridad ;
    ex:textoExtracto       "Por motivos de seguridad no se puede cambiar la familia de una herramienta que está en el almacén. SOLUCIÓN Descargar primero la herramienta."@es ;
    rdfs:label            "Aviso: Descarga previa obligatoria para cambiar familia de herramienta"@es ;
    ex:mitigaRiesgo        ex:AccionProhibida_CambioFamiliaHerramientaAlmacenada .