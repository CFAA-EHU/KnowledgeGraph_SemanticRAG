@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de parametrización" ;
    ns1:solucionaFallo ns1:FalloError4019,
        ns1:FalloError4020 ;
    ns1:textoExtracto "SOLUCIÓN Corregir la parametrización." .

ns1:CorregirLaParametrizacionIncorrectaDelModuloRCSS a ns1:AccionProhibida ;
    rdfs:label "Corregir la parametrización incorrecta del módulo RCS-S" ;
    ns1:textoExtracto "SOLUCIÓN Corregir la parametrización." .

ns1:CorregirLaParametrizacionIncorrectaDelModuloRCSSOSusRecursos a ns1:AccionProhibida ;
    rdfs:label "Corregir la parametrización incorrecta del módulo RCS-S o sus recursos" ;
    ns1:textoExtracto "SOLUCIÓN Corregir la parametrización." .

ns1:FalloError4022 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos debido a un Reset de contadora por Watchdog" ;
    ns1:textoExtracto "4022 Error en el anillo Sercos debido a un Reset de contadora por Watchdog." .

ns1:PongaseEnContactoConFagorSiElErrorPersiste a ns1:AvisoSeguridad ;
    rdfs:label "Póngase en contacto con Fagor si el error persiste" ;
    ns1:mitigaRiesgo ns1:FalloError4019 ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor." .

ns1:SubsanarLaCausaDelResetEnElModuloRCSS a ns1:AccionProhibida ;
    rdfs:label "Subsanar la causa del reset en el módulo RCS-S" ;
    ns1:textoExtracto "SOLUCIÓN Subsanar la causa del problema. Si el error persiste, póngase en contacto con Fagor." .

ns1:TipoDeCaptacion_089d2606ff a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:textoExtracto "el tipo de captación (parámetro FEEDBACKTYPE)" .

ns1:FalloError4020 a ns1:DiagnosticoFallo ;
    rdfs:label "Parametrización inconsistente" ;
    ns1:textoExtracto "4020 Parametrización inconsistente." .

ns1:FalloError4019 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos debido a un Reset de contadora" ;
    ns1:textoExtracto "4019 Error en el anillo Sercos debido a un Reset de contadora." .

