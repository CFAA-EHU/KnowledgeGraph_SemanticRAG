@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_7050
    a ex:Alarma ;
    rdfs:label "Alarma 7050: ROTATEMZ - Posición no válida" ;
    ex:identificador "7050" ;
    ex:textoExtracto "7050 ROTATEMZ: Posición no válida. DETECCIÓN Durante la ejecución. CAUSA La posición programada en #ROTATEMZ no es válida. SOLUCIÓN Revisar la programación." .

ex:Alarma_7051
    a ex:Alarma ;
    rdfs:label "Alarma 7051: Número de filo no válido" ;
    ex:identificador "7051" ;
    ex:textoExtracto "7051 'Número de filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta tiene menos filos que el programado. SOLUCIÓN Programar un filo existente o añadir nuevos filos a la herramienta." .

ex:Herramienta_7051
    a ex:Herramienta ;
    rdfs:label "Herramienta con número de filos programable" ;
    ex:textoExtracto "La herramienta tiene menos filos que el programado." .