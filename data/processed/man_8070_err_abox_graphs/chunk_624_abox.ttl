@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8000
    a ex:AvisoSeguridad ;
    rdfs:label "El Kernel de simulación no se encuentra activado" ;
    ex:textoExtracto "8000 'El Kernel de simulación no se encuentra activado' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel de simulación está arrancado pero no está activado. SOLUCIÓN Comprobar si el CNC ha arrancado correctamente. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." ;
    ex:identificador "8000" .

ex:Error_8001
    a ex:AvisoSeguridad ;
    rdfs:label "El Kernel de simulación no se encuentra activado" ;
    ex:textoExtracto "8001 'El Kernel de simulación no se encuentra activado' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel de simulación está arrancado pero no está activado. SOLUCIÓN Comprobar si el CNC ha arrancado correctamente." ;
    ex:identificador "8001" .

ex:Error_8002
    a ex:AvisoSeguridad ;
    rdfs:label "Error registrando tecla" ;
    ex:textoExtracto "8002 'Error registrando tecla' DETECCIÓN Durante el arranque del sistema. CAUSA EL CNC no ha podido registrar alguna de las softkeys o de las teclas de acceso rápido. SOLUCIÓN Comprobar si el CNC ha arrancado correctamente." ;
    ex:identificador "8002" .

ex:Error_8003
    a ex:AvisoSeguridad ;
    rdfs:label "Cierre no permitido mientras se encuentre en ejecución o interrumpido" ;
    ex:textoExtracto "8003 'Cierre no permitido mientras se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control. SOLUCIÓN Detener los programas en ejecución." ;
    ex:identificador "8003" .

ex:Error_8004
    a ex:AvisoSeguridad ;
    rdfs:label "Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido" ;
    ex:textoExtracto "8004 'Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si algún canal se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control. SOLUCIÓN Detener los programas en ejecución." ;
    ex:identificador "8004" .

ex:Error_8005
    a ex:AvisoSeguridad ;
    rdfs:label "Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución" ;
    ex:textoExtracto "8005 'Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución' DETECCIÓN Durante la ejecución. CAUSA No está permitido cambiar de modo si algún canal del grupo se encuentra en ejecución. SOLUCIÓN Detener los programas en ejecución de todos los canales del grupo." ;
    ex:identificador "8005" .

ex:Error_8006
    a ex:AvisoSeguridad ;
    rdfs:label "Error iniciando proceso de carga" ;
    ex:textoExtracto "8006 'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la preparación del proceso de carga de la COMPCI o los módulos remotos." ;
    ex:identificador "8006" .

ex:CNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "CNC" .

ex:Error_8000 ex:activaAlarma ex:CNC .
ex:Error_8001 ex:activaAlarma ex:CNC .
ex:Error_8002 ex:activaAlarma ex:CNC .
ex:Error_8003 ex:activaAlarma ex:CNC .
ex:Error_8004 ex:activaAlarma ex:CNC .
ex:Error_8005 ex:activaAlarma ex:CNC .
ex:Error_8006 ex:activaAlarma ex:CNC .