@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b02c3257a2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "del CNC, validación de los parámetros máquina y reset." .

ns1:DatosDeEncoderFeeDatEnDat a ns1:Parametro ;
    rdfs:label "Datos de encoder FeeDat/EnDat" ;
    ns1:textoExtracto "Incoherencia en datos de encoder FeeDat/EnDat." .

ns1:SolucionActualizacionRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Instalar versión posterior de reguladores" ;
    ns1:solucionaFallo ns1:VersionDeReguladorNoSoportaTandemConControlDeParOModoDeReferenciaCNC ;
    ns1:textoExtracto "instalar en los reguladores una versión posterior a la v6.28 u v8.08." .

ns1:SolucionConfiguracionMAB a ns1:TareaMantenimiento ;
    rdfs:label "Configurar Multi-Axis Box (MAB) en el anillo Sercos" ;
    ns1:solucionaFallo ns1:NoSeHaIdentificadoMultiAxisBoxMABEnElAnilloSercos ;
    ns1:textoExtracto "Eliminar la opción MABSYSTEM o incluir un regulador MAB en la configuración Sercos." .

ns1:ValidarNuevaConfiguracionSercos a ns1:TareaMantenimiento ;
    rdfs:label "Validar nueva configuración Sercos" ;
    ns1:textoExtracto "Es necesario validar la nueva configuración." .

ns1:NoSeHaIdentificadoMultiAxisBoxMABEnElAnilloSercos a ns1:AccionProhibida ;
    rdfs:label "No se ha identificado Multi-Axis Box (MAB) en el anillo Sercos" ;
    ns1:textoExtracto "No se ha identificado Multi-Axis Box (MAB) en el anillo Sercos." .

ns1:VersionDeReguladorNoSoportaTandemConControlDeParOModoDeReferenciaCNC a ns1:AccionProhibida ;
    rdfs:label "Versión de regulador no soporta tandem con control de par o modo de referencia CNC" ;
    ns1:textoExtracto "La versión de un regulador no soporta el tandem con control de par o el modo de referencia CNC." .

