@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionFeeDatEnDatParametrizadaEnContadoraSercosQueNoSoportaElProtocolo a ns1:AccionProhibida ;
    rdfs:label "Captación FeeDat/EnDat parametrizada en contadora Sercos que no soporta el protocolo" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:solucionaFallo ns1:SeHaParametrizadoUnaCaptacionFeeDatEnDatEnUnModuloRCSSQueNoLoPermite ;
    ns1:textoExtracto "4027 Captación FeeDat/EnDat parametrizada en contadora Sercos que no soporta el protocolo." .

ns1:EsNecesarioActualizarElModuloRCSSOCambiarloPorOtroNodoQueSoporteLosPr_6704fb68e2 a ns1:TareaMantenimiento ;
    rdfs:label "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat" ;
    ns1:textoExtracto "SOLUCIÓN Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat." .

ns1:IncoherenciaEnDatosDeEncoderFeeDatEnDat a ns1:AccionProhibida ;
    rdfs:label "Incoherencia en datos de encoder FeeDat/EnDat" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:solucionaFallo ns1:LosDatosLeidosDeUnEncoderFeeDatEnDatSonDiferentesALosGuardadosEnElCNC_638e5b5a4c ;
    ns1:textoExtracto "4026 Incoherencia en datos de encoder FeeDat/EnDat. Es necesario validar la nueva configuración." .

ns1:VolverAConectarElEncoderQueSeValidoEnLaPuestaAPuntoOValidarElNuevoEncoder a ns1:TareaMantenimiento ;
    rdfs:label "Volver a conectar el encoder que se validó en la puesta a punto o validar el nuevo encoder" ;
    ns1:textoExtracto "SOLUCIÓN Volver a conectar el encoder que se validó en la puesta a punto o validar el nuevo encoder." .

ns1:LosDatosLeidosDeUnEncoderFeeDatEnDatSonDiferentesALosGuardadosEnElCNC_638e5b5a4c a ns1:DiagnosticoFallo ;
    rdfs:label "Los datos leídos de un encoder FeeDat/EnDat son diferentes a los guardados en el CNC. El encoder es diferente del que se validó durante la puesta a punto." ;
    ns1:textoExtracto "CAUSA Los datos leídos de un encoder FeeDat/EnDat son diferentes a los guardados en el CNC. El encoder es diferente del que se validó durante la puesta a punto." .

ns1:SeHaParametrizadoUnaCaptacionFeeDatEnDatEnUnModuloRCSSQueNoLoPermite a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha parametrizado una captación FeeDat/EnDat en un módulo RCS-S que no lo permite." ;
    ns1:textoExtracto "CAUSA Se ha parametrizado una captación FeeDat/EnDat en un módulo RCS-S que no lo permite." .

