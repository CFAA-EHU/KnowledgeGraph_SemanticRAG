@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizarModuloRCSS_4980d64449 a ns1:AccionProhibida ;
    rdfs:label "Actualizar módulo RCS-S" ;
    ns1:textoExtracto "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat." .

ns1:NodoSercos a ns1:ComponenteElectrico ;
    rdfs:label "Nodo Sercos" ;
    ns1:textoExtracto "Variable DRV cuyo IDN no existe en el nodo Sercos." .

ns1:RevisarYCorregirParametrizacionDRVVAR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar y corregir parametrización DRVVAR" ;
    ns1:solucionaFallo ns1:FalloInicializacionBusSercos ;
    ns1:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización." .

ns1:VariableDRVVAR a ns1:Parametro ;
    rdfs:label "Variable DRVVAR" ;
    ns1:textoExtracto "La inicialización del bus Sercos ha fallado porque una variable DRVVAR tiene IDN incorrecto." .

ns1:FalloInicializacionBusSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Falla inicialización bus Sercos" ;
    ns1:textoExtracto "La inicialización del bus Sercos ha fallado porque una variable DRVVAR tiene IDN incorrecto." .

