@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrizacionDeEncoderesFeeDatEnDat a ns1:Parametro ;
    rdfs:label "Parametrización de encóderes FeeDat/EnDat" ;
    ns1:textoExtracto "Revisar la parametrización de los encóderes FeeDat/EnDat de la contadora Sercos, garantizando que todos sean absolutos." .

ns1:ParametrizacionDeNodosSercos a ns1:Parametro ;
    rdfs:label "Parametrización de nodos Sercos" ;
    ns1:textoExtracto "La parametrización de nodos Sercos (reguladores y contadoras) no es coherente." .

ns1:RevisarLaParametrizacionDeEjesYContadorasSercosYCorregirLaParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la parametrización de ejes y contadoras Sercos, y corregir la parametrización" ;
    ns1:solucionaFallo ns1:NumeracionErroneaDeLosNodosSercos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la parametrización de ejes y contadoras Sercos, y corregir la parametrización." .

ns1:RevisarLaParametrizacionDeLosEncoderesFeeDatEnDatDeLaContadoraSercosG_0a0ea6578d a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la parametrización de los encóderes FeeDat/EnDat de la contadora Sercos, garantizando que todos sean absolutos" ;
    ns1:solucionaFallo ns1:NoSeSoportanEncoderesFeeDatEnDatIncrementales ;
    ns1:textoExtracto "SOLUCIÓN Revisar la parametrización de los encóderes FeeDat/EnDat de la contadora Sercos, garantizando que todos sean absolutos." .

ns1:RevisarLaTablaDRVVARYCorregirLaParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la tabla DRVVAR y corregir la parametrización" ;
    ns1:solucionaFallo ns1:VariableDRVCuyosAtributosNoPuedenSerLeidos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la tabla DRVVAR y corregir la parametrización." .

ns1:TablaDRVVAR a ns1:Parametro ;
    rdfs:label "Tabla DRVVAR" ;
    ns1:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización." .

ns1:NoSeSoportanEncoderesFeeDatEnDatIncrementales a ns1:DiagnosticoFallo ;
    rdfs:label "No se soportan encóderes FeeDat/EnDat incrementales" ;
    ns1:textoExtracto "4031 No se soportan encóderes FeeDat/EnDat incrementales." .

ns1:NumeracionErroneaDeLosNodosSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Numeración errónea de los nodos Sercos" ;
    ns1:textoExtracto "4030 Numeración errónea de los nodos Sercos." .

ns1:VariableDRVCuyosAtributosNoPuedenSerLeidos a ns1:DiagnosticoFallo ;
    rdfs:label "Variable DRV cuyos atributos no pueden ser leídos" ;
    ns1:textoExtracto "4029 Variable DRV cuyos atributos no pueden ser leídos." .

