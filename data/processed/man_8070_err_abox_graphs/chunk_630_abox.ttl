@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_138a3cc045 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para parametrización incorrecta del Gap Control en reguladores sin REFMODE = Regulador" ;
    ns1:mitigaRiesgo ns1:ParaGapControlElReguladorDebeTenerREFMODERegulador_5b761246f9 ;
    ns1:textoExtracto "SOLUCIÓN Definir el parámetro REFMODE del eje como \"Regulador\"." .

ns1:AvisoSeguridad_47bc698556 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para parametrización incorrecta del Gap Control en reguladores no Sercos Posición" ;
    ns1:mitigaRiesgo ns1:ParaGapControlElReguladorDebeSerSercosPosicion_eea7a787ef ;
    ns1:textoExtracto "SOLUCIÓN Parametrizar correctamente el regulador que debe hacer el control de gap." .

ns1:AvisoSeguridad_927b84d96e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para parametrización incorrecta del Gap Control en reguladores no compatibles" ;
    ns1:mitigaRiesgo ns1:ParametrizadoGapControlEnUnReguladorQueNoLoSoporta_7d491f5402 ;
    ns1:textoExtracto "SOLUCIÓN Utilizar un regulador Fagor con versión de software v9.03 o superior, o anular el control de gap interno del regulador." .

ns1:AvisoSeguridad_efccfcb4cd a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para escritura síncrona de la variable DRV FFGAIN en reguladores no compatibles",
        "Aviso de seguridad para parametrización incorrecta del Gap Control en reguladores sin captación externa libre" ;
    ns1:mitigaRiesgo ns1:ElReguladorNoSoportaLaEscrituraSincronaDeLaVariableDRVFFGAIN_1acfb79654,
        ns1:ParaGapControlElReguladorDebeTenerSuCaptacionExternaLibre_0fd29a93ea ;
    ns1:textoExtracto "SOLUCIÓN Instalar una tarjeta de control de gap en el regulador (conector X3)." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ParametroGAPANAINID a ns1:Parametro ;
    rdfs:label "Parámetro GAPANAINID" ;
    ns1:textoExtracto "El parámetro GAPANAINID indica un regulador Fagor cuya versión no soporta control de gap o el regulador no es Fagor." .

ns1:ParametroREFMODE a ns1:Parametro ;
    rdfs:label "Parámetro REFMODE" ;
    ns1:textoExtracto "El eje seleccionado para el control de gap tiene su parámetro REFMODE definido como \"CNC\", no como \"Regulador\"." .

ns1:TarjetaDeControlDeGap a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta de control de gap" ;
    ns1:textoExtracto "Instalar una tarjeta de control de gap en el regulador (conector X3)." .

ns1:ElReguladorNoSoportaLaEscrituraSincronaDeLaVariableDRVFFGAIN_1acfb79654 a ns1:AccionProhibida ;
    rdfs:label "El regulador no soporta la escritura síncrona de la variable DRV FFGAIN" ;
    ns1:textoExtracto "4037 El regulador no soporta la escritura síncrona de la variable DRV FFGAIN." .

ns1:ParaGapControlElReguladorDebeSerSercosPosicion_eea7a787ef a ns1:AccionProhibida ;
    rdfs:label "Para Gap Control, el regulador debe ser Sercos Posición" ;
    ns1:textoExtracto "4034 Para Gap Control, el regulador debe ser Sercos Posición." .

ns1:ParaGapControlElReguladorDebeTenerREFMODERegulador_5b761246f9 a ns1:AccionProhibida ;
    rdfs:label "Para Gap Control, el regulador debe tener REFMODE = Regulador" ;
    ns1:textoExtracto "4035 Para Gap Control, el regulador debe tener REFMODE = Regulador." .

ns1:ParaGapControlElReguladorDebeTenerSuCaptacionExternaLibre_0fd29a93ea a ns1:AccionProhibida ;
    rdfs:label "Para Gap Control, el regulador debe tener su captación externa libre" ;
    ns1:textoExtracto "4036 Para Gap Control, el regulador debe tener su captación externa libre." .

ns1:ParametrizadoGapControlEnUnReguladorQueNoLoSoporta_7d491f5402 a ns1:AccionProhibida ;
    rdfs:label "Parametrizado Gap Control en un regulador que no lo soporta" ;
    ns1:textoExtracto "4033 Parametrizado Gap Control en un regulador que no lo soporta." .

