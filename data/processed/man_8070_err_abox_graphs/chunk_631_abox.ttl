@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminarVariableSincronaOUtilizarReguladorAXDConVersionV910OSuperior a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar variable síncrona o utilizar regulador AXD con versión v9.10 o superior" ;
    ns1:solucionaFallo ns1:ErrorEnElCanalCiclicoDeSercos ;
    ns1:textoExtracto "Eliminar la variable síncrona de la tabla DRVVAR o utilizar un regulador AXD con una versión de software v9.10 o superior." .

ns1:VerificarCompatibilidadDelReguladorYLaVersionDeSoftware a ns1:AvisoSeguridad ;
    rdfs:label "Verificar compatibilidad del regulador y la versión de software" ;
    ns1:mitigaRiesgo ns1:ParametrizarIDN296ComoDeEscrituraSincrona ;
    ns1:textoExtracto "En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona, y el regulador no es AXD o la versión de software es incompatible." .

ns1:ErrorEnElCanalCiclicoDeSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el canal cíclico de Sercos" ;
    ns1:textoExtracto "'Error en el canal cíclico de Sercos' EJE Número lógico del eje." .

ns1:ParametrizarIDN296ComoDeEscrituraSincrona a ns1:AccionProhibida ;
    rdfs:label "Parametrizar IDN296 como de escritura síncrona" ;
    ns1:textoExtracto "En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona, y el regulador no es AXD o la versión de software es incompatible." .

