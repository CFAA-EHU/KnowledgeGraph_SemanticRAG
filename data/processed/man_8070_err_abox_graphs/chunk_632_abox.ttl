@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DriveEnableDRENA a ns1:Parametro ;
    rdfs:label "Drive Enable (DRENA)" ;
    ns1:textoExtracto "Durante el movimiento de un eje, cae la habilitación DRENA de PLC." .

ns1:ErrorAlResetearElDriverDeSERCOS_728b9b2e89 a ns1:AvisoSeguridad ;
    rdfs:label "Error al resetear el driver de SERCOS" ;
    ns1:mitigaRiesgo ns1:EjeLogico ;
    ns1:textoExtracto "'Error al resetear el driver de SERCOS'. CAUSA Errores en el driver de Sercos." .

ns1:ErrorEnElCanalCiclicoDeSercos_0e5f4facf7 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el canal cíclico de Sercos" ;
    ns1:mitigaRiesgo ns1:EjeLogico ;
    ns1:textoExtracto "'Error en el canal cíclico de Sercos'. CAUSA Error en los procesos de lectura o escritura del canal cíclico (telegrama inválido o fase distinta de 4). SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorEnElCanalDeServicioDeSercos a ns1:AvisoSeguridad ;
    rdfs:label "Error en el canal de servicio de Sercos" ;
    ns1:mitigaRiesgo ns1:EjeLogico ;
    ns1:textoExtracto "'Error en el canal de servicio de Sercos'. CAUSA Error el canal de servicio de Sercos, en los procesos desencadenados desde el lazo. SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error. Póngase en contacto con el servicio de asistencia técnica." .

ns1:FaltaDriveEnableDRENA a ns1:AvisoSeguridad ;
    rdfs:label "Falta Drive Enable (DRENA)" ;
    ns1:mitigaRiesgo ns1:EjeLogico,
        ns1:SistemaPLC ;
    ns1:textoExtracto "'Falta Drive Enable (DRENA)'. CAUSA Durante el movimiento de un eje, cae la habilitación DRENA de PLC. SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal DRENA." .

ns1:FaltaSpeedEnableSPENA a ns1:AvisoSeguridad ;
    rdfs:label "Falta Speed Enable (SPENA)" ;
    ns1:mitigaRiesgo ns1:EjeLogico,
        ns1:SistemaPLC ;
    ns1:textoExtracto "'Falta Speed Enable (SPENA)'. CAUSA Durante el movimiento de un eje, cae la habilitación SPENA de PLC. SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA." .

ns1:SpeedEnableSPENA a ns1:Parametro ;
    rdfs:label "Speed Enable (SPENA)" ;
    ns1:textoExtracto "Durante el movimiento de un eje, cae la habilitación SPENA de PLC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Durante el movimiento de un eje, cae la habilitación DRENA de PLC." .

ns1:EjeLogico a ns1:ComponenteMecanico ;
    rdfs:label "Eje Lógico" ;
    ns1:textoExtracto "Número lógico del eje." .

