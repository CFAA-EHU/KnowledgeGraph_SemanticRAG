@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalizarLosCodigosDeError a ns1:TareaMantenimiento ;
    rdfs:label "Analizar los códigos de error" ;
    ns1:solucionaFallo ns1:FalloReguladorSercos ;
    ns1:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente" .

ns1:ErrorAlResetearElDriverDeSERCOS a ns1:AccionProhibida ;
    rdfs:label "Error al resetear el driver de SERCOS" ;
    ns1:solucionaFallo ns1:FalloReguladorSercos ;
    ns1:textoExtracto "'Error al resetear el driver de SERCOS'" .

ns1:FalloReguladorSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Errores en el driver de Sercos" ;
    ns1:textoExtracto "Errores en el driver de Sercos. Ver códigos de error descritos en el error 4000." .

