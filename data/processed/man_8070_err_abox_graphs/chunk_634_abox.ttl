ns1:AnalizarCodigosDeErrorParaDeterminarLaFuenteDelProblema a ns1:TareaMantenimiento ;
    rdfs:label "Analizar códigos de error para determinar la fuente del problema" ;
    ns1:solucionaFallo ns1:ErrorEnElAnilloSERCOS ;
    ns1:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error." .

ns1:EjecutarComandoDuranteResetDelCNC a ns1:AccionProhibida ;
    rdfs:label "Ejecutar comando durante reset del CNC" ;
    ns1:textoExtracto "El lazo ejecuta este comando durante el tratamiento de un reset del CNC si el regulador está reportando errores." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica_6bba71596e a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorEnElAnilloSERCOS a ns1:DiagnosticoFallo ;
