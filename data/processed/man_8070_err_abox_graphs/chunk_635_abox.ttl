    ns1:mitigaRiesgo ns1:SistemaCNC8070_0f2bbb8202 ;
    ns1:textoExtracto "'Error en el anillo Sercos (MST perdido)' VALOR Códigos de error que identifican la fuente o fuentes del problema." .

ns1:ErrorEnLaTransmisionDeATsFibraOpticaOReguladorReseteado a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la transmisión de ATs (Fibra óptica o regulador reseteado)" ;
    ns1:textoExtracto "0x00008000 Error en la transmisión de ATs. ( Fibra óptica o regulador reseteado)" .

ns1:ErrorEnReguladorSERCOS a ns1:AvisoSeguridad ;
    rdfs:label "Error en regulador SERCOS" ;
    ns1:mitigaRiesgo ns1:SistemaCNC8070_0f2bbb8202 ;
    ns1:textoExtracto "'Error en regulador SERCOS' EJE Número lógico del eje. CAUSA El regulador reporta error." .

ns1:FalloEnAccesosALaRAMComunDelSERCON a ns1:AvisoSeguridad ;
    rdfs:label "Fallo en accesos a la RAM común del SERCON" ;
    ns1:mitigaRiesgo ns1:SistemaCNC8070_0f2bbb8202 ;
    ns1:textoExtracto "Fallo en accesos a la RAM común del SERCON. CAUSA Error en el bus Sercos que provoca pérdida de fase 4." .

ns1:FaltaDriveStatusReadyDRSTAFDRSTAS a ns1:AvisoSeguridad ;
    rdfs:label "Falta Drive Status Ready (DRSTAF/DRSTAS)" ;
    ns1:mitigaRiesgo ns1:SistemaCNC8070_0f2bbb8202 ;
    ns1:textoExtracto "'Falta Drive Status Ready (DRSTAF/DRSTAS)' DETECCIÓN Durante la ejecución. CAUSA Vigilancia DRSTAF, DRSTAS o del tandem, cuando el eje esta en movimiento." .

ns1:PerdidaDeATs a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de ATs" ;
    ns1:textoExtracto "0x00000100 Pérdida de ATs." .

