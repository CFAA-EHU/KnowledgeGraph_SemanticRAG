@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalizarLosCodigosDeErrorParaIntentarDeterminarLaFuenteDelError a ns1:AccionProhibida ;
    rdfs:label "Analizar los códigos de error para intentar determinar la fuente del error" ;
    ns1:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error. Póngase en contacto con el servicio de asistencia técnica." .

ns1:ComprobarLaParametrizacionEnElCNCYReguladores a ns1:AccionProhibida ;
    rdfs:label "Comprobar la parametrización en el CNC y reguladores" ;
    ns1:textoExtracto "SOLUCIÓN Realizar las siguientes comprobaciones: • Garantizar el buen conexionado e integridad de la fibra óptica. • Comprobar la parametrización en el CNC y reguladores." .

ns1:ComprobarLasSenalesDeHabilitacionYElEstadoDelRegulador a ns1:AccionProhibida ;
    rdfs:label "Comprobar las señales de habilitación y el estado del regulador" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar las señales de habilitación y el estado del regulador." .

ns1:ErrorEnElAnilloSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos" ;
    ns1:textoExtracto "'Error en el anillo Sercos (fibra óptica)' VALOR Códigos de error que identifican la fuente o fuentes del problema." .

ns1:ErrorEnElAnilloSercosFibraOptica a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo Sercos (fibra óptica)" ;
    ns1:mitigaRiesgo ns1:SistemaCNC8070_0f2bbb8202 ;
    ns1:textoExtracto "'Error en el anillo Sercos (fibra óptica)' VALOR Códigos de error que identifican la fuente o fuentes del problema." .

