@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnElAnilloSercos2ATsPerdidos a ns1:Alarma ;
    rdfs:label "'Error en el anillo Sercos (2 ATs perdidos)'" ;
    ns1:textoExtracto "4211 'Error en el anillo Sercos (2 ATs perdidos)' EJE Número lógico del eje." .

ns1:ErrorEnElAnilloSercosMSTPerdido a ns1:Alarma ;
    rdfs:label "'Error en el anillo Sercos (MST perdido)'" ;
    ns1:textoExtracto "4210 'Error en el anillo Sercos (MST perdido)' VALOR Códigos de error que identifican la fuente o fuentes del problema." .

ns1:ModoDeOperacion a ns1:Parametro ;
    rdfs:label "Modo de operación" ;
    ns1:textoExtracto "parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:PotenciaDeSalidaDelServo a ns1:Parametro ;
    rdfs:label "Potencia de salida del servo" ;
    ns1:textoExtracto "parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:SelectorDeNodoDelRegulador a ns1:Parametro ;
    rdfs:label "Selector de nodo del regulador" ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID)" .

ns1:TasaDeActualizacionDelServo a ns1:Parametro ;
    rdfs:label "Tasa de actualización del servo" ;
    ns1:textoExtracto "parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:TiempoDeBucle_8d6a26063b a ns1:Parametro ;
    rdfs:label "Tiempo de bucle" ;
    ns1:textoExtracto "parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:GarantizarLaConectividadATravesDeTodoElAnillo a ns1:AvisoSeguridad ;
    rdfs:label "Garantizar la conectividad a través de todo el anillo" ;
    ns1:mitigaRiesgo ns1:PerdidaDeMSTs ;
    ns1:textoExtracto "SOLUCIÓN Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." .

ns1:PerdidaDeMSTs a ns1:AccionProhibida ;
    rdfs:label "Pérdida de MSTs" ;
    ns1:mitigaRiesgo ns1:GarantizarLaConectividadATravesDeTodoElAnillo ;
    ns1:textoExtracto "0x00000200 Pérdida de MSTs." .

