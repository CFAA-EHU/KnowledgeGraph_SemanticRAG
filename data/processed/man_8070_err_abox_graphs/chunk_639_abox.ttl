    rdfs:label "Error en el anillo Sercos (Escritura de MDT, buffer 0)" ;
    ns1:textoExtracto "'Error en el anillo Sercos (Escritura de MDT, buffer 0)'" .

ns1:ErrorEnElAnilloSercosRecepcionDeMDT a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (Recepción de MDT)" ;
