    ns1:textoExtracto "'Error en búsqueda de I0 de contadora Sercos'" .

ns1:ErrorEnElBusSercosQueProvocaPerdidaDeFase4 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el bus Sercos que provoca pérdida de fase 4" ;
    ns1:textoExtracto "'Error en contadora Sercos'" .

ns1:GarantizarLaConectividadATravesDeTodoElAnilloFibraOpticaMasterYEsclavos a ns1:TareaMantenimiento ;
    rdfs:label "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)" ;
    ns1:textoExtracto "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." .

ns1:LaContadoraReportaError a ns1:DiagnosticoFallo ;
    rdfs:label "La contadora reporta error" ;
    ns1:textoExtracto "'Error en contadora Sercos'" .

ns1:SistemaCNC8070_7780d89e03 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:controla ns1:PongaseEnContactoConFagorAutomation_d966b40a21,
        ns1:RevisarLaConexionDelBusSercosIII_eb510b479b,
        ns1:TareaMantenimientoRevisarConexionBusSercosIII4215 ;
    ns1:textoExtracto "Sistema CNC 8070" .

