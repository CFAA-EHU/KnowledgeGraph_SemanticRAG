ns1:PongaseEnContactoConFagorAutomation_d966b40a21 a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorEnElAnilloSercosSincronismo ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarLaConexionDelBusSercosIII_eb510b479b a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión del bus Sercos III" ;
    ns1:solucionaFallo ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer0_bc36f05ff5 ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III." .

ns1:TareaMantenimientoRevisarConexionBusSercosIII4215 a ns1:TareaMantenimiento ;
    ns1:solucionaFallo ns1:ErrorEnElAnilloSercosRecepcionDeMDT ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III." .

