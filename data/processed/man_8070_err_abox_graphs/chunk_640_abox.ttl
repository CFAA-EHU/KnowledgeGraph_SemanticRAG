@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarLaConexionDelBusSercosIII a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión del bus Sercos III"@es ;
    ns1:solucionaFallo ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer0,
        ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer1 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la conexión del bus Sercos III. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (Escritura de MDT, buffer 0)"@es ;
    ns1:textoExtracto "4217 Error en el anillo Sercos (Escritura de MDT, buffer 0). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer1 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ns1:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o" .

