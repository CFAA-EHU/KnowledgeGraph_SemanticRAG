ns1:RevisarLaConexionDelBusSercosIII_3fab39a85c a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la conexión del bus Sercos III"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_493bfee3d0,
        ns1:DiagnosticoFallo_5199f12b29,
        ns1:DiagnosticoFallo_c11dc7e6b5,
        ns1:DiagnosticoFallo_f08dc63f92,
        ns1:ErrorEnElAnilloSercosEscrituraDeMDTBuffer1 ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:DiagnosticoFallo_493bfee3d0 a ns1:DiagnosticoFallo ;
    rdfs:label "errMSTValidMiss"@es ;
    ns1:textoExtracto "4220 errMSTValidMiss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

