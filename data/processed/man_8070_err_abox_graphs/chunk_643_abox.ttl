@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarSiElCNCArrancoCorrectamente a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar si el CNC arrancó correctamente" ;
    ns1:solucionaFallo ns1:NoSePuedeAccederALasVariablesSercos,
        ns1:VariableSercosNoIdentificada ;
    ns1:textoExtracto "SOLUCIÓN Comprobar si el CNC arrancó correctamente." .

ns1:ComprobarSiElNombreDeLaVariableSercosEsCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar si el nombre de la variable Sercos es correcto" ;
    ns1:solucionaFallo ns1:VariableSercosNoIdentificada ;
    ns1:textoExtracto "SOLUCIÓN Comprobar si el nombre de la variable Sercos es correcto." .

ns1:EliminarDelNombreDeLaVariableElIndicativoDelSet a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar del nombre de la variable el indicativo del set" ;
    ns1:solucionaFallo ns1:LaVariableSercosNoTieneSets ;
    ns1:textoExtracto "SOLUCIÓN Eliminar del nombre de la variable el indicativo del set." .

ns1:IdentificarElComandoQueHaProducidoElErrorYElEsclavoRelacionado a ns1:TareaMantenimiento ;
    rdfs:label "Identificar el comando que ha producido el error y el esclavo relacionado" ;
    ns1:solucionaFallo ns1:ErrorEnComandoMechatrolink_607d23e238 ;
    ns1:textoExtracto "SOLUCIÓN Identificar el comando que ha producido el error y el esclavo relacionado." .

ns1:VerificarLaParametrizacionDeLaComunicacionYLaIntegridadFisicaDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la parametrización de la comunicación y la integridad física del bus" ;
    ns1:solucionaFallo ns1:ErrorEnLaInicializacionDelHwDeMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc) y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:ErrorEnComandoMechatrolink_607d23e238 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en comando Mechatrolink" ;
    ns1:textoExtracto "'Error en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado." .

ns1:ErrorEnLaInicializacionDelHwDeMechatrolink a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del Hw de Mechatrolink" ;
    ns1:textoExtracto "'Error en la inicialización del Hw de Mechatrolink' DETECCIÓN Durante el arranque del CNC. CAUSA No se pudo completar con éxito la fase de inicialización de la comunicación Mechatrolink." .

ns1:LaVariableSercosNoTieneSets a ns1:DiagnosticoFallo ;
    rdfs:label "La variable Sercos no tiene sets" ;
    ns1:textoExtracto "'La variable Sercos no tiene sets' DETECCIÓN En el osciloscopio. CAUSA En un canal del osciloscopio hay definida una variable Sercos, en cuya sintaxis se indica el set pero la variable no tiene sets." .

ns1:NoSePuedeAccederALasVariablesSercos a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede acceder a las variables Sercos" ;
    ns1:textoExtracto "4301 No se puede acceder a las variables Sercos. DETECCIÓN Desde el interface. CAUSA Desde el interface se ha pedido una variable de regulador Sercos, pero el servidor de variables no ha sido inicializado correctamente y no puede acceder a la información de las variables Sercos." .

ns1:VariableSercosNoIdentificada a ns1:DiagnosticoFallo ;
    rdfs:label "Variable Sercos no identificada" ;
    ns1:textoExtracto "4302 Variable Sercos no identificada. DETECCIÓN Desde el interface. CAUSA Desde el interface se ha pedido una variable de regulador Sercos, pero la variable es desconocida." .

