@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnComandoMechatrolink a ns1:AccionProhibida ;
    rdfs:label "Error en comando Mechatrolink" ;
    ns1:solucionadoPor ns1:IdentificarComandoProblematicoYVerificarCondiciones ;
    ns1:textoExtracto "'Error en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC." .

ns1:TimeOutEnLaInicializacionDe a ns1:DiagnosticoFallo ;
    rdfs:label "Time out en la inicialización de" ;
    ns1:textoExtracto "'Time out en la inicialización de" .

ns1:IdentificarComandoProblematicoYVerificarCondiciones a ns1:TareaMantenimiento ;
    rdfs:label "Identificar comando problemático y verificar condiciones" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Identificar el comando que ha producido el error y el esclavo relacionado. Verificar, si las hubiera, las condiciones para que el comando pueda completarse con éxito (estado del regulador, alimentación, potencia, conexionado del motor, etc)." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Personal Técnico Autorizado" .

