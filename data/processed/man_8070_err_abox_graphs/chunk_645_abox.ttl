@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entity4502TimeOutEnLaInicializacionDeMechatrolink a ns1:Alarma ;
    rdfs:label "4502 'Time out en la inicialización de Mechatrolink'"@es ;
    ns1:textoExtracto "'Time out en la inicialización de Mechatrolink' DETECCIÓN Durante el arranque del CNC." .

ns1:IdentificarYConsultarAlarmaMechatrolink a ns1:AvisoSeguridad ;
    rdfs:label "Identificar y consultar alarma Mechatrolink"@es ;
    ns1:mitigaRiesgo ns1:EjecucionDeComandoMechatrolinkQueProvocaAlarma ;
    ns1:textoExtracto "Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:IdentificarYConsultarWarningMechatrolink a ns1:AvisoSeguridad ;
    rdfs:label "Identificar y consultar warning Mechatrolink"@es ;
    ns1:mitigaRiesgo ns1:EjecucionDeComandoMechatrolinkQueProvocaWarning ;
    ns1:textoExtracto "Identificar el código del warning reportado y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:RevisarHardwareYIntegridadFisicaDelBus a ns1:AvisoSeguridad ;
    rdfs:label "Revisar hardware y integridad física del bus"@es ;
    ns1:mitigaRiesgo ns1:FalloEnElTrasvaseDeInformacionCiclicaMechatrolink ;
    ns1:textoExtracto "Revisar el hardware del master y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:VerificarParametrizacionYIntegridadFisicaDelBus a ns1:AvisoSeguridad ;
    rdfs:label "Verificar parametrización y integridad física del bus"@es ;
    ns1:mitigaRiesgo ns1:IntegridadFisicaDelBusIncorrecta,
        ns1:ParametrizacionIncorrectaDeLaComunicacionMechatrolink ;
    ns1:textoExtracto "Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc) y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:VerificarPotenciaEnEsclavosMechatrolink a ns1:AvisoSeguridad ;
    rdfs:label "Verificar potencia en esclavos Mechatrolink"@es ;
    ns1:mitigaRiesgo ns1:FaltaDePotenciaEnEsclavoMechatrolink ;
    ns1:textoExtracto "Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia." .

ns1:EjecucionDeComandoMechatrolinkQueProvocaAlarma a ns1:AccionProhibida ;
    rdfs:label "Ejecución de comando Mechatrolink que provoca alarma"@es ;
    ns1:textoExtracto "La ejecución de un comando Mechatrolink desde el master a un determinado esclavo provoca una situación de alarma en dicho dispositivo." .

ns1:EjecucionDeComandoMechatrolinkQueProvocaWarning a ns1:AccionProhibida ;
    rdfs:label "Ejecución de comando Mechatrolink que provoca warning"@es ;
    ns1:textoExtracto "La ejecución de un comando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo." .

ns1:FalloEnElTrasvaseDeInformacionCiclicaMechatrolink a ns1:AccionProhibida ;
    rdfs:label "Fallo en el trasvase de información cíclica Mechatrolink"@es ;
    ns1:textoExtracto "Fallo en el trasvase de información cíclica entre el master Mechatrolink y algún esclavo." .

ns1:FaltaDePotenciaEnEsclavoMechatrolink a ns1:AccionProhibida ;
    rdfs:label "Falta de potencia en esclavo Mechatrolink"@es ;
    ns1:textoExtracto "Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia." .

ns1:IntegridadFisicaDelBusIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Integridad física del bus incorrecta"@es ;
    ns1:textoExtracto "y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:ParametrizacionIncorrectaDeLaComunicacionMechatrolink a ns1:AccionProhibida ;
    rdfs:label "Parametrización incorrecta de la comunicación Mechatrolink"@es ;
    ns1:textoExtracto "Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc)" .

