@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDelConexionadoDePotencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del conexionado de potencia" ;
    ns1:solucionaFallo ns1:FaltaPotenciaEnEsclavoMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los" .

ns1:FaltaPotenciaEnEsclavoMechatrolink a ns1:DiagnosticoFallo ;
    rdfs:label "Falta potencia en esclavo Mechatrolink" ;
    ns1:textoExtracto "'Falta potencia en esclavo Mechatrolink' DETECCIÓN Durante la ejecución del CNC, una vez que ha entrado en estado de movimiento interpolado." .

