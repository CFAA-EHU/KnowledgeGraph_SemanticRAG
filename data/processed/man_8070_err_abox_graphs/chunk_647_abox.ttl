@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionContactarFagor a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorInicializacionHardware ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:SolucionIdentificarCodigoAlarma a ns1:TareaMantenimiento ;
    rdfs:label "Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica" ;
    ns1:solucionaFallo ns1:AlarmaEnSubcomandoMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:SolucionIdentificarCodigoWarning a ns1:TareaMantenimiento ;
    rdfs:label "Identificar el código del warning reportado y consultar el manual del esclavo Mechatrolink para obtener información más específica" ;
    ns1:solucionaFallo ns1:AvisoEnSubcomandoMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Identificar el código del warning reportado y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:SolucionRevisarCableado a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración" ;
    ns1:solucionaFallo ns1:ErrorConexionNodos ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ns1:SolucionRevisarCableadoConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración" ;
    ns1:solucionaFallo ns1:ErrorConfiguracionBus ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ns1:SolucionRevisarCableadoDeteccion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración" ;
    ns1:solucionaFallo ns1:ErrorDeteccionNodos ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ns1:SolucionRevisarConexionado a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los reguladores" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los reguladores." .

ns1:AlarmaEnSubcomandoMechatrolink a ns1:Alarma ;
    rdfs:label "Alarma en subcomando Mechatrolink" ;
    ns1:textoExtracto "'Alarma en subcomando Mechatrolink' DETECCIÓN Durante la ejecución del CNC." .

ns1:AvisoEnSubcomandoMechatrolink a ns1:Alarma ;
    rdfs:label "Aviso en subcomando Mechatrolink" ;
    ns1:textoExtracto "'Aviso en subcomando Mechatrolink' DETECCIÓN Durante la ejecución del CNC." .

ns1:ErrorConexionNodos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la conexión de nodos del bus" ;
    ns1:textoExtracto "4601 Error en la conexión de nodos del bus. DETECCIÓN Durante el arranque del CNC." .

ns1:ErrorConfiguracionBus a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la fase de configuración del bus" ;
    ns1:textoExtracto "4603 Error en la fase de configuración del bus. DETECCIÓN Durante el arranque del CNC." .

ns1:ErrorDeteccionNodos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la detección de nodos" ;
    ns1:textoExtracto "4602 Error en la detección de nodos. DETECCIÓN Durante el arranque del CNC." .

ns1:ErrorInicializacionHardware a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del hardware del bus" ;
    ns1:textoExtracto "4600 Error en la inicialización del hardware del bus. DETECCIÓN Durante el arranque del CNC." .

