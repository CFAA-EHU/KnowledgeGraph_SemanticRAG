@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnLaFaseDeConfiguracionDelBus a ns1:AccionProhibida ;
    rdfs:label "Error en la fase de configuración del bus" ;
    ns1:solucionaFallo ns1:ErrorInternoDuranteLaFaseDeConfiguracionDeEsclavosConectadosAlBus ;
    ns1:textoExtracto "4603 Error en la fase de configuración del bus." .

ns1:RevisarElCableadoConexionadoYAlimentacionDeLosEsclavos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cableado, conexionado y alimentación de los esclavos" ;
    ns1:solucionaFallo ns1:ErrorInternoDuranteLaFaseDeConfiguracionDeEsclavosConectadosAlBus ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos." .

ns1:ErrorInternoDuranteLaFaseDeConfiguracionDeEsclavosConectadosAlBus a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno durante la fase de configuración de esclavos conectados al bus" ;
    ns1:textoExtracto "Se ha producido un error interno durante la fase de configuración de esclavos conectados al bus." .

