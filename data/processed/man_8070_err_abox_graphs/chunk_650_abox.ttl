@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetachMasterSinExportarENI a ns1:AccionProhibida ;
    rdfs:label "Detach Master sin exportar ENI" ;
    ns1:textoExtracto "Realizar un \"Detach Master\" en el configurador KPA antes de exportar el fichero ENI." .

ns1:Error4606EnComandoDePreparacionDelBus a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4606 en comando de preparación del bus" ;
    ns1:textoExtracto "4606 Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la preparación de los parámetros del bus SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:PongaseEnContactoConFagorAutomation_ed018e8abc a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error se repite, póngase en contacto con Fagor Automation." .

