@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_501a0e57cb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af ;
    ns1:textoExtracto "CNC 8070" .

ns1:CorregirLaConfiguracionDelBusSimulado a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la configuración del bus simulado" ;
    ns1:solucionaFallo ns1:ErrorBusNumeroDeNodosDetectadosIncorrectos_904373d920,
        ns1:ErrorNodeModuleSinDefinir_0eb614a086 ;
    ns1:textoExtracto "Corregir la configuración del bus simulado. Si no hay bus simulado, póngase en contacto con Fagor Automation." .

ns1:RevisarCableadoYAlimentacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar cableado y alimentación" ;
    ns1:solucionaFallo ns1:ErrorBusTimeout_d1dd51ee96 ;
    ns1:textoExtracto "Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ns1:RevisarConexionesDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisar conexiones del CNC" ;
    ns1:textoExtracto "Revisar el apartado conexiones del CNC y comprobar que existen todas las conexiones que se van a utilizar." .

ns1:ErrorBusIndefinido_f6e361196f a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus indefinido" ;
    ns1:textoExtracto "4614 Error bus indefinido. DETECCIÓN Durante el arranque del CNC, durante la ejecución o tras un reset. CAUSA Se ha producido un error inesperado en el bus Sercos III." .

ns1:ErrorBusNumeroDeNodosDetectadosIncorrectos_904373d920 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus número de nodos detectados incorrectos" ;
    ns1:textoExtracto "4613 Error bus número de nodos detectados incorrectos. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de detección de nodos en el bus. SOLUCIÓN Corregir la configuración del bus simulado." .

ns1:ErrorBusTimeout_d1dd51ee96 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus timeout" ;
    ns1:textoExtracto "4615 Error bus timeout. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error de timeout durante el arranque o reset del bus de comunicaciones." .

ns1:ErrorDeConfiguracionDelNumeroDeSerie_d4aeb2153a a ns1:DiagnosticoFallo ;
    rdfs:label "Error de configuración del número de serie" ;
    ns1:textoExtracto "4630 Error de configuración del número de serie. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error en la lectura de los números de serie de un nodo Sercos III o números de serie incorrectos." .

ns1:ErrorNodeModuleSinDefinir_0eb614a086 a ns1:DiagnosticoFallo ;
    rdfs:label "Error Node Module sin definir" ;
    ns1:textoExtracto "4616 Error Node Module sin definir. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de detección de nodos en el bus." .

ns1:NombreDeConexionNoEncontrado_9c831f263c a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de conexión no encontrado" ;
    ns1:textoExtracto "4631 Nombre de conexión no encontrado. DETECCIÓN Durante el arranque del CNC, la validación de parámetros máquina o tras un reset. CAUSA La conexión especificada en el parámetro no existe." .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorBusIndefinido_f6e361196f,
        ns1:ErrorDeConfiguracionDelNumeroDeSerie_d4aeb2153a,
        ns1:NombreDeConexionNoEncontrado_9c831f263c ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

