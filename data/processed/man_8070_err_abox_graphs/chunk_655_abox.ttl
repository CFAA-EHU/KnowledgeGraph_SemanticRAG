@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConFagorAutomation_a7b0183b99 a ns1:AvisoSeguridad ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:mitigaRiesgo ns1:FalloDatosHardwareNoEncontrados,
        ns1:FalloErrorComunicacionNodo,
        ns1:FalloNodoHardwareIdDesconocido,
        ns1:FalloNodoNoDefinido,
        ns1:FalloNodoNoDetectado,
        ns1:FalloNodoNoEncontradoTopologia,
        ns1:FalloNumeroSerieNodoError ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation." .

ns1:FalloDatosHardwareNoEncontrados a ns1:DiagnosticoFallo ;
    rdfs:label "Datos hardware no encontrados" ;
    ns1:textoExtracto "4636 Datos hardware no encontrados. DETECCIÓN Durante el arranque del CNC." .

ns1:FalloErrorComunicacionNodo a ns1:DiagnosticoFallo ;
    rdfs:label "Error en comunicación con nodo" ;
    ns1:textoExtracto "4633 Error en comunicación con nodo. DETECCIÓN Durante el arranque del CNC o tras un reset." .

ns1:FalloNodoHardwareIdDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Node hardware id desconocido" ;
    ns1:textoExtracto "4632 Node hardware id desconocido. DETECCIÓN Durante el arranque del CNC." .

ns1:FalloNodoNoDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Nodo no definido" ;
    ns1:textoExtracto "4635 Nodo no definido. DETECCIÓN Durante el arranque del CNC, durante la ejecución o tras un reset." .

ns1:FalloNodoNoDetectado a ns1:DiagnosticoFallo ;
    rdfs:label "Nodo no detectado" ;
    ns1:textoExtracto "4638 Nodo no detectado. DETECCIÓN Durante el arranque del CNC." .

ns1:FalloNodoNoEncontradoTopologia a ns1:DiagnosticoFallo ;
    rdfs:label "Nodo no encontrado en topología" ;
    ns1:textoExtracto "4634 Nodo no encontrado en topología. DETECCIÓN Durante el arranque del CNC." .

ns1:FalloNumeroSerieNodoError a ns1:DiagnosticoFallo ;
    rdfs:label "Error en número de serie de nodo" ;
    ns1:textoExtracto "4637 Error en número de serie de nodo. DETECCIÓN Durante el arranque del CNC." .

