ex:Error_8243
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8243: 'I doblemente programada'"@es ;
    ex:identificador "8243" ;
    ex:textoExtracto "'I doblemente programada' DETECCIÓN Durante la edición. CAUSA El parámetro I está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro I una sola vez en el bloque."@es ;
    ex:solucionaFallo ex:Parametro_I_Duplicado_8243 .

