@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8247
    a ex:AvisoSeguridad ;
    rdfs:label "Sólo R1 puede formar parte de expresiones" ;
    ex:identificador "8247" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA La programación del radio es incorrecta. SOLUCIÓN El radio sólo se puede programar mediante \"R\" o \"R1\"." .

ex:AvisoSeguridad_8250
    a ex:AvisoSeguridad ;
    rdfs:label "Variable de eje sin permiso de escritura" ;
    ex:identificador "8250" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ex:AvisoSeguridad_8251
    a ex:AvisoSeguridad ;
    rdfs:label "Variable global sin permiso de escritura" ;
    ex:identificador "8251" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ex:AvisoSeguridad_8253
    a ex:AvisoSeguridad ;
    rdfs:label "Faltan ejes en G20" ;
    ex:identificador "8253" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA No se han programado todos los parámetros obligatorios en la función G20. SOLUCIÓN Revisar la sintaxis de programación de la función G20." .

ex:AvisoSeguridad_8254
    a ex:AvisoSeguridad ;
    rdfs:label "Sobran ejes en G20" ;
    ex:identificador "8254" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Algunos de los parámetros programados para la función G20 no están permitidos. SOLUCIÓN Revisar la sintaxis de programación de la función G20." .

ex:AvisoSeguridad_8256
    a ex:AvisoSeguridad ;
    rdfs:label "Instrucción de ciclo de interpolador inexistente" ;
    ex:identificador "8256" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La instrucción programada no existe. SOLUCIÓN Revisar el manual de programación." .

ex:AvisoSeguridad_8257
    a ex:AvisoSeguridad ;
    rdfs:label "No puede haber nada después del nombre del programa o subrutina" ;
    ex:identificador "8257" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA En el nombre del programa principal o de la subrutina hay un carácter incorrecto. SOLUCIÓN La definición del nombre del programa principal o subrutina tan solo puede ir acompañada de comentario. Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco. • Subrutina local: / ? \" < > | ) y espacio en blanco." .

ex:AvisoSeguridad_K_DoblementeProgramada
    a ex:AvisoSeguridad ;
    rdfs:label "'K doblemente programada'" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA El parámetro K está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro K una sola vez en el bloque." .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K" ;
    ex:textoExtracto "El parámetro K está programado más de una vez en el bloque." .

ex:Parametro_R1
    a ex:Parametro ;
    rdfs:label "Parámetro R1" ;
    ex:textoExtracto "El radio sólo se puede programar mediante \"R\" o \"R1\"." .

ex:Funcion_G20 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G20" ;
    ex:textoExtracto "Revisar la sintaxis de programación de la función G20." .