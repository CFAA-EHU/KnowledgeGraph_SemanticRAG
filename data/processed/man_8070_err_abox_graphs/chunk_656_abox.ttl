@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizarTopologia a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar topología" ;
    ns1:solucionaFallo ns1:NodoNoDetectado ;
    ns1:textoExtracto "SOLUCIÓN Actualizar la topología de acuerdo con los nodos conectados (eliminar nodo de la topología) o revisar cableado, conexionado y alimentación de los esclavos del bus." .

ns1:PongaseEnContactoConFagorAutomation_96d21b5e90 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarCableado a ns1:TareaMantenimiento ;
    rdfs:label "Revisar cableado" ;
    ns1:solucionaFallo ns1:NodoNoDetectado ;
    ns1:textoExtracto "SOLUCIÓN Actualizar la topología de acuerdo con los nodos conectados (eliminar nodo de la topología) o revisar cableado, conexionado y alimentación de los esclavos del bus." .

ns1:NodoNoDetectado a ns1:DiagnosticoFallo ;
    rdfs:label "Nodo no detectado" ;
    ns1:textoExtracto "4638 Nodo no detectado. DETECCIÓN Durante el arranque del CNC. CAUSA No se ha detectado un nodo de la topología durante el arranque del CNC." .

