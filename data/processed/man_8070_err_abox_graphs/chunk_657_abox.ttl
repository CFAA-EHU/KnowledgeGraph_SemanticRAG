@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AccionProhibida_ProgramaPrincipal
    a ex:AccionProhibida ;
    rdfs:label "Uso de caracteres prohibidos en nombre de programa principal"@es ;
    ex:textoExtracto "Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco."@es ;
    ex:identificador "\\ / : * ? \" < > |" .

ex:AccionProhibida_SubrutinaLocal
    a ex:AccionProhibida ;
    rdfs:label "Uso de caracteres prohibidos en nombre de subrutina local"@es ;
    ex:textoExtracto "Subrutina local: / ? \" < > | ) y espacio en blanco."@es ;
    ex:identificador "/ ? \" < > | )" .

ex:AvisoSeguridad_8258
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8258: 'Se esperaba expresión tras #TIME'"@es ;
    ex:identificador "8258" ;
    ex:textoExtracto "'Se esperaba expresión tras #TIME' [...] SOLUCIÓN Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde"@es .