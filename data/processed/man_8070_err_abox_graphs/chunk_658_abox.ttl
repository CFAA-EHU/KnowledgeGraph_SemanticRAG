@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8265
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8265: Palabra desconocida o incompleta" ;
    ex:textoExtracto "8265 'Palabra desconocida o incompleta' [...] Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." ;
    ex:identificador "8265" .

ex:Error_8267
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8267: Variable de ciclo sin permiso de escritura" ;
    ex:textoExtracto "8267 'Variable de ciclo sin permiso de escritura' [...] La variable es de solo lectura." ;
    ex:identificador "8267" .

ex:Error_8268
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8268: Argumento fuera de límites en función" ;
    ex:textoExtracto "8268 'Argumento fuera de límites en función' [...] Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." ;
    ex:identificador "8268" .

ex:Error_8269
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8269: Rebasamiento por encima en función" ;
    ex:textoExtracto "8269 'Rebasamiento por encima en función' [...] Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." ;
    ex:identificador "8269" .

ex:Error_8270
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8270: Pérdida parcial de función" ;
    ex:textoExtracto "8270 'Pérdida parcial de función' [...] Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." ;
    ex:identificador "8270" .

ex:Error_8271
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8271: Argumento no permitido en función" ;
    ex:textoExtracto "8271 'Argumento no permitido en función' [...]" ;
    ex:identificador "8271" .

ex:Sentencia_TIME
    a ex:Parametro ;
    rdfs:label "Sentencia #TIME" ;
    ex:textoExtracto "Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde el parámetro <time> puede ser un número entero, un parámetro aritmético o una variable." ;
    ex:identificador "#TIME" .

ex:Funcion_TOOL_AX a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Sentencia #TOOL AX" ;
    ex:textoExtracto "Programación incorrecta de la sentencia #TOOL AX." ;
    ex:identificador "#TOOL AX" .

ex:FuncionesMatematicas a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Funciones matemáticas (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)" ;
    ex:textoExtracto "Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." ;
    ex:identificador "LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN" .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." .