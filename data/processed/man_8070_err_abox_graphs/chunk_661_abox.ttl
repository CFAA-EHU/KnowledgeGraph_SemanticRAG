ex:Alarma_8279
    a ex:Alarma ;
    rdfs:label "Imagen espejo repetida" ;
    ex:identificador "8279" ;
    ex:textoExtracto "8279 'Imagen espejo repetida' DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque. La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque." ;
    ex:solucionaFallo ex:DiagnosticoFallo_8279 .

ex:DiagnosticoFallo_8279
    a ex:DiagnosticoFallo ;
    ex:textoExtracto "Las funciones G11, G12 y G13 se pueden combinar en un mismo bloque pero cada una de ellas sólo se puede programar una vez. La funciones G10 y G14 no se pueden programar en el mismo bloque que la G11, G12 o G13." .

ex:Alarma_8280
    a ex:Alarma ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ex:identificador "8280" ;
    ex:textoExtracto "8280 'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad" .