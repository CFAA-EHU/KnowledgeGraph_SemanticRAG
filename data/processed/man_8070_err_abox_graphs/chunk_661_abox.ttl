@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_7b06ee2e2d a ns1:DiagnosticoFallo ;
    rdfs:label "Encóder digital no soportado" ;
    ns1:textoExtracto "4675 Encóder digital no soportado. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un encóder digital no soportado o con protocolo digital no soportado." .

ns1:ErrorConfigurandoReferencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error configurando referencia" ;
    ns1:textoExtracto "4680 Error configurando referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la configuración de una referencia." .

ns1:ErrorDeComunicacionesConReferencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicaciones con referencia" ;
    ns1:textoExtracto "4681 Error de comunicaciones con referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error de comunicación con una referencia." .

ns1:ErrorDeIdentificacionDeReferencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error de identificación de referencia" ;
    ns1:textoExtracto "4682 Error de identificación de referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado una referencia no soportada." .

ns1:ErrorEnLaActualizacionDeSWDeLosDispositivosPwCConectadosAlBus a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos PwC conectados al bus" ;
    ns1:textoExtracto "4683 Error en la actualización de SW de los dispositivos PwC conectados al bus. DETECCIÓN Durante la ejecución. CAUSA La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo." .

ns1:ErrorLeyendoLosParametrosDelEncoderDigital a ns1:DiagnosticoFallo ;
    rdfs:label "Error leyendo los parámetros del encóder digital" ;
    ns1:textoExtracto "4674 Error leyendo los parámetros del encóder digital. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante la lectura de parámetros de un encóder digital o los datos leídos no son correctos." .

ns1:SWDeReguladorAsociadoALaReferenciaNoCoincideConElTipoDeMotorConectado a ns1:DiagnosticoFallo ;
    rdfs:label "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado" ;
    ns1:textoExtracto "4684 SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." .

