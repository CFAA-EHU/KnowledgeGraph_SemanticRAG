@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioEnLosTiposDeMotorOFuenteRPS a ns1:AccionProhibida ;
    rdfs:label "Cambio en los tipos de motor o fuente RPS" ;
    ns1:textoExtracto "DETECCIÓN Durante la puesta en marcha, asignación de conexiones y/o cambio en los tipos de motor o fuente RPS." .

ns1:IdentificarCodigoDelWarningEnElManualDelEsclavoMechatrolink a ns1:AccionProhibida ;
    rdfs:label "Identificar código del warning en el manual del esclavo Mechatrolink" ;
    ns1:mitigaRiesgo ns1:CodigoDeWarning4684 ;
    ns1:textoExtracto "SOLUCIÓN Identificar el código del warning en el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:CodigoDeWarning4684 a ns1:DiagnosticoFallo ;
    rdfs:label "Código de warning 4684" ;
    ns1:textoExtracto "4684 SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." .

