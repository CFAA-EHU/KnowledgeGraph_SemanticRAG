@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoSeEncuentraUnaVariableDeBus a ns1:DiagnosticoFallo ;
    rdfs:label "No se encuentra una variable de bus" ;
    ns1:textoExtracto "CAUSA La variable de bus no se ha definido correctamente." .

ns1:RevisarLaDefinicionDeLaReferenciaYElIdentificadorDelNodo a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la definición de la referencia y el identificador del nodo" ;
    ns1:solucionaFallo ns1:NoSeEncuentraElFeedbackDelEje,
        ns1:NoSeEncuentraLaReferenciaDelEje ;
    ns1:textoExtracto "SOLUCIÓN Revisar la definición de la referencia y el identificador del nodo." .

ns1:ValidarTopologia a ns1:TareaMantenimiento ;
    rdfs:label "Validar topología" ;
    ns1:solucionaFallo ns1:NoCoincideConElTipoDeMotorConectado ;
    ns1:textoExtracto "SOLUCIÓN Validar la topología." .

ns1:NoCoincideConElTipoDeMotorConectado a ns1:DiagnosticoFallo ;
    rdfs:label "No coincide con el tipo de motor conectado" ;
    ns1:textoExtracto "El tipo motor conectado a la referencia no coincide con el tipo de control del regulador asociado." .

ns1:NoSeEncuentraElFeedbackDelEje a ns1:DiagnosticoFallo ;
    rdfs:label "No se encuentra el feedback del eje" ;
    ns1:textoExtracto "CAUSA El feedback del eje no se ha definido correctamente (identificador del nodo)." .

ns1:NoSeEncuentraLaReferenciaDelEje a ns1:DiagnosticoFallo ;
    rdfs:label "No se encuentra la referencia del eje" ;
    ns1:textoExtracto "CAUSA No se ha definido correctamente la referencia del eje (identificador del nodo)." .

