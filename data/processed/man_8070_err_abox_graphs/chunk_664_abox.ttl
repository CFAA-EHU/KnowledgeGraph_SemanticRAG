@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarTopologiaBusYLasConexiones a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar topología bus y las conexiones" ;
    ns1:solucionaFallo ns1:FicheroDeConfiguracionDelBusErroneo ;
    ns1:textoExtracto "SOLUCIÓN Comprobar topología bus y las conexiones." .

ns1:ElNodoTieneProblemasDeComunicacionConElNodoAnterior a ns1:DiagnosticoFallo ;
    rdfs:label "El nodo tiene problemas de comunicación con el nodo anterior" ;
    ns1:textoExtracto "4709 El nodo tiene problemas de comunicación con el nodo anterior. DETECCIÓN Durante el arranque del CNC." .

ns1:EliminarNodosEnLaParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar nodos en la parametrización" ;
    ns1:solucionaFallo ns1:SuperadoMaximoNumeroDeNodos ;
    ns1:textoExtracto "SOLUCIÓN Eliminar nodos en la parametrización." .

ns1:EnDiagnosisSePuedeComprobarLasOpcionesDeSoftwareActivas a ns1:TareaMantenimiento ;
    rdfs:label "En diagnosis se puede comprobar las opciones de software activas" ;
    ns1:solucionaFallo ns1:TipoDeNodoNoPermitido ;
    ns1:textoExtracto "SOLUCIÓN En diagnosis se puede comprobar las opciones de software activas." .

ns1:RevisarLaDefinicionDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la definición de la variable" ;
    ns1:solucionaFallo ns1:LaVariableDeBusNoSeHaDefinidoCorrectamente ;
    ns1:textoExtracto "SOLUCIÓN Revisar la definición de la variable." .

ns1:FicheroDeConfiguracionDelBusErroneo a ns1:DiagnosticoFallo ;
    rdfs:label "Fichero de configuración del bus erróneo" ;
    ns1:textoExtracto "4708 Fichero de configuración del bus erróneo. DETECCIÓN Durante el arranque del CNC. CAUSA La topología real del bus no coincide con el archivo de configuración." .

ns1:LaVariableDeBusNoSeHaDefinidoCorrectamente a ns1:DiagnosticoFallo ;
    rdfs:label "La variable de bus no se ha definido correctamente" ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA La variable de bus no se ha definido correctamente." .

ns1:SuperadoMaximoNumeroDeNodos a ns1:DiagnosticoFallo ;
    rdfs:label "Superado máximo número de nodos" ;
    ns1:textoExtracto "4707 Superado máximo número de nodos. DETECCIÓN Durante el arranque o la validación de parámetros máquina. CAUSA Hay definidos más nodos que los permitidos." .

ns1:TipoDeNodoNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de nodo no permitido" ;
    ns1:textoExtracto "4706 Tipo de nodo no permitido. DETECCIÓN Durante la detección nodos bus. CAUSA El control no dispone de la opción de software necesaria para inicializar ese tipo de nodo." .

