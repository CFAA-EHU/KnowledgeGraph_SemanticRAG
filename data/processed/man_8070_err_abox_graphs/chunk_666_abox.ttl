@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarElNumeroDelContador a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el número del contador" ;
    ns1:solucionaFallo ns1:ErrorDePLCNoExisteContador ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el número del contador; contadores válidos, T1 a T256." .

ns1:ComprobarElNumeroDelTemporizador a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el número del temporizador" ;
    ns1:solucionaFallo ns1:ErrorDePLCNoExisteTemporizador ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el número del temporizador; temporizadores válidos, T1 a T256." .

ns1:ComprobarLosPermisosDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar los permisos de la variable" ;
    ns1:solucionaFallo ns1:VariableSinPermisoDeEscrituraParaPLC,
        ns1:VariableSinPermisoDeLecturaParaPLC ;
    ns1:textoExtracto "SOLUCIÓN Comprobar los permisos de la variable." .

ns1:VerificarLaSintaxisDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la sintaxis de la variable" ;
    ns1:solucionaFallo ns1:CNCRDVariableNoIdentificada ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable. Si el error se produce durante el arranque, condicionar la lectura de la variable a que la marca SERCOSRDY esté activa." .

ns1:VerificarLaSintaxisDeLaVariableYLosValoresValidos a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la sintaxis de la variable y los valores válidos" ;
    ns1:solucionaFallo ns1:EscrituraDeVariableDesdePLCFueraDeRango_bbc3d0c28c ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable y los valores válidos." .

ns1:VerificarLaSintaxisDeLaVariable_6eae3714f4 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la sintaxis de la variable" ;
    ns1:solucionaFallo ns1:CNCWRVariableNoIdentificada ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable." .

ns1:CNCRDVariableNoIdentificada a ns1:DiagnosticoFallo ;
    rdfs:label "CNCRD: Variable no identificada" ;
    ns1:textoExtracto "'CNCRD: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe." .

ns1:CNCWRVariableNoIdentificada a ns1:DiagnosticoFallo ;
    rdfs:label "CNCWR: Variable no identificada" ;
    ns1:textoExtracto "'CNCWR: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA La variable no existe." .

ns1:ErrorDePLCNoExisteContador a ns1:DiagnosticoFallo ;
    rdfs:label "Error de PLC: No existe contador" ;
    ns1:textoExtracto "'Error de PLC: No existe contador' DETECCIÓN Procesos de lectura de los datos de contadores de PLC. CAUSA Petición de lectura de un contador que no existe." .

ns1:ErrorDePLCNoExisteTemporizador a ns1:DiagnosticoFallo ;
    rdfs:label "Error de PLC: No existe temporizador" ;
    ns1:textoExtracto "'Error de PLC: No existe temporizador' DETECCIÓN Procesos de lectura de los datos de temporizadores de PLC. CAUSA Petición de lectura de un temporizador que no existe." .

ns1:EscrituraDeVariableDesdePLCFueraDeRango_bbc3d0c28c a ns1:DiagnosticoFallo ;
    rdfs:label "Escritura de variable desde PLC fuera de rango" ;
    ns1:textoExtracto "'Escritura de variable desde PLC fuera de rango' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA El valor asignado a la variable no es válido." .

ns1:VariableSinPermisoDeEscrituraParaPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Variable sin permiso de escritura para PLC" ;
    ns1:textoExtracto "'Variable sin permiso de escritura para PLC' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA Escritura de una variable que no tiene permiso de escritura desde el PLC." .

ns1:VariableSinPermisoDeLecturaParaPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Variable sin permiso de lectura para PLC" ;
    ns1:textoExtracto "'Variable sin permiso de lectura para PLC' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de una variable que no tiene permiso de lectura desde el PLC." .

