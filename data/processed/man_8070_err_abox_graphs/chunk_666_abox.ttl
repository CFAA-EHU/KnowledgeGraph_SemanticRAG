@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8302
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8302: Coordenada X mínima mayor/igual que máxima" ;
    ex:textoExtracto "'La coordenada X mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada X mínima es mayor o igual que la máxima." ;
    ex:identificador "8302" .

ex:Error_8303
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8303: Coordenada Y mínima mayor/igual que máxima" ;
    ex:textoExtracto "'La coordenada Y mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada Y mínima es mayor o igual que la máxima." ;
    ex:identificador "8303" .

ex:Error_8304
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8304: Coordenada Z mínima mayor/igual que máxima" ;
    ex:textoExtracto "'La coordenada Z mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada Z mínima es mayor o igual que la máxima." ;
    ex:identificador "8304" .

ex:Error_8306
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8306: G201 requiere sentencia #AXIS" ;
    ex:textoExtracto "'G201 precisa la programación de la función especial #AXIS' DETECCIÓN Durante la edición. CAUSA No se ha programado la sentencia #AXIS en el mismo bloque que la función G201." ;
    ex:identificador "8306" .

ex:Error_8307
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8307: Programación incorrecta del tercer eje primario" ;
    ex:textoExtracto "'Programación incorrecta del tercer eje primario' DETECCIÓN Durante la edición. CAUSA En la sentencia G20, el parámetro 5 es igual que el 1 o el 2." ;
    ex:identificador "8307" .

ex:Error_8308
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8308: Sintaxis incorrecta en G04" ;
    ex:textoExtracto "'Se esperaba expresión o K expresión tras G04' DETECCIÓN Durante la edición. CAUSA Función G4 mal programada." ;
    ex:identificador "8308" .

ex:Error_8309
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8309: Exceso de ejes programados" ;
    ex:textoExtracto "'Demasiados ejes programados' DETECCIÓN Durante la edición." ;
    ex:identificador "8309" .

ex:Funcion_G170 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G170" ;
    ex:textoExtracto "función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157." ;
    ex:identificador "G170" .

ex:Funcion_G171 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G171" ;
    ex:textoExtracto "función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157." ;
    ex:identificador "G171" .

ex:Funcion_G157 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G157" ;
    ex:textoExtracto "función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157." ;
    ex:identificador "G157" .

ex:Funcion_G201 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G201" ;
    ex:textoExtracto "'G201 precisa la programación de la función especial #AXIS' DETECCIÓN Durante la edición." ;
    ex:identificador "G201" .

ex:Sentencia_AXIS
    a ex:Parametro ;
    rdfs:label "Sentencia #AXIS" ;
    ex:textoExtracto "La función G201 exige la programación en el mismo bloque de la sentencia #AXIS. En esta sentencia se deben indicar que ejes se ven afectados por la función G." ;
    ex:identificador "#AXIS" .

ex:Funcion_G20 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G20" ;
    ex:textoExtracto "En la sentencia G20, el parámetro 5 es igual que el 1 o el 2." ;
    ex:identificador "G20" .

ex:Funcion_G04 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G04 (G4)" ;
    ex:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera." ;
    ex:identificador "G04" .