@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarLosPermisosDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar los permisos de la variable" ;
    ns1:solucionaFallo ns1:EscrituraDeVariableDesdePLCFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Comprobar los permisos de la variable." .

ns1:VerificarLaSintaxisDeLaVariableYLosValoresValidos a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la sintaxis de la variable y los valores válidos" ;
    ns1:solucionaFallo ns1:ErrorSintacticoEnLaEscrituraDeVariableDesdePLC ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable y los valores válidos." .

ns1:VerificarLaSintaxisYLosPermisosDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la sintaxis y los permisos de la variable" ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis y los permisos de la variable." .

ns1:ErrorSintacticoEnLaEscrituraDeVariableDesdePLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico en la escritura de variable desde PLC" ;
    ns1:textoExtracto "'Error sintáctico en la escritura de variable desde PLC'" .

ns1:EscrituraDeVariableDesdePLCFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Escritura de variable desde PLC fuera de rango" ;
    ns1:textoExtracto "'Escritura de variable desde PLC fuera de rango'" .

