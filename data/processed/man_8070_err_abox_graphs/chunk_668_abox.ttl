@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DivisionPorCeroEnElPLC a ns1:DiagnosticoFallo ;
    rdfs:label "División por cero en el PLC" ;
    ns1:solucionaFallo ns1:RevisarProgramaPLCYEvitarDivisionesPor0 ;
    ns1:textoExtracto "'División por cero en el PLC'" .

ns1:ErrorEnLaEscrituraDeSalidasDigitalesDelPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la escritura de salidas digitales del PLC" ;
    ns1:solucionaFallo ns1:RevisarTablaDeConfiguracionDeIOsDigitalesComprobarIntegridadDelBusOAu_4723b7a52e ;
    ns1:textoExtracto "'Error en la escritura de salidas digitales del PLC'" .

ns1:ErrorEnLaLecturaDeEntradasDigitalesDelPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la lectura de entradas digitales del PLC" ;
    ns1:solucionaFallo ns1:RevisarTablaDeConfiguracionDeIOsDigitalesYComprobarIntegridadDelBus ;
    ns1:textoExtracto "'Error en la lectura de entradas digitales del PLC'" .

ns1:ErrorSintacticoEnLaLecturaDeVariableDesdePLC a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico en la lectura de variable desde PLC" ;
    ns1:solucionaFallo ns1:VerificarSintaxisYPermisosDeLaVariable ;
    ns1:textoExtracto "'Error sintáctico en la lectura de variable desde PLC'" .

ns1:LaEscrituraDeLaVariableDesdePLCNoPudoRealizarse a ns1:DiagnosticoFallo ;
    rdfs:label "La escritura de la variable desde PLC no pudo realizarse" ;
    ns1:solucionaFallo ns1:VerificarParametrizacionYProgramaPLC ;
    ns1:textoExtracto "'La escritura de la variable desde PLC no pudo realizarse'" .

ns1:RevisarProgramaPLCYEvitarDivisionesPor0 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programa PLC y evitar divisiones por 0" ;
    ns1:textoExtracto "Revisar el programa PLC. No realizar divisiones por 0." .

ns1:RevisarTablaDeConfiguracionDeIOsDigitalesComprobarIntegridadDelBusOAu_4723b7a52e a ns1:TareaMantenimiento ;
    rdfs:label "Revisar tabla de configuración de I/Os digitales, comprobar integridad del bus o aumentar tiempo de ciclo" ;
    ns1:textoExtracto "Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ." .

ns1:RevisarTablaDeConfiguracionDeIOsDigitalesYComprobarIntegridadDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Revisar tabla de configuración de I/Os digitales y comprobar integridad del bus" ;
    ns1:textoExtracto "Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus." .

ns1:VerificarParametrizacionYProgramaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Verificar parametrización y programa PLC" ;
    ns1:textoExtracto "Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC." .

ns1:VerificarSintaxisYPermisosDeLaVariable a ns1:TareaMantenimiento ;
    rdfs:label "Verificar sintaxis y permisos de la variable" ;
    ns1:textoExtracto "Verificar la sintaxis y los permisos de la variable." .

