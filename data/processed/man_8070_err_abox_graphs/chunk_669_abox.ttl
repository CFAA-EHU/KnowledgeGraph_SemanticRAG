@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeIOsDigitales a ns1:Parametro ;
    rdfs:label "Configuración de I/Os digitales" ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ." .

ns1:LaLecturaDeLaVariableDesdePLCNoPudoRealizarse a ns1:DiagnosticoFallo ;
    rdfs:label "La lectura de la variable desde PLC no pudo realizarse" ;
    ns1:textoExtracto "'La lectura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de un parámetro aritmético global o local que" .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarTablaDeConfiguracionDeIOsDigitales a ns1:AccionProhibida ;
    rdfs:label "Revisar tabla de configuración de I/Os digitales" ;
    ns1:textoExtracto "SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ." .

ns1:TiempoDeCiclo_20d8030654 a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo" ;
    ns1:identificador "PLCFREQ" ;
    ns1:textoExtracto "SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ." .

