@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar parametrización" ;
    ns1:solucionaFallo ns1:LaLecturaDeLaVariableDesdePLCNoPudoRealizarse_0619d3e363 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC." .

ns1:ComprobarSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar sintaxis" ;
    ns1:solucionaFallo ns1:ValorDeLecturaFueraDeRango ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la sintaxis de la instrucción." .

ns1:NoSeHaEjecutadoCNCEXPorEstarLaMarcaDeComunicacionA1_969e12c873 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha ejecutado CNCEX por estar la marca de comunicación a '1'" ;
    ns1:textoExtracto "5018 'No se ha ejecutado CNCEX por estar la marca de comunicación a '1'' DETECCIÓN Al ejecutar una instrucción CNCEX." .

ns1:RevisarBloqueYEstadoDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Revisar bloque y estado del canal" ;
    ns1:solucionaFallo ns1:BloqueNuloDeCNCEX ;
    ns1:textoExtracto "SOLUCIÓN Revisar el bloque a ejecutar y el estado del canal." .

ns1:BloqueNuloDeCNCEX a ns1:DiagnosticoFallo ;
    rdfs:label "Bloque nulo de CNCEX" ;
    ns1:textoExtracto "5017 'Bloque nulo de CNCEX' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El bloque programado en la instrucción CNCEX es nulo o la canal programado no está disponible." .

ns1:LaLecturaDeLaVariableDesdePLCNoPudoRealizarse_0619d3e363 a ns1:DiagnosticoFallo ;
    rdfs:label "La lectura de la variable desde PLC no pudo realizarse" ;
    ns1:textoExtracto "5015 'La lectura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de un parámetro aritmético global o local que no existe." .

ns1:ValorDeLecturaFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de lectura fuera de rango" ;
    ns1:textoExtracto "5016 'Valor de lectura fuera de rango' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Dato leído fuera de rango." .

