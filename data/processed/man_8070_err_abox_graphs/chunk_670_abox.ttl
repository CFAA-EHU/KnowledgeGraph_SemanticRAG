ex:Error_8318
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8318: 'Sólo se permite un eje activo 1 por bloque'"@es ;
    ex:identificador "8318" ;
    ex:textoExtracto "8318 'Sólo se permite un eje activo 1 por bloque' DETECCIÓN Durante la edición. CAUSA El eje @1 está programado más de una vez en el bloque. SOLUCIÓN Programar el eje @1 una única vez en el bloque."@es .

