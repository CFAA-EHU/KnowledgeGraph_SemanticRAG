@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNCEXEjecucionNoFinalizada_3a4797cf4b a ns1:DiagnosticoFallo ;
    rdfs:label "CNCEX: Ejecución no finalizada"@es ;
    ns1:textoExtracto "'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX." .

ns1:ComprobarEstadoDelCanalProgramado a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar estado del canal programado"@es ;
    ns1:solucionaFallo ns1:CNCEXCanalDeEjecucionNoDisponible ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el estado del canal programado en la instrucción CNCEX." .

ns1:RevisarLogicaDeLaInstruccionCNCEX a ns1:TareaMantenimiento ;
    rdfs:label "Revisar lógica de la instrucción CNCEX"@es ;
    ns1:solucionaFallo ns1:NoSeHaEjecutadoCNCEXPorEstarLaMarcaDeComunicacionA1 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el programa de PLC la lógica de la instrucción CNCEX y de las marcas utilizadas." .

ns1:CNCEXCanalDeEjecucionNoDisponible a ns1:DiagnosticoFallo ;
    rdfs:label "CNCEX: Canal de ejecución no disponible"@es ;
    ns1:textoExtracto "'CNCEX: Canal de ejecución no disponible' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no está disponible." .

ns1:NoSeHaEjecutadoCNCEXPorEstarLaMarcaDeComunicacionA1 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha ejecutado CNCEX por estar la marca de comunicación a '1'"@es ;
    ns1:textoExtracto "'No se ha ejecutado CNCEX por estar la marca de comunicación a \"1\"' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La marca programada en la instrucción CNCEX ya está activa al ejecutar la instrucción."@es .

