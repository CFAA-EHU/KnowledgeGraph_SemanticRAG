@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarEstadoDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar estado del canal" ;
    ns1:solucionaFallo ns1:CNCEXEjecucionNoFinalizada_76f28e9b59 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el estado del canal programado en la instrucción CNCEX." .

ns1:ComprobarSintaxisDeLaInstruccion a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar sintaxis de la instrucción" ;
    ns1:solucionaFallo ns1:CNCEXElCanalIndicadoNoEsDePLC_f7c783ae5a ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la sintaxis de la instrucción. Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ns1:TipoDeCanal a ns1:Parametro ;
    rdfs:label "Tipo de Canal" ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ns1:CNCEXEjecucionNoFinalizada_76f28e9b59 a ns1:DiagnosticoFallo ;
    rdfs:label "CNCEX: Ejecución no finalizada" ;
    ns1:textoExtracto "'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La instrucción CNCEX no puede ejecutar el bloque en el canal indicado." .

ns1:CNCEXElCanalIndicadoNoEsDePLC_f7c783ae5a a ns1:DiagnosticoFallo ;
    rdfs:label "CNCEX: El canal indicado no es de PLC" ;
    ns1:textoExtracto "'CNCEX: El canal indicado no es de PLC' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no es de PLC." .

