@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DemasiadosCNCRDYCNCWRDeVariablesAsincronas a ns1:AccionProhibida ;
    rdfs:label "Demasiados CNCRD y CNCWR de variables asíncronas" ;
    ns1:solucionaFallo ns1:DemasiadosCNCRDYCNCWRDeVariablesAsincronas_0bad2389bf ;
    ns1:textoExtracto "'PLC:Demasiados CNCRD y CNCWR de variables asíncronas'" .

ns1:RevisarSintaxisDeLaInstruccionCNCEX a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de la instrucción CNCEX" ;
    ns1:textoExtracto "Comprobar la sintaxis de la instrucción. Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ns1:TipoDeCanal a ns1:Parametro ;
    rdfs:label "Tipo de Canal" ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ns1:VerificarMarcasPLC a ns1:TareaMantenimiento ;
    rdfs:label "Verificar marcas PLC" ;
    ns1:textoExtracto "Los valores que aparecen en el warning son los números de las marcas de PLC que controlan los procesos CNCRD, CNCWR y CNCEX que causan el error." .

ns1:DemasiadosCNCRDYCNCWRDeVariablesAsincronas_0bad2389bf a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados CNCRD y CNCWR de variables asíncronas" ;
    ns1:textoExtracto "'PLC:Demasiados CNCRD y CNCWR de variables asíncronas'" .

