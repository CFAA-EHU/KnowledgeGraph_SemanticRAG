ex:Fallo_8336 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TANGFEED RMIN[radio]'"@es ;
    ex:textoExtracto "8336 '#TANGFEED RMIN[radio]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "8336" .

