@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisionDeLaInstalacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de la instalación" ;
    ns1:solucionaFallo ns1:ContadorDePLCDeshabilitado,
        ns1:ErrorEnLaEscrituraDeSalidasDigitalesLocales,
        ns1:ErrorEnLaLecturaDeEntradasDigitalesLocales ;
    ns1:textoExtracto "SOLUCIÓN Revisar la instalación de la aplicación y los drivers del CNC. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ContadorDePLCDeshabilitado a ns1:DiagnosticoFallo ;
    rdfs:label "Contador de PLC deshabilitado" ;
    ns1:textoExtracto "'Contador de PLC deshabilitado' DETECCIÓN Durante el arranque del CNC. CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización." .

ns1:ErrorEnLaEscrituraDeSalidasDigitalesLocales a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la escritura de salidas digitales locales" ;
    ns1:textoExtracto "'Error en la escritura de salidas digitales locales' DETECCIÓN Error en la escritura de salidas digitales locales. CAUSA Fallo en la escritura de las salidas digitales locales de PLC." .

ns1:ErrorEnLaLecturaDeEntradasDigitalesLocales a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la lectura de entradas digitales locales" ;
    ns1:textoExtracto "'Error en la lectura de entradas digitales locales' DETECCIÓN Error en la lectura de entradas digitales locales. CAUSA Fallo en la lectura de las entradas digitales locales de PLC." .

