@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_adb0de773d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de variable únicamente admite valor '0'" ;
    ns1:textoExtracto "'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable" .

ns1:ParametroCEN a ns1:Parametro ;
    rdfs:label "Parámetro CEN" ;
    ns1:parametroMonitoradoPor ns1:SistemaPLC ;
    ns1:textoExtracto "(CEN = 1)" ;
    ns1:valor "1" .

ns1:AvisoSeguridad_1cc4ac6e13 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de contador deshabilitado" ;
    ns1:mitigaRiesgo ns1:SistemaPLC ;
    ns1:textoExtracto "CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización. SOLUCIÓN Tras este aviso, el PLC fuerza la habilitación del contador (CEN = 1) de forma automática." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:activaAlarma ns1:AvisoSeguridad_1cc4ac6e13 ;
    ns1:textoExtracto "El PLC fuerza la habilitación del contador (CEN = 1) de forma automática." .

