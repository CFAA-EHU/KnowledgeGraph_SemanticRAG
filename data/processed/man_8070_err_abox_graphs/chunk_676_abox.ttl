@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1f70bd4550 a ns1:AvisoSeguridad ;
    rdfs:label "Alarma de sobrecorriente en salida analógica local (report desde PLC)" ;
    ns1:mitigaRiesgo ns1:CortocircuitoEnSalidaAnalogicaLocal ;
    ns1:textoExtracto "'Cortocircuito en salida analógica local (report desde PLC)'" .

ns1:ErrorAlConfigurarLosRecursosRemotos a ns1:AvisoSeguridad ;
    rdfs:label "Error al configurar los recursos remotos" ;
    ns1:mitigaRiesgo ns1:ErrorEnConfiguracionDeModulosRemotos ;
    ns1:textoExtracto "'Error al configurar los módulos remotos.'" .

ns1:LaVariableUnicamenteAdmiteElValor0 a ns1:AvisoSeguridad ;
    rdfs:label "La variable únicamente admite el valor '0'" ;
    ns1:mitigaRiesgo ns1:EscribirValorDiferenteDe0EnVariableQueSoloAdmite0 ;
    ns1:textoExtracto "'CNCWR: La variable únicamente admite el valor '0''" .

ns1:RevisarConexionDeSalidaAnalogicaDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisar conexión de salida analógica del CNC" ;
    ns1:solucionaFallo ns1:CortocircuitoEnSalidaAnalogicaLocal ;
    ns1:textoExtracto "'SOLUCIÓN Revisar el conexionado de la salida analógica del CNC.'" .

ns1:RevisarConfiguracionDeModulosRemotos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar configuración de módulos remotos" ;
    ns1:solucionaFallo ns1:ErrorEnConfiguracionDeModulosRemotos ;
    ns1:textoExtracto "'SOLUCIÓN Revisar la configuración de los módulos remotos.'" .

ns1:RevisarProgramaPLCYEscribirValor0EnVariableOEliminarComandoCNCWR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programa PLC y escribir valor 0 en variable o eliminar comando CNCWR" ;
    ns1:solucionaFallo ns1:EscribirValorDiferenteDe0EnVariableQueSoloAdmite0 ;
    ns1:textoExtracto "'SOLUCIÓN Revisar el programa de PLC. Escribir el valor 0 en la variable o eliminar el comando CNCWR.'" .

ns1:CortocircuitoEnSalidaAnalogicaLocal a ns1:AccionProhibida ;
    rdfs:label "Cortocircuito en salida analógica local" ;
    ns1:textoExtracto "'El PLC ha detectado una alarma de sobrecorriente a la hora de escribir la salida analógica local.'" .

ns1:ErrorEnConfiguracionDeModulosRemotos a ns1:AccionProhibida ;
    rdfs:label "Error en configuración de módulos remotos" ;
    ns1:textoExtracto "'Error al configurar los módulos remotos.'" .

ns1:EscribirValorDiferenteDe0EnVariableQueSoloAdmite0 a ns1:AccionProhibida ;
    rdfs:label "Escribir valor diferente de 0 en variable que sólo admite 0" ;
    ns1:textoExtracto "'El PLC ha intentado escribir un valor diferente de 0 en una variable que sólo admite valor 0 (cero).'" .

