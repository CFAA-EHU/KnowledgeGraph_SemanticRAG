@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeLaConfiguracionDeLosModulosRemotos a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de la configuración de los módulos remotos" ;
    ns1:solucionaFallo ns1:ErrorEnLaConfiguracionDeLosModulosRemotos,
        ns1:ErrorEnLaConfiguracionDelRouterDeRecursosRemotos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la configuración de los módulos remotos." .

ns1:ErrorEnLaConfiguracionDeLosModulosRemotos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la configuración de los módulos remotos" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos." .

ns1:ErrorEnLaConfiguracionDelRouterDeRecursosRemotos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la configuración del router de recursos remotos" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún módulo remoto está utilizando un canal que no existe." .

