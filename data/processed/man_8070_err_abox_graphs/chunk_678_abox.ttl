@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ErrorDeCircuitoAbiertoEnUnaSalidaAnalogicaRemota a ns1:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en una salida analógica remota" ;
    ns1:textoExtracto "Se ha abierto el circuito conectado a una salida analógica remota." .

ns1:ErrorDeCortoCircuitoEnUnaSalidaAnalogicaRemota a ns1:DiagnosticoFallo ;
    rdfs:label "Error de corto circuito en una salida analógica remota" ;
    ns1:textoExtracto "Se ha producido un cortocircuito en una salida analógica remota." .

ns1:ErrorEnLaParametrizacionDeAlgunRecursoRemoto a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la parametrización de algún recurso remoto" ;
    ns1:textoExtracto "Error a la hora de configurar los módulos remotos. Algún parámetro de los recursos remotos no es correcto." .

ns1:UnaSalidaAnalogicaRemotaEstaConfiguradaIncorrectamente a ns1:DiagnosticoFallo ;
    rdfs:label "Una salida analógica remota está configurada incorrectamente" ;
    ns1:textoExtracto "La configuración de una salida analógica remota no es correcta." .

ns1:UnaSalidaAnalogicaRemotaHaDetectadoUnErrorDeAlimentacion a ns1:DiagnosticoFallo ;
    rdfs:label "Una salida analógica remota ha detectado un error de alimentación" ;
    ns1:textoExtracto "La alimentación de la salida analógica remota no es correcta." .

ns1:UnaSalidaAnalogicaRemotaHaDetectadoUnErrorDesconocido_5f8e27a93a a ns1:DiagnosticoFallo ;
    rdfs:label "Una salida analógica remota ha detectado un error desconocido" ;
    ns1:textoExtracto "Una salida analógica remota ha detectado un error desconocido." .

ns1:UnaSalidaAnalogicaRemotaHaDetectadoUnErrorEnElModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Una salida analógica remota ha detectado un error en el módulo" ;
    ns1:textoExtracto "El módulo remoto de salidas analógicas no funciona correctamente." .

ns1:AccionProhibidaAlimentacionIncorrecta a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarLaAlimentacionDeLaSalidaAnalogicaRemota ;
    ns1:textoExtracto "La alimentación de la salida analógica remota no es correcta." .

ns1:AccionProhibidaCircuitoAbierto a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarElConexionadoDeLaSalidaAnalogicaRemota ;
    ns1:textoExtracto "Se ha abierto el circuito conectado a una salida analógica remota." .

ns1:AccionProhibidaConfiguracionIncorrecta a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarLaConfiguracionDeLosModulosRemotos ;
    ns1:textoExtracto "Error a la hora de configurar los módulos remotos." .

ns1:AccionProhibidaConfiguracionSalidaAnaloga a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarConfiguracionDeLaSalidaAnalogicaRemota ;
    ns1:textoExtracto "La configuración de una salida analógica remota no es correcta." .

ns1:AccionProhibidaCortoCircuito a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarElConexionadoDeLaSalidaAnalogicaRemota ;
    ns1:textoExtracto "Se ha producido un cortocircuito en una salida analógica remota." .

ns1:AccionProhibidaModuloIncorrecto a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarModuloRemoto_e7833425cb ;
    ns1:textoExtracto "El módulo remoto de salidas analógicas no funciona correctamente." .

ns1:AccionProhibidaParametroIncorrecto a ns1:AccionProhibida ;
    ns1:solucionadoPor ns1:RevisarLaConfiguracionDeLosModulosRemotos ;
    ns1:textoExtracto "Algún parámetro de los recursos remotos no es correcto." .

ns1:RevisarConfiguracionDeLaSalidaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar configuración de la salida analógica remota" ;
    ns1:solucionaFallo ns1:AccionProhibidaConfiguracionSalidaAnaloga ;
    ns1:textoExtracto "Revisar configuración de la salida analógica remota." .

ns1:RevisarLaAlimentacionDeLaSalidaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la alimentación de la salida analógica remota" ;
    ns1:solucionaFallo ns1:AccionProhibidaAlimentacionIncorrecta ;
    ns1:textoExtracto "Revisar la alimentación de la salida analógica remota." .

ns1:RevisarModuloRemoto_e7833425cb a ns1:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto" ;
    ns1:solucionaFallo ns1:AccionProhibidaModuloIncorrecto ;
    ns1:textoExtracto "Revisar módulo remoto." .

ns1:RevisarElConexionadoDeLaSalidaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado de la salida analógica remota" ;
    ns1:solucionaFallo ns1:AccionProhibidaCircuitoAbierto,
        ns1:AccionProhibidaCortoCircuito ;
    ns1:textoExtracto "Revisar el conexionado de la salida analógica remota." .

ns1:RevisarLaConfiguracionDeLosModulosRemotos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la configuración de los módulos remotos" ;
    ns1:solucionaFallo ns1:AccionProhibidaConfiguracionIncorrecta,
        ns1:AccionProhibidaParametroIncorrecto ;
    ns1:textoExtracto "Revisar la configuración de los módulos remotos." .

