@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8353
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8353: '#CS/ACS ON/NEW'" ;
    ex:identificador "8353" ;
    ex:textoExtracto "'#CS/ACS ON/NEW <[n]> <[MODE m, V1, V2, V3, j1, j2, j3, 0/1]>: error de sintaxis'" ;
    ex:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: La sintaxis de la sentencia no es correcta. SOLUCIÓN: Revisar en el manual de programación la sintaxis de la sentencia." .

