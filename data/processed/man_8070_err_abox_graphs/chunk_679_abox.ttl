@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDelModuloRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del módulo remoto" ;
    ns1:solucionaFallo ns1:RevisarModuloRemoto_23fb1315c6 ;
    ns1:textoExtracto "SOLUCIÓN Revisar módulo remoto." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Durante el funcionamiento del PLC." .

ns1:UnaEntradaAnalogicaRemotaHaDetectadoUnErrorDeRangoExcedido a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error de rango excedido" ;
    ns1:textoExtracto "5041 Una entrada analógica remota ha detectado un error de rango excedido." .

ns1:UnaSalidaAnalogicaRemotaHaDetectadoUnErrorDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Una salida analógica remota ha detectado un error desconocido" ;
    ns1:textoExtracto "5040 Una salida analógica remota ha detectado un error desconocido." .

ns1:RevisarModuloRemoto_23fb1315c6 a ns1:AccionProhibida ;
    rdfs:label "Revisar módulo remoto" ;
    ns1:textoExtracto "SOLUCIÓN Revisar módulo remoto." .

