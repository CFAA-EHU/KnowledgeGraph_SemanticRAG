@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:RevisarAlimentacionDeLaEntradaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar alimentación de la entrada analógica remota" ;
    ns1:solucionaFallo ns1:FalloErrorAlimentacion ;
    ns1:textoExtracto "Revisar la alimentación de la entrada analógica remota." .

ns1:RevisarCircuitoConectadoALaEntradaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar circuito conectado a la entrada analógica remota" ;
    ns1:solucionaFallo ns1:FalloErrorRangoExcedido,
        ns1:FalloErrorRangoMinimoExcedido ;
    ns1:textoExtracto "Revisar el circuito conectado a la entrada analógica remota." .

ns1:RevisarConfiguracionDeLaEntradaAnalogicaRemota a ns1:TareaMantenimiento ;
    rdfs:label "Revisar configuración de la entrada analógica remota" ;
    ns1:solucionaFallo ns1:FalloConfiguracionIncorrecta ;
    ns1:textoExtracto "Revisar configuración de la entrada analógica remota." .

ns1:RevisarModuloRemoto_e7833425cb a ns1:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto" ;
    ns1:solucionaFallo ns1:FalloErrorConversion,
        ns1:FalloErrorDesconocido,
        ns1:FalloErrorModulo,
        ns1:FalloErrorRangoExcedido ;
    ns1:textoExtracto "Revisar módulo remoto." .

ns1:FalloConfiguracionIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota está configurada incorrectamente" ;
    ns1:textoExtracto "5044 Una entrada analógica remota esta configurada incorrectamente." .

ns1:FalloErrorAlimentacion a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error de alimentación" ;
    ns1:textoExtracto "5045 Una entrada analógica remota ha detectado un error de alimentación." .

ns1:FalloErrorConversion a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error conversión" ;
    ns1:textoExtracto "5043 Una entrada analógica remota ha detectado un error conversión." .

ns1:FalloErrorDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error desconocido" ;
    ns1:textoExtracto "5047 Una entrada analógica remota ha detectado un error desconocido." .

ns1:FalloErrorModulo a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error en el módulo" ;
    ns1:textoExtracto "5046 Una entrada analógica remota ha detectado un error en el módulo." .

ns1:FalloErrorRangoMinimoExcedido a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error de rango mínimo excedido" ;
    ns1:textoExtracto "5042 Una entrada analógica remota ha detectado un error de rango mínimo excedido." .

ns1:FalloErrorRangoExcedido a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error de rango excedido" ;
    ns1:textoExtracto "5041 Una entrada analógica remota ha detectado un error de rango excedido." .

