@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_07002f00ff a ns1:ComponenteElectrico ;
    rdfs:label "Sensor de temperatura remoto" ;
    ns1:textoExtracto "Error de circuito abierto en un sensor de temperatura remoto." .

ns1:RevisarModuloRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto" ;
    ns1:solucionaFallo ns1:ErrorDeCircuitoAbiertoEnUnSensorDeTemperaturaRemoto,
        ns1:UnaEntradaAnalogicaRemotaHaDetectadoUnErrorDesconocido ;
    ns1:textoExtracto "SOLUCIÓN Revisar módulo remoto." .

ns1:ErrorDeCircuitoAbiertoEnUnSensorDeTemperaturaRemoto a ns1:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en un sensor de temperatura remoto" ;
    ns1:textoExtracto "5048 Error de circuito abierto en un sensor de temperatura remoto." .

ns1:UnaEntradaAnalogicaRemotaHaDetectadoUnErrorDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Una entrada analógica remota ha detectado un error desconocido" ;
    ns1:textoExtracto "5047 Una entrada analógica remota ha detectado un error desconocido." .

