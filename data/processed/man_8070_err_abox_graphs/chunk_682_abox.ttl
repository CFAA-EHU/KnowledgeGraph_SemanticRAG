@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CircuitoAbiertoEnUnSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Circuito abierto en un sensor de temperatura remoto" ;
    ns1:textoExtracto "Error de circuito abierto en un sensor de temperatura remoto." .

ns1:RevisarElConexionadoDelSensorDeTemperaturaRemoto_f546c745aa a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado del sensor de temperatura remoto" ;
    ns1:solucionaFallo ns1:AccionProhibida_49b31592e6,
        ns1:ErrorDeAlimentacionEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDeRangoExcedidoEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDesconocidoEnElSensorDeTemperaturaRemoto,
        ns1:ErrorEnElModuloDelSensorDeTemperaturaRemoto ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado del sensor de temperatura remoto." .

ns1:RevisarLaAlimentacionDelSensorDeTemperaturaRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la alimentación del sensor de temperatura remoto" ;
    ns1:solucionaFallo ns1:ErrorDeAlimentacionEnElSensorDeTemperaturaRemoto ;
    ns1:textoExtracto "SOLUCIÓN Revisar la alimentación del sensor de temperatura remoto." .

ns1:RevisarLaConfiguracionDelSensorDeTemperaturaRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la configuración del sensor de temperatura remoto" ;
    ns1:solucionaFallo ns1:AccionProhibida_49b31592e6 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la configuración del sensor de temperatura remoto." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:activaAlarma ns1:AccionProhibida_49b31592e6,
        ns1:ErrorDeAlimentacionEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDeConversionEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDeRangoExcedidoEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDeRangoMinimoExcedidoEnElSensorDeTemperaturaRemoto,
        ns1:ErrorDesconocidoEnElSensorDeTemperaturaRemoto,
        ns1:ErrorEnElModuloDelSensorDeTemperaturaRemoto ;
    ns1:textoExtracto "Durante el funcionamiento del PLC." .

ns1:ErrorDeConversionEnElSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error de conversión en el sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error conversión." .

ns1:ErrorDeRangoMinimoExcedidoEnElSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error de rango mínimo excedido en el sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error de rango mínimo excedido." .

ns1:ErrorDeRangoExcedidoEnElSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error de rango excedido en el sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error de rango excedido." .

ns1:ErrorDesconocidoEnElSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error desconocido en el sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error desconocido." .

ns1:ErrorEnElModuloDelSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error en el módulo del sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error en el módulo." .

ns1:AccionProhibida_49b31592e6 a ns1:AccionProhibida ;
    rdfs:label "Sensor de temperatura remoto configurado incorrectamente" ;
    ns1:textoExtracto "Un sensor de temperatura remoto esta configurado incorrectamente." .

ns1:ErrorDeAlimentacionEnElSensorDeTemperaturaRemoto a ns1:AccionProhibida ;
    rdfs:label "Error de alimentación en el sensor de temperatura remoto" ;
    ns1:textoExtracto "Un sensor de temperatura remoto ha detectado un error de alimentación." .

