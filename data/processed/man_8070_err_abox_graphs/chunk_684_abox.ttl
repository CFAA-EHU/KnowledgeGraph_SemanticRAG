ex:Error_8381
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TOOL ORI'"@es ;
    ex:identificador "8381" ;
    ex:textoExtracto "'#TOOL ORI: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

