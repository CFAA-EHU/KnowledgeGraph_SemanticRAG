@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarEmergenciaExterna a ns1:TareaMantenimiento ;
    rdfs:label "Activar emergencia externa" ;
    ns1:solucionaFallo ns1:FalloEmergenciaNoActivada ;
    ns1:textoExtracto "CAUSA La marca _EMERGEN del PLC está desactivada." .

ns1:AjustarParametrosDelTestDeTendencia a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar parámetros del test de tendencia" ;
    ns1:solucionaFallo ns1:FalloTestTendencia ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el signo de la consigna (parámetro AXISCHG), el contaje (LOOPCHG) y tiempo asignado al parámetro ESTDELAY." .

ns1:Alarma_18adf230ed a ns1:Alarma ;
    rdfs:label "Alarma de captación" ;
    ns1:textoExtracto "'Alarma de captación' DETECCIÓN Durante la ejecución. CAUSA Alarma de captación en algún eje analógico (parámetro FBACKAL)." .

ns1:Alarma_4c8134bdd6 a ns1:Alarma ;
    rdfs:label "Alarma del test de tendencia activada" ;
    ns1:textoExtracto "'Alarma del test de tendencia activada' DETECCIÓN Cuando un eje se embala y está activa la vigilancia del test de tendencia." .

ns1:ContactarConElServicioDeAsistenciaTecnica a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:FalloAlarmaCaptacion ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ElProgramaPLCNoEstaEnMarcha a ns1:Alarma ;
    rdfs:label "El programa PLC no está en marcha" ;
    ns1:textoExtracto "'El programa PLC no está en marcha' DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC." .

ns1:EmergenciaExternaActivada_b8418944c7 a ns1:Alarma ;
    rdfs:label "Emergencia externa activada" ;
    ns1:textoExtracto "'Emergencia externa activada' DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC." .

ns1:Parametro_9fe8c4cf48 a ns1:Parametro ;
    rdfs:label "Parámetro de retroalimentación de captación" ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "(parámetro FBACKAL)" .

ns1:PonerEnMarchaElProgramaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Poner en marcha el programa PLC" ;
    ns1:solucionaFallo ns1:FalloProgramaPLCNoEnMarcha ;
    ns1:textoExtracto "SOLUCIÓN Poner en marcha el programa PLC. Si es necesario, compilar el programa de PLC." .

ns1:RevisionDeCablesYConexionesDeCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cables y conexiones de captación" ;
    ns1:solucionaFallo ns1:FalloAlarmaCaptacion ;
    ns1:textoExtracto "SOLUCIÓN Revisar los cables y la conexión de las entradas de captación." .

ns1:FalloEmergenciaNoActivada a ns1:DiagnosticoFallo ;
    rdfs:label "Falla por emergencia no activada" ;
    ns1:textoExtracto "CAUSA La marca _EMERGEN del PLC está desactivada." .

ns1:FalloProgramaPLCNoEnMarcha a ns1:DiagnosticoFallo ;
    rdfs:label "Falla por programa PLC no en marcha" ;
    ns1:textoExtracto "CAUSA El programa de PLC no está en marcha. • Instalación de una nueva versión de software. • El usuario ha parado el PLC, olvidando ponerlo en marcha." .

ns1:FalloTestTendencia a ns1:DiagnosticoFallo ;
    rdfs:label "Falla en el test de tendencia" ;
    ns1:textoExtracto "CAUSA Realimentación positiva en el eje durante un tiempo superior al definido en el parámetro ESTDELAY." .

ns1:FalloAlarmaCaptacion a ns1:DiagnosticoFallo ;
    rdfs:label "Falla alarma de captación" ;
    ns1:textoExtracto "Para señal TTL diferencial. • Uno o más cables rotos (señales A, B o sus negadas). • Entrada de captación desconectada en la contadora." .

