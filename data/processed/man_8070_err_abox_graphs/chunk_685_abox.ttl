@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c0e47ee611 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:EmergenciaExternaActivada,
        ns1:ErrorEnLaInicializacionDelBusCAN_75859fb206 ;
    ns1:textoExtracto "CNC 8070" .

ns1:ComprobarEstadoDePulsadoresYLogicaDeSenalEMERGENEnProgramaPLC a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar estado de pulsadores y lógica de señal _EMERGEN en programa PLC" ;
    ns1:mitigaRiesgo ns1:EmergenciaExternaActivada ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el estado de los pulsadores de emergencia. Comprobar la lógica de la señal _EMERGEN en el programa de PLC." .

ns1:ComprobarInicializacionDelBusCAN a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar inicialización del bus CAN" ;
    ns1:mitigaRiesgo ns1:ErrorEnLaInicializacionDelBusCAN_75859fb206 ;
    ns1:textoExtracto "SOLUCIÓN Poner en marcha el programa PLC. Si es necesario, compilar el programa de PLC." .

ns1:EmergenciaExternaActivada a ns1:AccionProhibida ;
    rdfs:label "Emergencia externa activada" ;
    ns1:textoExtracto "'Emergencia externa activada' DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC." .

ns1:ErrorEnLaInicializacionDelBusCAN_75859fb206 a ns1:AccionProhibida ;
    rdfs:label "Error en la inicialización del Bus CAN" ;
    ns1:textoExtracto "'Error en la inicialización del Bus CAN' DETECCIÓN Durante el arranque del CNC." .

