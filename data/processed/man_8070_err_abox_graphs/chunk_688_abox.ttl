@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCANOpen a ns1:Sistema ;
    rdfs:label "Sistema CANopen" ;
    ns1:activaAlarma ns1:CodigosDeErrorParaElBusCANfagor ;
    ns1:textoExtracto "Para el bus CANopen, la ventana de error indica cuál es el módulo provoca el error." .

ns1:SistemaCANfagor a ns1:Sistema ;
    rdfs:label "Sistema CANfagor" ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen. Para el bus CANopen, la ventana de error indica cuál es el módulo provoca el error." .

ns1:UnoOVariosNodosCANNoResponden a ns1:AccionProhibida ;
    rdfs:label "Uno o varios nodos CAN no responden" ;
    ns1:textoExtracto "'Uno o varios nodos CAN no responden' DETECCIÓN Durante la ejecución. CAUSA Uno o varios nodos remotos dejan de responder por reset, cortocircuitos, mal funcionamiento, etc." .

ns1:UnoOVariosNodosCANNoResponden_f25bf17d3a a ns1:DiagnosticoFallo ;
    rdfs:label "Uno o varios nodos CAN no responden" ;
    ns1:activaAlarma ns1:CodigosDeErrorParaElBusCANfagor ;
    ns1:textoExtracto "'Uno o varios nodos CAN no responden' DETECCIÓN Durante la ejecución. CAUSA Uno o varios nodos remotos dejan de responder por reset, cortocircuitos, mal funcionamiento, etc." .

ns1:CodigosDeErrorParaElBusCANfagor a ns1:Alarma ;
    rdfs:label "Códigos de error para el bus CANfagor" ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen. Para el bus CANopen, la ventana de error indica cuál es el módulo provoca el error." .

