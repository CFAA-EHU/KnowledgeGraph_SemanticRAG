    rdfs:label "'Error en procesos de la COMPCI'" ;
    ns1:textoExtracto "6010 'Error en procesos de la COMPCI' DETECCIÓN Durante la ejecución. CAUSA Errores varios en los procesos que gestiona la COMPCI." .

