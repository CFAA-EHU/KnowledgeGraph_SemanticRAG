@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8405
    a ex:Alarma ;
    rdfs:label "Alarma 8405: Error de sintaxis en '#MOVE INF[eje+/- <,avance> <,PRESENT/NEXT/NULL/WAITINPOS>]'" ;
    ex:identificador "8405" ;
    ex:textoExtracto "#MOVE INF[eje+/- <,avance> <,PRESENT/NEXT/NULL/WAITINPOS>] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Alarma_8406
    a ex:Alarma ;
    rdfs:label "Alarma 8406: Error de sintaxis en '#<T>CAM ON[l, maestro, esclavo, n, m, o, p <,ONCE/CONT>]'" ;
    ex:identificador "8406" ;
    ex:textoExtracto "#<T>CAM ON[l, maestro, esclavo, n, m, o, p <,ONCE/CONT>] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Alarma_8407
    a ex:Alarma ;
    rdfs:label "Alarma 8407: Error de sintaxis en '#<T>CAM OFF[esclavo]'" ;
    ex:identificador "8407" ;
    ex:textoExtracto "#<T>CAM OFF[esclavo] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación (referenciado en alarmas 8405, 8406, 8407)" ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Alarma_8405 ex:solucionaFallo ex:ManualProgramacion .
ex:Alarma_8406 ex:solucionaFallo ex:ManualProgramacion .
ex:Alarma_8407 ex:solucionaFallo ex:ManualProgramacion .