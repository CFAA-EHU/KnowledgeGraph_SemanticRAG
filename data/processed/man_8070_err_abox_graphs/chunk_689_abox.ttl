    ns1:textoExtracto "6011 'Error de CAN en nodo remoto' DETECCIÓN Durante la ejecución." .

ns1:ErrorEnElBitDeToggle a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el bit de toggle" ;
    ns1:textoExtracto "3 Error en el bit de toggle." .

