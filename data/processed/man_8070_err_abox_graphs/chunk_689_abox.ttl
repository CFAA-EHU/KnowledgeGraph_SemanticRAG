    rdfs:label "Timeout (el nodo responde)" ;
    ns1:textoExtracto "2 Timeout (el nodo responde)." .

ns1:WatchdogEnLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en la COMPCI'" ;
    ns1:textoExtracto "6007 'Watchdog en la COMPCI' DETECCIÓN Durante la ejecución. CAUSA La COMPCI no responde; posible mal funcionamiento, contactos, etc." .

ns1:WatchdogEnPC a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en PC'" ;
    ns1:textoExtracto "6009 'Watchdog en PC' DETECCIÓN Durante la ejecución. CAUSA El PC no responde por pérdidas de RT IT." .

ns1:WatchdogEnPCCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en PC + COMPCI'" ;
    ns1:textoExtracto "6008 'Watchdog en PC + COMPCI' DETECCIÓN Durante la ejecución. CAUSA La COMPCI y el PC no responden por mal funcionamiento, contactos, pérdidas de RT IT, etc." .

