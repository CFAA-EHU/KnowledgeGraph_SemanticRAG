@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:SolucionParaErrorCANRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Solución para Error CAN remoto" ;
    ns1:solucionaFallo ns1:ErrorDeCANEnNodoRemoto ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorDeCANEnNodoRemoto a ns1:DiagnosticoFallo ;
    rdfs:label "Error de CAN en nodo remoto" ;
    ns1:textoExtracto "'Error de CAN en nodo remoto' DETECCIÓN Durante la ejecución." .

