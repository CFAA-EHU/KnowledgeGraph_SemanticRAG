@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8407
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8407: Sintaxis incorrecta en '#<T>CAM OFF[esclavo]'" ;
    ex:identificador "8407" ;
    ex:textoExtracto "8407 '#<T>CAM OFF[esclavo]' [...] SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error8408
