@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8416
    a ex:Alarma ;
    rdfs:label "Programar el numerador antes que el denominador" ;
    ex:identificador "8416" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." .

ex:Alarma_8417
    a ex:Alarma ;
    rdfs:label "'ambos o ninguno'" ;
    ex:identificador "8417" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." .

ex:Alarma_8418
    a ex:Alarma ;
    rdfs:label "'#ANGAX OFF/SUSP <[expresión1, expresión2, expresión3, ...]>' - Sintaxis incorrecta" ;
    ex:identificador "8418" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

