ex:Parametro_D
    a ex:Parametro ;
    rdfs:label "Parámetro D (denominador)" ;
    ex:textoExtracto "En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N." .

ex:Parametro_N
    a ex:Parametro ;
    rdfs:label "Parámetro N (numerador)" ;
    ex:textoExtracto "En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N." .

ex:DiagnosticoFallo_8416
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta de programación conjunta de parámetros D y N" ;
    ex:textoExtracto "CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." ;
    ex:solucionaFallo ex:Alarma_8416 .

ex:DiagnosticoFallo_8417
    a ex:DiagnosticoFallo ;
    rdfs:label "Orden incorrecto de programación de parámetros D y N" ;
    ex:textoExtracto "CAUSA En las sentencias #FOLLOW ON y #SYNC, el parámetro D está programado antes que el parámetro N. SOLUCIÓN Programar el parámetro N antes que el parámetro D." ;
    ex:solucionaFallo ex:Alarma_8416 .