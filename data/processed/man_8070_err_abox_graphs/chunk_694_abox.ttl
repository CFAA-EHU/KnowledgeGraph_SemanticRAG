@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8425
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8425: '#HSC OFF' - Sintaxis incorrecta" ;
    ex:textoExtracto "'#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8425" .

ex:Error_8426
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8426: '#DEF macro' - Sintaxis incorrecta" ;
    ex:textoExtracto "'#DEF \"macro1\" = \"text1\" \"macro2\" = \"text2\" ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8426" .

ex:Error_8427
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8427: Parámetro FIRST/SECOND no permitido en MODE" ;
    ex:textoExtracto "'Parámetro FIRST/SECOND no permitido en este MODE' DETECCIÓN Durante la edición. CAUSA En las sentencias #CS y #ACS, los comandos FIRST y SECOND sólo se pueden programar en el MODE 6. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." ;
    ex:identificador "8427" .

ex:Error_8428
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8428: Sentencia (ERROR) - Sintaxis incorrecta en lenguaje 8055" ;
    ex:textoExtracto "'(ERROR <nºentero> <,\"texto\">)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:identificador "8428" .

ex:Error_8429
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8429: Sentencia (MSG) - Sintaxis incorrecta en lenguaje 8055" ;
    ex:textoExtracto "'(MSG \"texto\")' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:identificador "8429" .

ex:Error_8430
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8430: Sentencia (DGWZ) - Sintaxis incorrecta en lenguaje 8055" ;
    ex:textoExtracto "'(DGWZ expresión1, expresión2, expresión3, expresión4 <,expresión5, expresión6>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:identificador "8430" .

ex:Error_8431
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8431: Sentencias (ESBLK/DSBLK) - Sintaxis incorrecta en lenguaje 8055" ;
    ex:textoExtracto "'(ESBLK/DSBLK)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las sentencias ESBLK/DSBLK no están solas en el bloque, o falta programar alguna de las dos. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:identificador "8431" .

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual de programación del lenguaje 8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ex:Error_8428
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8429
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8430
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8431
    ex:solucionaFallo ex:Manual_8055 .