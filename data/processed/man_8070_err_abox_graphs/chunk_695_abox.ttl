@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaEmergenciasCANopen a ns1:Tabla ;
    rdfs:label "Tabla de emergencias para el bus CANopen" ;
    ns1:ilustra ns1:ErrorGenerico,
        ns1:SobrecorrienteEnLasSalidas,
        ns1:TemperaturaAmbiente_2f5f195a91 ;
    ns1:textoExtracto "VALOR 3 Tabla de emergencias para el bus CANopen (codificación en base a bits)." .

ns1:ErrorGenerico a ns1:Alarma ;
    rdfs:label "Error genérico" ;
    ns1:identificador "0x1000" ;
    ns1:textoExtracto "0x1000 | Error genérico." .

ns1:SobrecorrienteEnLasSalidas a ns1:Alarma ;
    rdfs:label "Sobrecorriente en las salidas" ;
    ns1:identificador "0x2310" ;
    ns1:textoExtracto "0x2310 | Sobrecorriente en las salidas." .

ns1:TemperaturaAmbiente_2f5f195a91 a ns1:Alarma ;
    rdfs:label "Temperatura ambiente" ;
    ns1:identificador "0x4100" ;
    ns1:textoExtracto "0x4100 | Temperatura ambiente." .

