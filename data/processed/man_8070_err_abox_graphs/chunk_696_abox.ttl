@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:DiagnosticoFallo_8433
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en EFHOLD/DFHOLD"@es ;
    ex:identificador "8433" ;
    ex:textoExtracto "Las sentencias EFHOLD/DFHOLD no están solas en el bloque, o falta programar alguna de las dos. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. Ambas sentencias deben ir solas en el bloque, y deben estar programadas ambas."@es ;
    ex:solucionaFallo ex:Manual_8055 .

