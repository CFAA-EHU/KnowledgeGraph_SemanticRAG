@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnControladorDeCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Error en controlador de CAN" ;
    ns1:textoExtracto "'Error en controlador de CAN'" .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica_fdd70a2d41 a ns1:AvisoSeguridad ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:mitigaRiesgo ns1:DuranteLaEjecucionLaCOMPCIDetectaBUSOFFYElBusCae ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica." .

ns1:DuranteLaEjecucionLaCOMPCIDetectaBUSOFFYElBusCae a ns1:AccionProhibida ;
    rdfs:label "Durante la ejecución. La COMPCI detecta BUSOFF y el bus cae." ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La COMPCI detecta BUSOFF y el bus cae." .

