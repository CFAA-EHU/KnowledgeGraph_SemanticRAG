@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8439
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8439: Sintaxis incorrecta en '(CALL expresión)'"@es ;
    ex:textoExtracto "CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. [...] 8439 '(CALL expresión)' DETECCIÓN Durante la edición."@es ;
    ex:identificador "8439" ;
    ex:solucionaFallo ex:Manual8055 .

ex:Error8440
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8440: Sintaxis incorrecta en '(PCALL/MCALL/PROBE expresión <,param>)'"@es ;
    ex:textoExtracto "CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. [...] 8440 '(PCALL/MCALL/PROBE expresión <,param>)' DETECCIÓN Durante la edición."@es ;
    ex:identificador "8440" ;
    ex:solucionaFallo ex:Manual8055 .

ex:Manual8055
    a ex:Manual ;
    rdfs:label "Manual de programación del 8055"@es ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:identificador "8055" .