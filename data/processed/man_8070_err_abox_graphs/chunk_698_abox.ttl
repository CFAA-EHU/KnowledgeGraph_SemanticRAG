ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ComprobacionesYAccionesParaGarantizarLaIntegridadDelBusCAN a ns1:TareaMantenimiento ;
    rdfs:label "Comprobaciones y acciones para garantizar la integridad del bus CAN" ;
    ns1:solucionaFallo ns1:TimeoutEnLaInicializacionDeCAN ;
    ns1:textoExtracto "Realizar las siguientes comprobaciones y acciones para garantizar la integridad del bus CAN:" .

ns1:ConsultarConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Consultar con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:FalloEnAccesosADPRAMDeLaCOMPCI ;
    ns1:textoExtracto "Consultar con el servicio de asistencia técnica." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica." ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:RealizarLasComprobacionesOportunasParaGarantizarLaIntegridadDelBusCAN a ns1:TareaMantenimiento ;
    rdfs:label "Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN" ;
    ns1:solucionaFallo ns1:ContadorDeErroresCANSobrepasoNivel1_895a5e75e9 ;
    ns1:textoExtracto "Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:ContadorDeErroresCANSobrepasoNivel1_895a5e75e9 a ns1:DiagnosticoFallo ;
    rdfs:label "Contador de errores CAN sobrepaso nivel 1" ;
    ns1:textoExtracto "'Contador de errores CAN sobrepaso nivel 1' DETECCIÓN Durante la ejecución." .

ns1:FalloEnAccesosADPRAMDeLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en accesos a DPRAM de la COMPCI" ;
    ns1:textoExtracto "'Fallo en accesos a DPRAM de la COMPCI' DETECCIÓN Durante la ejecución." .

ns1:TimeoutEnLaInicializacionDeCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Timeout en la inicialización de CAN" ;
    ns1:textoExtracto "'Timeout en la inicialización de CAN' DETECCIÓN Durante el arranque del sistema." .

