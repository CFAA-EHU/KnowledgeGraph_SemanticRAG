@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8447_ParametrosIJK
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 8447: La función programada exige parámetros I, J, K"@es ;
    ex:identificador "8447" ;
    ex:textoExtracto "La función programada exige parámetros I, J, K"@es ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Consultar sintaxis incorrecta en manual 8055"@es ;
        ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es
    ] .

ex:Error8055_InterpolacionG2G3
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error de programación en G2/G3: parámetros I, J, K no admitidos"@es ;
    ex:textoExtracto "El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación"@es ;
    ex:solucionaFallo ex:Error8447_ParametrosIJK .

ex:Error8055_FuncionG9
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en G9: falta punto intermedio (I, J, K)"@es ;
    ex:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es ;
    ex:solucionaFallo ex:Error8447_ParametrosIJK .

ex:Parametro_I
    a               ex:Parametro ;
    rdfs:label      "Parámetro I"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "I" .

ex:Parametro_J
    a               ex:Parametro ;
    rdfs:label      "Parámetro J"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "J" .

ex:Parametro_K
    a               ex:Parametro ;
    rdfs:label      "Parámetro K"@es ;
    ex:textoExtracto "parámetros I, J, K"@es ;
    ex:identificador "K" .

ex:Manual8055
    a               ex:Manual ;
    rdfs:label      "Manual del controlador 8055"@es ;
    ex:identificador "8055" ;
    ex:textoExtracto "manual del 8055"@es .