@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobacionesCAN a ns1:TareaMantenimiento ;
    rdfs:label "Comprobaciones CAN" ;
    ns1:solucionaFallo ns1:ContadorDeErroresCANSobrepasoNivel1_9e5f1fedff ;
    ns1:textoExtracto "Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ContadorDeErroresCANSobrepasoNivel1_9e5f1fedff a ns1:DiagnosticoFallo ;
    rdfs:label "Contador de errores CAN sobrepaso nivel 1" ;
    ns1:textoExtracto "'Contador de errores CAN sobrepaso nivel 1' DETECCIÓN Durante la ejecución. CAUSA El contador de tramas de error (Rx/Tx) supera el nivel 1 (96)." .

