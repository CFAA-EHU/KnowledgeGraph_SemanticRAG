@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AumentarTiemposDeCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Aumentar tiempos de ciclo" ;
    ns1:solucionaFallo ns1:TimeoutEnLecturasDeCAN ;
    ns1:textoExtracto "En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:ComprobacionIntegridadDelBusCAN a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación integridad del bus CAN" ;
    ns1:solucionaFallo ns1:ContadorDeErroresCANEnNivelCritico,
        ns1:TimeoutEnLecturasDeCAN ;
    ns1:textoExtracto "Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:ComprobarModulosYContadorDeErroresCAN_63085e1e92 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar módulos y contador de errores CAN" ;
    ns1:solucionaFallo ns1:TimeoutEnLecturasDeCAN ;
    ns1:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN; si existen errores, realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:NoContinuarSiElErrorPersiste a ns1:AccionProhibida ;
    rdfs:label "No continuar si el error persiste" ;
    ns1:mitigaRiesgo ns1:ConsultarConElServicioDeAsistenciaTecnica_93fe2b7236 ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:SolapamientoDelCicloDeCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Solapamiento del ciclo de CAN" ;
    ns1:textoExtracto "'Solapamiento del ciclo de CAN' DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos cíclicos de lectura de las entradas digitales, analógicas, contadores y volantes de teclado." .

ns1:ConsultarConElServicioDeAsistenciaTecnica_93fe2b7236 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:OverrunEnFIFOCANDeLaCOMPCI,
        ns1:OverrunEnFIFODelControladorCAN ;
    ns1:textoExtracto "Consultar con el servicio de asistencia técnica." .

ns1:ContadorDeErroresCANEnNivelCritico a ns1:DiagnosticoFallo ;
    rdfs:label "Contador de errores CAN en nivel crítico" ;
    ns1:textoExtracto "'Contador de errores CAN en nivel crítico' DETECCIÓN Durante la ejecución. CAUSA El contador de tramas de error (Rx/Tx) supera el nivel crítico (127). SOLUCIÓN Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:OverrunEnFIFOCANDeLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Overrun en FIFO CAN de la COMPCI" ;
    ns1:textoExtracto "'Overrun en FIFO CAN de la COMPCI' DETECCIÓN Durante la ejecución. CAUSA Overflow en la FIFO de recepción de la COMPCI." .

ns1:OverrunEnFIFODelControladorCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Overrun en FIFO del controlador CAN" ;
    ns1:textoExtracto "'Overrun en FIFO del controlador CAN' DETECCIÓN Durante la ejecución. CAUSA Overflow en la FIFO de recepción del controlador de CAN." .

ns1:TimeoutEnLecturasDeCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Timeout en lecturas de CAN" ;
    ns1:textoExtracto "'Timeout en lecturas de CAN' DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos cíclicos de lectura de las entradas digitales, analógicas, contadores y volantes de teclado." .

