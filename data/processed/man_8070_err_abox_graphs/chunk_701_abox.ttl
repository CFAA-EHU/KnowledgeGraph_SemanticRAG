@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_8454
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 8454: 'Valor de parámetro E incorrecto'"@es ;
    ex:textoExtracto "8454 'Valor de parámetro E incorrecto' [...] CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro E en la función G49."@es ;
    ex:identificador "8454" ;
    ex:mitigaRiesgo [
        a ex:Parametro ;
        rdfs:label "Parámetro E (función G49)"@es ;
        ex:textoExtracto "Valor incorrecto del parámetro E en la función G49"@es ;
        ex:identificador "E" ;
        ex:monitoreaParametro ex:Maquina_8055
    ] .

ex:AvisoSeguridad_8455
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 8455: 'Valor de parámetro S incorrecto'"@es ;
    ex:textoExtracto "8455 'Valor de parámetro S incorrecto' [...] CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro S en la función G."@es ;
    ex:identificador "8455" ;
    ex:mitigaRiesgo [
        a ex:Parametro ;
        rdfs:label "Parámetro S (función G)"@es ;
        ex:textoExtracto "Valor incorrecto del parámetro S en la función G"@es ;
        ex:identificador "S" ;
        ex:monitoreaParametro ex:Maquina_8055
    ] .

ex:Maquina_8055
    a ex:Maquina ;
    rdfs:label "Máquina 8055"@es ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8055" ;
    ex:documentadoEn [
        a ex:Manual ;
        rdfs:label "Manual de programación de la máquina 8055"@es ;
        ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es
    ] .