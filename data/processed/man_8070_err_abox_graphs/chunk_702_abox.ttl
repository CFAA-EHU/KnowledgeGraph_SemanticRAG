@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8456
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8456: Valor de parámetro L incorrecto"@es ;
    ex:identificador "8456" ;
    ex:textoExtracto "8456 'Valor de parámetro L incorrecto' [...] CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro L en la función G33/G34. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar sintaxis incorrecta en manual 8055"@es ;
        ex:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es
    ] .

ex:Error_8457
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8457: Orden incorrecto de los ejes"@es ;
    ex:identificador "8457" ;
    ex:textoExtracto "8457 'Orden incorrecto de los ejes' [...] CAUSA Error al programar en lenguaje del 8055. El orden de los ejes en el bloque no es correcto."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar sintaxis de ejes en manual 8055"@es ;
        ex:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es
    ] .

ex:Error_8458
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8458: Función o variable inexistente en fresadora"@es ;
    ex:identificador "8458" ;
    ex:textoExtracto "8458 'Función o variable inexistente en fresadora' [...] CAUSA La función programada sólo existe en torno y el programa es de una fresa (archivo pim)."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Cambiar nombre de fichero o usar software correcto"@es ;
        ex:textoExtracto "SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es
    ] .

ex:Error_8459
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8459: Función o variable inexistente en torno"@es ;
    ex:identificador "8459" ;
    ex:textoExtracto "8459 'Función o variable inexistente en torno' [...] CAUSA La función programada sólo existe en fresa y el programa es de un torno (archivo pit)."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Cambiar nombre de fichero o usar software correcto"@es ;
        ex:textoExtracto "SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es
    ] .

ex:Error_8460
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8460: Ciclo PROBE inexistente en torno"@es ;
    ex:identificador "8460" ;
    ex:textoExtracto "8460 'Ciclo PROBE inexistente en torno' [...] CAUSA El ciclo PROBE no existe."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar ciclos disponibles en manual 8055"@es ;
        ex:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 los ciclos disponibles."@es
    ] .

ex:Error_8461
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8461: Sentencia INIPAR mal programada"@es ;
    ex:identificador "8461" ;
    ex:textoExtracto "8461 '(INIPAR)' [...] CAUSA La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN [...] La sentencia debe ir sola en el bloque."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Aislar sentencia INIPAR en bloque independiente"@es ;
        ex:textoExtracto "La sentencia debe ir sola en el bloque."@es
    ] .

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual de programación 8055"@es ;
    ex:identificador "8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:Error_8455
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8455: Valor incorrecto del parámetro S en función G"@es ;
    ex:identificador "8455" ;
    ex:textoExtracto "CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro S en la función G. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Consultar sintaxis de parámetro S en manual 8055"@es ;
        ex:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es
    ] ;
    ex:documentadoEn ex:Manual_8055 .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "Parámetro S en función G"@es ;
    ex:textoExtracto "Valor incorrecto del parámetro S en la función G."@es ;
    ex:monitoreaParametro ex:Error_8455 .

ex:Parametro_L
    a ex:Parametro ;
    rdfs:label "Parámetro L en funciones G33/G34"@es ;
    ex:textoExtracto "Valor incorrecto del parámetro L en la función G33/G34."@es ;
    ex:monitoreaParametro ex:Error_8456 .

ex:Funcion_PROBE a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Ciclo PROBE"@es ;
    ex:textoExtracto "El ciclo PROBE no existe."@es ;
    ex:monitoreaParametro ex:Error_8460 .

ex:Sentencia_INIPAR
    a ex:Parametro ;
    rdfs:label "Sentencia INIPAR"@es ;
    ex:textoExtracto "La sentencia no está sola en el bloque o no se ha programado."@es ;
    ex:monitoreaParametro ex:Error_8461 .