@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_6f64e8bbb0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:solucionaFallo ns1:ProblemasEnLaTransmisionDeCAN ;
    ns1:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN." .

ns1:ComprobarModulosYContadorDeErroresCAN a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar módulos y contador de errores CAN" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "SOLUCIÓN Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN; si existen errores, realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:FrecuenciaDelControladorPLCFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia del controlador PLCFREQ" ;
    ns1:textoExtracto "En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:PonerseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con el servicio de asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:RevisarParametrosMaquina_fda5830f0f a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros máquina" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:TiempoDeCicloLOOPTIME a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo LOOPTIME" ;
    ns1:textoExtracto "En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:ProblemasEnLaTransmisionDeCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Problemas en la transmisión de CAN" ;
    ns1:textoExtracto "'Problemas en la transmisión de CAN' DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos transmisión de salidas digitales, analógicas, etc. Posible colapso del bus." .

