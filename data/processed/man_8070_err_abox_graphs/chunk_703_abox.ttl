@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeChecksumEnLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum en la COMPCI" ;
    ns1:textoExtracto "'Error de checksum en la COMPCI'" .

ns1:PonerseEnContactoConAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con asistencia técnica" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:RevisionDeParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina" ;
    ns1:solucionaFallo ns1:ErrorDeVolanteNoExistente ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:RevisionDelChecksumDeLosDatos a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del checksum de los datos" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error en el cheksum de los datos." .

ns1:ErrorDeVolanteNoExistente a ns1:DiagnosticoFallo ;
    rdfs:label "Error de volante no existente" ;
    ns1:textoExtracto "La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error." .

