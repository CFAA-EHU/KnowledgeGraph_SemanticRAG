@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8461
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 8461 (INIPAR)" ;
    ex:identificador "8461" ;
    ex:textoExtracto "8461 '(INIPAR)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque." .

ex:Error_8462
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 8462 (DIGIT/TRACE)" ;
    ex:identificador "8462" ;
    ex:textoExtracto "8462 '(DIGIT/TRACE expresión <,param>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ex:Error_8463
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 8463 (OPEN P)" ;
    ex:identificador "8463" ;
    ex:textoExtracto "8463 '(OPEN P(expresión) <,directorio><,A/D><,comentario>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ex:Manual_8055
    a               ex:Manual ;
    rdfs:label      "Manual del 8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ex:Error_8461 ex:solucionaFallo ex:Manual_8055 .
ex:Error_8462 ex:solucionaFallo ex:Manual_8055 .