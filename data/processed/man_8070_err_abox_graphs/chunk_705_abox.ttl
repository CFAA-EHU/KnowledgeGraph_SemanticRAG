@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaElectrico a ns1:Sistema ;
    rdfs:label "Sistema Eléctrico"@es ;
    ns1:ilustradoEn ns1:TablaSalidasAnalogicasDigitales ;
    ns1:textoExtracto "Sistema Eléctrico" .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico"@es ;
    ns1:ilustradoEn ns1:TablaSalidasAnalogicasDigitales ;
    ns1:textoExtracto "Sistema Hidraulico" .

ns1:TablaSalidasAnalogicasDigitales a ns1:Tabla ;
    ns1:textoExtracto """Código. | Significado.
1 | Salidas analógicas.
3 | Salidas digitales.""" .

