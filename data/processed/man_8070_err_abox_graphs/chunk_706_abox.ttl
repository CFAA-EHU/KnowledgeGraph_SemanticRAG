ns1:Componente_0468260117 a ns1:Componente ;
    rdfs:label "SERCON" ;
    ns1:textoExtracto "Fallo en el test de la RAM común del SERCON (accesos R/W en modos Byte/Word)." .

ns1:Componente_601f1e4520 a ns1:Componente ;
    rdfs:label "COMPCI" ;
    ns1:textoExtracto "Error en el test de hardware de la COMPCI." .

ns1:ConsultarConElServicioDeAsistenciaTecnica_50421e216d a ns1:AccionProhibida ;
    rdfs:label "Consultar con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:ErrorDeHardwareEnLaCOMPCI,
        ns1:ErrorDeHardwareEnNodoRemotoCAN,
        ns1:ErrorEnAccesosALaRAMDelSERCON,
        ns1:LimiteDeIncrementoDePosicionSuperadoEnElCNC,
