ns1:NodoRemotoCAN a ns1:Componente ;
    rdfs:label "nodo remoto CAN" ;
    ns1:textoExtracto "Error en el test de hardware de los nodos remotos." .

ns1:ErrorDeHardwareEnLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en la COMPCI" ;
    ns1:textoExtracto "'Error de hardware en la COMPCI' DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de la COMPCI." .

ns1:ErrorDeHardwareEnNodoRemotoCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en nodo remoto CAN" ;
    ns1:textoExtracto "'Error de hardware en nodo remoto CAN' DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de los nodos remotos." .

ns1:ErrorEnAccesosALaRAMDelSERCON a ns1:DiagnosticoFallo ;
    rdfs:label "Error en accesos a la RAM del SERCON" ;
    ns1:textoExtracto "'Error en accesos a la RAM del SERCON' DETECCIÓN Durante el arranque del sistema o durante la ejecución. CAUSA Fallo en el test de la RAM común del SERCON." .

ns1:LimiteDeIncrementoDePosicionSuperadoEnElCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el CNC" ;
    ns1:textoExtracto "'Límite de incremento de posición superado en el CNC' DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico." .

ns1:LimiteDeIncrementoDePosicionSuperadoEnElNodoContadoraDeCAN_0b4a3777df a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el nodo contadora de CAN" ;
    ns1:textoExtracto "'Límite de incremento de posición superado en el nodo contadora de CAN' DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico." .

