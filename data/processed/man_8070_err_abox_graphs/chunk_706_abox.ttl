@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8055" .

ex:Error_8471
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8471: '(WKEY)'"@es ;
    ex:textoExtracto "8471 '(WKEY)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es ;
    ex:identificador "8471" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8472
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8472: '(WBUF <\"texto\", expresión>)'"@es ;
    ex:textoExtracto "8472 '(WBUF <\"texto\", expresión>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:identificador "8472" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8473
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8473: '(SYSTEM)'"@es ;
    ex:textoExtracto "8473 '(SYSTEM)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es ;
    ex:identificador "8473" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8474
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8474: 'Ciclo DIGIT inexistente en torno'"@es ;
    ex:textoExtracto "8474 'Ciclo DIGIT inexistente en torno' DETECCIÓN Durante la edición o traducción de un programa. CAUSA Error al programar en lenguaje del 8055. La función programada sólo existe en fresadora y el programa es de torno (archivo pit). SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es ;
    ex:identificador "8474" .

ex:Error_8475
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8475: 'Ciclo TRACE inexistente en torno'"@es ;
    ex:textoExtracto "8475 'Ciclo TRACE inexistente en torno' DETECCIÓN Durante la edición o traducción de un programa. CAUSA Error al programar en lenguaje del 8055. La función programada sólo existe en fresadora y el programa es de torno (archivo pit). SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es ;
    ex:identificador "8475" .

ex:Error_8476
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8476: 'Función sin traducción'"@es ;
    ex:textoExtracto "8476 'Función sin traducción' DETECCIÓN Durante la traducción de un programa. CAUSA La función programada no tiene equivalente en el del 8055. SOLUCIÓN El CNC no puede traducir la función. Consultar en el manual del 8055 las funciones disponibles."@es ;
    ex:identificador "8476" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:Error_8477
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8477: 'Minúsculas no permitidas en 8055'"@es ;
    ex:textoExtracto "8477 'Minúsculas no permitidas en 8055' DETECCIÓN Durante la edición."@es ;
    ex:identificador "8477" .