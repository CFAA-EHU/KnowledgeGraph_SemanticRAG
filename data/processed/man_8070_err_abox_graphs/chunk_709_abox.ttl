@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlimentarLasIOsLocalesCon24V a ns1:TareaMantenimiento ;
    rdfs:label "Alimentar las I/Os locales con 24 V" ;
    ns1:solucionaFallo ns1:FaltaAlimentacionDeIOsLocales ;
    ns1:textoExtracto "SOLUCIÓN Alimentar las I/Os locales con 24 V." .

ns1:Parametro_e71834e406 a ns1:Parametro ;
    rdfs:label "Parámetro LOOPTIME" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "'Parámetro LOOPTIME no es válido'" .

ns1:FaltaAlimentacionDeIOsLocales a ns1:DiagnosticoFallo ;
    rdfs:label "Falta alimentación de IOs locales" ;
    ns1:textoExtracto "'Falta alimentación de IOs locales'" .

