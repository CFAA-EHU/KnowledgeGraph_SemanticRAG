@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8493
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '$SWITCH expresión'"@es ;
    ex:identificador "8493" ;
    ex:textoExtracto "8493 '$SWITCH expresión' [...] CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:Error_8494
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '$CASE expresión'"@es ;
    ex:identificador "8494" ;
    ex:textoExtracto "8494 '$CASE expresión' [...] CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:Error_8495
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '$WHILE condición'"@es ;
    ex:identificador "8495" ;
    ex:textoExtracto "8495 $WHILE condición [...] CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Error_8493 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8494 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8495 ex:solucionaFallo ex:ManualProgramacion .