@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_8503
    a ex:Alarma ;
    rdfs:label "Falta programar la cota final del movimiento" ;
    ex:identificador "8503" ;
    ex:textoExtracto "8503 'Falta programar la cota final del movimiento' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Falta la cota final de movimiento en G8, G9 o G33. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ex:alarma_8504
    a ex:Alarma ;
    rdfs:label "Valor incorrecto del número de bloques (0-50)" ;
    ex:identificador "8504" ;
    ex:textoExtracto "8504 'Valor incorrecto del número de bloques (0-50)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del número de bloques en G41/G42. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ex:alarma_8506
    a ex:Alarma ;
    rdfs:label "Programar sólo parámetro E" ;
    ex:identificador "8506" ;
    ex:textoExtracto "8506 'Programar sólo parámetro E' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Si en la función G49 se programa el parámetro E, la función no permite más parámetros. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ex:alarma_8507
    a ex:Alarma ;
    rdfs:label "Doble programación comodín" ;
    ex:identificador "8507" ;
    ex:textoExtracto "8507 'Doble programación comodín' DETECCIÓN Durante la edición. CAUSA El comodín \"? n\" está programado más de una vez en el bloque. SOLUCIÓN Programar el comodín una sola vez en el bloque." .

ex:alarma_8508
    a ex:Alarma ;
    rdfs:label "Comodín no permitido en sentencia" ;
    ex:identificador "8508" ;
    ex:textoExtracto "8508 No se permite este tipo de comodín en sentencia. DETECCIÓN Durante la edición. CAUSA Se ha programado con un comodín el eje de una variable, y el eje está en otro canal. SOLUCIÓN No se admite un comodín como eje de un variable, cuando el eje está en otro canal." .

ex:alarma_8509
    a ex:Alarma ;
    rdfs:label "Número de comodín no válido" ;
    ex:identificador "8509" ;
    ex:textoExtracto "8509 'Número de comodín no válido' DETECCIÓN Durante la edición. CAUSA El número programado en el comodín \"? n\" es negativo o mayor que el número de ejes del canal. SOLUCIÓN El número programado en el comodín \"? n\" debe ser un número de eje válido." .

ex:alarma_8510
    a ex:Alarma ;
    rdfs:label "#ABORT [expresión]/[\"file_name\"]/Nexpresión/OFF" ;
    ex:identificador "8510" ;
    ex:textoExtracto "8510 #ABORT [expresión]/[\"file_name\"]/Nexpresión/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:parametro_E
    a ex:Parametro ;
    rdfs:label "Parámetro E en función G49" ;
    ex:textoExtracto "Si en la función G49 se programa el parámetro E, la función no permite más parámetros." ;
    ex:monitoreaParametro ex:alarma_8506 .

ex:parametro_G8
    a ex:Parametro ;
    rdfs:label "Cota final de movimiento en G8" ;
    ex:textoExtracto "Falta la cota final de movimiento en G8, G9 o G33." ;
    ex:monitoreaParametro ex:alarma_8503 .

ex:parametro_G9
    a ex:Parametro ;
    rdfs:label "Cota final de movimiento en G9" ;
    ex:textoExtracto "Falta la cota final de movimiento en G8, G9 o G33." ;
    ex:monitoreaParametro ex:alarma_8503 .

ex:parametro_G33
    a ex:Parametro ;
    rdfs:label "Cota final de movimiento en G33" ;
    ex:textoExtracto "Falta la cota final de movimiento en G8, G9 o G33." ;
    ex:monitoreaParametro ex:alarma_8503 .

ex:parametro_G41
    a ex:Parametro ;
    rdfs:label "Número de bloques en G41" ;
    ex:textoExtracto "Valor incorrecto del número de bloques en G41/G42." ;
    ex:monitoreaParametro ex:alarma_8504 .

ex:parametro_G42
    a ex:Parametro ;
    rdfs:label "Número de bloques en G42" ;
    ex:textoExtracto "Valor incorrecto del número de bloques en G41/G42." ;
    ex:monitoreaParametro ex:alarma_8504 .

ex:comodin_wildcard
    a ex:Parametro ;
    rdfs:label "Comodín \"? n\"" ;
    ex:textoExtracto "El comodín \"? n\" está programado más de una vez en el bloque.", "El número programado en el comodín \"? n\" es negativo o mayor que el número de ejes del canal." ;
    ex:monitoreaParametro ex:alarma_8507, ex:alarma_8509 .

ex:manual_8055
    a ex:Manual ;
    rdfs:label "Manual de programación 8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:documentadoEn ex:alarma_8503, ex:alarma_8504, ex:alarma_8506 .