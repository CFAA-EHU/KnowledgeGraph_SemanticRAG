@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaExternaDelCaptador a ns1:Alarma ;
    rdfs:label "Alarma externa del captador" ;
    ns1:textoExtracto "'Alarma externa del captador' DETECCIÓN El lazo ha detectado alarma externa en el contaje local." .

ns1:Alarma_1bcfbc95b2 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud" ;
    ns1:textoExtracto "'Alarma de amplitud' DETECCIÓN El lazo ha detectado alarma de amplitud Vpp en el contaje local." .

ns1:RevisarElCaptadorConectadoALaCaptacionLocalDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el captador conectado a la captación local del CNC" ;
    ns1:solucionaFallo ns1:FalloCaptadorAlarmaExterna ;
    ns1:textoExtracto "SOLUCIÓN Revisar el captador conectado a la captación local del CNC." .

ns1:RevisarLosNivelesDeLaSenalVppEnLaCaptacionLocalDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los niveles de la señal Vpp en la captación local del CNC" ;
    ns1:solucionaFallo ns1:FalloAmplitudVpp ;
    ns1:textoExtracto "SOLUCIÓN Revisar los niveles de la señal Vpp en la captación local del CNC." .

ns1:FalloAmplitudVpp a ns1:DiagnosticoFallo ;
    rdfs:label "La señal senoidal conectada al contaje local tiene una amplitud fuera de límites, demasiado pequeña o demasiado grande" ;
    ns1:textoExtracto "CAUSA La señal senoidal conectada al contaje local tiene una amplitud fuera de límites, demasiado pequeña o demasiado grande." .

ns1:FalloCaptadorAlarmaExterna a ns1:DiagnosticoFallo ;
    rdfs:label "El captador conectado al contaje local reporta alarma" ;
    ns1:textoExtracto "CAUSA El captador conectado al contaje local reporta alarma." .

