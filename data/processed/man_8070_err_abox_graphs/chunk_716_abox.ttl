@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_a3899e3902 a ns1:Alarma ;
    rdfs:label "Alarma de Captación en volante" ;
    ns1:textoExtracto "'Alarma de Captación en volante' DETECCIÓN Durante la ejecución del CNC." .

ns1:CortocircuitoEnVolanteDeJog a ns1:Alarma ;
    rdfs:label "Cortocircuito en volante de jog" ;
    ns1:textoExtracto "'Cortocircuito en volante de jog (alarma de sobrecorriente)' DETECCIÓN Durante la ejecución del CNC." .

ns1:RevisionDelConexionadoYAlimentacionDeLosVolantesLocales a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del conexionado y alimentación de los volantes locales" ;
    ns1:solucionaFallo ns1:FalloCaptacionVolanteContajeLocal,
        ns1:FalloSobrecorrienteVolanteJog ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." .

ns1:FalloCaptacionVolanteContajeLocal a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de captación en volante conectado al contaje local" ;
    ns1:textoExtracto "CAUSA Alarma de captación en volante conectado al contaje local." .

ns1:FalloSobrecorrienteVolanteJog a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de sobrecorriente en el volante conectado al jog local" ;
    ns1:textoExtracto "CAUSA Alarma de sobrecorriente en el volante conectado al jog local." .

