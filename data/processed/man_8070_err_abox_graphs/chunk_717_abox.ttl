ns1:AvisoSeguridad_44fe3a46c0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de relé de emergencia abierto" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "En reset o validación de parámetros máquina, no se ha conseguido finalizar correctamente la ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos." .

ns1:AvisoSeguridad_813acbdd9a a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de nodos CANopen no Fagor sin opción de software" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "Desconectar del bus CANopen aquellos nodos que no sean Fagor, o comprar la opción de software que permita su empleo." .

