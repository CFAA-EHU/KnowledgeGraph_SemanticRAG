@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnSercosDuranteUnProceso a ns1:Parametro ;
    rdfs:label "Error en Sercos durante un proceso" ;
    ns1:identificador "ErrorSercosProceso" ;
    ns1:parametroMonitoradoPor ns1:ResetDelCNC_f16210bd97 ;
    ns1:textoExtracto "VALOR 1 Error en Sercos durante un proceso" .

ns1:ReleDeEmergencia_6ac5234b29 a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ns1:textoExtracto "el relé de emergencia ha quedado abierto." .

ns1:ResetDelCNC_f16210bd97 a ns1:AccionProhibida ;
    rdfs:label "Reset del CNC" ;
    ns1:solucionaFallo ns1:FalloRearmeAnilloSercos,
        ns1:FalloRearmeBusCAN ;
    ns1:textoExtracto "Tras un reset del CNC o durante la validación de parámetros máquina." .

