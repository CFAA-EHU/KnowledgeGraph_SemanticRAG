    ns1:textoExtracto "VALOR 3 Error en Sercos y CAN durante un proceso de reset CNC." ;
    ns1:valor "3" .

ns1:ErrorEnSercosYCANDuranteUnProcesoDeValidacionDeParametrosMaquina a ns1:Parametro ;
    rdfs:label "Error en Sercos y CAN durante un proceso de validación de parámetros máquina" ;
    ns1:textoExtracto "VALOR 12 Error en Sercos y CAN durante un proceso de validación de parámetros máquina." ;
    ns1:valor "12" .

ns1:ReleDeEmergencia_6ac5234b29 a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ns1:activaAlarma ns1:ReleDeEmergenciaAbierto ;
    ns1:textoExtracto "el relé de emergencia ha quedado abierto." .

ns1:ReleDeEmergenciaAbierto a ns1:Alarma ;
    rdfs:label "Relé de emergencia abierto" ;
    ns1:textoExtracto "el relé de emergencia ha quedado abierto." .

