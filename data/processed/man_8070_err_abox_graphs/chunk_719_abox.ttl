@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirElProblemaEnCANOSercosQueImpideQueSeCierreElReleDeEmergencia a ns1:AccionProhibida ;
    rdfs:label "Corregir el problema en CAN o Sercos que impide que se cierre el relé de emergencia" ;
    ns1:solucionaFallo ns1:ReleDeEmergenciaAbierto ;
    ns1:textoExtracto "SOLUCIÓN Corregir el problema en CAN o Sercos que impide que se cierre el relé de emergencia." .

ns1:ErrorEnCANDuranteUnProcesoDeResetCNC a ns1:Parametro ;
    rdfs:label "Error en CAN durante un proceso de reset CNC" ;
    ns1:textoExtracto "VALOR 2 Error en CAN durante un proceso de reset CNC." ;
    ns1:valor "2" .

ns1:ErrorEnCANDuranteUnProcesoDeValidacionDeParametrosMaquina a ns1:Parametro ;
    rdfs:label "Error en CAN durante un proceso de validación de parámetros máquina" ;
    ns1:textoExtracto "VALOR 8 Error en CAN durante un proceso de validación de parámetros máquina." ;
    ns1:valor "8" .

ns1:ErrorEnSercosDuranteUnProcesoDeResetCNC a ns1:Parametro ;
    rdfs:label "Error en Sercos durante un proceso de reset CNC" ;
    ns1:textoExtracto "VALOR 1 Error en Sercos durante un proceso de reset CNC." ;
    ns1:valor "1" .

ns1:ErrorEnSercosDuranteUnProcesoDeValidacionDeParametrosMaquina a ns1:Parametro ;
    rdfs:label "Error en Sercos durante un proceso de validación de parámetros máquina" ;
    ns1:textoExtracto "VALOR 4 Error en Sercos durante un proceso de validación de parámetros máquina." ;
    ns1:valor "4" .

ns1:ErrorEnSercosYCANDuranteUnProcesoDeResetCNC a ns1:Parametro ;
