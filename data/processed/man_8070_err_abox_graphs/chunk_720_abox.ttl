@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarMaquinaParaAceptarHerramientasDeTierraOIncluirLaHerramienta_dabef2632b a ns1:TareaMantenimiento ;
    rdfs:label "Configurar máquina para aceptar herramientas de tierra o incluir la herramienta en la tabla del almacén"@es ;
    ns1:solucionaFallo ns1:LaHerramientaNoEstaEnElAlmacenYNoSePermitenHerramientasDeTierra ;
    ns1:textoExtracto "SOLUCIÓN Configurar la máquina para aceptar herramientas de tierra o incluir la herramienta en la tabla del almacén." .

ns1:EnUnAlmacenCiclicoHayQueProgramarM06DespuesDeCadaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "En un almacén cíclico hay que programar M06 después de cada herramienta"@es ;
    ns1:solucionaFallo ns1:DosTsConsecutivasEnAlmacenCiclicoM6Necesaria ;
    ns1:textoExtracto "SOLUCIÓN En un almacén cíclico hay que programar M06 después de cada herramienta." .

ns1:ProgramarUnCorrectorExistenteOAnadirNuevosCorrectoresALaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Programar un corrector existente o añadir nuevos correctores a la herramienta"@es ;
    ns1:solucionaFallo ns1:DNoAdmitidaParaEstaHerramienta_8d35ced450 ;
    ns1:textoExtracto "SOLUCIÓN Programar un corrector existente o añadir nuevos correctores a la herramienta." .

ns1:RepararLaHerramientaOHabilitarEnElAlmacenUnaHerramientaDeLaMismaFamil_8db625bafa a ns1:TareaMantenimiento ;
    rdfs:label "Reparar la herramienta o habilitar en el almacén una herramienta de la misma familia que pueda ser utilizada"@es ;
    ns1:textoExtracto "SOLUCIÓN Reparar la herramienta o habilitar en el almacén una herramienta de la misma familia que pueda ser utilizada." .

ns1:RepararLaHerramientaOUtilizarUnaHerramientaEquivalente a ns1:TareaMantenimiento ;
    rdfs:label "Reparar la herramienta o utilizar una herramienta equivalente"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_5d335af3cb,
        ns1:DiagnosticoFallo_cd8b4265f8 ;
    ns1:textoExtracto "SOLUCIÓN Reparar la herramienta o utilizar una herramienta equivalente." .

ns1:TodasLasHerramientasDebenEstarDefinidasEnLaTablaDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Todas las herramientas deben estar definidas en la tabla de herramientas"@es ;
    ns1:solucionaFallo ns1:TNoDefinidaEnLaTabla ;
    ns1:textoExtracto "SOLUCIÓN Todas las herramientas deben estar definidas en la tabla de herramientas, incluso las herramientas de tierra." .

ns1:DNoAdmitidaParaEstaHerramienta_8d35ced450 a ns1:DiagnosticoFallo ;
    rdfs:label "D no admitida para esta herramienta"@es ;
    ns1:textoExtracto "'D no admitida para esta herramienta' DETECCIÓN Durante la ejecución. CAUSA Corrector de herramienta no válido. La herramienta tiene menos correctores que el programado." .

ns1:DiagnosticoFallo_5d335af3cb a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta de tierra rechazada o gastada"@es ;
    ns1:textoExtracto "'Herramienta de tierra rechazada o gastada' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada está gastada o ha sido rechazada por el PLC." .

ns1:DiagnosticoFallo_cd8b4265f8 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta rechazada o gastada y sin sustituta"@es ;
    ns1:textoExtracto "'Herramienta rechazada o gastada y sin sustituta' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada está gastada o ha sido rechazada por el PLC y en el almacén no hay otra herramienta de la misma familia." .

ns1:DosTsConsecutivasEnAlmacenCiclicoM6Necesaria a ns1:DiagnosticoFallo ;
    rdfs:label "Dos Ts consecutivas en almacén cíclico (M6 necesaria)"@es ;
    ns1:textoExtracto "'Dos Ts consecutivas en almacén cíclico (M6 necesaria)' DETECCIÓN Durante la ejecución. CAUSA El almacén es cíclico y hay programadas dos herramientas consecutivas sin M06." .

ns1:LaHerramientaNoEstaEnElAlmacenYNoSePermitenHerramientasDeTierra a ns1:DiagnosticoFallo ;
    rdfs:label "La herramienta no está en el almacén y no se permiten herramientas de tierra"@es ;
    ns1:textoExtracto "'La herramienta no está en el almacén y no se permiten herramientas de tierra' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una herramienta que está en la tabla de herramientas, pero no está en la tabla del almacén." .

ns1:TNoDefinidaEnLaTabla a ns1:DiagnosticoFallo ;
    rdfs:label "T no definida en la tabla"@es ;
    ns1:textoExtracto "'T no definida en la tabla' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada no está definida en la tabla de herramientas." .

