@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8529
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #RENAME AX OFF" ;
    ex:identificador "8529" ;
    ex:textoExtracto "#RENAME AX OFF [nombreEje,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

