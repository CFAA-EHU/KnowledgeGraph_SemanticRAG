@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_66df62c8a2 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad 7006" ;
    ns1:mitigaRiesgo ns1:ProgramarCorrectorNoValido ;
    ns1:textoExtracto "'D no admitida para esta herramienta'" .

ns1:AvisoSeguridad_ffd913f826 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad 7007" ;
    ns1:mitigaRiesgo ns1:ProgramarT0EnModoCarga ;
    ns1:textoExtracto "'En modo carga:T0 no admitida'" .

ns1:Fallo7006 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 7006" ;
    ns1:solucionadoPor ns1:ProgramarCorrectorNoValido ;
    ns1:textoExtracto "'D no admitida para esta herramienta'" .

ns1:Fallo7007 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 7007" ;
    ns1:solucionadoPor ns1:ProgramarT0EnModoCarga ;
    ns1:textoExtracto "'En modo carga:T0 no admitida'" .

ns1:ProgramarCorrectorNoValido a ns1:AccionProhibida ;
    rdfs:label "Programar corrector no válido" ;
    ns1:solucionaFallo ns1:Fallo7006 ;
    ns1:textoExtracto "Corrector de herramienta no válido. La herramienta tiene menos correctores que el programado." .

ns1:ProgramarT0EnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Programar T0 en modo carga" ;
    ns1:solucionaFallo ns1:Fallo7007 ;
    ns1:textoExtracto "Almacén en modo carga. No se permite programar T0." .

