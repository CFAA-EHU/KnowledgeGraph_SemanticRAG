@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_25ff347674 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para programación de herramientas cargadas" ;
    ns1:mitigaRiesgo ns1:ProgramarT0EnModoCarga_a66b704d00 ;
    ns1:textoExtracto "'Esta herramienta ya está cargada'" .

ns1:AvisoSeguridad_7993b3ab60 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para posición inválida en el almacén" ;
    ns1:mitigaRiesgo ns1:EspecificarUnaPosicionInvalidaOLlenaEnElAlmacenEnModoCarga ;
    ns1:textoExtracto "'Posición inválida o no hay sitio en el almacén'" .

ns1:AvisoSeguridad_81bd8211ae a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para herramientas que no están en el almacén" ;
    ns1:mitigaRiesgo ns1:IntentarDescargarUnaHerramientaQueNoEstaEnElAlmacen ;
    ns1:textoExtracto "'T no esta en el almacén'" .

ns1:LaHerramientaEstaGastadaORechazada a ns1:DiagnosticoFallo ;
    rdfs:label "La herramienta está gastada o rechazada" ;
    ns1:textoExtracto "'En modo carga:La herramienta esta gastada o rechazada'" .

ns1:ProgramarDosM6ConsecutivasSinHerramientaEnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Programar dos M6 consecutivas sin herramienta en modo carga" ;
    ns1:textoExtracto "'En modo carga:T con dos M6'" .

ns1:ProgramarM6SinHerramientaEnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Programar M6 sin herramienta en modo carga" ;
    ns1:textoExtracto "'En modo carga:M6 sin T'" .

ns1:ProgramarSoloElCorrectorDEnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Programar solo el corrector D en modo carga" ;
    ns1:textoExtracto "'En modo carga:D sola no admitida'" .

ns1:EspecificarUnaPosicionInvalidaOLlenaEnElAlmacenEnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Especificar una posición inválida o llena en el almacén en modo carga" ;
    ns1:textoExtracto "'En modo carga:Posición inválida o no hay sitio en el almacén'" .

ns1:IntentarDescargarUnaHerramientaQueNoEstaEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "Intentar descargar una herramienta que no está en el almacén" ;
    ns1:textoExtracto "'En modo descarga:T no esta en el almacén'" .

ns1:ProgramarT0EnModoCarga_a66b704d00 a ns1:AccionProhibida ;
    rdfs:label "Programar T0 en modo carga" ;
    ns1:textoExtracto "'En modo carga:T0 no admitida'" .

