@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnModoDescargaDNoAdmitidaJuntoConT a ns1:AccionProhibida ;
    rdfs:label "En modo descarga:D no admitida junto con T" ;
    ns1:textoExtracto "'En modo descarga:D no admitida junto con T'" .

ns1:EnModoDescargaTNoEstaEnElAlmacen_ae2d0903b9 a ns1:AccionProhibida ;
    rdfs:label "En modo descarga:T no esta en el almacén" ;
    ns1:textoExtracto "'En modo descarga:T no esta en el almacén'" .

ns1:PosicionEspecificadaOcupada a ns1:AccionProhibida ;
    rdfs:label "Posición especificada ocupada" ;
    ns1:mitigaRiesgo ns1:NoHaySitioEnElAlmacen ;
    ns1:textoExtracto "Si la posición especificada está ocupada, habrá que elegir otra ubicación." .

ns1:ProgramarUnaHerramientaValida a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta válida" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_062a32f8f8 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta válida." .

ns1:DiagnosticoFallo_062a32f8f8 a ns1:DiagnosticoFallo ;
    rdfs:label "Almacén en modo descarga. La herramienta no está en el almacén." ;
    ns1:textoExtracto "Almacén en modo descarga. La herramienta no está en el almacén." .

ns1:NoHaySitioEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "No hay sitio en el almacén" ;
    ns1:textoExtracto "Si no hay sitio en el almacén habrá que descargar previamente alguna herramienta." .

