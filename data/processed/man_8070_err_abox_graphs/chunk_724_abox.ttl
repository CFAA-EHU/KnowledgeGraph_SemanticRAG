@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltaProgramarElCorrector a ns1:AccionProhibida ;
    rdfs:label "Falta programar el corrector" ;
    ns1:textoExtracto "Falta programar el corrector. SOLUCIÓN Programar el corrector." .

ns1:ProgramarCorrectorJuntoConLaHerramienta a ns1:AccionProhibida ;
    rdfs:label "Programar corrector junto con la herramienta" ;
    ns1:textoExtracto "No se permite programar el corrector junto a la herramienta. SOLUCIÓN No se admite esta programación." .

ns1:ProgramarDosM06ConsecutivasParaUnaMismaHerramienta a ns1:AccionProhibida ;
    rdfs:label "Programar dos M06 consecutivas para una misma herramienta" ;
    ns1:textoExtracto "Hay programadas dos M06 consecutivas para una misma herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ns1:ProgramarM06EnModoSetting a ns1:AccionProhibida ;
    rdfs:label "Programar M06 en modo setting" ;
    ns1:textoExtracto "No se permite programar M06. SOLUCIÓN No se admite esta programación." .

ns1:ProgramarM6SinHerramienta a ns1:AccionProhibida ;
    rdfs:label "Programar M6 sin herramienta" ;
    ns1:textoExtracto "No se permite programar una M6 sin herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ns1:ProgramarSoloElCorrector a ns1:AccionProhibida ;
    rdfs:label "Programar solo el corrector" ;
    ns1:textoExtracto "No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ns1:ProgramarSoloElCorrectorEnModoSetting a ns1:AccionProhibida ;
    rdfs:label "Programar solo el corrector en modo setting" ;
    ns1:textoExtracto "No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ns1:ProgramarT0 a ns1:AccionProhibida ;
    rdfs:label "Programar T0" ;
    ns1:textoExtracto "No se permite programar T0. SOLUCIÓN Programar una herramienta diferente de 0." .

ns1:ProgramarUnaHerramientaInvalida a ns1:AccionProhibida ;
    rdfs:label "Programar una herramienta inválida" ;
    ns1:textoExtracto "herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida." .

