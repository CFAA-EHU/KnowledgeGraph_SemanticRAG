ns1:HayProgramadasDosHerramientasConsecutivasSinM06 a ns1:AccionProhibida ;
    rdfs:label "Hay programadas dos herramientas consecutivas sin M06" ;
    ns1:solucionaFallo ns1:EnModoCargaM6Obligatoria ;
    ns1:textoExtracto "Almacén en modo carga. Hay programadas dos herramientas consecutivas sin M06." .

ns1:NoSeAdmiteEstaProgramacion a ns1:AccionProhibida ;
    rdfs:label "No se admite esta programación" ;
    ns1:textoExtracto "CAUSA Almacén en modo setting. No se permite programar M06. SOLUCIÓN No se admite esta programación." .

