    ns1:solucionaFallo ns1:EnModoDescargaT0NoAdmitida_704104bda2 ;
    ns1:textoExtracto "SOLUCIÓN Programar M06 detrás de cada herramienta." .

ns1:EnModoCargaM6Obligatoria a ns1:DiagnosticoFallo ;
