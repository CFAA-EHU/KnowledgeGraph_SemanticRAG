@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9d2b2e3d30 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de emergencia del almacén" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "Almacén en estado de emergencia. El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra." .

ns1:OperacionNoPudoEfectuarseGestorDeHerramientasEnEstadoDeError a ns1:DiagnosticoFallo ;
    rdfs:label "Operación no pudo efectuarse: Gestor de herramientas en estado de error" ;
    ns1:textoExtracto "'La operación no pudo efectuarse:Gestor de herramientas en estado de error' DETECCIÓN Durante la ejecución. CAUSA Almacén en estado de emergencia." .

ns1:Parametro_4c324b254e a ns1:Parametro ;
    rdfs:label "Parámetro de configuración para M6 sin T" ;
    ns1:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no hacer nada." .

ns1:PlcControlador a ns1:ComponenteElectrico ;
    rdfs:label "PLC Controlador" ;
    ns1:textoExtracto "El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra." .

ns1:SolucionParaM6SinT a ns1:TareaMantenimiento ;
    rdfs:label "Solución para M6 sin T" ;
    ns1:solucionaFallo ns1:M6SinT_ebaf235f39 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta y a continuación la función M06 o modificar el parámetro máquina para cambiar el comportamiento del CNC." .

ns1:SolucionParaT0NoAdmitida a ns1:TareaMantenimiento ;
    rdfs:label "Solución para T0 no admitida" ;
    ns1:solucionaFallo ns1:T0NoAdmitida ;
    ns1:textoExtracto "SOLUCIÓN No se admite esta programación." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:M6SinT_ebaf235f39 a ns1:DiagnosticoFallo ;
    rdfs:label "M6 sin T" ;
    ns1:textoExtracto "'M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta." .

ns1:T0NoAdmitida a ns1:DiagnosticoFallo ;
    rdfs:label "T0 no admitida" ;
    ns1:textoExtracto "'T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA El almacén de tipo torreta no admite T0." .

