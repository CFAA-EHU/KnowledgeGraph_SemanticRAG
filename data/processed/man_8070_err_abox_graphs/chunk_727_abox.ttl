@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8559
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación de cotas en bloque G820" ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. 8559 Sólo G820 permite programar varias cotas en el bloque. DETECCIÓN Durante la edición y ejecución. CAUSA La sentencia o función G programada en el bloque no permite la programación de cotas separadas por comas." ;
    ex:identificador "8559" .

ex:Fallo_8560
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #ISO ON" ;
    ex:textoExtracto "8560 #ISO <ON><[NAME=\"fileName\"]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8560" .

ex:Fallo_8561
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #ISO OFF" ;
    ex:textoExtracto "8561 #ISO OFF DETECCIÓN Durante" ;
    ex:identificador "8561" .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Fallo_8560
    ex:solucionaFallo ex:ManualProgramacion .