ex:Error_8567
    a ex:AvisoSeguridad ;
    rdfs:label "Programación de NR no permitida en el ciclo" ;
    ex:identificador "8567" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA El ciclo no admite la programación del comando NR. SOLUCIÓN Eliminar el comando NR del bloque. Para repetir el bloque, utilizar la sentencia #RPT." .

ex:Error_8568
    a ex:AvisoSeguridad ;
    rdfs:label "Valor incorrecto de NR (0-1)" ;
    ex:identificador "8568" ;
    ex:textoExtracto "Valor incorrecto de NR (0-1)." .

ex:Parametro_NR
    a ex:Parametro ;
    rdfs:label "Parámetro NR" ;
    ex:valor "0-1" ;
    ex:textoExtracto "Valor incorrecto de NR (0-1)." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8561 ex:documentadoEn ex:ManualProgramacion .
