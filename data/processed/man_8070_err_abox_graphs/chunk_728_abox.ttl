@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2441094eef a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:parametroMonitoradoPor ns1:Parametro_3ad1277941 ;
    ns1:textoExtracto "CNC 8070" .

ns1:ManiobraInvalida a ns1:AccionProhibida ;
    rdfs:label "Maniobra invalida" ;
    ns1:solucionaFallo ns1:CorreccionDelProgramaDePLC ;
    ns1:textoExtracto "El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra." .

ns1:CorreccionDelProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del programa de PLC" ;
    ns1:solucionaFallo ns1:ErrorM6SinT ;
    ns1:textoExtracto "SOLUCIÓN Corregir en el programa de PLC la maniobra de cambio de herramienta. Si el PLC ha activado la marca SETTMEM, corregir la causa por la que el PLC ha puesto la señal de emergencia." .

ns1:ErrorM6SinT a ns1:DiagnosticoFallo ;
    rdfs:label "Error M6 sin T" ;
    ns1:textoExtracto "'M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta." .

ns1:Parametro_3ad1277941 a ns1:Parametro ;
    rdfs:label "Parámetro máquina que indica al CNC qué hacer en esta situación" ;
    ns1:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no." .

