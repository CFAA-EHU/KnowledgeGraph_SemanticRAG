@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnLaOperacionDeCambioDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "error en la operación de cambio de herramienta" ;
    ns1:solucionaFallo ns1:ComprobarElProgramaDePLC ;
    ns1:textoExtracto "Error en la secuencia de cambio de herramienta, en el programa del PLC." .

ns1:PLCGeneroEmergenciaEnElAlmacenDeHerramientas a ns1:AccionProhibida ;
    rdfs:label "PLC generó emergencia en el almacén de herramientas" ;
    ns1:textoExtracto "El PLC activa la señal de emergencia en el gestor de herramientas." .

ns1:Parametro_4c324b254e a ns1:Parametro ;
    rdfs:label "parámetro máquina que indica al CNC qué hacer en esta situación" ;
    ns1:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no hacer nada." .

ns1:ProgramarDosM06ConsecutivasParaUnaMismaHerramienta_3b1ccb8e20 a ns1:AccionProhibida ;
    rdfs:label "programar dos M06 consecutivas para una misma herramienta" ;
    ns1:solucionaFallo ns1:ProgramarUnaM06ParaCadaHerramienta ;
    ns1:textoExtracto "Hay programadas dos M06 consecutivas para una misma herramienta." .

ns1:ProgramarUnaM06SinSuCorrespondienteHerramienta a ns1:AccionProhibida ;
    rdfs:label "programar una M06 sin su correspondiente herramienta" ;
    ns1:solucionaFallo ns1:ProgramarUnaHerramientaYAContinuacionLaFuncionM6OModificarElParametro_7e8b76c738 ;
    ns1:textoExtracto "Hay programada una M06 sin su correspondiente herramienta." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Siempre que esté funcionando el PLC." .

ns1:ComprobarElProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "comprobar el programa de PLC" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC." .

ns1:ProgramarUnaHerramientaYAContinuacionLaFuncionM6OModificarElParametro_7e8b76c738 a ns1:TareaMantenimiento ;
    rdfs:label "Programar una herramienta y a continuación la función M6 o modificar el parámetro máquina para cambiar el comportamiento del CNC" ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta y a continuación la función M6 o modificar el parámetro máquina para cambiar el comportamiento del CNC." .

ns1:ProgramarUnaM06ParaCadaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Programar una M06 para cada herramienta" ;
    ns1:textoExtracto "SOLUCIÓN Programar una M06 para cada herramienta." .

