@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8568
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Valor incorrecto de NR (0-1)"@es ;
    ex:textoExtracto       "8568 Valor incorrecto de NR (0-1). DETECCIÓN Durante la edición y ejecución. CAUSA El comando NR no admite los valores 0 y 1. SOLUCIÓN Programar el comando NR con un valor igual o superior a 2."@es ;
    ex:identificador       "8568" .

ex:Error_8569
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Sintaxis incorrecta en #OPEN"@es ;
    ex:textoExtracto       "8569 #OPEN[\"fichero\" <, A/D> <, KEEPLINE> <, FhandleFichero>]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es ;
    ex:identificador       "8569" .

ex:Comando_NR
    a                     ex:Parametro ;
    rdfs:label            "Parámetro NR"@es ;
    ex:textoExtracto       "El comando NR no admite los valores 0 y 1. SOLUCIÓN Programar el comando NR con un valor igual o superior a 2."@es ;
    ex:valor               ">=2" .

ex:Sentencia_RPT
    a                     ex:Parametro ;
    rdfs:label            "Sentencia #RPT"@es ;
    ex:textoExtracto       "Para repetir el bloque, utilizar la sentencia #RPT."@es .

ex:Sentencia_OPEN
    a                     ex:Parametro ;
    rdfs:label            "Sentencia #OPEN"@es ;
    ex:textoExtracto       "#OPEN[\"fichero\" <, A/D> <, KEEPLINE> <, FhandleFichero>]"@es ;
    ex:identificador       "#OPEN" .

ex:DiagnosticoFallo_8568
    a                     ex:DiagnosticoFallo ;
    ex:solucionaFallo      ex:Comando_NR ;
    ex:textoExtracto       "SOLUCIÓN Programar el comando NR con un valor igual o superior a 2."@es .

ex:DiagnosticoFallo_8569
    a                     ex:DiagnosticoFallo ;
    ex:solucionaFallo      ex:Sentencia_OPEN ;
    ex:textoExtracto       "CAUSA La sintaxis de la sentencia no es correcta."@es .