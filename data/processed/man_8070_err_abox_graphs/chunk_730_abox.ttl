@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivaLaSenalDeEmergenciaEnElGestorDeHerramientas a ns1:AccionProhibida ;
    rdfs:label "activa la señal de emergencia en el gestor de herramientas" ;
    ns1:solucionaFallo ns1:ErrorDeOperacionNoSePudoEncontrarSitioEnAlmacen ;
    ns1:textoExtracto "El PLC activa la señal de emergencia en el gestor de herramientas." .

ns1:CambiarLaFamiliaDeUnaHerramientaQueEstaEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "cambiar la familia de una herramienta que está en el almacén" ;
    ns1:solucionaFallo ns1:NoSeAdmiteCambioDeFamiliaParaHerramientasEnElAlmacenOEnElCabezal ;
    ns1:textoExtracto "Por motivos de seguridad no se puede cambiar la familia de una herramienta que está en el almacén." .

ns1:ComprobarEstadoDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "comprobar estado del almacén" ;
    ns1:solucionaFallo ns1:ErrorEnLaTablaDeAlmacenamiento,
        ns1:NoSeAdmiteCambioDeFamiliaParaHerramientasEnElAlmacenOEnElCabezal ;
    ns1:textoExtracto "Comprobar el estado del almacén. Es posible que no haya sitio libre en el almacén." .

ns1:ComprobarProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "comprobar programa de PLC" ;
    ns1:solucionaFallo ns1:ErrorDeOperacionNoSePudoEncontrarSitioEnAlmacen ;
    ns1:textoExtracto "Comprobar el programa de PLC." .

ns1:ErrorEnElAlmacenDuranteUnaManiobra a ns1:AccionProhibida ;
    rdfs:label "error en el almacén durante una maniobra" ;
    ns1:solucionaFallo ns1:ErrorEnLaTablaDeAlmacenamiento ;
    ns1:textoExtracto "Error en el almacén durante una maniobra." .

ns1:GeneraErrorDuranteUnaManiobraDelPLC a ns1:AccionProhibida ;
    rdfs:label "genera error durante una maniobra del PLC" ;
    ns1:solucionaFallo ns1:ErrorDeOperacionNoSePudoEncontrarSitioEnAlmacen ;
    ns1:textoExtracto "La maniobra del PLC genera error." .

ns1:QuitarEmergenciaYAnalizarCausas a ns1:TareaMantenimiento ;
    rdfs:label "quitar emergencia y analizar causas" ;
    ns1:solucionaFallo ns1:ErrorDeOperacionNoSePudoEncontrarSitioEnAlmacen ;
    ns1:textoExtracto "Quitar la emergencia y analizar las causas por las que el PLC la ha activado." .

ns1:ErrorEnLaTablaDeAlmacenamiento a ns1:AvisoSeguridad ;
    rdfs:label "Error en la tabla de almacenamiento" ;
    ns1:textoExtracto "'Error en la tabla de almacenamiento'" .

ns1:NoSeAdmiteCambioDeFamiliaParaHerramientasEnElAlmacenOEnElCabezal a ns1:AvisoSeguridad ;
    rdfs:label "No se admite cambio de familia para herramientas en el almacén o en el cabezal" ;
    ns1:textoExtracto "'No se admite cambio de familia para herramientas en el almacén o en el cabezal'" .

ns1:ErrorDeOperacionNoSePudoEncontrarSitioEnAlmacen a ns1:AvisoSeguridad ;
    rdfs:label "Error de operación: No se pudo encontrar sitio en almacén" ;
    ns1:textoExtracto "'Error de operación:No se pudo encontrar sitio en almacén'" .

