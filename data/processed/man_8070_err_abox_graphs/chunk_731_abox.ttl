@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8575
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en sentencia #PREVIEW"@es ;
    ex:textoExtracto "#PREVIEW BEGIN/#PREVIEW END DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "8575" .

ex:AvisoSeguridad_8576
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en sentencia #PARALAX OFF"@es ;
    ex:textoExtracto "#PARALAX OFF<[númeroTransforEjesParalelos]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "8576" .

ex:AvisoSeguridad_8577
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en sentencia #KIN ID"@es ;
    ex:textoExtracto "#KIN ID[númeroCinemática <,TIP/TIP=valor>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "8577" .

ex:AvisoSeguridad_8578
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en sentencia #RTCP"@es ;
    ex:textoExtracto "#RTCP"@es ;
    ex:identificador "8578" .

ex:Parametro_n_meroTransforEjesParalelos
    a ex:Parametro ;
    rdfs:label "númeroTransforEjesParalelos"@es ;
    ex:textoExtracto "#PARALAX OFF<[númeroTransforEjesParalelos]>"@es ;
    ex:valor "númeroTransforEjesParalelos" .

ex:Parametro_n_meroCinem_tica
    a ex:Parametro ;
    rdfs:label "númeroCinemática"@es ;
    ex:textoExtracto "#KIN ID[númeroCinemática <,TIP/TIP=valor>]"@es ;
    ex:valor "númeroCinemática" .

ex:Parametro_TIP
    a ex:Parametro ;
    rdfs:label "TIP"@es ;
    ex:textoExtracto "#KIN ID[númeroCinemática <,TIP/TIP=valor>]"@es ;
    ex:valor "TIP" .