@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_283f89874e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para modos CARGA y DESCARGA" ;
    ns1:mitigaRiesgo ns1:CambioDeModoDelAlmacenConCabezalOcupado ;
    ns1:textoExtracto "El cabezal tiene que estar vacío para los modos CARGA o DESCARGA." .

ns1:DescargaDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Descarga de herramienta" ;
    ns1:solucionaFallo ns1:CambioDeFamiliaDeHerramientaEnAlmacen ;
    ns1:textoExtracto "Descargar primero la herramienta." .

ns1:VaciarCabezalYBrazos a ns1:TareaMantenimiento ;
    rdfs:label "Vaciar cabezal y brazos" ;
    ns1:solucionaFallo ns1:CambioDeModoDelAlmacenConCabezalOcupado ;
    ns1:textoExtracto "Vaciar el cabezal y los brazos." .

ns1:CambioDeFamiliaDeHerramientaEnAlmacen a ns1:AccionProhibida ;
    rdfs:label "Cambio de familia de herramienta en almacén" ;
    ns1:textoExtracto "Por motivos de seguridad no se puede cambiar la familia de una herramienta que está en el almacén." .

ns1:CambioDeModoDelAlmacenConCabezalOcupado a ns1:AccionProhibida ;
    rdfs:label "Cambio de modo del almacén con cabezal ocupado" ;
    ns1:textoExtracto "Para cambiar el modo del almacén a modo carga o descarga hay que tener el cabezal (y los brazos en los almacenes donde proceda) vacíos." .

