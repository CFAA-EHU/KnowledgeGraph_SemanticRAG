@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DescargarLaHerramientaDelOtroCanal_24d395f6aa a ns1:TareaMantenimiento ;
    rdfs:label "Descargar la herramienta del otro canal" ;
    ns1:solucionaFallo ns1:PedirHerramientaQueEsActivaEnOtroCanal ;
    ns1:textoExtracto "Descargar la herramienta del otro canal." .

ns1:ErrorEnOperacionVaciarPrimeroElBrazo1 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en operación:Vaciar primero el brazo 1'" ;
    ns1:textoExtracto "'Error en operación:Vaciar primero el brazo 1'" .

ns1:LaHerramientaPedidaEsLaHerramientaActivaDeOtroCanal a ns1:DiagnosticoFallo ;
    rdfs:label "'La herramienta pedida es la herramienta activa de otro canal'" ;
    ns1:textoExtracto "'La herramienta pedida es la herramienta activa de otro canal'" .

ns1:ModificarNumeroDeFilosDeUnaHerramientaActiva a ns1:AccionProhibida ;
    rdfs:label "Modificar número de filos de una herramienta activa" ;
    ns1:textoExtracto "'No se puede modificar el número de filos de la herramienta activa'" .

ns1:NoHayHerramientaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "'No hay herramienta activa'" ;
    ns1:textoExtracto "'No hay herramienta activa'" .

ns1:NoPuedeHaberUnaHerramientaEnElCabezalYEnElBrazo2Simultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente'" ;
    ns1:textoExtracto "'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente'" .

ns1:NoSePuedeModificarElNumeroDeFilosDeLaHerramientaActiva_667c6b6d25 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede modificar el número de filos de la herramienta activa'" ;
    ns1:textoExtracto "'No se puede modificar el número de filos de la herramienta activa'" .

ns1:PonerUnaHerramientaEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Poner una herramienta en el cabezal" ;
    ns1:solucionaFallo ns1:NoTenerHerramientaActivaEnElCabezalConCorrectorProgramado ;
    ns1:textoExtracto "Poner una herramienta en el cabezal." .

ns1:ProgramadaPOSYElAlmacenNoEstaEnModoCARGA a ns1:DiagnosticoFallo ;
    rdfs:label "'Programada POS y el almacén no está en modo CARGA'" ;
    ns1:textoExtracto "'Programada POS y el almacén no está en modo CARGA'" .

ns1:ProgramarPosicionDeAlmacenSinEstarEnModoCarga a ns1:AccionProhibida ;
    rdfs:label "Programar posición de almacén sin estar en modo carga" ;
    ns1:textoExtracto "'Programada POS y el almacén no está en modo CARGA'" .

ns1:VaciarElCabezalYLosBrazos a ns1:TareaMantenimiento ;
    rdfs:label "Vaciar el cabezal y los brazos" ;
    ns1:solucionaFallo ns1:TenerElCabezalLlenoAlCambiarModoDelAlmacen,
        ns1:TenerHerramientaEnElCabezalYEnElBrazo1Simultaneamente,
        ns1:TenerHerramientaEnElCabezalYEnElBrazo2Simultaneamente ;
    ns1:textoExtracto "Vaciar el cabezal y los brazos." .

ns1:NoTenerHerramientaActivaEnElCabezalConCorrectorProgramado a ns1:AccionProhibida ;
    rdfs:label "No tener herramienta activa en el cabezal con corrector programado" ;
    ns1:textoExtracto "'No hay herramienta activa'" .

ns1:PedirHerramientaQueEsActivaEnOtroCanal a ns1:AccionProhibida ;
    rdfs:label "Pedir herramienta que es activa en otro canal" ;
    ns1:textoExtracto "'La herramienta pedida es la herramienta activa de otro canal'" .

ns1:TenerElCabezalLlenoAlCambiarModoDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Tener el cabezal lleno al cambiar modo del almacén" ;
    ns1:textoExtracto "Para cambiar el modo del almacén a modo carga o descarga hay que tener el cabezal (y los brazos en los almacenes donde proceda) vacíos." .

ns1:TenerHerramientaEnElCabezalYEnElBrazo1Simultaneamente a ns1:AccionProhibida ;
    rdfs:label "Tener herramienta en el cabezal y en el brazo 1 simultáneamente" ;
    ns1:textoExtracto "'Error en operación:Vaciar primero el brazo 1'" .

ns1:TenerHerramientaEnElCabezalYEnElBrazo2Simultaneamente a ns1:AccionProhibida ;
    rdfs:label "Tener herramienta en el cabezal y en el brazo 2 simultáneamente" ;
    ns1:textoExtracto "'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente'" .

