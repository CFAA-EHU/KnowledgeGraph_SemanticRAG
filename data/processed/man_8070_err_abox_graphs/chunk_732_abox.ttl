@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8578
    a ex:AvisoSeguridad ;
    rdfs:label "Error sintaxis #RTCP ON/OFF" ;
    ex:textoExtracto "#RTCP ON/OFF<[CLEAR, HEAD=ST/DYN/OFF, TABLE=ST/DYN/OFF, COROT=valor/ROT/FIX]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8578" .

ex:AvisoSeguridad_8579
    a ex:AvisoSeguridad ;
    rdfs:label "Error sintaxis #LOAD GAPTABLE" ;
    ex:textoExtracto "#LOAD GAPTABLE[fichero]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8579" .

ex:AvisoSeguridad_8580
    a ex:AvisoSeguridad ;
    rdfs:label "Error sintaxis #LOAD PWRTABLE" ;
    ex:textoExtracto "#LOAD PWRTABLE[fichero]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8580" .

ex:AvisoSeguridad_8581
    a ex:AvisoSeguridad ;
    rdfs:label "Error sintaxis #FOLLOW STEP" ;
    ex:textoExtracto "#FOLLOW STEP[nombreEje incrementoEje]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8581" .

ex:AvisoSeguridad_8582
    a ex:AvisoSeguridad ;
    rdfs:label "Programación no permitida con giro activo" ;
    ex:textoExtracto "Programación no permitida con giro activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activo un giro del sistema de coordenadas. SOLUCIÓN Desactivar el giro de coordenadas." ;
    ex:identificador "8582" .

ex:AvisoSeguridad_8583
    a ex:AvisoSeguridad ;
    rdfs:label "Programación no permitida con transformada activa" ;
    ex:textoExtracto "Programación no permitida con transformada activa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activa alguna transformación de coordenadas; #CS/#ACS, #RTCP, #ANGAX, #PARALAX, #VIRTAX. SOLUCIÓN Desactivar la transformación de coordenadas." ;
    ex:identificador "8583" .

ex:AvisoSeguridad_8584
    a ex:AvisoSeguridad ;
    rdfs:label "Programación no permitida con compensación activa" ;
    ex:textoExtracto "Programación no permitida con compensación activa. DETECCIÓN Durante la ejecución." ;
    ex:identificador "8584" .

ex:Parametro_RTCP
    a ex:Parametro ;
    rdfs:label "RTCP (Rotational Tool Center Point)" ;
    ex:textoExtracto "#RTCP ON/OFF<[CLEAR, HEAD=ST/DYN/OFF, TABLE=ST/DYN/OFF, COROT=valor/ROT/FIX]>" .

ex:Parametro_GAPTABLE
    a ex:Parametro ;
    rdfs:label "GAPTABLE (tabla de holguras)" ;
    ex:textoExtracto "#LOAD GAPTABLE[fichero]" .

ex:Parametro_PWRTABLE
    a ex:Parametro ;
    rdfs:label "PWRTABLE (tabla de potencia)" ;
    ex:textoExtracto "#LOAD PWRTABLE[fichero]" .

ex:Parametro_FOLLOW_STEP
    a ex:Parametro ;
    rdfs:label "FOLLOW STEP (seguimiento de eje)" ;
    ex:textoExtracto "#FOLLOW STEP[nombreEje incrementoEje]" .