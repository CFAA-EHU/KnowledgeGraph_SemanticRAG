@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8585
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8585: Programación no permitida sin movimiento independiente activo" ;
    ex:textoExtracto "8585 Programación no permitida sin movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida porque no está activo el movimiento independiente. SOLUCIÓN Activar el movimiento independiente." ;
    ex:identificador "8585" .

ex:Error_8586
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8586: Sintaxis incorrecta en sentencia #FACE" ;
    ex:textoExtracto "8586 #FACE[nombreAbscisa, nombreOrdenada <,nombreLong, Eje4, Eje5, Q valorOrigenC>] <[númeroCinemática]>. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8586" .

ex:Error_8587
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8587: Sintaxis incorrecta en sentencia #CYL" ;
    ex:textoExtracto "8587 #CYL [nombreAbscisa, nombreOrdenada, nombreLong valorRadio <,Q valorOrigenC>] <[númeroCinemática]>. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8587" .

ex:Error_8701
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8701: Falta recurso o número tras símbolo" ;
    ex:textoExtracto "8701 'Falta recurso o número tras símbolo' DETECCIÓN Durante la edición. CAUSA Falta recurso tras DFU, DFD, ERA o tras el símbolo de DEF/PDEF. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DFU/DFD/ERA recurso\"." ;
    ex:identificador "8701" .

ex:Error_8702
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8702: Recurso antes de símbolo" ;
    ex:textoExtracto "8702 'Recurso antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El recurso está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\"." ;
    ex:identificador "8702" .

ex:Error_8703
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8703: Número antes de símbolo" ;
    ex:textoExtracto "8703 'Número antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El número está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo número\"." ;
    ex:identificador "8703" .

ex:Error_8704
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8704: Se esperaba recurso o número en lugar de símbolo" ;
    ex:textoExtracto "8704 'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos símbolos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"." ;
    ex:identificador "8704" .

ex:Funcion_G a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G (movimiento independiente)" ;
    ex:textoExtracto "Se ha programado una sentencia o función G no permitida porque no está activo el movimiento independiente." .

ex:Sentencia_FACE
    a ex:Parametro ;
    rdfs:label "Sentencia #FACE" ;
    ex:textoExtracto "#FACE[nombreAbscisa, nombreOrdenada <,nombreLong, Eje4, Eje5, Q valorOrigenC>] <[númeroCinemática]>." .

ex:Sentencia_CYL
    a ex:Parametro ;
    rdfs:label "Sentencia #CYL" ;
    ex:textoExtracto "#CYL [nombreAbscisa, nombreOrdenada, nombreLong valorRadio <,Q valorOrigenC>] <[númeroCinemática]>." .

ex:Comando_DEF
    a ex:Parametro ;
    rdfs:label "Comando DEF/PDEF" ;
    ex:textoExtracto "Comando DEF o PDEF." .

ex:Comando_DFU
    a ex:Parametro ;
    rdfs:label "Comando DFU/DFD/ERA" ;
    ex:textoExtracto "Falta recurso tras DFU, DFD, ERA o tras el símbolo de DEF/PDEF." .

ex:MovimientoIndependiente
    a ex:ModoOperacion ;
    rdfs:label "Movimiento independiente" ;
    ex:textoExtracto "Activar el movimiento independiente." .

ex:Error_8585 ex:solucionaFallo ex:MovimientoIndependiente .