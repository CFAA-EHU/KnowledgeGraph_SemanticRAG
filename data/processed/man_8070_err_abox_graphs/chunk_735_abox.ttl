@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnLaSentenciaROTATEMZ a ns1:AccionProhibida ;
    rdfs:label "Error en la Sentencia ROTATEMZ" ;
    ns1:solucionaFallo ns1:RevisarElAlmacenYDefinirUnNumeroDeHerramientas ;
    ns1:textoExtracto "7048 Error en la Sentencia ROTATEMZ." .

ns1:EsperarAQueElCNCTermineDeCargarLaLevaParaActivarla a ns1:TareaMantenimiento ;
    rdfs:label "Esperar a que el CNC termine de cargar la leva para activarla" ;
    ns1:textoExtracto "• Esperar a que el CNC termine de cargar la leva para activarla." .

ns1:EsperarAQueElCNCTermineDeCargarLaLevaParaLeerOEscribirLaVariableVGCAM a ns1:TareaMantenimiento ;
    rdfs:label "Esperar a que el CNC termine de cargar la leva para leer o escribir la variable (V.)G.CAM" ;
    ns1:textoExtracto "• Esperar a que el CNC termine de cargar la leva para leer o escribir la variable (V.)G.CAM." .

ns1:EsperarAQueTermineLaValidacionDeLaTablaQueDefineLaLevaParaLeerLaVariableVGCAM a ns1:TareaMantenimiento ;
    rdfs:label "Esperar a que termine la validación de la tabla que define la leva para leer la variable (V.)G.CAM" ;
    ns1:textoExtracto "• Esperar a que termine la validación de la tabla que define la leva para leer la variable (V.)G.CAM." .

ns1:MemoriaInsuficienteParaElNumeroTotalDeHerramientasDefinidoEnLosAlmacenes a ns1:AccionProhibida ;
    rdfs:label "Memoria insuficiente para el número total de herramientas definido en los almacenes" ;
    ns1:solucionaFallo ns1:RevisarElAlmacenYDefinirUnNumeroDeHerramientas ;
    ns1:textoExtracto "7047 Memoria insuficiente para el número total de herramientas definido en los almacenes." .

ns1:RevisarElAlmacenYDefinirUnNumeroDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el almacén y definir un número de herramientas" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el almacén y definir un número de herramientas." .

