@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ROTATEMZConPosicionNoValida a ns1:AccionProhibida ;
    rdfs:label "#ROTATEMZ con posición no válida" ;
    ns1:textoExtracto "La posición programada en #ROTATEMZ no es válida." .

ns1:ROTATEMZSoloSePuedeEjecutarEnUnAlmacenTorreta a ns1:AccionProhibida ;
    rdfs:label "#ROTATEMZ sólo se puede ejecutar en un almacén torreta" ;
    ns1:textoExtracto "La sentencia #ROTATEMZ sólo se puede ejecutar en un almacén torreta." .

ns1:RevisarElAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el almacén" ;
    ns1:solucionaFallo ns1:ROTATEMZElRegistroMZPOSDelPLCNoPuedeSer0 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el almacén." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:ROTATEMZElRegistroMZPOSDelPLCNoPuedeSer0,
        ns1:ROTATEMZPosicionNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ROTATEMZPosicionNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "ROTATEMZ: Posición no válida" ;
    ns1:textoExtracto "7050 ROTATEMZ: Posición no válida." .

ns1:ROTATEMZElRegistroMZPOSDelPLCNoPuedeSer0 a ns1:DiagnosticoFallo ;
    rdfs:label "ROTATEMZ: el registro MZPOS del PLC no puede ser 0" ;
    ns1:textoExtracto "7049 ROTATEMZ: el registro MZPOS del PLC no puede ser 0." .

