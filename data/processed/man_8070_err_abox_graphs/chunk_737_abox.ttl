@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarUnFiloExistenteOAnadirNuevosFilosALaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Programar un filo existente o añadir nuevos filos a la herramienta" ;
    ns1:solucionaFallo ns1:NumeroDeFiloNoValido ;
    ns1:textoExtracto "SOLUCIÓN Programar un filo existente o añadir nuevos filos a la herramienta." .

ns1:RevisarLaProgramacion_ba32351030 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:PosicionNoValida ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:NumeroDeFiloNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Número de filo no válido" ;
    ns1:textoExtracto "'Número de filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta tiene menos filos que el programado." .

ns1:PosicionNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "Posición no válida" ;
    ns1:textoExtracto "7050 ROTATEMZ: Posición no válida. DETECCIÓN Durante la ejecución. CAUSA La posición programada en #ROTATEMZ no es válida." .

