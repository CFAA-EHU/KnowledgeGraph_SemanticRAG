@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8715
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta operando de la consulta NOT" ;
    ex:textoExtracto "8715 'Falta operando de la consulta NOT' DETECCIÓN Durante la edición. CAUSA Falta la consulta del comando NOT. SOLUCIÓN Programar \"NOT consulta\"" ;
    ex:identificador "8715" .

ex:Fallo_8716
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta paréntesis de cierre" ;
    ex:textoExtracto "8716 'Falta paréntesis de cierre' DETECCIÓN Durante la edición. CAUSA Hay un paréntesis de apertura pero falta el paréntesis de cierre. SOLUCIÓN Programar \"(consulta)\"" ;
    ex:identificador "8716" .

ex:Fallo_8717
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta paréntesis de apertura" ;
    ex:textoExtracto "8717 'Falta paréntesis de apertura'" ;
    ex:identificador "8717" .

ex:Fallo_XOR
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta la segunda consulta del comando XOR" ;
    ex:textoExtracto "CAUSA Falta la segunda consulta del comando XOR. SOLUCIÓN Programar \"consulta XOR consulta\"" .