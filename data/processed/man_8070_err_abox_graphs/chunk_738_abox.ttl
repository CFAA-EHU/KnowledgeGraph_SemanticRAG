@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarSiElCNCHaArrancadoCorrectamente a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar si el CNC ha arrancado correctamente" ;
    ns1:solucionaFallo ns1:ElKernelDeSimulacionNoSeEncuentraActivado,
        ns1:ErrorRegistrandoTecla ;
    ns1:textoExtracto "SOLUCIÓN Comprobar si el CNC ha arrancado correctamente." .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:ElKernelDeSimulacionNoSeEncuentraActivado ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Comprobar si el CNC ha arrancado correctamente. Apagar y encender el CNC." .

ns1:ErrorRegistrandoTecla a ns1:DiagnosticoFallo ;
    rdfs:label "Error registrando tecla" ;
    ns1:textoExtracto "'Error registrando tecla' DETECCIÓN Durante el arranque del sistema. CAUSA EL CNC no ha podido registrar alguna de las softkeys o de las teclas de acceso rápido." .

ns1:ElKernelDeSimulacionNoSeEncuentraActivado a ns1:DiagnosticoFallo ;
    rdfs:label "El Kernel de simulación no se encuentra activado" ;
    ns1:textoExtracto "'El Kernel de simulación no se encuentra activado' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel de simulación está arrancado pero no está activado." .

