@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8717
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Falta paréntesis de cierre"@es ;
    ex:identificador "8717" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Hay un paréntesis de apertura pero falta el paréntesis de cierre. SOLUCIÓN Programar \"(consulta)\""@es .

ex:Error_8718
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Falta paréntesis de apertura"@es ;
    ex:identificador "8718" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Hay un paréntesis de cierre pero falta el paréntesis de apertura. SOLUCIÓN Programar \"(consulta)\""@es .

ex:Error_8719
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Paréntesis desparejado"@es ;
    ex:identificador "8719" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre. SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre."@es .

ex:Error_8720
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Falta recurso DFU"@es ;
    ex:identificador "8720" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Falta el recurso tras el comando DFU. SOLUCIÓN Programar \"DFU recurso\"."@es .

ex:Error_8721
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Falta recurso DFD"@es ;
    ex:identificador "8721" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Falta el recurso tras el comando DFD. SOLUCIÓN Programar \"DFD recurso\"."@es .

ex:Error_8722
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Se esperaba instrucción de acción tras '='"@es ;
    ex:identificador "8722" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Falta instrucción tras \"=\". SOLUCIÓN Programar \"condición = instrucción\"."@es .

ex:Error_8723
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Falta segundo operando del CPS"@es ;
    ex:identificador "8723" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Falta el segundo recurso del comando CPS. SOLUCIÓN Programar \"CPS recurso operación recurso\". Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT."@es .

ex:Comando_CPS
    a               ex:Parametro ;
    rdfs:label      "CPS"@es ;
    ex:textoExtracto "CPS recurso operación recurso. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT."@es ;
    ex:solucionaFallo ex:Error_8723 .

ex:Operacion_GT
    a               ex:Parametro ;
    rdfs:label      "GT"@es ;
    ex:textoExtracto "operación del comando CPS: GT"@es .

ex:Operacion_GE
    a               ex:Parametro ;
    rdfs:label      "GE"@es ;
    ex:textoExtracto "operación del comando CPS: GE"@es .

ex:Operacion_EQ
    a               ex:Parametro ;
    rdfs:label      "EQ"@es ;
    ex:textoExtracto "operación del comando CPS: EQ"@es .

ex:Operacion_NE
    a               ex:Parametro ;
    rdfs:label      "NE"@es ;
    ex:textoExtracto "operación del comando CPS: NE"@es .

ex:Operacion_LE
    a               ex:Parametro ;
    rdfs:label      "LE"@es ;
    ex:textoExtracto "operación del comando CPS: LE"@es .

ex:Operacion_LT
    a               ex:Parametro ;
    rdfs:label      "LT"@es ;
    ex:textoExtracto "operación del comando CPS: LT"@es .