@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetenerLosProgramasEnEjecucion a ns1:TareaMantenimiento ;
    rdfs:label "Detener los programas en ejecución" ;
    ns1:solucionaFallo ns1:CierreNoPermitidoMientrasAlgunCanalSeEncuentreEnEjecucionOInterrumpido,
        ns1:CierreNoPermitidoMientrasSeEncuentreEnEjecucionOInterrumpido ;
    ns1:textoExtracto "Detener los programas en ejecución" .

ns1:DetenerLosProgramasEnEjecucionDeTodosLosCanalesDelGrupo a ns1:TareaMantenimiento ;
    rdfs:label "Detener los programas en ejecución de todos los canales del grupo" ;
    ns1:solucionaFallo ns1:CambioDeModoNoPermitidoMientrasAlgunCanalDelGrupoSeEncuentreEnEjecucion ;
    ns1:textoExtracto "Detener los programas en ejecución de todos los canales del grupo" .

ns1:ErrorIniciandoProcesoDeCarga_ef6b32afed a ns1:DiagnosticoFallo ;
    rdfs:label "Error iniciando proceso de carga" ;
    ns1:textoExtracto "'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema." .

ns1:CambioDeModoNoPermitidoMientrasAlgunCanalDelGrupoSeEncuentreEnEjecucion a ns1:AccionProhibida ;
    rdfs:label "Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución" ;
    ns1:textoExtracto "'Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución' DETECCIÓN Durante la ejecución. CAUSA No está permitido cambiar de modo si algún canal del grupo se encuentra en ejecución." .

ns1:CierreNoPermitidoMientrasAlgunCanalSeEncuentreEnEjecucionOInterrumpido a ns1:AccionProhibida ;
    rdfs:label "Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido" ;
    ns1:textoExtracto "'Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si algún canal se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control." .

ns1:CierreNoPermitidoMientrasSeEncuentreEnEjecucionOInterrumpido a ns1:AccionProhibida ;
    rdfs:label "Cierre no permitido mientras se encuentre en ejecución o interrumpido" ;
    ns1:textoExtracto "'Cierre no permitido mientras se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control." .

