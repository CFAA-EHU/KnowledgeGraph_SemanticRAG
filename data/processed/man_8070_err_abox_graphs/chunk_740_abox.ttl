ns1:AvisoSeguridad_6a29661306 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para el error 'Error iniciando proceso de carga'"@es ;
    ns1:mitigaRiesgo ns1:ErrorIniciandoProcesoDeCarga ;
    ns1:textoExtracto "'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la preparación del proceso de carga de la COMPCI o los módulos remotos." .

ns1:CNC8070_12092ab057 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:ParametroCANMODE ;
    ns1:textoExtracto "'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la preparación del proceso de carga de la COMPCI o los módulos remotos." .

ns1:VerificarElReconocimientoDeLaCOMPCIYParametrosRelacionados a ns1:TareaMantenimiento ;
    rdfs:label "Verificar el reconocimiento de la COMPCI y parámetros relacionados"@es ;
    ns1:solucionaFallo ns1:ErrorIniciandoProcesoDeCarga ;
    ns1:textoExtracto "SOLUCIÓN Verificar el reconocimiento de la COMPCI, el valor del parámetro CANMODE y la instalación del driver de comunicaciones." .

ns1:ParametroCANMODE a ns1:Parametro ;
