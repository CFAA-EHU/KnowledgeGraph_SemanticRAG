@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarLaConfiguracionCANYCompararlaConLaReal a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar la configuración CAN y compararla con la real" ;
    ns1:solucionaFallo ns1:ErrorAlmacenadoConfiguracionDelSistema ;
    ns1:textoExtracto "SOLUCIÓN Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos." .

ns1:VerificarLaConfiguracionCANLaConexionDelSistemaYLasVersionesDeBootDeL_04c5847e22 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos" ;
    ns1:solucionaFallo ns1:ErrorCargandoSoftwareDeLasContadoras_3730bc2ca1,
        ns1:ErrorCargandoSoftwareDeLosNodosIO,
        ns1:ErrorCargandoSoftwareDeTeclado_1194181c93 ;
    ns1:textoExtracto "SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:VerificarReconocimientoYCorrectaInstalacionDeLaCOMPCI a ns1:TareaMantenimiento ;
    rdfs:label "Verificar reconocimiento y correcta instalación de la COMPCI" ;
    ns1:solucionaFallo ns1:ErrorCargandoProgramaDeLaCOMPCI ;
    ns1:textoExtracto "SOLUCIÓN Verificar el reconocimiento y correcta instalación de la COMPCI. Póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorAlmacenadoConfiguracionDelSistema a ns1:DiagnosticoFallo ;
    rdfs:label "Error almacenado configuración del sistema" ;
    ns1:textoExtracto "'Error almacenado configuración del sistema' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la configuración CAN durante el proceso de carga." .

ns1:ErrorCargandoProgramaDeLaCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando programa de la COMPCI" ;
    ns1:textoExtracto "'Error cargando programa de la COMPCI' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de la COMPCI." .

ns1:ErrorCargandoSoftwareDeLasContadoras_3730bc2ca1 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ns1:textoExtracto "'Error cargando software de las contadoras' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora." .

ns1:ErrorCargandoSoftwareDeLosNodosIO a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de los nodos IO" ;
    ns1:textoExtracto "'Error cargando software de los nodos IO' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos de I/Os." .

ns1:ErrorCargandoSoftwareDeTeclado_1194181c93 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclado" ;
    ns1:textoExtracto "'Error cargando software de teclado' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga del nodo del teclado de 12\"." .

