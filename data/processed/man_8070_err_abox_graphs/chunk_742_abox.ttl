@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConElServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con el servicio de asistencia técnica" ;
    ns1:solucionaFallo ns1:ErrorCargandoSoftwareDeLasContadoras ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:VerificarLaConfiguracionCANYLaConexionDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la configuración CAN y la conexión del sistema" ;
    ns1:solucionaFallo ns1:ErrorCargandoSoftwareDeLasContadoras ;
    ns1:textoExtracto "SOLUCIÓN Verificar la configuración CAN, la conexión del" .

ns1:ErrorCargandoSoftwareDeLasContadoras a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ns1:textoExtracto "'Error cargando software de las contadoras'" .

