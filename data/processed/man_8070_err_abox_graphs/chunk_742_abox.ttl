@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8732
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8732: Orden de operandos invertidos en TG" ;
    ex:textoExtracto "'Orden de operandos invertidos en TG' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del comando TG. SOLUCIÓN Programar 'TG temporizador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." ;
    ex:identificador "8732" .

ex:Error_8733
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8733: Se esperaba instrucción de acción tras NOT" ;
    ex:textoExtracto "'Se esperaba instrucción de acción tras NOT' DETECCIÓN Durante la edición. CAUSA Falta instrucción tras NOT. SOLUCIÓN Programar 'NOT instrucción'." ;
    ex:identificador "8733" .

ex:Error_8734
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8734: Falta índice de contador en CUP" ;
    ex:textoExtracto "'Falta índice de contador en CUP' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CUP. SOLUCIÓN Programar 'CUP contador'." ;
    ex:identificador "8734" .

ex:Error_8735
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8735: Falta índice de contador en CDW" ;
    ex:textoExtracto "'Falta índice de contador en CDW' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CDW. SOLUCIÓN Programar 'CDW contador'." ;
    ex:identificador "8735" .

ex:Error_8736
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8736: Falta índice de contador en CEN" ;
    ex:textoExtracto "'Falta índice de contador en CEN' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CEN. SOLUCIÓN Programar 'CEN contador'." ;
    ex:identificador "8736" .

ex:Error_8737
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8737: Falta preselección en CPR" ;
    ex:textoExtracto "'Falta preselección en CPR' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando CPR. SOLUCIÓN Programar 'CPR contador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." ;
    ex:identificador "8737" .

ex:Error_8738
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8738: Falta índice de contador y preselección en CPR" ;
    ex:textoExtracto "'Falta índice de contador y preselección en CPR' DETECCIÓN Durante la edición. CAUSA Falta el contador y el valor de preselección en el comando CPR. SOLUCIÓN Programar 'CPR contador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." ;
    ex:identificador "8738" .

ex:Error_8739
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8739: Orden de operandos invertidos en CPR" ;
    ex:textoExtracto "'Orden de operandos invertidos en CPR' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del comando CPR. SOLUCIÓN Programar 'CPR contador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." ;
    ex:identificador "8739" .

ex:Comando_TG
    a ex:Parametro ;
    rdfs:label "Comando TG (temporizador)" ;
    ex:textoExtracto "Programar 'TG temporizador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." .

ex:Comando_NOT
    a ex:Parametro ;
    rdfs:label "Comando NOT" ;
    ex:textoExtracto "Programar 'NOT instrucción'." .

ex:Comando_CUP
    a ex:Parametro ;
    rdfs:label "Comando CUP (contador)" ;
    ex:textoExtracto "Programar 'CUP contador'." .

ex:Comando_CDW
    a ex:Parametro ;
    rdfs:label "Comando CDW (contador)" ;
    ex:textoExtracto "Programar 'CDW contador'." .

ex:Comando_CEN
    a ex:Parametro ;
    rdfs:label "Comando CEN (contador)" ;
    ex:textoExtracto "Programar 'CEN contador'." .

ex:Comando_CPR
    a ex:Parametro ;
    rdfs:label "Comando CPR (contador con preselección)" ;
    ex:textoExtracto "Programar 'CPR contador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." .

ex:Error_8732 ex:solucionaFallo ex:Comando_TG .
ex:Error_8733 ex:solucionaFallo ex:Comando_NOT .
ex:Error_8734 ex:solucionaFallo ex:Comando_CUP .
ex:Error_8735 ex:solucionaFallo ex:Comando_CDW .
