@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8741
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8741: Falta operando en RES"@es ;
    ex:identificador "8741" ;
    ex:textoExtracto "8741 'Falta operando en RES' DETECCIÓN Durante la edición. CAUSA Falta el recurso en el comando RES. SOLUCIÓN Programar 'RES recurso'."@es .

ex:Error8742
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8742: Falta operando en CPL"@es ;
    ex:identificador "8742" ;
    ex:textoExtracto "8742 'Falta operando en CPL' DETECCIÓN Durante la edición. CAUSA Falta el recurso en el comando CPL. SOLUCIÓN Programar 'CPL recurso'."@es .

ex:Error8743
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8743: Falta nombre de subrutina tras CAL"@es ;
    ex:identificador "8743" ;
    ex:textoExtracto "8743 Falta nombre de subrutina tras CAL. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la subrutina en el comando CAL. SOLUCIÓN Programar 'CAL subrutina'."@es .

ex:Error8744
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8744: Falta etiqueta de salto tras JMP"@es ;
    ex:identificador "8744" ;
    ex:textoExtracto "8744 Falta etiqueta de salto tras JMP. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar 'JMP etiqueta'."@es .

ex:Error8745
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8745: Código MOV no válido"@es ;
    ex:identificador "8745" ;
    ex:textoExtracto "8745 Código MOV no válido. DETECCIÓN Durante la edición del programa PLC. CAUSA El código de origen o destino en el comando MOV no es válido. SOLUCIÓN Los códigos de origen y destino indican el formato de la información (binario o BCD). Los códigos podrán ser 0 (binario) o 1 (BCD)."@es .

ex:Error8746
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8746: Fallo del parser al buscar número de bits en MOV"@es ;
    ex:identificador "8746" ;
    ex:textoExtracto "8746 Fallo del parser al buscar el número de bits a transmitir en el MOV. DETECCIÓN Durante la ejecución del programa PLC. CAUSA Falta programar el número de bits en el comando MOV. SOLUCIÓN El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32."@es .

ex:Error8747
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8747: Solapamiento de origen y destino en MOV"@es ;
    ex:identificador "8747" ;
    ex:textoExtracto "8747 Hay solapamiento de origen y destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Algunos bits a mover comparten origen y destino. SOLUCIÓN Los datos de origen y destino no deben solaparse. Disminuir el número de bits a mover o seleccionar un destino diferente."@es .

ex:Error8748
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8748: Falta origen o destino en MOV"@es ;
    ex:identificador "8748" ;
    ex:textoExtracto "8748 Falta origen o destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar 'JMP etiqueta'."@es .

ex:Error8749
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 8749: Falta origen y destino en MOV"@es ;
    ex:identificador "8749" ;
    ex:textoExtracto "8749 Falta origen y destino en el MOV. DETECCIÓN Durante la edición del programa PLC."@es .

ex:SistemaPLC
    a               ex:Sistema ;
    rdfs:label      "Sistema de programación PLC"@es ;
    ex:textoExtracto "Detección durante la edición/execución del programa PLC."@es ;
    ex:activaAlarma  ex:Error8741, ex:Error8742, ex:Error8743, ex:Error8744, ex:Error8745, ex:Error8746, ex:Error8747, ex:Error8748, ex:Error8749 .