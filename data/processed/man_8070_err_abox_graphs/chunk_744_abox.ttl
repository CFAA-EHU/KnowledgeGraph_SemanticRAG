@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesincronizarElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Desincronizar el cabezal" ;
    ns1:solucionaFallo ns1:ElUsuarioHaIntentadoApagarElCNCMientrasHayAlgunCabezalSincronizado ;
    ns1:textoExtracto "SOLUCIÓN Desincronizar el cabezal." .

ns1:DetenerLosProgramasEnEjecucion_554e85a5f5 a ns1:TareaMantenimiento ;
    rdfs:label "Detener los programas en ejecución" ;
    ns1:solucionaFallo ns1:NoSePermiteGenerarElPlcMientrasSeEncuentreEnEjecucionOInterrumpido ;
    ns1:textoExtracto "SOLUCIÓN Detener los programas en ejecución." .

ns1:ElUsuarioHaIntentadoApagarElCNCMientrasHayAlgunCabezalSincronizado a ns1:DiagnosticoFallo ;
    rdfs:label "El usuario ha intentado apagar el CNC mientras hay algún cabezal sincronizado" ;
    ns1:textoExtracto "CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal sincronizado." .

ns1:NoSePermiteGenerarElPlcMientrasSeEncuentreEnEjecucionOInterrumpido a ns1:DiagnosticoFallo ;
    rdfs:label "'No se permite generar el plc mientras se encuentre en ejecución o interrumpido'" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si el CNC se encuentra en ejecución o interrumpido." .

