ns1:CNCTrabajandoEnModoPuestaAPunto a ns1:AccionProhibida ;
    rdfs:label "CNC trabajando en Modo Puesta a Punto" ;
    ns1:textoExtracto "'CNC trabajando en Modo Puesta a Punto'" .

ns1:NoSePermiteCompilarElPLCSiElCNCSeEncuentraEnEjecucionOInterrumpido a ns1:AccionProhibida ;
    rdfs:label "No se permite compilar el PLC si el CNC se encuentra en ejecución o interrumpido." ;
    ns1:textoExtracto "'No se permite generar el plc mientras algún canal se encuentre en ejecución o interrumpido'" .

ns1:NoSePermiteCompilarElPLCSiHayAlgunCabezalEnMovimiento a ns1:AccionProhibida ;
    rdfs:label "No se permite compilar el PLC si hay algún cabezal en movimiento." ;
    ns1:textoExtracto "'No se permite generar el plc:Cabezal en marcha'" .

ns1:NoSePermiteCompilarElPLCSiHayAlgunCabezalSincronizado a ns1:AccionProhibida ;
    rdfs:label "No se permite compilar el PLC si hay algún cabezal sincronizado." ;
    ns1:textoExtracto "'No se permite generar el plc:Cabezal en sincronización'" .

ns1:NoSePermiteCompilarElPLCSiHayAlgunEjeEnMovimientoOSincronizado a ns1:AccionProhibida ;
    rdfs:label "No se permite compilar el PLC si hay algún eje en movimiento o sincronizado." ;
    ns1:textoExtracto "'No se permite generar el plc:Eje en movimiento o en sincronización'" .

ns1:MemoriaEnDiscoPorDebajoDelMinimoRecomendado a ns1:AccionProhibida ;
