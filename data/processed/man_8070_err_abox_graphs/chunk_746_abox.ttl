@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8751 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan argumentos en operación ADS (8751)"@es ;
    ex:identificador "8751" ;
    ex:textoExtracto "Faltan dos argumentos en la operación ADS. [...] SOLUCIÓN Programar \"ADS operando operando resultado\"."@es .

ex:Error8752 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en operación ADS (8752)"@es ;
    ex:identificador "8752" ;
    ex:textoExtracto "Faltan todos los argumentos en la operación ADS. [...] SOLUCIÓN Programar \"ADS operando operando resultado\"."@es .

ex:Error8753 a ex:DiagnosticoFallo ;
    rdfs:label "Falta argumento en operación SBS (8753)"@es ;
    ex:identificador "8753" ;
    ex:textoExtracto "Falta un argumento en la operación SBS. [...] SOLUCIÓN Programar \"SBS operando operando resultado\"."@es .

ex:Error8754 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en operación SBS (8754)"@es ;
    ex:identificador "8754" ;
    ex:textoExtracto "Faltan dos argumentos en la operación SBS. [...] SOLUCIÓN Programar \"SBS operando operando resultado\"."@es .

ex:Error8755 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en operación SBS (8755)"@es ;
    ex:identificador "8755" ;
    ex:textoExtracto "Faltan todos los argumentos en la operación SBS. [...] SOLUCIÓN Programar \"SBS operando operando resultado\"."@es .

ex:Error8756 a ex:DiagnosticoFallo ;
    rdfs:label "Falta argumento en operación MLS (8756)"@es ;
    ex:identificador "8756" ;
    ex:textoExtracto "Falta un argumento en la operación MLS. [...] SOLUCIÓN Programar \"MLS operando operando resultado\"."@es .

ex:Error8757 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en operación MLS (8757)"@es ;
    ex:identificador "8757" ;
    ex:textoExtracto "Faltan dos argumentos en la operación MLS. [...] SOLUCIÓN Programar \"MLS operando operando resultado\"."@es .

ex:Error8758 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en operación MLS (8758)"@es ;
    ex:identificador "8758" ;
    ex:textoExtracto "Faltan todos los argumentos en la operación MLS. [...] SOLUCIÓN Programar \"MLS operando operando resultado\"."@es .

ex:Error8759 a ex:DiagnosticoFallo ;
    rdfs:label "Falta argumento en operación DVS (8759)"@es ;
    ex:identificador "8759" ;
    ex:textoExtracto "Falta un argumento en la operación DVS."@es .

ex:OperacionADS a ex:Parametro ;
    rdfs:label "Operación ADS"@es ;
    ex:textoExtracto "Programar \"ADS operando operando resultado\"."@es ;
    ex:valor "ADS operando operando resultado" .

ex:OperacionSBS a ex:Parametro ;
    rdfs:label "Operación SBS"@es ;
    ex:textoExtracto "Programar \"SBS operando operando resultado\"."@es ;
    ex:valor "SBS operando operando resultado" .

ex:OperacionMLS a ex:Parametro ;
    rdfs:label "Operación MLS"@es ;
    ex:textoExtracto "Programar \"MLS operando operando resultado\"."@es ;
    ex:valor "MLS operando operando resultado" .

ex:OperacionDVS a ex:Parametro ;
    rdfs:label "Operación DVS"@es ;
    ex:textoExtracto "Falta un argumento en la operación DVS."@es .

ex:ProgramacionPLC a ex:InterfazUsuario ;
    rdfs:label "Edición de programa PLC"@es ;
    ex:textoExtracto "Durante la edición del programa PLC."@es .

ex:Error8751 ex:solucionaFallo ex:OperacionADS .
ex:Error8752 ex:solucionaFallo ex:OperacionADS .
ex:Error8753 ex:solucionaFallo ex:OperacionSBS .
ex:Error8754 ex:solucionaFallo ex:OperacionSBS .
ex:Error8755 ex:solucionaFallo ex:OperacionSBS .
ex:Error8756 ex:solucionaFallo ex:OperacionMLS .
ex:Error8757 ex:solucionaFallo ex:OperacionMLS .
ex:Error8758 ex:solucionaFallo ex:OperacionMLS .