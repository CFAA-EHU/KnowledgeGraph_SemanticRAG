@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_38c177bcdf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:AvisoSeguridad_496e65d208 ;
    ns1:textoExtracto "'CNC trabajando en Modo Puesta a Punto'" .

ns1:CambiarAlModoUsuarioUtilizandoDiskMonitor a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar al modo usuario utilizando DiskMonitor" ;
    ns1:solucionaFallo ns1:ElCNCHaArrancadoEnModoPuestaAPuntoYEstaTrabajandoConElDiscoDesprotegido ;
    ns1:textoExtracto "utilice la utilidad DiskMonitor para pasar a modo usuario y trabajar con el disco protegido. Volver a arrancar el CNC." .

ns1:AvisoSeguridad_496e65d208 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad en Modo Puesta a Punto" ;
    ns1:mitigaRiesgo ns1:RealizarPuestaAPuntoDelCNCSinNecesidad ;
    ns1:textoExtracto "'CNC trabajando en Modo Puesta a Punto'" .

ns1:ElCNCHaArrancadoEnModoPuestaAPuntoYEstaTrabajandoConElDiscoDesprotegido a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido" ;
    ns1:textoExtracto "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ns1:RealizarPuestaAPuntoDelCNCSinNecesidad a ns1:AccionProhibida ;
    rdfs:label "Realizar puesta a punto del CNC sin necesidad" ;
    ns1:textoExtracto "Si no va a realizar la puesta a punto del CNC, apaguelo y utilice la utilidad DiskMonitor para pasar a modo usuario y trabajar con el disco protegido." .

