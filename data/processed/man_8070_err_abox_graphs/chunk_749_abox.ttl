@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d8893a5d6a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:LaCarpetaDRIVERSNoExiste,
        ns1:LaCarpetaUSERSNoExiste,
        ns1:LosSiguientesPasswordsDeAccesoEstanAunPorDefinir,
        ns1:PuestaAPuntoIncompletaNoSeHaEncontradoNingunaCopiaDeSeguridad ;
    ns1:textoExtracto "CNC 8070" .

ns1:CrearCarpetaDrivers a ns1:TareaMantenimiento ;
    rdfs:label "Crear Carpeta Drivers" ;
    ns1:solucionaFallo ns1:LaCarpetaDRIVERSNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Desde el modo utilidades, usar la opción \"Nuevo directorio\" del menú de softkeys para crear la carpeta." .

ns1:CrearCarpetaUsers a ns1:TareaMantenimiento ;
    rdfs:label "Crear Carpeta Users" ;
    ns1:solucionaFallo ns1:LaCarpetaUSERSNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Desde el modo utilidades, usar la opción \"Nuevo directorio\" del menú de softkeys para crear la carpeta." .

ns1:DefinirPasswordsDeAcceso a ns1:TareaMantenimiento ;
    rdfs:label "Definir Passwords de Acceso" ;
    ns1:solucionaFallo ns1:LosSiguientesPasswordsDeAccesoEstanAunPorDefinir ;
    ns1:textoExtracto "SOLUCIÓN Con el CNC arrancado, acceder al modo utilidades y desde la opción \"Códigos de acceso\" del menú de softkeys introducir los passwords indicados." .

ns1:HacerCopiaDeSeguridadDePuestaAPunto a ns1:TareaMantenimiento ;
    rdfs:label "Hacer Copia de Seguridad de Puesta a Punto" ;
    ns1:solucionaFallo ns1:PuestaAPuntoIncompletaNoSeHaEncontradoNingunaCopiaDeSeguridad ;
    ns1:textoExtracto "SOLUCIÓN Al apagar el CNC, seleccionar la opción \"Cerrar y hacer copia de seguridad\", para que el CNC haga una copia de seguridad de la puesta a punto." .

ns1:LaCarpetaDRIVERSNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La carpeta DRIVERS no existe" ;
    ns1:textoExtracto "'La carpeta DRIVERS no existe' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se ubicará el PLC una vez generado (C:\\CNC8070\\Drivers)." .

ns1:LaCarpetaUSERSNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La carpeta USERS no existe" ;
    ns1:textoExtracto "'La carpeta USERS no existe' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta de trabajo del usuario (C:\\CNC8070\\Users)." .

ns1:LosSiguientesPasswordsDeAccesoEstanAunPorDefinir a ns1:DiagnosticoFallo ;
    rdfs:label "Los siguientes passwords de acceso están aún por definir" ;
    ns1:textoExtracto "'Los siguientes passwords de acceso están aún por definir' DETECCIÓN Durante el arranque de un CNC abierto, en modo puesta a punto. CAUSA Los passwords de acceso indicados en el aviso no están definidos." .

ns1:PuestaAPuntoIncompletaNoSeHaEncontradoNingunaCopiaDeSeguridad a ns1:DiagnosticoFallo ;
    rdfs:label "Puesta a punto incompleta: No se ha encontrado ninguna copia de seguridad" ;
    ns1:textoExtracto "'Puesta a punto incompleta:No se ha encontrado ninguna copia de seguridad' DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC no ha encontrado ninguna copia de seguridad de la puesta a punto." .

