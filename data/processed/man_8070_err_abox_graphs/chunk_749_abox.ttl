@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorPLC_8768
    a ex:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la instrucción AND (Código 8768)"@es ;
    ex:identificador "8768" ;
    ex:textoExtracto "8768 Faltan dos argumentos en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación AND. SOLUCIÓN Programar \"AND operando operando resultado\"."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Omisión de dos argumentos en operación AND"@es ;
        ex:textoExtracto "Faltan dos argumentos en la operación AND."@es
    ] .

ex:ErrorPLC_8769
    a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la instrucción AND (Código 8769)"@es ;
    ex:identificador "8769" ;
    ex:textoExtracto "8769 Faltan todos argumentos en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los"@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Omisión total de argumentos en operación AND"@es ;
        ex:textoExtracto "Faltan todos los argumentos en la instrucción de acción AND."@es
    ] .

ex:SintaxisCorrecta_AND
    a ex:Parametro ;
    rdfs:label "Sintaxis correcta para operación AND"@es ;
    ex:valor "\"AND operando operando resultado\"" ;
    ex:textoExtracto "Programar \"AND operando operando resultado\"."@es .