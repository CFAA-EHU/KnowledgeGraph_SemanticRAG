ex:InterfazProgramacionPLC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación del PLC" ;
    ex:textoExtracto "Durante la edición del programa PLC." ;
    ex:activaAlarma ex:Error8769, ex:Error8770, ex:Error8771, ex:Error8772, ex:Error8773, ex:Error8774, ex:Error8775, ex:Error8776, ex:Error8777 .