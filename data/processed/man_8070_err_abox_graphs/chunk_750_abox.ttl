@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8769
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8769: Faltan todos los argumentos en la instrucción AND" ;
    ex:identificador "8769" ;
    ex:textoExtracto "8769 Faltan todos argumentos en la instrucción de acción AND. [...] SOLUCIÓN Programar \"AND operando operando resultado\"." .

