@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_57e1af87ac a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:MemoriaEnDiscoPorDebajoDelMinimoRecomendadoParaElCorrectoFuncionamientoDelCNC_5c4b762d23,
        ns1:MemoriaPorDebajoDelMinimoRecomendado,
        ns1:NoSeAdmiteMDIEnINSPECCIONEnElEstadoActual_754f98e28f ;
    ns1:textoExtracto "CNC 8070" .

ns1:CerrarAplicacionesDeTerceros a ns1:TareaMantenimiento ;
    rdfs:label "Cerrar aplicaciones de terceros" ;
    ns1:solucionaFallo ns1:FalloCargaSoftwareTeclado,
        ns1:MemoriaRAMDisponiblePorDebajoDel10 ;
    ns1:textoExtracto "Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla." .

ns1:LiberarMemoriaEnDiscoAntesDelArranqueDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Liberar memoria en disco antes del arranque del CNC" ;
    ns1:solucionaFallo ns1:FalloMemoriaDisco ;
    ns1:textoExtracto "Hay que liberar memoria en disco para poder arrancar el CNC." .

ns1:ReiniciarCNC_dea41ef440 a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar CNC" ;
    ns1:solucionaFallo ns1:FalloCargaSoftwareTeclado,
        ns1:MemoriaRAMDisponiblePorDebajoDel10 ;
    ns1:textoExtracto "Apagar y encender el CNC." .

ns1:VerificarConfiguracionCANYConexionDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Verificar configuración CAN y conexión del sistema" ;
    ns1:solucionaFallo ns1:FalloCargaSoftwareTeclado ;
    ns1:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:FalloMemoriaDisco a ns1:DiagnosticoFallo ;
    rdfs:label "Menos de 50 MB de memoria libre en disco" ;
    ns1:textoExtracto "El CNC ha detectado menos de 50 MB de memoria libre en disco." .

ns1:MemoriaEnDiscoPorDebajoDelMinimoRecomendadoParaElCorrectoFuncionamientoDelCNC_5c4b762d23 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria en disco por debajo del mínimo recomendado para el correcto funcionamiento del CNC" ;
    ns1:textoExtracto "'Memoria en disco por debajo del mínimo recomendado para el correcto funcionamiento del CNC. Libere memoria en disco antes del arranque del CNC'" .

ns1:MemoriaPorDebajoDelMinimoRecomendado a ns1:AvisoSeguridad ;
    rdfs:label "Memoria por debajo del mínimo recomendado" ;
    ns1:textoExtracto "'Memoria por debajo del mínimo recomendado. Es necesario reiniciar'" .

ns1:NoSeAdmiteMDIEnINSPECCIONEnElEstadoActual_754f98e28f a ns1:AvisoSeguridad ;
    rdfs:label "No se admite MDI en INSPECCIÓN en el estado actual" ;
    ns1:textoExtracto "'No se admite MDI en INSPECCIÓN en el estado actual'" .

ns1:MemoriaRAMDisponiblePorDebajoDel10 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria RAM disponible por debajo del 10%" ;
    ns1:textoExtracto "El CNC ha detectado que la memoria RAM disponible esta por debajo del 10% de la memoria RAM total." .

ns1:FalloCargaSoftwareTeclado a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclado" ;
    ns1:textoExtracto "'Error cargando software de teclado'" .

