@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApagarYEncenderElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Apagar y encender el CNC" ;
    ns1:textoExtracto "Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:LiberarMemoriaEnDisco a ns1:TareaMantenimiento ;
    rdfs:label "Liberar memoria en disco" ;
    ns1:solucionaFallo ns1:FalloMemoriaInsuficiente ;
    ns1:textoExtracto "SOLUCIÓN Hay que liberar memoria en disco para poder arrancar el CNC. • Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo" .

ns1:FalloMemoriaInsuficiente a ns1:DiagnosticoFallo ;
    rdfs:label "'Memoria por debajo del mínimo recomendado para la ejecución'" ;
    ns1:textoExtracto "8041 'Memoria por debajo del mínimo recomendado para la ejecución' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco." .

