@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8787
    a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación RL2" ;
    ex:identificador "8787" ;
    ex:textoExtracto "Faltan todos argumentos en la operación RL2. [...] SOLUCIÓN Programar 'RL2 origen rotaciones destino'." .

ex:Error_8788
    a ex:DiagnosticoFallo ;
    rdfs:label "Índice final menor que inicial en ERA" ;
    ex:identificador "8788" ;
    ex:textoExtracto "Índice final menor que inicial en ERA. [...] SOLUCIÓN Programar 'ERA recurso índice'. El índice debe ser mayor que el recurso." .

ex:Error_8789
    a ex:DiagnosticoFallo ;
    rdfs:label "Índice final fuera de rango en ERA" ;
    ex:identificador "8789" ;
    ex:textoExtracto "Índice final fuera de rango en ERA. [...] SOLUCIÓN El rango válido para cada recurso es el siguiente: Entradas (I1-I1024), Salidas (O1-O1024), Entradas locales (LI1-LI16), Salidas locales (LO1-LO8), Marcas (M1-M8192), Mensajes (MSG1-MSG1024), Errores (ERR1-ERR1024), Relojes (CLK), Registros (R1-R1024), Estado de los temporizadores (T1-T512), Estado de los contadores (C1-C256)." .

ex:Error_8790
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta índice final en ERA" ;
    ex:identificador "8790" ;
    ex:textoExtracto "Falta índice final en ERA. [...] SOLUCIÓN Programar 'ERA recurso índice'." .

ex:Error_8791
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta recurso inicial e índice final en ERA" ;
    ex:identificador "8791" ;
    ex:textoExtracto "Falta recurso inicial e índice final en ERA. [...] SOLUCIÓN Programar 'ERA recurso índice'." .

ex:Error_8792
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta destino en PAR" ;
    ex:identificador "8792" ;
    ex:textoExtracto "Falta destino en PAR. [...] SOLUCIÓN Programar 'PAR recurso recurso'." .

ex:Error_8793
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta origen y destino en PAR" ;
    ex:identificador "8793" ;
    ex:textoExtracto "Falta origen y destino en PAR." .

ex:Instruccion_RL2
    a ex:Parametro ;
    rdfs:label "Operación RL2" ;
    ex:textoExtracto "operación RL2. SOLUCIÓN Programar 'RL2 origen rotaciones destino'." ;
    ex:valor "RL2 origen rotaciones destino" .

ex:Instruccion_ERA
    a ex:Parametro ;
    rdfs:label "Instrucción ERA" ;
    ex:textoExtracto "instrucción ERA. SOLUCIÓN Programar 'ERA recurso índice'." ;
    ex:valor "ERA recurso índice" .

ex:Instruccion_PAR
    a ex:Parametro ;
    rdfs:label "Instrucción PAR" ;
    ex:textoExtracto "instrucción PAR. SOLUCIÓN Programar 'PAR recurso recurso'." ;
    ex:valor "PAR recurso recurso" .

ex:Rango_Entradas
    a ex:Parametro ;
    rdfs:label "Rango de entradas" ;
    ex:identificador "I1-I1024" ;
    ex:textoExtracto "Entradas (I1-I1024)." .

