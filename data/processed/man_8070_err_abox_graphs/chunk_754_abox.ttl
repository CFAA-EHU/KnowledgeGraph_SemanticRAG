    a ex:Parametro ;
    rdfs:label "Rango de salidas" ;
    ex:identificador "O1-O1024" ;
    ex:textoExtracto "Salidas (O1-O1024)." .

ex:Rango_EntradasLocales
    a ex:Parametro ;
    rdfs:label "Rango de entradas locales" ;
    ex:identificador "LI1-LI16" ;
    ex:textoExtracto "Entradas locales (LI1-LI16)." .

ex:Rango_SalidasLocales
    a ex:Parametro ;
    rdfs:label "Rango de salidas locales" ;
    ex:identificador "LO1-LO8" ;
    ex:textoExtracto "Salidas locales (LO1-LO8)." .

ex:Rango_Marcas
    a ex:Parametro ;
    rdfs:label "Rango de marcas" ;
    ex:identificador "M1-M8192" ;
    ex:textoExtracto "Marcas (M1-M8192)." .

ex:Rango_Mensajes
    a ex:Parametro ;
    rdfs:label "Rango de mensajes" ;
    ex:identificador "MSG1-MSG1024" ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024)." .

ex:Rango_Errores
    a ex:Parametro ;
    rdfs:label "Rango de errores" ;
    ex:identificador "ERR1-ERR1024" ;
    ex:textoExtracto "Errores (ERR1-ERR1024)." .

ex:Rango_Relojes
    a ex:Parametro ;
    rdfs:label "Rango de relojes" ;
    ex:identificador "CLK" ;
    ex:textoExtracto "Relojes (CLK)." .

ex:Rango_Registros
    a ex:Parametro ;
    rdfs:label "Rango de registros" ;
    ex:identificador "R1-R1024" ;
    ex:textoExtracto "Registros (R1-R1024)." .

ex:Rango_Temporizadores
    a ex:Parametro ;
    rdfs:label "Rango de temporizadores" ;
    ex:identificador "T1-T512" ;
    ex:textoExtracto "Estado de los temporizadores (T1-T512)." .

ex:Rango_Contadores
    a ex:Parametro ;
    rdfs:label "Rango de contadores" ;
    ex:identificador "C1-C256" ;
    ex:textoExtracto "Estado de los contadores (C1-C256)." .

ex:Error_8789
    ex:solucionaFallo ex:Instruccion_ERA .

ex:Error_8787
    ex:solucionaFallo ex:Instruccion_RL2 .

ex:Error_8792
    ex:solucionaFallo ex:Instruccion_PAR .