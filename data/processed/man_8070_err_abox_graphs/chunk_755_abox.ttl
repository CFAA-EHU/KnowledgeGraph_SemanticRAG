@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionApagarYUsarDiskMonitor a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloModoNoSeguro ;
    ns1:textoExtracto "'CNC trabajando en modo NO seguro'" .

ns1:AccionFinalizarPuestaAPunto a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloPuestaAPuntoIncompleta ;
    ns1:textoExtracto "'Puesta a punto incompleta'" .

ns1:AccionReiniciarCNC a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloCodigoValidacionTemporalExpirado ;
    ns1:textoExtracto "'El código de validación temporal ha expirado. Reinicie el CNC'" .

ns1:AccionReiniciarCNCAgain a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloCodigoValidacionTemporalCancelado ;
    ns1:textoExtracto "'El código de validación temporal ha sido cancelado. Reinicie el CNC'" .

ns1:AccionVerificarAccesoArchivoUsuario a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloRestauracionSesionUsuario ;
    ns1:textoExtracto "'Error restaurando sesión de Usuario'" .

ns1:AccionVerificarConfiguracionCAN a ns1:AccionProhibida ;
    ns1:solucionaFallo ns1:FalloCargaSoftwareRIOR ;
    ns1:textoExtracto "'Error cargando software de RIOR'" .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:FalloCargaSoftwareRIOR a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de RIOR" ;
    ns1:textoExtracto "'Error cargando software de RIOR'" .

ns1:FalloCodigoValidacionTemporalCancelado a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación temporal ha sido cancelado" ;
    ns1:textoExtracto "'El código de validación temporal ha sido cancelado. Reinicie el CNC'" .

ns1:FalloCodigoValidacionTemporalExpirado a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación temporal ha expirado" ;
    ns1:textoExtracto "'El código de validación temporal ha expirado. Reinicie el CNC'" .

ns1:FalloModoNoSeguro a ns1:DiagnosticoFallo ;
    rdfs:label "CNC trabajando en modo NO seguro" ;
    ns1:textoExtracto "'CNC trabajando en modo NO seguro'" .

ns1:FalloPuestaAPuntoIncompleta a ns1:DiagnosticoFallo ;
    rdfs:label "Puesta a punto incompleta" ;
    ns1:textoExtracto "'Puesta a punto incompleta'" .

ns1:FalloRestauracionSesionUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Error restaurando sesión de Usuario" ;
    ns1:textoExtracto "'Error restaurando sesión de Usuario'" .

