@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8792
    a ex:Alarma ;
    rdfs:label "Falta destino en PAR" ;
    ex:textoExtracto "8792 Falta destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." ;
    ex:identificador "8792" .

ex:Alarma_8793
    a ex:Alarma ;
    rdfs:label "Falta origen y destino en PAR" ;
    ex:textoExtracto "8793 Falta origen y destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta origen y destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." ;
    ex:identificador "8793" .

ex:Alarma_8794
    a ex:Alarma ;
    rdfs:label "Cadena de error vacía" ;
    ex:textoExtracto "8794 Cadena de error vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un error sin texto. SOLUCIÓN Definir el texto de error." ;
    ex:identificador "8794" .

ex:Alarma_8795
    a ex:Alarma ;
    rdfs:label "Error sintáctico. No se esperaba %" ;
    ex:textoExtracto "8795 Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La instrucción programada no admite el" ;
    ex:identificador "8795" .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema de programación PLC" ;
    ex:textoExtracto "Durante la edición del programa PLC" ;
    ex:activaAlarma ex:Alarma_8792, ex:Alarma_8793, ex:Alarma_8794, ex:Alarma_8795 .