@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:PongaseEnContactoConSuProveedor_72a67cdea2 a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con su proveedor" ;
    ns1:solucionaFallo ns1:ElCNCHaSidoBloqueadoDebidoAUnaViolacionDeLosTerminosDeUso,
        ns1:ElPeriodoDeServicioEstaAPuntoDeExpirar,
        ns1:ElPeriodoDeServicioHaExpirado,
        ns1:LaSumaDeEjesYCabezalesNoDebeSuperarElValorMaximo ;
    ns1:textoExtracto "SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:ElCNCHaSidoBloqueadoDebidoAUnaViolacionDeLosTerminosDeUso a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha sido bloqueado debido a una violación de los términos de uso" ;
    ns1:textoExtracto "8055 El CNC ha sido bloqueado debido a una violación de los términos de uso. Contacte con el OEM." .

ns1:ElPeriodoDeServicioEstaAPuntoDeExpirar a ns1:DiagnosticoFallo ;
    rdfs:label "El periodo de servicio esta a punto de expirar" ;
    ns1:textoExtracto "8053 El periodo de servicio esta a punto de expirar. Contacte con el OEM para obtener un código de actualización." .

ns1:ElPeriodoDeServicioHaExpirado a ns1:DiagnosticoFallo ;
    rdfs:label "El periodo de servicio ha expirado" ;
    ns1:textoExtracto "8054 El periodo de servicio ha expirado. Contacte con el OEM para obtener un código de actualización." .

ns1:LaSumaDeEjesYCabezalesNoDebeSuperarElValorMaximo a ns1:DiagnosticoFallo ;
    rdfs:label "La suma de ejes y cabezales no debe superar el valor máximo" ;
    ns1:textoExtracto "8052 La suma de ejes y cabezales no debe superar el valor máximo. DETECCIÓN Durante el arranque del CNC. CAUSA La suma de ejes de cabezales supera el valor máximo." .

