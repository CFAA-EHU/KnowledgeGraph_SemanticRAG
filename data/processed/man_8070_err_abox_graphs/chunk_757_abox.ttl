@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8808
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8808: Operandos OR iguales"@es ;
    ex:identificador "8808" ;
    ex:textoExtracto "Los operandos de la expresión OR son iguales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Dos operandos de la expresión \"OR\" iguales. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ex:Error8809
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8809: Operandos AND iguales"@es ;
    ex:identificador "8809" ;
    ex:textoExtracto "Los operandos de la expresión AND son iguales."@es .

ex:ErrorCAM_FOLLOWOFF
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación: Comando CAM/FOLLOWOFF sin eje esclavo"@es ;
    ex:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .