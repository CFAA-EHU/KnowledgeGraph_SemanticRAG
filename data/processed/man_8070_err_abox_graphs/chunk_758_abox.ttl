@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8809
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8809: operandos AND iguales" ;
    ex:identificador "8809" ;
    ex:textoExtracto "Los operandos de la expresión AND son iguales. [...] SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error8810
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8810: operandos XOR iguales" ;
    ex:identificador "8810" ;
    ex:textoExtracto "Los operandos de la expresión XOR son iguales. [...] SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error8811
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8811: operandos CPS iguales" ;
    ex:identificador "8811" ;
    ex:textoExtracto "Los operandos de la expresión CPS son iguales. [...] SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error8812
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8812: recursos MOV iguales" ;
    ex:identificador "8812" ;
    ex:textoExtracto "Los recursos del MOV son iguales. [...] SOLUCIÓN Programar recursos de origen y destino diferentes." .

ex:Error8813
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8813: registros MOV iguales" ;
    ex:identificador "8813" ;
    ex:textoExtracto "Los registros del MOV son iguales. [...] SOLUCIÓN Programar los registros de origen y destino diferentes." .

ex:Error8814
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8814: símbolo comienza por dígito" ;
    ex:identificador "8814" ;
    ex:textoExtracto "Un símbolo no puede comenzar por un dígito. [...] SOLUCIÓN Los símbolos deben comenzar por una letra o por el carácter \"/\" seguido de una letra." .

ex:Error8815
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8815: entrada digital fuera de rango" ;
    ex:identificador "8815" ;
    ex:textoExtracto "Entrada fuera de rango permitido. [...] SOLUCIÓN Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16." .

ex:Error8816
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8816: salida digital fuera de rango" ;
    ex:identificador "8816" ;
    ex:textoExtracto "Salida fuera de rango permitido. [...] CAUSA El número de la salida digital no es válido." .

ex:ManualInstalacionPLC
    a ex:Manual ;
    rdfs:label "Manual de instalación del PLC" ;
    ex:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ex:Error8809 ex:solucionaFallo ex:ManualInstalacionPLC .
ex:Error8810 ex:solucionaFallo ex:ManualInstalacionPLC .
ex:Error8811 ex:solucionaFallo ex:ManualInstalacionPLC .