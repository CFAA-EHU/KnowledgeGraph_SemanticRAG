@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeFechaNoPermitido a ns1:AccionProhibida ;
    rdfs:label "cambio de fecha no permitido" ;
    ns1:textoExtracto "El CNC está bloqueado porque ha detectado un cambio de fecha no permitido." .

ns1:PongaseEnContactoConElOEM a ns1:AvisoSeguridad ;
    rdfs:label "Póngase en contacto con el OEM" ;
    ns1:mitigaRiesgo ns1:CNC8070_b30e176db5 ;
    ns1:textoExtracto "Póngase en contacto con el OEM." .

ns1:CNC8070_b30e176db5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:ElCNCHaSidoBloqueadoDebidoAUnaViolacionDeLosTerminosDeUso,
        ns1:InconsistenciaEnLaRecuperacionDeLasPosicionesDeLasHerramientasEnElAlmacen ;
    ns1:textoExtracto "CNC 8070" .

ns1:ElCNCHaSidoBloqueadoDebidoAUnaViolacionDeLosTerminosDeUso a ns1:DiagnosticoFallo ;
    rdfs:label "El CNC ha sido bloqueado debido a una violación de los términos de uso" ;
    ns1:textoExtracto "8055 El CNC ha sido bloqueado debido a una violación de los términos de uso. Contacte con el OEM." .

ns1:InconsistenciaEnLaRecuperacionDeLasPosicionesDeLasHerramientasEnElAlmacen a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén" ;
    ns1:textoExtracto "8056 Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén." .

