@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VerificarLaConfiguracionEtherCATConexionesVersionDeBootYAplicacionDeNodosRemotos a ns1:TareaMantenimiento ;
    rdfs:label "Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos" ;
    ns1:solucionaFallo ns1:ErrorDuranteElProcesoDeRecuperacionDeDatosDeFRAM ;
    ns1:textoExtracto "SOLUCIÓN Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos." .

ns1:ErrorDuranteElProcesoDeRecuperacionDeDatosDeFRAM a ns1:DiagnosticoFallo ;
    rdfs:label "Error durante el proceso de recuperación de datos de FRAM" ;
    ns1:textoExtracto "8128 No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM." .

