ex:Error_8824
    a ex:AvisoSeguridad ;
    rdfs:label "Pantalla fuera de rango" ;
    ex:identificador "8824" ;
    ex:textoExtracto "8824 Pantalla fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA La pantalla programada no es válida. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error_8825
    a ex:AvisoSeguridad ;
    rdfs:label "Fallo del lexer al reconocer pantallas" ;
    ex:identificador "8825" ;
    ex:textoExtracto "8825 Fallo del lexer al reconocer pantallas. DETECCIÓN" .

ex:Error_Conversi_nCadena
    a ex:AvisoSeguridad ;
    rdfs:label "Error al convertir una cadena de caracteres" ;
    ex:textoExtracto "CAUSA Error al convertir una cadena de caracteres a errores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .