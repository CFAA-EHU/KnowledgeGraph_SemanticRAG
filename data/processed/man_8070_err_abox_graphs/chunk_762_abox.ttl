@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarAntesDelNombreDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Programar '#' antes del nombre de la sentencia" ;
    ns1:solucionaFallo ns1:FaltaAntesDelNombreDeLaInstruccionDeControl ;
    ns1:textoExtracto "SOLUCIÓN Programar '#' antes del nombre de la sentencia." .

ns1:ReducirElNombreDelProgramaOSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el nombre del programa o subrutina" ;
    ns1:solucionaFallo ns1:NombreDeProgramaOSubrutinaDemasiadoLargo ;
    ns1:textoExtracto "SOLUCIÓN Programar '$' antes del nombre de la instrucción de control." .

ns1:FaltaAntesDelNombreDeLaInstruccionDeControl a ns1:DiagnosticoFallo ;
    rdfs:label "Falta '#' antes del nombre de la instrucción de control" ;
    ns1:textoExtracto "'Falta '#'' DETECCIÓN Durante la edición. CAUSA Programada una sentencia sin el carácter de inicio '#'. SOLUCIÓN Programar '#' antes del nombre de la sentencia." .

ns1:NombreDeProgramaOSubrutinaDemasiadoLargo a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de programa o subrutina demasiado largo" ;
    ns1:textoExtracto "'Nombre de programa o subrutina demasiado largo' DETECCIÓN Durante la edición. CAUSA Superado el máximo número de caracteres" .

