@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarLaSintaxisDeLaInstruccion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la sintaxis de la instrucción" ;
    ns1:solucionaFallo ns1:ExcedidoFormatoParaFuncion ;
    ns1:textoExtracto "SOLUCIÓN Revisar la sintaxis de la instrucción." .

ns1:RevisarLaSintaxisDeLaSentenciaEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la sintaxis de la sentencia en el manual de programación" ;
    ns1:solucionaFallo ns1:ExcedidosLimitesParaFlotantes ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ExcedidoFormatoParaFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "Excedido formato para función" ;
    ns1:textoExtracto "'Excedido formato para función'" .

ns1:ExcedidosLimitesParaFlotantes a ns1:DiagnosticoFallo ;
    rdfs:label "Excedidos límites para flotantes" ;
    ns1:textoExtracto "'Excedidos límites para flotantes'" .

