@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8839
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque (TG1)"@es ;
    ex:identificador "8839" ;
    ex:textoExtracto "Falta índice de entrada de arranque. Suponemos TG1. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta programar el índice de la entrada de arranque. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Programar entrada de arranque (TG1-TG4)"@es ;
        ex:textoExtracto "Programar una entrada de arranque dentro del rango TG1 a TG4."@es
    ] .

ex:Fallo_8840
    a ex:DiagnosticoFallo ;
    rdfs:label "Recurso obsoleto PIC/PAG (sustituido por MSG)"@es ;
    ex:identificador "8840" ;
    ex:textoExtracto "Recurso obsoleto PIC o PAG; sustituido por MSG."@es .

ex:Fallo_8839_ProgramaPLC
    a ex:Sistema ;
    rdfs:label "Programa PLC con error de índice de arranque"@es ;
    ex:textoExtracto "Durante la edición del programa PLC."@es ;
    ex:tieneComponente [
        a ex:Parametro ;
        rdfs:label "Índice de entrada de arranque (TG1-TG4)"@es ;
        ex:textoExtracto "Falta programar el índice de la entrada de arranque."@es ;
        ex:valor "TG1"  # Valor por defecto asumido
    ] .