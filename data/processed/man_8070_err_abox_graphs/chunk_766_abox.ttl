@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorPLC_8840
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8840: Recurso obsoleto PIC o PAG"@es ;
    ex:identificador "8840" ;
    ex:textoExtracto "Recurso obsoleto PIC o PAG; sustituido por MSG. DETECCIÓN Durante la edición del programa PLC. CAUSA Ambos recursos ya no son válidos. SOLUCIÓN Es posible que ambos recursos pertenezcan a otra familia de CNCs o hayan cambiado de nombre. No es posible utilizar ambos registros y el PLC los ha sustituido por MSG."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Uso de recursos PIC o PAG en PLC"@es ;
        ex:textoExtracto "No es posible utilizar ambos registros y el PLC los ha sustituido por MSG."@es
    ] .

ex:ErrorPLC_8841
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8841: Falta directiva de comienzo de módulo o subrutina"@es ;
    ex:identificador "8841" ;
    ex:textoExtracto "Se esperaba directiva de comienzo de módulo o subrutina. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programado algún módulo o subrutina y falta la directiva de comienzo. SOLUCIÓN Programar la directiva CY1, PRG, PE al comienzo del módulo, o SUB al comienzo de cada subrutina."@es .

ex:ErrorPLC_8842
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8842: Consulta esperada en lugar de %"@es ;
    ex:identificador "8842" ;
    ex:textoExtracto "Se esperaba consulta en lugar de %. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una consulta. SOLUCIÓN Programar una consulta."@es .

ex:ErrorPLC_8843
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8843: Acción esperada en lugar de %"@es ;
    ex:identificador "8843" ;
    ex:textoExtracto "Se esperaba acción en lugar de %. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una acción. SOLUCIÓN Programar una acción."@es .

ex:ErrorPLC_8844
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8844: Falta consulta previa"@es ;
    ex:identificador "8844" ;
    ex:textoExtracto "Falta consulta previa. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una consulta para poder ejecutar la instrucción. SOLUCIÓN Revisar la sintaxis."@es .

ex:ErrorPLC_8845
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8845: Marca de sistema redefinida"@es ;
    ex:identificador "8845" ;
    ex:textoExtracto "Marca de sistema redefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (marcas) con el mismo nombre. SOLUCIÓN Revisar el nombre de las marcas."@es .

ex:ErrorPLC_8846
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8846: Símbolo de usuario redefinido"@es ;
    ex:identificador "8846" ;
    ex:textoExtracto "Símbolo de usuario redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos símbolos con el mismo nombre. SOLUCIÓN Revisar el nombre de los símbolos."@es .

ex:ErrorPLC_8847
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8847: Demasiados símbolos de usuario"@es ;
    ex:identificador "8847" ;
    ex:textoExtracto "Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definidos más de 100 símbolos PDEF."@es .

ex:ErrorPLC_IndiceArranque
    a ex:DiagnosticoFallo ;
    rdfs:label "Error: Falta programar índice de entrada de arranque"@es ;
    ex:textoExtracto "CAUSA Falta programar el índice de la entrada de arranque. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Falta de programación de índice de entrada TG1-TG4"@es ;
        ex:textoExtracto "Falta programar el índice de la entrada de arranque."@es
    ] .