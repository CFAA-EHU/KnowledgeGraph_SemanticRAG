@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarEnElManualDeProgramacionLasFuncionesExistentes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación las funciones existentes" ;
    ns1:solucionaFallo ns1:LaFuncionMProgramadaNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:RevisarEnElManualDeProgramacionLasFuncionesGExistentes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación las funciones G existentes" ;
    ns1:solucionaFallo ns1:LaFuncionGProgramadaNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación las funciones G existentes." .

ns1:RevisarEnElManualDeProgramacionLasFuncionesHExistentes a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación las funciones H existentes" ;
    ns1:solucionaFallo ns1:LaFuncionHProgramadaNoExiste ;
    ns1:textoExtracto "SOLUCIÓN Revisar" .

ns1:LaFuncionGProgramadaNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La función G programada no existe" ;
    ns1:textoExtracto "CAUSA La función G programada no existe." .

ns1:LaFuncionHProgramadaNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La función H programada no existe" ;
    ns1:textoExtracto "CAUSA La función H programada no existe." .

ns1:LaFuncionMProgramadaNoExiste a ns1:DiagnosticoFallo ;
    rdfs:label "La función M programada no existe" ;
    ns1:textoExtracto "CAUSA La función M programada no existe." .

