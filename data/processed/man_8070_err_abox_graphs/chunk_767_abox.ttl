    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación las funciones H existentes." .

ns1:RevisarLaSintaxisDeLaSentenciaEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la sintaxis de la sentencia en el manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

