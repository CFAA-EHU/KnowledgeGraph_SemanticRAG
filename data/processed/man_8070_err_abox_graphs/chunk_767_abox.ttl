@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ADoblementeProgramada a ns1:AccionProhibida ;
    rdfs:label "A doblemente programada" ;
    ns1:solucionaFallo ns1:ProgramarElEjeAUnaSolaVezEnElBloque ;
    ns1:textoExtracto "'A doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje A más de una vez en el bloque." .

ns1:AccionProhibida_cc7806f78b a ns1:AccionProhibida ;
    rdfs:label "Función H fuera de rango" ;
    ns1:solucionaFallo ns1:RevisarFuncionesHExistentesEnElManualDeProgramacion ;
    ns1:textoExtracto "'Función H fuera de rango' DETECCIÓN Durante la edición. CAUSA La función H programada no existe." .

ns1:BDoblementeProgramada a ns1:AccionProhibida ;
    rdfs:label "B doblemente programada" ;
    ns1:solucionaFallo ns1:ProgramarElEjeBUnaSolaVezEnElBloque ;
    ns1:textoExtracto "'B doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje B más de una vez en el bloque." .

ns1:CDoblementeProgramada_f7548b35a4 a ns1:AccionProhibida ;
    rdfs:label "C doblemente programada" ;
    ns1:solucionaFallo ns1:ProgramarElEjeCUnaSolaVezEnElBloque ;
    ns1:textoExtracto "'C doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje C más de una vez en el bloque." .

ns1:FOEFueraDeRango a ns1:AccionProhibida ;
    rdfs:label "F o E fuera de rango" ;
    ns1:solucionaFallo ns1:RevisarLaSintaxisDeLaSentenciaEnElManualDeProgramacion ;
    ns1:textoExtracto "'F o E fuera de rango' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:NumeroDeHerramientaFueraDeRango a ns1:AccionProhibida ;
    rdfs:label "Número de herramienta fuera de rango" ;
    ns1:solucionaFallo ns1:ElNumeroDeHerramientaHaDeSerSiemprePositivoONulo ;
    ns1:textoExtracto "'Número de herramienta fuera de rango' DETECCIÓN Durante la edición. CAUSA Programado un número de herramienta negativo." .

ns1:RevisarFuncionesGExistentesEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar funciones G existentes en el manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación las funciones G existentes." .

ns1:SoloSePermiteUnaSNegativaConG63 a ns1:AccionProhibida ;
    rdfs:label "Sólo se permite una S negativa con G63" ;
    ns1:solucionaFallo ns1:LaVelocidadDeCabezalDebeSerPositiva ;
    ns1:textoExtracto "'Sólo se permite una S negativa con G63' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de cabezal negativa sin haber programado la función G63 en el bloque." .

ns1:UDoblementeProgramada_ea95dd0eb1 a ns1:AccionProhibida ;
    rdfs:label "U doblemente programada" ;
    ns1:textoExtracto "'U doblemente programada' DETECCIÓN Durante la edición." .

ns1:VelocidadFDoblementeProgramada_deafcfe44b a ns1:AccionProhibida ;
    rdfs:label "Velocidad F doblemente programada" ;
    ns1:solucionaFallo ns1:ProgramarLaFuncionFUnaSolaVezEnElBloque ;
    ns1:textoExtracto "'Velocidad F doblemente programada' DETECCIÓN Durante la edición. CAUSA La función F está programada más de una vez en el bloque." .

ns1:ElNumeroDeHerramientaHaDeSerSiemprePositivoONulo a ns1:TareaMantenimiento ;
    rdfs:label "El número de herramienta ha de ser siempre positivo o nulo" ;
    ns1:textoExtracto "SOLUCIÓN El número de herramienta ha de ser siempre positivo o nulo." .

ns1:LaVelocidadDeCabezalDebeSerPositiva a ns1:TareaMantenimiento ;
    rdfs:label "La velocidad de cabezal debe ser positiva" ;
    ns1:textoExtracto "SOLUCIÓN La velocidad de cabezal debe ser positiva; sólo se permite un valor negativo si se programa en el mismo bloque que la función G63." .

ns1:ProgramarElEjeAUnaSolaVezEnElBloque a ns1:TareaMantenimiento ;
    rdfs:label "Programar el eje A una sola vez en el bloque" ;
    ns1:textoExtracto "SOLUCIÓN Programar el eje A una sola vez en el bloque." .

