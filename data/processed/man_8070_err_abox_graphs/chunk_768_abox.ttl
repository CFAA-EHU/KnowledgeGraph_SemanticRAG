@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarElEjeCMasDeUnaVezEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Programar el eje C más de una vez en el bloque" ;
    ns1:textoExtracto "CAUSA Programado el eje C más de una vez en el bloque." .

ns1:ProgramarElEjeUMasDeUnaVezEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Programar el eje U más de una vez en el bloque" ;
    ns1:textoExtracto "CAUSA Programado el eje U más de una vez en el bloque." .

ns1:ProgramarElEjeVMasDeUnaVezEnElBloque a ns1:AccionProhibida ;
    rdfs:label "Programar el eje V más de una vez en el bloque" ;
    ns1:textoExtracto "CAUSA Programado el eje V más de una vez en el bloque." .

ns1:SolucionParaCDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para 'C doblemente programada'" ;
    ns1:solucionaFallo ns1:CDoblementeProgramada ;
    ns1:textoExtracto "SOLUCIÓN Programar el eje C una sola vez en el bloque." .

ns1:SolucionParaUDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para 'U doblemente programada'" ;
    ns1:solucionaFallo ns1:UDoblementeProgramada ;
    ns1:textoExtracto "SOLUCIÓN Programar el eje U una sola vez en el bloque." .

ns1:SolucionParaVDoblementeProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para 'V doblemente programada'" ;
    ns1:solucionaFallo ns1:VDoblementeProgramada ;
    ns1:textoExtracto "SOLUCIÓN Programar el eje V una sola vez en el bloque." .

ns1:CDoblementeProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "C doblemente programada" ;
    ns1:textoExtracto "'C doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje C más de una vez en el bloque." .

ns1:UDoblementeProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "U doblemente programada" ;
    ns1:textoExtracto "'U doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje U más de una vez en el bloque." .

ns1:VDoblementeProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "V doblemente programada" ;
    ns1:textoExtracto "'V doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje V más de una vez en el bloque." .

