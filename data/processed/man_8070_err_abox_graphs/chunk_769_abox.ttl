@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorSintaxis_8855 a ex:DiagnosticoFallo ;
    rdfs:label "Error 8855: Sintaxis incorrecta (DEF esperado)"@es ;
    ex:textoExtracto "8855 Se esperaba DEF en lugar de %. DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta."@es ;
    ex:identificador "8855" .

ex:ErrorRedefinicionRegistro_8856 a ex:DiagnosticoFallo ;
    rdfs:label "Error 8856: Registro de sistema redefinido"@es ;
    ex:textoExtracto "8856 Registro de sistema redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (registros) con el mismo nombre."@es ;
    ex:identificador "8856" .

ex:ManualInstalacion_PLC a ex:Manual ;
    rdfs:label "Manual de instalación (referencia para sintaxis PLC)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ex:ErrorSintaxis_8855 ex:solucionaFallo ex:ManualInstalacion_PLC .
ex:ErrorRedefinicionRegistro_8856 ex:solucionaFallo ex:ManualInstalacion_PLC .