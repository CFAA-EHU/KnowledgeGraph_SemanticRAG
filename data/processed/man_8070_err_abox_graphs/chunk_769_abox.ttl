@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaFaltaCorchete a ns1:AccionProhibida ;
    rdfs:label "Acción prohibida: falta corchete" ;
    ns1:textoExtracto "'Falta corchete' CAUSA La sentencia programada exige que sus parámetros vayan programados entre corchetes. La variable requiere programación de algún índice entre corchetes." .

ns1:AccionProhibidaParametroDoblementeProgramado a ns1:AccionProhibida ;
    rdfs:label "Acción prohibida: parámetro doblemente programado" ;
    ns1:textoExtracto "'I doblemente programada' CAUSA El parámetro I está programado más de una vez en el bloque." .

ns1:AvisoSeguridad_4602612cfc a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de parámetro fuera de rango" ;
    ns1:textoExtracto "'Parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Programado un valor demasiado alto para algún parámetro de la sentencia. SOLUCIÓN Programar un valor menor para el parámetro en la sentencia." .

ns1:AvisoSeguridad_af925400a5 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de falta de corchete" ;
    ns1:textoExtracto "'Falta corchete' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia programada exige que sus parámetros vayan programados entre corchetes. La variable requiere programación de algún índice entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable." .

ns1:AvisoSeguridad_cd97d0e83c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de eje doblemente programado" ;
    ns1:mitigaRiesgo ns1:EjeDoblementeProgramado_541a492681 ;
    ns1:textoExtracto "'X doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje X más de una vez en el bloque. SOLUCIÓN Programar el eje X una sola vez en el bloque." .

ns1:AvisoSeguridad_db5648cec4 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de parámetro doblemente programado" ;
    ns1:textoExtracto "'I doblemente programada' DETECCIÓN Durante la edición. CAUSA El parámetro I está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro I una sola vez en el bloque." .

ns1:CorreccionDeParametroFueraDeRango a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de parámetro fuera de rango" ;
    ns1:solucionaFallo ns1:EjeDoblementeProgramado_541a492681 ;
    ns1:textoExtracto "'Parámetro fuera de rango' SOLUCIÓN Programar un valor menor para el parámetro en la sentencia." .

ns1:EjeDoblementeProgramado_541a492681 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje doblemente programado" ;
    ns1:textoExtracto "'X doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje X más de una vez en el bloque." .

