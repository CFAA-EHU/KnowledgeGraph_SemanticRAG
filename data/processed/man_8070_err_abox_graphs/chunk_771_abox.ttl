@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltanEjesEnG20 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan ejes en G20" ;
    ns1:textoExtracto "'Faltan ejes en G20' DETECCIÓN Durante la edición. CAUSA No se han programado todos los parámetros obligatorios en la función G20." .

ns1:LaVariableEsDeSoloLectura a ns1:AvisoSeguridad ;
    rdfs:label "La variable es de solo lectura" ;
    ns1:mitigaRiesgo ns1:VariableDeEjeSinPermisoDeEscritura,
        ns1:VariableGlobalSinPermisoDeEscritura ;
    ns1:textoExtracto "SOLUCIÓN La variable es de solo lectura." .

ns1:ProgramarElParametroKUnaSolaVez a ns1:TareaMantenimiento ;
    rdfs:label "Programar el parámetro K una sola vez" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_dde3da54b3 ;
    ns1:textoExtracto "SOLUCIÓN Programar el parámetro K una sola vez en el bloque." .

ns1:ProgramarElRadioCorrectamente a ns1:TareaMantenimiento ;
    rdfs:label "Programar el radio correctamente" ;
    ns1:solucionaFallo ns1:ErrorDeProgramacionDelRadio ;
    ns1:textoExtracto "SOLUCIÓN El radio sólo se puede programar mediante 'R' o 'R1'." .

ns1:DiagnosticoFallo_dde3da54b3 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro K doblemente programada" ;
    ns1:textoExtracto "'K doblemente programada' DETECCIÓN Durante la edición. CAUSA El parámetro K está programado más de una vez en el bloque." .

ns1:ErrorDeProgramacionDelRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación del radio" ;
    ns1:textoExtracto "'Sólo R1 puede formar parte de expresiones' DETECCIÓN Durante la edición. CAUSA La programación del radio es incorrecta." .

ns1:VariableDeEjeSinPermisoDeEscritura a ns1:DiagnosticoFallo ;
    rdfs:label "Variable de eje sin permiso de escritura" ;
    ns1:textoExtracto "'Variable de eje sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura." .

ns1:VariableGlobalSinPermisoDeEscritura a ns1:DiagnosticoFallo ;
    rdfs:label "Variable global sin permiso de escritura" ;
    ns1:textoExtracto "'Variable global sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura." .

