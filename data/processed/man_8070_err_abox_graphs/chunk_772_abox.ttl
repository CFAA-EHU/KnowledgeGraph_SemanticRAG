@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionDelNombreDelProgramaPrincipalOSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Definición del nombre del programa principal o subrutina" ;
    ns1:textoExtracto "La definición del nombre del programa principal o subrutina tan solo puede ir acompañada de comentario." .

ns1:NoPuedeHaberNadaDespuesDelNombreDelProgramaOSubrutina a ns1:DiagnosticoFallo ;
    rdfs:label "No puede haber nada después del nombre del programa o subrutina" ;
    ns1:textoExtracto "'No puede haber nada después del nombre del programa o subrutina'" .

ns1:RevisarElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el manual de programación" ;
    ns1:solucionaFallo ns1:InstruccionDeCicloDeInterpoladorInexistente ;
    ns1:textoExtracto "Revisar el manual de programación." .

ns1:RevisarSintaxisDeProgramacionDeLaFuncionG20 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de programación de la función G20" ;
    ns1:solucionaFallo ns1:SobranEjesEnG20 ;
    ns1:textoExtracto "Revisar la sintaxis de programación de la función G20." .

ns1:InstruccionDeCicloDeInterpoladorInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción de ciclo de interpolador inexistente" ;
    ns1:textoExtracto "'Instrucción de ciclo de interpolador inexistente'" .

ns1:SobranEjesEnG20 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobran ejes en G20" ;
    ns1:textoExtracto "'Sobran ejes en G20'" .

