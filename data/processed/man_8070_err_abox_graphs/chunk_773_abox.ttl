@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaCaracteresProhibidosProgramaPrincipal a ns1:AccionProhibida ;
    rdfs:label "Accion Prohibida Caracteres Prohibidos Programa Principal" ;
    ns1:textoExtracto "'Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco.'" .

ns1:AccionProhibidaCaracteresProhibidosSubrutinaLocal a ns1:AccionProhibida ;
    rdfs:label "Accion Prohibida Caracteres Prohibidos Subrutina Local" ;
    ns1:textoExtracto "'• Subrutina local: / ? \" < > | ) y espacio en blanco.'" .

ns1:TareaMantenimientoSolucionSentenciaTIME a ns1:TareaMantenimiento ;
    rdfs:label "Tarea Mantenimiento Solución Sentencia TIME" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_aabac7edc4 ;
    ns1:textoExtracto "'SOLUCIÓN Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde'" .

ns1:DiagnosticoFallo_aabac7edc4 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnostico Fallo Sentencia TIME Incorrecta" ;
    ns1:textoExtracto "'DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Sentencia #TIME programada incorrectamente.'" .

