@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaVariableEsDeSoloLectura a ns1:AvisoSeguridad ;
    rdfs:label "La variable es de solo lectura" ;
    ns1:mitigaRiesgo ns1:VariableDeCicloSinPermisoDeEscritura ;
    ns1:textoExtracto "SOLUCIÓN La variable es de solo lectura." .

ns1:PalabraDesconocidaOIncompleta a ns1:DiagnosticoFallo ;
    rdfs:label "'Palabra desconocida o incompleta'" ;
    ns1:textoExtracto "'Palabra desconocida o incompleta' DETECCIÓN Durante la edición." .

ns1:RevisarEnElManualDeProgramacionLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis" ;
    ns1:solucionaFallo ns1:LaFuncionSentenciaOExpresionProgramadaNoEsValida,
        ns1:ProgramacionIncorrectaDeLaFuncionMParaUnDeterminadoCabezal,
        ns1:ProgramacionIncorrectaDeLaSentenciaTOOLAX ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." .

ns1:SentenciaTIMEProgramadaIncorrectamente a ns1:AccionProhibida ;
    rdfs:label "Sentencia #TIME programada incorrectamente" ;
    ns1:textoExtracto "CAUSA Sentencia #TIME programada incorrectamente." .

ns1:LaFuncionSentenciaOExpresionProgramadaNoEsValida a ns1:AccionProhibida ;
    rdfs:label "La función, sentencia o expresión programada no es válida" ;
    ns1:textoExtracto "• La función, sentencia o expresión programada no es válida." .

ns1:ProgramacionIncorrectaDeLaFuncionMParaUnDeterminadoCabezal a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de la función M para un determinado cabezal" ;
    ns1:textoExtracto "• Programación incorrecta de la función M para un determinado cabezal." .

ns1:ProgramacionIncorrectaDeLaSentenciaTOOLAX a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de la sentencia #TOOL AX" ;
    ns1:textoExtracto "• Programación incorrecta de la sentencia #TOOL AX." .

ns1:VariableDeCicloSinPermisoDeEscritura a ns1:AccionProhibida ;
    rdfs:label "Variable de ciclo sin permiso de escritura" ;
    ns1:textoExtracto "'Variable de ciclo sin permiso de escritura' DETECCIÓN Durante la edición." .

