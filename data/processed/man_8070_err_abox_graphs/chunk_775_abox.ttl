@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaVariableNoTienePermisoDeEscrituraLaVariableEsDeSoloLectura a ns1:DiagnosticoFallo ;
    rdfs:label "La variable no tiene permiso de escritura. La variable es de solo lectura."@es ;
    ns1:textoExtracto "CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:PerdidaParcialDeFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "'Pérdida parcial de función'"@es ;
    ns1:textoExtracto "8270 'Pérdida parcial de función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

ns1:ProgramarUnArgumentoCorrectoEnLaFuncionMatematica a ns1:TareaMantenimiento ;
    rdfs:label "Programar un argumento correcto en la función matemática" ;
    ns1:solucionaFallo ns1:ArgumentoFueraDeLimitesEnFuncion,
        ns1:RebasamientoPorEncimaEnFuncion ;
    ns1:textoExtracto "SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:ArgumentoFueraDeLimitesEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "'Argumento fuera de límites en función'"@es ;
    ns1:textoExtracto "8268 'Argumento fuera de límites en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

ns1:RebasamientoPorEncimaEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "'Rebasamiento por encima en función'"@es ;
    ns1:textoExtracto "8269 'Rebasamiento por encima en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

