@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8877
    a               ex:DiagnosticoFallo ;
    rdfs:label      "No hay eje físico equivalente al eje lógico"@es ;
    ex:identificador "8877" ;
    ex:textoExtracto "8877 No hay eje físico equivalente al eje lógico. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa contiene una referencia a un eje que no existe. SOLUCIÓN Revisar la programación."@es .

ex:Fallo_8878
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Subrutina definida pero no llamada"@es ;
    ex:identificador "8878" ;
    ex:textoExtracto "8878 Subrutina definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una subrutina en el programa pero no hay"@es .

ex:Accion_ContactoSoporte
    a               ex:TareaMantenimiento ;
    rdfs:label      "Contactar con Fagor Automation para fichero corrupto"@es ;
    ex:textoExtracto "Si está corrupto, póngase en contacto con Fagor Automation."@es ;
    ex:solucionaFallo ex:Fallo_CorrupcionFichero .

ex:Fallo_CorrupcionFichero
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fichero corrupto"@es ;
    ex:textoExtracto "SOLUCIÓN Comprobar que el fichero existe y que se puede abrir con un editor habitual. Si está corrupto, póngase en contacto con Fagor Automation."@es .