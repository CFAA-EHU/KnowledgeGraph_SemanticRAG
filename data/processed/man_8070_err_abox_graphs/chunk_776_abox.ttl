@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PerdidaTotalEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida total en función" ;
    ns1:textoExtracto "'Pérdida total en función'" .

ns1:ProgramarUnArgumentoCorrectoEnLaFuncionMatematica a ns1:TareaMantenimiento ;
    rdfs:label "Programar un argumento correcto en la función matemática" ;
    ns1:solucionaFallo ns1:ArgumentoNoPermitidoEnFuncion ;
    ns1:textoExtracto "SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:ArgumentoNoPermitidoEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "Argumento no permitido en función" ;
    ns1:textoExtracto "'Argumento no permitido en función'" .

