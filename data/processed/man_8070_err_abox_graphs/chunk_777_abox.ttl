@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorSintaxis_8886
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción MOVE ABS/ADD"@es ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis. 8886 MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es ;
    ex:identificador "8886" .

ex:ErrorSintaxis_8887
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción MOVE INF"@es ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis. 8887 MOVE INF(eje,sentido,velocidad,tipoEnlace)"@es ;
    ex:identificador "8887" .

ex:Parametro_eje
    a ex:Parametro ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ex:Parametro_posicion
    a ex:Parametro ;
    rdfs:label "posición"@es ;
    ex:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ex:Parametro_velocidad
    a ex:Parametro ;
    rdfs:label "velocidad"@es ;
    ex:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ex:Parametro_tipoEnlace
    a ex:Parametro ;
    rdfs:label "tipoEnlace"@es ;
    ex:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ex:Parametro_sentido
    a ex:Parametro ;
    rdfs:label "sentido"@es ;
    ex:textoExtracto "MOVE INF(eje,sentido,velocidad,tipoEnlace)"@es .

ex:ManualInstalacionPLC
    a ex:Manual ;
    rdfs:label "manual de instalación"@es ;
    ex:textoExtracto "Revisar en el manual de instalación la sintaxis"@es .

ex:ErrorSintaxis_8886 ex:solucionaFallo ex:ManualInstalacionPLC .
ex:ErrorSintaxis_8887 ex:solucionaFallo ex:ManualInstalacionPLC .