@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EvitarLaRepeticionDeFuncionesG11G12OG13 a ns1:TareaMantenimiento ;
    rdfs:label "Evitar la repetición de funciones G11, G12 o G13" ;
    ns1:solucionaFallo ns1:ImagenEspejoRepetida_d62c867094 ;
    ns1:textoExtracto "SOLUCIÓN La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque." .

ns1:LimitarElNumeroDeFuncionesHEnUnBloque a ns1:TareaMantenimiento ;
    rdfs:label "Limitar el número de funciones H en un bloque" ;
    ns1:solucionaFallo ns1:LimiteDeFuncionesHEnUnMismoBloqueSobrepasado ;
    ns1:textoExtracto "SOLUCIÓN El número máximo de funciones H permitidas en un mismo bloque es 7." .

ns1:LimitarElNumeroDeFuncionesMEnUnBloque a ns1:TareaMantenimiento ;
    rdfs:label "Limitar el número de funciones M en un bloque" ;
    ns1:solucionaFallo ns1:LimiteDeFuncionesMEnUnMismoBloqueSobrepasado_a9ca294f51 ;
    ns1:textoExtracto "SOLUCIÓN El número máximo de funciones M permitidas en un mismo bloque es 7." .

ns1:ProgramarUnArgumentoCorrectoEnLaFuncionMatematica a ns1:TareaMantenimiento ;
    rdfs:label "Programar un argumento correcto en la función matemática" ;
    ns1:solucionaFallo ns1:PerdidaTotalEnFuncion_db194b3e4a,
        ns1:RebasamientoPorDebajoEnFuncion,
        ns1:TipoDeExcepcionDesconocido ;
    ns1:textoExtracto "SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:ImagenEspejoRepetida_d62c867094 a ns1:DiagnosticoFallo ;
    rdfs:label "Imagen espejo repetida" ;
    ns1:textoExtracto "'Imagen espejo repetida' DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque." .

ns1:LimiteDeFuncionesHEnUnMismoBloqueSobrepasado a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de funciones H en un mismo bloque sobrepasado" ;
    ns1:textoExtracto "'Límite de funciones H en un mismo bloque sobrepasado' DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones H permitidas en un mismo bloque." .

ns1:LimiteDeFuncionesMEnUnMismoBloqueSobrepasado_a9ca294f51 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de funciones M en un mismo bloque sobrepasado" ;
    ns1:textoExtracto "'Límite de funciones M en un mismo bloque sobrepasado' DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones M permitidas en un mismo bloque." .

ns1:PerdidaTotalEnFuncion_db194b3e4a a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida total en función" ;
    ns1:textoExtracto "'Pérdida total en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

ns1:RebasamientoPorDebajoEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "Rebasamiento por debajo en función" ;
    ns1:textoExtracto "'Rebasamiento por debajo en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

ns1:TipoDeExcepcionDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de excepción desconocido" ;
    ns1:textoExtracto "'Tipo de excepción desconocido' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido." .

