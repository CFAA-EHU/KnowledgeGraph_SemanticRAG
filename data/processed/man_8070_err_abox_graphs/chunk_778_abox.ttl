@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloVelocidadPosicionamientoCabezalNegativa a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ns1:textoExtracto "'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición." .

ns1:ImagenEspejoRepetida_550619d7d9 a ns1:AvisoSeguridad ;
    rdfs:label "Imagen espejo repetida" ;
    ns1:textoExtracto "'Imagen espejo repetida' DETECCIÓN Durante la edición." .

ns1:SolucionParaImagenEspejoRepetida a ns1:TareaMantenimiento ;
    rdfs:label "Solución para Imagen espejo repetida" ;
    ns1:solucionaFallo ns1:FalloImagenEspejoRepetida ;
    ns1:textoExtracto "SOLUCIÓN Las funciones G11, G12 y G13 se pueden combinar en un mismo bloque pero cada una de ellas sólo se puede programar una vez. La funciones G10 y G14 no se pueden programar en el mismo bloque que la G11, G12 o G13." .

ns1:VelocidadDePosicionamientoDelCabezalNegativa_d4101f9768 a ns1:AvisoSeguridad ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ns1:textoExtracto "'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad" .

ns1:FalloImagenEspejoRepetida a ns1:DiagnosticoFallo ;
    rdfs:label "Imagen espejo repetida" ;
    ns1:textoExtracto "'Imagen espejo repetida' DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque. La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque." .

