@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarQueLaVelocidadDePosicionamientoSeaPositiva a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que la velocidad de posicionamiento sea positiva" ;
    ns1:solucionaFallo ns1:VelocidadDePosicionamientoDelCabezalNegativa_01623e42b5 ;
    ns1:textoExtracto "SOLUCIÓN La velocidad de posicionamiento 'Sn. POS' debe ser positiva." .

ns1:NoProgramarG10YG14ConG11G12OG13EnElMismoBloque a ns1:AccionProhibida ;
    rdfs:label "No programar G10 y G14 con G11, G12 o G13 en el mismo bloque" ;
    ns1:textoExtracto "G10 y G14 no se pueden programar en el mismo bloque que la G11, G12 o G13." .

ns1:ProgramarCadaParametroDelCicloFijoSoloUnaVez a ns1:TareaMantenimiento ;
    rdfs:label "Programar cada parámetro del ciclo fijo solo una vez" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_9cb841d8a5 ;
    ns1:textoExtracto "SOLUCIÓN Cada parámetro del ciclo fijo sólo se puede programar una vez en el bloque." .

ns1:ProgramarUnaUnicaVezLaVelocidadDePosicionamientoDelCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Programar una única vez la velocidad de posicionamiento del cabezal" ;
    ns1:solucionaFallo ns1:VelocidadDePosicionamientoDelCabezalDoblementeProgramada ;
    ns1:textoExtracto "SOLUCIÓN Programar una única vez la velocidad de posicionamiento del cabezal 'Sn. POS'." .

ns1:DiagnosticoFallo_9cb841d8a5 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro de ciclo fijo repetido" ;
    ns1:textoExtracto "'Parámetro de ciclo fijo repetido' DETECCIÓN Durante la edición. CAUSA Algún parámetro del ciclo fijo está programado más de una vez en el bloque." .

ns1:VelocidadDePosicionamientoDelCabezalDoblementeProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de posicionamiento del cabezal doblemente programada" ;
    ns1:textoExtracto "'Velocidad de posicionamiento del cabezal doblemente programada' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA En un mismo bloque hay programado más de una vez la velocidad de posicionamiento del cabezal en M19." .

ns1:VelocidadDePosicionamientoDelCabezalNegativa_01623e42b5 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ns1:textoExtracto "'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de posicionamiento negativa en M19." .

