@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8902
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #GAPCTRL" ;
    ex:identificador "8902" ;
    ex:textoExtracto "#GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8903
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #TECHTABLE" ;
    ex:identificador "8903" ;
    ex:textoExtracto "#TECHTABLE<[N\"nombreFicheroMaterial\",> \"nombreTabla\" <OFF]> <Tvalor params> [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8904
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en CNCRD" ;
    ex:identificador "8904" ;
    ex:textoExtracto "CNCRD(idVar, canal, ejeLog, idxArray1, idxArray2, registro, marca <,registroError>) [...] DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La sintaxis del comando no es correcta." .

ex:Error_8905
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en CNCWR" ;
    ex:identificador "8905" ;
    ex:textoExtracto "CNCWR(registro, idVar, canal, ejeLog, idxArray1, idxArray2, marca <,registroError>) [...] DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La sintaxis del comando no es correcta." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:ManualInstalacion
    a ex:Manual ;
    rdfs:label "Manual de instalación" ;
    ex:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ex:Error_8902
    ex:solucionaFallo ex:ManualProgramacion .

ex:Error_8903
    ex:solucionaFallo ex:ManualProgramacion .

ex:Error_8904
    ex:solucionaFallo ex:ManualInstalacion .

ex:Error_8905
    ex:solucionaFallo ex:ManualInstalacion .