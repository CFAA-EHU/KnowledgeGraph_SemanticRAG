ns1:SolucionParaDemasiadosEjesProgramados_b6476a1906 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para demasiados ejes programados" ;
    ns1:solucionaFallo ns1:DemasiadosEjesProgramados_2fe71b10c6 ;
    ns1:textoExtracto "El número máximo de ejes que se pueden programar es 3." .

ns1:SolucionParaFaltaDeParametroObligatorio a ns1:TareaMantenimiento ;
    rdfs:label "Solución para falta de parámetro obligatorio" ;
    ns1:solucionaFallo ns1:FaltaParametroObligatorio ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:SolucionParaFuncionG4MalProgramada a ns1:TareaMantenimiento ;
    rdfs:label "Solución para función G4 mal programada" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_5d69ed897a ;
    ns1:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera." .

