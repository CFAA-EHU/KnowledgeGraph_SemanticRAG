    rdfs:label "Tiempo de espera para función G4" ;
    ns1:identificador "G4" ;
    ns1:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera." .

ns1:TiempoDeEspera_99158caa3e a ns1:Parametro ;
    rdfs:label "Tiempo de espera" ;
    ns1:identificador "time" ;
    ns1:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera." .

