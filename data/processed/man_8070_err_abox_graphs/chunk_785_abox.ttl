@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error9020
    a ex:DiagnosticoFallo ;
    rdfs:label "Demasiadas acciones (Error 9020)" ;
    ex:textoExtracto "9020 Demasiadas acciones. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas acciones. SOLUCIÓN Duplicar la proposición ejecutable y distribuir las acciones." ;
    ex:identificador "9020" .

ex:Error9026
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta fin de módulo o subrutina 'END' (Error 9026)" ;
    ex:textoExtracto "9026 Falta fin de módulo o de subrutina 'END'. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta la proposición directiva END al final de un módulo CY1, PRG o PE. SOLUCIÓN Finalizar todos los módulos con la proposición directiva END." ;
    ex:identificador "9026" .

ex:Error9027
    a ex:DiagnosticoFallo ;
    rdfs:label "Instrucción no soportada (Error 9027)" ;
    ex:textoExtracto "9027 Instrucción no soportada. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada no existe. SOLUCIÓN Revisar la sintaxis." ;
    ex:identificador "9027" .

ex:Error9028
    a ex:DiagnosticoFallo ;
    rdfs:label "Recurso o número esperado (Error 9028)" ;
    ex:textoExtracto "9028 Debe ser un recurso o un número. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada es incorrecta. SOLUCIÓN Programar un recurso o un número." ;
    ex:identificador "9028" .

ex:Error9029
    a ex:DiagnosticoFallo ;
    rdfs:label "DEF incorrectamente construido (Error 9029)" ;
    ex:textoExtracto "9029 DEF incorrectamente construido. DETECCIÓN Durante la compilación del programa PLC. CAUSA DEF incorrectamente construido. SOLUCIÓN Revisar la programación." ;
    ex:identificador "9029" .

ex:Error9030
    a ex:DiagnosticoFallo ;
    rdfs:label "Tipo de recurso desconocido (Error 9030)" ;
    ex:textoExtracto "9030 Tipo de recurso desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Tipo de recurso desconocido. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "9030" .

ex:Error9031
    a ex:DiagnosticoFallo ;
    rdfs:label "Fin de fichero en comentario (Error 9031)" ;
    ex:textoExtracto "9031 Fin de fichero en comentario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Fin de fichero en comentario. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "9031" .

ex:Error9032
    a ex:DiagnosticoFallo ;
    rdfs:label "Fichero de símbolos inaccesible (Error 9032)" ;
    ex:textoExtracto "9032 No se puede abrir el fichero de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA No se puede abrir el fichero de símbolos. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "9032" .

ex:Error9033
    a ex:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente para lista de símbolos (Error 9033)" ;
    ex:textoExtracto "9033 No hay memoria para crear la lista de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." ;
    ex:identificador "9033" .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation." .