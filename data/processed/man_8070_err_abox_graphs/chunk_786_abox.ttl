@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarSintaxisDeLasSentenciasEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de las sentencias en el manual de programación" ;
    ns1:solucionaFallo ns1:FaltaAlgunParametroObligatorioEnLaSentenciaPOLYCSACSOPROBE,
        ns1:ValorNoValidoEnAlgunArgumentoDeLaSentenciaCSACSHSCOPOLYValorNoValidoP_ec3bcbee6d,
        ns1:ValorNoValidoParaElComandoMODEDeLaSentenciaCSOACS ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:VerificarElComandoMODEEnLasSentenciasCSYACS a ns1:TareaMantenimiento ;
    rdfs:label "Verificar el comando MODE en las sentencias #CS y #ACS" ;
    ns1:solucionaFallo ns1:ValorNoValidoParaElComandoMODEDeLaSentenciaCSOACS ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:VerificarQueElIndiceDeUnParametroAritmeticoSeaPositivoONulo a ns1:TareaMantenimiento ;
    rdfs:label "Verificar que el índice de un parámetro aritmético sea positivo o nulo" ;
    ns1:solucionaFallo ns1:ValorNoValidoEnAlgunArgumentoDeLaSentenciaCSACSHSCOPOLYValorNoValidoP_ec3bcbee6d ;
    ns1:textoExtracto "El índice de un parámetro aritmético debe ser siempre positivo o nulo." .

ns1:FaltaAlgunParametroObligatorioEnLaSentenciaPOLYCSACSOPROBE a ns1:DiagnosticoFallo ;
    rdfs:label "Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE" ;
    ns1:textoExtracto "'parámetro obligatorio' DETECCIÓN Durante la edición. CAUSA Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:ValorNoValidoEnAlgunArgumentoDeLaSentenciaCSACSHSCOPOLYValorNoValidoP_ec3bcbee6d a ns1:DiagnosticoFallo ;
    rdfs:label "Valor no válido en algún argumento de la sentencia #CS, #ACS, #HSC o #POLY. Valor no válido para el índice de un parámetro aritmético." ;
    ns1:textoExtracto "'Valor de parámetro no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido en algún argumento de la sentencia #CS, #ACS, #HSC o #POLY. Valor no válido para el índice de un parámetro aritmético." .

ns1:ValorNoValidoParaElComandoMODEDeLaSentenciaCSOACS a ns1:DiagnosticoFallo ;
    rdfs:label "Valor no válido para el comando MODE de la sentencia #CS o #ACS" ;
    ns1:textoExtracto "'#CS/#ACS: modo no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido para el comando MODE de la sentencia #CS o #ACS." .

