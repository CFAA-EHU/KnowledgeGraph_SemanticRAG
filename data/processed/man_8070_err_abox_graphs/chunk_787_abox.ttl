@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloPalpador a ns1:Parametro ;
    rdfs:label "Número de ciclo de palpador" ;
    ns1:textoExtracto "El número de ciclo de palpador no es válido." .

ns1:ConsultarEnLaDocumentacionLosCiclosDePalpadorValidos a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en la documentación los ciclos de palpador válidos" ;
    ns1:solucionaFallo ns1:NumeroDeCicloDePalpadorNoValido ;
    ns1:textoExtracto "Consultar en la documentación los ciclos de palpador válidos." .

ns1:DiagnosticoFallo_ca919d2c2b a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no permitido" ;
    ns1:textoExtracto "'Parámetro no permitido'" .

ns1:NumeroDeSistema a ns1:Parametro ;
    rdfs:label "Número de sistema" ;
    ns1:textoExtracto "El número de sistema debe tener un valor entre 1 y 5, ambos inclusive." ;
    ns1:valor "1-5" .

ns1:ParametroI a ns1:Parametro ;
    rdfs:label "Parámetro I" ;
    ns1:textoExtracto "En la función G30/G73 se ha programado sólo uno de los parámetros I, J." .

ns1:ParametroJ a ns1:Parametro ;
    rdfs:label "Parámetro J" ;
    ns1:textoExtracto "En la función G30/G73 se ha programado sólo uno de los parámetros I, J." .

ns1:ProgramarAmbosParametrosIJONoProgramarNinguno a ns1:TareaMantenimiento ;
    rdfs:label "Programar ambos parámetros I, J o no programar ninguno" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaG30G73 ;
    ns1:textoExtracto "Programar ambos parámetros I, J o no programar ninguno." .

ns1:RevisarSintaxisSentenciasEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis sentencias en el manual de programación" ;
    ns1:solucionaFallo ns1:NumeroDeSistemaDeCoordenadasNoValida ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:NumeroDeCicloDePalpadorNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Número de ciclo de palpador no válido" ;
    ns1:textoExtracto "'Número de ciclo de palpador no válido'" .

ns1:NumeroDeSistemaDeCoordenadasNoValida a ns1:DiagnosticoFallo ;
    rdfs:label "número de sistema de coordenadas no válida" ;
    ns1:textoExtracto "'#CS/#ACS: número de sistema de coordenadas no válida'" .

ns1:ProgramacionIncorrectaG30G73 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta G30/G73" ;
    ns1:textoExtracto "'Programación incorrecta G30/G73'" .

