@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:FalloCompilacion_9042
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Sustitución de carácter '/' por '_' en compilación PLC"@es ;
    ex:identificador      "9042" ;
    ex:textoExtracto      "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"/\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"/\" por"@es .

ex:FalloCompilacion_MarcaRegistroIncorrecto
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Sustitución de marca/registro por recurso sugerido en compilación PLC"@es ;
    ex:textoExtracto      "CAUSA La marca o registro es incorrecto; el PLC lo ha sustituido en el programa compilado por el recurso sugerido. SOLUCIÓN Sustituir la marca o registro por el recurso sugerido."@es .