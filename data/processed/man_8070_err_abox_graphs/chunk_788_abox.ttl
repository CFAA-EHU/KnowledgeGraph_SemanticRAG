@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarCorrectorDeHerramientaPositivo a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar corrector de herramienta positivo" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_a9dfc8c5e7 ;
    ns1:textoExtracto "SOLUCIÓN El corrector de herramienta debe ser positivo." .

ns1:Parametro_5c3e608187 a ns1:Parametro ;
    rdfs:label "Parámetro del ciclo o sentencia" ;
    ns1:textoExtracto "Algún parámetro del ciclo o la sentencia no es válido." .

ns1:RevisarParametrosValidos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros válidos" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_83cb410d96 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación los parámetros válidos para cada ciclo y sentencia." .

ns1:SoloSePermiteUnEjeActivo1PorBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Sólo se permite un eje activo 1 por bloque" ;
    ns1:textoExtracto "'Sólo se permite un eje activo 1 por bloque' DETECCIÓN Durante la edición. CAUSA El eje @1 está programado más de una vez en el bloque." .

ns1:DiagnosticoFallo_83cb410d96 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no permitido" ;
    ns1:textoExtracto "'Parámetro no permitido' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Algún parámetro del ciclo o la sentencia no es válido." .

ns1:DiagnosticoFallo_a9dfc8c5e7 a ns1:DiagnosticoFallo ;
    rdfs:label "Función D negativa" ;
    ns1:textoExtracto "'Función D negativa' DETECCIÓN Durante la edición. CAUSA Corrector de herramienta negativo." .

