ns1:EliminarElEspacioEnBlanco_0662d5ab83 a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el espacio en blanco" ;
    ns1:solucionaFallo ns1:NoSeEsperabaEspacio ;
    ns1:textoExtracto "'No se esperaba espacio' DETECCIÓN Durante la edición. CAUSA Hay un espacio en blanco incorrecto. SOLUCIÓN Eliminar el espacio en blanco." .

