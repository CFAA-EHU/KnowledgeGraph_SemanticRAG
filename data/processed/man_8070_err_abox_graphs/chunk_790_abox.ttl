@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarQueCadaParentesisDeAperturaTieneSuCorrespondienteParentesisDeCierre a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre" ;
    ns1:solucionaFallo ns1:FaltaAlgunParentesis ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre." .

ns1:EliminarElEspacioEnBlanco a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el espacio en blanco" ;
    ns1:solucionaFallo ns1:HayUnEspacioEnBlancoIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el espacio en blanco." .

ns1:EliminarElSaltoDeLinea a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el salto de línea" ;
    ns1:solucionaFallo ns1:HayUnSaltoDeLineaIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el salto de línea." .

ns1:SETAXSoloSePermitePosicionCero a ns1:DiagnosticoFallo ;
    rdfs:label "#SET AX: sólo se permite posición cero" ;
    ns1:textoExtracto "CAUSA En la sentencia #SET AX se ha programado un valor" .

ns1:FaltaAlgunParentesis a ns1:DiagnosticoFallo ;
    rdfs:label "Falta algún paréntesis" ;
    ns1:textoExtracto "CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre." .

ns1:HayUnEspacioEnBlancoIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Hay un espacio en blanco incorrecto" ;
    ns1:textoExtracto "CAUSA Hay un espacio en blanco incorrecto." .

ns1:HayUnSaltoDeLineaIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Hay un salto de línea incorrecto" ;
    ns1:textoExtracto "CAUSA Hay un salto de línea incorrecto." .

