ex:Error_9049
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9049: No hay memoria para recursos registros nuevos"@es ;
    ex:identificador "9049" ;
    ex:textoExtracto "9049 No hay memoria para recursos registros nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos."@es .

ex:Error_9050
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9050: No hay memoria para recursos registros de sistema nuevos"@es ;
    ex:identificador "9050" ;
    ex:textoExtracto "9050 No hay memoria para recursos registros de sistema nuevos. DETECCIÓN Durante la compilación del programa"@es .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ex:Error_9049 ex:solucionaFallo ex:FagorAutomation .
ex:Error_9050 ex:solucionaFallo ex:FagorAutomation .