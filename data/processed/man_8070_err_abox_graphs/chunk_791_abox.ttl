@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DETECCIONDuranteLaEdicion a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la edición" ;
    ns1:mitigaRiesgo ns1:EnLaSentenciaSETAXSeHaProgramadoUnValorEnteroDistintoDeCero ;
    ns1:textoExtracto "'#SET AX: sólo se permite posición cero'" .

ns1:DETECCIONDuranteLaEdicionYEjecucionEnMDI a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la edición y ejecución en MDI" ;
    ns1:mitigaRiesgo ns1:LaSentenciaOVariableProgramadaExigeUnNombreONumeroDeEje ;
    ns1:textoExtracto "'Se esperaba nombre o número de eje'" .

ns1:DETECCIONDuranteLaEdicion_55a228bb07 a ns1:AvisoSeguridad ;
    rdfs:label "DETECCIÓN Durante la edición" ;
    ns1:mitigaRiesgo ns1:SeHaProgramadoUnNombreDeVariableQueNoComienzaConElPrefijoV ;
    ns1:textoExtracto "'Se esperaba V'" .

ns1:EnLaSentenciaSETAXSeHaProgramadoUnValorEnteroDistintoDeCero a ns1:DiagnosticoFallo ;
    rdfs:label "En la sentencia #SET AX se ha programado un valor entero distinto de cero" ;
    ns1:textoExtracto "CAUSA En la sentencia #SET AX se ha programado un valor entero distinto de cero." .

ns1:LaSentenciaOVariableProgramadaExigeUnNombreONumeroDeEje a ns1:DiagnosticoFallo ;
    rdfs:label "La sentencia o variable programada exige un nombre o número de eje" ;
    ns1:textoExtracto "CAUSA La sentencia o variable programada exige un nombre o número de eje." .

ns1:SeHaProgramadoUnNombreDeVariableQueNoComienzaConElPrefijoV a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha programado un nombre de variable que no comienza con el prefijo 'V.'" ;
    ns1:textoExtracto "CAUSA Se ha programado un nombre de variable que no comienza con el prefijo \"V.\"." .

