@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FREEAXEje a ns1:AccionProhibida ;
    rdfs:label "#FREE AX[eje, ...]" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaOVariable ;
    ns1:textoExtracto "'#FREE AX[eje, ...]'" .

ns1:MSGTextoDValor a ns1:AccionProhibida ;
    rdfs:label "#MSG[\"Texto <%d>\"<,valor>]" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaOVariable ;
    ns1:textoExtracto "'#MSG[\\\"Texto <%d>\\\"<,valor>]'" .

ns1:NoSeEsperabaNombreONumeroDeEje a ns1:AccionProhibida ;
    rdfs:label "No se esperaba nombre o número de eje" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaOVariable ;
    ns1:textoExtracto "'No se esperaba nombre o número de eje'" .

ns1:WARNINGERRORTextoDValorNoentero a ns1:AccionProhibida ;
    rdfs:label "#WARNING/#ERROR[\"Texto <%d>\"<,valor>]/[nºentero]" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaOVariable ;
    ns1:textoExtracto "'#WARNING/#ERROR[\\\"Texto <%d>\\\"<,valor>]/[nºentero]'" .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaOVariable a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia o variable" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia o variable." .

