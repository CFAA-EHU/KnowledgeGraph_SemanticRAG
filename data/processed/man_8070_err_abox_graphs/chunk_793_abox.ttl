ns1:DeteccionDeSintaxisIncorrectaEnWAITFORExpresion a ns1:Parametro ;
    rdfs:label "Detección de sintaxis incorrecta en '#WAIT FOR[expresión]'"@es ;
    ns1:textoExtracto "'#WAIT FOR[expresión]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisionDeSintaxisEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis en el manual de programación"@es ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a a ns1:DiagnosticoFallo ;
