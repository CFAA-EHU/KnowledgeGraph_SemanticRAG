@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

### Diagnósticos de fallo (9303-9307)
ex:Fallo_9303
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de asociación de palpador a entrada digital no válida" ;
    ex:identificador "9303" ;
    ex:textoExtracto "El palpador debe asociarse a entrada digital de nodo Fagor. [...] El parámetro PRBDI1 o PRBDI2 hace referencia a una entrada digital no válida. Solo son válidas las entradas digitales que pertenecen a módulos Fagor o las entradas lógicas si solo se desea simular el palpador." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Parámetro PRBDI1/PRBDI2" ;
        ex:textoExtracto "Asignar a los parámetros PRBDI1 y PRBDI2 una entrada digital de un módulo Fagor o una entrada lógica."
    ] .

ex:Fallo_9304
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en OPMODEP de ejes gantry/tándem" ;
    ex:identificador "9304" ;
    ex:textoExtracto "Ejes gantry: Los dos ejes SERCOS tienen que tener igual OPMODEP. [...] Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Parámetro OPMODEP" ;
        ex:textoExtracto "Revisar los parámetros máquina. Ambos ejes deben tener el parámetro OPMODEP igual."
    ] .

ex:Fallo_9305
    a ex:DiagnosticoFallo ;
    rdfs:label "Orden de filtro paso bajo excesivo" ;
    ex:identificador "9305" ;
    ex:textoExtracto "Se recomienda reducir el orden del filtro. [...] Uno de los filtros paso bajo del eje tiene un número de orden demasiado elevado para la frecuencia definida, lo que podría producir un sobrepasamiento." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Parámetro de orden de filtro/frecuencia" ;
        ex:textoExtracto "Reducir el orden del filtro o aumentar la frecuencia."
    ] .

ex:Fallo_9306
    a ex:DiagnosticoFallo ;
    rdfs:label "Conflicto entre filtro FAST y filtros de eje" ;
    ex:identificador "9306" ;
    ex:textoExtracto "Filtro FAST incompatible con 3º filtro de eje. [...] El CNC no puede activar el filtro automático del modo HSC FAST porque ya hay tres filtros de frecuencia activos en el eje." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Configuración de filtros de eje/modo HSC FAST" ;
        ex:textoExtracto "Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST."
    ] .

ex:Fallo_9307
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de CHTYPE con Motion Control" ;
    ex:identificador "9307" ;
    ex:textoExtracto "Con opción de software Motion Control el tipo de canal 'CHTYPE' debe ser de PLC." .

### Parámetros críticos (extraídos de soluciones)
ex:Parametro_PRBDI1
    a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:textoExtracto "Parámetro PRBDI1 para asociación de entrada digital del palpador." .

ex:Parametro_PRBDI2
    a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:textoExtracto "Parámetro PRBDI2 para asociación de entrada digital del palpador." .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP" ;
    ex:textoExtracto "Parámetro OPMODEP para sincronización de ejes gantry/tándem." .

ex:Parametro_FiltroOrden
    a ex:Parametro ;
    rdfs:label "Orden de filtro paso bajo" ;
    ex:textoExtracto "Número de orden del filtro paso bajo del eje." .

ex:Parametro_FiltroFrecuencia
    a ex:Parametro ;
    rdfs:label "Frecuencia de filtro" ;
    ex:textoExtracto "Frecuencia definida para el filtro paso bajo." .

ex:Parametro_CHTYPE
    a ex:Parametro ;
    rdfs:label "CHTYPE" ;
    ex:textoExtracto "Tipo de canal (debe ser PLC con Motion Control)." .

### Relaciones entre fallos y parámetros
ex:Fallo_9303 ex:solucionaFallo ex:Parametro_PRBDI1, ex:Parametro_PRBDI2 .
ex:Fallo_9304 ex:solucionaFallo ex:Parametro_OPMODEP .
ex:Fallo_9305 ex:solucionaFallo ex:Parametro_FiltroOrden, ex:Parametro_FiltroFrecuencia .
ex:Fallo_9307 ex:solucionaFallo ex:Parametro_CHTYPE .