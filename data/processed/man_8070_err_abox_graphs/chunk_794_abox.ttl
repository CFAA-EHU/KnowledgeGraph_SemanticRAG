    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "'#CONTJOG[valorAvance] nombreEje' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

