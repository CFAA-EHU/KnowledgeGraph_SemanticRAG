    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "'#MPG[valorResolución,...] nombreEje' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

