@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:FiltroFrecuenciaEje
    a               ex:ComponenteElectrico ;
    rdfs:label      "Filtro de frecuencia del eje"@es ;
    ex:textoExtracto "SOLUCIÓN Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST."@es .

ex:ModoHSC_FAST
    a               ex:ModoOperacion ;
    rdfs:label      "Modo HSC FAST"@es ;
    ex:textoExtracto "SOLUCIÓN Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST."@es .

ex:Parametro_CHTYPE
    a               ex:Parametro ;
    rdfs:label      "CHTYPE" ;
    ex:identificador "CHTYPE" ;
    ex:textoExtracto "el tipo de canal 'CHTYPE' debe ser de PLC"@es ;
    ex:valor         "PLC" .

ex:Error_9307
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 9307" ;
    ex:identificador "9307" ;
    ex:textoExtracto "'Con opción de software Motion Control el tipo de canal 'CHTYPE' debe ser de PLC'"@es ;
    ex:mitigaRiesgo  ex:Parametro_CHTYPE .

ex:Error_9308
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 9308" ;
    ex:identificador "9308" ;
    ex:textoExtracto "'No se permiten posiciones de compensación fuera del rango del módulo'"@es .

ex:Modelo_MC
    a               ex:Maquina ;
    rdfs:label      "Modelo MC"@es ;
    ex:textoExtracto "Es un modelo MC y algún canal no está definido como canal de PLC."@es ;
    ex:tieneComponente ex:Parametro_CHTYPE .

ex:CanalPLC
    a               ex:ComponenteElectrico ;
    rdfs:label      "Canal de PLC"@es ;
    ex:textoExtracto "todos los canales deben ser de PLC (parámetro CHTYPE)."@es ;
    ex:monitoreaParametro ex:Parametro_CHTYPE .