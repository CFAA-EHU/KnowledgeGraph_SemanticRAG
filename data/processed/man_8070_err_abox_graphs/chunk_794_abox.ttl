ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_0505ea8abc a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "'#TOOL AX[eje +/-]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

