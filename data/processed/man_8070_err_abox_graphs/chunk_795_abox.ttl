@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeOffsetDelEje a ns1:Parametro ;
    rdfs:label "Configuración de offset del eje" ;
    ns1:identificador "SETOFFSET" ;
    ns1:textoExtracto "'#SET OFFSET[inferior, superior]eje'" .

ns1:EnlaceEntreEjesMaestroYEsclavo a ns1:Parametro ;
    rdfs:label "Enlace entre ejes maestro y esclavo" ;
    ns1:identificador "LINK" ;
    ns1:textoExtracto "'#LINK[maestro, esclavo <,error>]...[...]'" .

ns1:IncrementoDeAvanceDelEje a ns1:Parametro ;
    rdfs:label "Incremento de avance del eje" ;
    ns1:identificador "INCJOG" ;
    ns1:textoExtracto "'#INCJOG[[valorIncremento, valorAvance],..., [...]] nombreEje'" .

ns1:UsoDeSintaxisIncorrectaEnSentencias a ns1:AccionProhibida ;
    rdfs:label "Uso de sintaxis incorrecta en sentencias" ;
    ns1:solucionaFallo ns1:RevisionDelManualDeProgramacionParaSintaxisDeSentencias ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

ns1:RevisionDelManualDeProgramacionParaSintaxisDeSentencias a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del manual de programación para sintaxis de sentencias" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

