@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarSintaxisDeSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de sentencia" ;
    ns1:solucionaFallo ns1:Error8345,
        ns1:Error8346,
        ns1:Error8347,
        ns1:Error8348,
        ns1:Error8349,
        ns1:Error8350,
        ns1:Error8351 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error8345 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8345" ;
    ns1:textoExtracto "'#LINK[maestro, esclavo <,error>]...[...]' DETECCIÓN Durante la edición y ejecución." .

ns1:Error8346 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8346" ;
    ns1:textoExtracto "'#ROUNDPAR[param, …]: error de sintaxis' DETECCIÓN Durante la ejecución." .

ns1:Error8347 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8347" ;
    ns1:textoExtracto "'#ASPLINE MODE [<inicial> <, final>]: error de sintaxis' DETECCIÓN Durante la ejecución." .

ns1:Error8348 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8348" ;
    ns1:textoExtracto "'#ASPLINE STARTTANG/ENDTANG ejes: error de sintaxis' DETECCIÓN Durante la ejecución." .

ns1:Error8349 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8349" ;
    ns1:textoExtracto "'#SLOPE[tipo <,jerk> <,acel> <,mov>]: error de sintaxis' DETECCIÓN Durante la ejecución." .

ns1:Error8350 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8350" ;
    ns1:textoExtracto "'#TLC ON[n]': error de sintaxis' DETECCIÓN Durante la ejecución." .

ns1:Error8351 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8351" ;
    ns1:textoExtracto "'#KIN ID <[cinemática]>: error de sintaxis' DETECCIÓN Durante la ejecución." .

