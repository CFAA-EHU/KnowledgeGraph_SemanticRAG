@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSintaxisEnCSACSDEF a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis en '#CS/ACS DEF'" ;
    ns1:solucionadoPor ns1:RevisarSintaxisEnElManualDeProgramacion_34d405c6c0 ;
    ns1:textoExtracto "'#CS/ACS DEF <[n]> [MODE m, V1, V2, V3, j1, j2, j3, 0/1]: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisEnCSACSONNEW a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis en '#CS/ACS ON/NEW'" ;
    ns1:solucionadoPor ns1:RevisarSintaxisEnElManualDeProgramacion_34d405c6c0 ;
    ns1:textoExtracto "'#CS/ACS ON/NEW <[n]> <[MODE m, V1, V2, V3, j1, j2, j3, 0/1]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisEnKINID a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis en '#KIN ID'" ;
    ns1:solucionadoPor ns1:RevisarSintaxisEnElManualDeProgramacion_34d405c6c0 ;
    ns1:textoExtracto "'#KIN ID <[cinemática]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisarSintaxisEnElManualDeProgramacion_34d405c6c0 a ns1:DiagnosticoFallo ;
    rdfs:label "revisar sintaxis en el manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

