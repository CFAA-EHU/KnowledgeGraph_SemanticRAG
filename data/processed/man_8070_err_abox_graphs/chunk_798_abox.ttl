@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSintaxisEnCAXCabezalNombre a ns1:DiagnosticoFallo ;
    rdfs:label "error de sintaxis en '#CAX <[cabezal, nombre]>'"@es ;
    ns1:solucionaFallo ns1:RevisionDeSintaxisEnElManualDeProgramacion ;
    ns1:textoExtracto "'#CAX <[cabezal, nombre]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisEnCSACSDEFACTN a ns1:DiagnosticoFallo ;
