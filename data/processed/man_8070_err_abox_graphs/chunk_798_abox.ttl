    ns1:solucionaFallo ns1:RevisionDeSintaxisEnElManualDeProgramacion ;
    ns1:textoExtracto "'#CS/ACS DEF ACT[n]: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisEnCSACSONNEW_02017d7ff3 a ns1:DiagnosticoFallo ;
    rdfs:label "error de sintaxis en '#CS/ACS ON/NEW'"@es ;
    ns1:solucionaFallo ns1:RevisionDeSintaxisEnElManualDeProgramacion ;
    ns1:textoExtracto "'#CS/ACS ON/NEW <[n]> <[MODE m, V1, V2, V3, j1, j2, j3, 0/1]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

