@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisionDeSintaxis_e50c4dcb54 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de Sintaxis" ;
    ns1:solucionaFallo ns1:DETECCIONDuranteLaEdicionYEjecucion,
        ns1:DETECCIONDuranteLaEdicionYEjecucion_81391164eb,
        ns1:DETECCIONDuranteLaEdicionYEjecucion_f2eb9cf0ed ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:DETECCIONDuranteLaEdicionYEjecucion a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la edición y ejecución" ;
    ns1:textoExtracto "'#DGWZ[Eje1min, Eje1max, Eje2min, Eje2max <, Eje3min, Eje3max>]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DETECCIONDuranteLaEdicionYEjecucion_81391164eb a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la edición y ejecución" ;
    ns1:textoExtracto "'#PATH[\"path\"]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DETECCIONDuranteLaEdicionYEjecucion_f2eb9cf0ed a ns1:DiagnosticoFallo ;
    rdfs:label "DETECCIÓN Durante la edición y ejecución" ;
    ns1:textoExtracto "'#CD ON <[horizonte]>' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

