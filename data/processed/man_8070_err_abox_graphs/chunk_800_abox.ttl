@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9322
    a ex:DiagnosticoFallo ;
    rdfs:label "No hay Hardware para ejes Mechatrolink"@es ;
    ex:identificador "9322" ;
    ex:textoExtracto "9322 'No hay Hardware para ejes Mechatrolink' [...] CAUSA No se dispone del hardware necesario para trabajar con ejes Mechatrolink."@es ;
    ex:solucionaFallo ex:Accion_ContactarFagorAutomation .

ex:Fallo_9323
    a ex:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Tandem"@es ;
    ex:identificador "9323" ;
    ex:textoExtracto "9323 'Con ejes Mechatrolink no se admiten ejes Tandem'"@es .

ex:Fallo_DriveTypeInconsistente
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en parámetro DRIVETYPE en grupo MULTIAXIS"@es ;
    ex:textoExtracto "CAUSA Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE. SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos."@es ;
    ex:solucionaFallo ex:Accion_RevisarParametrosMaquina .

ex:Accion_RevisarParametrosMaquina
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar parámetros máquina (DRIVETYPE)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos."@es .

ex:Accion_ContactarFagorAutomation
    a ex:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ex:Parametro_DRIVETYPE
    a ex:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ex:textoExtracto "parámetro DRIVETYPE"@es ;
    ex:monitoreaParametro ex:Maquina_GrupoMultiAxis .

ex:Maquina_GrupoMultiAxis
    a ex:Maquina ;
    rdfs:label "Grupo MULTIAXIS"@es ;
    ex:textoExtracto "grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE"@es ;
    ex:tieneComponente ex:Componente_EjesMechatrolink .

ex:Componente_EjesMechatrolink
    a ex:Componente ;
    rdfs:label "Ejes Mechatrolink"@es ;
    ex:textoExtracto "ejes Mechatrolink"@es .