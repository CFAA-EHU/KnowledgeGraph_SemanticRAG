ns1:ErrorDeSintaxisEnEXECPathCanal a ns1:AccionProhibida ;
    rdfs:label "Error de sintaxis en '#EXEC[\"path\" <,canal>]' "@es ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a ;
    ns1:textoExtracto "'#EXEC[\\\"path\\\" <,canal>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

