@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_9323
    a ex:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Tandem" ;
    ex:identificador "9323" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay un regulador Mechatrolink que forma parte de una pareja tandem. SOLUCIÓN Un regulador Mechatrolink no puede formar parte de un eje tandem. Eliminar el eje Mechatrolink de la pareja tandem o usar reguladores Sercos." .

ex:DiagnosticoFallo_9324
    a ex:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten grupos MULTIAXIS" ;
    ex:identificador "9324" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay un regulador Mechatrolink que forma parte de un grupo MULTIAXIS. SOLUCIÓN Un regulador Mechatrolink no puede formar parte de un grupo MULTIAXIS. Eliminar el eje Mechatrolink del grupo MULTIAXIS o usar reguladores Sercos." .

ex:DiagnosticoFallo_9325
    a ex:DiagnosticoFallo ;
    rdfs:label "Ejes Mechatrolink: Los inverter tienen que ser cabezales" ;
    ex:identificador "9325" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En una configuración Mechatrolink, los inverters siempre deben ser cabezales. SOLUCIÓN Revisar los parámetros máquina." .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:valor "2 ms" ;
    ex:textoExtracto "El modo Mlink-I de Mechatrolink sólo admite un tiempo de ciclo de 2ms." .

ex:Parametro_MLINK
    a ex:Parametro ;
    rdfs:label "MLINK" ;
    ex:textoExtracto "Para el modo Mlink-I asignar un tiempo de ciclo de 2 ms (parámetro LOOPTIME) o utilizar el modo Mlink II (parámetro MLINK)." .

ex:DiagnosticoFallo_9326
    a ex:DiagnosticoFallo ;
    rdfs:label "Mechatrolink I: Looptime 2 ms" ;
    ex:identificador "9326" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El modo Mlink-I de Mechatrolink sólo admite un tiempo de ciclo de 2ms. SOLUCIÓN Para el modo Mlink-I asignar un tiempo de ciclo de 2 ms (parámetro LOOPTIME) o utilizar el modo Mlink II (parámetro MLINK)." ;
    ex:monitoreaParametro ex:Parametro_LOOPTIME .

ex:DiagnosticoFallo_9327
    a ex:DiagnosticoFallo ;
    rdfs:label "Mechatrolink: Número máximo de ejes y cabezales sobrepasado" ;
    ex:identificador "9327" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA La configuración Mechatrolink supera el máximo permitido de ejes y cabezales (servos e inverters)." .

ex:Sistema_Mechatrolink
    a ex:Sistema ;
    rdfs:label "Sistema Mechatrolink" ;
    ex:textoExtracto "configuración Mechatrolink" .

ex:DiagnosticoFallo_9323
    ex:solucionaFallo ex:Sistema_Mechatrolink .

ex:DiagnosticoFallo_9324
    ex:solucionaFallo ex:Sistema_Mechatrolink .

ex:DiagnosticoFallo_9325
    ex:solucionaFallo ex:Sistema_Mechatrolink .

ex:DiagnosticoFallo_9326
    ex:solucionaFallo ex:Sistema_Mechatrolink .

ex:DiagnosticoFallo_9327
    ex:solucionaFallo ex:Sistema_Mechatrolink .