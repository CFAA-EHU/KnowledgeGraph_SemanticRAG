ns1:ErrorDeSintaxisEnCOMMENTBEGINEND a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis en #COMMENT BEGIN/END"@es ;
    ns1:solucionaFallo ns1:RevisionDeSintaxisEnElManualDeProgramacion_d392bcf78b ;
    ns1:textoExtracto "#COMMENT BEGIN/END DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

