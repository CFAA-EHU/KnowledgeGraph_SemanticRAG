@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSintaxisRTCPONOFF a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis '#RTCP ON/OFF'"@es ;
    ns1:solucionaFallo ns1:RevisionDeLaSintaxisDeSentenciasEnElManualDeProgramacion ;
    ns1:textoExtracto "'#RTCP ON/OFF: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisTLCOFF a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis '#TLC OFF'"@es ;
    ns1:solucionaFallo ns1:RevisionDeLaSintaxisDeSentenciasEnElManualDeProgramacion ;
    ns1:textoExtracto "'#TLC OFF: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ErrorDeSintaxisTOOLORI a ns1:AccionProhibida ;
    rdfs:label "error de sintaxis '#TOOL ORI'"@es ;
    ns1:solucionaFallo ns1:RevisionDeLaSintaxisDeSentenciasEnElManualDeProgramacion ;
    ns1:textoExtracto "'#TOOL ORI: error de sintaxis' DETECCIÓN Durante" .

ns1:RevisionDeLaSintaxisDeSentenciasEnElManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "revisión de la sintaxis de sentencias en el manual de programación"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

