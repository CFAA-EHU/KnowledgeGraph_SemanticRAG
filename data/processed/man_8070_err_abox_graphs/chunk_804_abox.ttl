@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b00e2af76d a ns1:Sistema ;
    rdfs:label "CNC 8070"@es ;
    ns1:activaAlarma ns1:ErrorDeSintaxisCAXFACECYLOFF,
        ns1:ErrorDeSintaxisCSACSOFFALL,
        ns1:ErrorDeSintaxisECSONOFF,
        ns1:ErrorDeSintaxisMCSONOFF,
        ns1:ErrorDeSintaxisTOOLORI_09102aae7e,
        ns1:ErrorESBLKDSBLK,
        ns1:ErrorESTOPDSTOP,
        ns1:ErrorINITMACROTAB ;
    ns1:textoExtracto "CNC 8070" .

ns1:RevisionDeSintaxisDeSentencias a ns1:TareaMantenimiento ;
    rdfs:label "revisión de sintaxis de sentencias" ;
    ns1:solucionaFallo ns1:ErrorDeSintaxisCAXFACECYLOFF,
        ns1:ErrorDeSintaxisCSACSOFFALL,
        ns1:ErrorDeSintaxisECSONOFF,
        ns1:ErrorDeSintaxisMCSONOFF,
        ns1:ErrorDeSintaxisTOOLORI_09102aae7e,
        ns1:ErrorESBLKDSBLK,
        ns1:ErrorESTOPDSTOP,
        ns1:ErrorINITMACROTAB ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ErrorDeSintaxisCAXFACECYLOFF a ns1:DiagnosticoFallo ;
    rdfs:label "error de sintaxis '#CAX/FACE/CYL OFF'"@es ;
    ns1:textoExtracto "'#CAX/FACE/CYL OFF: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

