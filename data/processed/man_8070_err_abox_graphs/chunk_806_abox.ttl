@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaSintaxisDeLaSentenciaRETNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '#RET' no es correcta" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 ;
    ns1:textoExtracto "'#RET' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

