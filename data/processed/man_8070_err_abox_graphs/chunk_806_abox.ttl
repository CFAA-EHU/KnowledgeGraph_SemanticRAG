@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9336
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Parámetros máquina incompatibles" ;
    ex:identificador      "9336" ;
    ex:textoExtracto      "9336 'Parámetros máquina incompatibles' [...] Los parámetros máquina relacionados aparecen en el mensaje de error (por ejemplo, los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie)."@es .

ex:Parametro_HBLS
    a                     ex:Parametro ;
    rdfs:label            "HBLS" ;
    ex:textoExtracto      "los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie."@es .

ex:Parametro_MODBUSSVRRS
    a                     ex:Parametro ;
    rdfs:label            "MODBUSSVRRS" ;
    ex:textoExtracto      "los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie."@es .

ex:Diagnostico_9336
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Diagnóstico de incompatibilidad de parámetros 9336" ;
    ex:textoExtracto      "CAUSA: Hay activas dos prestaciones que son incompatibles entre sí. SOLUCIÓN: Anular uno de los dos."@es ;
    ex:solucionaFallo      ex:Error_9336 .