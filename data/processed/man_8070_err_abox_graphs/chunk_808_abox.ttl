ns1:NumeroDeAlmacenDeHerramientasNoValido_346c8aee7a a ns1:AccionProhibida ;
    rdfs:label "Número de almacén de herramientas no válido"@es ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_ad1679b76a ;
    ns1:textoExtracto "'Número de almacén de herramientas no válido' DETECCIÓN Durante la edición. CAUSA El número de almacén definido en la variable no es válido." .

