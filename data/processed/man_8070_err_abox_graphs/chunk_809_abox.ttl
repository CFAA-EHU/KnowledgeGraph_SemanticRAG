@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de Sintaxis" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaMOVEINFNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaTCAMOFFNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaTCAMONNoEsCorrecta ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:LaSintaxisDeLaSentenciaMOVEINFNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia #MOVE INF no es correcta" ;
    ns1:textoExtracto "'#MOVE INF[eje+/- <,avance> <,PRESENT/NEXT/NULL/WAITINPOS>]'. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaTCAMOFFNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia #<T>CAM OFF no es correcta" ;
    ns1:textoExtracto "'#<T>CAM OFF[esclavo]'. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaTCAMONNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia #<T>CAM ON no es correcta" ;
    ns1:textoExtracto "'#<T>CAM ON[l, maestro, esclavo, n, m, o, p <,ONCE/CONT>]'. CAUSA La sintaxis de la sentencia no es correcta." .

