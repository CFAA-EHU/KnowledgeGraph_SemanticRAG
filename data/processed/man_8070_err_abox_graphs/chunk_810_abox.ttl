ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia"@es ;
    ns1:solucionaFallo ns1:BSPLINEEje,
        ns1:CAMOFFEsclavo,
        ns1:DiagnosticoFallo_729cc9cfb1,
        ns1:FOLLOWOFFEsclavo,
        ns1:FOLLOWONMaestroEsclavoNmDnVELPOS,
        ns1:LATHECYMILLCYONOFF,
        ns1:SYNCCabezalMasterCabezalEsclavoNxDxOx ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:BSPLINEEje a ns1:DiagnosticoFallo ;
    rdfs:label "BSPLINE[eje]"@es ;
    ns1:textoExtracto "'#BSPLINE[eje]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

