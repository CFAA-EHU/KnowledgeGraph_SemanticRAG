@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ProgramarAmbosParametrosDYNONingunoNoSePuede a ns1:TareaMantenimiento ;
    rdfs:label "Programar ambos parámetros D y N o ninguno; no se puede" ;
    ns1:solucionaFallo ns1:EnLasSentenciasFOLLOWONYSYNCFaltaProgramarUnoDeLosParametrosDON ;
    ns1:textoExtracto "SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede" .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia a ns1:AvisoSeguridad ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:mitigaRiesgo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:EnLasSentenciasFOLLOWONYSYNCFaltaProgramarUnoDeLosParametrosDON a ns1:AccionProhibida ;
    rdfs:label "En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N" ;
    ns1:textoExtracto "CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta a ns1:AccionProhibida ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

