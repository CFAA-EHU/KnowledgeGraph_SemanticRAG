@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_9347
    a ex:DiagnosticoFallo ;
    rdfs:label "9347 'Eje repetido en VOLCOMP'" ;
    ex:identificador "9347" ;
    ex:textoExtracto "9347 'Eje repetido en VOLCOMP' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces. SOLUCIÓN Corregir los parámetros máquina." .

ex:DiagnosticoFallo_9348
    a ex:DiagnosticoFallo ;
    rdfs:label "9348 Ajuste del eje rotativo fuera de rango" ;
    ex:identificador "9348" ;
    ex:textoExtracto "9348 Ajuste del eje rotativo, (valor medido=%d) fuera del rango permitido por el valor máximo (V.K.MAXROTCOMP=%d) en el eje %s. DETECCIÓN Durante la calibración de cinemáticas. CAUSA El valor medido es mayor que el máximo permitido (V.K.MAXROTCOMP). SOLUCIÓN Cambiar el valor de V.K.MAXROTCOMP en la subrutina KINCAL_BEGIN.NC o el valor compensado quedará limitado a ese valor." .

ex:DiagnosticoFallo_9349
    a ex:DiagnosticoFallo ;
    rdfs:label "9349 Feedback del SET activo del eje no conectado" ;
    ex:identificador "9349" ;
    ex:textoExtracto "9349 El feedback del SET activo del eje no está conectado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El feedback definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones." .

ex:DiagnosticoFallo_9350
    a ex:DiagnosticoFallo ;
    rdfs:label "9350 Motor del SET activo del eje no conectado" ;
    ex:identificador "9350" ;
    ex:textoExtracto "9350 El motor del SET activo del eje no está conectado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El motor definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones." ;
    ex:solucionaFallo ex:ComponenteElectrico_MotorSET .

ex:DiagnosticoFallo_9351
    a ex:DiagnosticoFallo ;
    rdfs:label "9351 DEFAULTSET no coincide con M41SET..M44SET" ;
    ex:identificador "9351" ;
    ex:textoExtracto "9351 DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto." .

ex:ComponenteElectrico_MotorSET
    a ex:ComponenteElectrico ;
    rdfs:label "Motor del SET activo del eje" ;
    ex:textoExtracto "El motor definido en el set activo del eje no está conectado." .

ex:Parametro_V_K_MAXROTCOMP
    a ex:Parametro ;
    rdfs:label "V.K.MAXROTCOMP" ;
    ex:identificador "V.K.MAXROTCOMP" ;
    ex:textoExtracto "valor máximo permitido (V.K.MAXROTCOMP)" ;
    ex:valor "límite superior para compensación de eje rotativo" .

ex:Parametro_DEFAULTSET
    a ex:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ex:identificador "DEFAULTSET" ;
    ex:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

ex:Parametro_M41SET
    a ex:Parametro ;
    rdfs:label "M41SET" ;
    ex:identificador "M41SET" ;
    ex:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales." .

