@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9351
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 9351: Inconsistencia en DEFAULTSET"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar las conexiones. 9351 DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto."@es ;
    ex:identificador "9351" ;
    ex:monitoreaParametro ex:Parametro_DEFAULTSET ;
    ex:monitoreaParametro ex:Parametro_M41SET ;
    ex:monitoreaParametro ex:Parametro_M44SET .

ex:Fallo_9352
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 9352: Inconsistencia en CAXSET"@es ;
    ex:textoExtracto "9352 CAXSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina."@es ;
    ex:identificador "9352" ;
    ex:monitoreaParametro ex:Parametro_CAXSET ;
    ex:monitoreaParametro ex:Parametro_M41SET ;
    ex:monitoreaParametro ex:Parametro_M44SET .

ex:Parametro_DEFAULTSET
    a ex:Parametro ;
    rdfs:label "DEFAULTSET"@es ;
    ex:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales"@es ;
    ex:identificador "DEFAULTSET" .

ex:Parametro_CAXSET
    a ex:Parametro ;
    rdfs:label "CAXSET"@es ;
    ex:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales"@es ;
    ex:identificador "CAXSET" .

ex:Parametro_M41SET
    a ex:Parametro ;
    rdfs:label "M41SET"@es ;
    ex:textoExtracto "M41SET..M44SET en cabezales"@es ;
    ex:identificador "M41SET" .

ex:Parametro_M44SET
    a ex:Parametro ;
    rdfs:label "M44SET"@es ;
    ex:textoExtracto "M41SET..M44SET en cabezales"@es ;
    ex:identificador "M44SET" .

ex:Sistema_ValidacionParametros
    a ex:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ex:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina"@es ;
    ex:controla ex:Parametro_DEFAULTSET ;
    ex:controla ex:Parametro_CAXSET ;
    ex:controla ex:Parametro_M41SET ;
    ex:controla ex:Parametro_M44SET .