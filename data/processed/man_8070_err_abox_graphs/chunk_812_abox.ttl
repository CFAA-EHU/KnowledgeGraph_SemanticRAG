@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ANGAXOFFSUSPExpresion1Expresion2Expresion3 a ns1:DiagnosticoFallo ;
    rdfs:label "#ANGAX OFF/SUSP <[expresión1, expresión2, expresión3, ...]>" ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#ANGAX OFF/SUSP <[expresión1, expresión2, expresión3, ...]>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ANGAXONExpresion1Expresion2Expresion3 a ns1:DiagnosticoFallo ;
    rdfs:label "#ANGAX ON [expresión1, expresión2, expresión3, ...]" ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#ANGAX ON [expresión1, expresión2, expresión3, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:AmbosONinguno a ns1:DiagnosticoFallo ;
    rdfs:label "ambos o ninguno" ;
    ns1:solucionaFallo ns1:ProgramacionCorrecta ;
    ns1:textoExtracto "'ambos o ninguno' DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N." .

ns1:CDOFF a ns1:DiagnosticoFallo ;
    rdfs:label "#CD OFF" ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#CD OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DiagnosticoFallo_432e083d69 a ns1:DiagnosticoFallo ;
    rdfs:label "#MDOFF" ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#MDOFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:OSCEje1Eje2 a ns1:DiagnosticoFallo ;
    rdfs:label "#OSC eje1 eje2 ..." ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#OSC eje1 eje2 ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ProgramarElNumeradorAntesQueElDenominador a ns1:DiagnosticoFallo ;
    rdfs:label "Programar el numerador antes que el denominador" ;
    ns1:solucionaFallo ns1:ProgramarNumeradorDenominador ;
    ns1:textoExtracto "'Programar el numerador antes que el denominador' DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC, el parámetro D está programado antes que el parámetro N." .

ns1:SERVOONOFFEjeCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "#SERVO ON/OFF [eje/cabezal]" ;
    ns1:solucionaFallo ns1:RevisarSintaxis_62084c771e ;
    ns1:textoExtracto "'#SERVO ON/OFF [eje/cabezal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ProgramacionCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Programación Correcta" ;
    ns1:textoExtracto "SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." .

ns1:ProgramarNumeradorDenominador a ns1:TareaMantenimiento ;
    rdfs:label "Programar Numerador Denominador" ;
    ns1:textoExtracto "SOLUCIÓN Programar el parámetro N antes que el parámetro D." .

ns1:RevisarSintaxis_62084c771e a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Sintaxis" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

