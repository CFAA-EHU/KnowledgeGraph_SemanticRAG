@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeSintaxis_e50c4dcb54 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de Sintaxis" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaCLEARMarcaNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaHSCOFFNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaOSCEje1Eje2NoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:LaSintaxisDeLaSentenciaCLEARMarcaNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '#CLEAR<[marca, ...]>' no es correcta" ;
    ns1:textoExtracto "'#CLEAR<[marca, ...]>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaHSCOFFNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '#HSC OFF' no es correcta" ;
    ns1:textoExtracto "'#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaOSCEje1Eje2NoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '#OSC eje1 eje2 ...' no es correcta" ;
    ns1:textoExtracto "'#OSC eje1 eje2 ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

