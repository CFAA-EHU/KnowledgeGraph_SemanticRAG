@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultaDeManualParaError8428 a ns1:TareaMantenimiento ;
    rdfs:label "Consulta de manual para error 8428" ;
    ns1:solucionaFallo ns1:Error8428ERRORNoenteroTexto ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ConsultaDeManualParaError8429 a ns1:TareaMantenimiento ;
    rdfs:label "Consulta de manual para error 8429" ;
    ns1:solucionaFallo ns1:Error8429MSGTexto ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ConsultaDeManualParaError8430 a ns1:TareaMantenimiento ;
    rdfs:label "Consulta de manual para error 8430" ;
    ns1:solucionaFallo ns1:Error8430DGWZExpresion1Expresion2Expresion3Expresion4Expresion5Expresion6 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ConsultaDeManualParaError8431 a ns1:TareaMantenimiento ;
    rdfs:label "Consulta de manual para error 8431" ;
    ns1:solucionaFallo ns1:Error8431ESBLKDSBLK ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:RevisionDeSintaxisParaError8425 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis para error 8425" ;
    ns1:solucionaFallo ns1:Error8425HSCOFF ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisionDeSintaxisParaError8426 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis para error 8426" ;
    ns1:solucionaFallo ns1:Error8426DEFMacro1Text1Macro2Text2 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisionDeSintaxisParaError8427 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis para error 8427" ;
    ns1:solucionaFallo ns1:Error8427ParametroFIRSTSECONDNoPermitidoEnEsteMODE ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:Error8425HSCOFF a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8425 '#HSC OFF'"@es ;
    ns1:textoExtracto "'#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error8426DEFMacro1Text1Macro2Text2 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8426 '#DEF \"macro1\" = \"text1\" \"macro2\" = \"text2\" ...'"@es ;
    ns1:textoExtracto "'#DEF \"macro1\" = \"text1\" \"macro2\" = \"text2\" ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Error8427ParametroFIRSTSECONDNoPermitidoEnEsteMODE a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8427 'Parámetro FIRST/SECOND no permitido en este MODE'"@es ;
    ns1:textoExtracto "'Parámetro FIRST/SECOND no permitido en este MODE' DETECCIÓN Durante la edición. CAUSA En las sentencias #CS y #ACS, los comandos FIRST y SECOND sólo se pueden programar en el MODE 6." .

ns1:Error8428ERRORNoenteroTexto a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8428 '(ERROR <nºentero> <,\"texto\">)'"@es ;
    ns1:textoExtracto "'(ERROR <nºentero> <,\"texto\">) DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada."@es .

ns1:Error8429MSGTexto a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8429 '(MSG \"texto\")'"@es ;
    ns1:textoExtracto "'(MSG \"texto\")' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada."@es .

ns1:Error8430DGWZExpresion1Expresion2Expresion3Expresion4Expresion5Expresion6 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8430 '(DGWZ expresión1, expresión2, expresión3, expresión4 <,expresión5, expresión6>)'"@es ;
    ns1:textoExtracto "'(DGWZ expresión1, expresión2, expresión3, expresión4 <,expresión5, expresión6>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada." .

ns1:Error8431ESBLKDSBLK a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8431 '(ESBLK/DSBLK)'"@es ;
    ns1:textoExtracto "'(ESBLK/DSBLK)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las sentencias ESBLK/DSBLK no están solas en el bloque, o falta programar alguna de las dos." .

