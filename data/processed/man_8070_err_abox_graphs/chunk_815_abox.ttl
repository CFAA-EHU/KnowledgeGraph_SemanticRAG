@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarSintaxisCorrectaParaESTOPDSTOP a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta para ESTOP/DSTOP"@es ;
    ns1:solucionaFallo ns1:Error8432ESTOPDSTOP ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. Ambas sentencias deben ir solas en el bloque, y deben estar programadas ambas." .

ns1:ManualDel8055_5ee57ceb31 a ns1:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error8432ESTOPDSTOP a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8432 (ESTOP/DSTOP)"@es ;
    ns1:textoExtracto "'(ESTOP/DSTOP)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las sentencias ESTOP/DSTOP no están solas en el bloque, o falta programar alguna de las dos." .

