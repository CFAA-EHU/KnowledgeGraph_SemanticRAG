@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_9361
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9361" ;
    rdfs:label           "Modificación de canales/ejes/cabezales requiere rearranque" ;
    ex:textoExtracto     "Para modificar el número de canales, ejes o cabezales es necesario rearrancar el CNC. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Se ha intentado validar la tabla de parámetros máquina tras modificar el número de canales, ejes o cabezales."@es .

ex:Fallo_9364
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9364" ;
    rdfs:label           "Conflicto de REFERENCEID en ejes/cabezales" ;
    ex:textoExtracto     "Distintos ejes/cabezales no pueden compartir el mismo REFERENCEID al mismo tiempo. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Dos ejes o cabezales comparten simultáneamente la misma referencia."@es .

ex:Fallo_9369
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9369" ;
    rdfs:label           "DEFAULTSET incompatible con REFERENCEID compartido" ;
    ex:textoExtracto     "DEFAULTSET incompatible con ejes/cabezales que comparten el mismo REFERENCEID. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Dos ejes o cabezales comparten simultáneamente la misma referencia."@es .

ex:Fallo_9370
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9370" ;
    rdfs:label           "CURRBFID no admitido en ejes analógicos" ;
    ex:textoExtracto     "No se admite CURRBFID en ejes analógicos. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Se ha parametrizado CURRFBID para un eje/cabezal analógico."@es .

ex:Fallo_9371
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9371" ;
    rdfs:label           "Motor desconocido (AUTODETECT fallido)" ;
    ex:textoExtracto     "Motor desconocido. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA El CNC no reconoce un motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml."@es .

ex:Parametro_CURRBFID
    a                     ex:Parametro ;
    ex:identificador      "CURRBFID" ;
    ex:textoExtracto      "parámetro CURRBFID para eje/cabezal"@es ;
    ex:monitoreaParametro ex:Fallo_9370 .

ex:Parametro_REFERENCEID
    a                     ex:Parametro ;
    ex:identificador      "REFERENCEID" ;
    ex:textoExtracto      "parámetro REFERENCEID compartido por ejes/cabezales"@es ;
    ex:monitoreaParametro ex:Fallo_9364 , ex:Fallo_9369 .

ex:Parametro_DEFAULTSET
    a                     ex:Parametro ;
    ex:identificador      "DEFAULTSET" ;
    ex:textoExtracto      "parametrización de DEFAULTSET para sets de ejes/cabezales"@es ;
    ex:monitoreaParametro ex:Fallo_9369 .

ex:Componente_MotorDesconocido
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Motor no reconocido (AUTODETECT)" ;
    ex:textoExtracto      "motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml"@es ;
    ex:solucionaFallo      ex:Fallo_9371 .