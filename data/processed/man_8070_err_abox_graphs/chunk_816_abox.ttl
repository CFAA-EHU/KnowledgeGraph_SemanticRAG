@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualDeSintaxisCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual de sintaxis correcta" ;
    ns1:solucionaFallo ns1:ErrorEnSentenciaGOTO,
        ns1:ErrorEnSentenciaIF,
        ns1:ErrorEnSentenciaRET,
        ns1:ErrorEnSentenciaRPT,
        ns1:ErrorEnSentenciaSUB,
        ns1:ErrorEnSentenciasEFHOLDDFHOLD ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ErrorEnSentenciaCALL a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia CALL" ;
    ns1:textoExtracto "'(CALL expresión)' DETECCIÓN Durante la edición." .

ns1:ErrorEnSentenciaGOTO a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia GOTO" ;
    ns1:textoExtracto "'(GOTO N(expresión))' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorEnSentenciaIF a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia IF" ;
    ns1:textoExtracto "'(IF condición acción1 <ELSE acción2>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorEnSentenciaRET a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia RET" ;
    ns1:textoExtracto "'(RET)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorEnSentenciaRPT a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia RPT" ;
    ns1:textoExtracto "'(RPT N(expresión), N(expresión))' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorEnSentenciaSUB a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia SUB" ;
    ns1:textoExtracto "'(SUB nºentero)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorEnSentenciasEFHOLDDFHOLD a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencias EFHOLD/DFHOLD" ;
    ns1:textoExtracto "'(EFHOLD/DFHOLD)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

