ns1:ConsultarEnElManualDel8055LaSintaxisCorrecta_bceb698a7f a ns1:TareaMantenimiento ;
    rdfs:label "Consultar en el manual del 8055 la sintaxis correcta" ;
    ns1:solucionaFallo ns1:ErrorAlProgramarEnLenguajeDel8055ElBloqueG2G3ProgramadoNoAdmiteLosPar_9c1940daee,
        ns1:ErrorAlProgramarEnLenguajeDel8055ElNumeroDeEjesProgramadoParaEsaFunci_7c3fe6aaf4,
