ns1:ErrorAlProgramarEnLenguajeDel8055ElBloqueG2G3ProgramadoNoAdmiteLosPar_9c1940daee a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación." ;
    ns1:textoExtracto "'El bloque G2/G3 programado no admite parámetros I, J, K' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación." .

ns1:ErrorAlProgramarEnLenguajeDel8055ElNumeroDeEjesProgramadoParaEsaFunci_7c3fe6aaf4 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. El número de ejes programado para esa función G no es correcto." ;
    ns1:textoExtracto "'Número de ejes programado incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El número de ejes programado para esa función G no es correcto." .

ns1:ErrorAlProgramarEnLenguajeDel8055FuncionGMalProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. Función G mal programada." ;
    ns1:textoExtracto "'Función G mal programada.' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ErrorAlProgramarEnLenguajeDel8055LaSentenciaNoEstaBienProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. La sentencia no está bien programada." ;
    ns1:textoExtracto "'(PCALL/MCALL/PROBE expresión <,param>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada." .

ns1:ErrorAlProgramarEnLenguajeDel8055LaSentenciaNoEstaBienProgramada_1738edd71f a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. La sentencia no está bien programada." ;
    ns1:textoExtracto "'(EXEC P(expresión) <,directorio>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada." .

ns1:ErrorAlProgramarEnLenguajeDel8055LaSentenciaNoEstaSolaEnElBloqueONoSe_a5ad9e022f a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado." ;
    ns1:textoExtracto "'(MDOFF)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado." .

ns1:ErrorAlProgramarEnLenguajeDel8055LasAccionesProgramadasEnLaSentenciaI_ea4079d945 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al programar en lenguaje del 8055. Las acciones programadas en la sentencia IF no son válidas; las acciones no pueden ser IF ni SUB." ;
    ns1:textoExtracto "'Acción no permitida en sentencia IF' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las acciones programadas en la sentencia IF no son válidas; las acciones no pueden ser IF ni SUB." .

