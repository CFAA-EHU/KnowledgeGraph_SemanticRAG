@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de fallo (Alarmas)
ex:Fallo_9382 a ex:DiagnosticoFallo ;
    rdfs:label "Configuración de buses (requiere reinicio CNC)"@es ;
    ex:textoExtracto "9382 configuración de buses, necesita reiniciar CNC. [...] SOLUCIÓN Reiniciar el CNC."@es ;
    ex:identificador "9382" .

ex:Fallo_9500 a ex:DiagnosticoFallo ;
    rdfs:label "Sobretensión en bus de potencia"@es ;
    ex:textoExtracto "9500 Sobretensión en el bus de potencia. [...] SOLUCIÓN Resistencia de Ballast abierta o mal dimensionada. Mal funcionamiento de la RPS."@es ;
    ex:identificador "9500" .

ex:Fallo_9501 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en regulador"@es ;
    ex:textoExtracto "9501 Sobrecorriente. [...] SOLUCIÓN Revisar los parámetros y conexionado del motor."@es ;
    ex:identificador "9501" ;
    ex:solucionaFallo ex:Motor_Generico .  # Relación implícita por "conexionado del motor"

ex:Fallo_9502 a ex:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en regulador"@es ;
    ex:textoExtracto "9502 Cortocircuito. [...] SOLUCIÓN [...] conexión de los cables de potencia sea errónea o que estén en contacto, provocando un cortocircuito."@es ;
    ex:identificador "9502" .

ex:Fallo_9503 a ex:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en regulador"@es ;
    ex:textoExtracto "9503 Error de comunicación en regulador. [...] SOLUCIÓN Eliminar la causa del error y resetear el regulador."@es ;
    ex:identificador "9503" .

ex:Fallo_9504 a ex:DiagnosticoFallo ;
    rdfs:label "Error en señales de captación (encoder)"@es ;
    ex:textoExtracto "9504 Alarma en las señales de captación. [...] SOLUCIÓN Revisar el conexionado del encoder."@es ;
    ex:identificador "9504" .

ex:Fallo_9505 a ex:DiagnosticoFallo ;
    rdfs:label "Alarma de pulsos entre I0s"@es ;
    ex:textoExtracto "9505 Alarma de pulsos entre I0s. DETECCIÓN Durante el funcionamiento habitual del sistema."@es ;
    ex:identificador "9505" .

### Componentes genéricos (mencionados en soluciones)
ex:Motor_Generico a ex:ComponenteElectrico ;
    rdfs:label "Motor (genérico)"@es ;
    ex:textoExtracto "Revisar los parámetros y conexionado del motor."@es .

ex:Regulador_Generico a ex:ComponenteElectrico ;
    rdfs:label "Regulador (genérico)"@es ;
    ex:textoExtracto "Funcionamiento incorrecto del regulador [...] Cortocircuito en el regulador [...] Error de comunicación en regulador."@es .

ex:Encoder_Generico a ex:Sensor ;
    rdfs:label "Encoder (genérico)"@es ;
    ex:textoExtracto "Revisar el conexionado del encoder."@es .

ex:ResistenciaBallast a ex:ComponenteElectrico ;
    rdfs:label "Resistencia de Ballast"@es ;
    ex:textoExtracto "Resistencia de Ballast abierta o mal dimensionada."@es .

ex:RPS a ex:ComponenteElectrico ;
    rdfs:label "RPS (sistema de protección)"@es ;
    ex:textoExtracto "Mal funcionamiento de la RPS."@es .

### Relaciones entre fallos y componentes
ex:Fallo_9500 ex:solucionaFallo ex:ResistenciaBallast , ex:RPS .
ex:Fallo_9504 ex:solucionaFallo ex:Encoder_Generico .