@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_9505
    a ex:Alarma ;
    rdfs:label "Alarma de pulsos entre I0s" ;
    ex:identificador "9505" ;
    ex:textoExtracto "9505 Alarma de pulsos entre I0s. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." .

ex:Alarma_9506
    a ex:Alarma ;
    rdfs:label "Error de comprobación de CRC de PM" ;
    ex:identificador "9506" ;
    ex:textoExtracto "9506 Error de comprobación de CRC de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ex:Alarma_9507
    a ex:Alarma ;
    rdfs:label "Error en la detección de PM" ;
    ex:identificador "9507" ;
    ex:textoExtracto "9507 Error en la detección de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ex:Alarma_9508
    a ex:Alarma ;
    rdfs:label "Watchdog de regulador" ;
    ex:identificador "9508" ;
    ex:textoExtracto "9508 Watchdog de regulador. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc. SOLUCIÓN Contacte con Fagor Automation." .

ex:Alarma_9509
    a ex:Alarma ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ex:identificador "9509" ;
    ex:textoExtracto "9509 Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha detectado una caída en la tensión de control. SOLUCIÓN Revisar el conexionado y la alimentación de control de 24 Vdc." .

ex:Alarma_9510
    a ex:Alarma ;
    rdfs:label "Lazos de corriente en mismo nodo incompatibles" ;
    ex:identificador "9510" ;
    ex:textoExtracto "9510 Lazos de corriente en mismo nodo incompatibles. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Un regulador doble tiene configurados modos incompatibles de control para cada motor. SOLUCIÓN En un regulador doble, parametrizar el mismo tipo de control en ambos motores." .

ex:Alarma_9511
    a ex:Alarma ;
    rdfs:label "Error en la actualización de versión DSP" ;
    ex:identificador "9511" ;
    ex:textoExtracto "9511 Error en la actualización de versión DSP. DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no puede actualizar la versión del DSP en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Alarma_9512
    a ex:Alarma ;
    rdfs:label "Error en la actualización de versión FPGA" ;
    ex:identificador "9512" ;
    ex:textoExtracto "9512 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado." .

ex:ComponenteElectrico_Encoder
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ex:textoExtracto "Revisar la parametrización y el conexionado del encoder." .

ex:ComponenteElectrico_Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ex:textoExtracto "El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder." .

ex:ComponenteElectrico_ReguladorDoble
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador doble" ;
    ex:textoExtracto "Un regulador doble tiene configurados modos incompatibles de control para cada motor." .

ex:ComponenteElectrico_CNC
    a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC no puede actualizar la versión del DSP en algún regulador o RPS." .

ex:ComponenteElectrico_RPS
    a ex:ComponenteElectrico ;
    rdfs:label "RPS" ;
    ex:textoExtracto "El CNC no puede actualizar la versión del DSP en algún regulador o RPS." .

ex:Parametro_Tension24Vdc
    a ex:Parametro ;
    rdfs:label "Tensión de control 24 Vdc" ;
    ex:valor "24 Vdc" ;
    ex:textoExtracto "El regulador ha detectado una caída en la tensión de control. SOLUCIÓN Revisar el conexionado y la alimentación de control de 24 Vdc." .

ex:ComponenteElectrico_Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ex:textoExtracto "Un regulador doble tiene configurados modos incompatibles de control para cada motor." .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "SOLUCIÓN Contacte con Fagor Automation." .