@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_9518
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Sobrecorriente o cortocircuito en captación"@es ;
    ex:identificador "9518" ;
    ex:textoExtracto "Captación: Sobrecorriente o cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador."@es .

ex:Fallo_9519
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Señal de alarma recibida en captación"@es ;
    ex:identificador "9519" ;
    ex:textoExtracto "Captación: Recibida señal de alarma. DETECCIÓN"@es .

ex:Sensor_Captacion
    a               ex:Sensor ;
    rdfs:label      "Captador del sistema"@es ;
    ex:textoExtracto "revisar el nivel de las señales proporcionadas por el captador"@es ;
    ex:activaAlarma ex:Fallo_9518, ex:Fallo_9519 .

ex:Cable_Senal_AL
    a               ex:ComponenteElectrico ;
    rdfs:label      "Cable de señal AL y/o /AL"@es ;
    ex:textoExtracto "El cable de la señal AL y/o /AL puede estar roto o desconectado"@es .