@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarSintaxisCorrectaParaError8462 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta para error 8462" ;
    ns1:solucionaFallo ns1:Error8462EnLenguajeDel8055 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque." .

ns1:ConsultarSintaxisCorrectaParaError8463 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta para error 8463" ;
    ns1:solucionaFallo ns1:Error8463EnLenguajeDel8055 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error8462EnLenguajeDel8055 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8462 en lenguaje del 8055" ;
    ns1:textoExtracto "'(DIGIT/TRACE expresión <,param>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado." .

ns1:Error8463EnLenguajeDel8055 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8463 en lenguaje del 8055" ;
    ns1:textoExtracto "'(OPEN P(expresión) <,directorio><,A/D><,comentario>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada." .

