@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualDeSintaxisCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual de sintaxis correcta" ;
    ns1:solucionaFallo ns1:Error8463,
        ns1:Error8464,
        ns1:Error8465,
        ns1:Error8466,
        ns1:Error8467,
        ns1:Error8468,
        ns1:Error8469 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error8463 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8463" ;
    ns1:textoExtracto "'(OPEN P(expresión) <,directorio><,A/D><,comentario>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8464 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8464" ;
    ns1:textoExtracto "'(WRITE bloque)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8465 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8465" ;
    ns1:textoExtracto "'(REPOS eje1, eje2, ...)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8466 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8466" ;
    ns1:textoExtracto "'(PAGE expresión)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8467 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8467" ;
    ns1:textoExtracto "'(SYMBOL/ODW expresión1, expresión2, expresión3)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8468 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8468" ;
    ns1:textoExtracto "'(IB expresión = INPUT\"texto\" <,formato>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:Error8469 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8469" ;
    ns1:textoExtracto "'(DW expresión1 = expresión2 <expresión3 = expresión4><...>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

