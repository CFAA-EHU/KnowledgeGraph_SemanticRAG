@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9524_ABSIND
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9524: ABSIND - Error leyendo información"@es ;
    ex:identificador "9524" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador. SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ex:Error_9525_INDUCTOSYN_INC_Baja
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9525: INDUCTOSYN - Señal INC demasiado baja"@es ;
    ex:identificador "9525" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo. SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. • Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver. • Si el error persiste y no se puede eliminar con las acciones anteriores, pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ex:Error_9526_INDUCTOSYN_INC_Alta
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9526: INDUCTOSYN - Señal INC demasiado alta"@es ;
    ex:identificador "9526" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es .

ex:Modulo_ABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ex:textoExtracto "módulo ABSIND"@es .

ex:Regulador_Sistema
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador del sistema"@es ;
    ex:textoExtracto "El regulador ha perdido la sincronización con el módulo ABSIND"@es .

ex:Transductor_InductosynResolver
    a ex:Sensor ;
    rdfs:label "Transductor inductosyn/resolver"@es ;
    ex:textoExtracto "transductor inductosyn/resolver"@es .

ex:Cableado_ABSIND_Inductosyn
    a ex:ComponenteElectrico ;
    rdfs:label "Cableado entre módulo ABSIND y transductor inductosyn/resolver"@es ;
    ex:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver"@es .

ex:SoftwareAjuste_ABSIND
    a ex:InterfazUsuario ;
    rdfs:label "Software de ajuste del módulo ABSIND"@es ;
    ex:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste"@es .

ex:Error_9524_ABSIND
    ex:solucionaFallo ex:Modulo_ABSIND ;
    ex:solucionaFallo ex:Cableado_ABSIND_Inductosyn .

ex:Error_9525_INDUCTOSYN_INC_Baja
    ex:solucionaFallo ex:Modulo_ABSIND ;
    ex:solucionaFallo ex:Transductor_InductosynResolver ;
    ex:solucionaFallo ex:Cableado_ABSIND_Inductosyn ;
    ex:solucionaFallo ex:SoftwareAjuste_ABSIND .

ex:Regulador_Sistema
    ex:controla ex:Modulo_ABSIND .

ex:Modulo_ABSIND
    ex:monitoreaParametro ex:Transductor_InductosynResolver .