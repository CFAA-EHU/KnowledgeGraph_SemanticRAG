@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarFuncionesDisponiblesEnManualDel8055 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar funciones disponibles en manual del 8055" ;
    ns1:solucionaFallo ns1:LaFuncionProgramadaNoTieneEquivalenteEnElDel8055 ;
    ns1:textoExtracto "SOLUCIÓN El CNC no puede traducir la función. Consultar en el manual del 8055 las funciones disponibles." .

ns1:ParametroG45 a ns1:Parametro ;
    rdfs:label "Parámetro G45" ;
    ns1:textoExtracto "8478 G45 <eje1 angulo1 eje2 angulo2 ..." .

ns1:ProgramarPalabrasReservadasEnMayusculas a ns1:TareaMantenimiento ;
    rdfs:label "Programar palabras reservadas en mayúsculas" ;
    ns1:solucionaFallo ns1:MinusculasNoPermitidasEn8055_658f9fa77f ;
    ns1:textoExtracto "SOLUCIÓN Programar las palabras reservadas en mayúsculas." .

ns1:LaFuncionProgramadaNoTieneEquivalenteEnElDel8055 a ns1:DiagnosticoFallo ;
    rdfs:label "La función programada no tiene equivalente en el del 8055" ;
    ns1:textoExtracto "CAUSA La función programada no tiene equivalente en el del 8055." .

ns1:MinusculasNoPermitidasEn8055_658f9fa77f a ns1:DiagnosticoFallo ;
    rdfs:label "Minúsculas no permitidas en 8055" ;
    ns1:textoExtracto "'Minúsculas no permitidas en 8055'" .

