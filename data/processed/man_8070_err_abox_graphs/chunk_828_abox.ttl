ex:Error_9526_INDUCTOSYN
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error 9526: INDUCTOSYN - Señal INC demasiado alta"@es ;
    ex:identificador    "9526" ;
    ex:textoExtracto    "9526 INDUCTOSYN: Señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es ;
    ex:monitoreaParametro ex:Parametro_SenalINC_Inductosyn .

ex:Parametro_SenalINC_Inductosyn
    a                   ex:Parametro ;
    rdfs:label          "Señal INC del transductor Inductosyn/Resolver"@es ;
    ex:textoExtracto    "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es .

ex:Modulo_ABSIND
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Módulo ABSIND"@es ;
    ex:textoExtracto    "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste."@es ;
    ex:monitoreaParametro ex:Parametro_SenalINC_Inductosyn .

ex:Empresa_FagorAutomation
    a                   ex:Empresa ;
    rdfs:label          "Fagor Automation"@es ;
    ex:textoExtracto    "Si el error persiste, póngase en contacto con Fagor Automation."@es .