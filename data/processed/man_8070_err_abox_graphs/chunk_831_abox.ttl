@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_7d6ae0ae39 a ns1:AccionProhibida ;
    rdfs:label "Función G15" ;
    ns1:textoExtracto "Programación incorrecta de la función G15 en" .

ns1:DGSPDLNombreCabezal a ns1:AccionProhibida ;
    rdfs:label "#DGSPDL nombre_cabezal" ;
    ns1:solucionaFallo ns1:RevisarManualDeProgramacion ;
    ns1:textoExtracto "'#DGSPDL nombre_cabezal' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:OrdenDeDatosIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Orden de datos incorrecto" ;
    ns1:solucionaFallo ns1:ConsultarManualDel8055 ;
    ns1:textoExtracto "'Orden de datos incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:ProgramacionNoValidaEnFresadora a ns1:AccionProhibida ;
    rdfs:label "Programación no válida en fresadora" ;
    ns1:solucionaFallo ns1:ConsultarManualDel8055 ;
    ns1:textoExtracto "'Programación no válida en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:RevisarManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ConsultarManualDel8055 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual del 8055" ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

