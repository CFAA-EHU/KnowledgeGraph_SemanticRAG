@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_9529
    a ex:Alarma ;
    rdfs:label "Checksum EEPROM incorrecto (INDUCTOSYN)"@es ;
    ex:identificador "9529" ;
    ex:textoExtracto "9529 INDUCTOSYN:Checksum EEPROM incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El checksum leído durante la inicialización del módulo ABSIND es incorrecto."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_9529 .

ex:DiagnosticoFallo_9529
    a ex:DiagnosticoFallo ;
    rdfs:label "Checksum EEPROM incorrecto en módulo ABSIND"@es ;
    ex:textoExtracto "El checksum leído durante la inicialización del módulo ABSIND es incorrecto. SOLUCIÓN Las posibles soluciones son: • Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. • Sustituir el módulo ABSIND asociado a esa captación."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_ABSIND .

ex:ComponenteElectrico_ABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ex:textoExtracto "módulo ABSIND asociado a esa captación"@es ;
    ex:monitoreaParametro ex:Parametro_SSITYPE .

ex:Parametro_SSITYPE
    a ex:Parametro ;
    rdfs:label "SSITYPE"@es ;
    ex:identificador "SSITYPE" ;
    ex:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND."@es .

ex:Alarma_9530
    a ex:Alarma ;
    rdfs:label "Error desconocido (INDUCTOSYN)"@es ;
    ex:identificador "9530" ;
    ex:textoExtracto "9530 INDUCTOSYN:Error desconocido. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El módulo ABSIND ha generado un error desconocido."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_9530 .

ex:DiagnosticoFallo_9530
    a ex:DiagnosticoFallo ;
    rdfs:label "Error desconocido en módulo ABSIND"@es ;
    ex:textoExtracto "El módulo ABSIND ha generado un error desconocido. SOLUCIÓN Si el error es repetitivo y persiste pruebe a sustituir el módulo ABSIND asociado a esa captación."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_ABSIND .

ex:Alarma_9531
    a ex:Alarma ;
    rdfs:label "Inconsistencia parámetro SSITYPE (INDUCTOSYN)"@es ;
    ex:identificador "9531" ;
    ex:textoExtracto "9531 INDUCTOSYN:Inconsistencia parámetro SSITYPE con captador conectado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_9531 .

ex:DiagnosticoFallo_9531
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia SSITYPE en módulo ABSIND"@es ;
    ex:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND. Revise el estado del dipswitch S50 del módulo ABSIND."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_ABSIND .

ex:Alarma_9532
    a ex:Alarma ;
    rdfs:label "Nivel de tensión 24 V DC/15 V DC demasiado bajo (INDUCTOSYN)"@es ;
    ex:identificador "9532" ;
    ex:textoExtracto "9532 INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado bajo. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Fallo en la alimentación del módulo."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_9532 .

ex:DiagnosticoFallo_9532
    a ex:DiagnosticoFallo ;
    rdfs:label "Alimentación insuficiente en módulo ABSIND"@es ;
    ex:textoExtracto "Fallo en la alimentación del módulo ABSIND. SOLUCIÓN Comprobar la alimentación del módulo ABSIND."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_ABSIND .

ex:Alarma_9533
    a ex:Alarma ;
    rdfs:label "Nivel de tensión 24 V DC/15 V DC demasiado alto (INDUCTOSYN)"@es ;
    ex:identificador "9533" ;
    ex:textoExtracto "9533 INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado alto."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_9533 .

ex:DiagnosticoFallo_9533
    a ex:DiagnosticoFallo ;
    rdfs:label "Sobretensión en módulo ABSIND"@es ;
    ex:textoExtracto "Nivel de tensión 24 V DC/15 V DC demasiado alto en el módulo ABSIND."@es ;
    ex:solucionaFallo ex:ComponenteElectrico_ABSIND .