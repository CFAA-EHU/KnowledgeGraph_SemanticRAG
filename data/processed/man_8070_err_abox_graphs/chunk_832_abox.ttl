@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloAlimentacionModuloABSIND
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la alimentación del módulo ABSIND"@es ;
    ex:textoExtracto "CAUSA Fallo en la alimentación del módulo. SOLUCIÓN Comprobar la alimentación del módulo ABSIND."@es ;
    ex:identificador "9533" .

ex:FalloAlimentacionModuloABSIND_9534
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la captación digital Fagor por fallo de alimentación"@es ;
    ex:textoExtracto "9534 Captación digital Fagor. Error en la"@es ;
    ex:identificador "9534" .

ex:ModuloABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ex:textoExtracto "Comprobar la alimentación del módulo ABSIND"@es .

ex:SistemaInductosyn
    a ex:Sistema ;
    rdfs:label "Sistema INDUCTOSYN"@es ;
    ex:textoExtracto "INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado alto"@es .

ex:ParametroTensionInductosyn
    a ex:Parametro ;
    rdfs:label "Nivel de tensión INDUCTOSYN (24 V DC/15 V DC)"@es ;
    ex:textoExtracto "Nivel de tensión 24 V DC/15 V DC demasiado alto"@es ;
    ex:valor "24/15 V DC" .

ex:FalloAlimentacionModuloABSIND
    ex:solucionaFallo ex:ModuloABSIND .

ex:SistemaInductosyn
    ex:tieneComponente ex:ModuloABSIND ;
    ex:monitoreaParametro ex:ParametroTensionInductosyn .

ex:ParametroTensionInductosyn
    ex:monitoreaParametro ex:ModuloABSIND .