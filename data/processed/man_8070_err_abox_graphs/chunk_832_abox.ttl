@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5a16c9f18c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ConsultarManual ;
    ns1:textoExtracto "CNC 8070" .

ns1:ConsultarManual a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual" ;
    ns1:solucionaFallo ns1:ELSEIFCondicion,
        ns1:FORIInicialFinalIncremento,
        ns1:GOTONexpresionGOTOExpresion,
        ns1:IFCondicion,
        ns1:NoSeAdmiteNumeroDeRepeticiones,
        ns1:ProgramacionNoValidaEnFresadora_fa51821eeb,
        ns1:ProgramacionNoValidaEnTorno,
        ns1:SWITCHExpresion ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ELSEIFCondicion a ns1:DiagnosticoFallo ;
    rdfs:label "$ELSEIF condición" ;
    ns1:textoExtracto "'$ELSEIF condición' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:FORIInicialFinalIncremento a ns1:DiagnosticoFallo ;
    rdfs:label "$FOR i = inicial, final, incremento" ;
    ns1:textoExtracto "'$FOR i = inicial, final, incremento' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:GOTONexpresionGOTOExpresion a ns1:DiagnosticoFallo ;
    rdfs:label "$GOTO Nexpresión/$GOTO [expresión]" ;
    ns1:textoExtracto "'$GOTO Nexpresión/$GOTO [expresión]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:IFCondicion a ns1:DiagnosticoFallo ;
    rdfs:label "$IF condición" ;
    ns1:textoExtracto "'$IF condición' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:NoSeAdmiteNumeroDeRepeticiones a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite número de repeticiones" ;
    ns1:textoExtracto "'No se admite número de repeticiones' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Sólo se permite programar el número de repeticiones en un bloque de movimiento." .

ns1:ProgramacionNoValidaEnFresadora_fa51821eeb a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no válida en fresadora" ;
    ns1:textoExtracto "'Programación no válida en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G15 en fresadora." .

ns1:ProgramacionNoValidaEnTorno a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no válida en torno" ;
    ns1:textoExtracto "'Programación no válida en torno' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G15 en torno." .

ns1:SWITCHExpresion a ns1:DiagnosticoFallo ;
    rdfs:label "$SWITCH expresión" ;
    ns1:textoExtracto "'$SWITCH expresión' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

