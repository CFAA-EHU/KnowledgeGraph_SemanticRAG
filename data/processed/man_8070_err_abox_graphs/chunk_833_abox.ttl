@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaCASEExpresionNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaSWITCHExpresionNoEsCorrecta,
        ns1:LaSintaxisDeLaSentenciaWHILECondicionNoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:LaSintaxisDeLaSentenciaCASEExpresionNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '$CASE expresión' no es correcta" ;
    ns1:textoExtracto "'$CASE expresión' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaSWITCHExpresionNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '$SWITCH expresión' no es correcta" ;
    ns1:textoExtracto "'$SWITCH expresión' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LaSintaxisDeLaSentenciaWHILECondicionNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la sentencia '$WHILE condición' no es correcta" ;
    ns1:textoExtracto "$WHILE condición DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

