@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSintaxisEnSentencia a ns1:AccionProhibida ;
    rdfs:label "Error de sintaxis en sentencia" ;
    ns1:mitigaRiesgo ns1:RevisarManualDeProgramacion_74ddf244d2 ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

ns1:OrdenODatoIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Orden o dato incorrecto" ;
    ns1:mitigaRiesgo ns1:RevisarManualDeProgramacion_74ddf244d2 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. Se ha programado un término desconocido en el bloque o bien el orden de los términos programados no es correcto." .

ns1:RevisarLaProgramacionDelBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Revisar la programación del bloque" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación del bloque." .

ns1:SobraParametro a ns1:AccionProhibida ;
    rdfs:label "Sobra parámetro" ;
    ns1:textoExtracto "'Sobra parámetro' DETECCIÓN Durante la edición." .

ns1:ValorDeParametroKIncorrecto a ns1:AccionProhibida ;
    rdfs:label "Valor de parámetro K incorrecto" ;
    ns1:mitigaRiesgo ns1:RevisarManualDeProgramacion_74ddf244d2 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. Valor incorrecto del parámetro K para la función G programada." .

ns1:ConsultarEnElManualDel8055LaSintaxisCorrecta_46b46f0c1e a ns1:DiagnosticoFallo ;
    rdfs:label "Consultar en el manual del 8055 la sintaxis correcta" ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e7517e91d6 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarManualDeProgramacion_74ddf244d2 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar manual de programación" ;
    ns1:solucionaFallo ns1:ConsultarEnElManualDel8055LaSintaxisCorrecta_46b46f0c1e,
        ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e7517e91d6 ;
    ns1:textoExtracto "Revisar manual de programación" .

