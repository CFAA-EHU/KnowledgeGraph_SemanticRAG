@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultarManualDel8055ParaSintaxisCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual del 8055 para sintaxis correcta" ;
    ns1:solucionaFallo ns1:LaFuncionOSentenciaVaSolaEnElBloque,
        ns1:ParametrosIncorrectosEnFuncion,
        ns1:SobraParametro_9292a0afa1 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:LaInterpolacionCircularEnPolaresNoAdmiteRadio a ns1:DiagnosticoFallo ;
    rdfs:label "La interpolación circular en polares no admite radio" ;
    ns1:textoExtracto "'La interpolación circular en polares no admite radio' DETECCIÓN Durante la edición." .

ns1:LaFuncionOSentenciaVaSolaEnElBloque a ns1:DiagnosticoFallo ;
    rdfs:label "La función o sentencia va sola en el bloque" ;
    ns1:textoExtracto "La función o sentencia va sola en el bloque. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Se ha programado en el bloque algún término no relacionado con la sentencia o función." .

ns1:ParametrosIncorrectosEnFuncion a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetros incorrectos en función" ;
    ns1:textoExtracto "'Parámetros incorrectos en función' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Hay parámetros inválidos en función G programada." .

ns1:SobraParametro_9292a0afa1 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobra parámetro" ;
    ns1:textoExtracto "'Sobra parámetro' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Hay un parámetro de más en la función G24/G27." .

