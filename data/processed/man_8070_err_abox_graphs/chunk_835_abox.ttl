@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

### Diagnósticos de Fallo (Códigos 9538-9542)
ex:Fallo_9538
    a ex:DiagnosticoFallo ;
    ex:identificador "9538" ;
    rdfs:label "Captación digital Fagor. Tensión de alimentación fuera de rango"@es ;
    ex:textoExtracto "9538 Captación digital Fagor. Tensión de alimentación fuera de rango. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        ex:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado. Comprobar que la longitud del cable es adecuada y la conexión del cableado es satisfactoria."@es
    ] .

ex:Fallo_9539
    a ex:DiagnosticoFallo ;
    ex:identificador "9539" ;
    rdfs:label "Captación digital Fagor. Error de parámetros en captación"@es ;
    ex:textoExtracto "9539 Captación digital Fagor. Error de parámetros en captación. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Pérdida de la configuración del encóder o de la cabeza de la regla."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        ex:textoExtracto "Reemplazar el encóder o la cabeza de la regla. Póngase en contacto con Fagor Automation."@es
    ] .

ex:Fallo_9540
    a ex:DiagnosticoFallo ;
    ex:identificador "9540" ;
    rdfs:label "Error en la alimentación de las salidas analógicas"@es ;
    ex:textoExtracto "9540 Error en la alimentación de las salidas analógicas. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en la alimentación de las salidas analógicas del CNC."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        ex:textoExtracto "Revisar el conexionado de salida analógica. Si el error persiste, póngase en contacto con Fagor Automation."@es
    ] .

ex:Fallo_9541
    a ex:DiagnosticoFallo ;
    ex:identificador "9541" ;
    rdfs:label "Caída del bus de potencia en presencia de par"@es ;
    ex:textoExtracto "9541 Caída del bus de potencia en presencia de par. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Posible caída en alguna de las líneas trifásicas o fallo en algún regulador."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        ex:textoExtracto "Comprobar que el estado de la líneas, los reguladores y revisar maniobra de potencia."@es
    ] .

ex:Fallo_9542
    a ex:DiagnosticoFallo ;
    ex:identificador "9542" ;
    rdfs:label "Captación digital Fagor. Señal analógica por debajo de 0,4 Vpp"@es ;
    ex:textoExtracto "9542 Captación digital Fagor. Señal analógica por debajo de 0,4 Vpp. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        ex:textoExtracto "Revisar los cables y la conexión de las entradas de captación. Si el error persiste, póngase en contacto con Fagor Automation."@es
    ] .

### Componentes Genéricos (Mencionados en Soluciones)
ex:Encoder_Regla
    a ex:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de la regla"@es ;
    ex:textoExtracto "reemplazar el encóder o la cabeza de la regla"@es .

ex:CableAlimentacionEncoder
    a ex:ComponenteElectrico ;
    rdfs:label "Cable de alimentación del encóder o de la regla"@es ;
    ex:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado"@es .

ex:CableadoSalidaAnalogica
    a ex:ComponenteElectrico ;
    rdfs:label "Conexionado de salida analógica"@es ;
    ex:textoExtracto "Revisar el conexionado de salida analógica"@es .

ex:LineasTrifasicas
    a ex:ComponenteElectrico ;
    rdfs:label "Líneas trifásicas"@es ;
    ex:textoExtracto "Posible caída en alguna de las líneas trifásicas"@es .

ex:ReguladorPotencia
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador de potencia"@es ;
    ex:textoExtracto "fallo en algún regulador"@es .

ex:CablesEntradaCaptacion
    a ex:ComponenteElectrico ;
    rdfs:label "Cables de entrada de captación"@es ;
    ex:textoExtracto "Revisar los cables y la conexión de las entradas de captación"@es .

### Empresa (Fabricante)
ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation"@es .