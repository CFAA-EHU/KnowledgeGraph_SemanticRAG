@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_94031b0b5c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055." .

ns1:ConsultarManualDeSintaxisCorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual de sintaxis correcta" ;
    ns1:solucionaFallo ns1:FaltaProgramarLaCotaFinalDelMovimiento,
        ns1:LaInterpolacionCircularEnPolaresNoAdmiteRadio ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:FaltaProgramarLaCotaFinalDelMovimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar la cota final del movimiento" ;
    ns1:textoExtracto "'Falta programar la cota final del movimiento' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

ns1:LaInterpolacionCircularEnPolaresNoAdmiteRadio a ns1:DiagnosticoFallo ;
    rdfs:label "La interpolación circular en polares no admite radio" ;
    ns1:textoExtracto "'La interpolación circular en polares no admite radio' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055." .

