@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_AmplitudSenialBaja
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo: Amplitud de señal de entrada baja"@es ;
    ex:textoExtracto "CAUSA Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente. [...] Revisar los cables y la conexión de las entradas de captación."@es ;
    ex:identificador "9543" ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Revisión de cables y conexiones de entrada"@es ;
        ex:textoExtracto "Revisar los cables y la conexión de las entradas de captación."@es ;
        ex:requiereMantenimiento ex:SistemaCaptacionDigital_Fagor
    ] .

ex:SistemaCaptacionDigital_Fagor
    a               ex:Sistema ;
    rdfs:label      "Sistema de captación digital Fagor"@es ;
    ex:textoExtracto "9543 Captación digital Fagor"@es ;
    ex:identificador "9543" ;
    ex:tieneComponente [
        a               ex:Sensor ;
        rdfs:label      "Encoder (captación digital)"@es ;
        ex:textoExtracto "Alimentación del encoder fuera de valores deseables. [...] Error interno en el encoder."@es
    ] ;
    ex:monitoreaParametro [
        a               ex:Parametro ;
        rdfs:label      "Amplitud de señal de entrada"@es ;
        ex:textoExtracto "Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente."@es ;
        ex:valor        "0.4 Vpp"^^<http://qudt.org/vocabulary/unit/VoltPeakToPeak>
    ] .

ex:Fallo_AlimentacionEncoder
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo: Alimentación del encoder fuera de rango"@es ;
    ex:textoExtracto "Alimentación del encoder fuera de valores deseables. [...] Error interno en el encoder."@es ;
    ex:identificador "9543_Encoder" ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Revisión del encoder"@es ;
        ex:textoExtracto "Revisar el [encoder]."@es ;
        ex:requiereMantenimiento ex:SistemaCaptacionDigital_Fagor
    ] .