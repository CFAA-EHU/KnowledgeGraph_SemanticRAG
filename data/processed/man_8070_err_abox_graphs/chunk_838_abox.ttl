@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ABORTExpresionFileNameNexpresionOFF a ns1:DiagnosticoFallo ;
    rdfs:label "#ABORT [expresión]/[\"file_name\"]/Nexpresión/OFF" ;
    ns1:textoExtracto "#ABORT [expresión]/[\"file_name\"]/Nexpresión/OFF DETECCIÓN Durante la edición y ejecución." .

ns1:SolucionDobleProgramacionComodin a ns1:TareaMantenimiento ;
    rdfs:label "Solución Doble Programación Comodín" ;
    ns1:solucionaFallo ns1:DobleProgramacionComodin ;
    ns1:textoExtracto "SOLUCIÓN Programar el comodín una sola vez en el bloque." .

ns1:SolucionNumeroComodinNoValido a ns1:TareaMantenimiento ;
    rdfs:label "Solución Número Comodín No Válido" ;
    ns1:solucionaFallo ns1:NumeroDeComodinNoValido ;
    ns1:textoExtracto "SOLUCIÓN El número programado en el comodín '? n' debe ser un número de eje válido." .

ns1:SolucionTipoComodinSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Solución Tipo Comodín Sentencia" ;
    ns1:solucionaFallo ns1:NoSePermiteEsteTipoDeComodinEnSentencia ;
    ns1:textoExtracto "SOLUCIÓN No se admite un comodín como eje de una variable, cuando el eje está en otro canal." .

ns1:DobleProgramacionComodin a ns1:DiagnosticoFallo ;
    rdfs:label "Doble programación comodín" ;
    ns1:textoExtracto "'Doble programación comodín' DETECCIÓN Durante la edición. CAUSA El comodín '? n' está programado más de una vez en el bloque." .

ns1:NoSePermiteEsteTipoDeComodinEnSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite este tipo de comodín en sentencia" ;
    ns1:textoExtracto "8508 No se permite este tipo de comodín en sentencia. DETECCIÓN Durante la edición. CAUSA Se ha programado con un comodín el eje de una variable, y el eje está en otro canal." .

ns1:NumeroDeComodinNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Número de comodín no válido" ;
    ns1:textoExtracto "'Número de comodín no válido' DETECCIÓN Durante la edición. CAUSA El número programado en el comodín '? n' es negativo o mayor que el número de ejes del canal." .

