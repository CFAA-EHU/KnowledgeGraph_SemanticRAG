@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9558
    a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de la resistencia de Ballast" ;
    ex:textoExtracto "9558 Sobrecarga de la resistencia de Ballast. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El ciclo de trabajo es demasiado exigente para la resistencia de Ballast. SOLUCIÓN Revisar selección de la resistencia de Ballast." ;
    ex:identificador "9558" .

ex:Fallo_9610
    a ex:DiagnosticoFallo ;
    rdfs:label "Cortocircuito" ;
    ex:textoExtracto "9610 Cortocircuito. DETECCIÓN" ;
    ex:identificador "9610" .

ex:ResistenciaBallast
    a ex:ComponenteElectrico ;
    rdfs:label "Resistencia de Ballast" ;
    ex:textoExtracto "Límite de corriente en la resistencia de Ballast. [...] Sobrecarga de la resistencia de Ballast. [...] Revisar selección de la resistencia de Ballast." .

ex:DiagnosticoFallo_9558_ResistenciaBallast
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de corriente en la resistencia de Ballast" ;
    ex:textoExtracto "CAUSA Límite de corriente en la resistencia de Ballast. SOLUCIÓN Revisar el conexionado e integridad de la resistencia de Ballast." ;
    ex:solucionaFallo ex:Fallo_9558 ;
    ex:monitoreaParametro ex:ResistenciaBallast .

ex:TareaMantenimiento_RevisarConexionadoResistenciaBallast
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar conexionado e integridad de la resistencia de Ballast" ;
    ex:textoExtracto "Revisar el conexionado e integridad de la resistencia de Ballast." ;
    ex:requiereMantenimiento ex:ResistenciaBallast .

ex:TareaMantenimiento_RevisarSeleccionResistenciaBallast
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar selección de la resistencia de Ballast" ;
    ex:textoExtracto "Revisar selección de la resistencia de Ballast." ;
    ex:requiereMantenimiento ex:ResistenciaBallast .