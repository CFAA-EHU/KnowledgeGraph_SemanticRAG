@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_9610
    a ex:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en regulador" ;
    ex:identificador "9610" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Detección de cortocircuito en el regulador. SOLUCIÓN Las posibles soluciones son las siguientes: • Realizar un reset del error. Si el error persiste, es posible que la conexión de los cables de potencia sea errónea o que estén en contacto, provocando un cortocircuito. • Es posible que los parámetros sean incorrectos o se deba a un fallo del regulador." ;
    ex:solucionaFallo ex:Regulador_Generico .

ex:DiagnosticoFallo_9611
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en regulador" ;
    ex:identificador "9611" ;
    ex:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Regulador en estado de error. SOLUCIÓN Eliminar la causa del error y resetear el regulador." ;
    ex:solucionaFallo ex:Regulador_Generico .

ex:DiagnosticoFallo_9612
    a ex:DiagnosticoFallo ;
    rdfs:label "Alarma en señales de captación (Vpp del encoder)" ;
    ex:identificador "9612" ;
    ex:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en las señales Vpp del encoder. SOLUCIÓN Revisar el conexionado del encoder." ;
    ex:solucionaFallo ex:Encoder_Generico ;
    ex:monitoreaParametro ex:Parametro_VppEncoder .

ex:DiagnosticoFallo_9613
    a ex:DiagnosticoFallo ;
    rdfs:label "Alarma de pulsos entre I0s del encoder" ;
    ex:identificador "9613" ;
    ex:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." ;
    ex:solucionaFallo ex:Encoder_Generico ;
    ex:monitoreaParametro ex:Parametro_I0Encoder .

ex:DiagnosticoFallo_9614
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de comprobación de CRC de PM" ;
    ex:identificador "9614" ;
    ex:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." ;
    ex:solucionaFallo ex:Regulador_Generico .

ex:DiagnosticoFallo_9615
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la detección de PM" ;
    ex:identificador "9615" ;
    ex:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." ;
    ex:solucionaFallo ex:Regulador_Generico .

ex:DiagnosticoFallo_9616
    a ex:DiagnosticoFallo ;
    rdfs:label "Watchdog de regulador" ;
    ex:identificador "9616" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc. SOLUCIÓN Contacte con Fagor Automation." ;
    ex:solucionaFallo ex:Regulador_Generico .

ex:DiagnosticoFallo_9617
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ex:identificador "9617" ;
    ex:textoExtracto "Fallo 24 Vdc inesperado." ;
    ex:solucionaFallo ex:SistemaElectrico_Generico .

ex:Regulador_Generico
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ex:textoExtracto "Detección de cortocircuito en el regulador", "Regulador en estado de error", "Error interno del regulador" .

ex:Encoder_Generico
    a ex:Sensor ;
    rdfs:label "Encoder" ;
    ex:textoExtracto "El regulador ha detectado un error en las señales Vpp del encoder", "El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder" .

ex:Parametro_VppEncoder
    a ex:Parametro ;
    rdfs:label "Señal Vpp del encoder" ;
    ex:textoExtracto "señales Vpp del encoder" .

ex:Parametro_I0Encoder
    a ex:Parametro ;
    rdfs:label "Señales I0 del encoder" ;
    ex:textoExtracto "señales de I0 del encoder" .

ex:SistemaElectrico_Generico
    a ex:Sistema ;
    rdfs:label "Sistema eléctrico (24 Vdc)" ;
    ex:textoExtracto "Fallo 24 Vdc inesperado" .