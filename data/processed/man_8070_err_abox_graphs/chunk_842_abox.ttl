PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9616
    a ex:DiagnosticoFallo ;
    rdfs:label "Watchdog de regulador" ;
    ex:identificador "9616" ;
    ex:textoExtracto "9616 Watchdog de regulador. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc." ;
    ex:textoExtracto "SOLUCIÓN Contacte con Fagor Automation." .

ex:Fallo_9617
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ex:identificador "9617" ;
    ex:textoExtracto "9617 Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha" .

ex:Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ex:textoExtracto "El regulador no responde; posible mal funcionamiento, conexionado, etc." .

ex:Fallo_9616
    ex:solucionaFallo ex:Regulador .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "SOLUCIÓN Contacte con Fagor Automation." .