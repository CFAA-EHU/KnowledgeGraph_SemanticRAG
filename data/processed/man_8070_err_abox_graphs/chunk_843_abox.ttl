@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:ProgramarUnaSecuenciaDeEjesYOCabezalesDelCanal,
        ns1:RENAMEAXOFF,
        ns1:VOLCOMPONOFF ;
    ns1:textoExtracto "8527 '#REPOS <INT/INI> nombreEje/nombreCabezal …'" .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta a ns1:AccionProhibida ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ProgramarUnaSecuenciaDeEjesYOCabezalesDelCanal a ns1:AccionProhibida ;
    rdfs:label "Programar una secuencia de ejes y/o cabezales del canal" ;
    ns1:textoExtracto "Tras #REPOS programar una secuencia de ejes y/o cabezales del canal." .

ns1:RENAMEAXOFF a ns1:AccionProhibida ;
    rdfs:label "#RENAME AX OFF" ;
    ns1:textoExtracto "8529 #RENAME AX OFF" .

ns1:VOLCOMPONOFF a ns1:AccionProhibida ;
    rdfs:label "#VOLCOMP ON/OFF" ;
    ns1:textoExtracto "8528 #VOLCOMP ON/OFF" .

