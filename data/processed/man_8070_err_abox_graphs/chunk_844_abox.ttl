@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9622
    a ex:DiagnosticoFallo ;
    rdfs:label "Cable roto en señal A del contaje del regulador"@es ;
    ex:textoExtracto "CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación."@es ;
    ex:identificador "9622" .

ex:Fallo_9623
    a ex:DiagnosticoFallo ;
    rdfs:label "Cable roto señal B de captación"@es ;
    ex:textoExtracto "9623 Captación: Cable roto señal B."@es ;
    ex:identificador "9623" .

ex:SistemaCaptacion
    a ex:Sistema ;
    rdfs:label "Sistema de captación del regulador"@es ;
    ex:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación."@es ;
    ex:activaAlarma ex:Fallo_9622, ex:Fallo_9623 .

ex:CableA_Contaje
    a ex:ComponenteElectrico ;
    rdfs:label "Cable de señal A del contaje"@es ;
    ex:textoExtracto "cable roto en la señal A del contaje del regulador"@es .

ex:CableB_Captacion
    a ex:ComponenteElectrico ;
    rdfs:label "Cable de señal B de captación"@es ;
    ex:textoExtracto "Cable roto señal B"@es .

ex:Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador del sistema"@es ;
    ex:textoExtracto "El regulador no recibe la señal A de la captación"@es ;
    ex:tieneComponente ex:CableA_Contaje, ex:CableB_Captacion .

ex:Tarea_RevisionCables
    a ex:TareaMantenimiento ;
    rdfs:label "Revisión de cables y conexiones de captación"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es ;
    ex:solucionaFallo ex:Fallo_9622, ex:Fallo_9623 .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .