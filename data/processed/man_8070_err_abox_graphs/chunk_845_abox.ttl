@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DeteccionDeErrorEnSintaxisCSROT a ns1:AccionProhibida ;
    rdfs:label "Detección de error en sintaxis #CSROT" ;
    ns1:solucionaFallo ns1:ErrorEnSintaxisDeSentencia ;
    ns1:textoExtracto "#CSROT<ON><[ROTATE]>/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DeteccionDeErrorEnSintaxisDEFROT a ns1:AccionProhibida ;
    rdfs:label "Detección de error en sintaxis #DEFROT" ;
    ns1:solucionaFallo ns1:ErrorEnSintaxisDeSentencia ;
    ns1:textoExtracto "#DEFROT[ERROR/WARNING/NONE, criterio, Q valorÁngulo] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DeteccionDeErrorEnSintaxisVIRTAX a ns1:AccionProhibida ;
    rdfs:label "Detección de error en sintaxis #VIRTAX" ;
    ns1:solucionaFallo ns1:ErrorEnSintaxisDeSentencia ;
    ns1:textoExtracto "#VIRTAX <ON> <[cotaEje]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:RevisionDelManualDeProgramacionParaSolucionarErroresDeSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del manual de programación para solucionar errores de sintaxis" ;
    ns1:solucionaFallo ns1:ErrorEnSintaxisDeSentencia ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ErrorEnSintaxisDeSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sintaxis de sentencia" ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

