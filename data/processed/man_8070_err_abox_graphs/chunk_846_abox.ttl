@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaFuncionG820AdmiteComoMaximoTresPuntos a ns1:AccionProhibida ;
    rdfs:label "La función G820 admite como máximo tres puntos" ;
    ns1:textoExtracto "CAUSA La función G820 admite como máximo tres puntos." .

ns1:LaSintaxisDeLaSentenciaNoEsCorrecta a ns1:AccionProhibida ;
    rdfs:label "La sintaxis de la sentencia no es correcta" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6,
        ns1:TareaMantanimientoRevisarSintaxisSentencia ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

ns1:LasFuncionesTYGProgramadasNoPuedenProgramarseJuntasEnElMismoBloque a ns1:AccionProhibida ;
    rdfs:label "Las funciones T y G programadas no pueden programarse juntas en el mismo bloque" ;
    ns1:solucionaFallo ns1:LaFuncionTNoPuedeProgramarseEnElMismoBloqueQueG801AG813G820G821G8331A_d45c6d4f2d ;
    ns1:textoExtracto "CAUSA Las funciones T y G programadas no pueden programarse juntas en el mismo bloque." .

ns1:LaFuncionTNoPuedeProgramarseEnElMismoBloqueQueG801AG813G820G821G8331A_d45c6d4f2d a ns1:DiagnosticoFallo ;
    rdfs:label "La función T no puede programarse en el mismo bloque que G801 a G813, G820, G821, G8331 a G833, G840 a G842, G850 o G851" ;
    ns1:textoExtracto "SOLUCIÓN La función T no puede programarse en el mismo bloque que G801 a G813, G820, G821, G8331 a G833, G840 a G842, G850 o G851." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentencia_e996812ce6 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

