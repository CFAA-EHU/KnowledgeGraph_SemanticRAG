@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Encoder_9628
    a ex:Sensor ;
    rdfs:label "Encoder con frecuencia de contaje excesiva" ;
    ex:textoExtracto "CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo. [...] 9628 Captación: Frecuencia de contaje excesiva." ;
    ex:identificador "9628" ;
    ex:activaAlarma ex:Alarma_9628 .

ex:Alarma_9628
    a ex:Alarma ;
    rdfs:label "Alarma por frecuencia de contaje excesiva" ;
    ex:textoExtracto "9628 Captación: Frecuencia de contaje excesiva. [...] La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal." ;
    ex:identificador "9628" .

ex:Diagnostico_Encoder_9628
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 9628 (Encoder)" ;
    ex:textoExtracto "SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado." ;
    ex:solucionaFallo ex:Alarma_9628 .