@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitarElNumeroDeElementosEnLaDefinicionDeUnEnteGeometrico a ns1:TareaMantenimiento ;
    rdfs:label "Limitar el número de elementos en la definición de un ente geométrico" ;
    ns1:solucionaFallo ns1:DeteccionDeDemasiadosElementosEnLaDefinicionDeUnEnteGeometrico ;
    ns1:textoExtracto "SOLUCIÓN El número máximo de elementos a utilizar en la definición de un ente geométrico es 6." .

ns1:ProgramarElRadioDelArcoConI1_b40f7295e4 a ns1:TareaMantenimiento ;
    rdfs:label "Programar el radio del arco con 'I1'" ;
    ns1:solucionaFallo ns1:DeteccionDeProgramacionIncorrectaDelRadioDelArco ;
    ns1:textoExtracto "SOLUCIÓN Programar el radio del arco con \"I1\". 8546 Sólo G802/803/832/833 permiten programar el radio del arco con I1." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaKINORG a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia #KINORG" ;
    ns1:solucionaFallo ns1:DeteccionDeSintaxisIncorrectaEnLaSentenciaKINORG ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarEnElManualDeProgramacionLaSintaxisDeLaSentenciaSELECTORI a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia #SELECT ORI" ;
    ns1:solucionaFallo ns1:DeteccionDeSintaxisIncorrectaEnLaSentenciaSELECTORI ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarLaProgramacion_e749ebaeca a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:solucionaFallo ns1:DeteccionDeFuncionGNoValidaEnLaDefinicionDeUnEnteGeometrico ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 8547 Ente geométrico no válido." .

ns1:DeteccionDeDemasiadosElementosEnLaDefinicionDeUnEnteGeometrico a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de demasiados elementos en la definición de un ente geométrico" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se han indicado demasiados elementos en la definición del ente geométrico." .

ns1:DeteccionDeFuncionGNoValidaEnLaDefinicionDeUnEnteGeometrico a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de función G no válida en la definición de un ente geométrico" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se ha programado una función G no válida en la definición de un ente geométrico." .

ns1:DeteccionDeProgramacionIncorrectaDelRadioDelArco a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de programación incorrecta del radio del arco" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se ha programado incorrectamente el radio del arco en la función G802, G803, G832 o 833." .

ns1:DeteccionDeSintaxisIncorrectaEnLaSentenciaKINORG a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de sintaxis incorrecta en la sentencia #KINORG" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DeteccionDeSintaxisIncorrectaEnLaSentenciaSELECTORI a ns1:DiagnosticoFallo ;
    rdfs:label "Detección de sintaxis incorrecta en la sentencia #SELECT ORI" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

