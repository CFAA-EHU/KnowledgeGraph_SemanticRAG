@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionDeNRNoPermitidaEnElCiclo a ns1:AccionProhibida ;
    rdfs:label "Programación de NR no permitida en el ciclo" ;
    ns1:solucionaFallo ns1:FalloValorIncorrectoNR ;
    ns1:textoExtracto "Programación de NR no permitida en el ciclo. DETECCIÓN Durante la edición y ejecución. CAUSA El ciclo no admite la programación del comando NR." .

ns1:RevisarSintaxisDeLaSentencia a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de la sentencia" ;
    ns1:solucionaFallo ns1:ValorIncorrectoDeNR01_f0d4fdf3df ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ValorIncorrectoDeNR01 a ns1:AccionProhibida ;
    rdfs:label "Valor incorrecto de NR (0-1)" ;
    ns1:textoExtracto "Valor incorrecto de NR (0-1)." .

ns1:ValorIncorrectoDeNR01_f0d4fdf3df a ns1:DiagnosticoFallo ;
    rdfs:label "Valor incorrecto de NR (0-1)" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

