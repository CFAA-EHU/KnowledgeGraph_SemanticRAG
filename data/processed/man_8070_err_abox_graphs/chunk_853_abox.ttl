@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminarElComandoNRDelBloqueYUtilizarLaSentenciaRPT a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar el comando NR del bloque y utilizar la sentencia #RPT" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_e517a7a212 ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el comando NR del bloque. Para repetir el bloque, utilizar la sentencia #RPT." .

ns1:ProgramarElComandoNRConUnValorIgualOSuperiorA2 a ns1:TareaMantenimiento ;
    rdfs:label "Programar el comando NR con un valor igual o superior a 2" ;
    ns1:solucionaFallo ns1:ValorIncorrectoDeNR01_fde19f2cb5 ;
    ns1:textoExtracto "SOLUCIÓN Programar el comando NR con un valor igual o superior a 2." .

ns1:DiagnosticoFallo_e517a7a212 a ns1:DiagnosticoFallo ;
    rdfs:label "Comando NR no admitido en ciclo"@es ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA El ciclo no admite la programación del comando NR. SOLUCIÓN Eliminar el comando NR del bloque." .

ns1:ValorIncorrectoDeNR01_fde19f2cb5 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor incorrecto de NR (0-1)"@es ;
    ns1:textoExtracto "8568 Valor incorrecto de NR (0-1). DETECCIÓN Durante la edición y ejecución. CAUSA El comando NR no admite los valores 0 y 1. SOLUCIÓN Programar el comando NR con un valor igual o superior a 2." .

