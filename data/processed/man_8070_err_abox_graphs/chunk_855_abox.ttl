@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisionDeSintaxisDeSentencias a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis de sentencias" ;
    ns1:solucionaFallo ns1:ErrorDeSintaxisEnSentencia_4fbe5ceab8 ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ErrorDeSintaxisEnSentencia_4fbe5ceab8 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia" ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

