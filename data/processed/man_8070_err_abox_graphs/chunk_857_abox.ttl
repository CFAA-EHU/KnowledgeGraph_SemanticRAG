@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionNoPermitidaConGiroActivo a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida con giro activo" ;
    ns1:textoExtracto "8582 Programación no permitida con giro activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activo un giro del sistema de coordenadas. SOLUCIÓN Desactivar el giro de coordenadas." .

ns1:ProgramacionNoPermitidaConTransformadaActiva a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida con transformada activa" ;
    ns1:textoExtracto "8583 Programación no permitida con transformada activa. DETECCIÓN Durante la ejecución." .

ns1:RevisarSintaxisDeSentencia_425b782541 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de sentencia" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_e7973eaac9 ;
    ns1:textoExtracto "8580 #LOAD PWRTABLE[fichero]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RevisarSintaxisDeSentencia_7ac187ce72 a ns1:TareaMantenimiento ;
