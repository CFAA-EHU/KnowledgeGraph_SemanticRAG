    ns1:solucionaFallo ns1:LaSintaxisDeLaSentenciaNoEsCorrecta_61d493cb30 ;
    ns1:textoExtracto "8581 #FOLLOW STEP[nombreEje incrementoEje]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

