@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9652 a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Velocidad excesiva en el eje"@es ;
    ex:identificador "9652" ;
    ex:textoExtracto "9652 Captación digital Fagor: Velocidad excesiva en el eje. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de conexionado e integridad del encoder"@es ;
        ex:textoExtracto "Revisar el conexionado e integridad del encoder."@es
    ] ;
    ex:mitigaRiesgo [
        a ex:AvisoSeguridad ;
        rdfs:label "Contacto con Fagor Automation si persiste el error 9652"@es ;
        ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es
    ] .

ex:Error_9653 a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Temperatura interna fuera de rango"@es ;
    ex:identificador "9653" ;
    ex:textoExtracto "9653 Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema."@es .

ex:FagorAutomation a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "póngase en contacto con Fagor Automation"@es .