@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarCompensacionDeRadio_697d95afc2 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar compensación de radio" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConCompensacionActiva ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio. 8584 Programación no permitida con compensación activa." .

ns1:DesactivarCompensacionDeRadio_df68ceb849 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar compensación de radio" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaSinMovimientoIndependienteActivo ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio. 8585 Programación no permitida sin movimiento independiente activo." .

ns1:DesactivarTransformacionDeCoordenadas_e01282a7c2 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar transformación de coordenadas" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaConTransformadaActiva_10bc08be8e ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el giro de coordenadas. 8583 Programación no permitida con transformada activa." .

ns1:ProgramacionNoPermitidaConCompensacionActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con compensación activa" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio. 8584 Programación no permitida con compensación activa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activa la compensación de radio (G41/G42)." .

ns1:ProgramacionNoPermitidaConTransformadaActiva_10bc08be8e a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con transformada activa" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el giro de coordenadas. 8583 Programación no permitida con transformada activa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activa alguna transformación de coordenadas; #CS/#ACS, #RTCP, #ANGAX, #PARALAX, #VIRTAX." .

ns1:ProgramacionNoPermitidaSinMovimientoIndependienteActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida sin movimiento independiente activo" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio. 8585 Programación no permitida sin movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida" .

