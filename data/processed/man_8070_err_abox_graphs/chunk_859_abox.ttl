@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9653
    a ex:DiagnosticoFallo ;
    ex:identificador "9653" ;
    rdfs:label "Captación digital Fagor: Temperatura interna fuera de rango"@es ;
    ex:textoExtracto "9653 Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Sobretemperatura en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es ;
    ex:solucionaFallo ex:Encoder_9653 .

ex:Encoder_9653
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Sobretemperatura en el encoder. Revisar el conexionado e integridad del encoder."@es .

ex:Error_9654
    a ex:DiagnosticoFallo ;
    ex:identificador "9654" ;
    rdfs:label "Captación digital Fagor: Pérdida de sincronización"@es ;
    ex:textoExtracto "9654 Captación digital Fagor: Pérdida de sincronización SOL. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error de comunicación del encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es ;
    ex:solucionaFallo ex:Encoder_9654 .

ex:Encoder_9654
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Error de comunicación del encoder. Revisar el conexionado e integridad del encoder."@es .

ex:Error_9655
    a ex:DiagnosticoFallo ;
    ex:identificador "9655" ;
    rdfs:label "Pulso de I0 no detectado"@es ;
    ex:textoExtracto "9655 Pulso de I0 no detectado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador no ha recibido la señal de I0. SOLUCIÓN Revisar la parametrización y el conexionado del encoder."@es ;
    ex:solucionaFallo ex:Encoder_9655 .

ex:Encoder_9655
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Revisar la parametrización y el conexionado del encoder."@es .

ex:Error_9656
    a ex:DiagnosticoFallo ;
    ex:identificador "9656" ;
    rdfs:label "Falta fase en la tarjeta sense"@es ;
    ex:textoExtracto "9656 Falta fase en la tarjeta sense. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Una fase de red no llega correctamente a la tarjeta sense. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es ;
    ex:solucionaFallo ex:TarjetaSense_9656 .

ex:TarjetaSense_9656
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Falta fase en la tarjeta sense. Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ex:Error_9657
    a ex:DiagnosticoFallo ;
    ex:identificador "9657" ;
    rdfs:label "Nivel de tensión por debajo del 80%"@es ;
    ex:textoExtracto "9657 Nivel de tensión por debajo del 80%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es ;
    ex:solucionaFallo ex:TarjetaSense_9657 .

ex:TarjetaSense_9657
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ex:Error_9658
    a ex:DiagnosticoFallo ;
    ex:identificador "9658" ;
    rdfs:label "Nivel de tensión por debajo del 70%"@es ;
    ex:textoExtracto "9658 Nivel de tensión por debajo del 70%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 70 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es ;
    ex:solucionaFallo ex:TarjetaSense_9658 .

ex:TarjetaSense_9658
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ex:Error_9659
    a ex:DiagnosticoFallo ;
    ex:identificador "9659" ;
    rdfs:label "Nivel de tensión por debajo del 40%"@es ;
    ex:textoExtracto "9659 Nivel de tensión por debajo del 40%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red."@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .