@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirSimboloRecurso a ns1:AccionProhibida ;
    rdfs:label "Definir símbolo recurso" ;
    ns1:textoExtracto "'Se esperaba recurso o número en lugar de símbolo'" .

ns1:ProgramarDEFPDEFSimboloRecursoODEFPDEFSimboloNumero a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'DEF/PDEF símbolo recurso' o 'DEF/PDEF símbolo número'" ;
    ns1:solucionaFallo ns1:NoSePuedeRedefinirNumeros_6326d816bf,
        ns1:NoSePuedeRedefinirRecursos,
        ns1:SeEsperabaRecursoONumeroEnLugarDeSimbolo ;
    ns1:textoExtracto "SOLUCIÓN Programar 'DEF/PDEF símbolo recurso' o 'DEF/PDEF símbolo número'." .

ns1:RedefinirNumeros a ns1:AccionProhibida ;
    rdfs:label "Redefinir números" ;
    ns1:textoExtracto "'No se puede redefinir números'" .

ns1:RedefinirRecursos a ns1:AccionProhibida ;
    rdfs:label "Redefinir recursos" ;
    ns1:textoExtracto "'No se puede redefinir recursos'" .

ns1:NoSePuedeRedefinirNumeros_6326d816bf a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede redefinir números" ;
    ns1:textoExtracto "'No se puede redefinir números' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos números." .

ns1:NoSePuedeRedefinirRecursos a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede redefinir recursos" ;
    ns1:textoExtracto "'No se puede redefinir recursos' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos recursos." .

ns1:SeEsperabaRecursoONumeroEnLugarDeSimbolo a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba recurso o número en lugar de símbolo" ;
    ns1:textoExtracto "'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos símbolos." .

