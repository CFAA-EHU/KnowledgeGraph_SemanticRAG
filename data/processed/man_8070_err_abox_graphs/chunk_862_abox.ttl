@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9709 a ex:AvisoSeguridad ;
    rdfs:label "Error de seguimiento excesivo (9709)"@es ;
    ex:textoExtracto "9709 Error de seguimiento excesivo. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)."@es ;
    ex:identificador "9709" .

ex:Parametro_G00FEED a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "SOLUCIÓN Revisar el parámetro G00FEED."@es ;
    ex:identificador "G00FEED" .

ex:Parametro_MAXFLWE a ex:Parametro ;
    rdfs:label "MAXFLWE" ;
    ex:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)."@es ;
    ex:identificador "MAXFLWE" .

ex:Motor_Eje a ex:ComponenteMecanico ;
    rdfs:label "Motor del eje"@es ;
    ex:textoExtracto "fallo en el motor o regulador"@es .

ex:Regulador_Eje a ex:ComponenteElectrico ;
    rdfs:label "Regulador del eje"@es ;
    ex:textoExtracto "fallo en el motor o regulador"@es .