@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9711
    a ex:AvisoSeguridad ;
    rdfs:label "Límite de carrera positivo alcanzado" ;
    ex:textoExtracto "9711 Límite de carrera positivo alcanzado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El eje ha alcanzado el límite de recorrido positivo. SOLUCIÓN Revisar los límites de carrera." ;
    ex:identificador "9711" .

ex:Error_9712
    a ex:AvisoSeguridad ;
    rdfs:label "Límite de carrera negativo alcanzado" ;
    ex:textoExtracto "9712 Límite de carrera negativo alcanzado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El eje ha alcanzado el límite de recorrido negativo. SOLUCIÓN Revisar los límites de carrera." ;
    ex:identificador "9712" .

ex:Error_9715
    a ex:AvisoSeguridad ;
    rdfs:label "Error en cálculo de I0s codificados" ;
    ex:textoExtracto "9715 Error en cálculo de I0s codificados. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los I0s latcheados no son coherentes. SOLUCIÓN Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." ;
    ex:identificador "9715" .

ex:Error_9718
    a ex:AvisoSeguridad ;
    rdfs:label "Fallo en la sincronización entre módulos" ;
    ex:textoExtracto "9718 Fallo en la sincronización entre módulos. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los reguladores no se sincronizan entre ellos. SOLUCIÓN Reducir la frecuencia de ejecución de los lazos." ;
    ex:identificador "9718" .

ex:Error_9719
    a ex:AvisoSeguridad ;
    rdfs:label "Warning en DrcLoop" ;
    ex:textoExtracto "9719 Warning en DrcLoop. DETECCIÓN Durante el arranque del sistema, validación de parámetros o cambio de ser en un eje o cabezal. CAUSA Error en el chequeo de coherencia de parámetros de tiempos de ciclo o error en la inicialización de los parámetros de un eje o cabezal. SOLUCIÓN Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." ;
    ex:identificador "9719" .

ex:Error_9720
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el regulador" ;
    ex:textoExtracto "9720 Error en el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "9720" .

ex:FalloSeguimientoEje
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento del eje (MAXFLWE)" ;
    ex:textoExtracto "CAUSA El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE). Posible ajuste inadecuado del eje, falta alguna habilitación, fallo en el motor o regulador, sistema de captación y/o mecánica. SOLUCIÓN Revisar los parámetros, ajuste, conexionado, estado del regulador, sistema de captación, motor, etc." ;
    ex:solucionaFallo ex:Error_9711 , ex:Error_9712 .

ex:Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor del sistema" ;
    ex:textoExtracto "fallo en el motor o regulador" .

ex:Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador del sistema" ;
    ex:textoExtracto "fallo en el motor o regulador" ;
    ex:monitoreaParametro ex:Param_MAXFLWE .

ex:Param_MAXFLWE
    a ex:Parametro ;
    rdfs:label "Parámetro MAXFLWE" ;
    ex:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)" ;
    ex:valor "MAXFLWE" .

ex:Param_I0TYPE
    a ex:Parametro ;
    rdfs:label "Parámetro I0TYPE" ;
    ex:textoExtracto "Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)" ;
    ex:valor "I0TYPE" .

ex:Param_CNCTIME
    a ex:Parametro ;
    rdfs:label "Parámetro CNCTIME" ;
    ex:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME" ;
    ex:valor "CNCTIME" .

ex:Param_SYSTEMTIME
    a ex:Parametro ;
    rdfs:label "Parámetro SYSTEMTIME" ;
    ex:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME" ;
    ex:valor "SYSTEMTIME" .

ex:Param_POS_LOOPTIME
    a ex:Parametro ;
    rdfs:label "Parámetro POS_LOOPTIME" ;
    ex:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME" ;
    ex:valor "POS_LOOPTIME" .