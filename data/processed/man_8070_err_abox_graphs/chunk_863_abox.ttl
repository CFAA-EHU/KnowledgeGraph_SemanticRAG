@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarQueCadaParentesisDeAperturaTieneSuCorrespondienteParentesisDeCierre a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre" ;
    ns1:solucionaFallo ns1:ParentesisDesparejado_a0fa00aadb ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre." .

ns1:ProgramarCPSConRecursosYOperacion a ns1:TareaMantenimiento ;
    rdfs:label "Programar CPS con recursos y operación" ;
    ns1:solucionaFallo ns1:FaltaOperadorDelCPS,
        ns1:FaltaSegundoOperandoDelCPS_cb350f49e9 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"CPS recurso operación recurso\". Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ns1:ProgramarCondicionConInstruccion a ns1:TareaMantenimiento ;
    rdfs:label "Programar condición con instrucción" ;
    ns1:solucionaFallo ns1:SeEsperabaInstruccionDeAccionTras_7bd82d1327 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"condición = instrucción\"." .

ns1:ProgramarConsultaConParentesisCorrectos a ns1:TareaMantenimiento ;
    rdfs:label "Programar consulta con paréntesis correctos" ;
    ns1:solucionaFallo ns1:FaltaParentesisDeApertura_f4954f34cb,
        ns1:FaltaParentesisDeCierre_5985d57723 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"(consulta)\"" .

ns1:ProgramarDFDConRecurso a ns1:TareaMantenimiento ;
    rdfs:label "Programar DFD con recurso" ;
    ns1:solucionaFallo ns1:FaltaRecursoDFD_19c0d51a34 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"DFD recurso\"." .

ns1:ProgramarDFUConRecurso a ns1:TareaMantenimiento ;
    rdfs:label "Programar DFU con recurso" ;
    ns1:solucionaFallo ns1:FaltaRecursoDFU_5de9250155 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"DFU recurso\"." .

ns1:FaltaOperadorDelCPS a ns1:DiagnosticoFallo ;
    rdfs:label "Falta operador del CPS" ;
    ns1:textoExtracto "'Falta operador del CPS' DETECCIÓN Durante la edición. CAUSA Falta la operación del comando CPS." .

ns1:FaltaParentesisDeApertura_f4954f34cb a ns1:DiagnosticoFallo ;
    rdfs:label "Falta paréntesis de apertura" ;
    ns1:textoExtracto "'Falta paréntesis de apertura' DETECCIÓN Durante la edición. CAUSA Hay un paréntesis de cierre pero falta el paréntesis de apertura." .

ns1:FaltaParentesisDeCierre_5985d57723 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta paréntesis de cierre" ;
    ns1:textoExtracto "'Falta paréntesis de cierre' DETECCIÓN Durante la edición. CAUSA Hay un paréntesis de apertura pero falta el paréntesis de cierre." .

ns1:FaltaRecursoDFD_19c0d51a34 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta recurso DFD" ;
    ns1:textoExtracto "'Falta recurso DFD' DETECCIÓN Durante la edición. CAUSA Falta el recurso tras el comando DFD." .

ns1:FaltaRecursoDFU_5de9250155 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta recurso DFU" ;
    ns1:textoExtracto "'Falta recurso DFU' DETECCIÓN Durante la edición. CAUSA Falta el recurso tras el comando DFU." .

ns1:FaltaSegundoOperandoDelCPS_cb350f49e9 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta segundo operando del CPS" ;
    ns1:textoExtracto "'Falta segundo operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el segundo recurso del comando CPS." .

ns1:ParentesisDesparejado_a0fa00aadb a ns1:DiagnosticoFallo ;
    rdfs:label "Paréntesis desparejado" ;
    ns1:textoExtracto "'Paréntesis desparejado' DETECCIÓN Durante la edición. CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre." .

ns1:SeEsperabaInstruccionDeAccionTras_7bd82d1327 a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba instrucción de acción tras \"=\"" ;
    ns1:textoExtracto "'Se esperaba instrucción de acción tras \"=\"' DETECCIÓN Durante la edición. CAUSA Falta instrucción tras \"=\"." .

