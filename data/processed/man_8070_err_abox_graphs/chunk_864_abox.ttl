@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error9720
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en el regulador"@es ;
    ex:identificador "9720" ;
    ex:textoExtracto "9720 Error en el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ex:Error9721
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Sobrecarga en el motor"@es ;
    ex:identificador "9721" ;
    ex:textoExtracto "9721 Sobrecarga en el motor. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor. SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al"@es .

ex:Motor_9721
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor con protección I²t"@es ;
    ex:textoExtracto "Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor."@es .

ex:Error9721 ex:solucionaFallo ex:Motor_9721 .