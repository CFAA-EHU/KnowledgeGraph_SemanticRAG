@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarCPS a ns1:TareaMantenimiento ;
    rdfs:label "Programar CPS" ;
    ns1:solucionaFallo ns1:FaltaOperadorYSegundoOperandoDelCPS_ffce1b8ca1,
        ns1:FaltaPrimerOperandoDelCPS_1263de3f5c ;
    ns1:textoExtracto "SOLUCIÓN Programar 'CPS recurso operación recurso'. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ns1:FaltaOperadorYSegundoOperandoDelCPS_ffce1b8ca1 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta operador y segundo operando del CPS" ;
    ns1:textoExtracto "'Falta operador y segundo operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el operador y el segundo recurso del comando CPS." .

ns1:FaltaPrimerOperandoDelCPS_1263de3f5c a ns1:DiagnosticoFallo ;
    rdfs:label "Falta primer operando del CPS" ;
    ns1:textoExtracto "'Falta primer operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el primer" .

