@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarCPSRecursoOperacionRecurso a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'CPS recurso operación recurso'" ;
    ns1:solucionaFallo ns1:FaltaPrimerOperandoDelCPS_1263de3f5c,
        ns1:FaltaPrimerOperandoOperadorYSegundoOperandoDelCPS_fb5d5729ad,
        ns1:OperadorDeComparacionNoValido_5273addb96 ;
    ns1:textoExtracto "SOLUCIÓN Programar 'CPS recurso operación recurso'. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ns1:ProgramarTENTemporizador a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'TEN temporizador'" ;
    ns1:solucionaFallo ns1:FaltaIndiceDeTemporizadorEnTEN_e7a2cc8651 ;
    ns1:textoExtracto "SOLUCIÓN Programar 'TEN temporizador'." .

ns1:ProgramarTGTemporizadorPreseleccion a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'TG temporizador preselección'" ;
    ns1:solucionaFallo ns1:FaltaPreseleccionEnTG_f138ddf376 ;
    ns1:textoExtracto "SOLUCIÓN Programar 'TG temporizador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:ProgramarTRSTemporizador a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'TRS temporizador'" ;
    ns1:solucionaFallo ns1:FaltaIndiceDeTemporizadorEnTRS_fcfa1aa9f3 ;
    ns1:textoExtracto "SOLUCIÓN Programar 'TRS temporizador'." .

ns1:FaltaIndiceDeTemporizadorEnTEN_e7a2cc8651 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de temporizador en TEN" ;
    ns1:textoExtracto "'Falta índice de temporizador en TEN' DETECCIÓN Durante la edición. CAUSA Falta el temporizador en el comando TEN." .

ns1:FaltaIndiceDeTemporizadorEnTRS_fcfa1aa9f3 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de temporizador en TRS" ;
    ns1:textoExtracto "'Falta índice de temporizador en TRS' DETECCIÓN Durante la edición. CAUSA Falta el temporizador en el comando TRS." .

ns1:FaltaPreseleccionEnTG_f138ddf376 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta preselección en TG" ;
    ns1:textoExtracto "'Falta preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando TG." .

ns1:FaltaPrimerOperandoDelCPS_1263de3f5c a ns1:DiagnosticoFallo ;
    rdfs:label "Falta primer operando del CPS" ;
    ns1:textoExtracto "'Falta primer operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el primer recurso del comando CPS." .

ns1:FaltaPrimerOperandoOperadorYSegundoOperandoDelCPS_fb5d5729ad a ns1:DiagnosticoFallo ;
    rdfs:label "Falta primer operando, operador y segundo operando del CPS" ;
    ns1:textoExtracto "'Falta primer operando, operador y segundo operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el operador y los dos recursos del comando CPS." .

ns1:OperadorDeComparacionNoValido_5273addb96 a ns1:DiagnosticoFallo ;
    rdfs:label "Operador de comparación no válido" ;
    ns1:textoExtracto "'Operador de comparación no válido' DETECCIÓN Durante la edición. CAUSA La operación programada en el comando CPS no es válida." .

