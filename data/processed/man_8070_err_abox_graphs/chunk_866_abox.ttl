ns1:OrdenDeOperandosInvertidosEnTG_bb9af48090 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden de operandos invertidos en TG" ;
    ns1:textoExtracto "'Orden de operandos invertidos en TG' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del" .

ns1:ProgramarTGTemporizadorPreseleccion a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'TG temporizador preselección'" ;
    ns1:solucionaFallo ns1:FaltaIndiceDeTemporizadorYPreseleccionEnTG,
        ns1:FaltaPreseleccionEnTG_f138ddf376 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"TG temporizador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:FaltaIndiceDeTemporizadorYPreseleccionEnTG a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de temporizador y preselección en TG" ;
    ns1:textoExtracto "'Falta índice de temporizador y preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el temporizador y el valor de preselección en el comando TG." .

ns1:FaltaPreseleccionEnTG_f138ddf376 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta preselección en TG" ;
    ns1:textoExtracto "'Falta preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando TG." .

