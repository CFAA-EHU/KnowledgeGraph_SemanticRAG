@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9724
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9724: Error en el seguimiento de la rampa de emergencia en frenada" ;
    ex:identificador "9724" ;
    ex:textoExtracto "9724 Error en el seguimiento de la rampa de emergencia en frenada. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La parada del eje o cabezal no puede seguir la rampa de emergencia (parámetros EMERGVELMAX y EMERGTIMEMAX)." .

ex:Error_9725
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9725: Diferencia excesiva de la posición real" ;
    ex:identificador "9725" ;
    ex:textoExtracto "9725 Diferencia excesiva de la posición real. DETECCIÓN Durante el" .

ex:Parametro_EMERGVELMAX
    a ex:Parametro ;
    rdfs:label "Parámetro EMERGVELMAX" ;
    ex:identificador "EMERGVELMAX" ;
    ex:textoExtracto "parámetros EMERGVELMAX y EMERGTIMEMAX" .

ex:Parametro_EMERGTIMEMAX
    a ex:Parametro ;
    rdfs:label "Parámetro EMERGTIMEMAX" ;
    ex:identificador "EMERGTIMEMAX" ;
    ex:textoExtracto "parámetros EMERGVELMAX y EMERGTIMEMAX" .

ex:Error_9724
    ex:solucionaFallo ex:Parametro_EMERGVELMAX , ex:Parametro_EMERGTIMEMAX .