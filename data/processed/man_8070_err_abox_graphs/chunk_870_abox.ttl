@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorSincronizacionReguladores
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error de sincronización de reguladores" ;
    ex:textoExtracto "Si en algún momento los reguladores no pueden sincronizarse o pierden la sincronización, se origina este error."@es ;
    ex:identificador "9738" .

ex:FalloDataLink
    a               ex:DiagnosticoFallo ;
    rdfs:label      "DataLink no presente" ;
    ex:textoExtracto "9738 DataLink no presente."@es ;
    ex:identificador "9738" .

ex:SolucionFalloDataLink
    a               ex:TareaMantenimiento ;
    rdfs:label      "Revisión de cable de transmisión y ruido" ;
    ex:textoExtracto "Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión."@es ;
    ex:solucionaFallo ex:FalloDataLink .

ex:CableTransmision
    a               ex:ComponenteElectrico ;
    rdfs:label      "Cable de transmisión" ;
    ex:textoExtracto "Revisar el cable de transmisión"@es .

ex:RuidoTransmision
    a               ex:Parametro ;
    rdfs:label      "Ruido en transmisión" ;
    ex:textoExtracto "comprobar que no hay presencia de ruido en la transmisión"@es ;
    ex:monitoreaParametro ex:CableTransmision .