@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarADSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'ADS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionADS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"ADS operando operando resultado\"." .

ns1:ProgramarJMPEtiqueta a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'JMP etiqueta'" ;
    ns1:solucionaFallo ns1:FaltaOrigenODestinoEnElMOV,
        ns1:FaltaOrigenYDestinoEnElMOV ;
    ns1:textoExtracto "SOLUCIÓN Programar \"JMP etiqueta\"." .

ns1:FaltaOrigenODestinoEnElMOV a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen o destino en el MOV" ;
    ns1:textoExtracto "8748 Falta origen o destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP." .

ns1:FaltaOrigenYDestinoEnElMOV a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen y destino en el MOV" ;
    ns1:textoExtracto "8749 Falta origen y destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP." .

ns1:FaltaUnArgumentoEnLaOperacionADS a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación ADS" ;
    ns1:textoExtracto "8750 Falta un argumento en la operación ADS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación ADS." .

