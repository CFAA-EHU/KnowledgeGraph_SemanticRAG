ns1:FaltaUnArgumentoEnLaOperacionDVS_0e0261c619 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación DVS" ;
    ns1:textoExtracto "Falta un argumento en la operación DVS." .

ns1:ProgramarADSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'ADS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltanDosArgumentosEnLaOperacionADS,
        ns1:FaltanTodosLosArgumentosEnLaOperacionADS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"ADS operando operando resultado\"." .

