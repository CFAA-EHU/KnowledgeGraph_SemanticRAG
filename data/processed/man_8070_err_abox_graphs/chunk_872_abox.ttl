@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarDVSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'DVS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionDVS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"DVS operando operando resultado\"." .

ns1:ProgramarMLSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'MLS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltanTodosLosArgumentosEnLaOperacionMLS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"MLS operando operando resultado\"." .

ns1:FaltaUnArgumentoEnLaOperacionDVS a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación DVS" ;
    ns1:textoExtracto "8759 Falta un argumento en la operación DVS. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanTodosLosArgumentosEnLaOperacionMLS a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación MLS" ;
    ns1:textoExtracto "8758 Faltan todos los argumentos en la operación MLS. DETECCIÓN Durante la edición del programa PLC." .

