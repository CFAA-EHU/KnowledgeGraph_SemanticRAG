@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltanDosArgumentosEnLaInstruccionDeAccionAND_46db00d0be a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la instrucción de acción AND" ;
    ns1:textoExtracto "Faltan dos argumentos en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC." .

ns1:ProgramarANDOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'AND operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaInstruccionDeAccionAND ;
    ns1:textoExtracto "SOLUCIÓN Programar \"AND operando operando resultado\"." .

ns1:ProgramarDVSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'DVS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltanDosArgumentosEnLaOperacionDVS,
        ns1:FaltanTodosLosArgumentosEnLaOperacionDVS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"DVS operando operando resultado\"." .

ns1:ProgramarMDSOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'MDS operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionMDS,
        ns1:FaltanDosArgumentosEnLaOperacionMDS,
        ns1:FaltanTodosLosArgumentosEnLaOperacionMDS ;
    ns1:textoExtracto "SOLUCIÓN Programar \"MDS operando operando resultado\"." .

ns1:ProgramarNGURegistro a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'NGU registro'" ;
    ns1:solucionaFallo ns1:FaltaRegistroEnNGS,
        ns1:FaltaRegistroEnNGU ;
    ns1:textoExtracto "SOLUCIÓN Programar \"NGU registro\"." .

ns1:FaltaRegistroEnNGS a ns1:DiagnosticoFallo ;
    rdfs:label "Falta registro en NGS" ;
    ns1:textoExtracto "Falta registro en NGU. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltaRegistroEnNGU a ns1:DiagnosticoFallo ;
    rdfs:label "Falta registro en NGU" ;
    ns1:textoExtracto "Falta registro en NGU. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltaUnArgumentoEnLaInstruccionDeAccionAND a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la instrucción de acción AND" ;
    ns1:textoExtracto "Falta un argumento en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltaUnArgumentoEnLaOperacionMDS a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación MDS" ;
    ns1:textoExtracto "Falta un argumento en la operación MDS. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanDosArgumentosEnLaOperacionDVS a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación DVS" ;
    ns1:textoExtracto "Faltan dos argumentos en la operación DVS. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanDosArgumentosEnLaOperacionMDS a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación MDS" ;
    ns1:textoExtracto "Faltan dos argumentos en la operación MDS. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanTodosLosArgumentosEnLaOperacionDVS a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación DVS" ;
    ns1:textoExtracto "Faltan todos los argumentos en la operación DVS. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanTodosLosArgumentosEnLaOperacionMDS a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación MDS" ;
    ns1:textoExtracto "Faltan todos los argumentos en la operación MDS. DETECCIÓN Durante la edición del programa PLC." .

