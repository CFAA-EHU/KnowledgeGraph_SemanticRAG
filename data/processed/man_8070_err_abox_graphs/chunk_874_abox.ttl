@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_20008
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando condición #WAIT FOR" ;
    ex:identificador "20008" ;
    ex:textoExtracto "20008 Esperando condición #WAIT FOR. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] o esperar a que se cumpla la condición." .

ex:AvisoSeguridad_20009
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando señal INPOS del cabezal %x" ;
    ex:identificador "20009" ;
    ex:textoExtracto "20009 Esperando señal INPOS del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ex:AvisoSeguridad_20010
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando finalizar proceso de sincronización de cabezales" ;
    ex:identificador "20010" ;
    ex:textoExtracto "20010 Esperando finalizar proceso de sincronización de cabezales. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ex:AvisoSeguridad_20011
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando respuesta del gestor de herramientas en el canal %c" ;
    ex:identificador "20011" ;
    ex:textoExtracto "20011 Esperando respuesta del gestor de herramientas en el canal %c. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Esperar a que la herramienta esté disponible, o pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ex:AvisoSeguridad_20012
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando finalizar paso a modo MANUAL del canal %c" ;
    ex:identificador "20012" ;
    ex:textoExtracto "20012 Esperando finalizar paso a modo MANUAL del canal %c. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ex:AvisoSeguridad_20013
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando confirmación de gama por el PLC" ;
    ex:identificador "20013" ;
    ex:textoExtracto "20013 Esperando confirmación de gama por el PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe confirmar la nueva gama." .

ex:AvisoSeguridad_20014
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando final de búsqueda de cero del cabezal %x" ;
    ex:identificador "20014" ;
    ex:textoExtracto "20014 Esperando final de búsqueda de cero del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema." .

ex:AccionProhibida_ResetNoJustificado
    a ex:AccionProhibida ;
    rdfs:label "Pulsar RESET sin analizar causas" ;
    ex:textoExtracto "Pulsar [RESET] y analizar las causas del retraso" .