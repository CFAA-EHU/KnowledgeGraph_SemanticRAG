@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarANDOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'AND operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltanDosArgumentosEnLaInstruccionDeAccionAND,
        ns1:FaltanTodosLosArgumentosEnLaInstruccionDeAccionAND ;
    ns1:textoExtracto "SOLUCIÓN Programar \"AND operando operando resultado\"." .

ns1:FaltanDosArgumentosEnLaInstruccionDeAccionAND a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la instrucción de acción AND" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación AND." .

ns1:FaltanTodosLosArgumentosEnLaInstruccionDeAccionAND a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la instrucción de acción AND" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación AND." .

