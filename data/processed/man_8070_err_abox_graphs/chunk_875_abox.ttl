ns1:ProgramarXOROperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'XOR operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaInstruccionDeAccionXOR,
        ns1:FaltanDosArgumentosEnLaInstruccionDeAccionXOR,
        ns1:FaltanTodosLosArgumentosEnLaInstruccionDeAccionXOR ;
    ns1:textoExtracto "SOLUCIÓN Programar \"XOR operando operando resultado\"." .

ns1:FaltaUnArgumentoEnLaInstruccionDeAccionOR a ns1:DiagnosticoFallo ;
