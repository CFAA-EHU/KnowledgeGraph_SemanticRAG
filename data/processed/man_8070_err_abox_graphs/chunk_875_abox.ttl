@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltanDosArgumentosEnLaOperacionRR1_c3c3255e22 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación RR1" ;
    ns1:textoExtracto "8777 Faltan dos argumentos en la operación RR1." .

ns1:ProgramarANDOperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'AND operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltanTodosArgumentosEnLaInstruccionDeAccionAND ;
    ns1:textoExtracto "SOLUCIÓN Programar \"AND operando operando resultado\"." .

ns1:ProgramarOROperandoOperandoResultado a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'OR operando operando resultado'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaInstruccionDeAccionOR,
        ns1:FaltanDosArgumentosEnLaInstruccionDeAccionOR,
        ns1:FaltanTodosLosArgumentosEnLaInstruccionDeAccionOR ;
    ns1:textoExtracto "SOLUCIÓN Programar \"OR operando operando resultado\"." .

ns1:ProgramarRR1OrigenRotacionesDestino a ns1:TareaMantenimiento ;
