@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltanTodosLosArgumentosEnLaOperacionRR1 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación RR1" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación RR1." .

ns1:ProgramarRR1OrigenRotacionesDestino a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'RR1 origen rotaciones destino'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionRR1,
        ns1:FaltanDosArgumentosEnLaOperacionRR1 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"RR1 origen rotaciones destino\"." .

ns1:FaltaUnArgumentoEnLaOperacionRR1 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación RR1" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación RR1." .

ns1:FaltanDosArgumentosEnLaOperacionRR1 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación RR1" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación RR1." .

