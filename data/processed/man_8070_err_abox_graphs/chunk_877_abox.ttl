@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarRL1OrigenRotacionesDestino a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'RL1 origen rotaciones destino'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionRL1,
        ns1:FaltanDosArgumentosEnLaOperacionRL1,
        ns1:FaltanTodosLosArgumentosEnLaOperacionRL1 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"RL1 origen rotaciones destino\"." .

ns1:ProgramarRL2OrigenRotacionesDestino a ns1:TareaMantenimiento ;
