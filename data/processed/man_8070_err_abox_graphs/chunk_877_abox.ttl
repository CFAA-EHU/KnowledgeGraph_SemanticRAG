        ns1:FaltanTodosLosArgumentosEnLaOperacionRR2 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"RR2 origen rotaciones destino\"." .

ns1:FaltaUnArgumentoEnLaOperacionRL1 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación RL1" ;
    ns1:textoExtracto "8782 Falta un argumento en la operación RL1. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación RL1." .

