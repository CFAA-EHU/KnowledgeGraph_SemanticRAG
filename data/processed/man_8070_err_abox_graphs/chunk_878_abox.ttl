@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarRL2OrigenRotacionesDestino a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'RL2 origen rotaciones destino'" ;
    ns1:solucionaFallo ns1:FaltaUnArgumentoEnLaOperacionRL2,
        ns1:FaltanDosArgumentosEnLaOperacionRL2,
        ns1:FaltanTodosLosArgumentosEnLaOperacionRL2 ;
    ns1:textoExtracto "SOLUCIÓN Programar \"RL2 origen rotaciones destino\"." .

ns1:FaltaUnArgumentoEnLaOperacionRL2 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación RL2" ;
    ns1:textoExtracto "8785 Falta un argumento en la operación RL2. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanDosArgumentosEnLaOperacionRL2 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación RL2" ;
    ns1:textoExtracto "8786 Faltan dos argumentos en la operación RL2. DETECCIÓN Durante la edición del programa PLC." .

ns1:FaltanTodosLosArgumentosEnLaOperacionRL2 a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación RL2" ;
    ns1:textoExtracto "8787 Faltan todos argumentos en la operación RL2. DETECCIÓN Durante la edición del programa PLC." .

