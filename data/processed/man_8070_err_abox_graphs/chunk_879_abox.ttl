ns1:ElRangoValidoParaCadaRecursoEsElSiguienteEntradasI1I1024SalidasO1O102_358b2c6e4b a ns1:TareaMantenimiento ;
    rdfs:label "El rango válido para cada recurso es el siguiente. Entradas (I1-I1024). Salidas (O1-O1024). Entradas locales (LI1-LI16). Salidas locales (LO1-LO8). Marcas (M1-M8192). Mensajes (MSG1-MSG1024). Errores (ERR1-ERR1024). Relojes (CLK). Registros (R1-R1024). Estado de los temporizadores (T1-T512). Estado de los contadores (C1-C256)" ;
    ns1:solucionaFallo ns1:IndiceFinalFueraDeRangoEnERA ;
    ns1:textoExtracto "SOLUCIÓN El rango válido para cada recurso es el siguiente. Entradas (I1-I1024). Salidas (O1-O1024). Entradas locales (LI1-LI16). Salidas locales (LO1-LO8). Marcas (M1-M8192). Mensajes (MSG1-MSG1024). Errores (ERR1-ERR1024). Relojes (CLK). Registros (R1-R1024). Estado de los temporizadores (T1-T512). Estado de los contadores (C1-C256)." .

