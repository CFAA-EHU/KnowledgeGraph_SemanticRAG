@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirElTextoDeError a ns1:TareaMantenimiento ;
    rdfs:label "Definir el texto de error" ;
    ns1:solucionaFallo ns1:CadenaDeErrorVacia ;
    ns1:textoExtracto "SOLUCIÓN Definir el texto de error." .

ns1:ErrorSintacticoNoSeEsperaba a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico. No se esperaba %" ;
    ns1:textoExtracto "8795 Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC." .

ns1:ProgramarPARRecursoRecurso a ns1:TareaMantenimiento ;
    rdfs:label "Programar 'PAR recurso recurso'" ;
    ns1:solucionaFallo ns1:FaltaDestinoEnPAR,
        ns1:FaltaOrigenYDestinoEnPAR ;
    ns1:textoExtracto "SOLUCIÓN Programar \"PAR recurso recurso\"." .

ns1:CadenaDeErrorVacia a ns1:DiagnosticoFallo ;
    rdfs:label "Cadena de error vacía" ;
    ns1:textoExtracto "8794 Cadena de error vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un error sin texto." .

ns1:FaltaDestinoEnPAR a ns1:DiagnosticoFallo ;
    rdfs:label "Falta destino en PAR" ;
    ns1:textoExtracto "8792 Falta destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta destino en PAR." .

ns1:FaltaOrigenYDestinoEnPAR a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen y destino en PAR" ;
    ns1:textoExtracto "8793 Falta origen y destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta origen y destino en PAR." .

