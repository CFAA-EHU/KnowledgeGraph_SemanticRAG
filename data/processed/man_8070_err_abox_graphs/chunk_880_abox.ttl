@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_20028
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 20028: Esperando pasar a lazo cerrado el cabezal %x" ;
    ex:textoExtracto "20028 Esperando pasar a lazo cerrado el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." ;
    ex:identificador "20028" .

ex:AvisoSeguridad_20029
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 20029: Movimiento de eje rotativo no permitido con RTCP STATIC activo" ;
    ex:textoExtracto "20029 Movimiento de eje rotativo no permitido con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado mover mover un eje afectado por RTCP STATIC. SOLUCIÓN Desactivar la función de RTCP STATIC." ;
    ex:identificador "20029" .

ex:AvisoSeguridad_20111
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 20111: Versión incompatible de archivo .xca" ;
    ex:textoExtracto "20111 El fichero .xca cargado es una versión anterior y no compatible con la versión actual del CNC. DETECCIÓN Al cargar archivos xca. CAUSA El archivo xca es v1.0 y debe ser v2.0. SOLUCIÓN Convertir el archivo a v2.0." ;
    ex:identificador "20111" .

ex:AvisoSeguridad_20112
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 20112: Error al generar fichero .xca desde .pxca" ;
    ex:textoExtracto "20112 Ha habido errores al generar el fichero xca a partir del fichero pxca. Fichero .xca no generado. DETECCIÓN Al cargar archivos xca. CAUSA Imposible generar el archivo xca a partir del archivo pxca. SOLUCIÓN Revisar el archivo Defgraph-err.log para ver las causas del error." ;
    ex:identificador "20112" .

ex:InterfazUsuario_Reset
    a ex:InterfazUsuario ;
    rdfs:label "Botón [RESET]" ;
    ex:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso." .

ex:AvisoSeguridad_20028 ex:solucionaFallo ex:InterfazUsuario_Reset .
ex:AvisoSeguridad_20029 ex:solucionaFallo ex:Parametro_RTCP_STATIC .

ex:Parametro_RTCP_STATIC
    a ex:Parametro ;
    rdfs:label "RTCP STATIC" ;
    ex:textoExtracto "20029 Movimiento de eje rotativo no permitido con RTCP STATIC activo." .