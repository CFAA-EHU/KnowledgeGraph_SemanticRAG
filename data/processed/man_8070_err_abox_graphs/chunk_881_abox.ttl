@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirLaSintaxisDeLaLinea a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la sintaxis de la línea" ;
    ns1:solucionaFallo ns1:DefinidoUnErrorSinTexto ;
    ns1:textoExtracto "SOLUCIÓN Corregir la sintaxis de la línea." .

ns1:DefinirElTextoDeWarning a ns1:TareaMantenimiento ;
    rdfs:label "Definir el texto de warning" ;
    ns1:solucionaFallo ns1:CadenaDeWarningVacia ;
    ns1:textoExtracto "SOLUCIÓN Definir el texto de warning." .

ns1:ElSegundoArgumentoDebeSerUnNumero a ns1:TareaMantenimiento ;
    rdfs:label "El segundo argumento debe ser un número" ;
    ns1:solucionaFallo ns1:ElSegundoArgumentoDebeSerUnIndiceEnERA ;
    ns1:textoExtracto "SOLUCIÓN El segundo argumento debe ser un número; no hay que programar el tipo de recurso." .

ns1:ProgramarElSimbolo a ns1:TareaMantenimiento ;
    rdfs:label "Programar el símbolo" ;
    ns1:solucionaFallo ns1:FaltaElSimbolo ;
    ns1:textoExtracto "SOLUCIÓN Programar el símbolo." .

ns1:ProgramarEnLaDirectivaPEUnValorMayorQueCero a ns1:TareaMantenimiento ;
    rdfs:label "Programar en la directiva 'PE' un valor mayor que cero" ;
    ns1:solucionaFallo ns1:ElPeriodoDebeSerMayorQueCero ;
    ns1:textoExtracto "SOLUCIÓN Programar en la directiva 'PE' un valor mayor que cero." .

ns1:RevisarEnElManualDeInstalacionLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de instalación la sintaxis" ;
    ns1:solucionaFallo ns1:FaltaEjeEnSentencia ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:RevisarLaProgramacionDelBloque_6a1720dab2 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación del bloque" ;
    ns1:solucionaFallo ns1:ExcedidoNumeroDeCaracteresEnSimbolo ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación del bloque. La longitud máxima permitida para el símbolo programado en estas directivas es 46 caracteres." .

ns1:CadenaDeWarningVacia a ns1:DiagnosticoFallo ;
    rdfs:label "Cadena de warning vacía" ;
    ns1:textoExtracto "8796 Cadena de warning vacía. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:DefinidoUnErrorSinTexto a ns1:DiagnosticoFallo ;
    rdfs:label "Definido un error sin texto" ;
    ns1:textoExtracto "definido un error sin texto. SOLUCIÓN Definir el texto de error." .

ns1:ElPeriodoDebeSerMayorQueCero a ns1:DiagnosticoFallo ;
    rdfs:label "El período debe ser mayor que cero" ;
    ns1:textoExtracto "8798 El período debe ser mayor que cero. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:ElSegundoArgumentoDebeSerUnIndiceEnERA a ns1:DiagnosticoFallo ;
    rdfs:label "El segundo argumento debe ser un índice en ERA" ;
    ns1:textoExtracto "8797 El segundo argumento debe ser un índice en ERA. DETECCIÓN Durante la edición del programa PLC." .

ns1:ExcedidoNumeroDeCaracteresEnSimbolo a ns1:DiagnosticoFallo ;
    rdfs:label "Excedido número de caracteres en símbolo" ;
    ns1:textoExtracto "8800 Excedido número de caracteres en símbolo. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:FaltaEjeEnSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "Falta eje en sentencia" ;
    ns1:textoExtracto "8802 Falta eje en sentencia. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:FaltaElSimbolo a ns1:DiagnosticoFallo ;
    rdfs:label "Falta el símbolo" ;
    ns1:textoExtracto "8799 Falta el símbolo. DETECCIÓN Durante la edición o compilación del programa PLC." .

