@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperadoresIgualesEnExpresionAND a ns1:DiagnosticoFallo ;
    rdfs:label "Operadores iguales en expresión AND" ;
    ns1:textoExtracto "Los operandos de la expresión AND son iguales." .

ns1:RevisarSintaxisEnManualDeInstalacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis en manual de instalación" ;
    ns1:solucionaFallo ns1:ProgramarComandoCAMOFOLLOWOFFSinIndicarEjeEsclavo ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ns1:RevisarSintaxisEnManualDeInstalacionParaOperadoresIgualesEnExpresionOR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis en manual de instalación para operadores iguales en expresión OR" ;
    ns1:solucionaFallo ns1:OperadoresIgualesEnExpresionOR ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ns1:OperadoresIgualesEnExpresionOR a ns1:AccionProhibida ;
    rdfs:label "Operadores iguales en expresión OR" ;
    ns1:textoExtracto "Los operandos de la expresión OR son iguales." .

ns1:ProgramarComandoCAMOFOLLOWOFFSinIndicarEjeEsclavo a ns1:AccionProhibida ;
    rdfs:label "Programar comando CAM o FOLLOWOFF sin indicar eje esclavo" ;
    ns1:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo." .

