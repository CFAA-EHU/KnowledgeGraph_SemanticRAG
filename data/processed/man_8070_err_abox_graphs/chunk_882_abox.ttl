@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23007_CompensacionVolumetrica
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 23007: Elemento fuera de rango en compensación volumétrica" ;
    ex:textoExtracto "23007 Error en el fichero de compensación volumétrica: elemento fuera del rango esperado. [...] CAUSA Variable o elemento del archivo de compensación volumétrica fuera de rango." ;
    ex:identificador "23007" .

ex:ParametroCompensacionVolumetrica_23007
    a ex:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica (eje incorrecto o fuera de rango)" ;
    ex:textoExtracto "Variable o elemento del archivo de compensación volumétrica fuera de rango. [...] El tercer eje asignado a la compensación volumétrica no es correcto." ;
    ex:monitoreaParametro ex:Error23007_CompensacionVolumetrica .

ex:SistemaCompensacionVolumetrica
    a ex:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: elemento fuera del rango esperado. [...] Durante el arranque del sistema o validación de los parámetros máquina." ;
    ex:tieneComponente ex:ParametroCompensacionVolumetrica_23007 ;
    ex:activaAlarma ex:Error23007_CompensacionVolumetrica .