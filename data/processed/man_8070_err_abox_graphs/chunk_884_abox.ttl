@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarRangosDeEntradasDigitales a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar rangos de entradas digitales" ;
    ns1:textoExtracto "SOLUCIÓN Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16." .

ns1:AjustarRangosDeSalidasDigitales a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar rangos de salidas digitales" ;
    ns1:solucionaFallo ns1:SalidaFueraDeRangoPermitido ;
    ns1:textoExtracto "SOLUCIÓN Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8." .

ns1:FalloDelLexerAlReconocerEntradas a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas" ;
    ns1:textoExtracto "8817 Fallo del lexer al reconocer entradas." .

ns1:SalidaFueraDeRangoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Salida fuera de rango permitido" ;
    ns1:textoExtracto "8816 Salida fuera de rango permitido." .

