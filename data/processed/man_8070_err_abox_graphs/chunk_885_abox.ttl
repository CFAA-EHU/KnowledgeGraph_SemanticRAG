@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23018
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en el fichero de compensación volumétrica"@es ;
    ex:identificador "23018" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero 'SQUARENESS_IS_POSITIVE' es incorrecto."@es ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Modificación incorrecta del archivo de compensación volumétrica"@es ;
        ex:textoExtracto "Modificar el archivo de la compensación volumétrica."@es
    ] .

ex:Parametro_SQUARENESS_IS_POSITIVE
    a               ex:Parametro ;
    rdfs:label      "SQUARENESS_IS_POSITIVE" ;
    ex:textoExtracto "valor del parámetro del fichero 'SQUARENESS_IS_POSITIVE' es incorrecto"@es ;
    ex:monitoreaParametro ex:Error23018 .