@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualInstalacion a ns1:Manual ;
    rdfs:label "Manual de Instalación" ;
    ns1:documentadoEn ns1:RevisionDeSintaxisDelManualDeInstalacion ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ns1:ErrorAlProgramarCaracteresNoValidosEnElPLC a ns1:AccionProhibida ;
    rdfs:label "Error al programar caracteres no válidos en el PLC" ;
    ns1:textoExtracto "Algún carácter programado no es correcto." .

ns1:RevisionDeSintaxisDelManualDeInstalacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis del manual de instalación" ;
    ns1:solucionaFallo ns1:ErrorAlProgramarCaracteresNoValidosEnElPLC ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

