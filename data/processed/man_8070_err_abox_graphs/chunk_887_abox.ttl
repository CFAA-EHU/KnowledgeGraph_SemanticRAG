@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23023
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ex:identificador "23023" ;
    ex:textoExtracto "23023 Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite inferior del volumen."@es ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina."@es ;
    ex:textoExtracto "CAUSA La coordenada del segundo eje está fuera del límite inferior del volumen."@es .

ex:ErrorCoordenadaEje1
    a ex:AvisoSeguridad ;
    rdfs:label "Coordenada del primer eje fuera del límite superior"@es ;
    ex:textoExtracto "CAUSA La coordenada del primer eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .