    a ex:AvisoSeguridad ;
    rdfs:label "Error en compensación volumétrica (tercer eje, límite superior)"@es ;
    ex:identificador "23026" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del tercer eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del tercer eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ex:Error23027
    a ex:AvisoSeguridad ;
    rdfs:label "Error en unidades del fichero de volumetría (inconsistencia)"@es ;
    ex:identificador "23027" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son iguales. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es .

ex:Error23028
    a ex:AvisoSeguridad ;
    rdfs:label "Error en unidades del fichero de volumetría (invalidez)"@es ;
    ex:identificador "23028" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son válidas."@es .

ex:ParametroVolumetria
    a ex:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica"@es ;
    ex:textoExtracto "fichero de compensación volumétrica"@es ;
    ex:monitoreaParametro ex:Error23023 , ex:Error23024 , ex:Error23025 , ex:Error23026 , ex:Error23027 , ex:Error23028 .

ex:SistemaControl
    a ex:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ex:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina"@es ;
    ex:activaAlarma ex:Error23023 , ex:Error23024 , ex:Error23025 , ex:Error23026 , ex:Error23027 , ex:Error23028 .