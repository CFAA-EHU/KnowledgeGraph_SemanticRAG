@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_4173a1666b a ns1:AccionProhibida ;
    rdfs:label "Marca fuera de rango permitido" ;
    ns1:textoExtracto "8832 Registro fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La marca programada no es válida. SOLUCIÓN Las marcas deben estar dentro del rango M1 a M8192." .

ns1:ContadorFueraDeRangoPermitido a ns1:AccionProhibida ;
    rdfs:label "Contador fuera de rango permitido" ;
    ns1:textoExtracto "8834 Contador fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El contador programado no es válido. SOLUCIÓN Los contadores deben estar dentro del rango C1 a C256." .

ns1:EntradaDeArranqueFueraDeRangoPermitido a ns1:AccionProhibida ;
    rdfs:label "Entrada de arranque fuera de rango permitido" ;
    ns1:textoExtracto "8837 Entrada de arranque fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Las entradas de arranque deben estar dentro del rango TG1 a TG4." .

ns1:FalloDelLexerAlReconocerEntradasDeArranque a ns1:AccionProhibida ;
    rdfs:label "Fallo del lexer al reconocer entradas de arranque" ;
    ns1:textoExtracto "8838 Fallo del lexer al reconocer entradas de arranque. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas de arranque. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:FalloDelLexerAlReconocerRelojes a ns1:AccionProhibida ;
    rdfs:label "Fallo del lexer al reconocer relojes" ;
    ns1:textoExtracto "8836 Fallo del lexer al reconocer relojes. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a relojes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:FaltaIndiceDeEntradaDeArranque_cd580c8cab a ns1:AccionProhibida ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ns1:textoExtracto "8839 Falta índice de entrada de arranque. Suponemos TG1. DETECCIÓN Durante la edición del programa PLC." .

ns1:RegistroFueraDeRangoPermitido_085ff23103 a ns1:AccionProhibida ;
    rdfs:label "Registro fuera de rango permitido" ;
    ns1:textoExtracto "8832 Registro fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El registro programado no es válido. SOLUCIÓN Los registros deben estar dentro del rango R1 a R1024." .

ns1:RelojFueraDeRango a ns1:AccionProhibida ;
    rdfs:label "Reloj fuera de rango" ;
    ns1:textoExtracto "8835 Reloj fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA El reloj programado no es válido. SOLUCIÓN Consultar en el manual de instalación los relojes válidos." .

ns1:TemporizadorFueraDeRangoPermitido a ns1:AccionProhibida ;
    rdfs:label "Temporizador fuera de rango permitido" ;
    ns1:textoExtracto "8833 Temporizador fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El temporizador programado no es válido. SOLUCIÓN Los temporizadores deben estar dentro del rango T1 a T512." .

