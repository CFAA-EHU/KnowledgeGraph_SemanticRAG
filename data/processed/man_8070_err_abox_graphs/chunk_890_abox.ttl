@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramarIndiceDeEntradaDeArranque a ns1:TareaMantenimiento ;
    rdfs:label "Programar índice de entrada de arranque" ;
    ns1:solucionaFallo ns1:FaltaIndiceDeEntradaDeArranque ;
    ns1:textoExtracto "SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4." .

ns1:RecursoObsoletoPICOPAGSustituidoPorMSG a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso obsoleto PIC o PAG; sustituido por MSG" ;
    ns1:textoExtracto "8840 Recurso obsoleto PIC o PAG; sustituido por MSG." .

ns1:RevisarSintaxis_fbd769150c a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis" ;
    ns1:solucionaFallo ns1:AlgunCaracterProgramadoNoEsCorrecto ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:AlgunCaracterProgramadoNoEsCorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Algún carácter programado no es correcto" ;
    ns1:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:FaltaIndiceDeEntradaDeArranque a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ns1:textoExtracto "8839 Falta índice de entrada de arranque. Suponemos TG1." .

