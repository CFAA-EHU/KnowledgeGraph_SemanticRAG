@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirMasDe100SimbolosPDEF a ns1:AccionProhibida ;
    rdfs:label "Definir más de 100 símbolos PDEF" ;
    ns1:textoExtracto "PLC. CAUSA Hay definidos más de 100 símbolos PDEF." .

ns1:DemasiadosSimbolosDeUsuario_a938a96440 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados símbolos de usuario" ;
    ns1:textoExtracto "PLC. CAUSA Hay definidos más de 100 símbolos PDEF." .

ns1:DiagnosticoFallo_4577e4dedc a ns1:DiagnosticoFallo ;
    rdfs:label "Marca de sistema redefinida" ;
    ns1:textoExtracto "PLC. CAUSA Hay dos señales (marcas) con el mismo nombre. SOLUCIÓN Revisar el nombre de las marcas." .

ns1:RecursoObsoletoPICOPAGSustituidoPorMSG_ced1fa4541 a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso obsoleto PIC o PAG; sustituido por MSG" ;
    ns1:textoExtracto "PLC. CAUSA Ambos recursos ya no son válidos. SOLUCIÓN Es posible que ambos recursos pertenezcan a otra familia de CNCs o hayan cambiado de nombre. No es posible utilizar ambos registros y el PLC los ha sustituido por MSG." .

ns1:RedefinirMarcaDeSistema a ns1:AccionProhibida ;
    rdfs:label "Redefinir marca de sistema" ;
    ns1:textoExtracto "PLC. CAUSA Hay dos señales (marcas) con el mismo nombre. SOLUCIÓN Revisar el nombre de las marcas." .

ns1:RedefinirSimboloDeUsuario a ns1:AccionProhibida ;
    rdfs:label "Redefinir símbolo de usuario" ;
    ns1:textoExtracto "PLC. CAUSA Hay dos símbolos con el mismo nombre. SOLUCIÓN Revisar el nombre de los símbolos." .

ns1:RevisarLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la sintaxis" ;
    ns1:solucionaFallo ns1:FaltaConsultaPrevia ;
    ns1:textoExtracto "PLC. SOLUCIÓN Revisar la sintaxis." .

ns1:SeEsperabaAccionEnLugarDe a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba acción en lugar de %" ;
    ns1:textoExtracto "PLC. CAUSA Falta programar una acción. SOLUCIÓN Programar una acción." .

ns1:SeEsperabaConsultaEnLugarDe a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba consulta en lugar de %" ;
    ns1:textoExtracto "PLC. CAUSA Falta programar una consulta. SOLUCIÓN Programar una consulta." .

ns1:SeEsperabaDirectivaDeComienzoDeModuloOSubrutina a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba directiva de comienzo de módulo o subrutina" ;
    ns1:textoExtracto "PLC. CAUSA Hay programado algún módulo o subrutina y falta la directiva de comienzo. SOLUCIÓN Programar la directiva CY1, PRG, PE al comienzo del módulo, o SUB al comienzo de cada subrutina." .

ns1:SimboloDeUsuarioRedefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Símbolo de usuario redefinido" ;
    ns1:textoExtracto "PLC. CAUSA Hay dos símbolos con el mismo nombre. SOLUCIÓN Revisar el nombre de los símbolos." .

ns1:FaltaConsultaPrevia a ns1:DiagnosticoFallo ;
    rdfs:label "Falta consulta previa" ;
    ns1:textoExtracto "PLC. CAUSA Falta programar una consulta para poder ejecutar la instrucción. SOLUCIÓN Revisar la sintaxis." .

