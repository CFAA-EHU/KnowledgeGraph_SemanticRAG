@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23035
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (AXIS_END)"@es ;
    ex:identificador "23035" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_END\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"AXIS_END\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:Parametro_AXIS_END .

ex:Error23036
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (AXIS_LENGTH)"@es ;
    ex:identificador "23036" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_LENGTH\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"AXIS_LENGTH\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:Parametro_AXIS_LENGTH .

ex:Error23037
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (valor mínimo sobrepasado)"@es ;
    ex:identificador "23037" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: Valor mínimo sobrepasado. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados. SOLUCIÓN Poner como valor máximo en el fichero, el valor máximo de la tabla."@es .

ex:Error23038
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (valor máximo sobrepasado)"@es ;
    ex:identificador "23038" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: Valor máximo sobrepasado. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados. SOLUCIÓN Poner como valor máximo en el fichero, el valor máximo de la tabla."@es .

ex:Error23039
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (rango inválido)"@es ;
    ex:identificador "23039" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: Valor del rango inválido. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados. SOLUCIÓN Cambiar el valor del rango a la diferencia entre el valor máximo y el mínimo."@es .

ex:Parametro_AXIS_BEGIN
    a ex:Parametro ;
    rdfs:label "AXIS_BEGIN" ;
    ex:textoExtracto "El parámetro \"AXIS_BEGIN\" es incorrecto."@es .

ex:Parametro_AXIS_END
    a ex:Parametro ;
    rdfs:label "AXIS_END" ;
    ex:textoExtracto "El parámetro \"AXIS_END\" es incorrecto."@es .

ex:Parametro_AXIS_LENGTH
    a ex:Parametro ;
    rdfs:label "AXIS_LENGTH" ;
    ex:textoExtracto "El parámetro \"AXIS_LENGTH\" es incorrecto."@es .

ex:FicheroCompensacionVolumetrica
    a ex:InterfazUsuario ;
    rdfs:label "Fichero de compensación volumétrica"@es ;
    ex:textoExtracto "El fichero de definición de la compensación volumétrica no contiene los datos adecuados."@es ;
    ex:tieneComponente ex:Parametro_AXIS_BEGIN , ex:Parametro_AXIS_END , ex:Parametro_AXIS_LENGTH .