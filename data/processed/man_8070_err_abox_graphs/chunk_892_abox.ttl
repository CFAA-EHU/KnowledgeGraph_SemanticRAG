@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DemasiadosErrores a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados errores" ;
    ns1:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC." .

ns1:NumeroDeSimbolosPDEF a ns1:Parametro ;
    rdfs:label "Número de símbolos PDEF" ;
    ns1:textoExtracto "El PLC permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF." ;
    ns1:valor "100" .

ns1:ProgramarAlgunosSimbolosPDEFComoDEF a ns1:TareaMantenimiento ;
    rdfs:label "Programar algunos símbolos PDEF como DEF" ;
    ns1:solucionaFallo ns1:DemasiadosSimbolosDeUsuario ;
    ns1:textoExtracto "SOLUCIÓN Programar algunos símbolos PDEF como símbolos DEF." .

ns1:RevisarNombresDeSimbolos a ns1:TareaMantenimiento ;
    rdfs:label "Revisar nombres de símbolos" ;
    ns1:solucionaFallo ns1:HayDosSimbolosConElMismoNombre ;
    ns1:textoExtracto "SOLUCIÓN Revisar el nombre de los símbolos." .

ns1:DemasiadosSimbolosDeUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados símbolos de usuario" ;
    ns1:textoExtracto "8847 Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC." .

ns1:HayDosSimbolosConElMismoNombre a ns1:DiagnosticoFallo ;
    rdfs:label "Hay dos símbolos con el mismo nombre" ;
    ns1:textoExtracto "CAUSA Hay dos símbolos con el mismo nombre." .

