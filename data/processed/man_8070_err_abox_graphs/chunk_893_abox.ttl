@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeErrores a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de errores" ;
    ns1:solucionaFallo ns1:DemasiadosErrores_4ac9b7248d ;
    ns1:textoExtracto "SOLUCIÓN Corregir los errores y volver a analizar el programa." .

ns1:ProgramacionDeENDAlFinalDelModulo a ns1:TareaMantenimiento ;
    rdfs:label "Programación de END al final del módulo" ;
    ns1:solucionaFallo ns1:SeEsperabaENDONuevaProposicion ;
    ns1:textoExtracto "SOLUCIÓN Programar END al final de cada módulo o subrutina. Programar END sola en el bloque." .

ns1:RevisionDeLaSintaxisDelPrograma a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de la sintaxis del programa" ;
    ns1:solucionaFallo ns1:ErrorFatal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la sintaxis del programa." .

ns1:UnaMarcaNoEsValidaEnEsteContexto a ns1:DiagnosticoFallo ;
    rdfs:label "Una marca no es válida en este contexto" ;
    ns1:textoExtracto "8851 Una marca no es válida en este contexto." .

ns1:DemasiadosErrores_4ac9b7248d a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados errores" ;
    ns1:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores y sólo muestra los primeros." .

ns1:ErrorFatal a ns1:DiagnosticoFallo ;
    rdfs:label "Error fatal" ;
    ns1:textoExtracto "8850 Error fatal. No se puede continuar." .

ns1:SeEsperabaENDONuevaProposicion a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba END o nueva proposición" ;
    ns1:textoExtracto "8849 Se esperaba END o nueva proposición. Puede que falte un salto de línea." .

