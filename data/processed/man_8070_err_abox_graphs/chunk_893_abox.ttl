@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23040 a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ex:identificador "23040" ;
    ex:textoExtracto "23040 Error en el fichero de compensación volumétrica: no se puede abrir el fichero de volumetría. parámetros máquina."@es ;
    ex:monitoreaParametro ex:ParametroCompensacionVolumetrica .

ex:ParametroCompensacionVolumetrica a ex:Parametro ;
    rdfs:label "Compensación volumétrica"@es ;
    ex:textoExtracto "fichero de definición de la compensación volumétrica"@es ;
    ex:textoExtracto "valor del rango a la diferencia entre el valor máximo y el mínimo"@es .

ex:FicheroVolumetria a ex:Sistema ;
    rdfs:label "Fichero de compensación volumétrica"@es ;
    ex:textoExtracto "fichero de definición de la compensación volumétrica"@es ;
    ex:textoExtracto "no se puede abrir el fichero de volumetría"@es ;
    ex:tieneComponente ex:ParametroCompensacionVolumetrica .

ex:TareaAjusteRango a ex:TareaMantenimiento ;
    rdfs:label "Ajuste del rango de compensación volumétrica"@es ;
    ex:textoExtracto "Cambiar el valor del rango a la diferencia entre el valor máximo y el mínimo."@es ;
    ex:solucionaFallo ex:Error23040 .