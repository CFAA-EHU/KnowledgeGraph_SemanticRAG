@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarSintaxis_fbd769150c a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis" ;
    ns1:solucionaFallo ns1:RegistroDeSistemaRedefinido,
        ns1:SeEsperabaDEFEnLugarDe ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:RegistroDeSistemaRedefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Registro de sistema redefinido" ;
    ns1:textoExtracto "8856 Registro de sistema redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (registros) con el mismo nombre." .

ns1:SeEsperabaDEFEnLugarDe a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba DEF en lugar de %"@es ;
    ns1:textoExtracto "8855 Se esperaba DEF en lugar de %. DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta." .

