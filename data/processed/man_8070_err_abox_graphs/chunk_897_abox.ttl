@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisarElNombreDeLasEtiquetasYLosSaltosALasEtiquetas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el nombre de las etiquetas y los saltos a las etiquetas" ;
    ns1:solucionaFallo ns1:EtiquetaIndefinida ;
    ns1:textoExtracto "SOLUCIÓN Revisar el nombre de las etiquetas y los saltos a las etiquetas." .

ns1:RevisarSaltosDeLineaTrasElFinDelModulo a ns1:TareaMantenimiento ;
    rdfs:label "Revisar saltos de línea tras el fin del módulo" ;
    ns1:solucionaFallo ns1:FaltaSaltoDeLineaTrasFinDeModulo_122299df1f ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación" .

ns1:UtilizarSaltosAEtiquetasEnLugarDeSubrutinasOAgruparVariasSubrutinasEnUnaSola a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar saltos a etiquetas en lugar de subrutinas, o agrupar varias subrutinas en una sola" ;
    ns1:solucionaFallo ns1:HayDemasiadasSubrutinasDefinidasEnElPrograma ;
    ns1:textoExtracto "SOLUCIÓN Utilizar saltos a etiquetas en lugar de subrutinas, o agrupar varias subrutinas en una sola." .

ns1:EtiquetaIndefinida a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta indefinida" ;
    ns1:textoExtracto "8863 Etiqueta indefinida." .

ns1:FaltaSaltoDeLineaTrasFinDeModulo_122299df1f a ns1:DiagnosticoFallo ;
    rdfs:label "Falta salto de linea tras fin de módulo" ;
    ns1:textoExtracto "8864 Falta salto de linea tras fin de módulo." .

ns1:HayDemasiadasSubrutinasDefinidasEnElPrograma a ns1:DiagnosticoFallo ;
    rdfs:label "Hay demasiadas subrutinas definidas en el programa" ;
    ns1:textoExtracto "CAUSA Hay demasiadas subrutinas definidas en el programa." .

