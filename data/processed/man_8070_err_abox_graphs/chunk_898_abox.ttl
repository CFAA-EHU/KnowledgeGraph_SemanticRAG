@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23153
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error 23153: Fichero de compensación volumétrica no válido" ;
    ex:textoExtracto    "23153 El fichero de compensación volumétrica no es valido. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica (parámetro VCOMPFILE) está vacío o no tiene el formato adecuado. SOLUCIÓN Añadir un fichero válido." ;
    ex:identificador    "23153" .

ex:Error23154
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error 23154: Error en análisis de fichero de compensación volumétrica" ;
    ex:textoExtracto    "23154 Error en el análisis del fichero de definición de la compensación volumétrica. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA Error en el análisis del fichero de definición de la compensación volumétrica. SOLUCIÓN Añadir un fichero válido." ;
    ex:identificador    "23154" .

ex:Parametro_VCOMPFILE
    a                   ex:Parametro ;
    rdfs:label          "Parámetro VCOMPFILE (compensación volumétrica)" ;
    ex:textoExtracto    "parámetro VCOMPFILE" ;
    ex:identificador    "VCOMPFILE" .

ex:Error23153
    ex:solucionaFallo    ex:Parametro_VCOMPFILE .

ex:Error23154
    ex:solucionaFallo    ex:Parametro_VCOMPFILE .

ex:TablaParametrosMaquina a ex:Tabla ;
     a                   ex:Tabla ;
    rdfs:label          "Tabla de parámetros máquina (feedback, motor, tandem, etc.)" ;
    ex:textoExtracto    "El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo." .

ex:ComponenteMotor
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Motor (referenciado en tabla de parámetros)" ;
    ex:textoExtracto    "tabla de parámetros máquina (feedback, motor, tandem, etc)" .