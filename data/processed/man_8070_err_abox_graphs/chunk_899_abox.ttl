@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_24001
    a ex:Alarma ;
    rdfs:label "EtherCAT: Datalink no presente" ;
    ex:identificador "24001" ;
    ex:textoExtracto "24001 EtherCAT: Datalink no presente. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El cable EtherCAT está desconectado. SOLUCIÓN Conectar el cable de EtherCAT." ;
    ex:monitoreaParametro ex:Parametro_EtherCAT_Datalink .

ex:Alarma_24002
    a ex:Alarma ;
    rdfs:label "EtherCAT: Paquete perdido" ;
    ex:identificador "24002" ;
    ex:textoExtracto "24002 EtherCAT: Paquete perdido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o algún esclavo no funciona correctamente. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." ;
    ex:monitoreaParametro ex:Parametro_EtherCAT_Paquete .

ex:Alarma_24003
    a ex:Alarma ;
    rdfs:label "EtherCAT: CRC Incorrecto" ;
    ex:identificador "24003" ;
    ex:textoExtracto "24003 EtherCAT: CRC Incorrecto. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o hay interferencias en el bus. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." ;
    ex:monitoreaParametro ex:Parametro_EtherCAT_CRC .

ex:Alarma_24004
    a ex:Alarma ;
    rdfs:label "EtherCAT: Working Counter error" ;
    ex:identificador "24004" ;
    ex:textoExtracto "24004 EtherCAT: Working Counter error. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Funcionamiento incorrecto de alguno de los esclavos de EtherCAT. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." ;
    ex:monitoreaParametro ex:Parametro_EtherCAT_WorkingCounter .

ex:Alarma_24010
    a ex:Alarma ;
    rdfs:label "EtherCAT: Fichero ENI de configuración no existe" ;
    ex:identificador "24010" ;
    ex:textoExtracto "24010 EtherCAT: Fichero ENI de configuración no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero ENI de configuración de la red EtherCAT. SOLUCIÓN Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT. El archivo se debe llamar fagor_ethercatConfFile.xml" .

ex:Alarma_24011
    a ex:Alarma ;
    rdfs:label "EtherCAT: Formato de fichero ENI de configuración incorrecto" ;
    ex:identificador "24011" ;
    ex:textoExtracto "24011 EtherCAT: Formato de fichero ENI de configuración incorrecto. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero ENI de configuración de la red EtherCAT tiene un formato ilegible para el CNC. El configurador que ha generado el fichero ENI puede no ser compatible con el CNC. El fichero puede estar incompleto o corrupto. SOLUCIÓN Revisar el fichero." .

ex:Alarma_24020
    a ex:Alarma ;
    rdfs:label "EtherCAT: Fichero de rutado no existe" ;
    ex:identificador "24020" ;
    ex:textoExtracto "24020 EtherCAT: Fichero de rutado no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor." .

ex:Parametro_EtherCAT_Datalink
    a ex:Parametro ;
    rdfs:label "Datalink EtherCAT" ;
    ex:textoExtracto "Datalink no presente" .

ex:Parametro_EtherCAT_Paquete
    a ex:Parametro ;
    rdfs:label "Paquete EtherCAT" ;
    ex:textoExtracto "Paquete perdido" .

ex:Parametro_EtherCAT_CRC
    a ex:Parametro ;
    rdfs:label "CRC EtherCAT" ;
    ex:textoExtracto "CRC Incorrecto" .

ex:Parametro_EtherCAT_WorkingCounter
    a ex:Parametro ;
    rdfs:label "Working Counter EtherCAT" ;
    ex:textoExtracto "Working Counter error" .

ex:Sistema_EtherCAT
    a ex:Sistema ;
    rdfs:label "Sistema EtherCAT" ;
    ex:textoExtracto "bus EtherCAT" ;
    ex:tieneComponente ex:ComponenteElectrico_CableEtherCAT .

ex:ComponenteElectrico_CableEtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Cable EtherCAT" ;
    ex:textoExtracto "cable EtherCAT" .