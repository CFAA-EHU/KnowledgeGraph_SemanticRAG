@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarFichero a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar Fichero" ;
    ns1:solucionaFallo ns1:NoSeHaPodidoAbrirElFicheroDeEjes ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el fichero existe y que se puede abrir con un editor habitual. Si está corrupto, póngase en contacto con Fagor Automation." .

ns1:ProgramarSimboloValido a ns1:TareaMantenimiento ;
    rdfs:label "Programar Símbolo Válido" ;
    ns1:solucionaFallo ns1:RegistroNoDefinido ;
    ns1:textoExtracto "SOLUCIÓN Programar un símbolo válido, donde \"Símbolo\" puede ser una variable del sistema o un símbolo definido con DEF/PDEF." .

ns1:RevisarNombreDeSubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Nombre de Subrutinas" ;
    ns1:solucionaFallo ns1:SubrutinaIndefinida ;
    ns1:textoExtracto "SOLUCIÓN Revisar el nombre de las subrutinas y las llamadas a subrutinas." .

ns1:RevisarSintaxis_fbd769150c a ns1:TareaMantenimiento ;
    rdfs:label "Revisar Sintaxis" ;
    ns1:solucionaFallo ns1:AlgunCaracterProgramadoNoEsCorrecto ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:AlgunCaracterProgramadoNoEsCorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Algún carácter programado no es correcto" ;
    ns1:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:NoSeHaPodidoAbrirElFicheroDeEjes a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha podido abrir el fichero de ejes" ;
    ns1:textoExtracto "8876 No se ha podido abrir el fichero de ejes DETECCIÓN Durante la compilación del programa PLC." .

ns1:RegistroNoDefinido a ns1:DiagnosticoFallo ;
    rdfs:label "Registro no definido" ;
    ns1:textoExtracto "8875 Registro no definido. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:SubrutinaIndefinida a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina indefinida" ;
    ns1:textoExtracto "8874 Subrutina indefinida. DETECCIÓN Durante la compilación del programa PLC." .

