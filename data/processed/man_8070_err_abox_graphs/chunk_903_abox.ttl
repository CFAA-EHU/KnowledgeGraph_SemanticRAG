ns1:DefinirDemasiadasEtiquetas a ns1:AccionProhibida ;
    rdfs:label "Definir demasiadas etiquetas" ;
    ns1:solucionaFallo ns1:SubrutinaDefinidaPeroNoLlamada_bb119f7209 ;
    ns1:textoExtracto "Hay demasiadas etiquetas definidas en el programa." .

ns1:DefinirSubrutinaSinLlamarla a ns1:AccionProhibida ;
    rdfs:label "Definir subrutina sin llamarla" ;
    ns1:solucionaFallo ns1:SubrutinaDefinidaPeroNoLlamada_bb119f7209 ;
    ns1:textoExtracto "SOLUCIÓN Revisar las llamadas a subrutinas o borrar la subrutina si no se usa." .

ns1:EnLugarDe_551d84a3c9 a ns1:AccionProhibida ;
    rdfs:label "% en lugar de %" ;
    ns1:solucionaFallo ns1:SubrutinaDefinidaPeroNoLlamada_bb119f7209 ;
    ns1:textoExtracto "8881 % en lugar de %. DETECCIÓN Durante la edición del programa PLC." .

ns1:ErrorSintacticoSeEsperaba_4d27b9bf3b a ns1:AccionProhibida ;
