    ns1:solucionaFallo ns1:SubrutinaDefinidaPeroNoLlamada_bb119f7209 ;
    ns1:textoExtracto "8880 Error sintáctico. Se esperaba %. DETECCIÓN Durante la edición del programa PLC." .

ns1:RevisarLlamadasASubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Revisar llamadas a subrutinas" ;
    ns1:textoExtracto "SOLUCIÓN Revisar las llamadas a subrutinas o borrar la subrutina si no se usa." .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:RevisarSintaxisEnElManualDeInstalacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis en el manual de instalación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:UtilizarSubrutinasEnLugarDeSaltosAEtiquetas a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar subrutinas en lugar de saltos a etiquetas" ;
    ns1:textoExtracto "SOLUCIÓN Utilizar subrutinas en lugar de saltos a etiquetas." .

ns1:SubrutinaDefinidaPeroNoLlamada_bb119f7209 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina definida pero no llamada" ;
    ns1:textoExtracto "8878 Subrutina definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC." .

