@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LaSintaxisDeLaInstruccionNoEsCorrecta_081423a6a6 a ns1:AccionProhibida ;
    rdfs:label "La sintaxis de la instrucción no es correcta" ;
    ns1:solucionaFallo ns1:CNCEXBloqueMarcaCanal,
        ns1:CNCRDVariableRegistroMarca,
        ns1:CNCWRRegistroVariableMarca,
        ns1:SobraParametroEnSentencia ;
    ns1:textoExtracto "CAUSA La sintaxis de la instrucción no es correcta." .

ns1:RevisarEnElManualDeInstalacionLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de instalación la sintaxis" ;
    ns1:solucionaFallo ns1:CNCEXBloqueMarcaCanal,
        ns1:CNCRDVariableRegistroMarca,
        ns1:CNCWRRegistroVariableMarca,
        ns1:SobraParametroEnSentencia ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:CNCEXBloqueMarcaCanal a ns1:DiagnosticoFallo ;
    rdfs:label "CNCEX(bloque,marca <,canal>)" ;
    ns1:identificador "8885" ;
    ns1:textoExtracto "8885 CNCEX(bloque,marca <,canal>)." .

