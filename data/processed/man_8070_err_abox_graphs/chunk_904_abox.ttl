ex:InterfazDiagnostico_EtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis EtherCAT"@es ;
    ex:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es ;
