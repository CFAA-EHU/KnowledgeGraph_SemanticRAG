ex:Fallo_24508
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo genérico de bus local"@es ;
    ex:identificador "24508" ;
    ex:textoExtracto "24508 Fallo genérico de bus local. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

