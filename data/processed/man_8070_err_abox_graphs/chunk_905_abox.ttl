@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error24513 a ex:DiagnosticoFallo ;
    rdfs:label "Módulo %u reset del dispositivo" ;
    ex:textoExtracto "24513 Módulo %u reset del dispositivo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    ex:identificador "24513" .

ex:Error24514 a ex:DiagnosticoFallo ;
    rdfs:label "Módulo %u timeout de comunicación" ;
    ex:textoExtracto "24514 Módulo %u timeout de comunicación. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    ex:identificador "24514" .

ex:Error24515 a ex:DiagnosticoFallo ;
    rdfs:label "Múltiples errores de comunicación en el módulo %u" ;
    ex:textoExtracto "24515 Múltiples errores de comunicación en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    ex:identificador "24515" .

ex:Error24516 a ex:DiagnosticoFallo ;
    rdfs:label "Error de comunicación de datos de E/S en el módulo %u" ;
    ex:textoExtracto "24516 Error de comunicación de datos de E/S en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    ex:identificador "24516" .

ex:Error24517 a ex:DiagnosticoFallo ;
    rdfs:label "Error de comunicación de datos de gestión en el módulo %u" ;
    ex:textoExtracto "24517 Error de comunicación de datos de gestión en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    ex:identificador "24517" .

ex:PantallaDiagnosis a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis" ;
    ex:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución." ;
    ex:activaAlarma ex:Error24513, ex:Error24514, ex:Error24515, ex:Error24516, ex:Error24517 .