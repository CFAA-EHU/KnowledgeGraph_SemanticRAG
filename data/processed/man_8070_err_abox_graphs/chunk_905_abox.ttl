@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MOVEABSADDEjePosicionVelocidadTipoEnlace a ns1:Parametro ;
    rdfs:label "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)" ;
    ns1:textoExtracto "8886 MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)" .

ns1:MOVEINFEjeSentidoVelocidadTipoEnlace a ns1:Parametro ;
    rdfs:label "MOVE INF(eje,sentido,velocidad,tipoEnlace)" ;
    ns1:textoExtracto "8887 MOVE INF(eje,sentido,velocidad,tipoEnlace)" .

ns1:RevisarEnElManualDeInstalacionLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de instalación la sintaxis" ;
    ns1:solucionaFallo ns1:LaSintaxisDeLaInstruccionNoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:LaSintaxisDeLaInstruccionNoEsCorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "La sintaxis de la instrucción no es correcta" ;
    ns1:textoExtracto "CAUSA La sintaxis de la instrucción no es correcta." .

