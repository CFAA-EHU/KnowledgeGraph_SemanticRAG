ex:PantallaDiagnosis
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis" ;
    ex:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución." ;
    ex:activaAlarma ex:ErrorGestionModulo_24517 ;
    ex:activaAlarma ex:ErrorBusDispositivo_24518 ;
    ex:activaAlarma ex:ErrorConfiguracionModulo_24519 ;
    ex:activaAlarma ex:ErrorHardwareModulo_24520 ;
    ex:activaAlarma ex:ErrorFirmwareModulo_24521 ;
    ex:activaAlarma ex:ErrorPerifericoModulo_24522 .