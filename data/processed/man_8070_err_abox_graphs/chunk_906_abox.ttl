@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorGestionModulo_24517
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de gestión en el módulo %u" ;
    ex:textoExtracto "24517 Error de gestión en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." ;
    ex:identificador "24517" .

