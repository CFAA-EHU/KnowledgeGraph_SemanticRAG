@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirInstruccionIncorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir instrucción incorrecta" ;
    ns1:solucionaFallo ns1:InstruccionIncorrecta ;
    ns1:textoExtracto "SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta." .

ns1:RevisarSintaxisDeLaInstruccion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de la instrucción" ;
    ns1:solucionaFallo ns1:InstruccionAnteriorIncorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:InstruccionAnteriorIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción anterior incorrecta" ;
    ns1:textoExtracto "8894 'Instrucción anterior incorrecta' DETECCIÓN Al compilar el programa PLC." .

ns1:InstruccionIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción incorrecta" ;
    ns1:textoExtracto "8895 'Instrucción incorrecta' DETECCIÓN Al compilar el programa PLC." .

