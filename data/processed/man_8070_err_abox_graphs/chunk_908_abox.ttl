@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorregirEliminarOComentarLaInstruccionIncorrecta a ns1:TareaMantenimiento ;
    rdfs:label "Corregir, eliminar o comentar la instrucción incorrecta" ;
    ns1:solucionaFallo ns1:InstruccionIncorrecta_c39c8f5c73 ;
    ns1:textoExtracto "SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta." .

ns1:EliminarModuloVacioOPonerUnaUnicaInstruccionQueSea a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar módulo vacío o poner una única instrucción que sea ';'." ;
    ns1:solucionaFallo ns1:SoloSePermiteModuloVacioEnCY1 ;
    ns1:textoExtracto "SOLUCIÓN Ante un módulo vacío hay dos alternativas; eliminarlo o poner una única instrucción que sea ';'" .

ns1:UtilizarLaSenalEnInstruccionesDeConsulta a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar la señal en instrucciones de consulta" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_c5ad4acc9b ;
    ns1:textoExtracto "SOLUCIÓN Utilizar la señal en instrucciones de consulta." .

ns1:DiagnosticoFallo_c5ad4acc9b a ns1:DiagnosticoFallo ;
    rdfs:label "Marca del sistema sin permiso de escritura para el PLC" ;
    ns1:textoExtracto "Marca del sistema sin permiso de escritura para el PLC. DETECCIÓN Durante la edición del programa PLC. CAUSA La señal (marca) no es modificable; es una señal de consulta." .

ns1:InstruccionIncorrecta_c39c8f5c73 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción incorrecta" ;
    ns1:textoExtracto "'Instrucción incorrecta' DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador, antes de su conversión a C, ha detectado una instrucción incorrecta." .

ns1:SoloSePermiteModuloVacioEnCY1 a ns1:DiagnosticoFallo ;
    rdfs:label "Sólo se permite módulo vacío en CY1" ;
    ns1:textoExtracto "'Sólo se permite módulo vacío en CY1' DETECCIÓN Al compilar el programa PLC. CAUSA En el programa PLC hay programado un módulo PRG, PE o SUB vacío." .

