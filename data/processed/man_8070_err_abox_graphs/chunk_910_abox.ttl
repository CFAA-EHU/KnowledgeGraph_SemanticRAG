@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error24560 a ex:DiagnosticoFallo ;
    ex:identificador "24560" ;
    ex:textoExtracto "Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Error de hardware/firmware en nodo EtherCAT (24560)"@es .

ex:Error24561 a ex:DiagnosticoFallo ;
    ex:identificador "24561" ;
    ex:textoExtracto "Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Error de hardware/firmware en nodo EtherCAT (24561)"@es .

ex:Error24562 a ex:DiagnosticoFallo ;
    ex:identificador "24562" ;
    ex:textoExtracto "Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Error de hardware/firmware en nodo EtherCAT (24562)"@es .

ex:Error24563 a ex:DiagnosticoFallo ;
    ex:identificador "24563" ;
    ex:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Fallo de activación del bus local (24563)"@es .

ex:Error24564 a ex:DiagnosticoFallo ;
    ex:identificador "24564" ;
    ex:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Fallo de activación del bus local (24564)"@es .

ex:InterfazDiagnostico a ex:InterfazUsuario ;
    ex:textoExtracto "En la pantalla de diagnosis, durante la ejecución."@es ;
    rdfs:label "Pantalla de diagnóstico"@es ;
    ex:monitoreaParametro ex:Error24560, ex:Error24561, ex:Error24562, ex:Error24563, ex:Error24564 .

ex:SistemaEtherCAT a ex:Sistema ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Sistema EtherCAT"@es ;
    ex:tieneComponente ex:NodoEtherCATGenerico ;
    ex:activaAlarma ex:Error24560, ex:Error24561, ex:Error24562, ex:Error24563, ex:Error24564 .

ex:NodoEtherCATGenerico a ex:ComponenteElectrico ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    rdfs:label "Nodo EtherCAT (genérico)"@es .