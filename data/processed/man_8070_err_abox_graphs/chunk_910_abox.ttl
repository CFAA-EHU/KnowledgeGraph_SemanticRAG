ns1:ParametroGAPCTRL a ns1:Parametro ;
    rdfs:label "Parámetro GAPCTRL" ;
    ns1:textoExtracto "#GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>]" .

ns1:ParametroLEAP a ns1:Parametro ;
    rdfs:label "Parámetro LEAP" ;
    ns1:textoExtracto "#LEAP[<,INCPOS> <,G90/G91> <,POSvalor> <,POSLIMITvalor> <,GAPvalor> <,TIMEvalor> <,OVRvalor>] <nombreEje cotaEje>" .

