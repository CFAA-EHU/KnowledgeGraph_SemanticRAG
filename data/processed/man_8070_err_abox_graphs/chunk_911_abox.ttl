@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24565 a ex:DiagnosticoFallo ;
    ex:identificador "24565" ;
    ex:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24566 a ex:DiagnosticoFallo ;
    ex:identificador "24566" ;
    ex:textoExtracto "El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24567 a ex:DiagnosticoFallo ;
    ex:identificador "24567" ;
    ex:textoExtracto "Módulo %u localbus perdido. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24568 a ex:DiagnosticoFallo ;
    ex:identificador "24568" ;
    ex:textoExtracto "Nuevo módulo %u localbus añadido. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24569 a ex:DiagnosticoFallo ;
    ex:identificador "24569" ;
    ex:textoExtracto "Módulo %u de bus local en posición incorrecta. DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es .

ex:InterfazDiagnostico a ex:InterfazUsuario ;
    ex:textoExtracto "pantalla de diagnosis, durante la ejecución"@es ;
    ex:documentadoEn ex:Manual_24000_24999 .

ex:Manual_24000_24999 a ex:Manual ;
    ex:identificador "24000-24999" ;
    ex:textoExtracto "Sección 24000-24999: Diagnósticos de fallos en bus local y módulos EtherCAT"@es .

ex:SistemaEtherCAT a ex:Sistema ;
    ex:textoExtracto "nodo EtherCAT"@es ;
    ex:activaAlarma ex:Error_24565, ex:Error_24566, ex:Error_24567, ex:Error_24568, ex:Error_24569 ;
    ex:monitoreaParametro ex:Parametro_Emergencia .

ex:Parametro_Emergencia a ex:Parametro ;
    ex:textoExtracto "valor adicional que acompaña al error (código hexadecimal de la emergencia)"@es ;
    ex:valor "código hexadecimal"@es .