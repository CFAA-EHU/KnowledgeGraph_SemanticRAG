@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDeGap_f1bdb231ab a ns1:Parametro ;
    rdfs:label "Control de gap" ;
    ns1:identificador "GAPCTRL" ;
    ns1:textoExtracto "#GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>]" .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:RegistroDeDatosCNC a ns1:Parametro ;
    rdfs:label "Registro de datos CNC" ;
    ns1:identificador "CNCRD" ;
    ns1:textoExtracto "CNCRD(idVar, canal, ejeLog, idxArray1, idxArray2, registro, marca <,registroError>)" .

ns1:TablaTecnica a ns1:Parametro ;
    rdfs:label "Tabla técnica" ;
    ns1:identificador "TECHTABLE" ;
    ns1:textoExtracto "#TECHTABLE<[N\"nombreFicheroMaterial\",> \"nombreTabla\" <OFF]> <Tvalor params>" .

ns1:UsoDeSintaxisIncorrectaEnSentenciasOComandos a ns1:AccionProhibida ;
    rdfs:label "Uso de sintaxis incorrecta en sentencias o comandos" ;
    ns1:mitigaRiesgo ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

