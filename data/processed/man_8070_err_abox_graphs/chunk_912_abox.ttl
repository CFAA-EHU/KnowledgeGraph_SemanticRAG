ns1:DuranteLaEdicionOCompilacionDelProgramaPLC a ns1:AccionProhibida ;
    rdfs:label "Durante la edición o compilación del programa PLC" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:Parametro_2c95ceee19 a ns1:Parametro ;
    rdfs:label "Comando CNCWR" ;
    ns1:textoExtracto "8905 CNCWR(registro, idVar, canal, ejeLog, idxArray1, idxArray2, marca <,registroError>)" .

ns1:RevisarEnElManualDeInstalacionLaSintaxis a ns1:TareaMantenimiento ;
    rdfs:label "Revisar en el manual de instalación la sintaxis" ;
    ns1:solucionaFallo ns1:LaSintaxisDelComandoNoEsCorrecta ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:LaSintaxisDelComandoNoEsCorrecta a ns1:AccionProhibida ;
