    ex:identificador "24578" ;
    ex:textoExtracto "Módulo %u: fallo en el suministro de E/S. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:PantallaDiagnosis a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ex:textoExtracto "En la pantalla de diagnosis, durante la ejecución."@es ;
    ex:activaAlarma ex:Error_24574, ex:Error_24575, ex:Error_24576, ex:Error_24577, ex:Error_24578 .

ex:NodoEtherCAT a ex:ComponenteElectrico ;
    rdfs:label "Nodo EtherCAT"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .