    ex:textoExtracto "Módulo %u: sobrecarga de cortocircuito/salida. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24577 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en suministro de E/S"@es ;
    ex:identificador "24577" ;
    ex:textoExtracto "Módulo %u: fallo en el suministro de E/S. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24578 a ex:DiagnosticoFallo ;
