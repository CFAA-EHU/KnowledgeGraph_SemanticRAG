@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24574 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de entrada en grupo"@es ;
    ex:identificador "24574" ;
    ex:textoExtracto "Módulo %u: Grupo %u de sobrecarga de entrada. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24575 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de cortocircuito/salida (24575)"@es ;
    ex:identificador "24575" ;
    ex:textoExtracto "Módulo %u: sobrecarga de cortocircuito/salida. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24576 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de cortocircuito/salida (24576)"@es ;
