@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SolucionDemasiadosDFUs a ns1:TareaMantenimiento ;
    rdfs:label "Solución demasiados DFUs" ;
    ns1:solucionaFallo ns1:DemasiadosDFUsEnUnaUnicaConsulta_c60a731b4f ;
    ns1:textoExtracto "Analizar las instrucciones DFU en grupos, guardando el resultado en una marca." .

ns1:SolucionModuloDuplicado a ns1:TareaMantenimiento ;
    rdfs:label "Solución módulo duplicado" ;
    ns1:solucionaFallo ns1:ErrorFatalModuloDuplicadoONoPermitido_8c02e589fd ;
    ns1:textoExtracto "Los módulos CY1 y PRG sólo se pueden programar una vez. Un proyecto puede tener varios módulos periódicos, pero con diferente periodo." .

ns1:SolucionNumeroDeBitsEnMOV a ns1:TareaMantenimiento ;
    rdfs:label "Solución número de bits en MOV" ;
    ns1:solucionaFallo ns1:NumeroDeBitsFueraDelRangoPermitidoEnMOV_16b4400f93 ;
    ns1:textoExtracto "El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32." .

ns1:SolucionRecursoFueraDeRango a ns1:TareaMantenimiento ;
    rdfs:label "Solución recurso fuera de rango" ;
    ns1:solucionaFallo ns1:RecursoFueraDelRangoPermitido_1e5ff9e59b ;
    ns1:textoExtracto "El rango válido para cada recurso es el siguiente. Entradas (I1-I1024). Salidas (O1-O1024). Entradas locales (LI1-LI16). Salidas locales (LO1-LO8). Marcas (M1-M8192). Mensajes (MSG1-MSG1024). Errores (ERR1-ERR1024). Relojes (CLK). Registros (R1-R1024). Bit de registros (B0-B31 R1-R1024). Estado de los temporizadores (T1-T512). Estado de los contadores (C1-C256)." .

ns1:SolucionTGFueraDeRango a ns1:TareaMantenimiento ;
    rdfs:label "Solución TG fuera de rango" ;
    ns1:solucionaFallo ns1:TGFueraDelRangoPermitido_b6317e6259 ;
    ns1:textoExtracto "Programar una entrada de arranque dentro del rango TG1 a TG4." .

ns1:DemasiadosDFUsEnUnaUnicaConsulta_c60a731b4f a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados DFUs en una única consulta" ;
    ns1:textoExtracto "9018 Demasiados DFUs en una única consulta." .

ns1:ErrorFatalModuloDuplicadoONoPermitido_8c02e589fd a ns1:DiagnosticoFallo ;
    rdfs:label "Error fatal. Módulo duplicado o no permitido" ;
    ns1:textoExtracto "9014 Error fatal. Módulo duplicado o no permitido." .

ns1:NumeroDeBitsFueraDelRangoPermitidoEnMOV_16b4400f93 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de bits fuera del rango permitido en MOV" ;
    ns1:textoExtracto "9017 Numero de bits fuera del rango permitido en MOV." .

ns1:RecursoFueraDelRangoPermitido_1e5ff9e59b a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso fuera del rango permitido" ;
    ns1:textoExtracto "9016 Recurso fuera del rango permitido." .

ns1:TGFueraDelRangoPermitido_b6317e6259 a ns1:DiagnosticoFallo ;
    rdfs:label "TG fuera del rango permitido" ;
    ns1:textoExtracto "9015 TG fuera del rango permitido." .

