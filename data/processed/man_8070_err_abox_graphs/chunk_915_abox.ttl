@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24584
    a ex:DiagnosticoFallo ;
    rdfs:label "Reinicio del dispositivo después del watchdog" ;
    ex:identificador "24584" ;
    ex:textoExtracto "24584 Reinicio del dispositivo después del watchdog. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

