ex:ManualEspecificoNodo
    a ex:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT" ;
    ex:textoExtracto "consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ex:Error_24584 ex:documentadoEn ex:ManualEspecificoNodo .
