@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SustituirElCaracterPor a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir el carácter '/' por '_'." ;
    ns1:solucionaFallo ns1:ElCaracterEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Sustituir el carácter \"/\" por" .

ns1:SustituirLaMarcaORegistroPorElRecursoSugerido a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir la marca o registro por el recurso sugerido" ;
    ns1:solucionaFallo ns1:LaMarcaORegistroEsIncorrecto ;
    ns1:textoExtracto "SOLUCIÓN Sustituir la marca o registro por el recurso sugerido." .

ns1:ElCaracterEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "El carácter '/' es incorrecto" ;
    ns1:textoExtracto "CAUSA El carácter \"/\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado." .

ns1:LaMarcaORegistroEsIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "La marca o registro es incorrecto" ;
    ns1:textoExtracto "CAUSA La marca o registro es incorrecto; el PLC lo ha sustituido en el programa compilado por el recurso sugerido." .

