@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NoHayMemoriaParaRecursosRegistrosNuevos_f5a4fbf4c2 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay memoria para recursos registros nuevos" ;
    ns1:textoExtracto "CAUSA El sistema no dispone de memoria para crear recursos nuevos." .

ns1:PongaseEnContactoConFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:NoHayMemoriaParaRecursosBinariosDeSistemaNuevos,
        ns1:NoHayMemoriaParaRecursosBinariosNuevos ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:SustituirElCaracterPorEnElProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir el carácter '.' por '_' en el programa de PLC",
        "Sustituir el carácter '/' por '_' en el programa de PLC" ;
    ns1:solucionaFallo ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorEnElProgramaCompilado ;
    ns1:textoExtracto "SOLUCIÓN Sustituir el carácter \"/\" por \"_\" en el programa de PLC." .

ns1:SustituirElCaracterPorNEGEnElProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir el carácter '-' por 'NEG' en el programa de PLC" ;
    ns1:solucionaFallo ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorNEGEnElProgramaCompilado ;
    ns1:textoExtracto "SOLUCIÓN Sustituir el carácter \"-\" por \"NEG\" en el programa de PLC." .

ns1:SustituirElCaracterPorPOSEnElProgramaDePLC a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir el carácter '+' por 'POS' en el programa de PLC" ;
    ns1:solucionaFallo ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorPOSEnElProgramaCompilado ;
    ns1:textoExtracto "SOLUCIÓN Sustituir el carácter \"+\" por \"POS\" en el programa de PLC." .

ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorEnElProgramaCompilado a ns1:DiagnosticoFallo ;
    rdfs:label "El carácter '.' es incorrecto; el PLC lo ha sustituido por '_' en el programa compilado",
        "El carácter '/' es incorrecto; el PLC lo ha sustituido por '_' en el programa compilado" ;
    ns1:textoExtracto "CAUSA El carácter \".\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado." .

ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorNEGEnElProgramaCompilado a ns1:DiagnosticoFallo ;
    rdfs:label "El carácter '-' es incorrecto; el PLC lo ha sustituido por 'NEG' en el programa compilado" ;
    ns1:textoExtracto "CAUSA El carácter \"-\" es incorrecto; el PLC lo ha sustituido por \"NEG\" en el programa compilado." .

ns1:ElCaracterEsIncorrectoElPLCLoHaSustituidoPorPOSEnElProgramaCompilado a ns1:DiagnosticoFallo ;
    rdfs:label "El carácter '+' es incorrecto; el PLC lo ha sustituido por 'POS' en el programa compilado" ;
    ns1:textoExtracto "CAUSA El carácter \"+\" es incorrecto; el PLC lo ha sustituido por \"POS\" en el programa compilado." .

ns1:NoHayMemoriaParaRecursosBinariosDeSistemaNuevos a ns1:DiagnosticoFallo ;
    rdfs:label "No hay memoria para recursos binarios de sistema nuevos" ;
    ns1:textoExtracto "CAUSA El sistema no dispone de memoria para crear recursos nuevos." .

ns1:NoHayMemoriaParaRecursosBinariosNuevos a ns1:DiagnosticoFallo ;
    rdfs:label "No hay memoria para recursos binarios nuevos" ;
    ns1:textoExtracto "CAUSA El sistema no dispone de memoria para crear recursos nuevos." .

