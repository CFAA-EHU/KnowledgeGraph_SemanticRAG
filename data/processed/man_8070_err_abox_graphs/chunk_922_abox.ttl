@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorEtherCAT_24626
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Reconfiguración del bus local"@es ;
    ex:identificador "24626" ;
    ex:textoExtracto "La aplicación solicitaba una reconfiguración del bus local. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:ErrorEtherCAT_24627
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Módulos faltantes en el sistema"@es ;
    ex:identificador "24627" ;
    ex:textoExtracto "Comenzar con el sistema restante, %u módulos esperados, encontrados %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:ErrorEtherCAT_24650
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Cambio de estado no válido"@es ;
    ex:identificador "24650" ;
    ex:textoExtracto "Petición de cambio de estado: De %u a:%u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:ErrorEtherCAT_24651
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error genérico de nodo EtherCAT"@es ;
    ex:identificador "24651" ;
    ex:textoExtracto "%u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:ErrorEtherCAT_24652
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Tiempo de ciclo del bus incorrecto"@es ;
    ex:identificador "24652" ;
    ex:textoExtracto "Cálculo erróneo del tiempo de ciclo del bus (Timer local muy lento). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:ErrorEtherCAT_Generico
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Emergencia de nodo EtherCAT"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:SistemaEtherCAT
    a               ex:Sistema ;
    rdfs:label      "Sistema de bus EtherCAT"@es ;
    ex:textoExtracto "bus local... módulos esperados... tiempo de ciclo del bus"@es .

ex:ErrorEtherCAT_24626 ex:solucionaFallo ex:SistemaEtherCAT .
ex:ErrorEtherCAT_24627 ex:solucionaFallo ex:SistemaEtherCAT .
ex:ErrorEtherCAT_24650 ex:solucionaFallo ex:SistemaEtherCAT .
ex:ErrorEtherCAT_24651 ex:solucionaFallo ex:SistemaEtherCAT .
ex:ErrorEtherCAT_24652 ex:solucionaFallo ex:SistemaEtherCAT .