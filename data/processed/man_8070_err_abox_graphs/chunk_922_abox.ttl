@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsociarPalpadorAEntradaDigitalDeNodoFagor a ns1:AccionProhibida ;
    rdfs:label "Asociar palpador a entrada digital de nodo Fagor" ;
    ns1:textoExtracto "'El palpador debe asociarse a entrada digital de nodo Fagor'" .

ns1:RearrancarWindows a ns1:TareaMantenimiento ;
    rdfs:label "Rearrancar Windows" ;
    ns1:solucionaFallo ns1:FalloParametrosMaquina ;
    ns1:textoExtracto "'Para asumir el nuevo valor es necesario rearrancar windows'" .

ns1:FalloParametrosMaquina a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio en parámetros máquina requiere rearranque de Windows" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto." .

