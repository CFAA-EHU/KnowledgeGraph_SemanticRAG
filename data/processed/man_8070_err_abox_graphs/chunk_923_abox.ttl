@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsegurarQueLosEjesSERCOSTenganIgualOPMODEP a ns1:TareaMantenimiento ;
    rdfs:label "Asegurar que los ejes SERCOS tengan igual OPMODEP" ;
    ns1:solucionaFallo ns1:TenerDiferenteParametroOPMODEPEnEjesGantry ;
    ns1:textoExtracto "Los dos ejes SERCOS tienen que tener igual OPMODEP." .

ns1:AsignarEntradaDigitalDeModuloFagorOLogicaAlPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Asignar entrada digital de módulo Fagor o lógica al palpador" ;
    ns1:solucionaFallo ns1:AsociarPalpadorAEntradaDigitalNoValida ;
    ns1:textoExtracto "SOLUCIÓN Asignar a los parámetros PRBDI1 y PRBDI2 una entrada digital de un módulo Fagor o una entrada lógica." .

ns1:ElPalpadorDebeAsociarseAEntradaDigitalDeNodoFagor a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador debe asociarse a entrada digital de nodo Fagor" ;
    ns1:identificador "9303" ;
    ns1:textoExtracto "'El palpador debe asociarse a entrada digital de nodo Fagor'" .

ns1:LosDosEjesSERCOSTienenQueTenerIgualOPMODEP a ns1:DiagnosticoFallo ;
    rdfs:label "Los dos ejes SERCOS tienen que tener igual OPMODEP" ;
    ns1:identificador "9304" ;
    ns1:textoExtracto "'Ejes gantry: Los dos ejes SERCOS tienen que tener igual OPMODEP'" .

ns1:RearrancarWindows_fedafbdb48 a ns1:TareaMantenimiento ;
    rdfs:label "Rearrancar Windows" ;
    ns1:solucionaFallo ns1:CambiarParametrosMaquinaSinRearrancarWindows ;
    ns1:textoExtracto "SOLUCIÓN Rearrancar windows." .

ns1:AsociarPalpadorAEntradaDigitalNoValida a ns1:AccionProhibida ;
    rdfs:label "Asociar palpador a entrada digital no válida" ;
    ns1:textoExtracto "El parámetro PRBDI1 o PRBDI2 hace referencia a una entrada digital no válida." .

ns1:CambiarParametrosMaquinaSinRearrancarWindows a ns1:AccionProhibida ;
    rdfs:label "Cambiar parámetros máquina sin rearrancar Windows" ;
    ns1:textoExtracto "Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto." .

ns1:TenerDiferenteParametroOPMODEPEnEjesGantry a ns1:AccionProhibida ;
    rdfs:label "Tener diferente parámetro OPMODEP en ejes gantry" ;
    ns1:textoExtracto "Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP." .

