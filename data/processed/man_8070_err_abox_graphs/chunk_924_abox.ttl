@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24658
    a ex:DiagnosticoFallo ;
    rdfs:label "Software exception" ;
    ex:identificador "24658" ;
    ex:textoExtracto "24658 Software exception, fichero: %s, linea: %d. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:Error_24659
    a ex:DiagnosticoFallo ;
    rdfs:label "Código de emergencia CoE" ;
    ex:identificador "24659" ;
    ex:textoExtracto "24659 Código de emergencia CoE: 0x%X, información adicional: 0x%X. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:Error_24660
    a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en salidas digitales" ;
    ex:identificador "24660" ;
    ex:textoExtracto "24660 Sobrecorriente en las salidas digitales. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:Error_24661
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en voltaje interno ±15V" ;
    ex:identificador "24661" ;
    ex:textoExtracto "24661 Error en voltaje interno +15 V/-15 V. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:Error_24662
    a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en salidas analógicas" ;
    ex:identificador "24662" ;
    ex:textoExtracto "24662 Sobrecorriente en las salidas analógica. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:Error_24663
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en testeo de memoria" ;
    ex:identificador "24663" ;
    ex:textoExtracto "24663 Falló el testeo de memoria. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ex:ManualEspecificoNodo
    a ex:Manual ;
    ex:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ex:Error_24658 ex:documentadoEn ex:ManualEspecificoNodo .
ex:Error_24659 ex:documentadoEn ex:ManualEspecificoNodo .
ex:Error_24660 ex:documentadoEn ex:ManualEspecificoNodo .
