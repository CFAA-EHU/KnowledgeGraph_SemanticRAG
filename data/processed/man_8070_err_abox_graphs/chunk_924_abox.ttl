@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminacionDeUnFiltroDeFrecuenciaOFiltroDelModoHSCFAST a ns1:TareaMantenimiento ;
    rdfs:label "Eliminación de un filtro de frecuencia o filtro del modo HSC FAST" ;
    ns1:solucionaFallo ns1:FiltroFASTIncompatibleCon3oFiltroDeEje_65406da271 ;
    ns1:textoExtracto "SOLUCIÓN Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST." .

ns1:ModoDeOperacion_78cb07824c a ns1:Parametro ;
    rdfs:label "Modo de operación" ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "Ambos ejes deben tener el parámetro OPMODEP igual." .

ns1:ReduccionDelOrdenDelFiltroOAumentoDeLaFrecuencia a ns1:TareaMantenimiento ;
    rdfs:label "Reducción del orden del filtro o aumento de la frecuencia" ;
    ns1:solucionaFallo ns1:NumeroDeOrdenDelFiltroDemasiadoElevado ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Reducir el orden del filtro o aumentar la frecuencia." .

ns1:RevisionDeParametrosMaquina_1443014623 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_c49230af05 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Ambos ejes deben tener el parámetro OPMODEP igual." .

ns1:DiagnosticoFallo_c49230af05 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro OPMODEP diferente en ejes maestro y esclavo" ;
    ns1:textoExtracto "Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP." .

ns1:FiltroFASTIncompatibleCon3oFiltroDeEje_65406da271 a ns1:DiagnosticoFallo ;
    rdfs:label "Filtro FAST incompatible con 3º filtro de eje" ;
    ns1:textoExtracto "El CNC no puede activar el filtro automático del modo HSC FAST porque ya hay tres filtros de frecuencia activos en el eje." .

ns1:NumeroDeOrdenDelFiltroDemasiadoElevado a ns1:DiagnosticoFallo ;
    rdfs:label "Número de orden del filtro demasiado elevado" ;
    ns1:textoExtracto "Uno de los filtros paso bajo del eje tiene un número de orden demasiado elevado para la frecuencia definida, lo que podría producir un sobrepasamiento." .

