PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24663 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en testeo de memoria" ;
    ex:identificador "24663" ;
    ex:textoExtracto "24663 Falló el testeo de memoria. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

