@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EliminarUnFiltroDeFrecuenciaDelEjeOEliminarElFiltroDelModoHSCFAST a ns1:TareaMantenimiento ;
    rdfs:label "Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST" ;
    ns1:textoExtracto "SOLUCIÓN Eliminar un filtro de frecuencia del eje o eliminar el filtro del modo HSC FAST." .

ns1:NoSePermitenPosicionesDeCompensacionFueraDelRangoDelModulo a ns1:AccionProhibida ;
    rdfs:label "No se permiten posiciones de compensación fuera del rango del módulo" ;
    ns1:textoExtracto "'No se permiten posiciones de compensación fuera del rango del módulo'" .

ns1:RevisarLosParametrosMaquina_dfe60b8459 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros máquina" ;
    ns1:solucionaFallo ns1:EsUnModeloMCYAlgunCanalNoEstaDefinidoComoCanalDePLC ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. En el modelo MC, todos los canales deben ser de PLC (parámetro CHTYPE)." .

ns1:TipoDeCanalCHTYPEDebeSerDePLC a ns1:Parametro ;
    rdfs:label "Tipo de canal CHTYPE debe ser de PLC" ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "'Con opción de software Motion Control el tipo de canal 'CHTYPE' debe ser de PLC'" .

ns1:EsUnModeloMCYAlgunCanalNoEstaDefinidoComoCanalDePLC a ns1:DiagnosticoFallo ;
    rdfs:label "Es un modelo MC y algún canal no está definido como canal de PLC" ;
    ns1:textoExtracto "Es un modelo MC y algún canal no está definido como canal de PLC." .

