ex:Error_80001
    a ex:AvisoSeguridad ;
    rdfs:label "Error interno #00: falta el texto del error E%D P0=%D" ;
    ex:identificador "80001" ;
    ex:textoExtracto "80001 Error interno #00: falta el texto del error E%D P0=%D. DETECCIÓN Durante la ejecución. CAUSA Error en la ejecución de la subrutina. SOLUCIÓN Revisar la programación." .

ex:Error_80010
