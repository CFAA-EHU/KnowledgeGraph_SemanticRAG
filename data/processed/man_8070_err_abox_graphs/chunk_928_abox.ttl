@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnDRIVEIDDentroDeLosGruposMULTIAXISQueEsteAsociadoAEjesDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un DRIVEID dentro de los grupos MULTIAXIS que esté asociado a ejes del sistema" ;
    ns1:solucionaFallo ns1:DRIVEIDDelEjeDelGrupoMULTIAXISNoValidoEnElSistema_1178e200d7 ;
    ns1:textoExtracto "SOLUCIÓN Asignar un DRIVEID dentro de los grupos MULTIAXIS que esté asociado a ejes del sistema." .

ns1:ReducirElNumeroDeEjesDelGrupoMULTIAXISOReducirElNumeroDeSetsDeParamet_48a58c3779 a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el número de ejes del grupo MULTIAXIS o reducir el número de sets de parámetros de los ejes del grupo" ;
    ns1:solucionaFallo ns1:ElNumeroDeSetsDelGrupoSuperaElNumeroDeSetsDelRegulador_3aba8dd1b0 ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de ejes del grupo MULTIAXIS o reducir el número de sets de parámetros de los ejes del grupo." .

ns1:RevisarLosParametrosMaquina_1a64a3ca20 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros máquina" ;
    ns1:solucionaFallo ns1:LosEjesDelGrupoNoTienenIgualOPMODEPTodosVelocidadOTodosPosicion_69ee76cb81 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo multieje deben tener el parámetro OPMODEP igual." .

ns1:TodosLosEjesSERCOSDebenSerVelocidad a ns1:TareaMantenimiento ;
    rdfs:label "Todos los ejes SERCOS deben ser velocidad" ;
    ns1:solucionaFallo ns1:GrupoDeEjesConDifCaptacionesTodosLosEjesSERCOSDebenSerVelocidad_40b8ade8af ;
    ns1:textoExtracto "SOLUCIÓN Todos los ejes SERCOS deben ser velocidad." .

ns1:TodosLosEjesSercosDeUnGrupoMULTIAXISDebenEstarAsociadosAlMismoRegulad_ab8f222787 a ns1:TareaMantenimiento ;
    rdfs:label "Todos los ejes Sercos de un grupo MULTIAXIS deben estar asociados al mismo regulador y por lo tanto deben tener igual el parámetro DRIVEID" ;
    ns1:solucionaFallo ns1:EjeSERCOSDelGrupoMultiaxisTieneDiferenteDRIVEID_8b84242ccd ;
    ns1:textoExtracto "SOLUCIÓN Todos los ejes Sercos de un grupo MULTIAXIS deben estar asociados al mismo regulador y por lo tanto deben tener igual el parámetro DRIVEID." .

ns1:DRIVEIDDelEjeDelGrupoMULTIAXISNoValidoEnElSistema_1178e200d7 a ns1:DiagnosticoFallo ;
    rdfs:label "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema" ;
    ns1:textoExtracto "'DRIVEID del eje del grupo MULTIAXIS no válido en el sistema' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No hay ningún eje en el sistema que tenga el mismo DRIVEID que el indicado al definir un grupo MULTIAXIS." .

ns1:EjeSERCOSDelGrupoMultiaxisTieneDiferenteDRIVEID_8b84242ccd a ns1:DiagnosticoFallo ;
    rdfs:label "Eje SERCOS del grupo multiaxis tiene diferente DRIVEID" ;
    ns1:textoExtracto "'Eje SERCOS del grupo multiaxis tiene diferente DRIVEID' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No todos los ejes de un grupo MULTIAXIS están asociados al mismo regulador (parámetro DRIVEID)." .

ns1:ElNumeroDeSetsDelGrupoSuperaElNumeroDeSetsDelRegulador_3aba8dd1b0 a ns1:DiagnosticoFallo ;
    rdfs:label "El número de Sets del grupo supera el número de Sets del regulador" ;
    ns1:textoExtracto "'El número de Sets del grupo supera el número de Sets del regulador' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El regulador admite 8 gamas y el número total de sets de parámetros definidos en un grupo MULTIAXIS supera este valor." .

ns1:GrupoDeEjesConDifCaptacionesTodosLosEjesSERCOSDebenSerVelocidad_40b8ade8af a ns1:DiagnosticoFallo ;
    rdfs:label "Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad" ;
    ns1:textoExtracto "'Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay algún grupo multieje cuyos ejes tienen diferente parámetro COUNTERID y los ejes no son Sercos velocidad." .

ns1:LosEjesDelGrupoNoTienenIgualOPMODEPTodosVelocidadOTodosPosicion_69ee76cb81 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes del grupo no tienen igual OPMODEP: todos velocidad o todos posición" ;
    ns1:textoExtracto "'Los ejes del grupo no tienen igual OPMODEP: todos velocidad o todos posición' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay algún grupo multieje cuyos ejes tienen diferente parámetro OPMODEP." .

