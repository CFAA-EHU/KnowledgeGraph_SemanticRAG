@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeParametrosMaquina_e896de1158 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina" ;
    ns1:solucionaFallo ns1:GrupoDeEjesConDiferenciasEnCaptaciones ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina." .

ns1:GrupoDeEjesConDiferenciasEnCaptaciones a ns1:DiagnosticoFallo ;
    rdfs:label "Grupo de ejes con diferencias en captaciones" ;
    ns1:monitoreaParametro ns1:ParametroCOUNTERID ;
    ns1:textoExtracto "'Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad'" .

ns1:ParametroCOUNTERID a ns1:Parametro ;
    rdfs:label "Parámetro COUNTERID" ;
    ns1:textoExtracto "Hay algún grupo multieje cuyos ejes tienen diferente parámetro COUNTERID y los ejes no son Sercos velocidad." .

