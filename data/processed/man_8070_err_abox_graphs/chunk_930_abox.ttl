@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error80028
    a ex:AvisoSeguridad ;
    rdfs:label "Error 80028: Parámetro S no permitido" ;
    ex:textoExtracto "80028 G%D S%D: Parámetro S no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro S. SOLUCIÓN Revisar la programación." ;
    ex:identificador "80028" .

ex:Error80029
    a ex:AvisoSeguridad ;
    rdfs:label "Error 80029: Parámetro T no permitido" ;
    ex:textoExtracto "80029 G%D T%D: Parámetro T no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro T. SOLUCIÓN Revisar la programación." ;
    ex:identificador "80029" .

ex:Error80030
    a ex:AvisoSeguridad ;
    rdfs:label "Error 80030: Parámetro U no permitido" ;
    ex:textoExtracto "80030 G%D U%D: Parámetro U no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro U. SOLUCIÓN Revisar la programación." ;
    ex:identificador "80030" .

ex:ParametroS
    a ex:Parametro ;
    rdfs:label "Parámetro S" ;
    ex:textoExtracto "Parámetro S no permitido" .

ex:ParametroT
    a ex:Parametro ;
    rdfs:label "Parámetro T" ;
    ex:textoExtracto "Parámetro T no permitido" .

ex:ParametroU
    a ex:Parametro ;
    rdfs:label "Parámetro U" ;
    ex:textoExtracto "Parámetro U no permitido" .

ex:Error80028 ex:monitoreaParametro ex:ParametroS .
ex:Error80029 ex:monitoreaParametro ex:ParametroT .
ex:Error80030 ex:monitoreaParametro ex:ParametroU .