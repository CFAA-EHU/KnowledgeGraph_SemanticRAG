@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AbsFeedback a ns1:Parametro ;
    rdfs:label "Abs Feedback" ;
    ns1:textoExtracto "Todos los ejes de un grupo MULTIAXIS deben tener el parámetro ABSFEEDBACK igual." .

ns1:AnaoutID a ns1:Parametro ;
    rdfs:label "Anaout ID" ;
    ns1:textoExtracto "Hay ejes en diferentes grupos MULTIAXIS que comparten la misma salida analógica." .

ns1:CambiarElParametroANAOUTIDDeLosEjesImplicados a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar el parámetro ANAOUTID de los ejes implicados" ;
    ns1:solucionaFallo ns1:DosEjesEnDiferentesGruposMultiejeConElMismoANAOUTIDEnAlgunoDeSusSETs ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el parámetro ANAOUTID de los ejes implicados para que no compartan la misma salida analógica." .

ns1:CambiarElParametroCOUNTERIDDeLosEjesImplicados a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar el parámetro COUNTERID de los ejes implicados" ;
    ns1:solucionaFallo ns1:DosEjesEnDiferentesGruposMultiejeConElMismoCOUNTERIDEnAlgunoDeSusSETs ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el parámetro CONTERID de los ejes implicados para que no compartan la misma entrada de captación." .

ns1:CounterID a ns1:Parametro ;
    rdfs:label "Counter ID" ;
    ns1:textoExtracto "Todos los ejes de un grupo multieje deben tener el parámetro COUNTERID igual." .

ns1:DriveType a ns1:Parametro ;
    rdfs:label "Drive Type" ;
    ns1:textoExtracto "Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos." .

ns1:RevisarLosParametrosMaquina_3df3aee219 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros máquina" ;
    ns1:solucionaFallo ns1:DosEjesEnDiferentesGruposMultiejeConElMismoCOUNTERIDEnAlgunoDeSusSETs,
        ns1:LosEjesDelGrupoMultiaxisTienenQueTenerElMismoDRIVETYPE,
        ns1:LosEjesMaestroYEsclavoDebenTenerElMismoABSFEEDBACK ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina." .

ns1:DosEjesEnDiferentesGruposMultiejeConElMismoANAOUTIDEnAlgunoDeSusSETs a ns1:DiagnosticoFallo ;
    rdfs:label "Dos ejes en diferentes grupos multieje con el mismo ANAOUTID en alguno de sus SETs" ;
    ns1:textoExtracto "'Dos ejes en diferentes grupos multieje con el mismo ANAOUTID en alguno de sus SETs'" .

ns1:LosEjesDelGrupoMultiaxisTienenQueTenerElMismoDRIVETYPE a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes del grupo multiaxis tienen que tener el mismo DRIVETYPE" ;
    ns1:textoExtracto "'Los ejes del grupo multiaxis tienen que tener el mismo DRIVETYPE'" .

ns1:LosEjesMaestroYEsclavoDebenTenerElMismoABSFEEDBACK a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben tener el mismo ABSFEEDBACK" ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben tener el mismo ABSFEEDBACK'" .

ns1:DosEjesEnDiferentesGruposMultiejeConElMismoCOUNTERIDEnAlgunoDeSusSETs a ns1:DiagnosticoFallo ;
    rdfs:label "Dos ejes en diferentes grupos multieje con el mismo COUNTERID en alguno de sus SETs" ;
    ns1:textoExtracto "'Dos ejes en diferentes grupos multieje con el mismo COUNTERID en alguno de sus SETs'" .

