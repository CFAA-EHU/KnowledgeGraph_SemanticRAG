@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConFagorAutomation_98c1273348 a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:NoHayHardwareParaEjesMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:RevisionDeLosParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de los parámetros máquina" ;
    ns1:solucionaFallo ns1:EjesDeUnGrupoMULTIAXISConDiferenteParametroDRIVETYPE ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos." .

ns1:TipoDeControlDelEje a ns1:Parametro ;
    rdfs:label "Tipo de control del eje" ;
    ns1:textoExtracto "Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE." .

ns1:EjesDeUnGrupoMULTIAXISConDiferenteParametroDRIVETYPE a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes de un grupo MULTIAXIS con diferente parámetro DRIVETYPE" ;
    ns1:textoExtracto "Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE." .

ns1:NoHayHardwareParaEjesMechatrolink a ns1:DiagnosticoFallo ;
    rdfs:label "No hay Hardware para ejes Mechatrolink" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No se dispone del hardware necesario para trabajar con ejes Mechatrolink." .

