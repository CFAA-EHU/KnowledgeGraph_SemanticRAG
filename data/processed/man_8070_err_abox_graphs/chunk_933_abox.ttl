@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroMaximoDeEjesYCabezalesSobrepasado a ns1:AvisoSeguridad ;
    rdfs:label "Número máximo de ejes y cabezales sobrepasado" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "'Mechatrolink:Número máximo de ejes y cabezales sobrepasado' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:ReducirNumeroDeReguladoresOUtilizarModoMlinkII a ns1:TareaMantenimiento ;
    rdfs:label "Reducir número de reguladores o utilizar modo Mlink-II" ;
    ns1:solucionaFallo ns1:ConfiguracionMechatrolinkSuperaElMaximoPermitidoDeEjesYCabezales ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de reguladores o utilizar el modo Mlink-II." .

ns1:ConfiguracionMechatrolinkSuperaElMaximoPermitidoDeEjesYCabezales a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración Mechatrolink supera el máximo permitido de ejes y cabezales" ;
    ns1:textoExtracto "La configuración Mechatrolink supera el máximo permitido de ejes y cabezales (servos e inverters)." .

