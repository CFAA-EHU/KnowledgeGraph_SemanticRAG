@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_85863_G8585CFG
    a ex:AvisoSeguridad ;
    rdfs:label "Configuración errónea: valor incorrecto de la variable V.S.G84585CFG"@es ;
    ex:identificador "85863" ;
    ex:textoExtracto "85863 G8585 configuración errónea: valor incorrecto de la variable V.S.G84585CFG=%D. DETECCIÓN Durante la ejecución. CAUSA El valor asignado a la variable no es válido. SOLUCIÓN Revisar la asignación de datos a la variable en la subrutina G8585."@es ;
    ex:mitigaRiesgo ex:Diagnostico_RevisarSubrutinaG8585 .

ex:Diagnostico_RevisarSubrutinaG8585
    a ex:DiagnosticoFallo ;
    rdfs:label "Revisión de asignación de datos en subrutina G8585"@es ;
    ex:textoExtracto "Revisar la asignación de datos a la variable en la subrutina G8585."@es ;
    ex:solucionaFallo ex:Error_85863_G8585CFG .

ex:Error_85870_KINID_TYPE
    a ex:AvisoSeguridad ;
    rdfs:label "Error interno #90 en G8585: KINID=%D, TYPE=%D"@es ;
    ex:identificador "85870" ;
    ex:textoExtracto "85870 Error interno #90 en G8585: KINID=%D, TYPE=%D. DETECCIÓN Durante la ejecución. CAUSA Error en la ejecución de la subrutina G8585, en la cinemática indicada. SOLUCIÓN Revisar la subrutina G8585."@es ;
    ex:mitigaRiesgo ex:Diagnostico_RevisarSubrutinaG8585 .