@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnMaximoDeDosVariablesDRVACadaEje a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un máximo de dos variables DRV a cada eje" ;
    ns1:solucionaFallo ns1:MECHATROLINKIINoSePermitenVariablesYParametrosDRVEnElMismoEje_dc236e5d4f ;
    ns1:textoExtracto "SOLUCIÓN Asignar un máximo de dos variables DRV a cada eje." .

ns1:DefinirSubcomandosQueResuelvenLasVariablesYParametrosEnMechatrolinkIIA32Bytes a ns1:TareaMantenimiento ;
    rdfs:label "Definir subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes" ;
    ns1:solucionaFallo ns1:NoSeAdmitenVariablesOParametrosDRVConMechatrolinkIOMechatrolinkIIA17Bytes_ddb30d3c8c ;
    ns1:textoExtracto "Sólo es posible enviar los subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes." .

ns1:ReducirElNumeroDeReguladoresOUtilizarElModoMlinkIIConUnSlotTimeDe60Microsegundos a ns1:TareaMantenimiento ;
    rdfs:label "Reducir el número de reguladores o utilizar el modo Mlink-II con un slot time de 60 microsegundos" ;
    ns1:solucionaFallo ns1:MECHATROLINKIIMaximo2VariablesDRVPorEje_9034a54a93 ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de reguladores o utilizar el modo Mlink-II con un slot time de 60 microsegundos." .

ns1:RevisarLosParametrosMaquinaParaCompatibilidadDeBusesDigitales a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los parámetros máquina para compatibilidad de buses digitales" ;
    ns1:solucionaFallo ns1:ConEjesMechatrolinkNoSeAdmitenEjesSercos_b9a80c8879 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. • Con bus Sercos, definir en todos los ejes el parámetro MLINK = No y además DRIVETYPE no puede valer 'Mlink'. • Con bus Mechatrolink, definir en todos los ejes el parámetro MLINK distinto de 'no' y además DRIVETYPE no puede valer 'Sercos'." .

ns1:ConEjesMechatrolinkNoSeAdmitenEjesSercos_b9a80c8879 a ns1:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Sercos" ;
    ns1:textoExtracto "'Con ejes Mechatrolink no se admiten ejes Sercos'" .

ns1:MECHATROLINKIIMaximo2VariablesDRVPorEje_9034a54a93 a ns1:DiagnosticoFallo ;
    rdfs:label "MECHATROLINK II:Máximo 2 variables DRV por eje" ;
    ns1:textoExtracto "'MECHATROLINK II:Máximo 2 variables DRV por eje'" .

ns1:MECHATROLINKIINoSePermitenVariablesYParametrosDRVEnElMismoEje_dc236e5d4f a ns1:DiagnosticoFallo ;
    rdfs:label "MECHATROLINK II:No se permiten variables y parámetros DRV en el mismo eje" ;
    ns1:textoExtracto "'MECHATROLINK II:No se permiten variables y parámetros DRV en el mismo eje'" .

ns1:NoSeAdmitenVariablesOParametrosDRVConMechatrolinkIOMechatrolinkIIA17Bytes_ddb30d3c8c a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten variables o parámetros DRV con Mechatrolink I ó Mechatrolink II a 17 bytes" ;
    ns1:textoExtracto "'No se admiten variables o parámetros DRV con Mechatrolink I ó Mechatrolink II a 17 bytes'" .

