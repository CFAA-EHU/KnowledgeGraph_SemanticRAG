@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorE034
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la identificación de la placa CPU" ;
    ex:textoExtracto "E034 Error en la identificación de la placa CPU. Contacte con Fagor Automation." ;
    ex:identificador "E034" .

ex:ErrorE038
    a ex:AvisoSeguridad ;
    rdfs:label "Error de checksum del código" ;
    ex:textoExtracto "E038 Error de checksum del código. El checksum del código de programa cargado no es correcto. Vuelva a cargar el software. Si el problema persiste, es posible que las memorias RAM, FLASH o el código cargado sean defectuosos. Contacte con Fagor Automation." ;
    ex:identificador "E038" .

ex:ErrorE039
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la placa Sercos" ;
    ex:textoExtracto "E039 Error en la placa Sercos ®. Contacte con Fagor Automation." ;
    ex:identificador "E039" .

ex:ErrorE040
    a ex:AvisoSeguridad ;
    rdfs:label "Fallo del clock de la placa del SerCon" ;
    ex:textoExtracto "E040 Fallo del clock de la placa del SerCon ®. Contacte con Fagor Automation." ;
    ex:identificador "E040" .

ex:ErrorE041
    a ex:AvisoSeguridad ;
    rdfs:label "Memoria del SerCon corrompida" ;
    ex:textoExtracto "E041 Memoria del SerCon corrompida. Contacte con Fagor Automation." ;
    ex:identificador "E041" .

ex:ErrorE044
    a ex:AvisoSeguridad ;
    rdfs:label "Sistema de ficheros en flash corrompido" ;
    ex:textoExtracto "E044 Sistema de ficheros en flash corrompido. Contacte con Fagor Automation." ;
    ex:identificador "E044" .

ex:ErrorE045
    a ex:AvisoSeguridad ;
    rdfs:label "Error de lectura de offset de analógicas" ;
    ex:textoExtracto "E045 Error de lectura de offset de analógicas. Contacte con Fagor Automation." ;
    ex:identificador "E045" .

ex:ErrorE046
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la identificación de la placa de ejes" ;
    ex:textoExtracto "E046 Error en la identificación de la placa de ejes. Contacte con Fagor Automation." ;
    ex:identificador "E046" .

ex:ErrorE047
    a ex:AvisoSeguridad ;
    rdfs:label "Identificación de placa de ejes desconocida" ;
    ex:textoExtracto "E047 Identificación de placa de ejes desconocida. Contacte con Fagor Automation." ;
    ex:identificador "E047" .

ex:ErrorE048
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el código de la FPGA" ;
    ex:textoExtracto "E048 Error en el código de la FPGA. El código de la FPGA parece corrompido o no está presente. Pruebe a volver a cargar la versión de software otra vez. Si el problema persiste, es posible que las memorias RAM, FLASH o el código cargado sean defectuosos. Contacte con Fagor Automation." ;
    ex:identificador "E048" .

ex:ErrorE083
    a ex:AvisoSeguridad ;
    rdfs:label "FPGA no cargada" ;
    ex:textoExtracto "E083 La FPGA no se ha podido cargar. Reinicie la contadora. Si el problema persiste, contacte con Fagor Automation." ;
    ex:identificador "E083" .

ex:ErrorE084
    a ex:AvisoSeguridad ;
    rdfs:label "Reset por Watchdog" ;
    ex:textoExtracto "E084 Reset por Watchdog. El sistema se ha reiniciado al saltar la vigilancia por watchdog. Si el problema es repetitivo y/o persiste, contacte con Fagor Automation." ;
    ex:identificador "E084" .

ex:ErrorE085
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la alimentación de las salidas analógicas" ;
    ex:textoExtracto "E085 Error en la alimentación de las salidas analógicas. Contacte con Fagor Automation." ;
    ex:identificador "E085" .

ex:ErrorE133
    a ex:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21A" ;
    ex:textoExtracto "E133 Cable roto, señal A de la captación E21A." ;
    ex:identificador "E133" .

ex:ErrorE233
    a ex:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21B" ;
    ex:textoExtracto "E233 Cable roto, señal A de la captación E21B." ;
    ex:identificador "E233" .

ex:ErrorE333
    a ex:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21C" ;
    ex:textoExtracto "E333 Cable roto, señal A de la captación E21C." ;
    ex:identificador "E333" .

ex:ErrorE433
    a ex:AvisoSeguridad ;
    rdfs:label "Cable roto en señal A de captación E21D" ;
    ex:textoExtracto "E433 Cable roto, señal A de la captación E21D. Para el caso de captación TTL diferencial. El cable de la señal A y/o /A puede estar roto o desconectado. Revisar el conexionado." ;
    ex:identificador "E433" .

ex:SistemaRCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "MÓDULO RCS-S" ;
    ex:activaAlarma ex:ErrorE034, ex:ErrorE038, ex:ErrorE039, ex:ErrorE040, ex:ErrorE041, ex:ErrorE044, ex:ErrorE045, ex:ErrorE046, ex:ErrorE047, ex:ErrorE048, ex:ErrorE083, ex:ErrorE084, ex:ErrorE085, ex:ErrorE133, ex:ErrorE233, ex:ErrorE333, ex:ErrorE433 .