@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_E134 a ex:DiagnosticoFallo ;
    rdfs:label "Cable roto, señal B de la captación E21A"@es ;
    ex:textoExtracto "E134 Cable roto, señal B de la captación E21A."@es ;
    ex:identificador "E134" .

ex:Fallo_E234 a ex:DiagnosticoFallo ;
    rdfs:label "Cable roto, señal B de la captación E21B"@es ;
    ex:textoExtracto "E234 Cable roto, señal B de la captación E21B."@es ;
    ex:identificador "E234" .

ex:Fallo_E334 a ex:DiagnosticoFallo ;
    rdfs:label "Cable roto (sin especificar señal)"@es ;
    ex:textoExtracto "E334"@es ;
    ex:identificador "E334" .

ex:CableSenalA a ex:ComponenteElectrico ;
    rdfs:label "Cable de la señal A"@es ;
    ex:textoExtracto "El cable de la señal A [...] puede estar roto o desconectado."@es .

ex:CableSenalA_Negada a ex:ComponenteElectrico ;
    rdfs:label "Cable de la señal /A"@es ;
    ex:textoExtracto "El cable de la señal [...] /A puede estar roto o desconectado."@es .

ex:Tarea_RevisionConexionado a ex:TareaMantenimiento ;
    rdfs:label "Revisión del conexionado de cables"@es ;
    ex:textoExtracto "Revisar el conexionado."@es .

ex:Tarea_RevisionSenalesCaptador a ex:TareaMantenimiento ;
    rdfs:label "Revisión de nivel de señales del captador"@es ;
    ex:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador."@es .

ex:Captador_E21A a ex:Sensor ;
    rdfs:label "Captador E21A"@es ;
    ex:identificador "E21A" ;
    ex:textoExtracto "señal B de la captación E21A"@es .

ex:Captador_E21B a ex:Sensor ;
    rdfs:label "Captador E21B"@es ;
    ex:identificador "E21B" ;
    ex:textoExtracto "señal B de la captación E21B"@es .

ex:Fallo_E134 ex:solucionaFallo ex:Tarea_RevisionConexionado .
ex:Fallo_E234 ex:solucionaFallo ex:Tarea_RevisionConexionado .
ex:Fallo_E134 ex:solucionaFallo ex:Tarea_RevisionSenalesCaptador .
ex:Fallo_E234 ex:solucionaFallo ex:Tarea_RevisionSenalesCaptador .
ex:Captador_E21A ex:monitoreaParametro ex:CableSenalA .
ex:Captador_E21B ex:monitoreaParametro ex:CableSenalA_Negada .