@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3ae598dac8 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de incompatibilidad COUNTERTYPE remoto y COUNTERID 0" ;
    ns1:mitigaRiesgo ns1:EnvioDeSubcomandosQueResuelvenVariablesYParametrosEnMechatrolinkIIA32Bytes ;
    ns1:textoExtracto "'COUNTERTYPE remoto y COUNTERID 0 incompatibles' DETECCIÓN Durante la validación de los parámetros máquina o el arranque" .

ns1:ConfiguracionDelBusMechatrolinkII a ns1:Parametro ;
    rdfs:label "Configuración del bus Mechatrolink II" ;
    ns1:textoExtracto "Para poder acceder a las variables y parámetros del regulador (DRV) hay que configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)." .

ns1:IncompatibilidadCOUNTERTYPERemotoYCOUNTERID0 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad COUNTERTYPE remoto y COUNTERID 0" ;
    ns1:textoExtracto "'COUNTERTYPE remoto y COUNTERID 0 incompatibles' DETECCIÓN Durante la validación de los parámetros máquina o el arranque" .

ns1:TamanoDeDatosDelBus a ns1:Parametro ;
    rdfs:label "Tamaño de datos del bus" ;
    ns1:textoExtracto "Para poder acceder a las variables y parámetros del regulador (DRV) hay que configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)." .

ns1:EnvioDeSubcomandosQueResuelvenVariablesYParametrosEnMechatrolinkIIA32Bytes a ns1:AccionProhibida ;
    rdfs:label "Envío de subcomandos que resuelven variables y parámetros en Mechatrolink II a 32 bytes" ;
    ns1:textoExtracto "CAUSA Sólo es posible enviar los subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes." .

