@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiarElTipoDeCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar el tipo de captación" ;
    ns1:solucionaFallo ns1:ElEjeDebeTenerElMismoTipoDeCaptacionEnTodasLasGamas ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el tipo de captación en los sets diferentes." .

ns1:DireccionLogicaDelRegulador_4c7a1a8579 a ns1:Parametro ;
    rdfs:label "dirección lógica del regulador" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "el parámetro COUNTERID no puede valor 0 (cero)" .

ns1:ParametrosMaquinaIncompatibles_df960b2ec3 a ns1:DiagnosticoFallo ;
    rdfs:label "'Parámetros máquina incompatibles'" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:RevisarParametrosMaquina_c53e9d3f88 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros máquina" ;
    ns1:solucionaFallo ns1:COUNTERTYPERemotoYCOUNTERID0Incompatibles ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina." .

ns1:TipoDeCaptacion_ca0a799e3c a ns1:Parametro ;
    rdfs:label "tipo de captación" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "'COUNTERTYPE remoto y COUNTERID 0 incompatibles'" .

ns1:TipoDeRegulador a ns1:Parametro ;
    rdfs:label "tipo de regulador" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "Comprobar el tipo de regulador definido en los parámetros máquina (parámetro DRIVETYPE)." .

ns1:UtilizarReguladoresMechatrolink a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar reguladores Mechatrolink" ;
    ns1:solucionaFallo ns1:HardwareMechatrolinkNoEsCompatibleConEjesSercos ;
    ns1:textoExtracto "SOLUCIÓN Utilizar reguladores Mechatrolink." .

ns1:UtilizarReguladoresSercos a ns1:TareaMantenimiento ;
    rdfs:label "Utilizar reguladores Sercos" ;
    ns1:solucionaFallo ns1:HardwareSercosNoEsCompatibleConEjesMechatrolink ;
    ns1:textoExtracto "SOLUCIÓN Utilizar reguladores Sercos." .

ns1:COUNTERTYPERemotoYCOUNTERID0Incompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "'COUNTERTYPE remoto y COUNTERID 0 incompatibles'" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:ElEjeDebeTenerElMismoTipoDeCaptacionEnTodasLasGamas a ns1:DiagnosticoFallo ;
    rdfs:label "'El eje debe tener el mismo tipo de captación en todas las gamas'" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:HardwareMechatrolinkNoEsCompatibleConEjesSercos a ns1:DiagnosticoFallo ;
    rdfs:label "'Hardware Mechatrolink no es compatible con ejes Sercos'" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC." .

ns1:HardwareSercosNoEsCompatibleConEjesMechatrolink a ns1:DiagnosticoFallo ;
