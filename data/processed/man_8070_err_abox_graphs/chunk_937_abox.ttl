@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularUnoDeLosDos a ns1:AccionProhibida ;
    rdfs:label "Anular uno de los dos" ;
    ns1:solucionaFallo ns1:ParametrosMaquinaIncompatibles ;
    ns1:textoExtracto "SOLUCIÓN Anular uno de los dos" .

ns1:CambiarElTipoDeCaptacionEnLosSetsDiferentes a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar el tipo de captación en los sets diferentes" ;
    ns1:solucionaFallo ns1:ParametrosMaquinaIncompatibles ;
    ns1:textoExtracto "SOLUCIÓN Cambiar el tipo de captación en los sets diferentes." .

ns1:ParametrosMaquinaIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetros máquina incompatibles" ;
    ns1:textoExtracto "'Parámetros máquina incompatibles'" .

