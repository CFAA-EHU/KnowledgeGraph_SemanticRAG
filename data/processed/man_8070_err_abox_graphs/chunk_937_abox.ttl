@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_E138
    a ex:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21A"@es ;
    ex:textoExtracto "E138 Alarma de amplitud en captación E21A."@es ;
    ex:identificador "E138" .

ex:alarma_E238
    a ex:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21B"@es ;
    ex:textoExtracto "E238 Alarma de amplitud en captación E21B."@es ;
    ex:identificador "E238" .

ex:alarma_E338
    a ex:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21C"@es ;
    ex:textoExtracto "E338 Alarma de amplitud en captación E21C."@es ;
    ex:identificador "E338" .

ex:alarma_E438
    a ex:Alarma ;
    rdfs:label "Alarma de amplitud en captación E21D"@es ;
    ex:textoExtracto "E438 Alarma de amplitud en captación E21D."@es ;
    ex:identificador "E438" .

ex:encoder_RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder del módulo RCS-S"@es ;
    ex:textoExtracto "Revise la documentación del encoder para determinar el origen de la alarma."@es ;
    ex:activaAlarma ex:alarma_E138, ex:alarma_E238, ex:alarma_E338, ex:alarma_E438 .

ex:captador_Sercos
    a ex:Sensor ;
    rdfs:label "Captador de la contadora Sercos"@es ;
    ex:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema."@es .

ex:se_al_A
    a ex:Parametro ;
    rdfs:label "Señal A del encoder"@es ;
    ex:textoExtracto "Excesiva atenuación o saturación de las señales A y/o B."@es ;
    ex:monitoreaParametro ex:encoder_RCS_S .

ex:se_al_B
    a ex:Parametro ;
    rdfs:label "Señal B del encoder"@es ;
    ex:textoExtracto "Excesiva atenuación o saturación de las señales A y/o B."@es ;
    ex:monitoreaParametro ex:encoder_RCS_S .