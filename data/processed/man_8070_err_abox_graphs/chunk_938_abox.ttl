@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularUnoDeLosDosParametrosMencionadosEnElMensajeDeError a ns1:AccionProhibida ;
    rdfs:label "Anular uno de los dos parámetros mencionados en el mensaje de error" ;
    ns1:textoExtracto "SOLUCIÓN Anular uno de los dos parámetros mencionados en el mensaje de error." .

ns1:MemoriaInsuficiente_6b413e4842 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente" ;
    ns1:textoExtracto "9338 Memoria insuficiente. Reducir el valor del parámetro." .

ns1:ParametroHBLS a ns1:Parametro ;
    rdfs:label "Parámetro HBLS" ;
    ns1:textoExtracto "los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie." .

ns1:ParametroMODBUSSVRRS a ns1:Parametro ;
    rdfs:label "Parámetro MODBUSSVRRS" ;
    ns1:textoExtracto "los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie." .

ns1:Parametro_698ce05606 a ns1:Parametro ;
    rdfs:label "Parámetro máquina LOOPTIME" ;
    ns1:textoExtracto "Asignar al parámetro máquina LOOPTIME un valor igual o inferior a 8 ms" .

ns1:ReducirElValorDelParametro a ns1:AccionProhibida ;
    rdfs:label "Reducir el valor del parámetro" ;
    ns1:textoExtracto "SOLUCIÓN Reducir el valor del parámetro." .

ns1:SercosPosicionNoFuncionaConLOOPTIMESuperiorA8Ms a ns1:DiagnosticoFallo ;
    rdfs:label "Sercos posición no funciona con LOOPTIME superior a 8 ms" ;
    ns1:textoExtracto "9337 Sercos posición no funciona con LOOPTIME superior a 8 ms." .

