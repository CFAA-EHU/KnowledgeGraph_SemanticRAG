@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_RCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "MÓDULO RCS-S" ;
    ex:tieneComponente ex:Captacion_E21A, ex:Captacion_E21B, ex:Captacion_E21C, ex:Captacion_E21D ;
    ex:tieneComponente ex:Contadora_Sercos ;
    ex:activaAlarma ex:Alarma_E438, ex:Alarma_E140, ex:Alarma_E240, ex:Alarma_E340, ex:Alarma_E440,
                   ex:Alarma_E141, ex:Alarma_E241, ex:Alarma_E341, ex:Alarma_E441,
                   ex:Alarma_E142, ex:Alarma_E242, ex:Alarma_E342, ex:Alarma_E442 .

ex:Contadora_Sercos
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora Sercos" ;
    ex:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema" ;
    ex:monitoreaParametro ex:Parametro_Amplitud, ex:Parametro_FrecuenciaContaje, ex:Parametro_DistanciaI0, ex:Parametro_Corriente .

ex:Captacion_E21A
    a ex:ComponenteElectrico ;
    ex:identificador "E21A" ;
    rdfs:label "Captación E21A" ;
    ex:textoExtracto "Frecuencia de contaje excesiva en captación E21A. Distancia incorrecta entre I0 en captación E21A. Sobrecorriente o cortocircuito en captación E21A" .

ex:Captacion_E21B
    a ex:ComponenteElectrico ;
    ex:identificador "E21B" ;
    rdfs:label "Captación E21B" ;
    ex:textoExtracto "Frecuencia de contaje excesiva en captación E21B. Distancia incorrecta entre I0 en captación E21B. Sobrecorriente o cortocircuito en captación E21B" .

ex:Captacion_E21C
    a ex:ComponenteElectrico ;
    ex:identificador "E21C" ;
    rdfs:label "Captación E21C" ;
    ex:textoExtracto "Frecuencia de contaje excesiva en captación E21C. Distancia incorrecta entre I0 en captación E21C. Sobrecorriente o cortocircuito en captación E21C" .

ex:Captacion_E21D
    a ex:ComponenteElectrico ;
    ex:identificador "E21D" ;
    rdfs:label "Captación E21D" ;
    ex:textoExtracto "E438 Alarma de amplitud en captación E21D. Excesiva atenuación o saturación de las señales A y/o B. Frecuencia de contaje excesiva en captación E21D. Distancia incorrecta entre I0 en captación E21D. Sobrecorriente o cortocircuito en captación E21D" .

ex:Alarma_E438
    a ex:Alarma ;
    ex:identificador "E438" ;
    rdfs:label "Alarma de amplitud en captación E21D" ;
    ex:textoExtracto "E438 Alarma de amplitud en captación E21D. Excesiva atenuación o saturación de las señales A y/o B. El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema" ;
    ex:mitigaRiesgo ex:AvisoSeguridad_RevisarCableado .

ex:Alarma_E140
    a ex:Alarma ;
    ex:identificador "E140" ;
    rdfs:label "Frecuencia de contaje excesiva en captación E21A" ;
    ex:textoExtracto "E140 Frecuencia de contaje excesiva en captación E21A. La velocidad del movimiento del eje excede la capacidad de muestreo del hardware de la contadora Sercos para ese tipo de señal del encoder" .

ex:Alarma_E240
    a ex:Alarma ;
    ex:identificador "E240" ;
    rdfs:label "Frecuencia de contaje excesiva en captación E21B" ;
    ex:textoExtracto "E240 Frecuencia de contaje excesiva en captación E21B" .

ex:Alarma_E340
    a ex:Alarma ;
    ex:identificador "E340" ;
    rdfs:label "Frecuencia de contaje excesiva en captación E21C" ;
    ex:textoExtracto "E340 Frecuencia de contaje excesiva en captación E21C" .

ex:Alarma_E440
    a ex:Alarma ;
    ex:identificador "E440" ;
    rdfs:label "Frecuencia de contaje excesiva en captación E21D" ;
    ex:textoExtracto "E440 Frecuencia de contaje excesiva en captación E21D" .

ex:Alarma_E141
    a ex:Alarma ;
    ex:identificador "E141" ;
    rdfs:label "Distancia incorrecta entre I0 en captación E21A" ;
    ex:textoExtracto "E141 Distancia incorrecta entre I0 en captación E21A. Error indicativo de no repetitividad de la señal de I0 en cada vuelta del encoder. Se está produciendo una pérdida de impulsos y/o la medida dada por el captador es errónea" .

ex:Alarma_E241
    a ex:Alarma ;
    ex:identificador "E241" ;
    rdfs:label "Distancia incorrecta entre I0 en captación E21B" ;
    ex:textoExtracto "E241 Distancia incorrecta entre I0 en captación E21B" .

ex:Alarma_E341
    a ex:Alarma ;
    ex:identificador "E341" ;
    rdfs:label "Distancia incorrecta entre I0 en captación E21C" ;
    ex:textoExtracto "E341 Distancia incorrecta entre I0 en captación E21C" .

ex:Alarma_E441
    a ex:Alarma ;
    ex:identificador "E441" ;
    rdfs:label "Distancia incorrecta entre I0 en captación E21D" ;
    ex:textoExtracto "E441 Distancia incorrecta entre I0 en captación E21D" .

ex:Alarma_E142
    a ex:Alarma ;
    ex:identificador "E142" ;
    rdfs:label "Sobrecorriente o cortocircuito en captación E21A" ;
    ex:textoExtracto "E142 Sobrecorriente o cortocircuito en captación E21A. Se ha producido un cortocircuito o se está sobrealimentando el captador" .

ex:Alarma_E242
    a ex:Alarma ;
    ex:identificador "E242" ;
    rdfs:label "Sobrecorriente o cortocircuito en captación E21B" ;
    ex:textoExtracto "E242 Sobrecorriente o cortocircuito en captación E21B" .

ex:Alarma_E342
    a ex:Alarma ;
    ex:identificador "E342" ;
    rdfs:label "Sobrecorriente o cortocircuito en captación E21C" ;
    ex:textoExtracto "E342 Sobrecorriente o cortocircuito en captación E21C" .

ex:Alarma_E442
    a ex:Alarma ;
    ex:identificador "E442" ;
    rdfs:label "Sobrecorriente o cortocircuito en captación E21D" ;
    ex:textoExtracto "E442 Sobrecorriente o cortocircuito en captación E21D" .

ex:Parametro_Amplitud
    a ex:Parametro ;
    rdfs:label "Amplitud de señal" ;
    ex:textoExtracto "Excesiva atenuación o saturación de las señales A y/o B" ;
    ex:valor "Excesiva"@es .

ex:Parametro_FrecuenciaContaje
    a ex:Parametro ;
    rdfs:label "Frecuencia de contaje" ;
    ex:textoExtracto "Frecuencia de contaje excesiva" ;
    ex:valor "Excesiva"@es .

ex:Parametro_DistanciaI0
    a ex:Parametro ;
    rdfs:label "Distancia entre I0" ;
    ex:textoExtracto "Distancia incorrecta entre I0" ;
    ex:valor "Incorrecta"@es .

ex:Parametro_Corriente
    a ex:Parametro ;
    rdfs:label "Corriente del captador" ;
    ex:textoExtracto "Sobrecorriente o cortocircuito" ;
    ex:valor "Sobrecorriente/Cortocircuito"@es .

ex:AvisoSeguridad_RevisarCableado
    a ex:AvisoSeguridad ;
    rdfs:label "Revisar estado del cableado, conexionado y captador" ;
    ex:textoExtracto "Revise el estado del cable, del conexionado y del captador. Si el problema persiste, contacte con Fagor Automation" .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "contacte con Fagor Automation" .