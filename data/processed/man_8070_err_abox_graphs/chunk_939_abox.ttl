ns1:ContadoraSercosSetsConIgualCOUNTERIDDebenTenerIgualParametroS a ns1:DiagnosticoFallo ;
    rdfs:label "Contadora Sercos: sets con igual COUNTERID deben tener igual parámetro(s)" ;
    ns1:textoExtracto "9340 Contadora Sercos: sets con igual COUNTERID deben tener igual el\\los parámetro(s):" .

ns1:NumeroDePuntos_04f759c7f3 a ns1:Parametro ;
    rdfs:label "Número de puntos" ;
    ns1:parametroMonitoradoPor ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "parámetro NPOINTS de Fagor > Diagnosis." .

ns1:ReducirValorDelParametroMaquinaNPOINTS a ns1:TareaMantenimiento ;
    rdfs:label "Reducir valor del parámetro máquina NPOINTS" ;
    ns1:solucionaFallo ns1:NoSeHaPodidoAlocarLaMemoriaParaElNumeroDePuntosIndicadosPorElParametroNPOINTS ;
    ns1:textoExtracto "SOLUCIÓN Reducir el valor de parámetro máquina NPOINTS de Fagor > Diagnosis." .

ns1:ReducirValorDelParametroSWTDELAYOAumentarElTiempoDeCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Reducir valor del parámetro SWTDELAY o aumentar el tiempo de ciclo" ;
    ns1:solucionaFallo ns1:NoSeAdmiteUnSWTDELAYTanGrandeConLOOPTIMEActual ;
    ns1:textoExtracto "SOLUCIÓN Reducir el valor de parámetro SWTDELAY o aumentar el tiempo de ciclo." .

ns1:TiempoDeRetardoDeConmutacion a ns1:Parametro ;
    rdfs:label "Tiempo de retardo de conmutación" ;
    ns1:parametroMonitoradoPor ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "El valor de SWTDELAY es demasiado grande para el tiempo de ciclo definido." .

ns1:NoSeAdmiteUnSWTDELAYTanGrandeConLOOPTIMEActual a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite un SWTDELAY tan grande con LOOPTIME actual" ;
    ns1:textoExtracto "9340 No se admite un SWTDELAY tan grande con LOOPTIME actual." .

ns1:NoSeHaPodidoAlocarLaMemoriaParaElNumeroDePuntosIndicadosPorElParametroNPOINTS a ns1:DiagnosticoFallo ;
