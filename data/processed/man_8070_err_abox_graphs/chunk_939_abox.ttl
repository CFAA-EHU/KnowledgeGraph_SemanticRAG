@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorE143
    a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21A"@es ;
    ex:identificador "E143" ;
    ex:textoExtracto "E143 Error de comunicación en captación E21A. CRC incorrecto."@es .

ex:ErrorE243
    a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21B"@es ;
    ex:identificador "E243" ;
    ex:textoExtracto "E243 Error de comunicación en captación E21B. CRC incorrecto."@es .

ex:ErrorE343
    a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21C"@es ;
    ex:identificador "E343" ;
    ex:textoExtracto "E343 Error de comunicación en captación E21C. CRC incorrecto."@es .

ex:TareaRevisarCables
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar cables y conexiones"@es ;
    ex:textoExtracto "Revisar cables y conexiones."@es ;
    ex:mitigaRiesgo ex:ErrorE143, ex:ErrorE243, ex:ErrorE343 .