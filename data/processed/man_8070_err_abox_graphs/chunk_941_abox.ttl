@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnValorDeOffsetDentroDelRangoPermitido a ns1:TareaMantenimiento ;
    rdfs:label "Asignar un valor de offset dentro del rango permitido" ;
    ns1:textoExtracto "Asignar a la variable V.MPK.OFTDATAkin[nb] de la cinemática un valor que esté comprendido entre \"- MAX OFFSET\" y \"+ MAX OFFSET\"." .

ns1:CompartirLaMismaSalidaAnalogicaEnDosSetsActivos a ns1:AccionProhibida ;
    rdfs:label "Compartir la misma salida analógica en dos sets activos" ;
    ns1:textoExtracto "Dos set activos no pueden compartir la misma salida analógica." .

ns1:ConfigurarUnaSalidaAnalogicaDiferenteEnElSetOActivarUnSetDiferente a ns1:TareaMantenimiento ;
    rdfs:label "Configurar una salida analógica diferente en el set o activar un set diferente" ;
    ns1:textoExtracto "Activar un set diferente en algún eje o configurar una salida analógica diferente en el set." .

ns1:DefinirLasVariablesDRVConDiferenteMnemonico a ns1:TareaMantenimiento ;
    rdfs:label "Definir las variables DRV con diferente mnemónico" ;
    ns1:textoExtracto "Definir las variables DRV con diferente mnemónico." .

ns1:DefinirLasVariablesDRVConElMismoMnemonicoSiTienenElMismoIdentificador a ns1:TareaMantenimiento ;
    rdfs:label "Definir las variables DRV con el mismo mnemónico si tienen el mismo identificador" ;
    ns1:textoExtracto "Las variables DRV con el mismo identificador deben tener el mismo mnemónico." .

ns1:DefinirOffsetDeCinematicaFueraDelRangoPermitido a ns1:AccionProhibida ;
    rdfs:label "Definir offset de cinemática fuera del rango permitido" ;
    ns1:textoExtracto "El offset definido para la cinemática está fuera del rango permitido por el parámetro máquina." .

ns1:DefinirUnaVariableDRVYaExistente a ns1:AccionProhibida ;
    rdfs:label "Definir una variable DRV ya existente" ;
    ns1:textoExtracto "La variable DRV ya existe en los parámetros máquina OEM." .

ns1:DefinirVariablesDRVConElMismoIdentificadorPeroDiferenteModo a ns1:AccionProhibida ;
    rdfs:label "Definir variables DRV con el mismo identificador pero diferente modo" ;
    ns1:textoExtracto "MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE." .

ns1:DefinirVariablesDRVConElMismoIdentificadorYTipoDeAccesoPeroDiferenteMnemonico a ns1:AccionProhibida ;
    rdfs:label "Definir variables DRV con el mismo identificador y tipo de acceso pero diferente mnemónico" ;
    ns1:textoExtracto "En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID) y del mismo tipo de acceso (TYPE), pero diferente mnemónico." .

ns1:DefinirVariablesDRVConElMismoMnemonicoEnDiferentesEjesONodos a ns1:AccionProhibida ;
    rdfs:label "Definir variables DRV con el mismo mnemónico en diferentes ejes o nodos" ;
    ns1:textoExtracto "Dos variables diferentes no pueden tener el mismo mnemónico." .

ns1:RevisarLaDefinicionDeLaVariableDRV a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la definición de la variable DRV" ;
    ns1:textoExtracto "Revisar la definición de la variable." .

ns1:SalidaAnalogicaDeUnModuloRCSS a ns1:Parametro ;
    rdfs:label "Salida analógica de un módulo RCS-S" ;
    ns1:identificador "ANAUOTID" ;
    ns1:textoExtracto "El set activo en varios ejes está utilizando la misma salida analógica de un módulo RCS-S (parámetro ANAUOTID)." .

