@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_70c5415020 a ns1:AccionProhibida ;
    rdfs:label "Acción prohibida de diferentes MODE para variables DRV" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_ef5c72213c ;
    ns1:textoExtracto "Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE." .

ns1:ParametrosMaquinaOEM a ns1:Parametro ;
    rdfs:label "Parámetros máquina OEM" ;
    ns1:textoExtracto "En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID)," .

ns1:VariablesDRVConIgualIDYDiferenteMNEMONIC a ns1:DiagnosticoFallo ;
    rdfs:label "Variables DRV con igual ID y diferente MNEMÓNIC" ;
    ns1:textoExtracto "9346 MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE." .

ns1:AvisoSeguridad_ef5c72213c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para variables DRV con identificadores iguales" ;
    ns1:textoExtracto "Las variables DRV con el mismo identificador deben tener el mismo mnemónico." .

