ex:Diagnostico_SenalBaja_Inductosyn
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Diagnóstico: Señal incremental demasiado baja en transductor Inductosyn/Resolver" ;
    ex:textoExtracto       "Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo. Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." ;
    ex:solucionaFallo      ex:Modulo_ABSIND ;
    ex:solucionaFallo      ex:Cable_ABSIND_Transductor .

ex:Diagnostico_SenalAlta_Inductosyn
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Diagnóstico: Señal incremental demasiado alta en transductor Inductosyn/Resolver" ;
    ex:textoExtracto       "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto. Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." ;
    ex:solucionaFallo      ex:Modulo_ABSIND ;
    ex:solucionaFallo      ex:Cable_ABSIND_Transductor .

ex:Empresa_FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation" ;
    ex:textoExtracto "Si el problema persiste, contacte con Fagor Automation." .