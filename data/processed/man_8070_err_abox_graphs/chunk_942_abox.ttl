@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_ABSIND
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Módulo ABSIND" ;
    ex:textoExtracto       "ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación." ;
    ex:monitoreaParametro  ex:Parametro_Ganancia_ABSIND ;
    ex:monitoreaParametro  ex:Parametro_Fase_ABSIND ;
    ex:tieneComponente     ex:Cable_ABSIND_Transductor .

ex:Contadora_Sercos
    a               ex:ComponenteElectrico ;
    rdfs:label      "Contadora Sercos" ;
    ex:textoExtracto "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación." .

ex:Transductor_InductosynResolver
    a               ex:Sensor ;
    rdfs:label      "Transductor Inductosyn/Resolver" ;
    ex:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo. [...] Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ex:Cable_ABSIND_Transductor
    a               ex:ComponenteElectrico ;
    rdfs:label      "Cable entre módulo ABSIND y transductor" ;
    ex:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ex:Parametro_Ganancia_ABSIND
    a               ex:Parametro ;
    rdfs:label      "Ganancia del módulo ABSIND" ;
    ex:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ex:Parametro_Fase_ABSIND
    a               ex:Parametro ;
    rdfs:label      "Fase del módulo ABSIND" ;
    ex:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ex:Alarma_E183
    a               ex:Alarma ;
    ex:identificador "E183" ;
    rdfs:label      "INDUCTOSYN: INC signal too-low en captación E21A" ;
    ex:textoExtracto "E183 INDUCTOSYN: INC signal too-low en captación E21A." ;
    ex:activaAlarma  ex:Modulo_ABSIND .

