ns1:CNC8070_93f6a8a259 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." .

ns1:CorregirParametrosMaquina a ns1:TareaMantenimiento ;
