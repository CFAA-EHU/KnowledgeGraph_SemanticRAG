ns1:ParametroDEFAULTSET a ns1:Parametro ;
    rdfs:label "Parámetro DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:ParametroVCOMPAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPAXIS" ;
    ns1:textoExtracto "En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

ns1:ParametroVMOVAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VMOVAXIS" ;
    ns1:textoExtracto "En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

ns1:RevisarConexiones_3f2bf94a9f a ns1:TareaMantenimiento ;
