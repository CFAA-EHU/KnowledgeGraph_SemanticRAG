@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_RCS_S
    a                       ex:Sistema ;
    rdfs:label              "Módulo RCS-S" ;
    ex:textoExtracto         "MÓDULO RCS-S" ;
    ex:tieneComponente       ex:Modulo_ABSIND ;
    ex:tieneComponente       ex:Transductor_E21A , ex:Transductor_E21B , ex:Transductor_E21C , ex:Transductor_E21D ;
    ex:tieneComponente       ex:Cable_E21A , ex:Cable_E21B , ex:Cable_E21C , ex:Cable_E21D .

ex:Modulo_ABSIND
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Módulo ABSIND" ;
    ex:textoExtracto         "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. [...] Comprobar el ajuste de ganancia y de fase del módulo ABSIND con el software de ajuste." ;
    ex:monitoreaParametro    ex:Parametro_Ganancia , ex:Parametro_Fase ;
    ex:controla             ex:Transductor_E21A , ex:Transductor_E21B , ex:Transductor_E21C , ex:Transductor_E21D .

ex:Transductor_E21A
    a                       ex:Sensor ;
    rdfs:label              "Transductor INDUCTOSYN E21A" ;
    ex:identificador         "E21A" ;
    ex:textoExtracto         "E186 INDUCTOSYN: Transductor no estable en Power-ON en captación E21A. [...] E187 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21A." ;
    ex:monitoreaParametro    ex:Parametro_Senal_GRAY .

ex:Transductor_E21B
    a                       ex:Sensor ;
    rdfs:label              "Transductor INDUCTOSYN E21B" ;
    ex:identificador         "E21B" ;
    ex:textoExtracto         "E21B. E385 INDUCTOSYN: GRAY signal absent en captación E21B. [...] E286 INDUCTOSYN: Transductor no estable en Power-ON en captación E21B. [...] E287 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21B." ;
    ex:monitoreaParametro    ex:Parametro_Senal_GRAY .

ex:Transductor_E21C
    a                       ex:Sensor ;
    rdfs:label              "Transductor INDUCTOSYN E21C" ;
    ex:identificador         "E21C" ;
    ex:textoExtracto         "E21C. E485 INDUCTOSYN: GRAY signal absent en captación E21C. [...] E386 INDUCTOSYN: Transductor no estable en Power-ON en captación E21C. [...] E387 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21C." ;
    ex:monitoreaParametro    ex:Parametro_Senal_GRAY .

ex:Transductor_E21D
    a                       ex:Sensor ;
    rdfs:label              "Transductor INDUCTOSYN E21D" ;
    ex:identificador         "E21D" ;
    ex:textoExtracto         "E21D. Nivel de la señal GRAY del transductor inductosyn/resolver ausente. [...] E486 INDUCTOSYN: Transductor no estable en Power-ON en captación E21D. [...] E487 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21D." ;
    ex:monitoreaParametro    ex:Parametro_Senal_GRAY .

ex:Cable_E21A
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Cable de conexión E21A (ABSIND-Transductor)" ;
    ex:textoExtracto         "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver [E21A]." .

ex:Cable_E21B
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Cable de conexión E21B (ABSIND-Transductor)" ;
    ex:textoExtracto         "pruebe a sustituir [...] el cable asociado a esa captación [E21B]." .

ex:Cable_E21C
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Cable de conexión E21C (ABSIND-Transductor)" ;
    ex:textoExtracto         "pruebe a sustituir [...] el cable asociado a esa captación [E21C]." .

ex:Cable_E21D
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Cable de conexión E21D (ABSIND-Transductor)" ;
    ex:textoExtracto         "pruebe a sustituir [...] el cable asociado a esa captación [E21D]." .

ex:Parametro_Senal_GRAY
    a                       ex:Parametro ;
    rdfs:label              "Señal GRAY del transductor INDUCTOSYN" ;
    ex:textoExtracto         "Nivel de la señal GRAY del transductor inductosyn/resolver ausente." .

ex:Parametro_Ganancia
    a                       ex:Parametro ;
    rdfs:label              "Ganancia del módulo ABSIND" ;
    ex:textoExtracto         "Comprobar los valores de la ganancia [...] del módulo ABSIND." .

ex:Parametro_Fase
    a                       ex:Parametro ;
    rdfs:label              "Fase del módulo ABSIND" ;
    ex:textoExtracto         "Comprobar los valores de [...] la fase del módulo ABSIND." .

ex:Empresa_FagorAutomation
    a                       ex:Empresa ;
    rdfs:label              "Fagor Automation" ;
    ex:textoExtracto         "Si el error persiste, contacte con Fagor Automation." .