@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DEFAULTSETIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "DEFAULTSET incorrecto" ;
    ns1:solucionadoPor ns1:RevisarConexiones ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:Parametro_968c5b1cdb a ns1:Parametro ;
    rdfs:label "CAXSET" ;
    ns1:identificador "CAXSET" ;
    ns1:textoExtracto "9352 CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_ed76f1d97d a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina." .

ns1:RevisarConexiones a ns1:TareaMantenimiento ;
    rdfs:label "Revisar conexiones" ;
    ns1:solucionaFallo ns1:ValorIncorrectoDeDEFAULTSET ;
    ns1:textoExtracto "SOLUCIÓN Revisar las conexiones. 9351 DEFAULTSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:ValorIncorrectoDeDEFAULTSET a ns1:AccionProhibida ;
    rdfs:label "Valor incorrecto de DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

