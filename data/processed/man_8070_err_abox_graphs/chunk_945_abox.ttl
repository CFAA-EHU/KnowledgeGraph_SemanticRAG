@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeLaCompensacionDelHusillo a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de la compensación del husillo" ;
    ns1:solucionaFallo ns1:Error9356 ;
    ns1:textoExtracto "Asignar al eje una única compensación de husillo." .

ns1:CorreccionDelEjeCOMPAXIS a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del eje COMPAXIS" ;
    ns1:solucionaFallo ns1:Error9357,
        ns1:Error9358 ;
    ns1:textoExtracto "Asignar a COMPTABLEID un valor adecuado." .

ns1:CorreccionDelParametroOPMODE a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del parámetro OPMODE" ;
    ns1:solucionaFallo ns1:Error9355 ;
    ns1:textoExtracto "El parámetro OPMODE debe ser igual en ambos ejes." .

ns1:CorreccionDelValorDEFAULTSET a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del valor DEFAULTSET" ;
    ns1:solucionaFallo ns1:Error9352,
        ns1:Error9353 ;
    ns1:textoExtracto "El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:ParametroDEFAULTSET a ns1:Parametro ;
    rdfs:label "Parámetro DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:Error9352 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9352" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:Error9353 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9353" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:Error9355 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9355" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En un eje gantry, el eje maestro y esclavo no tiene el parámetro OPMODE igual." .

ns1:Error9356 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9356" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay asignadas dos compensaciones de husillo iguales (parámetros MOVAXIS y COMPAXIS iguales) a un mismo eje." .

ns1:Error9357 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9357" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje tiene asignada una compensación cuyo eje compensado no coincide con el eje." .

ns1:Error9358 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9358" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe." .

