@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarValorAdecuadoACOMPTABLEID a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor adecuado a COMPTABLEID" ;
    ns1:solucionaFallo ns1:CompensacionNoDefinida ;
    ns1:textoExtracto "SOLUCIÓN Asignar a COMPTABLEID un valor adecuado." .

ns1:AsignarValorExistenteACOMPTABLEID a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor existente a COMPTABLEID" ;
    ns1:solucionaFallo ns1:CompensacionNoDefinida ;
    ns1:textoExtracto "SOLUCIÓN Asignar a COMPTABLEID un valor que exista." .

ns1:CompensacionNoDefinida_f748bb0830 a ns1:Parametro ;
    rdfs:label "Compensación no definida" ;
    ns1:identificador "COMPTABLEID" ;
    ns1:textoExtracto "El parámetro COMPTABLEID tiene un valor que ya no existe." .

ns1:NoEsPosibleValidarParametrosDeUnEjeConUnCambioDeGamaEnProceso a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible validar parámetros de un eje con un cambio de gama en proceso" ;
    ns1:textoExtracto "9360 No es posible validar parámetros de un eje con un cambio de gama en proceso." .

ns1:ValidacionDeParametrosDuranteCambioDeGama a ns1:AccionProhibida ;
    rdfs:label "Validación de parámetros durante cambio de gama" ;
    ns1:textoExtracto "No es posible validar parámetros de un eje con un cambio de gama en proceso." .

ns1:CompensacionNoDefinida a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación no definida" ;
    ns1:textoExtracto "9358 Compensación no definida." .

