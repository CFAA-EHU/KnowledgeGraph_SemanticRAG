@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorE193
    a ex:AvisoSeguridad ;
    rdfs:label "E193 - Captación digital Fagor. Error en la pista absoluta E21A" ;
    ex:textoExtracto "E193 Captación digital Fagor. Error en la pista absoluta E21A." ;
    ex:identificador "E193" .

ex:ErrorE293
    a ex:AvisoSeguridad ;
    rdfs:label "E293 - Captación digital Fagor. Error en la pista absoluta E21B" ;
    ex:textoExtracto "E293 Captación digital Fagor. Error en la pista absoluta E21B." ;
    ex:identificador "E293" .

ex:ErrorE393
    a ex:AvisoSeguridad ;
    rdfs:label "E393 - Captación digital Fagor. Error en la pista absoluta E21C" ;
    ex:textoExtracto "E393 Captación digital Fagor. Error en la pista absoluta E21C." ;
    ex:identificador "E393" .

ex:ErrorE493
    a ex:AvisoSeguridad ;
    rdfs:label "E493 - Captación digital Fagor. Error en la pista absoluta E21D" ;
    ex:textoExtracto "E493 Captación digital Fagor. Error en la pista absoluta E21D." ;
    ex:identificador "E493" .

ex:FalloPosicionAbsoluta
    a ex:DiagnosticoFallo ;
    rdfs:label "Pérdida de contaje en posición absoluta" ;
    ex:textoExtracto "No puede calcular la posición absoluta. Pérdida de contaje. La señal analógica < 0,20 Vpp." .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "contacte con Fagor Automation" ;
    ex:identificador "Fagor Automation" .

ex:ModuloRCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "MÓDULO RCS-S" ;
    ex:identificador "RCS-S" ;
    ex:activaAlarma ex:ErrorE193, ex:ErrorE293, ex:ErrorE393, ex:ErrorE493 ;
    ex:tieneComponente ex:PistaAbsolutaE21A, ex:PistaAbsolutaE21B, ex:PistaAbsolutaE21C, ex:PistaAbsolutaE21D .

ex:PistaAbsolutaE21A
    a ex:ComponenteElectrico ;
    rdfs:label "Pista absoluta E21A" ;
    ex:textoExtracto "Error en la pista absoluta E21A" ;
    ex:identificador "E21A" .

ex:PistaAbsolutaE21B
    a ex:ComponenteElectrico ;
    rdfs:label "Pista absoluta E21B" ;
    ex:textoExtracto "Error en la pista absoluta E21B" ;
    ex:identificador "E21B" .

ex:PistaAbsolutaE21C
    a ex:ComponenteElectrico ;
    rdfs:label "Pista absoluta E21C" ;
    ex:textoExtracto "Error en la pista absoluta E21C" ;
    ex:identificador "E21C" .

ex:PistaAbsolutaE21D
    a ex:ComponenteElectrico ;
    rdfs:label "Pista absoluta E21D" ;
    ex:textoExtracto "Error en la pista absoluta E21D" ;
    ex:identificador "E21D" .

ex:SenalAnalogica
    a ex:Parametro ;
    rdfs:label "Señal analógica" ;
    ex:textoExtracto "La señal analógica < 0,20 Vpp" ;
    ex:valor "< 0.20 Vpp" .