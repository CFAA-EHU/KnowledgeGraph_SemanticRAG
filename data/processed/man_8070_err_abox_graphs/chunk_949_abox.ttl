@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfirmarQueElMotorEsCorrecto a ns1:TareaMantenimiento ;
    rdfs:label "Confirmar que el motor es correcto" ;
    ns1:solucionaFallo ns1:NuevoMotorDetectado ;
    ns1:textoExtracto "SOLUCIÓN Confirmar que el motor es correcto." .

ns1:DesactivarAutophasingDuranteElProceso a ns1:AccionProhibida ;
    rdfs:label "Desactivar Autophasing durante el proceso" ;
    ns1:textoExtracto "El Autophasing se ha deshabilitado durante el proceso o devuelve un resultado incoherente." .

ns1:Parametro_4e0ce00763 a ns1:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ns1:identificador "ABSFEEDBACK" ;
    ns1:textoExtracto "Los valores ABSFEEDBACK = YES y M19SPDLEREV = YES pueden llevar a una pérdida de cota si se aplica un cambio de SDPLEREV." .

ns1:Parametro_977fc26748 a ns1:Parametro ;
    rdfs:label "M19SPDLEREV" ;
    ns1:identificador "M19SPDLEREV" ;
    ns1:textoExtracto "Los valores ABSFEEDBACK = YES y M19SPDLEREV = YES pueden llevar a una pérdida de cota si se aplica un cambio de SDPLEREV." .

ns1:RevisarLaHabilitacionDelSistemaYChequearElMotorSeleccionado a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la habilitación del sistema y chequear el motor seleccionado" ;
    ns1:solucionaFallo ns1:MalFuncionEnElComandoDeAutophasing ;
    ns1:textoExtracto "SOLUCIÓN Revisar la habilitación del sistema y chequear el motor seleccionado." .

ns1:RevisarLosValoresDeABSFEEDBACKYM19SPDLEREV a ns1:TareaMantenimiento ;
    rdfs:label "Revisar los valores de ABSFEEDBACK y M19SPDLEREV" ;
    ns1:solucionaFallo ns1:ParametrizacionABSFEEDBACKYM19SPDLEREVIncompatible ;
    ns1:textoExtracto "SOLUCIÓN Revisar la habilitación del sistema y chequear el motor seleccionado." .

ns1:SistemaAutophasing a ns1:Sistema ;
    rdfs:label "Sistema Autophasing" ;
    ns1:textoExtracto "El Autophasing se ha deshabilitado durante el proceso o devuelve un resultado incoherente." .

ns1:MalFuncionEnElComandoDeAutophasing a ns1:DiagnosticoFallo ;
    rdfs:label "Mal función en el comando de Autophasing" ;
    ns1:textoExtracto "9373 Mal función en el comando de Autophasing. DETECCIÓN Durante la ejecución." .

ns1:NuevoMotorDetectado a ns1:DiagnosticoFallo ;
    rdfs:label "Nuevo motor detectado" ;
    ns1:textoExtracto "9372 Nuevo motor detectado. DETECCIÓN Durante el arranque o validación de los parámetros máquina." .

ns1:ParametrizacionABSFEEDBACKYM19SPDLEREVIncompatible a ns1:DiagnosticoFallo ;
    rdfs:label "Parametrización ABSFEEDBACK y M19SPDLEREV incompatible" ;
    ns1:textoExtracto "9375 Parametrización ABSFEEDBACK y M19SPDLEREV incompatible, posible pérdida de posición." .

