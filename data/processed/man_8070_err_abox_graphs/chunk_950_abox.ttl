@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_RCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "MÓDULO RCS-S" ;
    ex:tieneComponente ex:Encoder_E21A, ex:Encoder_E21B, ex:Encoder_E21C, ex:Encoder_E21D, ex:AnilloFibraOptica_RCS_S ;
    ex:activaAlarma ex:Alarma_E297, ex:Alarma_E397, ex:Alarma_E497, ex:Alarma_E198, ex:Alarma_E298, ex:Alarma_E398, ex:Alarma_E498, ex:Alarma_E403, ex:Alarma_E404, ex:Alarma_E405, ex:Alarma_E406, ex:Alarma_E407 .

### Encoders/Reglas Digitales
ex:Encoder_E21A
    a ex:ComponenteElectrico ;
    rdfs:label "Captación digital Fagor E21A" ;
    ex:identificador "E21A" ;
    ex:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21A. E297" ;
    ex:monitoreaParametro ex:Parametro_TensionAlimentacion_Encoder ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionCableado .

ex:Encoder_E21B
    a ex:ComponenteElectrico ;
    rdfs:label "Captación digital Fagor E21B" ;
    ex:identificador "E21B" ;
    ex:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21B. E397" ;
    ex:monitoreaParametro ex:Parametro_TensionAlimentacion_Encoder ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionCableado .

ex:Encoder_E21C
    a ex:ComponenteElectrico ;
    rdfs:label "Captación digital Fagor E21C" ;
    ex:identificador "E21C" ;
    ex:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21C. E497" ;
    ex:monitoreaParametro ex:Parametro_TensionAlimentacion_Encoder ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionCableado .

ex:Encoder_E21D
    a ex:ComponenteElectrico ;
    rdfs:label "Captación digital Fagor E21D" ;
    ex:identificador "E21D" ;
    ex:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21D" ;
    ex:monitoreaParametro ex:Parametro_TensionAlimentacion_Encoder ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionCableado .

### Parámetro Crítico
ex:Parametro_TensionAlimentacion_Encoder
    a ex:Parametro ;
    rdfs:label "Tensión de alimentación del encoder/regla digital" ;
    ex:textoExtracto "La tensión de alimentación debe estar entre 5,3 V y 4,1 V" ;
    ex:valor "4.1 V - 5.3 V" .

### Anillo de Fibra Óptica
ex:AnilloFibraOptica_RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica del módulo RCS-S" ;
    ex:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionConexionesFibra .

### Alarmas
ex:Alarma_E297
    a ex:Alarma ;
    rdfs:label "Alarma E297: Tensión de alimentación fuera de rango (E21A)" ;
    ex:identificador "E297" ;
    ex:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21A. E297" ;
    ex:mitigaRiesgo ex:TareaMantenimiento_RevisionCableado .

