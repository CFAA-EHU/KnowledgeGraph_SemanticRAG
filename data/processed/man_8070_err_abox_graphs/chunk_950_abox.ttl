@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroAXISCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISCH" ;
    ns1:textoExtracto "SOLUCIÓN Parametrizar M19SPDLEREV=FALSE y utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:ParametroLOOPCH a ns1:Parametro ;
    rdfs:label "Parámetro LOOPCH" ;
    ns1:textoExtracto "SOLUCIÓN Parametrizar M19SPDLEREV=FALSE y utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:ParametroM19SPDLEREV a ns1:Parametro ;
    rdfs:label "Parámetro M19SPDLEREV" ;
    ns1:textoExtracto "SOLUCIÓN Parametrizar M19SPDLEREV=FALSE y utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:ParametroPP55 a ns1:Parametro ;
    rdfs:label "Parámetro PP55" ;
    ns1:textoExtracto "SOLUCIÓN Parametrizar M19SPDLEREV=FALSE y utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:RevisarLasTablasDeCompensacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar las tablas de compensación" ;
    ns1:solucionaFallo ns1:Error9380 ;
    ns1:textoExtracto "SOLUCIÓN Revisar las tablas de compensación." .

ns1:RevisarParametrosDelComandoElConexionadoYElEstadoYTipoDeCaptador a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros del comando, el conexionado y el estado y tipo de captador" ;
    ns1:solucionaFallo ns1:Error9379 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros del comando, el conexionado y el estado y tipo de captador." .

ns1:RevisarParametrosMOVAXIS a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetros MOVAXIS" ;
    ns1:solucionaFallo ns1:Error9376 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros MOVAXIS." .

ns1:Error9376 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9376" ;
    ns1:textoExtracto "Todos los ejes lineales o todos rotativos y máximo 2 rotativos." .

ns1:Error9379 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9379" ;
    ns1:textoExtracto "Error en la ejecución del comando de acceso al captador Stegmann." .

ns1:Error9380 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9380" ;
    ns1:textoExtracto "No se permiten correcciones distintas para una misma posición." .

