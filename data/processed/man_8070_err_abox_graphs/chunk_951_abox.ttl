@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_E407
    a ex:DiagnosticoFallo ;
    rdfs:label "Descenso erróneo de fase (E407)" ;
    ex:textoExtracto "E407 Descenso erróneo de fase. Problemas en la comunicación a través del anillo de fibra óptica." ;
    ex:identificador "E407" .

ex:Fallo_E410
    a ex:DiagnosticoFallo ;
    rdfs:label "Ruido resetea Sercon (E410)" ;
    ex:textoExtracto "E410 Ruido resetea Sercon. Por el latiguillo de conexión del bus interno entran ruidos que resetean el SerCon pero no el VeCon2." ;
    ex:identificador "E410" .

ex:Fallo_E411
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de recepción de telegramas (E411)" ;
    ex:textoExtracto "E411 Error de recepción de telegramas. Problemas en la comunicación a través del anillo de fibra óptica." ;
    ex:identificador "E411" .

ex:ComponenteElectrico_AnilloFibraOptica
    a ex:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica" ;
    ex:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ex:ComponenteElectrico_LatiguilloBusInterno
    a ex:ComponenteElectrico ;
    rdfs:label "Latiguillo de conexión del bus interno" ;
    ex:textoExtracto "Por el latiguillo de conexión del bus interno entran ruidos que resetean el SerCon pero no el VeCon2." .

ex:Sistema_SerCon
    a ex:Sistema ;
    rdfs:label "SerCon" ;
    ex:textoExtracto "ruidos que resetean el SerCon" .

ex:Sistema_VeCon2
    a ex:Sistema ;
    rdfs:label "VeCon2" ;
    ex:textoExtracto "ruidos que resetean el SerCon pero no el VeCon2" .

ex:Fallo_E407 ex:solucionaFallo ex:ComponenteElectrico_AnilloFibraOptica .
ex:Fallo_E410 ex:solucionaFallo ex:ComponenteElectrico_LatiguilloBusInterno .
ex:Fallo_E411 ex:solucionaFallo ex:ComponenteElectrico_AnilloFibraOptica .