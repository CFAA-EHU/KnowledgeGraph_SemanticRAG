@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorCargaHerramientaPosicion
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'No se puede cargar la herramienta en la posición %1'"@es ;
    ex:textoExtracto "'No se puede cargar la herramienta en la posición %1' DETECCIÓN Durante la carga manual de una herramienta desde un cuadro de diálogo o desde la lista del almacén. Cargando la tabla de almacén. CAUSA La herramienta no cabe en esa posición de almacén, ya está en el almacén o no está definida en la tabla de herramientas."@es .

ex:ErrorDescargaHerramienta
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'No se puede descargar la herramienta %1'"@es ;
    ex:textoExtracto "'No se puede descargar la herramienta %1' DETECCIÓN Durante la descarga manual de una herramienta desde un cuadro de diálogo o desde la lista del almacén. Cargando la tabla de herramientas o de almacén. CAUSA La herramienta no está en el almacén."@es .

ex:ErrorManiobraCabezal
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'No se puede ejecutar la maniobra. Comprobar que el cabezal esté vacío'"@es ;
    ex:textoExtracto "'No se puede ejecutar la maniobra. Comprobar que el cabezal esté vacío' DETECCIÓN Al ejecutar un bloque de carga o descarga de una herramienta de tierra. CAUSA El cabezal no está vacío o hay algún canal en estado de error."@es .

ex:ErrorTablaIncorrecta
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'Tipo de tabla seleccionada incorrecta'"@es ;
    ex:textoExtracto "'Tipo de tabla seleccionada incorrecta' DETECCIÓN Al cargar la tabla de herramientas o almacén. CAUSA El fichero con los datos no corresponde a la tabla que se desea cargar o ha sido modificado externamente."@es .

ex:ErrorHerramientaDuplicada
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'La herramienta no existe o ya está cargada en el almacén'"@es ;
    ex:textoExtracto "'La herramienta no existe o ya está cargada en el almacén' DETECCIÓN Durante la carga de una herramienta en almacén, con o sin maniobra. CAUSA La herramienta no existe o ya está en el almacén, en el cabezal o en los brazos cambiadores (si existen)."@es .

ex:ErrorEliminacionHerramienta
    a ex:AvisoSeguridad ;
    rdfs:label "Error: 'La herramienta %1 no puede ser eliminada'"@es ;
    ex:textoExtracto "'La herramienta %1 no puede ser eliminada' DETECCIÓN Al borrar una herramienta o al cargar la tabla de herramientas."@es .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ex:textoExtracto "Cargando la tabla de herramientas o de almacén."@es .

ex:TablaAlmacen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de almacén"@es ;
    ex:textoExtracto "Cargando la tabla de herramientas o de almacén."@es .

ex:InterfazGestionHerramientas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de gestión de herramientas (cuadro de diálogo/lista de almacén)"@es ;
    ex:textoExtracto "Durante la carga manual de una herramienta desde un cuadro de diálogo o desde la lista del almacén."@es ;
    ex:documentadoEn ex:TablaHerramientas ;
    ex:documentadoEn ex:TablaAlmacen .