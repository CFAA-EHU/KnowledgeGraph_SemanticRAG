@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Herramienta_Desconocida_954
    a               ex:Herramienta ;
    rdfs:label      "Herramienta %1"@es ;
    ex:textoExtracto "La herramienta %1 no puede ser eliminada"@es ;
    ex:textoExtracto "Si está en el cabezal o en los brazos cambiadores, cargarla en el almacén"@es .

ex:AvisoSeguridad_EliminacionHerramienta_954
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso: Herramienta no eliminable"@es ;
    ex:textoExtracto "La herramienta %1 no puede ser eliminada"@es ;
    ex:textoExtracto "SOLUCIÓN Definir la herramienta. Si está en el cabezal o en los brazos cambiadores, cargarla en el almacén."@es .

ex:DiagnosticoFallo_HerramientaNoEncontrada_954
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Herramienta no encontrada por CNC"@es ;
    ex:textoExtracto "DETECCIÓN Al borrar una herramienta o al cargar la tabla de herramientas."@es ;
    ex:textoExtracto "CAUSA El CNC no encuentra la herramienta."@es ;
    ex:textoExtracto "SOLUCIÓN La herramienta no está, luego no puede ser eliminada. Si se produce al cargar la tabla, inicializar la tabla mediante"@es .

ex:TablaHerramientas_954 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de herramientas"@es ;
    ex:textoExtracto "al cargar la tabla de herramientas"@es ;
    ex:textoExtracto "inicializar la tabla mediante"@es .