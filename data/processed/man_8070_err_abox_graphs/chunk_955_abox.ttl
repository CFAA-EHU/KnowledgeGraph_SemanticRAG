@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarConexion a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión" ;
    ns1:solucionaFallo ns1:ErrorEnLaActualizacionDeVersionFPGA_912ec59959 ;
    ns1:textoExtracto "SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ErrorEnLaActualizacionDeVersionFPGA_912ec59959 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión FPGA" ;
    ns1:textoExtracto "9512 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

