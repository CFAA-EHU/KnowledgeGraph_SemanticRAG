@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaHerramientasAlmacen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas y almacén"@es ;
    ex:textoExtracto "la tabla de herramientas. [...] al cargar la tabla de almacén."@es ;
    ex:identificador "Tabla de herramientas (pág. 317-318)" .

ex:Herramienta_CNC
    a ex:Herramienta ;
    rdfs:label "Herramienta genérica del CNC"@es ;
    ex:textoExtracto "La herramienta no está, luego no puede ser eliminada. [...] La herramienta no existe o no está en el almacén."@es ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .

ex:BaseDatosHerramientas_bd8070
    a ex:InterfazUsuario ;
    rdfs:label "Base de datos de herramientas (bd8070.mdb)"@es ;
    ex:textoExtracto "No puede crear la herramienta en la base de datos (bd8070.mdb). [...] esperar a que se libere."@es ;
    ex:identificador "bd8070.mdb" .

ex:Diagnostico_HerramientaNoExistente
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Herramienta %1 no existe o no está cargada"@es ;
    ex:textoExtracto "' La herramienta %1 no existe o no está cargada en el almacén' [...] SOLUCIÓN Definir la herramienta y cargarla en el almacén."@es ;
    ex:solucionaFallo ex:Herramienta_CNC ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .

ex:Diagnostico_ErrorRenombrarHerramienta
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Error al renombrar herramienta (BD bloqueada)"@es ;
    ex:textoExtracto "' Error renombrando la herramienta' [...] SOLUCIÓN La base de datos debe tener permiso de escritura."@es ;
    ex:solucionaFallo ex:BaseDatosHerramientas_bd8070 ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .

ex:Diagnostico_NombreHerramientaDuplicado
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Nombre de herramienta duplicado en cabezal/almacén"@es ;
    ex:textoExtracto "' No se puede renombrar una herramienta de cabezal, almacén o brazos' [...] SOLUCIÓN Elegir otro número o descargar la herramienta a tierra."@es ;
    ex:solucionaFallo ex:Herramienta_CNC ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .

ex:Diagnostico_BrazoCambiadorOcupado_1
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Brazo cambiador 2 ocupado"@es ;
    ex:textoExtracto "' No se puede poner una herramienta en el cabezal si ya hay una en el brazo 2' [...] SOLUCIÓN Quitar la herramienta del brazo cambiador 2."@es ;
    ex:solucionaFallo ex:Herramienta_CNC ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .

ex:Diagnostico_BrazoCambiadorOcupado_2
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Herramienta en brazo cambiador 1"@es ;
    ex:textoExtracto "' No se puede poner en el cabezal la herramienta del brazo cambiador' [...] SOLUCIÓN Quitar la herramienta del brazo cambiador 1."@es ;
    ex:solucionaFallo ex:Herramienta_CNC ;
    ex:documentadoEn ex:TablaHerramientasAlmacen .