@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionRecibidaSenalDeAlarma a ns1:AvisoSeguridad ;
    rdfs:label "Captación:Recibida señal de alarma" ;
    ns1:textoExtracto "9519 Captación:Recibida señal de alarma." .

ns1:CaptacionSobrecorrienteOCortocircuito a ns1:AvisoSeguridad ;
    rdfs:label "Captación:Sobrecorriente o cortocircuito" ;
    ns1:mitigaRiesgo ns1:RevisarElConexionadoYElNivelDeLasSenalesProporcionadasPorElCaptador ;
    ns1:textoExtracto "9518 Captación:Sobrecorriente o cortocircuito." .

ns1:RevisarElNivelDeLasSenalesProporcionadasPorElCaptador a ns1:AccionProhibida ;
    rdfs:label "Revisar el nivel de las señales proporcionadas por el captador" ;
    ns1:solucionaFallo ns1:SeHaProducidoUnCortocircuitoOSeEstaSobrealimentandoElCaptador ;
    ns1:textoExtracto "SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." .

ns1:RevisarElConexionadoYElNivelDeLasSenalesProporcionadasPorElCaptador a ns1:AccionProhibida ;
    rdfs:label "Revisar el conexionado y el nivel de las señales proporcionadas por el captador" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador." .

ns1:SeHaProducidoUnCortocircuitoOSeEstaSobrealimentandoElCaptador a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha producido un cortocircuito o se está sobrealimentando el captador" ;
    ns1:textoExtracto "CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador." .

