@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CortocircuitoOSeEstaSobrealimentandoElCaptador a ns1:DiagnosticoFallo ;
    rdfs:label "cortocircuito o se está sobrealimentando el captador" ;
    ns1:textoExtracto "un cortocircuito o se está sobrealimentando el captador." .

ns1:DisminuyaLaVelocidadMaximaDeMovimientoDelEje a ns1:AccionProhibida ;
    rdfs:label "Disminuya la velocidad máxima de movimiento del eje" ;
    ns1:textoExtracto "SOLUCIÓN Disminuya la velocidad máxima de movimiento del eje." .

ns1:ElEncoderHaGeneradoUnaSenalDeAlarmaPorUnMalFuncionamientoDelMismo a ns1:DiagnosticoFallo ;
    rdfs:label "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo" ;
    ns1:textoExtracto "CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo." .

ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_a32a30480b a ns1:AccionProhibida ;
    rdfs:label "Error de comunicación en captación. CRC incorrecto" ;
    ns1:textoExtracto "Error de comunicación en captación. CRC incorrecto." .

ns1:LaVelocidadDelEjeExcedeLaCapacidadDeMuestreoDelHardware a ns1:DiagnosticoFallo ;
    rdfs:label "La velocidad del eje excede la capacidad de muestreo del hardware" ;
    ns1:textoExtracto "CAUSA La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal del encóder." .

ns1:RevisarElConexionadoYElNivelDeLasSenalesProporcionadasPorElCaptador a ns1:AccionProhibida ;
    rdfs:label "Revisar el conexionado y el nivel de las señales proporcionadas por el captador" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador." .

ns1:ReviseLaDocumentacionDelEncoderParaDeterminarElOrigenDeLaAlarma a ns1:AccionProhibida ;
    rdfs:label "Revise la documentación del encóder para determinar el origen de la alarma" ;
    ns1:textoExtracto "SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma." .

