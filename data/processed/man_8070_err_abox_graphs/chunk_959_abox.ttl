@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReemplazarEncoderOCabezaDeLaRegla a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar encóder o cabeza de la regla" ;
    ns1:solucionaFallo ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_df027b446a ;
    ns1:textoExtracto "Si todo es correcto y sigue produciéndose el error, reemplazar el encóder o la cabeza de la regla." .

ns1:VerificarCableYConexionConElCaptador a ns1:TareaMantenimiento ;
    rdfs:label "Verificar cable y conexión con el captador" ;
    ns1:solucionaFallo ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_df027b446a ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador." .

ns1:VerificarCableYConexionConElCaptador_01f6188414 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar cable y conexión con el captador" ;
    ns1:solucionaFallo ns1:ErrorDeComunicacionEnCaptacionNoSeRecibioAcknowledge_27edf6cdf8 ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador. El error puede deberse a un problema en el captador." .

ns1:VerificarParametrizacionDelCaptador a ns1:TareaMantenimiento ;
    rdfs:label "Verificar parametrización del captador" ;
    ns1:solucionaFallo ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_df027b446a ;
    ns1:textoExtracto "Verifique la correcta parametrización del captador." .

ns1:ErrorDeComunicacionEnCaptacionNoSeRecibioAcknowledge_27edf6cdf8 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación. No se recibió acknowledge" ;
    ns1:textoExtracto "9522 Error de comunicación en captación. No se recibió acknowledge." .

ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_df027b446a a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación. CRC incorrecto" ;
    ns1:textoExtracto "9521 Error de comunicación en captación. CRC incorrecto." .

