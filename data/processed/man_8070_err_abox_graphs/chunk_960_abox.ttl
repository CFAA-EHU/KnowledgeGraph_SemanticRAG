@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_960_01
    a ex:AvisoSeguridad ;
    rdfs:label "Perfil sin resolver" ;
    ex:textoExtracto "'Perfil sin resolver' CAUSA El perfil a salvar no está resuelto completamente. SOLUCIÓN Resolver el perfil que se desea salvar. El CNC sólo permite salvar perfiles resueltos." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_02
    a ex:AvisoSeguridad ;
    rdfs:label "Memoria insuficiente" ;
    ex:textoExtracto "'Memoria insuficiente' CAUSA No hay memoria de sistema para seguir con el editor de perfiles. SOLUCIÓN Póngase en contacto con Fagor." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_03
    a ex:AvisoSeguridad ;
    rdfs:label "Error de geometría" ;
    ex:textoExtracto "'Error de geometría' CAUSA El perfil seleccionado tiene una geometría no válida. El perfil seleccionado tiene algún dato erróneo en la definición de las trayectorias. SOLUCIÓN Corregir el perfil. Todas las trayectorias que definen el perfil deben estar correctamente definidas." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_04
    a ex:AvisoSeguridad ;
    rdfs:label "Error en datos del elemento" ;
    ex:textoExtracto "'Error en datos del elemento' CAUSA Los datos introducidos en un elemento son incorrectos. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_05
    a ex:AvisoSeguridad ;
    rdfs:label "Error en datos del perfil" ;
    ex:textoExtracto "'Error en datos del perfil' CAUSA Datos no válidos en la edición de un perfil 'círculo' o 'rectángulo'. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_06
    a ex:AvisoSeguridad ;
    rdfs:label "El arco no pasa por su coordenada inicial" ;
    ex:textoExtracto "'El arco no pasa por su coordenada inicial' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto inicial. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_07
    a ex:AvisoSeguridad ;
    rdfs:label "El arco no pasa por su coordenada final" ;
    ex:textoExtracto "'El arco no pasa por su coordenada final' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto final. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_08
    a ex:AvisoSeguridad ;
    rdfs:label "No hay arco que cumpla todos los datos" ;
    ex:textoExtracto "'No hay arco que cumpla todos los datos' CAUSA El editor no puede encontrar un elemento arco coherente con todos los datos conocidos. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_09
    a ex:AvisoSeguridad ;
    rdfs:label "Elemento no tangente al anterior" ;
    ex:textoExtracto "'Elemento no tangente al anterior' CAUSA La tangencia de un elemento no es coherente con el elemento anterior. SOLUCIÓN Corregir los datos del elemento." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_10
    a ex:AvisoSeguridad ;
    rdfs:label "Valor no válido" ;
    ex:textoExtracto "'Valor no válido' CAUSA El valor introducido para modificar una arista (redondeo, chaflán, entrada tangencial o salida tangencial) no es válido. SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:AvisoSeguridad_960_11
    a ex:AvisoSeguridad ;
    rdfs:label "Error en eje del plano" ;
    ex:textoExtracto "'Error en eje del plano' CAUSA Algún eje del plano no es válido." ;
    ex:ilustradoEn ex:InterfazUsuario_EditorPerfiles .

ex:InterfazUsuario_EditorPerfiles
    a ex:InterfazUsuario ;
    rdfs:label "Editor de perfiles" ;
    ex:textoExtracto "Sección: EDITOR DE PERFILES" .