@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarConexionYCableadoDeABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión y cableado de ABSIND" ;
    ns1:solucionaFallo ns1:ErrorLeyendoInformacionDelModuloABSIND,
        ns1:NivelDeLaSenalIncrementalDelTransductorInductosynResolverDemasiadoAlto ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ComprobarSenalIncrementalDelTransductorInductosynResolver a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar señal incremental del transductor inductosyn/resolver" ;
    ns1:textoExtracto "SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. • Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Durante el arranque o funcionamiento habitual del sistema." .

ns1:SustituirModuloABSINDOCableAsociado a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND o cable asociado" ;
    ns1:textoExtracto "• Si el error persiste y no se puede eliminar con las acciones anteriores, pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

ns1:ErrorLeyendoInformacionDelModuloABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error leyendo información del módulo ABSIND" ;
    ns1:textoExtracto "9524 ABSIND:Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema." .

ns1:NivelDeLaSenalIncrementalDelTransductorInductosynResolverDemasiadoAlto a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto" ;
    ns1:textoExtracto "9526 INDUCTOSYN:Señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto." .

