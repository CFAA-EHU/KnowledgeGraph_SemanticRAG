@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:SenalINCDemasiadoAlta ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:SistemaInductosyn a ns1:Sistema ;
    rdfs:label "Sistema Inductosyn/Resolver" ;
    ns1:requiereMantenimiento ns1:ComprobarElNivelDeLaSenalIncremental,
        ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto." .

ns1:ComprobarElNivelDeLaSenalIncremental a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el nivel de la señal incremental" ;
    ns1:textoExtracto "Comprobar el nivel de la señal incremental del transductor inductosyn/resolver." .

ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar valores de ganancia y fase del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:SenalINCDemasiadoAlta a ns1:DiagnosticoFallo ;
    rdfs:label "Señal INC demasiado alta" ;
    ns1:textoExtracto "9526 INDUCTOSYN: Señal INC demasiado alta." .

