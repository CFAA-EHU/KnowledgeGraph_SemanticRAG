@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarLasConexionesDeTierraEnElArmario a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar las conexiones de tierra en el armario" ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:INDUCTOSYNResolverDemasiadoAlto a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN/Resolver demasiado alto" ;
    ns1:solucionaFallo ns1:ComprobarCableYConexionEntreElModuloABSINDYElTransductorInductosynResolver,
        ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND,
        ns1:SustituirModuloABSINDOCableAsociado_311335c5a7 ;
    ns1:textoExtracto "inductosyn/resolver demasiado alto." .

ns1:INDUCTOSYNSenalGRAYNoPresente a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Señal GRAY no presente" ;
    ns1:solucionaFallo ns1:ComprobarCableYConexionEntreElModuloABSINDYElTransductorInductosynResolver,
        ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND,
        ns1:SustituirModuloABSINDOCableAsociado_311335c5a7 ;
    ns1:textoExtracto "9527 INDUCTOSYN:Señal GRAY no presente." .

ns1:INDUCTOSYNTransductorNoEstableEnPowerON a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Transductor no estable en Power-ON" ;
    ns1:solucionaFallo ns1:ComprobarCableYConexionEntreElModuloABSINDYElTransductorInductosynResolver,
        ns1:ComprobarQueElEjeNoSeMueveDuranteElArranqueOInicializacionDelModuloABSIND,
        ns1:SustituirModuloABSINDOCableAsociado_311335c5a7 ;
    ns1:textoExtracto "9528 INDUCTOSYN:Transductor no estable en Power-ON." .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ComprobarQueElEjeNoSeMueveDuranteElArranqueOInicializacionDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar que el eje no se mueve durante el arranque o inicialización del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar que el eje no se mueve durante el arranque o inicialización del módulo ABSIND." .

ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar valores de ganancia y fase del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:ComprobarCableYConexionEntreElModuloABSINDYElTransductorInductosynResolver a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable y conexión entre el módulo ABSIND y el transductor inductosyn/resolver" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver." .

ns1:SustituirModuloABSINDOCableAsociado_311335c5a7 a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND o cable asociado" ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

