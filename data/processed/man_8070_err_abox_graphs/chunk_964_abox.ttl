@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ChecksumEEPROMIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Checksum EEPROM incorrecto" ;
    ns1:identificador "9529 INDUCTOSYN" ;
    ns1:textoExtracto "9529 INDUCTOSYN: Checksum EEPROM incorrecto." .

ns1:ComprobarConexionesDeTierra a ns1:AccionProhibida ;
    rdfs:label "Comprobar conexiones de tierra" ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:SustitucionDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Sustitución del módulo ABSIND" ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

