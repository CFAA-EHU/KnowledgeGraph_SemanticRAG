@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_Encoder_9543 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Error interno en encoder (sistema 9543)"@es ;
    ns1:solucionaFallo ns1:ContactarConSoporteTecnicoFagorAutomation ;
    ns1:textoExtracto "CAUSA Error interno en el encoder."@es .

ns1:Fallo_Se_alEntradaBaja a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Amplitud de señal de entrada por debajo de 0.4 Vpp"@es ;
    ns1:solucionaFallo ns1:RevisionDeCablesYConexionesDeEntradasDeCaptacion ;
    ns1:textoExtracto "CAUSA Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente. SOLUCIÓN Revisar los cables y la conexión de las entradas de captación."@es .

ns1:AmplitudDeSenalDeEntradaVpp a ns1:Parametro ;
    rdfs:label "Amplitud de señal de entrada (Vpp)"@es ;
    ns1:textoExtracto "Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente."@es ;
    ns1:valor "0.4" .

ns1:ContactarConSoporteTecnicoFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con soporte técnico Fagor Automation"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:EncoderDelSistemaDeCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Encoder del sistema de captación"@es ;
    ns1:textoExtracto "Alimentación del encoder fuera de valores deseables. [...] Error interno en el encoder."@es .

ns1:RevisionDeCablesYConexionesDeEntradasDeCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cables y conexiones de entradas de captación"@es ;
    ns1:requiereMantenimiento ns1:SistemaCaptacion_9543 ;
    ns1:textoExtracto "Revisar los cables y la conexión de las entradas de captación."@es .

ns1:SistemaCaptacion_9543 a ns1:Sistema ;
    rdfs:label "Sistema de captación digital Fagor 9543"@es ;
    ns1:identificador "9543" ;
    ns1:monitoreaParametro ns1:AmplitudDeSenalDeEntradaVpp ;
    ns1:textoExtracto "9543 Captación digital Fagor"@es ;
    ns1:tieneComponente ns1:EncoderDelSistemaDeCaptacion .

