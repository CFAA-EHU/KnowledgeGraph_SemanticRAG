@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_9543 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9543: Alimentación del encoder fuera de valores deseables" ;
    ns1:identificador "9543" ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Captación digital Fagor: Alimentación del encoder fuera de valores deseables. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:DiagnosticoFallo_9544 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9544: Velocidad excesiva en el eje" ;
    ns1:identificador "9544" ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Captación digital Fagor: Velocidad excesiva en el eje. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:DiagnosticoFallo_9545 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9545: Temperatura interna fuera de rango" ;
    ns1:identificador "9545" ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Sobretemperatura en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:DiagnosticoFallo_9546 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9546: Pérdida de sincronización" ;
    ns1:identificador "9546" ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Captación digital Fagor: Pérdida de sincronización. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error de comunicación del encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:DiagnosticoFallo_9547 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9547: Pulso de I0 no detectado" ;
    ns1:identificador "9547" ;
    ns1:monitoreaParametro ns1:Parametro_Se_alI0 ;
    ns1:solucionaFallo ns1:EncoderFagor ;
    ns1:textoExtracto "Pulso de I0 no detectado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador no ha recibido la señal de I0. SOLUCIÓN Revisar la parametrización y el conexionado del encoder."@es .

ns1:DiagnosticoFallo_9548 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9548: Falta fase en la tarjeta sense" ;
    ns1:identificador "9548" ;
    ns1:solucionaFallo ns1:TarjetaSense ;
    ns1:textoExtracto "Falta fase en la tarjeta sense. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Una fase de red no llega correctamente a la tarjeta sense. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:DiagnosticoFallo_9549 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9549: Nivel de tensión por debajo del 80%" ;
    ns1:identificador "9549" ;
    ns1:monitoreaParametro ns1:Parametro_TensionRed ;
    ns1:solucionaFallo ns1:TarjetaSense ;
    ns1:textoExtracto "Nivel de tensión por debajo del 80%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:Parametro_AlimentacionEncoder a ns1:Parametro ;
    rdfs:label "Alimentación del encoder" ;
    ns1:textoExtracto "Alimentación del encoder fuera de valores deseables"@es .

ns1:Parametro_Se_alI0 a ns1:Parametro ;
    rdfs:label "Señal de pulso I0" ;
    ns1:textoExtracto "Pulso de I0 no detectado... El regulador no ha recibido la señal de I0"@es .

ns1:Parametro_SincronizacionEncoder a ns1:Parametro ;
    rdfs:label "Sincronización del encoder" ;
    ns1:textoExtracto "Pérdida de sincronización"@es .

ns1:Parametro_TemperaturaEncoder a ns1:Parametro ;
    rdfs:label "Temperatura interna del encoder" ;
    ns1:textoExtracto "Temperatura interna fuera de rango"@es .

ns1:Parametro_VelocidadEje a ns1:Parametro ;
    rdfs:label "Velocidad del eje" ;
    ns1:textoExtracto "Velocidad excesiva en el eje"@es .

ns1:Parametro_TensionRed a ns1:Parametro ;
    rdfs:label "Tensión de red" ;
    ns1:textoExtracto "Nivel de tensión por debajo del 80%... Bajada en la tensión de red"@es ;
    ns1:valor "80%" .

ns1:TarjetaSense a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta sense" ;
    ns1:monitoreaParametro ns1:Parametro_TensionRed ;
    ns1:textoExtracto "Falta fase en la tarjeta sense... Revisar tensiones de red y cableado hasta la tarjeta sense"@es .

ns1:EncoderFagor a ns1:Sensor ;
    rdfs:label "Encoder digital Fagor" ;
    ns1:monitoreaParametro ns1:Parametro_AlimentacionEncoder,
        ns1:Parametro_SincronizacionEncoder,
        ns1:Parametro_TemperaturaEncoder,
        ns1:Parametro_VelocidadEje ;
    ns1:textoExtracto "Captación digital Fagor: Alimentación del encoder fuera de valores deseables... Revisar el conexionado e integridad del encoder."@es .

