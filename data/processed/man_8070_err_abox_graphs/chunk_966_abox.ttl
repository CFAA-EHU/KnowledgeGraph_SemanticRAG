@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisionDelDipswitchS50 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del dipswitch S50" ;
    ns1:solucionaFallo ns1:ErrorDesconocidoDelModuloABSIND ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND. El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC y con el tipo de captador (inductosyn/resolver) conectado al módulo ABSIND." .

ns1:SistemaCNC8070_d5361873a8 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:monitoreaParametro ns1:ParametroSSITYPE ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." .

ns1:SustitucionDelModuloABSIND_93c2ebbca1 a ns1:AccionProhibida ;
    rdfs:label "Sustitución del módulo ABSIND" ;
    ns1:solucionaFallo ns1:ErrorDesconocidoDelModuloABSIND ;
    ns1:textoExtracto "Si el error es repetitivo y persiste pruebe a sustituir el módulo ABSIND asociado a esa captación." .

ns1:ParametroSSITYPE a ns1:Parametro ;
    rdfs:label "Parámetro SSITYPE" ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." .

ns1:ErrorDesconocidoDelModuloABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error desconocido del módulo ABSIND" ;
    ns1:textoExtracto "El módulo ABSIND ha generado un error desconocido. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND." .

