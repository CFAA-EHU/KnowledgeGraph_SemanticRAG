@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarLaAlimentacionDelModuloABSIND_4b4cf53b9e a ns1:AccionProhibida ;
    rdfs:label "Comprobar la alimentación del módulo ABSIND" ;
    ns1:solucionaFallo ns1:FalloNivelTension24VDC15VDCBajo,
        ns1:FalloNivelTension24VDC15VDCHalto ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la alimentación del módulo ABSIND." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema Principal" ;
    ns1:textoExtracto "Durante el arranque o funcionamiento habitual del sistema." ;
    ns1:tieneComponente ns1:ModuloABSIND .

ns1:FalloNivelTension24VDC15VDCBajo a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión 24 V DC/15 V DC demasiado bajo" ;
    ns1:textoExtracto "9532 INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado bajo." .

ns1:FalloNivelTension24VDC15VDCHalto a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión 24 V DC/15 V DC demasiado alto" ;
    ns1:textoExtracto "9533 INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado alto." .

ns1:ModuloABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "Comprobar la alimentación del módulo ABSIND." .

