@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "conexionado del encoder" .

ns1:Fallo_9610 a ns1:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en regulador" ;
    ns1:identificador "9610" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9610 Cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Detección de cortocircuito en el regulador. SOLUCIÓN Las posibles soluciones son las siguientes: • Realizar un reset del error. Si el error persiste, es posible que la conexión de los cables de potencia sea errónea o que estén en contacto, provocando un cortocircuito. • Es posible que los parámetros sean incorrectos o se deba a un fallo del regulador." .

ns1:Fallo_9611 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en regulador" ;
    ns1:identificador "9611" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9611 Error de comunicación en regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Regulador en estado de error. SOLUCIÓN Eliminar la causa del error y resetear el regulador." .

ns1:Fallo_9612 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma en señales de captación (Vpp)" ;
    ns1:activaAlarma ns1:Alarma_Encoder_Vpp ;
    ns1:identificador "9612" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9612 Alarma en las señales de captación. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en las señales Vpp del encoder. SOLUCIÓN Revisar el conexionado del encoder." .

ns1:Fallo_9613 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de pulsos entre I0s" ;
    ns1:activaAlarma ns1:Alarma_Encoder_I0s ;
    ns1:identificador "9613" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9613 Alarma de pulsos entre I0s. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." .

ns1:Fallo_9614 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comprobación de CRC de PM" ;
    ns1:identificador "9614" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9614 Error de comprobación de CRC de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Fallo_9615 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en detección de PM" ;
    ns1:identificador "9615" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9615 Error en la detección de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Fallo_9616 a ns1:DiagnosticoFallo ;
    rdfs:label "Watchdog de regulador" ;
    ns1:identificador "9616" ;
    ns1:solucionaFallo ns1:Regulador_Fagor ;
    ns1:textoExtracto "9616 Watchdog de regulador. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Fallo_9617 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ns1:identificador "9617" ;
    ns1:textoExtracto "9617 Fallo 24 Vdc inesperado." .

ns1:Alarma_Encoder_I0s a ns1:Alarma ;
    rdfs:label "Alarma por error en correlación de pulsos I0 del encoder" ;
    ns1:textoExtracto "El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder." .

ns1:Alarma_Encoder_Vpp a ns1:Alarma ;
    rdfs:label "Alarma por error en señales Vpp del encoder" ;
    ns1:textoExtracto "El regulador ha detectado un error en las señales Vpp del encoder." .

ns1:Regulador_Fagor a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (Fagor Automation)" ;
    ns1:textoExtracto "regulador" .

