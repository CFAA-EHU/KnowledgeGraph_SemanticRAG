@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CableSe_alA a ns1:ComponenteElectrico ;
    rdfs:label "Cable de señal A" ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje del regulador. Revisar el cable y la conexión de las entradas de captación." .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Contacte con Fagor Automation. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Fallo_9617 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ns1:identificador "9617" ;
    ns1:textoExtracto "9617 Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha detectado una caída en la tensión de control. SOLUCIÓN Revisar el conexionado y la alimentación de control de 24 Vdc." .

ns1:Fallo_9618 a ns1:DiagnosticoFallo ;
    rdfs:label "Lazos de corriente en mismo nodo incompatibles" ;
    ns1:identificador "9618" ;
    ns1:textoExtracto "9618 Lazos de corriente en mismo nodo incompatibles. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Un regulador doble tiene configurados modos incompatibles de control para cada motor. SOLUCIÓN En un regulador doble, parametrizar el mismo tipo de control en ambos motores." .

ns1:Fallo_9619 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión DSP" ;
    ns1:identificador "9619" ;
    ns1:textoExtracto "9619 Error en la actualización de versión DSP. DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no puede actualizar la versión del DSP en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Fallo_9620 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión FPGA" ;
    ns1:identificador "9620" ;
    ns1:textoExtracto "9620 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Fallo_9621 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD" ;
    ns1:identificador "9621" ;
    ns1:textoExtracto "9621 Error en la actualización de versión CPLD. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión del CPDL en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Fallo_9622 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal A" ;
    ns1:identificador "9622" ;
    ns1:textoExtracto "9622 Captación: Cable roto señal A. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "El regulador ha detectado una caída en la tensión de control. Un regulador doble tiene configurados modos incompatibles de control para cada motor. El lazo ha detectado cable roto en la señal A del contaje del regulador." ;
    ns1:tieneComponente ns1:Motor_1,
        ns1:Motor_2 .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC no puede actualizar la versión del DSP/CPLD/FPGA en algún regulador o RPS." .

ns1:Motor_1 a ns1:ComponenteElectrico ;
    rdfs:label "Motor 1" ;
    ns1:textoExtracto "Un regulador doble tiene configurados modos incompatibles de control para cada motor." .

ns1:Motor_2 a ns1:ComponenteElectrico ;
    rdfs:label "Motor 2" ;
    ns1:textoExtracto "Un regulador doble tiene configurados modos incompatibles de control para cada motor." .

