@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_9623 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal B" ;
    ns1:identificador "9623" ;
    ns1:solucionaFallo ns1:Regulador_Captacion ;
    ns1:textoExtracto "Captación: Cable roto señal B. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal B de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación." .

ns1:Error_9624 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal I0" ;
    ns1:identificador "9624" ;
    ns1:solucionaFallo ns1:Regulador_Captacion ;
    ns1:textoExtracto "Captación: Cable roto señal I0. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal I0 del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación." .

ns1:Error_9625 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal AL" ;
    ns1:identificador "9625" ;
    ns1:solucionaFallo ns1:Regulador_Captacion ;
    ns1:textoExtracto "Captación: Cable roto señal AL. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal AL del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación." .

ns1:Error_9626 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Sobrecorriente o cortocircuito" ;
    ns1:identificador "9626" ;
    ns1:solucionaFallo ns1:Encoder_Captacion ;
    ns1:textoExtracto "Captación: Sobrecorriente o cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador. SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador." .

ns1:Error_9627 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Recibida señal de alarma" ;
    ns1:identificador "9627" ;
    ns1:solucionaFallo ns1:Encoder_Captacion ;
    ns1:textoExtracto "Captación: Recibida señal de alarma. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo. SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado." .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." ;
    ns1:tieneComponente ns1:Encoder_Captacion,
        ns1:Regulador_Captacion .

ns1:Encoder_Captacion a ns1:Sensor ;
    rdfs:label "Encóder de captación" ;
    ns1:textoExtracto "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo." .

ns1:Regulador_Captacion a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de contaje" ;
    ns1:textoExtracto "El regulador no recibe la señal B de la captación." .

