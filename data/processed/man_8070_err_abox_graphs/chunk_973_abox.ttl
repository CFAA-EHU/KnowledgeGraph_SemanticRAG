@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NivelDeTension a ns1:Parametro ;
    rdfs:label "Nivel de tensión" ;
    ns1:textoExtracto "9550 Nivel de tensión por debajo del 70%." ;
    ns1:valor "por debajo del 70%" .

ns1:RevisarTensionesDeRedYCableadoHastaLaTarjetaSense a ns1:TareaMantenimiento ;
    rdfs:label "Revisar tensiones de red y cableado hasta la tarjeta sense" ;
    ns1:solucionaFallo ns1:BajadaEnLaTensionDeRed ;
    ns1:textoExtracto "SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." .

ns1:BajadaEnLaTensionDeRed a ns1:DiagnosticoFallo ;
    rdfs:label "Bajada en la tensión de red" ;
    ns1:textoExtracto "CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado." .

