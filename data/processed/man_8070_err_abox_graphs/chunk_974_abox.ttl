@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_Encoder_9628 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo en encoder (9628)" ;
    ns1:solucionaFallo ns1:Alarma_9628_FrecuenciaContajeExcesiva ;
    ns1:textoExtracto "Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado." .

ns1:Encoder_9628 a ns1:Sensor ;
    rdfs:label "Encoder" ;
    ns1:activaAlarma ns1:Alarma_9628_FrecuenciaContajeExcesiva ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadEje ;
    ns1:textoExtracto "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo." .

ns1:Parametro_VelocidadEje a ns1:Parametro ;
    rdfs:label "Velocidad del eje" ;
    ns1:textoExtracto "La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal" .

ns1:Alarma_9628_FrecuenciaContajeExcesiva a ns1:Alarma ;
    rdfs:label "Frecuencia de contaje excesiva (9628)" ;
    ns1:identificador "9628" ;
    ns1:textoExtracto "Captación: Frecuencia de contaje excesiva. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

