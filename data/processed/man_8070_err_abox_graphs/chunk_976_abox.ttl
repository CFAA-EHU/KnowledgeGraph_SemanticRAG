@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9630 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9630: Error de comunicación en captación"@es ;
    ns1:identificador "9630" ;
    ns1:solucionaFallo ns1:ComprobacionCableadoCaptador9630 ;
    ns1:textoExtracto "9630 Error de comunicación en captación. No se recibió acknowledge. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en la lectura de la cota absoluta; no se recibió acknowledge."@es .

ns1:Error9631 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9631: ABSIND - Error de sincronismo"@es ;
    ns1:identificador "9631" ;
    ns1:solucionaFallo ns1:ComprobacionConexionABSIND9631 ;
    ns1:textoExtracto "9631 ABSIND: Error de sincronismo. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador."@es .

ns1:ReguladorSistema a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del sistema"@es ;
    ns1:controla ns1:ModuloABSIND ;
    ns1:textoExtracto "El regulador ha perdido la sincronización con el módulo ABSIND"@es .

ns1:CableadoCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Cableado del sistema de captación"@es ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador."@es .

ns1:CaptadorCota a ns1:Sensor ;
    rdfs:label "Captador de cota absoluta"@es ;
    ns1:monitoreaParametro ns1:ParametroCotaAbsoluta ;
    ns1:textoExtracto "Error en la lectura de la cota absoluta; no se recibió acknowledge."@es .

ns1:ComprobacionCableadoCaptador9630 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de cable y conexionado con el captador (Error 9630)"@es ;
    ns1:requiereMantenimiento ns1:SistemaCaptacion ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador."@es .

ns1:ComprobacionConexionABSIND9631 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de conexión y cableado del módulo ABSIND (Error 9631)"@es ;
    ns1:requiereMantenimiento ns1:ModuloABSIND ;
    ns1:textoExtracto "Comprobar que la conexión y el cableado son satisfactorios."@es .

ns1:ParametroCotaAbsoluta a ns1:Parametro ;
    rdfs:label "Cota absoluta"@es ;
    ns1:textoExtracto "Error en la lectura de la cota absoluta"@es ;
    ns1:valor "lectura incorrecta"@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación de cota absoluta"@es ;
    ns1:textoExtracto "Error en la lectura de la cota absoluta; no se recibió acknowledge."@es ;
    ns1:tieneComponente ns1:CableadoCaptacion,
        ns1:CaptadorCota .

ns1:ModuloABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ns1:textoExtracto "El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta."@es .

