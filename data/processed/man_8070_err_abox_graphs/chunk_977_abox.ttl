@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ComprobarConexion a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar conexión y cableado" ;
    ns1:solucionaFallo ns1:Error_9632_ABSIND ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios." .

ns1:Accion_ContactarSoporte a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor Automation si persiste el error" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Regulador_Sistema a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del sistema" ;
    ns1:controla ns1:Modulo_ABSIND ;
    ns1:textoExtracto "El regulador no ha podido leer la identificación del módulo ABSIND" .

ns1:Sistema_Control a ns1:Sistema ;
    rdfs:label "Sistema de control" ;
    ns1:textoExtracto "arranque o funcionamiento habitual del sistema" ;
    ns1:tieneComponente ns1:Modulo_ABSIND .

ns1:Error_9632_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9632 ABSIND" ;
    ns1:identificador "9632" ;
    ns1:textoExtracto "9632 ABSIND: Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "módulo ABSIND" .

