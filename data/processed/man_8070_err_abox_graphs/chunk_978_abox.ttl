@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompruebeElConexionado_3ddccd7681 a ns1:TareaMantenimiento ;
    rdfs:label "Compruebe el conexionado" ;
    ns1:solucionaFallo ns1:ErrorEnLaActualizacionDeVersionCPLD_f057f63dc9,
        ns1:ErrorEnLaActualizacionDeVersionDSP_d9cd3ba218,
        ns1:ErrorEnLaActualizacionDeVersionFPGA_0ba6b7195e ;
    ns1:textoExtracto "SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:EnUnReguladorDobleParametrizarElMismoTipoDeControlEnAmbosMotores a ns1:TareaMantenimiento ;
    rdfs:label "En un regulador doble, parametrizar el mismo tipo de control en ambos motores" ;
    ns1:solucionaFallo ns1:LazosDeCorrienteEnMismoNodoIncompatibles_8d92ab0fdf ;
    ns1:textoExtracto "SOLUCIÓN En un regulador doble, parametrizar el mismo tipo de control en ambos motores." .

ns1:RevisarElCableYLaConexionDeLasEntradasDeCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cable y la conexión de las entradas de captación" ;
    ns1:solucionaFallo ns1:CaptacionCableRotoSenalA_326c20cc71 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cable y la conexión de las entradas de captación. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarElConexionadoYLaAlimentacionDeControlDe24Vdc_8b6ea60317 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado y la alimentación de control de 24 Vdc" ;
    ns1:solucionaFallo ns1:Fallo24VdcInesperado_41a7cf9b84 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y la alimentación de control de 24 Vdc." .

ns1:CaptacionCableRotoSenalA_326c20cc71 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal A" ;
    ns1:textoExtracto "9622 Captación: Cable roto señal A. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador." .

ns1:ErrorEnLaActualizacionDeVersionCPLD_f057f63dc9 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD" ;
    ns1:textoExtracto "9621 Error en la actualización de versión CPLD. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión del CPDL en algún regulador o RPS." .

ns1:ErrorEnLaActualizacionDeVersionDSP_d9cd3ba218 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión DSP" ;
    ns1:textoExtracto "9619 Error en la actualización de versión DSP. DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no puede actualizar la versión del DSP en algún regulador o RPS." .

ns1:ErrorEnLaActualizacionDeVersionFPGA_0ba6b7195e a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión FPGA" ;
    ns1:textoExtracto "9620 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS." .

ns1:Fallo24VdcInesperado_41a7cf9b84 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ns1:textoExtracto "9617 Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha detectado una caída en la tensión de control." .

ns1:LazosDeCorrienteEnMismoNodoIncompatibles_8d92ab0fdf a ns1:DiagnosticoFallo ;
    rdfs:label "Lazos de corriente en mismo nodo incompatibles" ;
    ns1:textoExtracto "9618 Lazos de corriente en mismo nodo incompatibles. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Un regulador doble tiene configurados modos incompatibles de control para cada motor." .

