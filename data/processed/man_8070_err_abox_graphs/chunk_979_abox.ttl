@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionDeCableYConexion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cable y conexión" ;
    ns1:solucionaFallo ns1:CableRotoEnLaSenalADelContajeDelRegulador ;
    ns1:textoExtracto "Revisar el cable y la conexión de las entradas de captación. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisionDeCableYConexionParaLaSenalB a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cable y conexión para la señal B" ;
    ns1:solucionaFallo ns1:CableRotoEnLaSenalBDelContajeDelRegulador ;
    ns1:textoExtracto "Revisar el cable y la conexión de las entradas de captación. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de Captación" ;
    ns1:textoExtracto "9623 Captación: Cable roto señal B." .

ns1:CableRotoEnLaSenalADelContajeDelRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Cable roto en la señal A del contaje del regulador" ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación." .

ns1:CableRotoEnLaSenalBDelContajeDelRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Cable roto en la señal B del contaje del regulador" ;
    ns1:textoExtracto "9623 Captación: Cable roto señal B." .

