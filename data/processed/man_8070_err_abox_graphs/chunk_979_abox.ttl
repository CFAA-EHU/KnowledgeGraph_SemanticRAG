@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Senal_GRAY a ns1:Parametro ;
    rdfs:label "Señal GRAY" ;
    ns1:monitoreaParametro ns1:Sistema_Inductosyn ;
    ns1:textoExtracto "señal GRAY del transductor inductosyn/resolver ausente" .

ns1:Transductor_Inductosyn_Resolver a ns1:ComponenteElectrico ;
    rdfs:label "Transductor INDUCTOSYN/Resolver" ;
    ns1:textoExtracto "transductor inductosyn/resolver" ;
    ns1:tieneComponente ns1:Sistema_Inductosyn .

ns1:Error_9635_Inductosyn a ns1:AvisoSeguridad ;
    rdfs:label "Error 9635: INDUCTOSYN - señal GRAY no presente" ;
    ns1:identificador "9635" ;
    ns1:textoExtracto "9635 INDUCTOSYN: señal GRAY no presente. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal GRAY del transductor inductosyn/resolver ausente." .

ns1:Sistema_Inductosyn a ns1:Sistema ;
    rdfs:label "Sistema INDUCTOSYN" ;
    ns1:activaAlarma ns1:Error_9635_Inductosyn ;
    ns1:textoExtracto "señal GRAY del transductor inductosyn/resolver" .

