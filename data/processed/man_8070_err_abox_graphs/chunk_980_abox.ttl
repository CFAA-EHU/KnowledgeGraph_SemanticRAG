@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisarElCableYLaConexionDeLasEntradasDeCaptacion_639bac0979 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el cable y la conexión de las entradas de captación" ;
    ns1:solucionaFallo ns1:CaptacionCableRotoSenalAL_ff3b0c1807,
        ns1:CaptacionCableRotoSenalB_6a83a9f7d3,
        ns1:CaptacionCableRotoSenalI0_b53e211d02 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cable y la conexión de las entradas de captación." .

ns1:RevisarElConexionadoYElNivelDeLasSenalesProporcionadasPorElCaptador_278f635890 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar el conexionado y el nivel de las señales proporcionadas por el captador" ;
    ns1:solucionaFallo ns1:CaptacionSobrecorrienteOCortocircuito_56eaf702ba ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador." .

ns1:ReviseLaDocumentacionDelEncoderParaDeterminarElOrigenDeLaAlarma_32e8a6707c a ns1:TareaMantenimiento ;
    rdfs:label "Revise la documentación del encóder para determinar el origen de la alarma" ;
    ns1:solucionaFallo ns1:CaptacionRecibidaSenalDeAlarma_1a5a9b8ad4 ;
    ns1:textoExtracto "SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado." .

ns1:CaptacionCableRotoSenalAL_ff3b0c1807 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal AL" ;
    ns1:textoExtracto "9625 Captación: Cable roto señal AL. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal AL del contaje del regulador. El regulador no recibe la señal A de la captación." .

ns1:CaptacionCableRotoSenalB_6a83a9f7d3 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal B" ;
    ns1:textoExtracto "9623 Captación: Cable roto señal B. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal B de la captación." .

ns1:CaptacionCableRotoSenalI0_b53e211d02 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal I0" ;
    ns1:textoExtracto "9624 Captación: Cable roto señal I0. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal I0 del contaje del regulador. El regulador no recibe la señal A de la captación." .

ns1:CaptacionRecibidaSenalDeAlarma_1a5a9b8ad4 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Recibida señal de alarma" ;
    ns1:textoExtracto "9627 Captación: Recibida señal de alarma. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo." .

ns1:CaptacionSobrecorrienteOCortocircuito_56eaf702ba a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Sobrecorriente o cortocircuito" ;
    ns1:textoExtracto "9626 Captación: Sobrecorriente o cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador." .

