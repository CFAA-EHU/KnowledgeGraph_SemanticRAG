@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionFrecuenciaDeContajeExcesiva a ns1:AvisoSeguridad ;
    rdfs:label "Captación: Frecuencia de contaje excesiva" ;
    ns1:textoExtracto "9628 Captación: Frecuencia de contaje excesiva." .

ns1:RevisionDeDocumentacionDelEncoderParaDeterminarOrigenDeLaAlarma a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de documentación del encoder para determinar origen de la alarma" ;
    ns1:solucionaFallo ns1:FalloEncoderMalFuncionamiento ;
    ns1:textoExtracto "Revise la documentación del encóder para determinar el origen de la alarma." .

ns1:SistemaPrincipal a ns1:Sistema ;
    rdfs:label "Sistema principal" ;
    ns1:monitoreaParametro ns1:VelocidadDelEje_b18317263a ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:FalloEncoderMalFuncionamiento a ns1:DiagnosticoFallo ;
    rdfs:label "Señal de alarma del encóder por mal funcionamiento" ;
    ns1:textoExtracto "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo." .

ns1:VelocidadDelEje_b18317263a a ns1:Parametro ;
    rdfs:label "Velocidad del eje" ;
    ns1:textoExtracto "La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal" .

