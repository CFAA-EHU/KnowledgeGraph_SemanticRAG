@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_9638 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9638: INDUCTOSYN - Error desconocido" ;
    ns1:solucionaFallo ns1:Solucion_9638 ;
    ns1:textoExtracto "9638 INDUCTOSYN: Error desconocido. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El módulo ABSIND ha generado un error desconocido. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND." .

ns1:Error_9639 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9639: INDUCTOSYN - Inconsistencia parámetro SSITYPE" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:solucionaFallo ns1:Solucion_9639 ;
    ns1:textoExtracto "9639 INDUCTOSYN: Inconsistencia parámetro SSITYPE con captador conectado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:activaAlarma ns1:Error_9638,
        ns1:Error_9639 ;
    ns1:textoExtracto "El módulo ABSIND ha generado un error desconocido. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND." ;
    ns1:tieneComponente ns1:Dipswitch_S50 .

ns1:Parametro_SSITYPE a ns1:Parametro ;
    rdfs:label "Parámetro SSITYPE" ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." ;
    ns1:valor "Inconsistencia con dipswitch S50" .

ns1:Solucion_9638 a ns1:TareaMantenimiento ;
    rdfs:label "Sustitución del módulo ABSIND (Error 9638)" ;
    ns1:requiereMantenimiento ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Si el error es repetitivo y persiste pruebe a sustituir el módulo ABSIND asociado a esa captación." .

ns1:Solucion_9639 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del dipswitch S50 (Error 9639)" ;
    ns1:requiereMantenimiento ns1:Dipswitch_S50 ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND." .

ns1:Dipswitch_S50 a ns1:ComponenteElectrico ;
    rdfs:label "Dipswitch S50" ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND. Revise el estado del dipswitch S50 del módulo ABSIND." .

