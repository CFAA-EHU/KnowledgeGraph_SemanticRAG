@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarConexionYCableado_7876a098c1 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión y cableado" ;
    ns1:solucionaFallo ns1:ErrorLeyendoInformacionDelModuloABSIND_fbb66b6b58 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ErrorLeyendoInformacionDelModuloABSIND_fbb66b6b58 a ns1:DiagnosticoFallo ;
    rdfs:label "Error leyendo información del módulo ABSIND" ;
    ns1:textoExtracto "9632 ABSIND: Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

