@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9642_CaptacionDigitalFagor a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9642: Captación digital Fagor - Error en pista absoluta"@es ;
    ns1:identificador "9642" ;
    ns1:solucionaFallo ns1:Fallo_PerdidaContaje_9642,
        ns1:Fallo_PosicionAbsolutaNoCalculable_9642,
        ns1:Fallo_SenalBaja_9642 ;
    ns1:textoExtracto "9642 Captación digital Fagor. Error en la pista absoluta."@es .

ns1:TareaMantenimiento_ComprobacionTolerancias_9642 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de tolerancias de montaje"@es ;
    ns1:textoExtracto "Comprobar las tolerancias de montaje."@es .

ns1:TareaMantenimiento_ComprobacionVelocidadEncoder_9642 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de velocidad del encóder"@es ;
    ns1:requiereMantenimiento ns1:Sensor_Encoder_9642 ;
    ns1:textoExtracto "Comprobar que el encóder [...] está trabajando a una velocidad apropiada."@es .

ns1:TareaMantenimiento_LimpiezaRegla_9642 a ns1:TareaMantenimiento ;
    rdfs:label "Limpieza de cristal/cinta de acero de la regla"@es ;
    ns1:requiereMantenimiento ns1:Componente_Regla_9642 ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:Componente_CintaAcero_9642 a ns1:ComponenteMecanico ;
    rdfs:label "Cinta de acero de la regla"@es ;
    ns1:textoExtracto "Limpiar [...] la cinta de acero de la regla."@es .

ns1:Componente_Cristal_9642 a ns1:ComponenteMecanico ;
    rdfs:label "Cristal de protección de la regla"@es ;
    ns1:textoExtracto "Limpiar el cristal [...] de la regla."@es .

ns1:Componente_Regla_9642 a ns1:ComponenteMecanico ;
    rdfs:label "Regla de medición (cristal/cinta de acero)"@es ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es ;
    ns1:tieneComponente ns1:Componente_CintaAcero_9642,
        ns1:Componente_Cristal_9642 .

ns1:Fallo_PerdidaContaje_9642 a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de contaje en sistema de captación digital"@es ;
    ns1:textoExtracto "Pérdida de contaje."@es .

ns1:Fallo_PosicionAbsolutaNoCalculable_9642 a ns1:DiagnosticoFallo ;
    rdfs:label "Captador no puede calcular posición absoluta"@es ;
    ns1:textoExtracto "El captador no puede calcular la posición absoluta."@es .

ns1:Fallo_SenalBaja_9642 a ns1:DiagnosticoFallo ;
    rdfs:label "Señal analógica < 0.20 Vpp en captación digital"@es ;
    ns1:identificador "< 0.20 Vpp" ;
    ns1:textoExtracto "La señal analógica < 0,20 Vpp."@es .

ns1:Parametro_Velocidad_9642 a ns1:Parametro ;
    rdfs:label "Velocidad de operación del encóder"@es ;
    ns1:textoExtracto "trabajando a una velocidad apropiada"@es .

ns1:Sensor_Encoder_9642 a ns1:Sensor ;
    rdfs:label "Encóder del sistema de captación digital Fagor"@es ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad_9642 ;
    ns1:textoExtracto "Comprobar que el encóder [...] está trabajando a una velocidad apropiada."@es .

