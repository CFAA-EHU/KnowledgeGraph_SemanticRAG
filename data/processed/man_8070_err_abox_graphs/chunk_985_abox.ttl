@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9643 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9643: Captación digital Fagor - Error en la CPU"@es ;
    ns1:identificador "9643" ;
    ns1:solucionaFallo ns1:CabezaRegla,
        ns1:Encoder ;
    ns1:textoExtracto "9643 Captación digital Fagor. Error en la CPU. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error9644 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9644: Captación digital Fagor - Error de potenciómetros de ajuste"@es ;
    ns1:identificador "9644" ;
    ns1:solucionaFallo ns1:CabezaRegla,
        ns1:Encoder ;
    ns1:textoExtracto "9644 Captación digital Fagor. Error de los potenciómetros de ajuste. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error9645 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9645: Captación digital Fagor - Error del captador de imagen (CCD)"@es ;
    ns1:identificador "9645" ;
    ns1:solucionaFallo ns1:CCD,
        ns1:CabezaRegla,
        ns1:Encoder,
        ns1:LED ;
    ns1:textoExtracto "9645 Captación digital Fagor. Error del captador de imagen (CCD). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode). SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar las tolerancias de montaje. • Limpiar el cristal o la cinta de acero de la regla. • Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error9646 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9646: Captación digital Fagor - Tensión de alimentación fuera de rango"@es ;
    ns1:identificador "9646" ;
    ns1:solucionaFallo ns1:CableAlimentacionEncoder ;
    ns1:textoExtracto "9646 Captación digital Fagor. Tensión de alimentación fuera de rango. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V. SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado."@es .

ns1:TensionAlimentacion_9646 a ns1:Parametro ;
    rdfs:label "Tensión de alimentación (Error 9646)"@es ;
    ns1:monitoreaParametro ns1:CableAlimentacionEncoder ;
    ns1:textoExtracto "La tensión de alimentación debe estar entre **5,3 V y 4,1 V**"@es ;
    ns1:valor "5.3 V - 4.1 V" .

ns1:CCD a ns1:Sensor ;
    rdfs:label "Captador de imagen (CCD)"@es ;
    ns1:textoExtracto "Error del captador de imagen (CCD)"@es .

ns1:LED a ns1:ComponenteElectrico ;
    rdfs:label "LED (Light Emitting Diode)"@es ;
    ns1:textoExtracto "el CCD (Charge Coupled Device) o el **LED (Light Emitting Diode)**"@es .

ns1:CableAlimentacionEncoder a ns1:ComponenteElectrico ;
    rdfs:label "Cable de alimentación del encóder/regla"@es ;
    ns1:textoExtracto "Comprobar que el **cable de alimentación del encóder o de la regla** no está deteriorado"@es .

ns1:CabezaRegla a ns1:ComponenteElectrico ;
    rdfs:label "Cabeza de la regla"@es ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado"@es .

ns1:Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder"@es ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado"@es .

