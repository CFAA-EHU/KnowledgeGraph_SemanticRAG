@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorParametrosCaptacion_9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parámetros en captación digital"@es ;
    ns1:identificador "9647" ;
    ns1:solucionaFallo ns1:RestauracionConfiguracion_9647 ;
    ns1:textoExtracto "Error de parámetros en captación."@es .

ns1:ErrorTensionAlimentacion_9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de tensión de alimentación en captación digital"@es ;
    ns1:identificador "9647" ;
    ns1:solucionaFallo ns1:ComprobacionCableAlimentacion_9647,
        ns1:ComprobacionConexionCableado_9647 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es .

ns1:CableAlimentacionEncoder_9647 a ns1:ComponenteElectrico ;
    rdfs:label "Cable de alimentación del encóder/regla (sistema 9647)"@es ;
    ns1:textoExtracto "cable de alimentación del encóder o de la regla"@es .

ns1:CableadoConexion_9647 a ns1:ComponenteElectrico ;
    rdfs:label "Cableado de conexión del sistema de captación 9647"@es ;
    ns1:textoExtracto "longitud del cable [...] conexión del cableado"@es .

ns1:ComprobacionCableAlimentacion_9647 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable de alimentación del encóder/regla"@es ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionDigital_9647 ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado."@es .

ns1:ComprobacionConexionCableado_9647 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar longitud y conexión del cableado"@es ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionDigital_9647 ;
    ns1:textoExtracto "Comprobar que la longitud del cable es adecuada y la conexión del cableado es satisfactoria."@es .

ns1:RestauracionConfiguracion_9647 a ns1:TareaMantenimiento ;
    rdfs:label "Restaurar configuración del sistema de captación"@es ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionDigital_9647 ;
    ns1:textoExtracto "Pérdida de la configuración del [sistema]"@es .

ns1:SistemaCaptacionDigital_9647 a ns1:Sistema ;
    rdfs:label "Sistema de captación digital Fagor"@es ;
    ns1:identificador "9647" ;
    ns1:textoExtracto "9647 Captación digital Fagor. Error de parámetros en captación."@es ;
    ns1:tieneComponente ns1:CableAlimentacionEncoder_9647,
        ns1:CableadoConexion_9647 .

