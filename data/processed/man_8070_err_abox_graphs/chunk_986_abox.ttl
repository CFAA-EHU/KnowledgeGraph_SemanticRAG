@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContactarseConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "contactarse con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

