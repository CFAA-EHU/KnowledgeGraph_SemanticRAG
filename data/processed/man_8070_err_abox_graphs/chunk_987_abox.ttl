@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarCableYConexionEntreElModuloABSINDYElTransductorInductosynResolver a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable y conexión entre el módulo ABSIND y el transductor inductosyn/resolver" ;
    ns1:solucionaFallo ns1:TransductorInductosynNoEstableEnPowerON ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver." .

ns1:ComprobarConexionesDeTierraEnElArmario a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexiones de tierra en el armario" ;
    ns1:solucionaFallo ns1:TransductorInductosynNoEstableEnPowerON ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:NoMoverElEjeDuranteLaInicializacionDelModuloABSIND a ns1:AccionProhibida ;
    rdfs:label "No mover el eje durante la inicialización del módulo ABSIND" ;
    ns1:mitigaRiesgo ns1:TransductorInductosynNoEstableEnPowerON ;
    ns1:solucionaFallo ns1:TransductorInductosynNoEstableEnPowerON ;
    ns1:textoExtracto "Comprobar que el eje no se mueve durante el arranque o inicialización del módulo ABSIND." .

ns1:TransductorInductosynNoEstableEnPowerON a ns1:DiagnosticoFallo ;
    rdfs:label "Transductor inductosyn no estable en Power-ON" ;
    ns1:textoExtracto "La posición leída durante la inicialización del módulo ABSIND no es estable." .

