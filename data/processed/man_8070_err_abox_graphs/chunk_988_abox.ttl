@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarValoresDeGananciaYFaseDelModuloABSIND_3c48d0bd5b a ns1:AccionProhibida ;
    rdfs:label "Comprobar valores de ganancia y fase del módulo ABSIND" ;
    ns1:solucionaFallo ns1:INDUCTOSYNErrorDesconocido ;
    ns1:textoExtracto "• Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:PonerseEnContactoConFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:SustituirModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND" ;
    ns1:solucionaFallo ns1:INDUCTOSYNErrorDesconocido ;
    ns1:textoExtracto "• Si el error persiste y no se puede eliminar con las acciones anteriores, pruebe a sustituir el módulo ABSIND asociado a esa captación." .

ns1:INDUCTOSYNErrorDesconocido a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Error desconocido" ;
    ns1:textoExtracto "9638 INDUCTOSYN: Error desconocido." .

