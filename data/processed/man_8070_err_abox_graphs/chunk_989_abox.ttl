@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:INDUCTOSYNErrorDesconocido_f381796b5f a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Error desconocido" ;
    ns1:textoExtracto "9638 INDUCTOSYN: Error desconocido. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:INDUCTOSYNInconsistenciaParametroSSITYPEConCaptadorConectado a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Inconsistencia parámetro SSITYPE con captador conectado" ;
    ns1:textoExtracto "9639 INDUCTOSYN: Inconsistencia parámetro SSITYPE con captador conectado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:ParametroSSITYPE a ns1:Parametro ;
    rdfs:label "Parámetro SSITYPE" ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." .

ns1:PongaseEnContactoConFagorAutomation_4fdb3e53af a ns1:AccionProhibida ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:ReviseElEstadoDelDipswitchS50 a ns1:AccionProhibida ;
    rdfs:label "Revise el estado del dipswitch S50" ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." .

ns1:SustituirModuloABSIND_8aab5205c2 a ns1:AccionProhibida ;
    rdfs:label "Sustituir módulo ABSIND" ;
    ns1:textoExtracto "Si el error es repetitivo y persiste pruebe a sustituir el módulo ABSIND asociado a esa captación." .

