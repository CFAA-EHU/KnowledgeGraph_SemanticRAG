@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnLaPistaAbsolutaDuranteElArranqueOFuncionamientoHabitualDelSistema a ns1:AccionProhibida ;
    rdfs:label "Error en la pista absoluta durante el arranque o funcionamiento habitual del sistema" ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "9642 Captación digital Fagor. Error en la pista absoluta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:TareaMantenimiento_07c93a1349 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de solución para error en la captación digital" ;
    ns1:solucionaFallo ns1:ErrorEnLaCaptacionDigital ;
    ns1:textoExtracto "Las posibles soluciones son las siguientes: • Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. • Comprobar las tolerancias de montaje. • Limpiar el cristal o la cinta de acero de la regla." .

ns1:ErrorEnLaCaptacionDigital a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la captación digital" ;
    ns1:textoExtracto "Las posibles causas son las siguientes: • El captador no puede calcular la posición absoluta. • Pérdida de contaje. • La señal analógica < 0,20 Vpp." .

