@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9710 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento del eje (MAXFLWE)"@es ;
    ns1:identificador "9710" ;
    ns1:solucionaFallo ns1:Solucion_RevisarParametrosMAXFLWE ;
    ns1:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE). Posible ajuste inadecuado del eje, falta alguna habilitación, fallo en el motor o regulador, sistema de captación y/o mecánica."@es .

ns1:Fallo_9711 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de carrera positivo alcanzado"@es ;
    ns1:identificador "9711" ;
    ns1:solucionaFallo ns1:Solucion_RevisarLimitesCarrera ;
    ns1:textoExtracto "El eje ha alcanzado el límite de recorrido positivo."@es .

ns1:Fallo_9712 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de carrera negativo alcanzado"@es ;
    ns1:identificador "9712" ;
    ns1:solucionaFallo ns1:Solucion_RevisarLimitesCarrera ;
    ns1:textoExtracto "El eje ha alcanzado el límite de recorrido negativo."@es .

ns1:Fallo_9715 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en cálculo de I0s codificados"@es ;
    ns1:identificador "9715" ;
    ns1:textoExtracto "Los I0s latcheados no son coherentes."@es .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "Parámetro MAXFLWE (error de seguimiento permitido)"@es ;
    ns1:identificador "MAXFLWE" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "parámetro MAXFLWE"@es .

ns1:MotorEje a ns1:ComponenteMecanico ;
    rdfs:label "Motor del eje"@es ;
    ns1:textoExtracto "fallo en el motor"@es .

ns1:ReguladorEje a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del eje"@es ;
    ns1:textoExtracto "regulador"@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación y detección"@es ;
    ns1:textoExtracto "sistema de captación y/o mecánica"@es ;
    ns1:tieneComponente ns1:MotorEje,
        ns1:ReguladorEje .

ns1:Solucion_RevisarParametrosMAXFLWE a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros MAXFLWE, regulador, motor y sistema de captación"@es ;
    ns1:textoExtracto "Revisar los parámetros, ajuste, conexionado, estado del regulador, sistema de captación, motor, etc."@es .

ns1:Solucion_RevisarLimitesCarrera a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de límites de carrera"@es ;
    ns1:textoExtracto "Revisar los límites de carrera."@es .

