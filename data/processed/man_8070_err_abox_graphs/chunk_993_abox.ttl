ns1:LaTensionDeAlimentacionDebeEstarEntre53VY41V a ns1:DiagnosticoFallo ;
    rdfs:label "La tensión de alimentación debe estar entre 5,3 V y 4,1 V" ;
    ns1:textoExtracto "CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V." .

