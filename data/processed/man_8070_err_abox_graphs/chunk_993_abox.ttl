    rdfs:label "Comprobar longitud y conexión del cable" ;
    ns1:solucionaFallo ns1:LaTensionDeAlimentacionDebeEstarEntre53VY41V ;
    ns1:textoExtracto "• Comprobar que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:ComprobarQueElCableDeAlimentacionDelEncoderODeLaReglaNoEstaDeteriorado a ns1:AccionProhibida ;
    rdfs:label "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado" ;
    ns1:textoExtracto "• Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado." .

ns1:ComprobarQueLaLongitudDelCableEsAdecuadaYLaConexionDelCableadoEsSatisfactoria a ns1:AccionProhibida ;
    rdfs:label "Comprobar que la longitud del cable es adecuada y la conexión del cableado es satisfactoria" ;
    ns1:textoExtracto "• Comprobar que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:ErrorDeParametrosEnCaptacionDigitalFagor_e33f2e7aaf a ns1:AccionProhibida ;
