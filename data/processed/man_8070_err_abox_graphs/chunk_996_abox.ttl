@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_Motor a ns1:ComponenteElectrico ;
    rdfs:label "Motor eléctrico" ;
    ns1:monitoreaParametro ns1:Parametro_GP7,
        ns1:Parametro_GP8 ;
    ns1:textoExtracto "Protección I²t del motor" .

ns1:Fallo_9722 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor" ;
    ns1:identificador "9722" ;
    ns1:solucionaFallo ns1:CicloDeTrabajoInadecuadoParaElMotor ;
    ns1:textoExtracto "Sobrecarga en el motor. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor. SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un motor de mayor par." .

ns1:Fallo_9723 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de saturación de par" ;
    ns1:identificador "9723" ;
    ns1:solucionaFallo ns1:BloqueoMecanicoDelAccionamiento ;
    ns1:textoExtracto "Error de saturación de par. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Las posibles causas son las siguientes: • El accionamiento ha sufrido un bloqueo y no ha podido girar con libertad. • Con par motor muy elevado la velocidad de giro no ha superado GP8 durante un tiempo superior a GP7." .

ns1:BloqueoMecanicoDelAccionamiento a ns1:AccionProhibida ;
    rdfs:label "Bloqueo mecánico del accionamiento" ;
    ns1:textoExtracto "El accionamiento ha sufrido un bloqueo y no ha podido girar con libertad." .

ns1:CicloDeTrabajoInadecuadoParaElMotor a ns1:AccionProhibida ;
    rdfs:label "Ciclo de trabajo inadecuado para el motor" ;
    ns1:textoExtracto "El ciclo de trabajo es demasiado exigente para el motor." .

ns1:Parametro_GP7 a ns1:Parametro ;
    rdfs:label "Tiempo límite de saturación de par (GP7)" ;
    ns1:identificador "GP7" ;
    ns1:textoExtracto "tiempo superior a GP7" ;
    ns1:valor "GP7" .

ns1:Parametro_GP8 a ns1:Parametro ;
    rdfs:label "Velocidad mínima de giro (GP8)" ;
    ns1:identificador "GP8" ;
    ns1:textoExtracto "velocidad de giro no ha superado GP8" ;
    ns1:valor "GP8" .

