ns1:Error24624 a ns1:AvisoSeguridad ;
    rdfs:label "La configuración del módulo Localbus no coincide en el módulo %u"@es ;
    ns1:identificador "24624" ;
    ns1:textoExtracto "24624 La configuración del módulo Localbus no coincide en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error24625 a ns1:AvisoSeguridad ;
    rdfs:label "Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados"@es ;
    ns1:identificador "24625" ;
    ns1:textoExtracto "24625 Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que"@es .

ns1:Error2492 a ns1:AvisoSeguridad ;
    rdfs:label "Comodín no permitido fuera de la subrutina asociada a #CAX"@es ;
    ns1:identificador "2492" ;
    ns1:textoExtracto "2492 Comodín no permitido fuera de la subrutina asociada a #CAX. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB). SOLUCIÓN Revisar la programación. No se permite el uso de estos comodines fuera de la subrutina asociada a #CAX."@es .

ns1:Error2493 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "#FACE/CYL: se espera 'Q', programación del origen del eje C, en grados"@es,
        "Error 2493: Origen de eje C no programado en #FACECYL"@es ;
    ns1:identificador "2493" ;
    ns1:monitoreaParametro ns1:EjeC ;
    ns1:solucionaFallo ns1:Instruccion_FACECYL ;
    ns1:textoExtracto "2493 #FACE/CYL: se espera 'Q', programación del origen del eje C, en grados. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el origen del eje C en la instrucción #FACECYL. SOLUCIÓN Revisar la programación."@es,
        "DETECCIÓN Durante la ejecución. CAUSA No se ha programado el origen del eje C en la instrucción #FACECYL. SOLUCIÓN Revisar la programación."@es .

ns1:Error4200 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el canal cíclico de Sercos" ;
    ns1:identificador "4200" ;
    ns1:textoExtracto "4200 'Error en el canal cíclico de Sercos' [...] Error en los procesos de lectura o escritura del canal cíclico (telegrama inválido o fase distinta de 4)." .

ns1:Error4501 a ns1:AvisoSeguridad ;
    rdfs:label "Error en comando Mechatrolink"@es ;
    ns1:identificador "4501" ;
    ns1:solucionaFallo ns1:FalloComandoMechatrolink_4501 ;
    ns1:textoExtracto "4501 'Error en comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado."@es .

ns1:Error4614 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus indefinido"@es ;
    ns1:identificador "4614" ;
    ns1:textoExtracto "4614 Error bus indefinido. DETECCIÓN Durante el arranque del CNC, durante la ejecución o tras un reset. CAUSA Se ha producido un error inesperado en el bus Sercos III. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Error4615 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus timeout"@es ;
    ns1:identificador "4615" ;
    ns1:textoExtracto "4615 Error bus timeout. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error de timeout durante el arranque o reset del bus de comunicaciones. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error4630 a ns1:AvisoSeguridad ;
    rdfs:label "Error de configuración del número de serie"@es ;
    ns1:identificador "4630" ;
    ns1:textoExtracto "4630 Error de configuración del número de serie. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error en la lectura de los números de serie de un nodo Sercos III o números de serie incorrectos. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Error6026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en la COMPCI" ;
    ns1:identificador "6026" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Consultar con el servicio de asistencia técnica" ;
            ns1:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica." ] ;
    ns1:textoExtracto "Error de hardware en la COMPCI. DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de la COMPCI. En el arranque se realizan los siguientes test; Flash, RAM común, RAM externa, RAM interna y controlador CAN." .

ns1:Error6027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en nodo remoto CAN" ;
    ns1:identificador "6027" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Consultar con el servicio de asistencia técnica" ;
            ns1:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica." ] ;
    ns1:textoExtracto "Error de hardware en nodo remoto CAN. DETECCIÓN Durante el arranque del sistema. CAUSA Error en el test de hardware de los nodos remotos. En el arranque se realizan los siguientes test; Flash, RAM y controlador CAN." .

ns1:Error7023 a ns1:DiagnosticoFallo ;
    rdfs:label "'En modo carga:M6 obligatoria'",
        "Error 7023: 'En modo carga: M6 obligatoria'" ;
    ns1:identificador "7023" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_7023 ;
    ns1:textoExtracto "7023 'En modo carga:M6 obligatoria' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. Hay programadas dos herramientas consecutivas sin M06 SOLUCIÓN Programar M06 detrás de cada herramienta.",
        "DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga." .

ns1:Error7029 a ns1:Alarma ;
    rdfs:label "Error 7029: 'Gestor de herramientas en estado de error'" ;
    ns1:identificador "7029" ;
    ns1:textoExtracto "'La operación no pudo efectuarse:Gestor de herramientas en estado de error' DETECCIÓN Durante la ejecución. CAUSA Almacén en estado de emergencia. El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra. SOLUCIÓN Corregir en el programa de PLC la maniobra de cambio de herramienta." .

ns1:Error8051_RestauracionSesionUsuario a ns1:DiagnosticoFallo ;
