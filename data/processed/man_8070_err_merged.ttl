ns1:Error9724FalloEnRampaDeEmergenciaDuranteFrenada a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9724: Fallo en rampa de emergencia durante frenada"@es ;
    ns1:identificador "9724" ;
    ns1:monitoreaParametro ns1:GP7TiempoLimiteParaSuperacionDeVelocidad,
        ns1:GP8VelocidadDeGiroLimite ;
    ns1:solucionaFallo ns1:AlarmaPorParMotorElevadoSinSuperacionDeGP8_288561125d ;
    ns1:textoExtracto "Error en el seguimiento de la rampa de emergencia en frenada. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema."@es .

ns1:ErrorAlRegistrarVariablesDRV a ns1:AvisoSeguridad ;
    rdfs:label "Error al registrar variables DRV" ;
    ns1:documentadoEn ns1:VariablesDRV ;
    ns1:identificador "0107" ;
    ns1:textoExtracto "0107 'Error al registrar variables DRV' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El CNC ha generado un error al intentar registrar las variables definidas en la tabla de parámetros OEM." .

ns1:ErrorAlSeleccionarFrecuenciaDeTrabajoDelBUSCAN6005 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al seleccionar frecuencia de trabajo del BUS CAN (6005)"@es ;
    ns1:documentadoEn ns1:Pagina_187 ;
    ns1:identificador "6005" ;
    ns1:textoExtracto """\r
'Error al seleccionar frecuencia de trabajo del BUS CAN'\r
DETECCIÓN Durante el arranque del sistema.\r
CAUSA Uno o varios nodos no se sintonizan a la frecuencia parametrizada.\r
SOLUCIÓN Realizar las siguientes comprobaciones:\r
• Comprobar que la longitud del cable CAN es la adecuada para la frecuencia.\r
• Comprobar en el modo diagnosis que el CNC reconoce todos los módulos.\r
• Utilizar la herramienta itfcCAN.exe para comprobar el bus CAN (sólo servicio de asistencia técnica)."""@es .

ns1:ErrorAnilloSercosSync a ns1:AvisoSeguridad ;
    rdfs:label "Error en anillo Sercos (sincronismo)" ;
    ns1:mitigaRiesgo ns1:RevisarConexionSercosIII ;
    ns1:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:ErrorBusMensajeNoRecibidoEnFase0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus mensaje no recibido en fase 0",
        "Error 4612: Bus mensaje no recibido en fase 0"@es ;
    ns1:identificador "4612" ;
    ns1:solucionaFallo ns1:BusSercosIII_32b253e1c9 ;
    ns1:textoExtracto "4612 Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado."@es .

ns1:ErrorBusSercosFase4 a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de fase en bus Sercos" ;
    ns1:mitigaRiesgo ns1:GarantizarConectividadAnillo ;
    ns1:textoExtracto "Error en el bus Sercos que provoca pérdida de fase 4." .

ns1:ErrorCANopen_EmergenciaExterna a ns1:AvisoSeguridad ;
    rdfs:label "Error CANopen: Emergencia externa"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Report de nodo CANopen: 'Emergencia externa.' [...] Este error indica que un nodo CANopen ha enviado un mensaje de emergencia."@es .

ns1:ErrorCANopen_EmergenciaFabricante a ns1:AvisoSeguridad ;
