ns1:ErrorInicializacionAnilloSercos_4000_1 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la inicialización del anillo Sercos (Clase 0)"@es ;
    ns1:identificador "4000(1)" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_PlacaSercosNoDetectada ;
    ns1:textoExtracto "4000(1) 'Error en la inicialización del anillo Sercos' CLASE 0. CAUSA Error en la fase inicialización del chip. El CNC no detecta la placa Sercos u overflow en la DPRAM del SERCON por un número excesivo de ejes y datos a transmitir en el canal cíclico."@es .

ns1:ErrorInicializacionAnilloSercos_4000_2 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la inicialización del anillo Sercos (Clase 1)"@es ;
    ns1:identificador "4000(2)" ;
    ns1:textoExtracto "4000(2) 'Error en la inicialización del anillo Sercos' CLASE 1. TRANSICIÓN 0. CAUSA Timeout en la petición de inicialización del anillo Sercos."@es .

ns1:ErrorInicializacionModulosRemotos a ns1:DiagnosticoFallo ;
    rdfs:label "Error de inicialización: Orden incorrecto de comandos en router de recursos" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos." .

ns1:ErrorJMP a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta no existe (=JMP etiqueta)" ;
    ns1:textoExtracto "etiquete pero ésta no existe (=JMP etiqueta). SOLUCIÓN Revisar el nombre de las etiquetas y los saltos a las etiquetas." .

ns1:ErrorLecturaHerramienta_1512 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1512: Lectura de herramienta en posición inválida" ;
    ns1:identificador "1512" ;
    ns1:monitoreaParametro ns1:Variable_VTM_T ;
    ns1:textoExtracto "CAUSA: El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe. SOLUCIÓN: Sólo es posible leer la herramienta que está en una posición válida del almacén." .

