    ns1:textoExtracto "'La herramienta pedida es la herramienta activa de otro canal'" .

ns1:Error8200FalloDelLexerAlReconocerEnteros a ns1:AvisoSeguridad ;
    rdfs:label "Error 8200: Fallo del lexer al reconocer enteros"@es ;
    ns1:identificador "8200" ;
