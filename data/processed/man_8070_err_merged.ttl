ns1:Error_2347 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2347: 'No se admite perfil PROGTL3 con G91 activa'"@es ;
    ns1:solucionaFallo ns1:Fallo_2347_G91_Activa ;
    ns1:textoExtracto "2347 'No se admite perfil PROGTL3 con G91 activa' DETECCIÓN Durante la ejecución. CAUSA No se permite iniciar un perfil con G91 activa, ni programar G91 dentro de un perfil G841-G842."@es .

ns1:Error_2348 a ns1:DiagnosticoFallo ;
    rdfs:label "Macro G8735/G8736/G8725/G8726 doblemente definida" ;
    ns1:identificador "2348" ;
    ns1:textoExtracto "2348 'Macro G8735/G8736/G8725/G8726 doblemente definida' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir una nueva macro sin finalizar la anterior. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ns1:Error_2349 a ns1:DiagnosticoFallo ;
    rdfs:label "Inicio de perfil G841/G842 doblemente definido" ;
    ns1:identificador "2349" ;
    ns1:textoExtracto "2349 'Inicio de perfil G841/G842 doblemente definido' DETECCIÓN Durante la ejecución. CAUSA Se ha empezado a definir un nuevo perfil sin finalizar el anterior. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de los perfiles." .

ns1:Error_2350 a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera final de macro: G8738/G8734/G8728/G8724" ;
    ns1:identificador "2350" ;
    ns1:textoExtracto "2350 Se espera final de macro: G8738/G8734/G8728/G8724 DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado el final del programa sin finalizar la macro definida. SOLUCIÓN Revisar la programación. Finalizar correctamente la definición de las macros." .

ns1:Error_2351 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado perfil" ;
    ns1:identificador "2351" ;
    ns1:textoExtracto "2351 'No se ha programado perfil' DETECCIÓN Durante la ejecución. CAUSA Falta programar algún perfil en la macro ProGTL3. SOLUCIÓN Para ejecutar correctamente la macro es obligatorio definir todos los perfiles." .

ns1:Error_2352 a ns1:DiagnosticoFallo ;
    rdfs:label "Ente sin inicializar" ;
    ns1:identificador "2352" ;
    ns1:textoExtracto "2352 'Ente sin inicializar' DETECCIÓN Durante la ejecución. CAUSA El programa ha intentado utilizar un ente no inializado. SOLUCIÓN Antes de utilizar un ente, éste debe estar previamente inicializado." .

ns1:Error_2353 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #LSFIT" ;
    ns1:identificador "2353" ;
    ns1:textoExtracto "2353 Programar #LSFIT [tipo, pLocal <,data1, data2, data3> ] DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ns1:Error_2354 a ns1:DiagnosticoFallo ;
    rdfs:label "#LSFIT, parámetro local no válido" ;
    ns1:identificador "2354" ;
    ns1:textoExtracto "2354 #LSFIT, parámetro local no válido. DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error_2355 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en proceso #LSFIT" ;
    ns1:identificador "2355" ;
    ns1:textoExtracto "2355 'Error en proceso #LSFIT' DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT." .

ns1:Error_2356 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SELECT ORI" ;
    ns1:identificador "2356" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_24023 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Nodos EtherCAT no Fagor. Opción de software no permitida" ;
    ns1:identificador "24023" ;
    ns1:textoExtracto "EtherCAT: Nodos EtherCAT no Fagor. Opción de software no permitida. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA La inicialización de EtherCAT ha detectado algún nodo no Fagor y no está activa la opción de software para conectar nodos de terceros. SOLUCIÓN Quitar los nodos no Fagor del bus EtherCAT o contratar la opción de software para nodos de terceros." .

ns1:Error_2415_PWCTRL_OUT a ns1:AvisoSeguridad ;
    rdfs:label "Error 2415: PWCTRL OUT no permitido sin cabezal master en el canal" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "2415" ;
    ns1:solucionaFallo ns1:ComandoOUTControlDePotencia_c51284f1ad ;
    ns1:textoExtracto "2415 PWCTRL OUT no permitido sin cabezal master en el canal. DETECCIÓN Durante la ejecución. CAUSA El control de potencia se aplica al cabezal master. Se ha intentado activar el control de potencia y no hay un cabezal master activo. SOLUCIÓN Seleccionar un cabezal master (#MASTER) antes de activar el control de potencia." .

ns1:Error_2416_Sintaxis_PWRCTRL a ns1:AvisoSeguridad ;
    rdfs:label "Error 2416: Sintaxis incorrecta en comando #PWRCTRL" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "2416" ;
    ns1:solucionaFallo ns1:ComandoPWRCTRLControlDePotenciaPWM_afe5ba2d4d ;
    ns1:textoExtracto "2416 #PWRCTRL ON [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_2423 a ns1:DiagnosticoFallo ;
    rdfs:label "Error #PIERCING no definido"@es ;
    ns1:solucionaFallo ns1:ComandoPIERCINGOCUTTING_72c10f4d0f,
        ns1:ParametroTTipoDePiercingCutting_0b40909f1f,
        ns1:TablaTecnologica_3286e5ed7a ;
    ns1:textoExtracto "#PIERCING no definido. DETECCIÓN Durante la preparación de bloques. CAUSA El tipo de piercing o cutting es nulo. Falta el parámetro T en la sentencia y no se ha programado previamente un valor de T (tipo)."@es .

ns1:Error_2424 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2424: No hay tabla tecnológica activa (#MATERIAL)"@es ;
    ns1:solucionaFallo ns1:TablaTecnologicaMATERIAL ;
    ns1:textoExtracto "2424 No hay tabla tecnológica activa (#MATERIAL). DETECCIÓN Durante la preparación de bloques. CAUSA Se ha programado el comando #PIERCING y #CUTTING, y no hay ninguna tabla tecnológica activa."@es .

ns1:Error_2425 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2425: Sintaxis incorrecta en PLC"@es ;
    ns1:identificador "2425" ;
    ns1:textoExtracto "2425 #PLC[PLCmark=0/1,PLCmark=0/1,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Error_2437 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2437: Perfil no poligonal en macro G8077" ;
