        "El usuario ha intentado validar una tabla de parámetros máquina mientras hay un programa pieza en ejecución o interrumpido, o hay un movimiento independiente en ejecución."@es ;
    ns1:tieneComponente ns1:Parametro_MAXCOMP,
        ns1:Parametro_MAXGLBP,
        ns1:Parametro_MAXLOCP,
