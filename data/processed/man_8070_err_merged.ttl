ns1:Error_9049 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9049: No hay memoria para recursos registros nuevos"@es ;
    ns1:identificador "9049" ;
    ns1:solucionaFallo ns1:FagorAutomation ;
    ns1:textoExtracto "9049 No hay memoria para recursos registros nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos."@es .

ns1:Error_9050 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9050: No hay memoria para recursos registros de sistema nuevos"@es ;
    ns1:identificador "9050" ;
    ns1:solucionaFallo ns1:FagorAutomation ;
    ns1:textoExtracto "9050 No hay memoria para recursos registros de sistema nuevos. DETECCIÓN Durante la compilación del programa"@es .

ns1:Error_9307 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9307" ;
    ns1:identificador "9307" ;
    ns1:mitigaRiesgo ns1:Parametro_CHTYPE ;
    ns1:textoExtracto "'Con opción de software Motion Control el tipo de canal 'CHTYPE' debe ser de PLC'"@es .

ns1:Error_9308 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error 9308",
        "No se permiten posiciones de compensación fuera del rango del módulo"@es ;
    ns1:identificador "9308" ;
    ns1:solucionaFallo ns1:Parametro_CHTYPE ;
    ns1:textoExtracto "'No se permiten posiciones de compensación fuera del rango del módulo'"@es,
        "Durante la validación de los parámetros máquina. La tabla de compensación de husillo o de compensación cruzada del eje tiene definidas posiciones fuera de los límites del módulo. SOLUCIÓN Definir todas las posiciones dentro de los límites de módulo."@es .

ns1:Error_9309 a ns1:DiagnosticoFallo ;
    rdfs:label "Si el número de almacenes es 0, se deben permitir herramienta de tierra"@es ;
    ns1:identificador "9309" ;
    ns1:solucionaFallo ns1:Parametro_GROUND ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. La máquina no tiene ningún almacén y no admite herramientas de tierra. SOLUCIÓN Para poder cambiar de herramienta en una máquina sin almacenes, la máquina debe admitir herramientas de tierra (parámetro GROUND)."@es .

ns1:Error_9310 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite variar override de cabezal durante roscado si feedforward < 90%"@es ;
    ns1:identificador "9310" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o la ejecución de un roscado G33. No se permite modificar el override del cabezal durante el roscado si el feedforward es menor del 90%, para evitar dañar la rosca. SOLUCIÓN Aumentar el feedforward del cabezal."@es .

ns1:Error_9311 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje TANDEM no puede estar en un grupo MULTIAXIS"@es ;
    ns1:identificador "9311" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o el arranque del CNC. Uno de los ejes forma parte de una pareja tandem y de un grupo MULTIAXIS. SOLUCIÓN Corregir la tabla de ejes tandem y multieje. Un eje sólo puede estar en una de las dos configuraciones."@es .

ns1:Error_9312 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es ;
    ns1:identificador "9312" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o el arranque del CNC. Uno de los ejes forma parte de una pareja gantry y de un grupo MULTIAXIS."@es .

ns1:Error_9337 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9337: Sercos posición no funciona con LOOPTIME superior a 8 ms" ;
    ns1:identificador "9337" ;
    ns1:solucionaFallo ns1:Parametro_LOOPTIME,
        ns1:Parametro_OPMODE ;
    ns1:textoExtracto "9337 Sercos posición no funciona con LOOPTIME superior a 8 ms. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Los reguladores Sercos posición tienen limitado a 8 ms el tiempo de ciclo. SOLUCIÓN Asignar al parámetro máquina LOOPTIME un valor igual o inferior a 8 ms o usar los reguladores en velocidad (OPMODE = Velocidad)." .

ns1:Error_9338 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9338: Memoria insuficiente" ;
    ns1:identificador "9338" ;
    ns1:solucionaFallo ns1:Parametro_NPOINTS ;
    ns1:textoExtracto "9338 Memoria insuficiente. Reducir el valor del parámetro. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA No se ha podido alocar la memoria para el número de puntos indicados por el parámetro NPOINTS de Fagor > Diagnosis. SOLUCIÓN Reducir el valor de parámetro máquina NPOINTS de Fagor > Diagnosis." .

ns1:Error_9339 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9339: SWTDELAY demasiado grande para LOOPTIME actual" ;
    ns1:identificador "9339" ;
    ns1:solucionaFallo ns1:Parametro_LOOPTIME,
        ns1:Parametro_SWTDELAY ;
    ns1:textoExtracto "9339 No se admite un SWTDELAY tan grande con LOOPTIME actual. DETECCIÓN Durante la ejecución. CAUSA El valor de SWTDELAY es demasiado grande para el tiempo de ciclo definido. SOLUCIÓN Reducir el valor de parámetro SWTDELAY o aumentar el tiempo de ciclo." .

ns1:Error_9340 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9340: Parámetros inconsistentes en contadora Sercos" ;
    ns1:identificador "9340" ;
    ns1:solucionaFallo ns1:Parametro_ABSOFF,
        ns1:Parametro_COUNTERID,
        ns1:Parametro_EXTMULT,
        ns1:Parametro_FBACKAL,
        ns1:Parametro_FEEDBACKTYPE,
        ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2,
        ns1:Parametro_I0TYPE,
        ns1:Parametro_NPULSES,
        ns1:Parametro_REFPULSE,
        ns1:Parametro_SSI,
        ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "9340 Contadora Sercos: sets con igual COUNTERID deben tener igual el\\los parámetro(s): DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA Varios sets que con la misma entrada de captación de un módulo RCS-S (parámetro COUNTERID), no tienen el mismo valor en alguno de los siguientes parámetros: FEEDBACKTYPE, SSITYPE, SSI, I0TYPE, ABSOFF, EXTMULT, REFPULSE, I0CODDI1, I0CODDI2, NPULSES y FBACKAL. SOLUCIÓN En los sets con igual COUNTERID, definir los parámetros indicados con el mismo valor." .

ns1:Error_9513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD" ;
    ns1:identificador "9513" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Verificar conexionado y contactar con soporte" ;
            ns1:textoExtracto "Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." ] ;
    ns1:textoExtracto "Error en la actualización de versión CPLD. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión del CPDL en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_9514 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal A" ;
    ns1:identificador "9514" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Revisar nivel de señales del captador (señal A)" ;
            ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador." ] ;
    ns1:textoExtracto "Captación: Cable roto señal A. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La entrada de captación del regulador no recibe la señal A. El cable de la señal A y/o /A puede estar roto o desconectado. SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." .

ns1:Error_9515 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal B" ;
    ns1:identificador "9515" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Revisar nivel de señales del captador (señal B)" ;
            ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador." ] ;
    ns1:textoExtracto "Captación: Cable roto señal B. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La entrada de captación del regulador no recibe la señal B. El cable de la señal B y/o /B puede estar roto o desconectado. SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." .

ns1:Error_9516 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal I0" ;
    ns1:identificador "9516" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Revisar nivel de señales del captador (señal I0)" ;
            ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador." ] ;
    ns1:textoExtracto "Captación: Cable roto señal I0. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La entrada de captación del regulador no recibe la señal I0. El cable de la señal I0 y/o /I0 puede estar roto o desconectado. SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." .

ns1:Error_9517 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal AL" ;
    ns1:identificador "9517" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Revisar nivel de señales del captador (señal AL)" ;
            ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador." ] ;
    ns1:textoExtracto "Captación: Cable roto señal AL. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La entrada de captación del regulador no recibe la señal AL. El cable de la señal AL y/o /AL puede estar roto o desconectado. SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." .

ns1:Error_9518 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Sobrecorriente o cortocircuito" ;
    ns1:identificador "9518" ;
    ns1:textoExtracto "Captación: Sobrecorriente o cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:Error_9524_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9524: ABSIND - Error leyendo información"@es ;
    ns1:identificador "9524" ;
    ns1:solucionaFallo ns1:Cableado_ABSIND_Inductosyn,
        ns1:Modulo_ABSIND ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador. SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_9525_INDUCTOSYN_INC_Baja a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9525: INDUCTOSYN - Señal INC demasiado baja"@es ;
    ns1:identificador "9525" ;
    ns1:solucionaFallo ns1:Cableado_ABSIND_Inductosyn,
        ns1:Modulo_ABSIND,
        ns1:SoftwareAjuste_ABSIND,
        ns1:Transductor_InductosynResolver ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo. SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. • Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver. • Si el error persiste y no se puede eliminar con las acciones anteriores, pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_9526_INDUCTOSYN a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9526: INDUCTOSYN - Señal INC demasiado alta"@es ;
    ns1:identificador "9526" ;
    ns1:monitoreaParametro ns1:Parametro_SenalINC_Inductosyn ;
    ns1:textoExtracto "9526 INDUCTOSYN: Señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es .

ns1:Error_9526_INDUCTOSYN_INC_Alta a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9526: INDUCTOSYN - Señal INC demasiado alta"@es ;
    ns1:identificador "9526" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es .

ns1:Error_9534 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor. Error en la pista absoluta"@es ;
    ns1:identificador "9534" ;
    ns1:solucionaFallo ns1:Encoder_Regla_Fagor ;
    ns1:textoExtracto "9534 Captación digital Fagor. Error en la pista absoluta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Las posibles causas son las siguientes: • El captador no puede calcular la posición absoluta. • Pérdida de contaje. • La señal analógica < 0,20 Vpp. SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. • Comprobar las tolerancias de montaje. • Limpiar el cristal o la cinta de acero de la regla. • Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error_9535 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor. Error en la CPU"@es ;
    ns1:identificador "9535" ;
    ns1:solucionaFallo ns1:Encoder_Regla_Fagor ;
    ns1:textoExtracto "9535 Captación digital Fagor. Error en la CPU. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error_9536 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor. Error de los potenciómetros de ajuste"@es ;
    ns1:identificador "9536" ;
    ns1:solucionaFallo ns1:Encoder_Regla_Fagor ;
    ns1:textoExtracto "9536 Captación digital Fagor. Error de los potenciómetros de ajuste. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error_9537 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor. Error del captador de imagen (CCD)"@es ;
    ns1:identificador "9537" ;
    ns1:solucionaFallo ns1:Encoder_Regla_Fagor ;
    ns1:textoExtracto "9537 Captación digital Fagor. Error del captador de imagen (CCD). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode). SOLUCIÓN Las posibles soluciones son las siguientes: • Comprobar las tolerancias de montaje. • Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:Error_9629 a ns1:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación (CRC incorrecto)"@es ;
    ns1:identificador "9629" ;
    ns1:mitigaRiesgo ns1:Solucion_9629 ;
    ns1:textoExtracto "9629 Error de comunicación en captación. CRC incorrecto. [...] Pérdida de la configuración del encóder o de la cabeza de la regla. El CRC de la regla absoluta FAGOR conectada no ha sido identificado por el regulador."@es .

ns1:Error_9630 a ns1:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación (No ACK)"@es ;
    ns1:identificador "9630" ;
    ns1:mitigaRiesgo ns1:Solucion_9630 ;
    ns1:textoExtracto "9630 Error de comunicación en captación. No se recibió acknowledge. [...] Error en la lectura de la cota absoluta; no se recibió acknowledge."@es .

ns1:Error_9631 a ns1:AvisoSeguridad ;
    rdfs:label "Error de sincronismo ABSIND"@es ;
    ns1:identificador "9631" ;
    ns1:mitigaRiesgo ns1:Solucion_9631 ;
    ns1:textoExtracto "9631 ABSIND: Error de sincronismo. [...] El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta."@es .

ns1:Error_9632 a ns1:AvisoSeguridad ;
    rdfs:label "Error de lectura ABSIND"@es ;
    ns1:identificador "9632" ;
    ns1:textoExtracto "9632 ABSIND: Error leyendo información."@es .

ns1:Error_9638 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9638: INDUCTOSYN - Error desconocido" ;
    ns1:identificador "9638" ;
    ns1:solucionaFallo ns1:Modulo_ABSIND ;
    ns1:textoExtracto "9638 INDUCTOSYN: Error desconocido. [...] Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND." .

ns1:Error_9639 a ns1:AvisoSeguridad ;
