    ns1:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ns1:ComponenteMotor a ns1:ComponenteElectrico ;
    rdfs:label "Motor (referenciado en tabla de parámetros)" ;
    ns1:textoExtracto "tabla de parámetros máquina (feedback, motor, tandem, etc)" .

ns1:Componente_Brazos a ns1:Componente ;
    rdfs:label "Brazos del almacén"@es ;
    ns1:textoExtracto "los brazos en los almacenes donde proceda"@es .

ns1:Componente_CNC a ns1:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ns1:activaAlarma ns1:Alarma_3511,
        ns1:Alarma_3600,
        ns1:Alarma_3601,
        ns1:Alarma_3602,
        ns1:Alarma_3603,
        ns1:Alarma_3604 ;
    ns1:controla ns1:Componente_Cabezal ;
    ns1:textoExtracto "El CNC ignora las funciones M3/M4.",
        "El CNC intenta controlar un cabezal que se encuentra en modo visualizador." .

ns1:Componente_CabezalesSincronizados a ns1:ComponenteMecanico ;
    rdfs:label "Cabezales sincronizados"@es ;
    ns1:textoExtracto "Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos."@es .

ns1:Componente_Cuchilla a ns1:ComponenteMecanico ;
    ns1:textoExtracto "La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada."@es .

ns1:Componente_Drive a ns1:ComponenteElectrico ;
    rdfs:label "Drive (unidad de control de eje)"@es ;
    ns1:textoExtracto "Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem."@es .

ns1:Componente_EjeC a ns1:ComponenteMecanico ;
    rdfs:label "Eje C"@es ;
    ns1:identificador "Eje C" ;
    ns1:textoExtracto "El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa."@es,
        "Uno de los ejes implicados en la función G201 es eje C y forma parte de los tres primeros ejes del canal."@es .

ns1:Componente_EsferaCalibracion a ns1:ComponenteMecanico ;
    rdfs:label "Esfera de calibración"@es ;
    ns1:textoExtracto "el palpador no ha tocado la esfera [...] colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente."@es .

ns1:Componente_GAPCTRL a ns1:Componente ;
    rdfs:label "Control de gap (#GAPCTRL)" ;
    ns1:textoExtracto "#GAPCTRL programado en otro canal. [...] Sólo puede haber activo un control de gap en el CNC." .

ns1:Componente_GrupoMultieje a ns1:Componente ;
    rdfs:label "Grupo multieje"@es ;
    ns1:textoExtracto "Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]. El índice (grupo) no corresponde a ningún grupo multieje definido en los parámetros máquina."@es .

ns1:Componente_Herramienta a ns1:ComponenteMecanico ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ns1:textoExtracto "Esto puede indicar que la herramienta está gastada, deteriorada o que ha colisionado con la pieza. [...] Comprobar el estado de la herramienta y del mecanizado."@es .

ns1:Componente_LEAP a ns1:Componente ;
    rdfs:label "Función de salto (#LEAP)" ;
    ns1:textoExtracto "#LEAP:falta programación de POSLIMIT. [...] #LEAP activo. No se puede alterar POS, posición final del salto." .

ns1:Componente_MarcaDRO_axis a ns1:ComponenteElectrico ;
    rdfs:label "Marca DRO(axis)" ;
    ns1:textoExtracto "desactivar el modo visualizador (marca DRO(axis) del PLC)" .

ns1:Componente_MarcaSERVOON a ns1:ComponenteElectrico ;
    rdfs:label "Marca SERVOON" ;
    ns1:textoExtracto "comprobar el estado de la marca SERVOON del cabezal." .

ns1:Componente_MotorDesconocido a ns1:ComponenteElectrico ;
    rdfs:label "Motor no reconocido (AUTODETECT)" ;
    ns1:solucionaFallo ns1:Fallo_9371 ;
    ns1:textoExtracto "motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml"@es .

ns1:Componente_PLC a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "Cancelada M3 o M4 de PLC en G96 sin S programada.",
        "desactivar el modo visualizador (marca DRO(axis) del PLC)" .

ns1:Componente_PilaCNC a ns1:ComponenteElectrico ;
    rdfs:label "Pila del CNC" ;
    ns1:textoExtracto "La pila está descargada; ha terminado su ciclo de vida útil. Cuando el CNC está apagado, la pila se encarga de mantener datos necesarios para el CNC (por ejemplo, las cotas)." .

ns1:Componente_ReglaMedicion a ns1:ComponenteMecanico ;
    rdfs:label "Regla de medición (cristal/cinta de acero)"@es ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:Componente_SensorTemperaturaMotor a ns1:Sensor ;
    rdfs:label "Sensor de temperatura del motor" ;
    ns1:textoExtracto "cableado de medición de temperatura del motor (manguera del sensor de posición) o el termistor" .

ns1:Componente_TarjetaSense a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta sense" ;
    ns1:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense." .

ns1:Componente_Termistor a ns1:ComponenteElectrico ;
    rdfs:label "Termistor del motor" ;
    ns1:textoExtracto "cableado de medición de temperatura del motor (manguera del sensor de posición) o el termistor" .

ns1:Componente_Torreta a ns1:ComponenteMecanico ;
    rdfs:label "Almacén tipo torreta"@es ;
    ns1:textoExtracto "La sentencia #ROTATEMZ sólo es válida para un almacén de tipo torreta."@es .

ns1:Componente_ZonaTrabajo a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje que define una zona de trabajo activa"@es ;
    ns1:tieneComponente ns1:Componente_EjeControlado .

ns1:ConfiguracionCAN a ns1:Parametro ;
    ns1:monitoreaParametro ns1:SistemaContadoras ;
    ns1:textoExtracto "Verificar la configuración CAN" .

ns1:ContadoraSercos a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos"@es ;
    ns1:textoExtracto "contadora Sercos"@es ;
    ns1:tieneComponente ns1:ModuloRCS_S .

ns1:ContajesLocales a ns1:ComponenteElectrico ;
    rdfs:label "Contajes analógicos locales" ;
    ns1:monitoreaParametro ns1:Parametro_G174 ;
    ns1:textoExtracto "En la lectura de los contajes analógicos locales desde el lazo de posición." .

ns1:DiagnosticoError5015 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error 5015"@es ;
    ns1:monitoreaParametro ns1:ParametroNDOMOD,
        ns1:ParametroPLCFREQ ;
    ns1:solucionaFallo ns1:Error5015 ;
    ns1:textoExtracto "SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ."@es .

ns1:DiagnosticoErrorBusSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error en bus Sercos (pérdida de fase)" ;
    ns1:solucionaFallo ns1:ErrorBusSercosPerdidaFase ;
    ns1:textoExtracto "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." .

ns1:DiagnosticoFallo_0030 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de eje por índice en variables DRV"@es ;
    ns1:identificador "0030" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Programación de eje por número lógico en variables DRV"@es ;
            ns1:textoExtracto "En alguna variable del regulador (DRV), el eje está programado mediante su número lógico o indice en el canal."@es ] ;
    ns1:textoExtracto "'Se debe programar el eje de la variable mediante su nombre' DETECCIÓN Durante la ejecución. CAUSA En alguna variable del regulador (DRV), el eje está programado mediante su número lógico o indice en el canal. SOLUCIÓN En estas variables, el eje se debe programar mediante su nombre."@es .

ns1:DiagnosticoFallo_0063 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 0063" ;
    ns1:solucionaFallo ns1:Alarma_0063 ;
    ns1:textoExtracto "CAUSA El parámetro INCJOGFEED es superior a G00FEED.",
        "CAUSA El parámetro JOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED." .

ns1:DiagnosticoFallo_0074 a ns1:DiagnosticoFallo ;
    rdfs:label "Test de tendencia sin activar" ;
    ns1:identificador "0074" ;
    ns1:solucionaFallo ns1:Parametro_TENDENCY ;
    ns1:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: En algún eje o cabezal, el test de tendencia está desactivado. SOLUCIÓN: En los ejes y cabezales, activar el test de tendencia (parámetro TENDENCY)." .

ns1:DiagnosticoFallo_0075 a ns1:DiagnosticoFallo ;
    rdfs:label "Tabla de configuración de IOs no válida" ;
    ns1:identificador "0075" ;
    ns1:solucionaFallo ns1:Parametro_NDIMOD,
        ns1:Parametro_NDOMOD ;
    ns1:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Los parámetros NDIMOD y NDOMOD deben ser iguales al número de módulos de entradas y salidas detectados por hardware. SOLUCIÓN: Corregir los parámetros NDIMOD y NDOMOD." .

ns1:DiagnosticoFallo_0076 a ns1:DiagnosticoFallo ;
    rdfs:label "La suma de ejes o cabezales por canal supera el número total de ejes o cabezales" ;
    ns1:identificador "0076" ;
    ns1:solucionaFallo ns1:Parametro_CHNAXIS,
        ns1:Parametro_CHNSPDL,
        ns1:Parametro_NAXIS,
        ns1:Parametro_NSPDL ;
    ns1:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: El valor del parámetro CHNAXIS es mayor que el valor del parámetro NAXIS o el valor del parámetro CHNSPDL es mayor que el valor del parámetro NSPDL. SOLUCIÓN: Corregir los parámetros máquina." .

ns1:DiagnosticoFallo_0077 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje o cabezal asignado a más de un canal" ;
    ns1:identificador "0077" ;
    ns1:solucionaFallo ns1:Parametro_CHAXISNAME,
        ns1:Parametro_CHSPDLNAME ;
    ns1:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Hay un eje o cabezal asignado a varios canales. SOLUCIÓN: Corregir los parámetros máquina CHAXISNAME y CHSPDLNAME en todos los canales." .

ns1:DiagnosticoFallo_0078 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben pertenecer al mismo canal",
        "Diagnóstico: Ejes Gantry en canales distintos"@es ;
    ns1:identificador "0078" ;
    ns1:solucionaFallo ns1:Alarma_0078 ;
    ns1:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Algún eje gantry está formado por ejes de canales distintos.",
        "Algún eje gantry está formado por ejes de canales distintos. SOLUCIÓN En un eje gantry, ambos ejes deben pertenecer al mismo canal."@es .

ns1:DiagnosticoFallo_0079 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Eje esclavo Gantry aparcado"@es ;
    ns1:solucionaFallo ns1:Alarma_0079 ;
    ns1:textoExtracto "El CNC ha detectado que el eje esclavo de una pareja gantry está aparcado."@es .

ns1:DiagnosticoFallo_0094 a ns1:DiagnosticoFallo ;
    rdfs:label "Alguno de los canales debe tener el parámetro HIDDENCH = No" ;
    ns1:identificador "0094" ;
    ns1:solucionaFallo ns1:Parametro_HIDDENCH ;
    ns1:textoExtracto "0094 'Alguno de los canales debe tener el parámetro HIDDENCH = No' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)." .

ns1:DiagnosticoFallo_0095 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje no puede ser MASTERAXIS de varias parejas de gantrys" ;
    ns1:identificador "0095" ;
    ns1:textoExtracto "0095 'Un eje no puede ser MASTERAXIS de varias parejas de gantrys' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay dos ejes gantry con el mismo eje maestro. SOLUCIÓN Corregir la configuración de ejes gantry." .

ns1:DiagnosticoFallo_0096 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro" ;
    ns1:identificador "0096" ;
    ns1:solucionaFallo ns1:Parametro_DRIVETYPE,
        ns1:Parametro_OPMODEP ;
    ns1:textoExtracto "0096 Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)." .

ns1:DiagnosticoFallo_0097 a ns1:DiagnosticoFallo ;
    rdfs:label "Par tandem\\gantry eliminado por estar precedido de par vacío" ;
    ns1:identificador "0097" ;
    ns1:textoExtracto "0097 'Par tandem\\gantry eliminado por estar precedido de par vacío' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas. SOLUCIÓN Las parejas de ejes gantry o tándem tienen que ocupar posiciones consecutivas en las tablas." .

ns1:DiagnosticoFallo_0116 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al leer la tabla tecnológica" ;
    ns1:documentadoEn ns1:Tabla_Tecnologica ;
    ns1:identificador "0116" ;
    ns1:textoExtracto "0116 'Error al leer la tabla tecnológica' DETECCIÓN Durante el arranque del CNC, acceso a la tabla tecnológica o ejecución del comando #TECHTABLE. CAUSA El fichero ..\\mtb\\data\\techTable\\TTDsc.xml que define la tabla o tabla no existe o no es ..\\mtb\\data\\techTable\\Material Files\\*xml con los datos de la correcto. Es posible que haya cambios en la tabla (nuevas variables, nuevos tipos enumerados) y no se ha reiniciado el CNC. SOLUCIÓN Comprobar el nombre y contenido de la tabla. Si la tabla existe, reiniciar el CNC." .

ns1:DiagnosticoFallo_0118 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en hardware de SERCOS III o error en driver" ;
    ns1:identificador "0118" ;
    ns1:solucionaFallo ns1:Sistema_SERCOS_III ;
    ns1:textoExtracto "0118 No hay hardware de SERCOS III o error en la carga del driver. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El CNC no detecta el hardware asociado a Sercos III o no puede cargar el driver. SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:DiagnosticoFallo_0119 a ns1:DiagnosticoFallo ;
    rdfs:label "Actualización de SW correcta de dispositivos PwC conectados a SERCOS3",
        "Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3"@es ;
    ns1:identificador "0119" ;
    ns1:solucionaFallo ns1:Sistema_SERCOS_III ;
    ns1:textoExtracto "0119 Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción.",
        "Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción."@es .

ns1:DiagnosticoFallo_0120 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3"@es ;
    ns1:identificador "0120" ;
    ns1:textoExtracto "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el"@es .

ns1:DiagnosticoFallo_0125_CoresInvalidos a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación de cores inválido" ;
    ns1:activaAlarma ns1:Alarma_0125 ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Autogeneración de código de validación" ;
            ns1:textoExtracto "Póngase en contacto con Fagor para obtener un código de validación válido." ] ;
    ns1:textoExtracto "El número de cores definido en el código de validación no es válido para ese hardware." .

ns1:DiagnosticoFallo_1000 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1000: Falta programación de ejes" ;
    ns1:identificador "1000" ;
    ns1:textoExtracto "'La función o sentencia requiere programación de ejes' DETECCIÓN Durante la ejecución. CAUSA Falta programar los ejes sobre los que debe actuar la sentencia o función G programada. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1004 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1004: Velocidad de cabezal nula" ;
    ns1:identificador "1004" ;
    ns1:textoExtracto "'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado con la función G63 tiene velocidad cero. SOLUCIÓN Programar una velocidad de cabezal." .

ns1:DiagnosticoFallo_1005 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1005: Bloque de movimiento con avance nulo" ;
    ns1:identificador "1005" ;
    ns1:textoExtracto "'Bloque de movimiento con avance nulo' DETECCIÓN Durante la ejecución. CAUSA No hay un avance activo en el canal. SOLUCIÓN Programar el avance F." .

ns1:DiagnosticoFallo_1006 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1006: G20 no admite cabezal" ;
    ns1:identificador "1006" ;
    ns1:textoExtracto "'G20: no se admite cabezal' DETECCIÓN Durante la ejecución. CAUSA La función G20 no admite la programación de cabezal. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1007 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1007: Falta eje principal" ;
    ns1:identificador "1007" ;
    ns1:textoExtracto "'La función programada requiere algún eje principal no existente' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita uno o dos ejes principales y estos no existen o están aparcados. SOLUCIÓN Revisar la programación. • Las funciones G11, G12, G13 y G14 necesitan uno de los dos ejes del plano principal. • Las funciones G2, G3, G8, G9, G30, G36, G37, G38, G39, G73 necesitan los dos ejes del plano principal. • También hacen falta los dos ejes del plano principal para activar la detección de colisiones (#CD) y para la función G20 cuando la detección de colisiones está activa. • Recuperar mediante la sentencia #CALL AX/#SET AX el eje que falta. • Desaparcar el eje (#UNPARK)." .

ns1:DiagnosticoFallo_1008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1008: Coordenadas fuera de rango" ;
    ns1:identificador "1008" ;
    ns1:textoExtracto "'Coordenadas fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La cota programada para el eje es demasiado grande. • La función G101 intenta incluir en el eje un offset demasiado grande. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1023 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1023: Número de gama no válido" ;
    ns1:identificador "1023" ;
    ns1:textoExtracto "1023 'Número de gama no válido' [...] CAUSA El número de gama (set) del eje es incorrecto." .

ns1:DiagnosticoFallo_1024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1024: Número de gama fuera de rango" ;
    ns1:identificador "1024" ;
    ns1:textoExtracto "1024 'Número de gama fuera de rango' [...] CAUSA El número de gama (set) del eje es demasiado alto." .

ns1:DiagnosticoFallo_1046 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del segundo eje del plano"@es ;
    ns1:identificador "1046" ;
    ns1:solucionaFallo ns1:Parametro_G20_Par2 ;
    ns1:textoExtracto "1046 'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal."@es .

ns1:DiagnosticoFallo_1047 a ns1:DiagnosticoFallo ;
    rdfs:label "Es necesario un tercer eje para el plano (índice 5)"@es ;
    ns1:identificador "1047" ;
    ns1:solucionaFallo ns1:Parametro_G20_Par3 ;
    ns1:textoExtracto "1047 'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto."@es .

ns1:DiagnosticoFallo_1077 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G115/G116/G117)"@es ;
    ns1:identificador "1077" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:DiagnosticoFallo_1078 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G134/G135)"@es ;
    ns1:identificador "1078" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí."@es .

ns1:DiagnosticoFallo_1141 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: $CONTINUE sin bucle abierto"@es ;
    ns1:solucionaFallo ns1:Alarma_1141 ;
    ns1:textoExtracto "CAUSA El CNC ha detectado una instrucción $CONTINUE pero no hay ningún bucle de control abierto; $FOR, $WHILE o $DO. SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1142 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: #TIME no programada correctamente"@es ;
    ns1:solucionaFallo ns1:Alarma_1142 ;
    ns1:textoExtracto "CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1162 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1162: Revisión de programación de final de programa principal"@es ;
    ns1:solucionaFallo ns1:Alarma_1162 ;
    ns1:textoExtracto "SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET."@es .

ns1:DiagnosticoFallo_1163 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1163: Revisión de finalización de subrutinas"@es ;
    ns1:solucionaFallo ns1:Alarma_1163 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET."@es .

ns1:DiagnosticoFallo_1164 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1164: Revisión de términos en expresión matemática"@es ;
    ns1:solucionaFallo ns1:Alarma_1164 ;
    ns1:textoExtracto "SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc."@es .

ns1:DiagnosticoFallo_1165 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1165: Revisión de variables en programación"@es ;
    ns1:solucionaFallo ns1:Alarma_1165 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1166 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1166: Revisión de raíz cuadrada (SQRT) en programación"@es ;
    ns1:solucionaFallo ns1:Alarma_1166 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1167 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1167: Revisión de logaritmos (LOG/LN) en programación"@es ;
    ns1:solucionaFallo ns1:Alarma_1167 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1180 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de tipo de eje en acoplo (AXISTYPE)"@es ;
    ns1:identificador "1180" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "AXISTYPE" ;
            ns1:textoExtracto "parámetro AXISTYPE"@es ;
            ns1:valor "lineal/rotativo"@es ] ;
    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)."@es .

ns1:DiagnosticoFallo_1181 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de modo de eje rotativo (AXISMODE)"@es ;
    ns1:identificador "1181" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "AXISMODE" ;
            ns1:textoExtracto "parámetro AXISMODE"@es ;
            ns1:valor "linearlike/módulo"@es ] ;
    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)."@es .

ns1:DiagnosticoFallo_1325 a ns1:DiagnosticoFallo ;
    rdfs:label "'Número de bloque definido varias veces'" ;
    ns1:identificador "1325" ;
    ns1:textoExtracto "1325 'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" está repetido en el programa. SOLUCIÓN No repetir el número de bloque." .

ns1:DiagnosticoFallo_1326 a ns1:DiagnosticoFallo ;
    rdfs:label "'Valor erróneo para asignar a variable'" ;
    ns1:identificador "1326" ;
    ns1:textoExtracto "1326 'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_1344 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de plano no permitido durante mecanizado lateral"@es ;
    ns1:solucionaFallo ns1:Alarma_1344 ;
    ns1:textoExtracto "El CNC ha intentado cambiar el plano de trabajo (G17-G20) mientras está activo el mecanizado en la superficie lateral."@es .

ns1:DiagnosticoFallo_1345 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes incorrectos en función G20"@es ;
    ns1:solucionaFallo ns1:Alarma_1345 ;
    ns1:textoExtracto "En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos. Ambos ejes han de ser diferentes y estar entre los tres primeros ejes."@es .

ns1:DiagnosticoFallo_1360 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 1360" ;
    ns1:solucionaFallo ns1:Alarma_1360 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el eje C para ejecutar la [función conflictiva]." .

ns1:DiagnosticoFallo_1406 a ns1:DiagnosticoFallo ;
    rdfs:label "'#CALL: no admite programación de parámetros'"@es ;
    ns1:identificador "1406" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Programación de parámetros en sentencia #CALL"@es ;
            ns1:textoExtracto "Revisar la programación."@es ] ;
    ns1:textoExtracto "La sentencia #CALL no admite programación de parámetros."@es .

ns1:DiagnosticoFallo_1407 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en la lectura de datos de la cajera'"@es ;
    ns1:identificador "1407" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Edición manual incorrecta de cajeras 2D/3D"@es ;
            ns1:textoExtracto "Volver a editar la cajera con el editor de ciclos."@es ] ;
    ns1:textoExtracto "Al ejecutar una cajera 2D ó 3D, el CNC no ha podido decodificar alguno de los datos. Esto puede suceder cuando se han editado manualmente los datos de la cajera y se ha sustituido un valor numérico por una variable, se ha eliminado el corchete final de las instrucciones #DATAP2D, #DATAP3D, etc."@es .

ns1:DiagnosticoFallo_1408 a ns1:DiagnosticoFallo ;
    rdfs:label "'G63/G74/M19/CAX: Programación no permitida si no hay encóder en el cabezal'"@es ;
    ns1:identificador "1408" ;
    ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
            rdfs:label "Encoder del cabezal"@es ;
            ns1:textoExtracto "Es necesario que haya encoder en el cabezal."@es ] ;
    ns1:textoExtracto "El CNC no puede ejecutar la función o sentencia programada si el cabezal no está controlado en posición."@es .

ns1:DiagnosticoFallo_1409 a ns1:DiagnosticoFallo ;
    rdfs:label "'Anidamiento de funciones T con subrutina no permitido'"@es ;
    ns1:identificador "1409" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Anidamiento de funciones T en subrutinas TOOLSUB"@es ;
            ns1:textoExtracto "No es posible programar una función T dentro de la subrutina asociada al cambio de herramienta."@es ] ;
    ns1:textoExtracto "El CNC ha intentado ejecutar un cambio de herramienta y en la subrutina asociada a la función T (parámetro TOOLSUB) hay programado otro cambio de herramienta."@es .

ns1:DiagnosticoFallo_1411 a ns1:DiagnosticoFallo ;
    rdfs:label "'#CD: número de bloques no válido'"@es ;
    ns1:identificador "1411" ;
    ns1:textoExtracto "El número de bloques programado en la sentencia es incorrecto."@es .

ns1:DiagnosticoFallo_1439 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1439: Eje Hirth en transformación" ;
    ns1:solucionaFallo ns1:Alarma_1439 ;
    ns1:textoExtracto "Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)." .

ns1:DiagnosticoFallo_1441 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1441: Cinemática no activada" ;
    ns1:solucionaFallo ns1:Alarma_1441 ;
    ns1:textoExtracto "Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry." .

ns1:DiagnosticoFallo_1447_Causa1 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de opción de software en CNC" ;
    ns1:solucionaFallo ns1:Alarma_1447 ;
    ns1:textoExtracto "El CNC no dispone de la opción de software necesaria para ejecutar la orden programada." .

ns1:DiagnosticoFallo_1447_Causa2 a ns1:DiagnosticoFallo ;
    rdfs:label "Intento de superar 550 Hz en regulador MDU" ;
    ns1:solucionaFallo ns1:Alarma_1447 ;
    ns1:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED." .

ns1:DiagnosticoFallo_1470 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1470"@es ;
    ns1:solucionaFallo ns1:Alarma_1470 ;
    ns1:textoExtracto "Si el parámetro máquina UNIDIR del eje rotativo es POSITIVO la cota incremental programada debe ser positiva o nula. Si el parámetro máquina UNIDIR del eje rotativo es NEGATIVO la cota incremental programada debe ser negativa o nula."@es .

ns1:DiagnosticoFallo_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo 1479: subrutina G74 no asociada"@es ;
    ns1:identificador "1479" ;
    ns1:mitigaRiesgo [ a ns1:AvisoSeguridad ;
            rdfs:label "Verificación de asociación de subrutinas antes de ejecución"@es ;
            ns1:textoExtracto "DETECCIÓN Durante la ejecución."@es ] ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Ejecutar ciclo G74 sin subrutina asociada"@es ;
            ns1:textoExtracto "G74: falta asociar subrutina"@es ] ;
    ns1:textoExtracto "G74: falta asociar subrutina"@es .

ns1:DiagnosticoFallo_1486 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación de señales"@es ;
    ns1:identificador "1486" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1486 'Programar: #SIGNAL [señal, señal, señal, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque."@es .

ns1:DiagnosticoFallo_1487 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación de CLEAR"@es ;
    ns1:identificador "1487" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. 1487 'Programar: #CLEAR [señal, señal, señal, ...]'"@es .

ns1:DiagnosticoFallo_1567 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1567: Radio polar programado incorrectamente" ;
    ns1:identificador "1567" ;
    ns1:solucionaFallo ns1:Parametro_R ;
    ns1:textoExtracto "'El radio polar sólo se puede programar con R' DETECCIÓN Durante la ejecución. CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263. SOLUCIÓN Programar el radio polar con el parámetro R." .

ns1:DiagnosticoFallo_1568 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1568: Número de almacén incorrecto" ;
    ns1:identificador "1568" ;
    ns1:textoExtracto "'Número de almacén incorrecto' DETECCIÓN Durante la ejecución. CAUSA El número de almacén programado en el comando MZ no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4." .

ns1:DiagnosticoFallo_1569 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1569: Ejecución no permitida en canal exclusivo de PLC" ;
    ns1:identificador "1569" ;
    ns1:textoExtracto "'Ejecución no permitida, el canal es exclusivo de PLC' DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_1582 a ns1:DiagnosticoFallo ;
    rdfs:label "NR: doble programación del número de repeticiones" ;
    ns1:identificador "1582" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: La instrucción NR está programada más de una vez en el mismo bloque. SOLUCIÓN: Revisar la programación." .

ns1:DiagnosticoFallo_1583 a ns1:DiagnosticoFallo ;
    rdfs:label "#FOLLOW ON: el eje maestro y esclavo no pueden ser iguales" ;
    ns1:identificador "1583" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: Los ejes maestro y el esclavo son el mismo. SOLUCIÓN: Revisar la programación." .

ns1:DiagnosticoFallo_1584 a ns1:DiagnosticoFallo ;
    rdfs:label "#FOLLOW ON: el numerador y denominador deben ser números enteros" ;
    ns1:identificador "1584" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: El numerador y/o denominador están programados con decimales. SOLUCIÓN: Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión." .

ns1:DiagnosticoFallo_1585 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes de la transformación activa no pueden ser ejes de intercambio temporal" ;
    ns1:identificador "1585" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: Los ejes de la transformada no pueden ser ejes de intercambio temporal, ya que la transformada definida se mantiene una vez activada. SOLUCIÓN: Si es posible, definir los ejes como de intercambio mantenido; si no, utilizar otros ejes para la transformada. Los ejes de intercambio temporal sólo se pueden utilizar en su canal, y cuando los ejes están en sus posiciones originales dentro del canal. En las tranformadas #FACE y #CYL se pueden utilizar ejes de intercambio temporal, porque estas transformadas se anulan con M30 y tras un reset." .

ns1:DiagnosticoFallo_1586 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el número de almacén (MZ)" ;
    ns1:identificador "1586" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: En un sistema con varios almacenes, hay programado en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta. SOLUCIÓN: En un sistema multialmacén, hay que programar en el mismo bloque la herramienta, la posición y el almacén." .

ns1:DiagnosticoFallo_1637 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1637: Sentido de giro del cabezal incompatible con la herramienta"@es ;
    ns1:identificador "1637" ;
    ns1:textoExtracto "'Sentido de giro del cabezal incompatible con la herramienta' [...] Durante la ejecución. [...] El sentido de giro predeterminado de la herramienta es"@es .

ns1:DiagnosticoFallo_1649 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_1649 ;
    ns1:textoExtracto "Falta la función de coordenadas PcsToMcs al intentar realizar la transformación de coordenadas pieza a máquina en una cinemática de usuario." .

ns1:DiagnosticoFallo_1650 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_1650 ;
    ns1:textoExtracto "Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario." .

ns1:DiagnosticoFallo_1695 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Sintaxis incorrecta en #SWTOUT"@es ;
    ns1:solucionaFallo ns1:Alarma_1695 ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1699 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: CSROT no compatible con ejes manuales"@es ;
    ns1:solucionaFallo ns1:Alarma_1699 ;
    ns1:textoExtracto "CAUSA Los ejes rotativos de la cinemática tienen que ser servocontrolados de forma continua. SOLUCIÓN Desactivar la sentencia #CSROT."@es .

ns1:DiagnosticoFallo_1701_F a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta avance programado (F=0)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1701_F ;
    ns1:textoExtracto "CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1701_S a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta velocidad programada (S=0)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1701_S ;
    ns1:textoExtracto "CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1702 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta herramienta programada (T=0)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1702 ;
    ns1:textoExtracto "CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1720_F a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1720: ESCARIADO: F = 0"@es ;
    ns1:identificador "1720_F" ;
    ns1:solucionaFallo ns1:Parametro_F_1720 ;
    ns1:textoExtracto "CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1740 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta mayor que cajera" ;
    ns1:identificador "1740" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_AjusteParametros ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN Elegir una herramienta de menor diámetro." .

ns1:DiagnosticoFallo_1741 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta ACABADO menor que delta" ;
    ns1:identificador "1741" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado." .

ns1:DiagnosticoFallo_1742 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: F = 0" ;
    ns1:identificador "1742" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_1743 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: S = 0" ;
    ns1:identificador "1743" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_1744 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: T = 0" ;
    ns1:identificador "1744" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_ProgramacionHerramienta ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:DiagnosticoFallo_1758 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1758: Herramienta no programada"@es ;
    ns1:solucionaFallo ns1:Alarma_1758 ;
    ns1:textoExtracto "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:DiagnosticoFallo_1765 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1765: 'PLANEADO: T = 0'" ;
    ns1:identificador "1765" ;
    ns1:solucionaFallo ns1:Parametro_T ;
