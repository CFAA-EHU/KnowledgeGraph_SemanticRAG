ns1:DiagnosticoFallo_24507 a ns1:DiagnosticoFallo ;
    rdfs:label "Reinicio del dispositivo después del watchdog" ;
    ns1:identificador "24507" ;
    ns1:textoExtracto "Reinicio del dispositivo después del watchdog. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que" .

ns1:DiagnosticoFallo_3604 a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ns1:DiagnosticoFallo_3702 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de parámetros y componentes para error de seguimiento del eje 3702"@es ;
    ns1:solucionaFallo ns1:ComponenteElectrico_Motor,
