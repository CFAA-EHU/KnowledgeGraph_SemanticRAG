    rdfs:label "Solución para alarma 3803" ;
    ns1:monitoreaParametro ns1:Parametro_MPGRESOL ;
    ns1:solucionaFallo ns1:Alarma_3803 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro máquina de ejes MPGRESOL." .

ns1:DiagnosticoFallo_3805 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3805" ;
    ns1:monitoreaParametro ns1:Parametro_INCJOGDIST,
        ns1:Parametro_INCJOGFEED ;
    ns1:solucionaFallo ns1:Alarma_3805 ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina de ejes INCJOGDIST e INCJOGFEED." .

ns1:DiagnosticoFallo_3806 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3806" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
