ns1:Alarma_EjeAparcado a ns1:Alarma ;
    rdfs:label "Alarma: Eje esclavo de pareja gantry aparcado"@es ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_EjeAparcado ;
    ns1:textoExtracto "'no puede estar aparcado' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. gantry está aparcado; la señal CAUSA El CNC ha detectado que el eje esclavo de una pareja PARKED del eje esclavo está activa."@es .

ns1:Alarma_G8734 a ns1:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8735" ;
    ns1:identificador "G8734" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8734 programada fuera de una macro G8735. SOLUCIÓN Revisar la programación. La función G8734 se debe programar a continuación de la macro G8735." .

ns1:Alarma_ModuloSalidasAnalogicas a ns1:Alarma ;
    rdfs:label "Alarma: Error en módulo remoto de salidas analógicas" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:textoExtracto "el funcionamiento del PLC. CAUSA El módulo remoto de salidas analógicas tiene un error. SOLUCIÓN Revisar módulo remoto." .

ns1:Alarma_RPT1508 a ns1:Alarma ;
    rdfs:label "RPT. 1508 'No se admiten G201 y eje C activo en los ejes del plano principal'"@es ;
    ns1:identificador "RPT.1508" ;
    ns1:textoExtracto """\r
    con el #RPT. 1508 'No se admiten G201 y eje C activo en los ejes del plano principal'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Las posibles causas son las siguientes:\r
    • Uno de los ejes implicados en la función G201 es eje C y forma parte de los tres primeros ejes del canal.\r
    • Uno de los ejes programados en la sentencia #FACE está en modo manual aditivo, G201.\r
    SOLUCIÓN Anular el eje C o el modo manual aditivo."""@es .

ns1:Alarma_RPT1509 a ns1:Alarma ;
    rdfs:label "#RPT. 1509 '#SET AX/#CALL AX: la programación de offsets no tiene efecto'"@es ;
    ns1:identificador "RPT.1509" ;
    ns1:textoExtracto """\r
    1509 '#SET AX/#CALL AX: la programación de offsets no tiene efecto'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Todos los ejes programados en la sentencia pertenecían ya a la configuración actual y por tanto, la sentencia sólo supone un cambio de orden. En este caso la opción de offsets programada no tiene efecto.\r
    SOLUCIÓN Revisar la programación."""@es .

ns1:Alarma_RPT1510 a ns1:Alarma ;
    rdfs:label "#RPT. 1510 'Eje inexistente o no disponible en el canal'"@es ;
    ns1:identificador "RPT.1510" ;
    ns1:textoExtracto """\r
    1510 'Eje inexistente o no disponible en el canal'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Las posibles causas son las siguientes:\r
    • El CNC ha intentado mover un eje que no existe o que no está disponible en el canal.\r
    • El CNC ha intentado ejecutar una sentencia que involucra a un eje que no existe o que no está disponible en el canal.\r
    • El CNC ha intentado leer o escribir una variable de un eje que no existe o que no está disponible en el canal.\r
    SOLUCIÓN Revisar la programación."""@es .

ns1:Alarma_RPT1511 a ns1:Alarma ;
    rdfs:label "#RPT. 1511 'La herramienta no está en el almacén'"@es ;
    ns1:identificador "RPT.1511" ;
    ns1:textoExtracto """\r
    1511 'La herramienta no está en el almacén'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA El CNC ha intentado leer mediante la variable V.TM.P la posición en el almacén de una herramienta que no está presente en el mismo.\r
    SOLUCIÓN Sólo es posible leer la posición de herramientas que existen en el almacén."""@es .

ns1:Alarma_RPT1512 a ns1:Alarma ;
    rdfs:label "#RPT. 1512 'Posición del almacén libre o inexistente'"@es ;
    ns1:identificador "RPT.1512" ;
    ns1:textoExtracto """\r
    1512 'Posición del almacén libre o inexistente'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe.\r
    SOLUCIÓN Sólo es posible leer la herramienta que está en una posición válida del almacén."""@es .

ns1:Alarma_Sobretemperatura_64 a ns1:Alarma ;
    rdfs:label "Alarma por sobretemperatura del equipo"@es ;
    ns1:activaAlarma ns1:Ventilador_CPU_64 ;
    ns1:textoExtracto "CAUSA Riesgo de sobretemperatura del equipo."@es .

ns1:AlmacenTorreta a ns1:ComponenteMecanico ;
    rdfs:label "Almacén torreta" ;
    ns1:textoExtracto "La sentencia #ROTATEMZ sólo se puede ejecutar en un almacén torreta." .

ns1:Aplicacion_Fagor_EtherCAT_Mapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper"@es ;
    ns1:solucionaFallo ns1:Fallo_24020_EtherCAT_FicheroRutadoInexistente ;
    ns1:textoExtracto "aplicación Fagor EtherCAT Mapper"@es .

ns1:ArchivoConfiguracionBus a ns1:InterfazUsuario ;
    rdfs:label "Archivo de configuración del bus EtherCAT"@es ;
    ns1:controla ns1:BusEtherCAT ;
    ns1:textoExtracto "archivo de configuración"@es .

ns1:ArchivoESI a ns1:InterfazUsuario ;
    rdfs:label "Archivo ESI de esclavos" ;
    ns1:identificador "ESI" ;
    ns1:textoExtracto "algún archivo ESI de los esclavos no sea adecuado." .

ns1:Archivo_ResourceRouterConf a ns1:Componente ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:requiereMantenimiento ns1:Fallo_24020_EtherCAT_FicheroRutadoInexistente ;
    ns1:textoExtracto "El archivo se debe llamar resourceRouterConf.xml"@es .

ns1:Archivo_cncWrite a ns1:InterfazUsuario ;
    rdfs:label "cncWrite.txt" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." .

ns1:Archivo_plc_prg_sym a ns1:Componente ;
    rdfs:label "Archivo plc_prg.sym" ;
    ns1:identificador "plc_prg.sym" ;
    ns1:textoExtracto "El archivo plc_prg.sym que contiene la información necesaria para crear las variables asociadas a los símbolos externos PDEF está corrupto." .

ns1:AvisoErrorAbrirFichero a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'Error abriendo fichero %1'"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:textoExtracto "'Error abriendo fichero %1' DETECCIÓN Al cargar, guardar o imprimir la tabla de herramientas o almacén. CAUSA Las posibles causas son las siguientes: • Al cargar una tabla. El fichero con los datos no existe, no tiene permiso de lectura o está siendo usado por otra aplicación. • Al guardar una tabla o imprimir una tabla a un archivo. El fichero con los datos no se ha podido crear, ya existe y no tiene permiso de escritura, está siendo usado por otra aplicación o no hay sitio en disco. • Al imprimir una tabla en una impresora, ésta no existe o está mal configurada."@es .

ns1:AvisoErrorGuardarDatos a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'Error guardando todos los datos en %1'"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:textoExtracto "'Error guardando todos los datos en %1' DETECCIÓN Al guardar la tabla de herramientas o almacén. CAUSA El fichero con los datos no se ha podido crear, ya existe y no tiene permiso de escritura, está siendo usado por otra aplicación o no hay sitio en disco. SOLUCIÓN Elegir otro directorio para guardar las tablas, darles permiso de escritura, cerrar la aplicación que los está usando o liberar espacio en el disco."@es .

ns1:AvisoFicheroNoEncontrado a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'Fichero %1 no encontrado'"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:textoExtracto "'Fichero %1 no encontrado' DETECCIÓN Al cargar la tabla de herramientas o almacén. CAUSA El fichero con los datos no existe. SOLUCIÓN Elegir ficheros que existan e indicar correctamente su path."@es .

ns1:AvisoPathNoEncontrado a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'Path %1 no encontrado'"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:textoExtracto "'Path %1 no encontrado' DETECCIÓN Al cargar, guardar o imprimir la tabla de herramientas o almacén. CAUSA El path seleccionado no existe. SOLUCIÓN Definir el path correctamente o crear la carpeta de destino."@es .

ns1:AvisoPosicionInexistente a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'La posición no existe'"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:textoExtracto "'La posición no existe' DETECCIÓN En carga o descarga de una herramienta del almacén, con o sin maniobra. CAUSA La posición del almacén no existe. SOLUCIÓN Elegir una posición existente del almacén."@es .

ns1:AvisoSeguridad_0035 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 0035: Número máximo de variables en oscilo sobrepasado" ;
    ns1:identificador "0035" ;
    ns1:textoExtracto "0035 Número máximo de variables en oscilo sobrepasado. DETECCIÓN En el osciloscopio. CAUSA Hay más de dos canales del oscilo con variables del mismo regulador. SOLUCIÓN El número máximo de variables del mismo regulador que se pueden tracear simultáneamente en el oscilo es dos" .

ns1:AvisoSeguridad_0052 a ns1:AvisoSeguridad ;
    rdfs:label "Diferencia de módulos demasiado pequeña" ;
    ns1:identificador "0052" ;
    ns1:mitigaRiesgo ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM ;
    ns1:textoExtracto "0052 'Diferencia de módulos demasiado pequeña' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje. SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:AvisoSeguridad_0053 a ns1:AvisoSeguridad ;
    rdfs:label "Parámetro MPGAXIS repetido en varios volantes" ;
    ns1:identificador "0053" ;
    ns1:mitigaRiesgo ns1:Parametro_MPGAXIS ;
    ns1:textoExtracto "0053 'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros" .

ns1:AvisoSeguridad_0057 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error en pendiente de compensación"@es ;
    ns1:documentadoEn ns1:TablaCompensacion_0057 ;
    ns1:textoExtracto "El valor a compensar no puede ser cero en todos los puntos. [...] CAUSA En las tablas de compensación de husillo, la diferencia entre dos errores consecutivos es mayor que la distancia que separa ambos puntos."@es .

ns1:AvisoSeguridad_0090 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0090: Configuración de ejes por defecto"@es ;
    ns1:identificador "0090" ;
    ns1:mitigaRiesgo ns1:Sistema_CNC ;
    ns1:textoExtracto "0090 'Se arranca con la configuración de ejes por defecto debido a errores en parámetros máquina' [...] SOLUCIÓN Al ser imposible arrancar con la configuración del usuario, el CNC arranca con la configuración por defecto. Corregir la configuración de parámetros máquina para eliminar el resto de errores y warnings."@es .

ns1:AvisoSeguridad_0091 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0091: Variables DRV con ID duplicado y mnemónico inconsistente"@es ;
    ns1:identificador "0091" ;
    ns1:mitigaRiesgo ns1:Sistema_CNC ;
    ns1:textoExtracto "0091 'Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico' [...] SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo mnemónico."@es .

ns1:AvisoSeguridad_0092 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0092: Variables DRV con ID duplicado y MODE/TYPE inconsistente"@es ;
    ns1:identificador "0092" ;
    ns1:mitigaRiesgo ns1:Sistema_CNC ;
    ns1:textoExtracto "0092 'Variables DRV con igual identificador (ID) no pueden tener diferente MODE o TYPE' [...] SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:AvisoSeguridad_0093 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0093: Variables DRV con mnemónico duplicado e ID/MODE/TYPE inconsistente"@es ;
    ns1:identificador "0093" ;
    ns1:mitigaRiesgo ns1:Sistema_CNC ;
    ns1:textoExtracto "0093 'Variables DRV con igual nombre (MNEMONIC) no pueden tener diferente ID, MODE o TYPE' [...] En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente"@es .

ns1:AvisoSeguridad_0170 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 'Tensión de pila baja' (0170)" ;
    ns1:identificador "0170" ;
    ns1:textoExtracto "0170 'Tensión de pila baja' [...] La pila está descargada; ha terminado su ciclo de vida útil." .

ns1:AvisoSeguridad_0171 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 'Sobrepasamiento del LOOPTIME' (0171)" ;
    ns1:identificador "0171" ;
    ns1:textoExtracto "0171 'Sobrepasamiento del LOOPTIME' [...] Las interrupciones de tiempo real superan el tiempo permitido." .

ns1:AvisoSeguridad_0172 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 'Ventilador de la CPU parado' (0172)" ;
    ns1:identificador "0172" ;
    ns1:textoExtracto "0172 Ventilador de la cpu parado. Riesgo de sobretemperatura. [...] El CNC ha detectado que el ventilador de la CPU está parado." .

ns1:AvisoSeguridad_1024 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1024: Número de gama fuera de rango" ;
    ns1:identificador "1024" ;
    ns1:monitoreaParametro ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "1024 'Número de gama fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es demasiado alto. SOLUCIÓN La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." .

ns1:AvisoSeguridad_1025 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1025: Distancia programada igual a cero" ;
    ns1:identificador "1025" ;
    ns1:textoExtracto "1025 'Distancia programada igual a cero' DETECCIÓN Durante la ejecución. CAUSA Movimiento nulo en el bloque de G63. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1026 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1026: Trayectoria circular incorrecta con el radio programado" ;
    ns1:identificador "1026" ;
    ns1:textoExtracto "1026 'Trayectoria circular incorrecta con el radio programado' DETECCIÓN Durante la ejecución. CAUSA Radio demasiado pequeño para la interpolación circular. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1027 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1027: Punto inicial y final de trayectoria circular idénticos" ;
    ns1:identificador "1027" ;
    ns1:textoExtracto "1027 'Punto inicial y final de trayectoria circular idénticos (infinitas soluciones)' DETECCIÓN Durante la ejecución. CAUSA Radio nulo para la interpolación circular; las soluciones son infinitas. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1028 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1028: Diferencia entre el centro programado y el calculado demasiado grande" ;
    ns1:identificador "1028" ;
    ns1:monitoreaParametro ns1:Parametro_CIRINERR,
        ns1:Parametro_CIRINFACT ;
    ns1:textoExtracto "1028 'Diferencia entre el centro programado y el calculado demasiado grande' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular con la función G265 activa, la diferencia entre radio inicial y final supera los parámetros máquina CIRINERR y CIRINFACT. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1029 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1029: Radio nulo en trayectoria circular" ;
    ns1:identificador "1029" ;
    ns1:textoExtracto "1029 'Radio nulo en trayectoria circular' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Radio nulo en una interpolación circular. • Con la función G265 activa, el CNC calcula un radio nulo a partir de las coordenadas del centro programadas en la interpolación circular. • Con la función G264 activa, ambas coordenadas del centro son cero. SOLUCIÓN El radio de una interpolación circular no puede ser nulo. Ambas coordenadas del centro de una interpolación circular no pueden ser nulas." .

ns1:AvisoSeguridad_1030 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1030: #AXIS programado sin G200/201/202" ;
    ns1:identificador "1030" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución." .

ns1:AvisoSeguridad_1041 a ns1:AvisoSeguridad ;
    rdfs:label "Centro de la trayectoria circular corregida fuera de rango (1041)"@es ;
    ns1:identificador "1041" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "1041 'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio y las coordenadas del punto final o bien mediante las coordenadas del punto medio, del punto final y con la función G265 activa. Las coordenadas del centro de la interpolación calculadas por el CNC son demasiado grandes. Las coordenadas programadas para el centro, el punto medio o el radio son demasiado grandes. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1043 a ns1:AvisoSeguridad ;
    rdfs:label "El tercer eje del plano no puede coincidir con el primero o segundo (1043)"@es ;
    ns1:identificador "1043" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "1043 'El tercer eje del plano no puede coincidir con el primero o segundo' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el parámetro 5 coincide con el 1 o con el 2. SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. Este parámetro no deberá coincidir ni con el primero ni con el segundo."@es .

ns1:AvisoSeguridad_1044 a ns1:AvisoSeguridad ;
    rdfs:label "El primer y segundo eje del plano no pueden coincidir (1044)"@es ;
    ns1:identificador "1044" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "1044 'El primer y segundo eje del plano no pueden coincidir' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el primer eje del plano (parámetro 1) y el segundo (parámetro 2) son el mismo eje. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1045 a ns1:AvisoSeguridad ;
    rdfs:label "Programación incorrecta del primer eje del plano (1045)"@es ;
    ns1:identificador "1045" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "1045 'Programación incorrecta del primer eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el primer eje del plano (parámetro 1) es incorrecto. SOLUCIÓN El primer eje del plano debe ser uno de los tres primeros ejes del canal."@es .

ns1:AvisoSeguridad_1046 a ns1:AvisoSeguridad ;
    rdfs:label "Programación incorrecta del segundo eje del plano (1046)"@es ;
    ns1:identificador "1046" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "1046 'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal."@es .

ns1:AvisoSeguridad_1054 a ns1:AvisoSeguridad ;
    rdfs:label "Garra inexistente" ;
    ns1:identificador "1054" ;
    ns1:textoExtracto "1054 'Garra inexistente' DETECCIÓN Durante la ejecución. CAUSA El número de garra programado no existe. SOLUCIÓN El número de garra debe ser un valor entre cero y diez." .

ns1:AvisoSeguridad_1055 a ns1:AvisoSeguridad ;
    rdfs:label "Modificación simultánea de D y radio de herramienta" ;
    ns1:identificador "1055" ;
    ns1:textoExtracto "1055 'No se permite modificar D y el radio de la herramienta en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite modificar el radio de la herramienta (variable (V.)G.TOR) y programar un cambio de herramienta y/o corrector en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes." .

ns1:AvisoSeguridad_1056 a ns1:AvisoSeguridad ;
    rdfs:label "Número de variables externas sobrepasado" ;
    ns1:identificador "1056" ;
    ns1:textoExtracto "1056 'Número de variables externas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha alcanzado el número de variables externas admisibles. SOLUCIÓN Revisar la programación. El CNC admite 500 variables externas." .

ns1:AvisoSeguridad_1057 a ns1:AvisoSeguridad ;
    rdfs:label "Variable sin permiso de lectura" ;
    ns1:identificador "1057" ;
    ns1:textoExtracto "1057 'Variable sin permiso de lectura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer desde el programa pieza o MDI una variable que no tiene permiso de lectura por programa. SOLUCIÓN No es posible leer la variable desde programa pieza o MDI. Consultar en la documentación los permisos de la variable." .

ns1:AvisoSeguridad_1058 a ns1:AvisoSeguridad ;
    rdfs:label "Variable de usuario sin inicializar" ;
    ns1:identificador "1058" ;
    ns1:textoExtracto "1058 'Variable de usuario sin inicializar' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario V.P.name o V.S.name no ha sido definida. SOLUCIÓN Revisar la programación. Definir adecuadamente la variable." .

ns1:AvisoSeguridad_1059 a ns1:AvisoSeguridad ;
    rdfs:label "Variable sin permiso de escritura" ;
    ns1:identificador "1059" ;
    ns1:textoExtracto "1059 'Variable sin permiso de escritura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir desde el programa pieza o MDI una variable que no tiene permiso de escritura por programa. SOLUCIÓN No es posible escribir esta variable desde programa pieza o MDI. Consultar en la documentación los permisos de la variable." .

ns1:AvisoSeguridad_1060 a ns1:AvisoSeguridad ;
    rdfs:label "Valor de etiqueta N fuera de rango" ;
    ns1:identificador "1060" ;
    ns1:textoExtracto "1060 'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" no es válido. SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." .

ns1:AvisoSeguridad_1061 a ns1:AvisoSeguridad ;
    rdfs:label "Función G inexistente"@es ;
    ns1:identificador "1061" ;
    ns1:textoExtracto "1061 'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1062 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles"@es ;
    ns1:identificador "1062" ;
    ns1:textoExtracto "1062 'Funciones G incompatibles' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1063 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G108/G109/G193)"@es ;
    ns1:identificador "1063" ;
    ns1:textoExtracto "1063 'Funciones G incompatibles (G108/G109/G193)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1064 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G196/G197)"@es ;
    ns1:identificador "1064" ;
    ns1:textoExtracto "1064 'Funciones G incompatibles (G196/G197)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1065 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G17/G18/G19/G20)"@es ;
    ns1:identificador "1065" ;
    ns1:textoExtracto "1065 'Funciones G incompatibles (G17/G18/G19/G20)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1066 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G136/G137)"@es ;
    ns1:identificador "1066" ;
    ns1:textoExtracto "1066 'Funciones G incompatibles (G136/G137)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1067 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G40/G41/G42)"@es ;
    ns1:identificador "1067" ;
    ns1:textoExtracto "1067 'Funciones G incompatibles (G40/G41/G42)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1068 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G151/G152)"@es ;
    ns1:identificador "1068" ;
    ns1:textoExtracto "1068 'Funciones G incompatibles (G151/G152)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:AvisoSeguridad_1069 a ns1:AvisoSeguridad ;
    rdfs:label "Funciones G incompatibles (G54-G59/G159)"@es ;
    ns1:identificador "1069" ;
    ns1:textoExtracto "1069 'Funciones G incompatibles (G54-G59/G159)' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí."@es .

ns1:AvisoSeguridad_1070 a ns1:AvisoSeguridad ;
