ns1:ActualizacionDeSWCorrectaDeDispositivosPwCSERCOS3 a ns1:DiagnosticoFallo ;
    rdfs:label "Actualización de SW correcta de dispositivos PwC (SERCOS3)"@es ;
    ns1:identificador "0119" ;
    ns1:solucionaFallo ns1:DispositivoPwC_7ce24c23b1 ;
    ns1:textoExtracto "Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción."@es .

ns1:ActualizarModuloRCSS a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar módulo RCS-S" ;
    ns1:solucionaFallo ns1:Modulo_RCS_S ;
    ns1:textoExtracto "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat." .

ns1:AdvertenciaDeSaturacionDeRecursosEnModoBloqueABloque a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de saturación de recursos en modo bloque a bloque"@es ;
    ns1:mitigaRiesgo ns1:Fallo_3078 ;
    ns1:textoExtracto "Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas"@es .

ns1:AdvertenciaDesactivarCinematicaParaAcoplamientoDeEjeEsclavo a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Desactivar cinemática para acoplamiento de eje esclavo"@es ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la cinemática para poder acoplar el eje. El eje participante en la cinemática activa sí puede ser eje maestro de un acoplo."@es .

ns1:AdvertenciaDiscoDesprotegidoEnModoPuestaAPunto a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Disco desprotegido en modo puesta a punto"@es ;
    ns1:mitigaRiesgo ns1:CNCEnModoPuestaAPuntoConDiscoDesprotegido ;
    ns1:textoExtracto "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido."@es .

ns1:AdvertenciaSobreAnulacionDeSeguridades a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre anulación de seguridades" ;
    ns1:mitigaRiesgo ns1:CNC_8028 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC, y que sean imputables a la anulación de alguna de las seguridades."@es .

ns1:AdvertenciaSobreModificacionNoAutorizadaDeHardware a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre modificación no autorizada de hardware" ;
    ns1:mitigaRiesgo ns1:SistemaHardware_8028_1 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC, y que sean imputables a una modificación del hardware por personal no autorizado por Fagor Automation."@es .

ns1:AdvertenciaSobreVirusInformaticos a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre virus informáticos" ;
    ns1:mitigaRiesgo ns1:SistemaSoftware_8028_1 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC, y que sean imputables a la presencia de un virus informático en el sistema."@es .

ns1:AjusteDeEjesParaTransformacion a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de ejes para transformación" ;
    ns1:textoExtracto "Si es posible, definir los ejes como de intercambio mantenido; si no, utilizar otros ejes para la transformada." .

ns1:AjusteDeParametrosParaTrazaSercosError4023 a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de parámetros para traza Sercos (Error 4023)" ;
    ns1:solucionaFallo ns1:Error4023ConfiguracionFallidaDeTrazaProgramadaEnSercos ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de variables en el telegrama. Si el ancho de banda está limitado, subir la frecuencia SERBRATE o eliminar reguladores del anillo." .

ns1:AjusteDelEjeRotativoFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Ajuste del eje rotativo fuera de rango"@es ;
    ns1:identificador "9348" ;
    ns1:solucionaFallo ns1:VKMAXROTCOMP ;
    ns1:textoExtracto "Ajuste del eje rotativo, (valor medido=%d) fuera del rango permitido por el valor máximo (V.K.MAXROTCOMP=%d) en el eje %s. DETECCIÓN Durante la calibración de cinemáticas. CAUSA El valor medido es mayor que el máximo permitido (V.K.MAXROTCOMP). SOLUCIÓN Cambiar el valor de V.K.MAXROTCOMP en la subrutina KINCAL_BEGIN.NC o el valor compensado quedará limitado a ese valor."@es .

ns1:Alarma0048UnEjeNoPuedeSerEsclavoDeVariosMaestros_871965036d a ns1:Alarma ;
    rdfs:label "Alarma 0048: Un eje no puede ser esclavo de varios maestros" ;
    ns1:monitoreaParametro ns1:ParametroDeConfiguracionDeLaTablaDeEjesGantry_e3f92765e2 ;
    ns1:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry ya está definido como eje esclavo en otro eje gantry. SOLUCIÓN Corregir la tabla de ejes gantry." .

ns1:Alarma0049UnEjeMaestroNoPuedeSerASuVezEsclavoYViceversa_e8623af9eb a ns1:Alarma ;
    rdfs:label "Alarma 0049: Un eje maestro no puede ser a su vez esclavo y viceversa" ;
    ns1:monitoreaParametro ns1:ParametroDeConfiguracionDeLaTablaDeEjesGantry_e3f92765e2 ;
    ns1:textoExtracto "0049 'Un eje maestro no puede ser a su vez esclavo y viceversa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje maestro de un eje gantry es el eje esclavo en otro eje gantry o viceversa. SOLUCIÓN Corregir la tabla de ejes gantry." .

ns1:Alarma0050LosEjesMaestroYEsclavoDebenSerDelMismoTipoAXISTYPE_84002bb7e4 a ns1:Alarma ;
    rdfs:label "Alarma 0050: Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)" ;
    ns1:monitoreaParametro ns1:Parametro_AXISTYPE ;
    ns1:textoExtracto "0050 'Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no son del mismo tipo; lineales o rotativos. SOLUCIÓN Los ejes de una pareja gantry tienen que ser del mismo tipo, lineales o rotativos (parámetro AXISTYPE)." .

ns1:Alarma0051LosEjesMaestroYEsclavoDebenTenerCiertosParametrosConElMismoValor_1bb94507bb a ns1:Alarma ;
    rdfs:label "Alarma 0051: Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor" ;
    ns1:monitoreaParametro ns1:AXISMODEModoDeEje,
        ns1:LONGAXIS_3b1e99e02b,
        ns1:ParametroMPAFACEAXIS_8060b29a09,
        ns1:ParametroMaquinaCAXISNombrePorDefectoDelEjeC_e9a5684837,
        ns1:SHORTESTWAY_d9e770d3ae ;
    ns1:textoExtracto "0051 'Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de un eje gantry no tienen las mismas propiedades. SOLUCIÓN Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes." .

ns1:Alarma0074TestDeTendenciaSinActivar_0acee78abe a ns1:Alarma ;
    rdfs:label "Alarma 0074 'Test de tendencia sin activar'"@es ;
    ns1:identificador "0074" ;
    ns1:textoExtracto "0074 'Test de tendencia sin activar'"@es .

ns1:Alarma0080ValidacionDeParametrosGenerales_7e65e74677 a ns1:Alarma ;
    rdfs:label "Alarma 0080: Validación de parámetros generales"@es ;
    ns1:identificador "0080" ;
    ns1:textoExtracto "'Para validar el eje, hay que validar la tabla de PARAMETROS GENERALES' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha añadido algún eje al sistema (parámetro NAXIS), y sin validar la tabla de parámetros generales, ha intentado validar la tabla de parámetros de uno de los nuevos ejes."@es .

ns1:Alarma0081BandaDeMuerteInferiorAResolucionDelEje_1a96f40388 a ns1:Alarma ;
    rdfs:label "Alarma 0081: Banda de muerte inferior a resolución del eje"@es ;
    ns1:identificador "0081" ;
    ns1:textoExtracto "'La banda de muerte no puede ser menor que la resolución del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La banda de muerte es menor que la resolución del eje."@es .

ns1:Alarma0082CompensacionDeHusilloOCruzadaImposible_6f73538591 a ns1:Alarma ;
    rdfs:label "Alarma 0082: Compensación de husillo o cruzada imposible"@es ;
    ns1:identificador "0082" ;
    ns1:textoExtracto "'Compensación de husillo o cruzada imposible para todas las gamas del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una compensación, el eje que se mueve (parámetro MOVAXIS) es rotativo y no tiene los mismos límites de módulo en todos los sets de parámetros."@es .

ns1:Alarma0083TiposDeReguladorIncompatiblesEnParejaGantry_4884b39e6b a ns1:Alarma ;
    rdfs:label "Alarma 0083: Tipos de regulador incompatibles en pareja gantry"@es ;
    ns1:identificador "0083" ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben ser del mismo tipo (DRIVETYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink."@es .

ns1:Alarma0158WRITESinOPENPrevio_429eed13f8 a ns1:Alarma ;
    rdfs:label "Alarma 0158: #WRITE sin #OPEN previo" ;
    ns1:identificador "0158" ;
    ns1:solucionaFallo ns1:ComandoOPENAbrirArchivo_acc5edfce7 ;
    ns1:textoExtracto "#WRITE necesita un #OPEN previo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir (#WRITE) en un archivo que no está abierto." .

ns1:Alarma0159FicheroYaAbiertoPorOtroCanal_7505cbbbab a ns1:Alarma ;
    rdfs:label "Alarma 0159: Fichero ya abierto por otro canal" ;
    ns1:identificador "0159" ;
    ns1:solucionaFallo ns1:ComandoCLOSECerrarArchivo_c3cbec1887 ;
    ns1:textoExtracto "#OPEN:Fichero ya abierto por otro canal. DETECCIÓN Durante la ejecución. CAUSA Un canal ha intentado abrir un archivo que está abierto por otro canal." .

ns1:Alarma0160EjeSetNoDisponibleEnElSistema_2e64273573 a ns1:Alarma ;
    rdfs:label "Alarma 0160: Eje/Set no disponible en el sistema" ;
    ns1:identificador "0160" ;
    ns1:solucionaFallo ns1:ComandoFREEAXLiberarEje_079eb5206b ;
    ns1:textoExtracto "'Eje/Set no disponible en el sistema'. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Las sentencias #SET AX o #CALL AX están intentando añadir al canal un eje inexistente o que está en otro canal. • En la función G112 hay programado un set de parámetros inexistente." .

ns1:Alarma0161ModoAPPENDNoPermitidoSobreFicheroNoUnicode_1d1f66abca a ns1:Alarma ;
    rdfs:label "Alarma 0161: Modo APPEND no permitido sobre fichero no Unicode" ;
    ns1:identificador "0161" ;
    ns1:solucionaFallo ns1:ModoOperacion_DELETTE ;
    ns1:textoExtracto "#OPEN:Modo APPEND no permitido sobre un fichero no Unicode. DETECCIÓN Durante la ejecución. CAUSA Un canal ha intentado abrir un archivo no-Unicode con modo de acceso 'APPEND'." .

ns1:Alarma0162ParametroTYPENoCoincideConFormatoDelFichero_6f8646d561 a ns1:Alarma ;
    rdfs:label "Alarma 0162: Parámetro TYPE no coincide con formato del fichero" ;
    ns1:identificador "0162" ;
    ns1:mitigaRiesgo ns1:ParametroTYPEFormatoDeArchivo_80fd73a0ac ;
    ns1:textoExtracto "#OPEN:El parámetro TYPE no se corresponde con el formato del fichero. DETECCIÓN Durante la ejecución. CAUSA El formato del archivo no coincide con el formato seleccionado en TYPE." .

ns1:Alarma1037CoordenadasDelCentroIgnoradasConG0G1G100G63Activas_e82cfbac12 a ns1:Alarma ;
    rdfs:label "Alarma 1037: Coordenadas del centro ignoradas con G0/G1/G100/G63 activas" ;
    ns1:activaAlarma ns1:FuncionG0MovimientoRapido_2fb849866d,
        ns1:FuncionG100Medicion_0eda72bfea,
        ns1:FuncionG1InterpolacionLineal_2feb6c0d27,
        ns1:G63_73c48908e7 ;
    ns1:identificador "1037" ;
    ns1:monitoreaParametro ns1:ParametroI_d8545c5396,
        ns1:ParametroJFuncionG30G73_6fb2658b72,
        ns1:ParametroKNumeroDeMecanizados_c4d34836ef ;
    ns1:textoExtracto "'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado los parámetros I, J, K con la función G0, G1, G100 o G63 activa. El CNC ignora estos parámetros. SOLUCIÓN Estas funciones no necesitan estos parámetros." .

ns1:Alarma1038NoSeAdmiteCompensacionDeRadioActivaEnMedicion_06250f420b a ns1:Alarma ;
    rdfs:label "Alarma 1038: No se admite compensación de radio activa en medición" ;
    ns1:activaAlarma ns1:FuncionG100Medicion_0eda72bfea ;
    ns1:identificador "1038" ;
    ns1:monitoreaParametro ns1:FuncionG41CompensacionDeRadioIzquierda_dead262ed5,
        ns1:FuncionG42CompensacionDeRadioDerecha_072f6354eb ;
    ns1:textoExtracto "'No se admite compensación de radio activa en medición' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar la función G100 con la compensación de radio activa (G41/G42). SOLUCIÓN Revisar la programación." .

ns1:Alarma1039ExisteUnValorDeMedicionPrevioParaElEjeS_402f1a91c5 a ns1:Alarma ;
    rdfs:label "Alarma 1039: Existe un valor de medición previo para el eje(s)" ;
    ns1:activaAlarma ns1:FuncionG100Medicion_0eda72bfea ;
    ns1:identificador "1039" ;
    ns1:solucionaFallo ns1:FuncionG102_b587c5e005 ;
    ns1:textoExtracto "'Existe un valor de medición previo para el eje(s)' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta realizar un medición (G100) en un eje que tiene un offset de medición anterior. SOLUCIÓN Utilizar la función G102 para anular el offset de medición incluido en el eje." .

ns1:Alarma1060ValorDeEtiquetaNFueraDeRango_aab114000e a ns1:Alarma ;
    rdfs:label "Alarma 1060: Valor de etiqueta N fuera de rango" ;
    ns1:identificador "1060" ;
    ns1:monitoreaParametro ns1:NumeroDeBloqueN ;
    ns1:textoExtracto "'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" no es válido. SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." .

ns1:Alarma1061FuncionGInexistente_dfee186b68 a ns1:Alarma ;
