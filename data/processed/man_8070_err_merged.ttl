ns1:Fallo_9624 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal I0"@es ;
    ns1:identificador "9624" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisarCableado_9624 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal I0 del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es .

ns1:Fallo_9625 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal AL"@es ;
    ns1:identificador "9625" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisarCableado_9625 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal AL del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es .

ns1:Fallo_9626 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Sobrecorriente o cortocircuito"@es ;
    ns1:identificador "9626" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisarConexionado_9626 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador. SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador."@es .

ns1:Fallo_9627 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Recibida señal de alarma"@es ;
    ns1:identificador "9627" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisarEncoder_9627 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo. SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado."@es .

ns1:Fallo_9636 a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Transductor no estable en Power-ON" ;
    ns1:identificador "9636" ;
    ns1:solucionaFallo ns1:Cable_TransductorABSIND,
        ns1:Modulo_ABSIND ;
    ns1:textoExtracto "DETECCIÓN: Durante el arranque del sistema. CAUSA: La posición leída durante la inicialización del módulo ABSIND no es estable. SOLUCIÓN: Comprobar que el eje no se mueve durante el arranque o inicialización del módulo ABSIND. Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver. Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:Fallo_9637 a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: Checksum EEPROM incorrecto" ;
    ns1:identificador "9637" ;
    ns1:solucionaFallo ns1:Modulo_ABSIND ;
    ns1:textoExtracto "DETECCIÓN: Durante el arranque o funcionamiento habitual del sistema. CAUSA: El checksum leído durante la inicialización del módulo ABSIND es incorrecto. SOLUCIÓN: Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Fallo_9659 a ns1:DiagnosticoFallo ;
