        "20014 Esperando final de búsqueda de cero del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:AvisoSeguridad_20021 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando inicialización de captaciones" ;
    ns1:identificador "20021" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Reset ;
    ns1:textoExtracto "Esperando inicialización de captaciones. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. La inicialización de las captaciones debe finalizar." .

ns1:AvisoSeguridad_20022 a ns1:AvisoSeguridad ;
    rdfs:label "Opción de software #HSC FAST/SURFACE no permitida" ;
    ns1:identificador "20022" ;
    ns1:textoExtracto "Opción de software #HSC FAST/SURFACE no permitida. Ejecutándose en modo compatible. DETECCIÓN Durante la ejecución. CAUSA Programación de #HSC no permitida porque falta la opción de software. SOLUCIÓN Adquirir la opción de software o programar una opción permitida." .

ns1:AvisoSeguridad_20023 a ns1:AvisoSeguridad ;
    rdfs:label "DMC: aprendizaje para ajustar la potencia objetivo" ;
    ns1:identificador "20023" ;
    ns1:textoExtracto "DMC: aprendizaje para ajustar la potencia objetivo. DETECCIÓN Durante la ejecución. CAUSA El DMC avisa que ha empezado el aprendizaje. SOLUCIÓN No requiere ninguna acción." .

ns1:AvisoSeguridad_20024 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando parámetros nuevo Set del eje/cabezal %x" ;
    ns1:identificador "20024" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Reset ;
    ns1:textoExtracto "Esperando parámetros nuevo Set del eje/cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. Los parámetros del nuevo set deben llegar." .

ns1:AvisoSeguridad_20025 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar cambio de gama anterior del eje/cabezal %x" ;
