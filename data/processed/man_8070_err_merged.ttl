ns1:AvisoSeguridad_1769 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1769: PERFIL DE PUNTOS: S = 0"@es ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad_PerfilPuntos_S ;
    ns1:textoExtracto "1769 'PERFIL DE PUNTOS: S = 0' [...] SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1770 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1770: PERFIL DE PUNTOS: T = 0"@es ;
    ns1:monitoreaParametro ns1:Parametro_Herramienta_PerfilPuntos_T ;
