    ns1:identificador "1174" ;
    ns1:textoExtracto "1174 '#LINK: no se permite definir un nuevo acoplo con uno anterior activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero."@es .

ns1:Error1739 a ns1:AvisoSeguridad ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1739" ;
    ns1:textoExtracto "1739 'CAJERA RECTANGULAR: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o"@es .

ns1:Error23007_CompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error 23007: Elemento fuera de rango en compensación volumétrica" ;
    ns1:identificador "23007" ;
    ns1:textoExtracto "23007 Error en el fichero de compensación volumétrica: elemento fuera del rango esperado. [...] CAUSA Variable o elemento del archivo de compensación volumétrica fuera de rango." .

ns1:Error23018 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es,
        "Error en fichero de compensación volumétrica (SQUARENESS_IS_POSITIVE)"@es ;
    ns1:identificador "23018" ;
    ns1:monitoreaParametro ns1:Parametro_SQUARENESS_IS_POSITIVE ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Modificación incorrecta del archivo de compensación volumétrica"@es ;
            ns1:textoExtracto "Modificar el archivo de la compensación volumétrica."@es ] ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"SQUARENESS_IS_POSITIVE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"SQUARENESS_IS_POSITIVE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es,
        "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero 'SQUARENESS_IS_POSITIVE' es incorrecto."@es .

ns1:Error23024 a ns1:AvisoSeguridad ;
    rdfs:label "Error en compensación volumétrica (segundo eje, límite superior)"@es ;
    ns1:identificador "23024" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del segundo eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error23025 a ns1:AvisoSeguridad ;
    rdfs:label "Error en compensación volumétrica (tercer eje, límite inferior)"@es ;
    ns1:identificador "23025" ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del tercer eje está fuera del límite inferior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del tercer eje está fuera del límite inferior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

