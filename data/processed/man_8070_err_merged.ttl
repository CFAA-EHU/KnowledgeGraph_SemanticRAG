    rdfs:label "Error en la CPU (Captación E21B)"@es ;
    ns1:identificador "E294" ;
    ns1:textoExtracto "E294 Captación digital Fagor. Error en la CPU. Captación E21B."@es .

ns1:Error_E295 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21B)"@es ;
    ns1:identificador "E295" ;
    ns1:textoExtracto "E295 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21B."@es .

ns1:Error_E394 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la CPU (Captación E21C)"@es ;
    ns1:identificador "E394" ;
    ns1:textoExtracto "E394 Captación digital Fagor. Error en la CPU. Captación E21C."@es .

ns1:Error_E395 a ns1:AvisoSeguridad ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21C)"@es ;
    ns1:identificador "E395" ;
    ns1:textoExtracto "E395 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21C."@es .

ns1:Error_Indeterminado_Arranque a ns1:AvisoSeguridad ;
    rdfs:label "Error indeterminado: Apagado/reinicio durante arranque del CNC"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo."@es .

ns1:EsclavosBus_4603 a ns1:ComponenteElectrico ;
    rdfs:label "Esclavos conectados al bus EtherCAT"@es ;
    ns1:textoExtracto "esclavos conectados al bus"@es .

ns1:EsclavosSercos a ns1:ComponenteElectrico ;
    rdfs:label "Esclavos del anillo Sercos" ;
    ns1:textoExtracto "esclavos" .

ns1:FPGA_ReguladorRPS a ns1:ComponenteElectrico ;
    rdfs:label "FPGA en regulador o RPS"@es ;
    ns1:monitoreaParametro ns1:Param_VersionFPGA ;
    ns1:textoExtracto "la versión de la FPGA en algún regulador o RPS"@es .

ns1:FalloAccesoVariableCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Variable no accesible por programa o MDI"@es ;
    ns1:identificador "1674" ;
    ns1:textoExtracto "La variable programada existe, pero no tiene permiso de acceso desde el programa o MDI, o es una variable de texto. [...] Consultar en los manuales los permisos de acceso de las variables."@es .

ns1:FalloBus_24500 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del bus corregido (24500)"@es ;
    ns1:identificador "24500" ;
    ns1:textoExtracto "Se ha quitado el fallo del bus. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo del bus corregida. SOLUCIÓN No requiere ninguna acción."@es .

ns1:FalloComandoMechatrolink_4501 a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "Fallo en la ejecución de un comando Mechatrolink desde el master a un esclavo determinado."@es .

ns1:FalloConexionVolante_9731 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en conexionado o alimentación del volante de captación"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y la alimentación del volante."@es .

ns1:FalloConfiguracionEjesGantry a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en configuración de ejes gantry/tándem"@es ;
    ns1:identificador "0098" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "AXISEXCH (parámetro de eje)"@es ;
            ns1:textoExtracto "parámetro AXISEXCH"@es ;
            ns1:valor "consecutivo"@es ] ;
    ns1:textoExtracto "Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas. [...] 0098 'El eje maestro y el esclavo tienen diferente parámetro AXISEXCH'"@es .

ns1:FalloControlCabezalG33_G34 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de control del cabezal en funciones G33/G34"@es ;
    ns1:textoExtracto "La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición."@es .

ns1:FalloDataLink a ns1:DiagnosticoFallo ;
    rdfs:label "DataLink no presente" ;
    ns1:identificador "9738" ;
    ns1:textoExtracto "9738 DataLink no presente."@es .

ns1:FalloNodoCANopen_6011 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en nodo CANopen (código 6011)" ;
    ns1:identificador "6011" ;
    ns1:solucionaFallo ns1:AsistenciaTecnica_Contacto ;
    ns1:textoExtracto "Fallo en algún nodo de I/Os. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica. 6011 'Report de nodo CANopen:Emergencia indeterminada.' [...] Este error indica que un nodo CANopen ha enviado un mensaje de emergencia." .

ns1:FalloPosicionHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de posición de herramienta en cabezal"@es ;
    ns1:identificador "DETECCIÓN_DURANTE_ARRANQUE_CNC" ;
    ns1:textoExtracto "La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es .

ns1:FalloSeguimientoEjeTangencial a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de seguimiento del eje tangencial"@es ;
    ns1:textoExtracto "El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo."@es .

ns1:FalloSincronizacionCabezales a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo al sincronizar cabezales (búsqueda de cero/forzar cota bloqueada)"@es ;
    ns1:identificador "1673" ;
    ns1:textoExtracto "Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos. [...] Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es .

ns1:FalloSincronizacion_3413 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3413: Sincronización con ratio inválido"@es ;
    ns1:identificador "3413" ;
    ns1:textoExtracto "En la sincronización en posición, el eje maestro tiene módulo y el ratio de transmisión es diferente de 1"@es,
        "En la sincronización, el denominador del ratio de transmisión tiene valor cero"@es,
        "No se puede sincronizar en posición con módulo y ratio diferente de 1"@es .

ns1:FalloSintaxis8423 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#OSC eje1 eje2 ...'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:FalloSintaxis8424 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#CLEAR<[marca, ...]>'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:FalloSintaxis8425 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#HSC OFF'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:FalloTensionAlimentacion_9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de tensión de alimentación en captación digital"@es ;
    ns1:identificador "9647" ;
    ns1:monitoreaParametro ns1:ParametroTensionAlimentacion_5.3V-4.1V ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es .

ns1:FalloTensionUM_24501 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa (24501)"@es ;
    ns1:identificador "24501" ;
    ns1:textoExtracto "Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT"@es .

ns1:Fallo_0110 a ns1:DiagnosticoFallo ;
    rdfs:label "No se pudo cargar la cinemática de usuario"@es ;
    ns1:identificador "0110" ;
    ns1:textoExtracto """\r
    0110 'No se pudo cargar la cinemática de usuario'\r
    DETECCIÓN Durante el arranque del CNC.\r
    CAUSA El CNC no encuentra el fichero c:\\FagorCNC\\drivers\\kinematic.sys (o c:\\Cnc8070\\drivers\\kinematic.sys).\r
    SOLUCIÓN Compruebe que al hacer el make de cinemática de usuario no se producen errores y que el driver kinematic.sys se genera correctamente.\r
    """@es .

ns1:Fallo_0111 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de datos de la cinemática de usuario"@es ;
    ns1:identificador "0111" ;
    ns1:textoExtracto """\r
    0111 'Error en la inicialización de datos de la cinemática de usuario'\r
    DETECCIÓN Durante el arranque del CNC.\r
    CAUSA Error en la función de inicialización y carga de datos de la cinemática de usuario (UserTransforDataInit) implementada en el fichero Kin_iniData.c.\r
    SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error.\r
    """@es .

ns1:Fallo_0112 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de la cinemática de usuario"@es ;
    ns1:identificador "0112" ;
    ns1:textoExtracto """\r
    0112 'Error en la inicialización de la cinemática de usuario'\r
    DETECCIÓN Al activar una cinemática de usuario.\r
    CAUSA Error en la función de inicialización de la cinemática (UserTransforInit) implementada en el fichero Kin_impl.c.\r
    SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error.\r
    """@es .

ns1:Fallo_0113 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de parámetros de la cinemática de usuario"@es ;
    ns1:identificador "0113" ;
    ns1:textoExtracto """\r
    0113 'Error en la inicialización de parámetros de la cinemática de usuario'\r
    DETECCIÓN Al activar una cinemática de usuario.\r
    CAUSA Error en la función de inicialización de la cinemática (UserTransforParamInit) implementada en el fichero Kin_impl.c.\r
    SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error.\r
    """@es .

ns1:Fallo_0114 a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible validar parámetros durante la simulación de un programa en el canal"@es ;
    ns1:identificador "0114" ;
    ns1:textoExtracto """\r
    0114 No es posible validar parámetros durante la simulación de un programa en el canal.\r
    DETECCIÓN Durante la validación de los parámetros máquina.\r
    CAUSA El usuario ha intentado validar los parámetros durante la simulación de un programa.\r
    SOLUCIÓN Detener la simulación del programa para validar los parámetros.\r
    """@es .

ns1:Fallo_1248 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite roscado y G192 en el mismo bloque"@es ;
    ns1:identificador "1248" ;
    ns1:textoExtracto "El CNC no permite programar las funciones G63 (roscado rígido) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

ns1:Fallo_1249 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama con G96 activa"@es ;
    ns1:identificador "1249" ;
    ns1:solucionaFallo ns1:Funcion_G96 ;
    ns1:textoExtracto "1249 'No se admite cambio de gama con G96 activa' [...] CAUSA El CNC ha intentado cambiar la gama del cabezal (G112) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para realizar el cambio de gama del cabezal."@es,
        "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). SOLUCIÓN Activar el modo de velocidad de giro constante (G97)."@es .

ns1:Fallo_1399 a ns1:DiagnosticoFallo ;
    rdfs:label "No puede activarse el eje como Hirth"@es ;
    ns1:identificador "1399" ;
    ns1:textoExtracto "1399 'No puede activarse el eje como Hirth' DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1750 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: F = 0"@es ;
    ns1:identificador "1750" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN: Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1751 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: S = 0"@es ;
    ns1:identificador "1751" ;
    ns1:textoExtracto "Durante la ejecución del ciclo."@es .

ns1:Fallo_1753 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: P = 0" ;
    ns1:identificador "1753" ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            rdfs:label "Asignar al parámetro P un valor mayor que 0" ;
            ns1:textoExtracto "Asignar al parámetro un valor mayor que 0." ] ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:Fallo_1754 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Diámetro de herramienta menor que DELTA" ;
    ns1:identificador "1754" ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            rdfs:label "Reducir paso de fresado o usar herramienta de mayor diámetro" ;
            ns1:textoExtracto "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." ] ;
    ns1:textoExtracto "En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ)." .

ns1:Fallo_1755 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Diámetro de herramienta ACABADO menor que delta" ;
    ns1:identificador "1755" ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            rdfs:label "Herramienta de mayor diámetro para pasada de acabado" ;
            ns1:textoExtracto "Elegir una herramienta de mayor diámetro para la pasada de acabado." ] ;
    ns1:textoExtracto "El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ)." .

ns1:Fallo_1756 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: F = 0" ;
    ns1:identificador "1756" ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            rdfs:label "Asignar valor > 0 al parámetro F" ;
            ns1:textoExtracto "Asignar al parámetro un valor mayor que 0." ] ;
    ns1:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:Fallo_1757 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: S = 0" ;
    ns1:identificador "1757" ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            rdfs:label "Asignar valor > 0 al parámetro S" ;
            ns1:textoExtracto "Asignar al parámetro un valor mayor que 0." ] ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

ns1:Fallo_1758 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: T = 0" ;
    ns1:identificador "1758" ;
