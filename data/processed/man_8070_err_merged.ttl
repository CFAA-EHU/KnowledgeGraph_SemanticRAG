ns1:Error1239NumeroMaximoDeMacrosSobrepasado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1239: Número máximo de macros sobrepasado"@es ;
    ns1:identificador "1239" ;
    ns1:textoExtracto "1239 'Número máximo de macros sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de macros en el CNC. SOLUCIÓN El máximo es 50 macros. Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB."@es .

ns1:Error1290ProgramacionDeCoordenadasIJKIncorrecta a ns1:AvisoSeguridad ;
    rdfs:label "Error 1290: Programación de coordenadas I, J, K incorrecta" ;
    ns1:identificador "1290" ;
    ns1:textoExtracto "1290 'Programación de coordenadas I, J, K incorrecta' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los valores programados para el centro de una interpolación circular, origen polar o centro de giro del sistema de coordenadas son demasiado altos. • Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos. SOLUCIÓN Revisar la programación." .

ns1:Error1291NoSeAdmitenMasFuncionesS a ns1:AvisoSeguridad ;
    rdfs:label "Error 1291: No se admiten más funciones S" ;
    ns1:identificador "1291" ;
    ns1:textoExtracto "1291 'No se admiten más funciones S' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones S de las permitidas. SOLUCIÓN El máximo número de funciones S admitido en un mismo bloque es 4." .

ns1:Error1292FuncionMDoblementeProgramada a ns1:AvisoSeguridad ;
    rdfs:label "Error 1292: Función M doblemente programada" ;
    ns1:identificador "1292" ;
    ns1:textoExtracto "1292 'Función M doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función M está programada más de una vez en el bloque." .

ns1:Error1352VariableDuplicadaVARENDVAR a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1352: Variable duplicada (#VAR/#ENDVAR)"@es ;
    ns1:identificador "1352" ;
    ns1:textoExtracto "'#VAR/#ENDVAR: la variable definida ya existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación."@es .

ns1:Error1353ExcesoDeValoresEnInicializacionDeArray a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1353: Exceso de valores en inicialización de array"@es ;
    ns1:identificador "1353" ;
    ns1:textoExtracto "'Demasiados valores para inicializar el array' DETECCIÓN Durante la ejecución. CAUSA En la inicialización de una variable de array de usuario, el CNC inicializa más posiciones de las que tiene. SOLUCIÓN Revisar la programación."@es .

ns1:Error1354FalloEnLecturaDeVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1354: Fallo en lectura de variable"@es ;
    ns1:identificador "1354" ;
    ns1:textoExtracto "'Error en la lectura de la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede leer la variable. SOLUCIÓN Revisar la programación."@es .

ns1:Error1355IntentoDeBorradoDeVariableDeSistema a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1355: Intento de borrado de variable de sistema"@es ;
    ns1:identificador "1355" ;
    ns1:textoExtracto "'No se puede borrar la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado borrar una variable del sistema. SOLUCIÓN El CNC sólo puede borrar variables de usuario (prefijos P y S)."@es .

ns1:Error1356SintaxisIncorrectaEnIFEXIST a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1356: Sintaxis incorrecta en $IF EXIST"@es ;
    ns1:identificador "1356" ;
    ns1:textoExtracto "'Se espera variable o parámetro' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la sentencia $IF EXIST. SOLUCIÓN La instrucción $IF EXIST sólo permite parámetros aritméticos o variables."@es .

ns1:Error1357CaracterInvalidoEnDELETE a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1357: Carácter inválido en #DELETE"@es ;
    ns1:identificador "1357" ;
    ns1:textoExtracto "'#DELETE: carácter no válido' DETECCIÓN Durante la ejecución. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque. La sentencia se debe programar sola en el bloque o junto a la etiqueta del bloque. Este sentencia sólo permite variables de usuario."@es .

ns1:Error1358VariableInexistenteEnDELETE a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1358: Variable inexistente en #DELETE"@es ;
    ns1:identificador "1358" ;
    ns1:textoExtracto "'#DELETE: la variable a borrar no existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Error1359OperacionNoPermitidaEnVariablesDelSistema a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1359: Operación no permitida en variables del sistema"@es ;
    ns1:identificador "1359" ;
    ns1:textoExtracto "Los comandos #VAR/#ENDVAR/#DELETE no permiten este tipo de variable. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC. SOLUCIÓN No se pueden borrar las variables predefinidas del CNC."@es .

ns1:Error1499NumeroDeAnidamientosDeRPTYSubrutinasSobrepasado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1499: Número de anidamientos de #RPT y subrutinas sobrepasado" ;
    ns1:identificador "1499" ;
    ns1:textoExtracto "'Número de anidamientos de #RPT y subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se considera anidamiento cuando la sentencia #RPT se programa entre dos etiquetas que definen el radio de acción de otra sentencia #RPT. El CNC da error cuando sobrepasa el número de anidamientos de sentencias RPT y subrutinas, si las hay. SOLUCIÓN El máximo número de anidamientos permitido es 20." ;
    ns1:valor 20 .

ns1:Error1500EXECNoSePuedeEjecutarElProgramaEnElCanalIndicado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1500: #EXEC: no se puede ejecutar el programa en el canal indicado" ;
    ns1:identificador "1500" ;
    ns1:mitigaRiesgo ns1:ModoManual ;
    ns1:textoExtracto "'#EXEC: no se puede ejecutar el programa en el canal indicado' DETECCIÓN Durante la ejecución. CAUSA Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático." .

ns1:Error1538RecuperacionDeCabezal a ns1:AvisoSeguridad ;
    rdfs:label "Error 1538: Recuperación de cabezal"@es ;
    ns1:identificador "1538" ;
    ns1:textoExtracto "1538 'No se puede recuperar algún cabezal del canal' DETECCIÓN Durante la ejecución. CAUSA Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es .

ns1:Error1606TransformacionAngularConEjesEnCanalesDistintos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1606: Transformación angular con ejes en canales distintos" ;
    ns1:identificador "1606" ;
    ns1:textoExtracto "El CNC ha intentado activar una transformación angular con dos ejes que no pertenecen al mismo canal." .

ns1:Error1607CicloDeFresaConEjesInsuficientes a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1607: Ciclo de fresa con ejes insuficientes" ;
    ns1:identificador "1607" ;
    ns1:textoExtracto "'Para ejecutar un ciclo de fresa son necesarios tres ejes en el canal'" .

ns1:Error1704PUNTEADOALFA0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1704: PUNTEADO: ALFA = 0"@es ;
    ns1:identificador "1704" ;
    ns1:textoExtracto "1704 'PUNTEADO: ALFA = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro alfa tiene valor 0. No hay ángulo programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1705PUNTEADODIAMETRO0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1705: PUNTEADO: DIÁMETRO = 0"@es ;
    ns1:identificador "1705" ;
    ns1:textoExtracto "1705 'PUNTEADO: DIÁMETRO = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro para definir el diámetro tiene valor 0. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1706TALADRADO1F0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1706: TALADRADO 1: F = 0"@es ;
    ns1:identificador "1706" ;
    ns1:textoExtracto "1706 'TALADRADO 1: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1707TALADRADO1S0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1707: TALADRADO 1: S = 0"@es ;
    ns1:identificador "1707" ;
    ns1:textoExtracto "1707 'TALADRADO 1: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1708TALADRADO1T0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1708: TALADRADO 1: T = 0"@es ;
    ns1:identificador "1708" ;
    ns1:textoExtracto "1708 'TALADRADO 1: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1709TALADRADO1P0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1709: TALADRADO 1: P = 0"@es ;
    ns1:identificador "1709" ;
    ns1:textoExtracto "1709 'TALADRADO 1: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error1738CAJERARECTANGULARProfundidadNoProgramada a ns1:AvisoSeguridad ;
    rdfs:label "Error 1738: CAJERA RECTANGULAR - Profundidad no programada" ;
    ns1:identificador "1738" ;
    ns1:mitigaRiesgo ns1:SolucionParaError1738AsignarProfundidad0 ;
    ns1:textoExtracto "1738 'CAJERA RECTANGULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:Error1739CAJERARECTANGULARDiametroDeHerramientaInsuficiente a ns1:AvisoSeguridad ;
    rdfs:label "Error 1739: CAJERA RECTANGULAR - Diámetro de herramienta insuficiente" ;
    ns1:identificador "1739" ;
    ns1:mitigaRiesgo ns1:SolucionError1739 ;
    ns1:textoExtracto "1739 'CAJERA RECTANGULAR: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ)." .

ns1:Error1901DatoNoValido a ns1:AvisoSeguridad ;
    rdfs:label "Error 1901: Dato no válido" ;
    ns1:identificador "1901" ;
    ns1:textoExtracto "'Dato no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro del ciclo tiene un valor incorrecto. El parámetro incorrecto estará indicado en el mensaje de error. SOLUCIÓN Corregir la programación." .

ns1:Error1902PosicionInicialYFactorDeFormaDeLaHerramientaIncompatibles a ns1:AvisoSeguridad ;
    rdfs:label "Error 1902: Posición inicial y factor de forma de la herramienta incompatibles" ;
    ns1:identificador "1902" ;
    ns1:textoExtracto "'Posición inicial y factor de forma de la herramienta incompatibles' DETECCIÓN Durante la ejecución del ciclo. CAUSA La posición inicial de la herramienta no es compatible con el factor de forma y la geometría de la herramienta. SOLUCIÓN Posicionar la herramienta adecuadamente o" .

ns1:Error2340VectorDoblementeDefinido a ns1:AvisoSeguridad ;
    rdfs:label "Error 2340: Vector doblemente definido" ;
    ns1:identificador "2340" ;
    ns1:textoExtracto "2340 'Vector doblemente definido' [...] SOLUCIÓN Revisar la programación. Programar un único vector por bloque." .

ns1:Error2383NombreDeFicheroNoValido a ns1:AvisoSeguridad ;
    rdfs:label "Error 2383: Nombre de fichero no válido"@es ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2383" ;
    ns1:textoExtracto "2383 #ISO ON[]. Nombre de fichero no valido. DETECCIÓN Durante la ejecución. CAUSA La carpeta destino no existe o el nombre del fichero es incorrecto. SOLUCIÓN Seleccionar una carpeta que exista y un nombre de fichero correcto."@es .

ns1:Error2419PWRCTRLONParametrosIncompletos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2419: #PWRCTRL ON - Parámetros incompletos" ;
    ns1:identificador "2419" ;
    ns1:textoExtracto "2419 #PWRCTRL ON: la primera vez es obligatorio programar todos los parámetros. DETECCIÓN Durante la ejecución. CAUSA Es la primera vez que se programa la función #PWRCTRL y falta algún parámetro. SOLUCIÓN La primera vez que se programa la función #PWRCTRL es obligatorio programar todos los parámetros." .

ns1:Error2421CambioDeCabezalConPWRCTRLActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2421: Cambio de cabezal con #PWRCTRL activo" ;
    ns1:identificador "2421" ;
    ns1:textoExtracto "2421 No se admite cambiar o aparcar el cabezal master con PWRCTRL activo. DETECCIÓN Durante la ejecución. CAUSA No se admite cambiar o aparcar el cabezal master con PWRCTRL activo. SOLUCIÓN El control de potencia se aplica al cabezal master. Para cambiar o aparcar el cabezal master, desactivar el control de potencia (#PWRCTRL)." .

ns1:Error2422TFOLLOWONNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2422: #TFOLLOW ON no permitido" ;
    ns1:identificador "2422" ;
    ns1:textoExtracto "2422 No se permite #TFOLLOW ON [MASTER]. Permitido: #FOLLOW ON [MASTER] DETECCIÓN Durante la preparación de bloques. CAUSA Cuando un eje se programa para ser esclavo de la variable FLWMASTER, la sincronización solo puede ser sobre las cotas reales; no es posible sincronizar sobre las cotas teóricas." .

ns1:Error24620_Hardware a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24620" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "24620 Error de hardware en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error24621_Firmware a ns1:DiagnosticoFallo ;
    rdfs:label "Error de firmware en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24621" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "24621 Error de firmware en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error24622_Periferico a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24622" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "24622 Error periférico en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error24624_ConfiguracionLocalbus a ns1:DiagnosticoFallo ;
    rdfs:label "La configuración del módulo Localbus no coincide en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24624" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "24624 La configuración del módulo Localbus no coincide en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error24625_SistemaIncompleto a ns1:DiagnosticoFallo ;
    rdfs:label "Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24625" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "24625 Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error4022ResetDeContadoraPorWatchdogEnAnilloSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4022: Reset de contadora por Watchdog en anillo Sercos" ;
    ns1:identificador "4022" ;
    ns1:textoExtracto "Error en el anillo Sercos debido a un Reset de contadora por Watchdog. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha producido un reset por watchdog en el módulo RCS-S, por una causa interna del software del nodo." .

ns1:Error4023ConfiguracionFallidaDeTrazaProgramadaEnSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4023: Configuración fallida de traza programada en Sercos" ;
    ns1:identificador "4023" ;
    ns1:textoExtracto "No puede configurarse la traza programada en Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Error durante la configuración de los telegramas AT-MDT para capturar la traza programada. La traza programada no puede hacerse efectiva, bien porque se trata de un regulador no-Fagor o bien porque no hay hueco disponible para ella." .

ns1:Error4218ErrorEnElAnilloSercosEscrituraDeMDTBuffer1_964c5fbc39 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4218: Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ns1:identificador "4218" ;
    ns1:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error4680_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC y asegurarse que la referencia existe." .

ns1:Error4681_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC." .

ns1:Error4682_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC." .

ns1:Error4683_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Identificación de código de warning en manual del esclavo Mechatrolink" ;
    ns1:textoExtracto "Identificar el código del warning en el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:Error5008EscrituraDeVariableFallida a ns1:Alarma ;
    rdfs:label "Error 5008: Escritura de variable fallida"@es ;
    ns1:identificador "5008" ;
    ns1:mitigaRiesgo ns1:FalloEnEscrituraDeVariableCNCWR ;
    ns1:textoExtracto "'La escritura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA Escritura de un parámetro aritmético global o local que no existe. SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC."@es .

ns1:Error5009LecturaDeVariableFallida a ns1:Alarma ;
    rdfs:label "Error 5009: Lectura de variable fallida"@es ;
    ns1:identificador "5009" ;
    ns1:mitigaRiesgo ns1:FalloEnLecturaDeVariableCNCRD ;
    ns1:textoExtracto "'Error sintáctico en la lectura de variable desde PLC' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe o no tiene permiso de lectura desde el PLC. SOLUCIÓN Verificar la sintaxis y los permisos de la variable."@es .

ns1:Error5010DivisionPorCero a ns1:Alarma ;
    rdfs:label "Error 5010: División por cero"@es ;
    ns1:identificador "5010" ;
    ns1:mitigaRiesgo ns1:DivisionPorCeroEnInstruccionDVSMDS ;
    ns1:textoExtracto "'División por cero en el PLC' DETECCIÓN Al ejecutar una instrucción DVS o MDS. CAUSA El denominador de una operación DVS o MDS es 0. SOLUCIÓN Revisar el programa PLC. No realizar divisiones por 0."@es .

ns1:Error5013FalloEnEntradasDigitales a ns1:Alarma ;
    rdfs:label "Error 5013: Fallo en entradas digitales"@es ;
    ns1:identificador "5013" ;
    ns1:mitigaRiesgo ns1:FalloEnLecturaDeIOsDigitalesRemotas ;
    ns1:monitoreaParametro ns1:NDIMOD_1b11a2c0df ;
    ns1:textoExtracto "'Error en la lectura de entradas digitales del PLC' DETECCIÓN Al leer las entradas digitales del PLC. CAUSA Fallo en la lectura de las entradas digitales remotas de PLC. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus."@es .

ns1:Error5014FalloEnSalidasDigitales a ns1:Alarma ;
    rdfs:label "Error 5014: Fallo en salidas digitales"@es ;
    ns1:identificador "5014" ;
    ns1:mitigaRiesgo ns1:FalloEnEscrituraDeIOsDigitalesRemotas ;
    ns1:monitoreaParametro ns1:PLCFREQ_5f386d7e1a,
        ns1:ParametroNDOMODConfiguracionDeIOsDigitales_baa246c58e ;
    ns1:textoExtracto "'Error en la escritura de salidas digitales del PLC' DETECCIÓN Al escribir las salidas digitales del PLC. CAUSA Fallo en la escritura de las salidas digitales remotas de PLC. La tabla de configuración de las I/Os digitales no es válida (parámetro NDOMOD) o el PLC ha recibido una petición de escritura antes de finalizar la anterior. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ."@es .

ns1:Error5056EjecucionDeSalidaAnalogicaRemota a ns1:AvisoSeguridad ;
    rdfs:label "Error 5056: Ejecución de salida analógica remota" ;
    ns1:identificador "5056" ;
    ns1:textoExtracto "5056 Error de ejecución en el tratamiento de una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos. SOLUCIÓN Error interno. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error5057EjecucionDeEntradaAnalogicaRemota a ns1:AvisoSeguridad ;
    rdfs:label "Error 5057: Ejecución de entrada analógica remota" ;
    ns1:identificador "5057" ;
    ns1:textoExtracto "5057 Error de ejecución en el tratamiento de una entrada analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos. SOLUCIÓN Error interno. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error7039ConflictoDeHerramientaEnCabezalYBrazo2 a ns1:AvisoSeguridad ;
