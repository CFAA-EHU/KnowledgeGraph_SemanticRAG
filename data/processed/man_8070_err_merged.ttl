    rdfs:label "Cabezal esclavo"@es ;
    ns1:textoExtracto "cabezal esclavo a desincronizar"@es .

ns1:Componente_CabezalMaster a ns1:Componente,
        ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master"@es ;
    ns1:textoExtracto "El cabezal master de la sincronización no pasa a lazo abierto",
        "El cabezal master de la sincronización no pasa a lazo cerrado"@es,
        "el cabezal estaba en M19 antes de #SERVOON. [...] El cabezal master de la sincronización no está en la gama adecuada"@es .

ns1:Componente_EjesMechatrolink a ns1:Componente ;
    rdfs:label "Ejes Mechatrolink"@es ;
    ns1:textoExtracto "ejes Mechatrolink"@es .

ns1:Componente_Palpador a ns1:ComponenteMecanico,
        ns1:Sensor ;
    rdfs:label "Palpador"@es,
        "Sensor de palpado (probes)"@es ;
    ns1:activaAlarma ns1:Error_1491,
        ns1:Error_1492 ;
    ns1:textoExtracto "el palpador no ha tocado la pieza durante el movimiento de palpación [...] el palpador no ha tocado la esfera [...] el palpador ha tocado la esfera cuando no debía hacerlo."@es,
        "movimiento de palpado (G100)"@es,
        "sentencia #SELECT PROBE"@es .

ns1:Componente_PlacaExpansionSercos a ns1:ComponenteElectrico ;
    rdfs:label "Placa de expansión tipo Sercos" ;
    ns1:identificador "Sercos_v1.2+" ;
    ns1:mitigaRiesgo ns1:Fallo_3084 ;
    ns1:textoExtracto "Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2." .

ns1:Componente_VentiladorCPU a ns1:ComponenteElectrico ;
    rdfs:label "Ventilador de la CPU" ;
    ns1:mitigaRiesgo ns1:Alarma_OverTemp ;
    ns1:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado. Cuando la CPU dispone de ventilador, durante el régimen normal de funcionamiento del CNC, éste monitoriza y vigila que dicho ventilador esté en marcha." .

ns1:ComprobacionBusCAN_6013 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobaciones de integridad del bus CAN (Error 6013)" ;
    ns1:requiereMantenimiento ns1:BusCAN ;
    ns1:textoExtracto "Realizar las siguientes comprobaciones y acciones para garantizar la integridad del bus CAN: • No hay grupos CAN con la misma dirección seleccionada. • El selector de nodo de la COMPCI debe ser 0. • Terminadores de línea. • Conexión de tierras. • Continuidad del cable CAN. • Conectores del cable CAN (si es necesario, soltarlos y volverlos a montar). • Conexión del cable plano entre los nodos y la fuente. • Fuentes de alimentación de los grupos CAN (niveles, posibles reset, etc.). • Ver en el modo diagnosis si se reconocen todos los módulos." .

ns1:ComprobacionBusCAN_6015 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobaciones de integridad del bus CAN (Error 6015)" ;
    ns1:requiereMantenimiento ns1:BusCAN ;
    ns1:textoExtracto "Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN." .

ns1:ConectoresCAN a ns1:ComponenteElectrico ;
    rdfs:label "Conectores del cable CAN" ;
    ns1:textoExtracto "Conectores del cable CAN (si es necesario, soltarlos y volverlos a montar)." .

ns1:ContadorErroresCAN a ns1:Parametro ;
    rdfs:label "Contador de errores CAN" ;
    ns1:textoExtracto "contador de errores CAN" ;
    ns1:valor 96 .

ns1:Contadora_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_Amplitud,
        ns1:Parametro_Corriente,
        ns1:Parametro_DistanciaI0,
        ns1:Parametro_FrecuenciaContaje ;
    ns1:textoExtracto "El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema",
        "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación",
        "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación." .

ns1:DPRAM a ns1:ComponenteElectrico ;
    rdfs:label "Memoria DPRAM de la COMPCI" ;
    ns1:textoExtracto "memoria RAM común de la COMPCI" .

ns1:DPRAM_SERCON a ns1:ComponenteElectrico ;
    rdfs:label "DPRAM del SERCON"@es ;
    ns1:textoExtracto "overflow en la DPRAM del SERCON por un número excesivo de ejes y datos a transmitir en el canal cíclico"@es .

ns1:DiagnosticoFallo_0027 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje no es Mechatrolink"@es ;
    ns1:identificador "0027" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Uso de parámetros Mechatrolink en eje no compatible"@es ;
            ns1:textoExtracto "La variable o parámetro es exclusivo de un eje mechatrolink, pero el eje para el que se pide la variable o parámetro no es un eje mechatrolink."@es ] ;
    ns1:textoExtracto "El eje no es mechatrolink. DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA La variable o parámetro es exclusivo de un eje mechatrolink, pero el eje para el que se pide la variable o parámetro no es un eje mechatrolink. SOLUCIÓN Seleccionar un eje Mechatrolink. La variable o parámetro de eje debe existir para el eje pedido."@es .

ns1:DiagnosticoFallo_0028 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro Mechatrolink no asociable a canal de osciloscopio"@es ;
    ns1:identificador "0028" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Asociación no permitida de parámetros Mechatrolink en modo incorrecto"@es ;
            ns1:textoExtracto "En el osciloscopio hay definido un parámetro Mechatrolink o una variable DRV asociada a un parámetro mechatrolink."@es ] ;
    ns1:textoExtracto "No se permite asociar un parámetro mechatrolink a un canal del oscilo. DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA En el osciloscopio hay definido un parámetro Mechatrolink o una variable DRV asociada a un parámetro mechatrolink. SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está disponible para el modo Mlink-II a 32 bytes."@es .

ns1:DiagnosticoFallo_0029 a ns1:DiagnosticoFallo ;
    rdfs:label "Modo Mlink-I activo para variables Mechatrolink"@es ;
    ns1:identificador "0029" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Uso de variables Mechatrolink en modo Mlink-I"@es ;
            ns1:textoExtracto "En el osciloscopio hay definida una variable Mechatrolink o una variable DRV, pero en el CNC está activo el modo Mlink-I (parámetro MLINK)."@es ] ;
    ns1:textoExtracto "'Sólo MLINKII permite variables DRV o MLINK en un canal del oscilo' DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA En el osciloscopio hay definida una variable Mechatrolink o una variable DRV, pero en el CNC está activo el modo Mlink-I (parámetro MLINK). SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está disponible para el modo Mlink-II a 32 bytes."@es .

ns1:DiagnosticoFallo_0031 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0031: Incompatibilidad Mechatrolink/MLINK-I",
        "Parámetros Mechatrolink en osciloscopio con modo incorrecto"@es ;
    ns1:identificador "0031" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Definición de parámetros Mechatrolink en modo no compatible"@es ;
            ns1:textoExtracto "Definición de parámetros Mechatrolink en un canal del osciloscopio con modo no compatible (requiere Mlink-II)."@es ],
        ns1:Parametro_Mechatrolink ;
    ns1:textoExtracto "0031 'Sólo MLINKII permite parámetros mechatrolink en el oscilo'",
        "SOLUCIÓN En estas variables, el eje se debe programar mediante su nombre.",
        "'Sólo MLINKII permite parámetros mechatrolink en el oscilo' DETECCIÓN Al definir parámetros en un canal del osciloscopio."@es .

ns1:DiagnosticoFallo_0080 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de validación: Parámetros generales no validados"@es ;
    ns1:solucionaFallo ns1:Parametro_NAXIS ;
    ns1:textoExtracto "El usuario ha añadido algún eje al sistema (parámetro NAXIS), y sin validar la tabla de parámetros generales, ha intentado validar la tabla de parámetros de uno de los nuevos ejes."@es .

ns1:DiagnosticoFallo_0081 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de configuración: Banda de muerte < resolución del eje"@es ;
    ns1:solucionaFallo ns1:Parametro_INPOSW ;
    ns1:textoExtracto "La banda de muerte es menor que la resolución del eje."@es .

ns1:DiagnosticoFallo_0082 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de compensación: Límites de módulo inconsistentes en eje rotativo"@es ;
    ns1:solucionaFallo ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_MOVAXIS ;
    ns1:textoExtracto "El eje que se mueve (parámetro MOVAXIS) es rotativo y no tiene los mismos límites de módulo en todos los sets de parámetros."@es .

ns1:DiagnosticoFallo_0083 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de configuración: Tipos de regulador (DRIVETYPE) incompatibles en gantry"@es ;
    ns1:solucionaFallo ns1:Parametro_DRIVETYPE ;
    ns1:textoExtracto "Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink."@es .

ns1:DiagnosticoFallo_0115 a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación -tipo de CPU- no coherente con el hardware" ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "0115 Código de validación -tipo de CPU-, NO coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El tipo de CPU definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:DiagnosticoFallo_0117 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de cores no coherente con el hardware" ;
    ns1:identificador "0117" ;
    ns1:textoExtracto "0117 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:DiagnosticoFallo_0173 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecalentamiento del habitáculo del CNC" ;
    ns1:identificador "0173" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0173 ;
    ns1:textoExtracto "La causa del aumento de temperatura puede ser un fallo en el sistema de refrigeración del hardware o una temperatura ambiente muy elevada. SOLUCIÓN Respetar las dimensiones recomendadas para el habitáculo y las distancia mínima recomendada entre las paredes del habitáculo y la unidad central. En caso necesario, instalar ventiladores para airear el habitáculo." .

ns1:DiagnosticoFallo_1394 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1394: No existe la subrutina asociada a la función G"@es ;
    ns1:identificador "1394" ;
    ns1:solucionaFallo ns1:Herramienta_Cabezal_1394 ;
    ns1:textoExtracto "1394 'No existe la subrutina asociada a la función G'"@es .

ns1:DiagnosticoFallo_1478 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo 1478: ángulo de entrada de herramienta incorrecto"@es ;
    ns1:identificador "1478" ;
    ns1:mitigaRiesgo [ a ns1:AvisoSeguridad ;
            rdfs:label "Revisión de parámetros de herramienta antes de ejecución"@es ;
            ns1:textoExtracto "DETECCIÓN Durante la ejecución."@es ] ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Generar cajera con ángulo de entrada de herramienta incorrecto"@es ;
            ns1:textoExtracto "El CNC generó la cajera con un ángulo de entrada de herramienta diferente al actual."@es ] ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente ángulo de entrada de herramienta'"@es .

ns1:DiagnosticoFallo_1593 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1593: Cabezal esclavo no perteneciente al canal"@es ;
    ns1:identificador "1593" ;
    ns1:textoExtracto "El cabezal esclavo a desincronizar debe pertenecer al canal. DETECCIÓN Durante la ejecución. CAUSA Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal. SOLUCIÓN Cancelar la sincronización desde el canal al que pertenece el cabezal."@es .

ns1:DiagnosticoFallo_1594 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1594: Valor de transmisión no válido en sincronización"@es ;
    ns1:identificador "1594" ;
    ns1:textoExtracto "En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero. SOLUCIÓN El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero."@es .

ns1:DiagnosticoFallo_1636 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1636: Transformadas FACE y CYL activas simultáneamente"@es ;
    ns1:identificador "1636" ;
    ns1:monitoreaParametro ns1:Parametro_NKINAX ;
    ns1:textoExtracto "'No se permiten tener activas las transformadas FACE y CYL al mismo tiempo' [...] Durante la ejecución. [...] El CNC intentado activar la sentencia #FACE o #CYL con una de ellas activa."@es .

ns1:DiagnosticoFallo_1693 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: Sentencia #RTCP no admitida con cinemática actual"@es ;
    ns1:solucionaFallo ns1:AccionProhibida_1693_RTCP ;
    ns1:textoExtracto "CAUSA La sentencia no es admisible con la actual cinemática. SOLUCIÓN Programar la sentencia #FACE ó #CYL para activar dicha transformada."@es .

ns1:DiagnosticoFallo_1694 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Cota G174 fuera de rango"@es,
        "Fallo de programación: Cota en G174 fuera de rango"@es ;
    ns1:solucionaFallo ns1:Alarma_1694,
        ns1:Parametro_G174 ;
    ns1:textoExtracto "CAUSA La cota programada en G174 está fuera de rango."@es,
        "CAUSA La cota programada en G174 está fuera de rango. SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647."@es .

ns1:DiagnosticoFallo_1721 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1721: ESCARIADO: T = 0"@es ;
    ns1:identificador "1721" ;
    ns1:solucionaFallo ns1:Parametro_T_1721 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1722 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1722: ESCARIADO: P = 0"@es ;
    ns1:identificador "1722" ;
    ns1:solucionaFallo ns1:Parametro_P_1722 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1886 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido" ;
    ns1:identificador "1886" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste (parámetro β) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ns1:DiagnosticoFallo_1887 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de semiacabado no válido" ;
    ns1:identificador "1887" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º." .

ns1:DiagnosticoFallo_1935 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1935: No se ha definido ningún eje como LONGAXIS en ciclo de eje C"@es ;
    ns1:identificador "1935" ;
    ns1:textoExtracto "1935 'No se ha definido ningún eje como LONGAXIS en ciclo de eje C' [...] CAUSA No hay definido ningún eje longitudinal en el canal. SOLUCIÓN Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal."@es .

ns1:DiagnosticoFallo_2140 a ns1:DiagnosticoFallo ;
    rdfs:label "SLOPE: Parámetro no válido" ;
    ns1:identificador "2140" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Algún parámetro de la sentencia de programación #SLOPE es incorrecto. SOLUCIÓN Consultar en el manual de programación el formato correcto." .

ns1:DiagnosticoFallo_2325 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto final fuera del círculo en programación" ;
    ns1:textoExtracto "CAUSA El punto final no pertenece al círculo. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_2326 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta punto final en ciclos G802/G803" ;
    ns1:textoExtracto "CAUSA El punto final no pertenece al círculo. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_2327 a ns1:DiagnosticoFallo ;
    rdfs:label "Elemento previo no circular en G802/G803" ;
    ns1:textoExtracto "CAUSA El elemento anterior a una G802/G803 debe ser un círculo." .

ns1:DiagnosticoFallo_2328 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta elemento previo en G808" ;
    ns1:textoExtracto "CAUSA Se ha programado una G808 y no hay programado ningún elemento anterior." .

ns1:DiagnosticoFallo_2329 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto previo no definido en G808" ;
    ns1:textoExtracto "CAUSA Se ha programado una G808 y no hay programado ningún punto anterior." .

ns1:DiagnosticoFallo_2330 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto previo no definido en G809" ;
    ns1:textoExtracto "CAUSA Se ha programado una G809 y no hay programado ningún punto anterior." .

ns1:DiagnosticoFallo_2331 a ns1:DiagnosticoFallo ;
    rdfs:label "Datos insuficientes en definición de ente" ;
    ns1:textoExtracto "CAUSA Faltan datos en la programación del ente." .

ns1:DiagnosticoFallo_2332 a ns1:DiagnosticoFallo ;
    rdfs:label "Ente programado inválido" ;
    ns1:textoExtracto "CAUSA El ente programado no es válido." .

ns1:DiagnosticoFallo_2333 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G8737/G8738 fuera de macro G8736" ;
    ns1:textoExtracto "CAUSA Hay alguna función G8737 o G8738 programada fuera de una macro G8736. SOLUCIÓN [...] Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." .

ns1:DiagnosticoFallo_2407_Solucion a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 2407"@es ;
    ns1:solucionaFallo ns1:Alarma_2407 ;
    ns1:textoExtracto "Las posibles soluciones son las siguientes: • Programar POSLIMIT en el comando #LEAP con una cota superior a la posición inicial del salto. • Anular el control del gap (#GAPCTRL OFF)."@es .

ns1:DiagnosticoFallo_2408_Solucion a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 2408"@es ;
    ns1:solucionaFallo ns1:Alarma_2408 ;
    ns1:textoExtracto "Desactivar uno de los otros dos comandos activos."@es .

ns1:DiagnosticoFallo_2409_Solucion a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 2409"@es ;
    ns1:solucionaFallo ns1:Alarma_2409 ;
    ns1:textoExtracto "No programar el eje esclavo de #FOLLOW [MASTER]."@es .

ns1:DiagnosticoFallo_24501 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa" ;
    ns1:identificador "24501" ;
    ns1:textoExtracto "Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:DiagnosticoFallo_24502 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM OK" ;
    ns1:identificador "24502" ;
    ns1:textoExtracto "Tensión de alimentación UM OK. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción." .

