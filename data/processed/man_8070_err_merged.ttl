ns1:Error_2130 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la transformación de plano inclinado (2130)" ;
    ns1:identificador "2130" ;
    ns1:textoExtracto "2130 'Error en la transformación de plano inclinado' [...] CAUSA Hay programado un plano inclinado y no hay tres ejes en el canal. SOLUCIÓN Antes de activar el plano inclinado, configurar el canal con los ejes necesarios." .

ns1:Error_2131 a ns1:AvisoSeguridad ;
    rdfs:label "Error interno en modo eje C (2131)" ;
    ns1:identificador "2131" ;
    ns1:textoExtracto "2131 'Error interno en modo eje C' [...] CAUSA No es posible la transformación de eje C para el bloque. SOLUCIÓN Eliminar el bloque o bloques que provocan el error." .

ns1:Error_2132 a ns1:AvisoSeguridad ;
