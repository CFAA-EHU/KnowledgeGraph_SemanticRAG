ns1:DiagnosticoFallo_0174 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración incorrecta de ejes rotativos" ;
    ns1:identificador "0174" ;
    ns1:textoExtracto "El CNC no puede activar la compensación volumétrica porque entre los ejes que se mueven (parámetro MOVAXIS) hay más de un eje rotativo módulo, y el recorrido del segundo eje no es completo (0 a 360º). SOLUCIÓN Definir el módulo del segundo eje rotativo entre 0 y 360º y validar la compensación volumétrica." .

ns1:DiagnosticoFallo_1720 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1720: ESCARIADO: S = 0"@es ;
    ns1:identificador "1720" ;
    ns1:solucionaFallo ns1:Parametro_S_1720 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_2015 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta demasiado grande (2015)" ;
    ns1:identificador "2015" ;
    ns1:textoExtracto "No hay intersección entre arco y línea: radio de herramienta demasiado grande. DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada. SOLUCIÓN Usar una herramienta de menor radio." .

ns1:DiagnosticoFallo_2016 a ns1:DiagnosticoFallo ;
    rdfs:label "Colisión en compensación de radio (2016)" ;
    ns1:identificador "2016" ;
    ns1:textoExtracto "'Se ha modificado el perfil para evitar una colisión' DETECCIÓN Durante la ejecución. CAUSA La detección de colisiones durante la compensación de radio ha detectado una trayectoria que daña el perfil programado y la ha eliminado. SOLUCIÓN Dependiendo de la colisión detectada su solución puede ser utilizar una herramienta de radio menor, programar el perfil de otra forma o simplemente aceptar la modificación propuesta por el proceso de detección de colisiones." .

ns1:DiagnosticoFallo_8502 a ns1:DiagnosticoFallo ;
    rdfs:label "Interpolación circular en polares: radio no admitido" ;
    ns1:identificador "8502" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Programar radio en interpolación polar (solo parámetro Q permitido)" ;
            ns1:textoExtracto "La interpolación circular en polares no admite la programación del radio; sólo admite el parámetro Q." ] ;
    ns1:textoExtracto "'La interpolación circular en polares no admite radio' [...] Error al programar en lenguaje del 8055. La interpolación circular en polares no admite la programación del radio; sólo admite el parámetro Q." .

