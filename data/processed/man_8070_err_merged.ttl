    ns1:solucionaFallo ns1:Alarma_6043 ;
    ns1:textoExtracto "DETECCIÓN El lazo ha detectado una alarma genérica de cable roto en la entrada local de captación. CAUSA El contaje local del CNC tiene alguna de sus señales rota. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." .

ns1:DiagnosticoFallo_6044 a ns1:DiagnosticoFallo ;
    rdfs:label "'Alarma de cable roto en señal A'" ;
    ns1:identificador "6044" ;
    ns1:solucionaFallo ns1:Alarma_6044 ;
    ns1:textoExtracto "DETECCIÓN El lazo ha detectado cable roto en la señal A del contaje local. CAUSA El contaje local del CNC no recibe la señal A. SOLUCIÓN Revisar la señal A de la captación local del CNC." .

ns1:DiagnosticoFallo_6045 a ns1:DiagnosticoFallo ;
