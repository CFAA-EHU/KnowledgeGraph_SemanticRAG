    rdfs:label "Sobrevelocidad" ;
    ns1:identificador "9728" ;
    ns1:textoExtracto "9728 Sobrevelocidad. [...] SOLUCIÓN Revisar parametrización y/o ajuste del sistema." .

ns1:Error_9729 a ns1:DiagnosticoFallo ;
    rdfs:label "OverRun" ;
    ns1:identificador "9729" ;
