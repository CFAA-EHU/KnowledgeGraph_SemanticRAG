ns1:Fallo_1747 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1747" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN: Elegir una herramienta de menor diámetro."@es .

ns1:Fallo_1804 a ns1:DiagnosticoFallo ;
    rdfs:label "Profundidad de cajera cero"@es ;
    ns1:identificador "1804" ;
    ns1:solucionaFallo ns1:Solucion_1804 ;
    ns1:textoExtracto "La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D."@es .

ns1:Fallo_1987 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay contacto con la esfera"@es ;
    ns1:identificador "1987" ;
    ns1:textoExtracto "1987 'No hay contacto con la esfera' DETECCIÓN Durante la ejecución. CAUSA No ha llegado señal de palpado cuando se esperaba tocar la esfera."@es .

ns1:Fallo_24020_EtherCAT_FicheroRutadoInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24020: Fichero de rutado EtherCAT no existe"@es ;
    ns1:identificador "24020" ;
    ns1:textoExtracto "EtherCAT: Fichero de rutado no existe. [...] No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor."@es .

ns1:Fallo_3084 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3084: Fallo en driver de activación/desactivación láser" ;
    ns1:identificador "3084" ;
    ns1:textoExtracto "'Error del driver en la activación/desactivación del láser' [...] No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser." .

ns1:Fallo_3403 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten más operaciones con ejes independientes. En sincronización"@es ;
    ns1:identificador "3403" ;
    ns1:textoExtracto "3403 'No se admiten mas operaciones con ejes independientes. En sincronización'"@es,
        "DETECCIÓN: Durante la ejecución. CAUSA: El CNC intenta ejecutar una operación de eje"@es .

ns1:Fallo_G33_G34_3072 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3072: Avance máximo superado en roscado G33/G34" ;
    ns1:identificador "3072" ;
    ns1:textoExtracto "'Paso y S de cabezal programados para G33/G34 superan avance máximo permitido'",
        "Durante la ejecución. CAUSA: Al empezar un roscado G33/G34, el CNC ha detectado que el paso y la velocidad programados implican un avance que supera el máximo permitido. El avance máximo puede estar limitado por los parámetros máquina o por PLC." .

ns1:Fallo_PerdidaPosicionAbsoluta a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la pista absoluta"@es ;
    ns1:textoExtracto """\r
    Error en la pista absoluta.\r
    DETECCIÓN Durante el arranque o funcionamiento habitual del sistema.\r
    CAUSA Las posibles causas son las siguientes:\r
    • El captador no puede calcular la posición absoluta.\r
    • Pérdida de contaje.\r
    • La señal analógica < 0,20 Vpp.\r
    """@es .

