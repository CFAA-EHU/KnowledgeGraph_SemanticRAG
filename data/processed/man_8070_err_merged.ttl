ns1:Error_5008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de escritura de variable desde PLC (5008)" ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "180-185" ;
            ns1:textoExtracto "Sección 5000-5999: Códigos de error PLC." ] ;
    ns1:identificador "5008" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Escritura de parámetro no existente desde PLC" ;
            ns1:textoExtracto "Escritura de un parámetro aritmético global o local que no existe." ] ;
    ns1:textoExtracto "'La escritura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA Escritura de un parámetro aritmético global o local que no existe. SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC." .

ns1:Error_5009 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico en lectura de variable desde PLC (5009)" ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "180-185" ;
            ns1:textoExtracto "Sección 5000-5999: Códigos de error PLC." ] ;
    ns1:identificador "5009" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Lectura de variable no existente o sin permisos desde PLC" ;
            ns1:textoExtracto "La variable no existe o no tiene permiso de lectura desde el PLC." ] ;
    ns1:textoExtracto "'Error sintáctico en la lectura de variable desde PLC' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe o no tiene permiso de lectura desde el PLC. SOLUCIÓN Verificar la sintaxis y los permisos de la variable." .

ns1:Error_5010 a ns1:DiagnosticoFallo ;
    rdfs:label "División por cero en PLC (5010)" ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "180-185" ;
            ns1:textoExtracto "Sección 5000-5999: Códigos de error PLC." ] ;
    ns1:identificador "5010" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "División por cero en instrucciones DVS o MDS" ;
            ns1:textoExtracto "El denominador de una operación DVS o MDS es 0." ] ;
    ns1:textoExtracto "'División por cero en el PLC' DETECCIÓN Al ejecutar una instrucción DVS o MDS. CAUSA El denominador de una operación DVS o MDS es 0. SOLUCIÓN Revisar el programa PLC. No realizar divisiones por 0." .

ns1:Error_5013 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en lectura de entradas digitales del PLC (5013)" ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "180-185" ;
            ns1:textoExtracto "Sección 5000-5999: Códigos de error PLC." ] ;
    ns1:identificador "5013" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Configuración incorrecta de I/Os digitales (NDIMOD) o fallo de bus" ;
            ns1:textoExtracto "Fallo en la lectura de las entradas digitales remotas de PLC. Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus." ] ;
    ns1:textoExtracto "'Error en la lectura de entradas digitales del PLC' DETECCIÓN Al leer las entradas digitales del PLC. CAUSA Fallo en la lectura de las entradas digitales remotas de PLC. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus." .

ns1:Error_5014 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en escritura de salidas digitales del PLC (5014)" ;
    ns1:documentadoEn [ a ns1:Pagina ;
            ns1:identificador "180-185" ;
            ns1:textoExtracto "Sección 5000-5999: Códigos de error PLC." ] ;
    ns1:identificador "5014" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Configuración incorrecta de I/Os digitales (NDOMOD) o solapamiento de peticiones" ;
            ns1:textoExtracto "La tabla de configuración de las I/Os digitales no es válida (parámetro NDOMOD) o el PLC ha recibido una petición de escritura antes de finalizar la anterior." ] ;
    ns1:textoExtracto "'Error en la escritura de salidas digitales del PLC' DETECCIÓN Al escribir las salidas digitales del PLC. CAUSA Fallo en la escritura de las salidas digitales remotas de PLC. La tabla de configuración de las I/Os digitales no es válida (parámetro NDOMOD) o el PLC ha recibido una petición de escritura antes de finalizar la anterior. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ." .

ns1:Error_5034 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la parametrización de algún recurso remoto" ;
    ns1:identificador "5034" ;
    ns1:solucionaFallo ns1:ModuloRemoto ;
    ns1:textoExtracto "5034 Error en la parametrización de algún recurso remoto. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún parámetro de los recursos remotos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos." .

ns1:Error_5035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en una salida analógica remota" ;
    ns1:identificador "5035" ;
    ns1:solucionaFallo ns1:SalidaAnalogicaRemota ;
    ns1:textoExtracto "5035 Error de circuito abierto en una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Se ha abierto el circuito conectado a una salida analógica remota. SOLUCIÓN Revisar el conexionado de la salida analógica remota." .

