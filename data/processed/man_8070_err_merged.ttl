    ns1:mitigaRiesgo ns1:Alarma_1442 ;
    ns1:textoExtracto "Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry."@es .

ns1:AvisoSeguridad_EliminacionEjeC a ns1:AvisoSeguridad ;
