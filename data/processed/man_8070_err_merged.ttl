ns1:Error_8848 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8848: Demasiados errores" ;
    ns1:identificador "8848" ;
    ns1:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores y sólo muestra los primeros. SOLUCIÓN Corregir los errores y volver a analizar el programa." .

ns1:Error_8849 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8849: Falta END o nueva proposición" ;
    ns1:identificador "8849" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "8849 Se esperaba END o nueva proposición. Puede que falte un salto de línea. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta programar END al final de un módulo o subrutina. SOLUCIÓN Programar END al final de cada módulo o subrutina. Programar END sola en el bloque." .

ns1:Error_8850 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8850: Error fatal" ;
    ns1:identificador "8850" ;
    ns1:textoExtracto "8850 Error fatal. No se puede continuar. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado un error y no puede compilar o ejecutar el programa. SOLUCIÓN Revisar la sintaxis del programa." .

ns1:Error_8851 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8851: Marca no válida" ;
    ns1:identificador "8851" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "8851 Una marca no es válida en este contexto. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programada una marca y la instrucción necesita otro tipo de recurso. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_8852 a ns1:DiagnosticoFallo ;
