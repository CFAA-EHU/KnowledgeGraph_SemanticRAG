ns1:Error_6030 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el nodo contadora de CAN" ;
    ns1:identificador "6030" ;
    ns1:solucionaFallo ns1:ServicioAsistenciaTecnica ;
    ns1:textoExtracto "Límite de incremento de posición superado en el nodo contadora de CAN. DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico. Fallo de hardware del nodo contadora." .

ns1:Error_6031 a ns1:DiagnosticoFallo ;
    rdfs:label "Versión de soft incompatible en COMPCI/Nodos remotos"@es ;
    ns1:identificador "6031" ;
    ns1:solucionaFallo ns1:UsoDeSoftwareIncompatibleEnCOMPCINodosRemotos ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Versión de software incompatible en CNC y COMPCI o módulos remotos. SOLUCIÓN Actualizar el software de la COMPCI y módulos remotos."@es .

ns1:Error_6032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la configuración del teclado CAN"@es ;
    ns1:identificador "6032" ;
    ns1:solucionaFallo ns1:OperacionConFallosEnComunicacionCANNodo165_579a9669bc ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El 165 no responde o hay problemas en la comunicación CAN. SOLUCIÓN Revisar la conexión a través del bus CAN y la versión de la COMPCI."@es .

ns1:Error_6033 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración hardware no coincide con fichero guardado"@es ;
    ns1:identificador "6033" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o durante la ejecución. CAUSA La configuración hardware guardada en disco no coincide con la detectada en el arranque. Posibles cambios en la configuración CAN que no se han salvado, cambios no deseados en los parámetros máquina, etc. SOLUCIÓN En el modo diagnosis comprobar si la configuración CAN detectada coincide con la real; si es así, salvar la configuración. En caso contrario comprobar si es un error en la parametrización o hay algún error en la detección de los nodos."@es .

ns1:Error_6034 a ns1:DiagnosticoFallo ;
    rdfs:label "Reset en nodo CAN"@es ;
    ns1:identificador "6034" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Un nodo CAN se ha reseteado. La ventana de error indica el número de nodo. SOLUCIÓN Comprobar que la alimentación del nodo es correcta. Si no hay problemas en el bus, sustituir el nodo. Consultar con el servicio de asistencia técnica."@es .

ns1:Error_6035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de IOs locales"@es ;
    ns1:identificador "6035" ;
    ns1:solucionaFallo ns1:ConfiguracionDeMasDe8SalidasDigitalesLocalesEnCNC ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA En el CNC hay configuradas más salidas digitales locales que las que existentes. SOLUCIÓN Definir un máximo de 8 salidas digitales locales."@es .

ns1:Error_6036 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta alimentación de IOs locales"@es ;
    ns1:identificador "6036" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU)."@es .

ns1:Error_7027 a ns1:AvisoSeguridad ;
    rdfs:label "Error 'M6 sin T'"@es ;
    ns1:identificador "7027" ;
    ns1:solucionaFallo ns1:SolucionParaError7027 ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta. Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no hacer nada."@es .

ns1:Error_7028 a ns1:AvisoSeguridad ;
    rdfs:label "Error 'T0 no admitida'"@es ;
    ns1:identificador "7028" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA El almacén de tipo torreta no admite T0. En un almacén tipo torreta, el cambio de herramienta se realiza girando la torreta; basta con programar la herramienta."@es .

ns1:Error_7029 a ns1:Alarma ;
    rdfs:label "Error 'Gestor de herramientas en estado de error'"@es ;
    ns1:activaAlarma ns1:Sistema_GestionHerramientas ;
    ns1:identificador "7029" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Almacén en estado de emergencia. El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra."@es .

ns1:Error_7031 a ns1:DiagnosticoFallo ;
    rdfs:label "T con dos M6" ;
    ns1:identificador "7031" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay programadas dos M06 consecutivas para una misma herramienta. SOLUCIÓN Programar una M06 para cada herramienta." .

ns1:Error_7032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la operación de cambio de herramienta" ;
    ns1:identificador "7032" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error en la secuencia de cambio de herramienta, en el programa del PLC. SOLUCIÓN Comprobar el programa de PLC." .

ns1:Error_7047 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria insuficiente para herramientas"@es ;
    ns1:identificador "7047" ;
    ns1:solucionaFallo ns1:Solucion_7047 ;
    ns1:textoExtracto "7047 Memoria insuficiente para el número total de herramientas definido en los almacenes. DETECCIÓN Durante la ejecución. CAUSA El número de herramientas definido en los almacenes excede el máximo permitido."@es .

ns1:Error_7048 a ns1:AvisoSeguridad ;
    rdfs:label "Error en sentencia ROTATEMZ"@es ;
    ns1:identificador "7048" ;
    ns1:solucionaFallo ns1:Solucion_7048 ;
    ns1:textoExtracto "7048 Error en la Sentencia ROTATEMZ. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un cambio de herramienta en una torreta y la sentencia #ROTATEMZ ha dado error."@es .

