    ns1:solucionaFallo ns1:AnalisisDeCaidaDeSenalSPENAYErroresEnDriverSERCOS ;
    ns1:textoExtracto "4204 'Error al resetear el driver de SERCOS' [...] VALOR 1 Errores en el driver de Sercos."@es .

ns1:Error_4210 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo Sercos (MST perdido)" ;
    ns1:identificador "4210" ;
    ns1:solucionaFallo ns1:Solucion_4210 ;
    ns1:textoExtracto "4210 'Error en el anillo Sercos (MST perdido)' VALOR Códigos de error que identifican la fuente o fuentes del problema. | Código. | Significado. | --- | --- | 0x00000200 | Pérdida de MSTs." .

ns1:Error_5015 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5015: Fallo en lectura de variable desde PLC" ;
    ns1:identificador "5015" ;
    ns1:textoExtracto "'La lectura de la variable desde PLC no pudo realizarse'" .

ns1:Error_6025_EntradaVolanteInexistente a ns1:AvisoSeguridad ;
    rdfs:label "Error: Entrada de volante no existe"@es ;
    ns1:identificador "6025" ;
    ns1:textoExtracto "CAUSA La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error."@es .

ns1:Error_7033 a ns1:DiagnosticoFallo ;
    rdfs:label "PLC generó emergencia en el almacén de herramientas" ;
    ns1:identificador "7033" ;
    ns1:textoExtracto "DETECCIÓN Siempre que esté funcionando el PLC. CAUSA El PLC activa la señal de emergencia en el gestor de herramientas." .

ns1:Error_71_Sobretemperatura_CPU a ns1:AvisoSeguridad ;
    rdfs:label "Riesgo de sobretemperatura del equipo (ventilador CPU parado)"@es ;
    ns1:identificador "71" ;
    ns1:textoExtracto "Riesgo de sobretemperatura del equipo. El CNC ha detectado que el ventilador de la CPU está parado."@es .

ns1:Error_8515 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8515: Parámetro inicial incorrecto en #DINDIST" ;
    ns1:identificador "8515" ;
    ns1:textoExtracto "El primer parámetro #DINDIST debe ser 0 o 1. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_9523_Sincronizacion_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sincronización entre regulador y módulo ABSIND" ;
    ns1:identificador "9523" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador." .

ns1:Error_9524_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9524: ABSIND - Error leyendo información" ;
    ns1:identificador "9524" ;
    ns1:textoExtracto "9524 ABSIND:Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador." .

ns1:Error_9638_INDUCTOSYN a ns1:AvisoSeguridad ;
    rdfs:label "Error 9638 INDUCTOSYN"@es ;
    ns1:identificador "9638" ;
    ns1:mitigaRiesgo ns1:Solucion_ComprobacionAjusteABSIND,
        ns1:Solucion_ContactoFagorAutomation,
        ns1:Solucion_SustitucionModuloABSIND ;
    ns1:textoExtracto "INDUCTOSYN: Error desconocido."@es .

ns1:Error_CAN_6011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de CAN en nodo remoto"@es ;
    ns1:identificador "6011" ;
    ns1:textoExtracto "6011 'Error de CAN en nodo remoto' [...] Error reportado por un nodo. Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen. La ventana de error indica cuál es el módulo provoca el error."@es .

ns1:EsquemaDeEdicion a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:ManualDeProgramacionDelControl8055 ;
    ns1:identificador "Esquema de edición" ;
    ns1:textoExtracto "Durante la edición"@es .

