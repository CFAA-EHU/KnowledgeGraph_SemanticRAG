ns1:Alarma_2102 a ns1:Alarma ;
    rdfs:label "Alarma 2102: #ROUNDPAR: parámetro demasiado pequeño"@es ;
    ns1:identificador "2102" ;
    ns1:textoExtracto "2102 #ROUNDPAR:parámetro demasiado pequeño. DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado. SOLUCIÓN Programar la sentencia con un error de contorno superior a 20 micras."@es .

ns1:Alarma_2103 a ns1:Alarma ;
    rdfs:label "Alarma 2103: #ROUNDPAR: parámetro incorrecto"@es ;
    ns1:identificador "2103" ;
    ns1:textoExtracto "2103 #ROUNDPAR:parámetro incorrecto. DETECCIÓN Durante la ejecución. CAUSA El tipo de redondeo programado no es válido. SOLUCIÓN Consultar en el manual de programación el formato de esta sentencia."@es .

ns1:Alarma_2105_HSC_TangenteFinalIndeterminada a ns1:Alarma ;
    rdfs:label "Alarma 2105: HSC - Tangente final indeterminada" ;
    ns1:identificador "2105" ;
    ns1:textoExtracto "#HSC: tangente final indeterminada. DETECCIÓN Durante la ejecución." .

ns1:Alarma_2106_HSC_ErrorInterno a ns1:Alarma ;
    rdfs:label "Alarma 2106: HSC - Error interno en modo HSC" ;
    ns1:identificador "2106" ;
    ns1:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución." .

ns1:Alarma_2124 a ns1:Alarma ;
    rdfs:label "SPLINE: Son necesarios al menos dos ejes principales"@es ;
    ns1:identificador "2124" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ModoSpline_EjesInsuficientes ;
    ns1:textoExtracto "2124 'SPLINE: Son necesarios al menos dos ejes principales' DETECCIÓN Durante la ejecución. CAUSA No se puede activar el modo spline con sólo un eje en el canal. SOLUCIÓN Configurar el canal con dos ejes o programar los movimientos sin modo spline."@es .

ns1:Alarma_2125 a ns1:Alarma ;
    rdfs:label "SPLINE: Error en el cálculo de la tangente"@es ;
    ns1:identificador "2125" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ModoSpline_PuntosRepetidos ;
    ns1:textoExtracto "2125 'SPLINE: Error en el cálculo de la tangente' DETECCIÓN Durante la ejecución. CAUSA Hay programado puntos repetidos. SOLUCIÓN Programar puntos distintos."@es .

ns1:Alarma_2126 a ns1:Alarma ;
    rdfs:label "Límite software positivo sobrepasado en el spline"@es ;
    ns1:identificador "2126" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ModoSpline_LimitePositivoExcedido ;
    ns1:textoExtracto "2126 'Límite software positivo sobrepasado en el spline' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo spline en el bloque o bloques que provocan el error."@es .

ns1:Alarma_2127 a ns1:Alarma ;
    rdfs:label "Límite software negativo sobrepasado en el spline"@es ;
    ns1:identificador "2127" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ModoSpline_LimiteNegativoExcedido ;
    ns1:textoExtracto "2127 'Límite software negativo sobrepasado en el spline' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo spline en el bloque o bloques que provocan el error."@es .

ns1:Alarma_2371 a ns1:Alarma ;
    rdfs:label "#LSFIT, el algoritmo no converge" ;
    ns1:identificador "2371" ;
    ns1:textoExtracto "2371 #LSFIT, el algoritmo no converge, compruebe los datos de entrada. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2372 a ns1:Alarma ;
    rdfs:label "#LSFIT, número mínimo de datos sobrepasado" ;
    ns1:identificador "2372" ;
    ns1:textoExtracto "2372 #LSFIT, número mínimo de datos sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El número de palpaciones o datos de entrada es mayor que el mínimo permitido. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2373 a ns1:Alarma ;
    rdfs:label "#LSFIT, número de datos insuficiente" ;
    ns1:identificador "2373" ;
    ns1:textoExtracto "2373 #LSFIT, número de datos insuficiente. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2374 a ns1:Alarma ;
    rdfs:label "#LSFIT, error de cálculo (radio=0)" ;
    ns1:identificador "2374" ;
    ns1:textoExtracto "2374 #LSFIT, error de cálculo (radio=0), compruebe los datos de entrada. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2375 a ns1:Alarma ;
    rdfs:label "#LSFIT, error de cálculo (SVD)" ;
    ns1:identificador "2375" ;
    ns1:textoExtracto "2375 #LSFIT, error de cálculo (SVD), compruebe los datos de entrada. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2376 a ns1:Alarma ;
    rdfs:label "#LSFIT, error de cálculo (SVBK)" ;
    ns1:identificador "2376" ;
    ns1:textoExtracto "2376 #LSFIT, error de cálculo (SVBK), compruebe los datos de entrada." .

ns1:Alarma_2404 a ns1:Alarma ;
    rdfs:label "#GAPCTRL: Se ha alterado el índice en el canal del eje controlado"@es ;
    ns1:identificador "2404" ;
    ns1:textoExtracto """\r
    DETECCIÓN Durante la preparación de bloques.\r
    CAUSA Las posibles causas son las siguientes:\r
    • Con el control del gap activo (#GAPCTRLON), se ha programado una instrucción que altera el índice de dicho eje en el canal (#SETAX, #CALLAX, #FREEAX).\r
    • Si el parámetro máquina GAPCTRLCANCEL tiene valor "NO", el eje sigue controlado después de acabar el programa o tras un reset. Si en estas condiciones se altera el índice del eje, también se produce este error.\r
    SOLUCIÓN No es posible modificar lo posición de los ejes en el canal con el control de gap activo.\r
    """@es .

ns1:Alarma_2408 a ns1:Alarma ;
    rdfs:label "Alarma 2408: Conflicto entre #LEAP, #GAPCTRL ON y #SWTOUT ON"@es ;
    ns1:identificador "2408" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_2408_Solucion ;
    ns1:textoExtracto "2408 #LEAP, #GAPCTRL ON #SWTOUT ON: Los tres comandos no pueden estar activos. DETECCIÓN Durante la preparación de bloques. CAUSA Los comandos #LEAP, #GAPCTRL ON y #SWTOUT ON no pueden estar activos simultáneamente."@es .

ns1:Alarma_2418 a ns1:Alarma ;
    rdfs:label "Alarma 2418: #PWRCTRL ON - OVRMIN > OVRMAX" ;
    ns1:identificador "2418" ;
    ns1:monitoreaParametro ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN ;
    ns1:textoExtracto "#PWRCTRL ON: OVRMIN debe ser menor que OVRMAX. [...] CAUSA En la función #PWRCTRL, el override mínimo es mayor que el override máximo.",
        "2418 #PWRCTRL ON: OVRMIN debe ser menor que OVRMAX. [...] En la función #PWRCTRL, el override mínimo es mayor que el override máximo." .

ns1:Alarma_2419 a ns1:Alarma ;
    rdfs:label "Alarma 2419: #PWRCTRL ON - Parámetros incompletos" ;
    ns1:identificador "2419" ;
    ns1:textoExtracto "#PWRCTRL ON: la primera vez es obligatorio programar todos los parámetros. [...] CAUSA Es la primera vez que se programa la función #PWRCTRL y falta algún parámetro." .

ns1:Alarma_2420 a ns1:Alarma ;
    rdfs:label "Alarma 2420: #FOLLOW ON - Conflicto de eje esclavo" ;
    ns1:identificador "2420" ;
    ns1:textoExtracto "#FOLLOW ON[MASTER, ]. El eje esclavo no puede ser esclavo de otro master. [...] SOLUCIÓN Un eje no puede ser esclavo en dos sincronizaciones." .

ns1:Alarma_2421 a ns1:Alarma ;
    rdfs:label "Alarma 2421: Cambio de cabezal con #PWRCTRL activo" ;
    ns1:identificador "2421" ;
    ns1:textoExtracto "No se admite cambiar o aparcar el cabezal master con PWRCTRL activo. [...] SOLUCIÓN Para cambiar o aparcar el cabezal master, desactivar el control de potencia (#PWRCTRL)." .

ns1:Alarma_2422 a ns1:Alarma ;
    rdfs:label "Alarma 2422: #TFOLLOW ON no permitido" ;
    ns1:identificador "2422" ;
    ns1:textoExtracto "No se permite #TFOLLOW ON [MASTER]. [...] CAUSA [...] no es posible sincronizar sobre las cotas teóricas." .

ns1:Alarma_2429 a ns1:Alarma ;
    rdfs:label "Parámetro DMC fuera de rango" ;
    ns1:identificador "2429" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de sintaxis #DMC" ;
            ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." ] ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango [...] Algún comando de la sentencia #DMC tiene un valor no válido." .

ns1:Alarma_2431 a ns1:Alarma ;
    rdfs:label "#DMC ON: Error de configuración",
        "Alarma 2431: #DMC ON - OVRMIN > OVRMAX" ;
    ns1:activaAlarma ns1:Sistema_DMC ;
    ns1:identificador "2431" ;
    ns1:textoExtracto "2431 #DMC ON:",
        "DETECCIÓN Durante la ejecución. CAUSA En la función #DMC, el override mínimo es mayor que el override máximo. SOLUCIÓN El override mínimo (OVRMIN) debe ser menor que el override máximo (OVRMAX)." .

ns1:Alarma_2436 a ns1:Alarma ;
    rdfs:label "Alarma 2436: Programación no permitida fuera de macro G8777",
        "Alarma 2436: Programación no permitida fuera de una macro G8777" ;
    ns1:identificador "2436" ;
    ns1:textoExtracto "2436 Programación no permitida fuera de una macro G8777. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777. SOLUCIÓN Revisar la programación. Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777.",
        "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777. SOLUCIÓN Revisar la programación." .

ns1:Alarma_2437 a ns1:Alarma ;
    rdfs:label "Alarma 2437: Perfil poligonal en macro G8077" ;
    ns1:identificador "2437" ;
    ns1:textoExtracto "2437 El perfil de la macro G8077 es poligonal. DETECCIÓN Durante la ejecución. CAUSA El perfil debe estar construido con tramos rectos. SOLUCIÓN Modificar el perfil." .

ns1:Alarma_2444 a ns1:Alarma ;
    rdfs:label "Alarma 2444: #OPEN/#CLOSE/#WRITE - valor de handle de fichero fuera de rango"@es ;
    ns1:identificador "2444" ;
    ns1:textoExtracto "2444 #OPEN/#CLOSE/#WRITE:valor de handle de fichero fuera de rango. [...] SOLUCIÓN: El identificador de fichero (comando F) debe tener un valor entre 1 y 4."@es .

ns1:Alarma_2445 a ns1:Alarma ;
    rdfs:label "Alarma 2445: #OPEN/#CLOSE/#WRITE - doble programación"@es ;
    ns1:identificador "2445" ;
    ns1:textoExtracto "2445 #OPEN/#CLOSE/#WRITE:doble programación. [...] SOLUCIÓN: Programar una única vez cada parámetro de la sentencia."@es .

ns1:Alarma_2446 a ns1:Alarma ;
    rdfs:label "Alarma 2446: Prefijo de variable inexistente"@es ;
    ns1:identificador "2446" ;
    ns1:textoExtracto "2446 Prefijo de variable inexistente. [...] SOLUCIÓN: Consulte en la documentación la lista de variables permitidas."@es .

ns1:Alarma_2447 a ns1:Alarma ;
    rdfs:label "Alarma 2447: #PARALAX - ejes paralelos deben pertenecer al mismo canal"@es ;
    ns1:identificador "2447" ;
    ns1:textoExtracto "2447 #PARALAX: Los ejes paralelos deben pertenecer al mismo canal. [...] SOLUCIÓN: Los ejes programados deben pertenecer al mismo canal."@es .

ns1:Alarma_2448 a ns1:Alarma ;
    rdfs:label "Alarma 2448: Programación no permitida con transformación #PARALAX activa"@es ;
    ns1:identificador "2448" ;
    ns1:textoExtracto "2448 Programación no permitida con la transformación #PARALAX activa. [...] SOLUCIÓN: Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones."@es .

ns1:Alarma_2449 a ns1:Alarma ;
    rdfs:label "Alarma 2449: Eje Hirth no compatible con transformación #PARALAX"@es ;
    ns1:identificador "2449" ;
    ns1:textoExtracto "2449 No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. [...] SOLUCIÓN: Los ejes programados no pueden ser Hirth."@es .

ns1:Alarma_2450 a ns1:Alarma ;
    rdfs:label "Alarma 2450: Ejes de transformación activa no excluibles (#PARALAX)"@es ;
    ns1:identificador "2450" ;
    ns1:textoExtracto "ser Hirth. 2450 #PARALAX: Los ejes de la transformación activa, no pueden excluirse. DETECCIÓN Durante la ejecución. CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una transformación de ejes paralelos. SOLUCIÓN Desactivar la transformación antes de cambiar los ejes del canal."@es .

ns1:Alarma_2451 a ns1:Alarma ;
    rdfs:label "Alarma 2451: Transformación de ejes paralelos desactivada (#PARALAX)"@es ;
    ns1:identificador "2451" ;
    ns1:textoExtracto "2451 Se ha desactivado la transformación de ejes paralelos #PARALAX. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los ejes necesarios para la transformación no son adecuados. • Se ha intentando hacer una búsqueda de cero con la función #PARALAX activa. SOLUCIÓN Las posibles soluciones son las siguientes: • Los ejes de una transformación deben ser lineales, pertenecer al canal, no estar aparcados y no ser esclavos de un acoplo o eje gantry. • Desactivar la transformación antes de hacer una búsqueda de referencia."@es .

ns1:Alarma_2452 a ns1:Alarma ;
    rdfs:label "Alarma 2452: Ejes de transformación paralela deben ser lineales (#PARALAX)"@es ;
    ns1:identificador "2452" ;
    ns1:textoExtracto "2452 Los ejes de la transformación paralela, #PARALAX, deben ser lineales. DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes programados es un eje rotativo. SOLUCIÓN Los ejes programados deben ser lineales."@es .

ns1:Alarma_2457 a ns1:Alarma ;
    rdfs:label "Alarma 2457: Exceso de parámetros en #GAPPOS" ;
    ns1:identificador "2457" ;
    ns1:textoExtracto "#GAPPOS: demasiados parámetros. DETECCIÓN Durante la preparación de bloques. CAUSA Se han definido más de tres ejes en la sentencia #GAPPOS. SOLUCIÓN En la sentencia #GAPPOS sólo hay que definir los tres primeros ejes del canal." .

ns1:Alarma_2458 a ns1:Alarma ;
    rdfs:label "Alarma 2458: Parámetro DMCSPDL no configurado para DMC" ;
    ns1:identificador "2458" ;
    ns1:textoExtracto "#DMC ON:El cabezal master debe tener el parámetro DMCSPDL = Sí. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." .

ns1:Alarma_2459 a ns1:Alarma ;
    rdfs:label "Alarma 2459: Valor inválido en parámetro TYPE de #OPEN" ;
    ns1:identificador "2459" ;
    ns1:textoExtracto "#OPEN: valor de parámetro TYPE no válido. DETECCIÓN Durante la ejecución. CAUSA El comando TYPE tiene un valor no válido. SOLUCIÓN Revisar la programación de la sentencia #OPEN." .

ns1:Alarma_2461 a ns1:Alarma ;
    rdfs:label "Alarma 2461: Conflicto de eje en #GAPCTRL y transformadas" ;
    ns1:identificador "2461" ;
    ns1:textoExtracto "El eje del #GAPCTRL, no puede formar parte de los ejes de la transformada. DETECCIÓN Durante la ejecución. CAUSA El eje para el control de gap (#GAPCTRL) coincide con algún eje de las transformaciones #CS/#ACS, #RTCP, #ANGAX o #VIRTAX. SOLUCIÓN Programar el control de gap con un eje simulado." .

ns1:Alarma_2482 a ns1:Alarma ;
    rdfs:label "Alarma 2482: Número de origen no válido" ;
    ns1:identificador "2482" ;
    ns1:textoExtracto "2482 Número de origen no válido. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #KINORG con un origen no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para el origen es 1..99." .

ns1:Alarma_2483 a ns1:Alarma ;
    rdfs:label "Alarma 2483: #KINORG no admite origen activo" ;
    ns1:identificador "2483" ;
    ns1:textoExtracto "2483 #KINORG: no se admite el origen activo. DETECCIÓN Durante la ejecución. CAUSA En la sentencia #KINORG no se permite programar el origen activo. SOLUCIÓN Revisar la programación. Programar un origen distinto del activo. El rango de valores admitido para el origen es 1..99." .

ns1:Alarma_2484 a ns1:Alarma ;
    rdfs:label "Alarma 2484: Movimiento de eje rotativo no permitido con compensación de radio activa" ;
    ns1:identificador "2484" ;
    ns1:textoExtracto "2484 Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42). DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP] y la compensación de radio (G41/G42). SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo." .

ns1:Alarma_2485 a ns1:Alarma ;
    rdfs:label "Alarma 2485: Programación conjunta de eje lineal y rotativo no permitida" ;
    ns1:identificador "2485" ;
    ns1:textoExtracto "2485 No se permite programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP]. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:Alarma_2486 a ns1:Alarma ;
    rdfs:label "Alarma 2486: Renombrado de cabezal en modo eje C no permitido" ;
    ns1:identificador "2486" ;
    ns1:textoExtracto "2486 No se admite #RENAME del cabezal en modo eje C. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C." .

ns1:Alarma_2487 a ns1:Alarma ;
    rdfs:label "Alarma 2487: Activación de #FACE/#CYL con cinemática incompatible" ;
    ns1:identificador "2487" ;
    ns1:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde." .

ns1:Alarma_2507 a ns1:Alarma ;
    rdfs:label "Alarma 2507: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas"@es ;
    ns1:identificador "2507" ;
    ns1:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución. CAUSA No es posible programar las cotas de un bloque en G107 con coordenadas polares o mediante coordenadas cartesianas y ángulo."@es .

ns1:Alarma_2508 a ns1:Alarma ;
    rdfs:label "Alarma 2508: Valor de escritura fuera de rango"@es ;
    ns1:identificador "2508" ;
    ns1:textoExtracto "2508 Valor de escritura fuera de rango. DETECCIÓN Durante la ejecución. CAUSA No es posible escribir ese valor en la variable."@es .

ns1:Alarma_3000 a ns1:Alarma ;
    rdfs:label "No se puede programar una trayectoria circular con un eje esclavo"@es ;
    ns1:identificador "3000" ;
    ns1:textoExtracto """\r
    3000 'No se puede programar una trayectoria circular con un eje esclavo'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA El CNC intenta mover individualmente el eje esclavo de un acoplo o de un eje gantry.\r
    SOLUCIÓN Un eje esclavo no se puede desplazar individualmente. Para desplazar un eje esclavo, hay que desplazar el eje maestro al que se encuentra asociado.\r
    """@es .

ns1:Alarma_3001 a ns1:Alarma ;
    rdfs:label "No se puede mover un eje en modo visualizador"@es ;
    ns1:identificador "3001" ;
    ns1:textoExtracto """\r
    3001 'No se puede mover un eje en modo visualizador'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA El CNC intenta desplazar un eje que se encuentra en modo visualizador.\r
    SOLUCIÓN El CNC no puede desplazar los ejes activos en modo visualizador. Para desplazar el eje, desactivar el modo visualizador (marca DRO(axis) del PLC).\r
    """@es .

ns1:Alarma_3002 a ns1:Alarma ;
    rdfs:label "Límite positivo de software sobrepasado"@es ;
    ns1:identificador "3002" ;
    ns1:textoExtracto """\r
    3002 'Límite positivo de software sobrepasado'\r
    DETECCIÓN Durante la reposición de un eje.\r
    CAUSA Durante el movimiento de reposicionamiento, el eje ha alcanzado los límites de software. Si el punto de reposición está fuera de los límites de software, el eje no puede alcanzar dicho punto.\r
    SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC.\r
    """@es .

ns1:Alarma_3003 a ns1:Alarma ;
    rdfs:label "Límite negativo de software sobrepasado"@es ;
    ns1:identificador "3003" ;
    ns1:textoExtracto """\r
    3003 'Límite negativo de software sobrepasado'\r
    DETECCIÓN Durante la reposición de un eje.\r
    CAUSA Durante el movimiento de reposicionamiento, el eje ha alcanzado los límites de software. Si el punto de reposición está fuera de los límites de software, el eje no puede alcanzar dicho punto.\r
    SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC.\r
    """@es .

ns1:Alarma_3005 a ns1:Alarma ;
    rdfs:label "Error del control de posición en la inicialización del proceso de palpador"@es ;
    ns1:identificador "3005" ;
    ns1:textoExtracto """\r
    3005 'Error del control de posición en la inicialización del proceso de palpador'\r
    DETECCIÓN En la inicialización del proceso de palpado.\r
    CAUSA Es una seguridad de habilitación del proceso de palpado. Algún eje programado no es válido o no está disponible.\r
    """@es .

ns1:Alarma_3007 a ns1:Alarma ;
    rdfs:label "Alarma 3007: Señal de palpador prematura" ;
    ns1:identificador "3007" ;
    ns1:textoExtracto "'Se ha recibido señal del palpador antes del movimiento' DETECCIÓN Tras detectar la señal de palpador. CAUSA Proceso de palpado habilitado sin G100 programada. SOLUCIÓN Póngase en contacto con su proveedor." .

ns1:Alarma_3009 a ns1:Alarma ;
    rdfs:label "Alarma 3009: Falta señal de palpador" ;
    ns1:identificador "3009" ;
    ns1:textoExtracto "3009 No se ha recibido señal del palpador. DETECCIÓN Durante la ejecución. CAUSA No ha llegado la señal del palpador tras un movimiento de palpado. SOLUCIÓN Revisar la parametrización del palpador y señales físicas." .

ns1:Alarma_3013 a ns1:Alarma ;
    rdfs:label "Alarma 3013: Distancia de frenado excesiva" ;
    ns1:identificador "3013" ;
    ns1:textoExtracto "'Distancia de frenado mayor que el parámetro PROBERANGE' DETECCIÓN Durante la ejecución. CAUSA La distancia necesaria para frenar con el avance activo es mayor que la distancia máxima admisible (parámetro PROBERANGE), probablemente debido al error de seguimiento. SOLUCIÓN Disminuir el avance de palpado o disminuir el error de seguimiento." .

ns1:Alarma_3025 a ns1:Alarma ;
    rdfs:label "Límite positivo de software sobrepasado" ;
    ns1:identificador "3025" ;
    ns1:textoExtracto "3025 'Límite positivo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los limites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:Alarma_3026 a ns1:Alarma ;
    rdfs:label "Límite negativo de software sobrepasado" ;
    ns1:identificador "3026" ;
    ns1:textoExtracto "3026 'Límite negativo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los limites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:Alarma_3027 a ns1:Alarma ;
    rdfs:label "Error en el cálculo de la transformada inversa de RTCP" ;
    ns1:identificador "3027" ;
    ns1:textoExtracto "3027 'Error en el cálculo de la transformada inversa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas pieza a coordenadas máquina. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:Alarma_3029 a ns1:Alarma ;
    rdfs:label "Error en el cálculo de la transformada directa de RTCP" ;
    ns1:identificador "3029" ;
    ns1:textoExtracto "3029 'Error en el cálculo de la transformada directa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas máquina a coordenadas pieza. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:Alarma_3030 a ns1:Alarma ;
    rdfs:label "No se pueden mezclar ejes simulados con no simulados" ;
    ns1:identificador "3030" ;
    ns1:textoExtracto "3030 'No se pueden mezclar ejes simulados con no simulados' DETECCIÓN Durante la ejecución. CAUSA En el proceso de medición con palpador hay ejes simulados y no simulados. SOLUCIÓN Todos los ejes que intervienen en un proceso de medición con palpador deben ser del mismo tipo." .

ns1:Alarma_3031 a ns1:Alarma ;
    rdfs:label "Compensación (RTCP/TLC) no permitida en el estado actual" ;
    ns1:identificador "3031" ;
    ns1:textoExtracto "3031 'Compensación (RTCP/TLC) no permitida en el estado actual' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las compensaciones RTCP o TLC estando la otra activa." .

ns1:Alarma_3032 a ns1:Alarma ;
    rdfs:label "Alarma 3032: No se admite búsqueda de cero en modo visualizador" ;
    ns1:identificador "3032" ;
    ns1:textoExtracto "3032 'No se admite búsqueda de cero en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer una búsqueda de referencia de un eje visualizador. SOLUCIÓN El CNC no permite realizar una búsqueda de referencia de un eje visualizador." .

ns1:Alarma_3033 a ns1:Alarma ;
    rdfs:label "Alarma 3033: No se admite el paso a modo manual si el eje está en el centro de giro" ;
    ns1:identificador "3033" ;
    ns1:textoExtracto "3033 'No se admite el paso a modo manual si el eje esta en el centro de giro' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta activar el modo manual con la transformación de eje C frontal activa y los ejes en el centro de giro. SOLUCIÓN Activar el modo manual con los ejes en una posición distinta a la del centro de giro." .

ns1:Alarma_3034 a ns1:Alarma ;
    rdfs:label "Alarma 3034: Número de gama no válido" ;
    ns1:identificador "3034" ;
    ns1:textoExtracto "3034 'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta acceder a un set de parámetros que no existe. SOLUCIÓN El número de set debe estar comprendido entre 1 y el parámetro NPARSET." .

ns1:Alarma_3035 a ns1:Alarma ;
    rdfs:label "Alarma 3035: Diferencia de errores de seguimiento de ejes acoplados demasiado grande" ;
    ns1:identificador "3035" ;
    ns1:textoExtracto "3035 'Diferencia de errores de seguimiento de ejes acoplados demasiado grande' DETECCIÓN Durante la ejecución. CAUSA En un eje gantry, la diferencia entre el error de seguimiento del eje maestro y del esclavo es superior a la definida en el parámetro MAXCOUPE; en un acoplo de ejes, la diferencia es superior al valor definido. SOLUCIÓN Ajustar de forma similar el comportamiento dinámico ambos ejes o aumentar error permitido." .

ns1:Alarma_3036 a ns1:Alarma ;
    rdfs:label "Alarma 3036: Proceso de cambio de gama incorrecto" ;
    ns1:identificador "3036" ;
    ns1:textoExtracto "3036 'Proceso de cambio de gama incorrecto' DETECCIÓN Durante la ejecución. CAUSA No coincide la gama de cabezal que está en la historia del CNC y la gama que marca el PLC como gama activa. SOLUCIÓN Comprobar el programa de PLC." .

ns1:Alarma_3037 a ns1:Alarma ;
    rdfs:label "Alarma 3037: Eje bloqueado" ;
    ns1:identificador "3037" ;
    ns1:textoExtracto "3037 'Eje bloqueado' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje, pero el PLC no ha puesto la señal SERVO(axis)ON." .

ns1:Alarma_3067 a ns1:Alarma ;
    rdfs:label "Cabezal no controlado en posición" ;
    ns1:identificador "3067" ;
    ns1:textoExtracto "controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste no dispone de encóder. SOLUCIÓN El cabezal necesita un encóder." .

ns1:Alarma_3068 a ns1:Alarma ;
    rdfs:label "RETRACE finalizado, desactivar marca para continuar" ;
    ns1:identificador "3068" ;
    ns1:textoExtracto "3068 'RETRACE finalizado, desactivar marca para continuar' DETECCIÓN Durante la ejecución. CAUSA Tras finalizar la ejecución en retrace, la marca RETRACE del PLC sigue activa. SOLUCIÓN El PLC debe desactivar la marca RETRACE para que el programa continúe." .

ns1:Alarma_3069 a ns1:Alarma ;
    rdfs:label "Cambio de gama incorrecto, el regulador no responde" ;
    ns1:identificador "3069" ;
    ns1:textoExtracto "3069 Cambio de gama incorrecto, el regulador no responde. DETECCIÓN Durante la ejecución. CAUSA El CNC no ha finalizado correctamente el cambio de gama de un eje o cabezal porque el regulador no responde a la petición de cambio de gama. SOLUCIÓN Comprobar estado del regulador." .

ns1:Alarma_3070 a ns1:Alarma ;
    rdfs:label "Velocidad del cabezal asociado a G33/G34/G95 nula" ;
    ns1:identificador "3070" ;
    ns1:textoExtracto "3070 'Velocidad del cabezal asociado a G33/G34/G95 nula' DETECCIÓN Durante la ejecución. CAUSA El cabezal asociado a la función G33, G34 o G95 está parado. SOLUCIÓN Comprobar la velocidad del cabezal asociado a estas funciones, que será el cabezal master del canal o el cabezal indicado en el registro SYNC, asociado al canal." .

ns1:Alarma_3071 a ns1:Alarma ;
    rdfs:label "No se admiten S, ni funciones M o H con proceso de cambio de gama activo" ;
    ns1:identificador "3071" ;
    ns1:textoExtracto "3071 'No se admiten S, ni funciones M o H con proceso de cambio de gama activo' DETECCIÓN Durante la ejecución. CAUSA El usuario ha interrumpido el programa durante el cambio de gama y ha intentado cambiar las funciones S, M ó H desde el modo MHFS. SOLUCIÓN Continuar la ejecución hasta que finalice el cambio de gama. A continuación interrumpir el programa y enviar las funciones deseadas al cabezal." .

ns1:Alarma_3078 a ns1:Alarma ;
    rdfs:label "El cabezal master de la sincronización no pasa a lazo abierto"@es ;
    ns1:identificador "3078" ;
    ns1:textoExtracto "3078 'El cabezal master de la sincronización no pasa a lazo abierto'         DETECCIÓN: Durante la ejecución.         CAUSA: El usuario ha programado una sincronización (#SYNC) en lazo abierto (comando OLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo cerrado para otra sincronización previa y seguirá en lazo cerrado.         SOLUCIÓN: El cabezal no cambia de lazo. Dejar el cabezal en lazo cerrado o eliminar la sincronización previa para que el cabezal pase a lazo abierto."@es .

ns1:Alarma_3079 a ns1:Alarma ;
    rdfs:label "El cabezal master de la sincronización no pasa a lazo cerrado"@es ;
    ns1:identificador "3079" ;
    ns1:textoExtracto "3079 'El cabezal master de la sincronización no pasa a lazo cerrado'         DETECCIÓN: Durante la ejecución.         CAUSA: El usuario ha programado una sincronización (#SYNC) en lazo cerrado (comando CLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo abierto para otra sincronización previa y seguirá en lazo abierto.         SOLUCIÓN: El cabezal no cambia de lazo. Dejar el cabezal en lazo abierto o eliminar la sincronización previa para que el cabezal pase a lazo cerrado."@es .

ns1:Alarma_3080 a ns1:Alarma ;
    rdfs:label "No es posible asumir el offset del eje no reposicionado"@es ;
    ns1:identificador "3080" ;
    ns1:textoExtracto "3080 'No es posible asumir el offset del eje no reposicionado'         DETECCIÓN: Durante la ejecución.         CAUSA: El CNC ha intentado mover un eje que previamente ha quedado sin reposicionar en una trayectoria circular.         SOLUCIÓN: No es posible mover un eje que ha quedado sin reposicionar en una trayectoria circular."@es .

ns1:Alarma_3081 a ns1:Alarma ;
    rdfs:label "Velocidad demasiado alta"@es ;
    ns1:identificador "3081" ;
    ns1:textoExtracto "3081 'Velocidad demasiado alta'         DETECCIÓN: Durante la ejecución del corte por láser (conmutación sincronizada).         CAUSA: La velocidad de corte es demasiado alta para el tamaño de la rejilla.         SOLUCIÓN: Disminuir la velocidad o el tiempo de ciclo."@es .

ns1:Alarma_3082 a ns1:Alarma ;
    rdfs:label "No es posible tanta anticipación para activar la salida digital"@es ;
    ns1:identificador "3082" ;
    ns1:textoExtracto "3082 'No es posible tanta anticipación para activar la salida digital'         DETECCIÓN: Durante la ejecución del corte por láser (conmutación sincronizada)."@es .

ns1:Alarma_3094 a ns1:Alarma ;
    rdfs:label "Sensor detecta distancia negativa"@es ;
    ns1:identificador "3094" ;
    ns1:textoExtracto "3094 El sensor detecta distancia negativa. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el sensor muestra distancia negativa. SOLUCIÓN Revisar la calibración del sensor."@es .

ns1:Alarma_3101 a ns1:Alarma ;
    rdfs:label "Potencia excesiva en el cabezal detectada durante DMC"@es ;
    ns1:identificador "3101" ;
    ns1:monitoreaParametro ns1:Parametro_TV51 ;
    ns1:textoExtracto "3101 'Potencia excesiva en el cabezal detectada durante DMC.Pulse MARCHA para continuar' DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado. Esto puede indicar que la herramienta ha colisionado con la pieza, por lo que el CNC detiene los ejes manteniendo el giro del cabezal."@es .

ns1:Alarma_3103 a ns1:Alarma ;
    rdfs:label "Potencia objetivo insuficiente para el funcionamiento correcto con DMC"@es ;
    ns1:identificador "3103" ;
    ns1:monitoreaParametro ns1:Parametro_TV51 ;
    ns1:textoExtracto "3103 Potencia objetivo insuficiente para el funcionamiento correcto con DMC. DETECCIÓN Durante la ejecución. CAUSA Los valores de la potencia en vacío y la potencia objetivo durante el mecanizado son similares. Es posible que el DMC no pueda distinguir con exactitud las entradas y salidas de la pieza."@es .

ns1:Alarma_3403 a ns1:Alarma ;
    rdfs:label "Alarma 3403: No se admiten más operaciones con ejes independientes. En sincronización"@es ;
    ns1:identificador "3403" ;
    ns1:textoExtracto "3403 'No se admiten mas operaciones con ejes independientes. En sincronización' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente pero existe una sincronización activa. SOLUCIÓN No programar operaciones de eje independiente con levas activas ni programar dos sincronizaciones seguidas."@es .

ns1:Alarma_3404 a ns1:Alarma ;
    rdfs:label "Alarma 3404: No se admite #FOLLOW OFF con otra operación pendiente"@es ;
    ns1:identificador "3404" ;
    ns1:textoExtracto "3404 'No se admite #FOLLOW OFF con otra operación pendiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una sentencia #FOLLOW OFF pero existe una operación pendiente. SOLUCIÓN Desde el PLC abortar las sentencias pendientes (marca ABORT) o bien esperar a que haya espacio para almacenarla (marca FREE)."@es .

ns1:Alarma_3405 a ns1:Alarma ;
    rdfs:label "Alarma 3405: No se admite #MOVE INF para un eje con límites"@es ;
    ns1:identificador "3405" ;
    ns1:textoExtracto "3405 'No se admite #MOVE INF para un eje con límites' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #MOVE INF tiene límites de recorrido definidos. SOLUCIÓN Eliminar los límites de software o interrumpir el movimiento antes de que el eje alcance el límite."@es .

ns1:Alarma_3406 a ns1:Alarma ;
    rdfs:label "Alarma 3406: La velocidad necesaria para sincronizar es superior a la máxima"@es ;
    ns1:identificador "3406" ;
    ns1:textoExtracto "3406 'La velocidad necesaria para sincronizar es superior a la máxima' DETECCIÓN Durante la ejecución. CAUSA La sincronización programada implica superar el avance máximo del eje. SOLUCIÓN Programar la sincronización con el eje maestro moviéndose a un avance menor o programar un ratio de sincronización menor."@es .

ns1:Alarma_3407 a ns1:Alarma ;
    rdfs:label "Alarma 3407: Cota programada para eje independiente superior al límite positivo"@es ;
    ns1:identificador "3407" ;
    ns1:textoExtracto "3407 'Cota programada para eje independiente superior al límite positivo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los límites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:Alarma_3408 a ns1:Alarma ;
    rdfs:label "Alarma 3408: 'inferior al límite negativo'"@es,
        "Alarma 3408: Cota programada para eje independiente inferior al límite negativo"@es ;
    ns1:identificador "3408" ;
    ns1:textoExtracto "3408 'Cota programada para eje independiente inferior al límite negativo' DETECCIÓN Durante la ejecución."@es,
        "3408 'inferior al límite negativo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los limites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:Alarma_3409 a ns1:Alarma ;
    rdfs:label "Alarma 3409: 'El eje no es válido como eje independiente'"@es ;
    ns1:identificador "3409" ;
    ns1:textoExtracto "3409 'El eje no es válido como eje independiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente en la que interviene un eje que depende de otros o del que dependen otros (por ejemplo ejes gantry, acoplados o que forman parte de una transformación) o bien porque es un eje visualizador, o es módulo y el límite inferior del módulo es negativo. SOLUCIÓN Desactivar el acoplo o las transformaciones existentes."@es .

ns1:Alarma_3410 a ns1:Alarma ;
    rdfs:label "Alarma 3410: 'Se ha superado el tiempo máximo permitido para sincronizar'"@es ;
    ns1:identificador "3410" ;
    ns1:textoExtracto "3410 'Se ha superado el tiempo máximo permitido para sincronizar' DETECCIÓN Durante la ejecución. CAUSA La sincronización no alcanza la posición deseada en el tiempo definido. SOLUCIÓN Aumentar el tiempo de sincronización, comenzar la sincronización a velocidades más parecidas o aumentar la aceleración del esclavo."@es .

ns1:Alarma_3411 a ns1:Alarma ;
    rdfs:label "Alarma 3411: 'Se intenta superar la velocidad máxima MAXFEED'"@es ;
    ns1:identificador "3411" ;
    ns1:textoExtracto "3411 'Se intenta superar la velocidad máxima MAXFEED' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de eje independiente con una sincronización activa y la suma de ambas componentes de velocidad supera la máxima permitida del eje. SOLUCIÓN Si la velocidad del eje maestro es alta, hay que programar el movimiento adicional con una velocidad más pequeña."@es .

ns1:Alarma_3412 a ns1:Alarma ;
    rdfs:label "Alarma 3412: 'No se puede programar denominador 0 en sincronización'"@es ;
    ns1:identificador "3412" ;
    ns1:textoExtracto "3412 'No se puede programar denominador 0 en sincronización' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el denominador del ratio de transmisión tiene valor cero. SOLUCIÓN El denominador del ratio no puede valer cero."@es .

ns1:Alarma_3413 a ns1:Alarma ;
    rdfs:label "Alarma 3413: 'No se puede sincronizar en posición con módulo y ratio diferente de 1'"@es ;
    ns1:identificador "3413" ;
    ns1:textoExtracto "3413 'No se puede sincronizar en posición con módulo y ratio diferente de 1' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma_3605 a ns1:Alarma ;
    rdfs:label "Sentido del giro de cabezal contrario al de parámetro máquina"@es ;
    ns1:identificador "3605" ;
    ns1:textoExtracto "3605 'Sentido del giro de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución. CAUSA El giro programado requiere un movimiento del cabezal en sentido contrario al indicado por parámetro máquina con UNIDIR. SOLUCIÓN Revisar la programación y el parámetro máquina UNIDIR del cabezal."@es .

ns1:Alarma_3606 a ns1:Alarma ;
    rdfs:label "El posicionamiento del cabezal requiere cota absoluta"@es ;
    ns1:identificador "3606" ;
    ns1:textoExtracto "3606 'El posicionamiento del cabezal requiere cota absoluta' DETECCIÓN Durante la ejecución. CAUSA Tras un giro del cabezal en lazo abierto, el posicionamiento debe ser en cotas absolutas. SOLUCIÓN Programar el posicionamiento en cotas absolutas."@es .

ns1:Alarma_3607 a ns1:Alarma ;
    rdfs:label "No se puede sincronizar el cabezal teniendo activo PLCCNTL"@es ;
    ns1:identificador "3607" ;
    ns1:textoExtracto "3607 'No se puede sincronizar el cabezal teniendo activo PLCCNTL' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado realizar una sincronización mientras la marca PLCCNTL está activa. SOLUCIÓN Desactivar la marca PLCCNTL del PLC."@es .

ns1:Alarma_3608 a ns1:Alarma ;
    rdfs:label "No se admite PLCCNTL si el cabezal está sincronizado"@es ;
    ns1:identificador "3608" ;
    ns1:textoExtracto "3608 'No se admite PLCCNTL si el cabezal está sincronizado'. DETECCIÓN Durante la ejecución. CAUSA El PLC ha activado la marca PLCCNTL en un cabezal que está sincronizado, ya sea como maestro o como esclavo. SOLUCIÓN Desactivar la marca PLCCNTL del PLC."@es .

ns1:Alarma_3609 a ns1:Alarma ;
    rdfs:label "No se permite #SERVO ON si no se ha buscado el cero del cabezal previamente"@es ;
    ns1:identificador "3609" ;
    ns1:textoExtracto "3609 'No se permite #SERVO ON si no se ha buscado el cero del cabezal previamente'. DETECCIÓN Durante la ejecución. CAUSA Hay programada una sentencia #SERVO ON para un cabezal que no está referenciado. SOLUCIÓN Hacer una búsqueda de referencia del cabezal, con M19 o G74, antes de utilizar la instrucción #SERVO ON."@es .

ns1:Alarma_3610 a ns1:Alarma ;
    rdfs:label "No se puede abrir el lazo por estar en M19 o en sincronización"@es ;
    ns1:identificador "3610" ;
    ns1:textoExtracto "3610 'No se puede abrir el lazo por estar en M19 o en sincronización' DETECCIÓN Durante la ejecución. CAUSA Hay programada una sentencia #SERVO OFF pero no se puede abrir el lazo porque el cabezal estaba en M19 antes de #SERVOON. SOLUCIÓN El cabezal se mantiene en lazo cerrado."@es .

ns1:Alarma_3716 a ns1:Alarma ;
    rdfs:label "Máxima consigna de velocidad superada" ;
    ns1:identificador "3716" ;
    ns1:textoExtracto "3716 'Máxima consigna de velocidad superada' DETECCIÓN Durante el movimiento de un eje o cabezal. CAUSA En los ejes Sercos velocidad, el CNC envía la consigna al regulador en diezmilésimas de rpm; el valor de la consigna ha sobrepasado el rango permitido. Aunque la velocidad programada no supere G00FEED, la consigna enviada al regulador tras aplicar Kv supera el máximo permitido. SOLUCIÓN Revisar los parámetros máquina PITCH, INPUTREV, OUTPUTREV y PROGAIN. Limitar la velocidad máxima (parámetro G00FEED) al valor que indica el warning para evitar el sobrepasamiento." .

ns1:Alarma_3723 a ns1:Alarma ;
    rdfs:label "Error en los límites de la ventana de palpado desde PLC",
        "Alarma 3723: No se admite G174 para eje en modo visualizador"@es ;
    ns1:identificador "3723" ;
    ns1:textoExtracto "Error en los límites de la ventana de palpado desde PLC. DETECCIÓN: Durante la ejecución. CAUSA: En el palpado desde PLC están mal definidos los límites de la ventana de palpado (límite inferior > límite superior).",
        "'No se admite G174 para eje en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca DRO). SOLUCIÓN Revisar la programación. Para forzar la cota de un eje (G174), éste no puede estar en modo visualizador; es decir, hay que desactivar su marca DRO(axis) y activar su marca SERVO(axis)ON."@es .

ns1:Alarma_3724 a ns1:Alarma ;
    rdfs:label "Alarma 3724: No se permite G174 si el eje no está en posición"@es ;
    ns1:identificador "3724" ;
    ns1:textoExtracto "'No se permite G174 si el eje no está en posición' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que no está en posición. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje esté en posición; es decir, que no esté en movimiento y que tenga su marca INPOS(axis) activa."@es .

ns1:Alarma_3725 a ns1:Alarma ;
    rdfs:label "Alarma 3725: No se permite G174 para un eje que está sincronizado"@es ;
    ns1:identificador "3725" ;
    ns1:textoExtracto "'No se permite G174 para un eje que está sincronizado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está sincronizado. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje no esté sincronizado con otro. Desincronizar eje antes de forzar cota o comprobar en el programa de PLC la lógica de la marca INSYNC del eje."@es .

ns1:Alarma_3726 a ns1:Alarma ;
    rdfs:label "Alarma 3726: Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem"@es ;
    ns1:identificador "3726" ;
    ns1:textoExtracto "'Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem' DETECCIÓN Al iniciar el movimiento de un eje tandem. CAUSA El CNC ha intentado mover el eje maestro del tandem sin esperar a que el eje esclavo esté habilitado. SOLUCIÓN En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados."@es .

ns1:Alarma_3729 a ns1:Alarma ;
    rdfs:label "No se permite más de un eje del grupo múltiple activo" ;
    ns1:identificador "3729" ;
    ns1:textoExtracto "3729 'No se permite más de un eje del grupo múltiple activo' DETECCIÓN Al activar la marca SWITCH del eje. CAUSA El CNC ha intentado activar un eje de un grupo múltiple, antes de desactivar el eje anterior." .

ns1:Alarma_3730 a ns1:Alarma ;
    rdfs:label "TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo" ;
    ns1:identificador "3730" ;
    ns1:textoExtracto "3730 'TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo' DETECCIÓN Al ejecutar el PLC un comando TOUCHPROBE. CAUSA El PLC ha intentado activar un palpado, pero el palpador está siendo utilizado por un comando TOUCHPROBE previo y ambos comandos utilizan flancos diferentes." .

ns1:Alarma_3731 a ns1:Alarma ;
    rdfs:label "G174: Desplazamiento no válido, valor demasiado grande" ;
    ns1:identificador "3731" ;
    ns1:textoExtracto "3731 'G174: Desplazamiento no válido, valor demasiado grande' DETECCIÓN Al ejecutar G174 CAUSA Al calcular el desplazamiento programado en unidades del regulador, se obtiene un valor fuera del rango admitido por el regulador." .

ns1:Alarma_3743 a ns1:Alarma ;
    rdfs:label "Colisión de palpador"@es ;
    ns1:activaAlarma ns1:Sensor_SondaPalpado ;
    ns1:identificador "3743" ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba."@es .

ns1:Alarma_3744 a ns1:Alarma ;
    rdfs:label "#GAPCTRL: No hay señal de la sonda"@es ;
    ns1:activaAlarma ns1:Sensor_SondaPalpado ;
    ns1:identificador "3744" ;
    ns1:textoExtracto "3744 #GAPCTRL: No hay señal de la sonda. DETECCIÓN Durante la ejecución. CAUSA No hay señal del sensor, a partir de la cual el CNC calcula la distancia."@es .

ns1:Alarma_3760 a ns1:Alarma ;
    rdfs:label "Alarma 3760: RPS, tensión de bus por debajo de la deseada" ;
    ns1:identificador "3760" ;
    ns1:textoExtracto "3760 RPS, tensión de bus por debajo de la deseada. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Caída inesperada de la linea de red que alimenta la maniobra. SOLUCIÓN Revisar la instalación y la maniobra." .

ns1:Alarma_3761 a ns1:Alarma ;
    rdfs:label "Alarma 3761: RPS, tensión de red alta, alcanza a la consigna de bus DC" ;
    ns1:identificador "3761" ;
    ns1:textoExtracto "3761 RPS, tensión de red alta, alcanza a la consigna de bus DC. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Subida de tensión de red, que al ser rectificada, alcanza la consigna del bus DC. SOLUCIÓN Subir la tensión de consigna del bus DC." .

ns1:Alarma_3800 a ns1:Alarma ;
    rdfs:label "Alarma 3800: Velocidad en jog continuo igual a cero" ;
    ns1:identificador "3800" ;
    ns1:textoExtracto "3800 'Velocidad en jog continuo igual a cero' DETECCIÓN Durante la ejecución o al cambiar el modo a jog continuo. CAUSA El avance para el modo jog continuo es cero. No hay programado ningún avance para el modo manual y el parámetro máquina JOGFEED es cero. SOLUCIÓN Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED." .

ns1:Alarma_3802 a ns1:Alarma ;
    rdfs:label "Velocidad en jog incremental demasiado pequeña" ;
    ns1:identificador "3802" ;
    ns1:textoExtracto "3802 'Velocidad en jog incremental demasiado pequeña' DETECCIÓN Durante la ejecución. CAUSA El incremento de posición calculado para un ciclo de PLC es demasiado pequeño." .

ns1:Alarma_3803 a ns1:Alarma ;
    rdfs:label "No se admite resolución de volante cero" ;
    ns1:identificador "3803" ;
    ns1:textoExtracto "3803 'No se admite resolución de volante cero' DETECCIÓN Durante un cambio en la resolución del volante desde el panel de mando. CAUSA La posición de volante seleccionada desde el conmutador o PLC tiene asociada una resolución de cero." .

ns1:Alarma_3805 a ns1:Alarma ;
    rdfs:label "Velocidad o distancia cero en modo jog incremental" ;
    ns1:identificador "3805" ;
    ns1:textoExtracto "3805 'Velocidad o distancia cero en modo jog incremental' DETECCIÓN Durante un cambio en el avance o en la distancia a recorrer en jog incremental. CAUSA La posición de jog incremental seleccionada desde el conmutador o PLC es cero." .

ns1:Alarma_3806 a ns1:Alarma ;
    rdfs:label "Velocidad de jog incremental mayor que valor máximo" ;
    ns1:identificador "3806" ;
    ns1:textoExtracto "3806 'Velocidad de jog incremental mayor que valor máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad definida en parámetros máquina para jog incremental es mayor que la máxima permitida" .

ns1:Alarma_4000_4 a ns1:Alarma ;
    rdfs:label "Error en la inicialización del anillo Sercos (4000-4)" ;
    ns1:identificador "4000(4)" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4000_4 ;
    ns1:textoExtracto "4000(4) 'Error en la inicialización del anillo Sercos' CAUSA Timeout en el reset de errores tras inicializar el anillo Sercos." .

ns1:Alarma_4024 a ns1:Alarma ;
    rdfs:label "Alarma 4024: Versión no válida del regulador para eje TANDEM"@es ;
    ns1:identificador "4024" ;
    ns1:textoExtracto "4024 Versión no válida del Regulador para eje TANDEM en posición o para REFMODE CNC."@es,
        "CAUSA La versión de un regulador no soporta el tandem con control de par o el modo de referencia CNC."@es,
        "DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset."@es .

ns1:Alarma_6043 a ns1:Alarma ;
    rdfs:label "'Alarma de cable roto'" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:textoExtracto "El lazo ha detectado una alarma genérica de cable roto en la entrada local de captación." .

ns1:Alarma_6044 a ns1:Alarma ;
    rdfs:label "'Alarma de cable roto en señal A'" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje local." .

ns1:Alarma_6045 a ns1:Alarma ;
    rdfs:label "'Alarma de cable roto en señal B'" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal B del contaje local." .

ns1:Alarma_6046 a ns1:Alarma ;
    rdfs:label "'Alarma de cable roto en señal I0'" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal I0 del contaje local." .

ns1:Alarma_6047 a ns1:Alarma ;
    rdfs:label "'Alarma de cable roto en señal AL'" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal AL del contaje local." .

ns1:Alarma_6048 a ns1:Alarma ;
    rdfs:label "'Alarma externa del captador'",
        "Alarma externa del captador" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocalCNC ;
    ns1:identificador "6048" ;
    ns1:textoExtracto "6048 'Alarma externa del captador' DETECCIÓN El lazo ha detectado alarma externa en el contaje local. CAUSA El captador conectado al contaje local reporta alarma. SOLUCIÓN Revisar el captador conectado a la captación local del CNC.",
        "El lazo ha detectado alarma externa en el contaje local." .

ns1:Alarma_8025 a ns1:Alarma ;
    rdfs:label "Alarma 8025: Cambio de fecha detectado"@es ;
    ns1:identificador "8025" ;
    ns1:textoExtracto "'Se ha detectado un cambio de fecha y ha sido necesario restaurarla' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un cambio de fecha u hora y los ha restaurado a sus valores esperados."@es .

ns1:Alarma_8026 a ns1:Alarma ;
    rdfs:label "Alarma 8026: Protección OEM activada"@es ;
    ns1:identificador "8026" ;
    ns1:textoExtracto "'Protección de OEM activada:Los cambios tendrán carácter temporal' DETECCIÓN Durante la edición de programas, programa PLC o parámetros máquina. CAUSA El CNC está en modo usuario, con la protección de OEM activada, por lo que todo cambio tendrá carácter temporal y se perderá al apagar el CNC."@es .

ns1:Alarma_8027 a ns1:Alarma ;
    rdfs:label "Alarma 8027: Error en kernel"@es ;
    ns1:identificador "8027" ;
    ns1:textoExtracto "'Error arrancando Kernel' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel está arrancado pero no está activado."@es .

ns1:Alarma_8028 a ns1:Alarma ;
    rdfs:label "Alarma 8028: Compilador PLC no disponible"@es ;
    ns1:identificador "8028" ;
    ns1:textoExtracto "'Compilador no disponible' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentra instalado el compilador de PLC."@es .

ns1:Alarma_8029 a ns1:Alarma ;
    rdfs:label "Alarma 8029: Includes PLC no disponibles"@es ;
    ns1:identificador "8029" ;
    ns1:textoExtracto "'Includes del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instalados los includes necesarios para compilar el PLC."@es .

ns1:Alarma_8030 a ns1:Alarma ;
    rdfs:label "Alarma 8030: Librerías PLC no disponibles"@es ;
    ns1:identificador "8030" ;
    ns1:textoExtracto "'Librerias del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC."@es .

ns1:Alarma_8037 a ns1:Alarma ;
    rdfs:label "Memoria por debajo del mínimo recomendado. Es necesario reiniciar" ;
    ns1:identificador "8037" ;
    ns1:textoExtracto "8037 'Memoria por debajo del mínimo recomendado. Es necesario reiniciar' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado que la memoria RAM disponible esta por debajo del 10% de la memoria RAM total. SOLUCIÓN Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Alarma_8038 a ns1:Alarma ;
    rdfs:label "No se admite MDI en INSPECCIÓN en el estado actual" ;
    ns1:identificador "8038" ;
    ns1:textoExtracto "8038 'No se admite MDI en INSPECCIÓN en el estado actual' DETECCIÓN Durante la edición y ejecución en modo MDI/MDA. CAUSA No se permite entrar en modo MDI/MDA desde el estado actual de la inspección de herramienta. SOLUCIÓN Salir del modo inspección de herramienta para acceder al modo MDI/MDA." .

ns1:Alarma_8039 a ns1:Alarma ;
    rdfs:label "Error cargando software de teclado" ;
    ns1:identificador "8039" ;
    ns1:textoExtracto "8039 'Error cargando software de teclado' DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga del software del nodo SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Alarma_8040 a ns1:Alarma ;
    rdfs:label "Memoria en disco por debajo del mínimo recomendado para el correcto funcionamiento del CNC" ;
    ns1:identificador "8040" ;
    ns1:textoExtracto "8040 'Memoria en disco por debajo del mínimo recomendado para el correcto funcionamiento del CNC. Libere memoria en disco antes del arranque del CNC' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Hay que liberar memoria en disco para poder arrancar el CNC. • Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. • Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Alarma_8041 a ns1:Alarma ;
    rdfs:label "Memoria por debajo del mínimo recomendado para la ejecución" ;
    ns1:identificador "8041" ;
    ns1:textoExtracto "8041 'Memoria por debajo del mínimo recomendado para la ejecución' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco." .

ns1:Alarma_8045 a ns1:Alarma ;
    rdfs:label "Código de validación temporal expirado"@es ;
    ns1:identificador "8045" ;
    ns1:textoExtracto "que su código de validación temporal ha expirado. El CNC no permitirá la marcha hasta que el usuario haya reiniciado el CNC. SOLUCIÓN Reiniciar el CNC."@es .

ns1:Alarma_8046 a ns1:Alarma ;
    rdfs:label "Código de validación temporal cancelado"@es ;
    ns1:identificador "8046" ;
    ns1:textoExtracto "8046 'El código de validación temporal ha sido cancelado. Reinicie el CNC' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado que el usuario ha cancelado el código de validación temporal. El CNC no permitirá la marcha hasta que el usuario haya reiniciado el CNC. SOLUCIÓN Reinicie el CNC."@es .

ns1:Alarma_8047 a ns1:Alarma ;
    rdfs:label "CNC en modo NO seguro"@es ;
    ns1:identificador "8047" ;
    ns1:textoExtracto "8047 'CNC trabajando en modo NO seguro' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC está trabajando en modo Setup (puesta a punto). SOLUCIÓN Apague el CNC y utilice la utilidad DiskMonitor para pasar a modo Usuario."@es .

ns1:Alarma_8048 a ns1:Alarma ;
    rdfs:label "Puesta a punto incompleta"@es ;
    ns1:identificador "8048" ;
    ns1:textoExtracto "8048 'Puesta a punto incompleta' DETECCIÓN Durante el arranque del CNC. CAUSA Se cumple una de las siguientes condiciones en modo Usuario: • No están definidos los passwords de protección. • No hay copia de seguridad. SOLUCIÓN Para finalizar la puesta a punto, siga los siguientes pasos. 1. Apague el CNC y utilice la utilidad DiskMonitor para pasar al modo Setup (puesta a punto). 2. En el modo utilidades, entre en la ventana de códigos de acceso e introduzca el 'Código de acceso general'. 3. Pulse [ALT][F4] para apagar el CNC y seleccione la opción 'Cerrar y hacer copia de seguridad'. 4. Utilice la utilidad DiskMonitor para pasar a modo Usuario."@es .

ns1:Alarma_8050 a ns1:Alarma ;
    rdfs:label "Error carga software RIOR"@es ;
    ns1:identificador "8050" ;
    ns1:textoExtracto "8050 'Error cargando software de RIOR' DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga del software de los nodos RIOR. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Alarma_8051 a ns1:Alarma ;
    rdfs:label "Error restauración sesión Usuario"@es ;
    ns1:identificador "8051" ;
    ns1:textoExtracto "8051 'Error restaurando sesión de Usuario' DETECCIÓN Durante el arranque del CNC. CAUSA Uno de los archivos de la sesión de usuario no es accesible o está corrupto."@es .

ns1:Alarma_8584 a ns1:Alarma ;
    rdfs:label "Alarma 8584: Programación no permitida con compensación activa"@es ;
    ns1:identificador "8584" ;
    ns1:textoExtracto "8584 Programación no permitida con compensación activa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activa la compensación de radio (G41/G42)."@es .

ns1:Alarma_8585 a ns1:Alarma ;
    rdfs:label "Alarma 8585: Programación no permitida sin movimiento independiente activo"@es ;
    ns1:identificador "8585" ;
    ns1:textoExtracto "8585 Programación no permitida sin movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida"@es .

ns1:Alarma_8792 a ns1:Alarma ;
    rdfs:label "Falta destino en PAR" ;
    ns1:identificador "8792" ;
    ns1:textoExtracto "8792 Falta destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." .

ns1:Alarma_8793 a ns1:Alarma ;
    rdfs:label "Falta origen y destino en PAR" ;
    ns1:identificador "8793" ;
    ns1:textoExtracto "8793 Falta origen y destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta origen y destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." .

ns1:Alarma_8794 a ns1:Alarma ;
    rdfs:label "Cadena de error vacía" ;
    ns1:identificador "8794" ;
    ns1:textoExtracto "8794 Cadena de error vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un error sin texto. SOLUCIÓN Definir el texto de error." .

ns1:Alarma_8795 a ns1:Alarma ;
    rdfs:label "Error sintáctico. No se esperaba %" ;
    ns1:identificador "8795" ;
    ns1:textoExtracto "8795 Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La instrucción programada no admite el" .

ns1:Alarma_9034 a ns1:Alarma ;
    rdfs:label "Alarma 9034: No se puede abrir el fichero de recursos con símbolo"@es ;
    ns1:identificador "9034" ;
    ns1:textoExtracto "9034 No se puede abrir el fichero de recursos con símbolo. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Alarma_9035 a ns1:Alarma ;
    rdfs:label "Alarma 9035: No hay eje físico correspondiente al eje lógico"@es ;
    ns1:identificador "9035" ;
    ns1:textoExtracto "9035 No hay eje físico correspondiente al eje lógico. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa contiene una referencia a un eje que no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_9036 a ns1:Alarma ;
    rdfs:label "Alarma 9036: Símbolo desconocido"@es ;
    ns1:identificador "9036" ;
    ns1:textoExtracto "9036 Símbolo desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa utiliza un símbolo que está definido. SOLUCIÓN Utilizar la directiva DEF o PDEF para definir los símbolos."@es .

ns1:Alarma_9037 a ns1:Alarma ;
    rdfs:label "Alarma 9037: Marca o registro de sistema obsoleto"@es ;
    ns1:identificador "9037" ;
    ns1:textoExtracto "9037 Marca o registro de sistema obsoleto. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Eliminar la marca o registro del programa PLC."@es .

ns1:Alarma_9038 a ns1:Alarma ;
    rdfs:label "Alarma 9038: Marca o registro de sistema obsoleto (usar %)"@es ;
    ns1:identificador "9038" ;
    ns1:textoExtracto "9038 Marca o registro de sistema obsoleto. En su lugar use %. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Utilice la marca la marca o registro sugerida."@es .

ns1:Alarma_9039 a ns1:Alarma ;
    rdfs:label "Alarma 9039: Marca o registro de sistema pendiente de implementar"@es ;
    ns1:identificador "9039" ;
    ns1:textoExtracto "9039 Marca o registro de sistema pendiente de ser implementado. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro todavía no ha sido implementada. SOLUCIÓN No se puede usar la marca o registro."@es .

ns1:Alarma_9040 a ns1:Alarma ;
    rdfs:label "Alarma 9040: Línea de comentarios demasiado larga"@es ;
    ns1:identificador "9040" ;
    ns1:textoExtracto "9040 Linea de comentarios demasiado larga. DETECCIÓN Durante la compilación del programa PLC. CAUSA El comentario es demasiado largo. SOLUCIÓN Escribir un comentario mas corto o dividir el comentario en dos."@es .

ns1:Alarma_9041 a ns1:Alarma ;
    rdfs:label "Alarma 9041: Marca o registro sustituido por %"@es ;
