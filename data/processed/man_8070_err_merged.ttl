    rdfs:label "Error 0152: No se puede abrir el fichero" ;
    ns1:identificador "0152" ;
    ns1:textoExtracto "'No se puede abrir el fichero' DETECCIÓN Al acceder a un archivo. CAUSA No es posible abrir el fichero indicado en la sentencia #OPEN. SOLUCIÓN Comprobar que el fichero existe y que tiene los permisos adecuados. Si en la sentencia #OPEN se ha programado la opción MUTED, la variable G.FILEERRNO indica la causa del error." .

ns1:Error_10 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en lectura de SlaveNr."@es ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Error en lectura de SlaveNr."@es .

ns1:Error_1096 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1096: 'No se admite programar la velocidad con E'" ;
    ns1:identificador "1096" ;
    ns1:textoExtracto "1096 'No se admite programar la velocidad con E' DETECCIÓN Durante la ejecución. CAUSA El avance se ha programado con la función E. SOLUCIÓN Programar el avance con la función F." .

ns1:Error_1097 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1097: 'Nombre de cabezal desconocido'" ;
    ns1:identificador "1097" ;
    ns1:textoExtracto "1097 'Nombre de cabezal desconocido' DETECCIÓN Durante la ejecución. CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal. SOLUCIÓN Los nombres válidos para el cabezal son S, S1, …, S9. El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal. Un canal sólo puede controlar sus cabezales." .

ns1:Error_1098 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1098: 'Velocidad S doblemente programada'" ;
    ns1:identificador "1098" ;
    ns1:textoExtracto "1098 'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución." .

ns1:Error_11 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en lectura de Tatat"@es ;
    ns1:identificador "11" ;
    ns1:textoExtracto "Error en lectura de Tatat."@es .

ns1:Error_1155 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1155: Acceso denegado a fichero" ;
    ns1:identificador "1155" ;
    ns1:solucionaFallo ns1:SolucionParaError1155 ;
    ns1:textoExtracto "No se puede acceder al fichero. DETECCIÓN Durante la ejecución. CAUSA No es posible abrir el fichero programado en la instrucción. La programación del fichero puede ser directa o estar asociado a un elemento del bloque (función G con subrutina asociada)." .

