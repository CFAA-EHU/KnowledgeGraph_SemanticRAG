ns1:AlarmaPOLYDemasiadosEjesProgramados_5dbc72a17f a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Demasiados ejes programados" ;
    ns1:identificador "#POLY" ;
    ns1:monitoreaParametro ns1:NumeroDeEjesEnInterpolacionPolinomica ;
    ns1:textoExtracto "'#POLY: Demasiados ejes programados' DETECCIÓN Durante la ejecución. CAUSA Hay más de tres ejes en el polinomio. SOLUCIÓN En la interpolación polinómica sólo pueden intervenir tres ejes." .

ns1:AlarmaPOLYPuntoInicialNoValido_8bba5a1cc3 a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Punto inicial no válido" ;
    ns1:identificador "#POLY" ;
    ns1:textoExtracto "'#POLY: Punto inicial no válido' DETECCIÓN Durante la ejecución." .

ns1:AlarmaPOLYValorDeParametroNoValido_6974926c9f a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Valor de parámetro no válido" ;
    ns1:identificador "#POLY" ;
    ns1:monitoreaParametro ns1:ParametroDeInterpolacionPolinomica_d6a5597b4f,
        ns1:RadioDeCurvatura_7a7bcd142c ;
    ns1:textoExtracto "'#POLY: Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los parámetros de interpolación del polinomio no son correctos. • El radio de curvatura es menor o igual que cero. SOLUCIÓN Los parámetros de interpolación del polinomio deben ser positivos, el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP) y el radio de curvatura debe ser mayor que cero." .

ns1:AlarmaRPT1508_9179df8c91 a ns1:Alarma ;
    rdfs:label "Alarma RPT 1508" ;
    ns1:activaAlarma ns1:EjeC_8b31d30f41,
        ns1:ModoOperacion_G201 ;
    ns1:identificador "RPT.1508" ;
    ns1:textoExtracto "'No se admiten G201 y eje C activo en los ejes del plano principal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Uno de los ejes implicados en la función G201 es eje C y forma parte de los tres primeros ejes del canal. • Uno de los ejes programados en la sentencia #FACE está en modo manual aditivo, G201. SOLUCIÓN Anular el eje C o el modo manual aditivo." .

ns1:AlarmaRPT1509_9f2b2b2f5c a ns1:Alarma ;
    rdfs:label "Alarma RPT 1509" ;
    ns1:activaAlarma ns1:Sistema_ConfiguracionEjes ;
    ns1:identificador "RPT.1509" ;
    ns1:textoExtracto "'#SET AX/#CALL AX: la programación de offsets no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA Todos los ejes programados en la sentencia pertenecían ya a la configuración actual y por tanto, la sentencia sólo supone un cambio de orden. En este caso la opción de offsets programada no tiene efecto. SOLUCIÓN Revisar la programación." .

ns1:AlarmaRPT1510_3c1f1ddde8 a ns1:Alarma ;
    rdfs:label "Alarma RPT 1510" ;
    ns1:identificador "RPT.1510" ;
    ns1:textoExtracto "'Eje inexistente o no disponible en el canal' DETECCIÓN Durante la ejecución." .

ns1:Alerta_1853 a ns1:AvisoSeguridad ;
    rdfs:label "No se ha recibido señal del palpador"@es ;
    ns1:identificador "1853" ;
    ns1:solucionaFallo ns1:Palpador ;
    ns1:textoExtracto "1853 'No se ha recibido señal del palpador' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación."@es .

ns1:Alerta_1854 a ns1:AvisoSeguridad ;
    rdfs:label "El diámetro J debe ser mayor que cero"@es ;
    ns1:identificador "1854" ;
    ns1:monitoreaParametro ns1:ParametroJFuncionG30G73_6fb2658b72 ;
    ns1:textoExtracto "1854 'El diámetro J debe ser mayor que cero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro J (diámetro teórico del agujero) tiene un valor incorrecto."@es .

ns1:Alerta_1855 a ns1:AvisoSeguridad ;
    rdfs:label "Diámetro de herramienta mayor que el del agujero"@es ;
    ns1:identificador "1855" ;
    ns1:monitoreaParametro ns1:ParametroJFuncionG30G73_6fb2658b72 ;
    ns1:textoExtracto "1855 'Diámetro de herramienta mayor que el del agujero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El diámetro del palpador es mayor que el diámetro del agujero a medir o que el agujero utilizado para calibrar el palpador."@es .

ns1:Alerta_1856 a ns1:AvisoSeguridad ;
    rdfs:label "Distancia de retroceso E incorrecta"@es ;
    ns1:identificador "1856" ;
    ns1:monitoreaParametro ns1:ParametroE_7654d5a0eb ;
    ns1:textoExtracto "1856 'Distancia de retroceso E incorrecta' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro E (distancia de retroceso) tiene un valor incorrecto."@es .

ns1:Alerta_1857 a ns1:AvisoSeguridad ;
    rdfs:label "No hay corrector seleccionado"@es ;
    ns1:identificador "1857" ;
    ns1:monitoreaParametro ns1:CorrectorHerramienta ;
    ns1:textoExtracto "1857 'No hay corrector seleccionado' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 1 o #PROBE 2. CAUSA No hay corrector de herramienta activo para el ciclo de calibración de herramienta."@es .

ns1:AlgunasFuncionesIncompatiblesSonG74G198G199LINKCiclosDePalpadoEtc a ns1:ModoOperacion ;
    ns1:textoExtracto "Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc." .

ns1: a ns1:ModoOperacion ;
    ns1:textoExtracto "Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc. SOLUCIÓN Desactivar la transformación de coordenadas para poder ejecutar el resto de funciones. 1265 'Programación no permitida con RTCP/TLC activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la función RTCP o TLC. Algunas funciones incompatibles son G74, G198, G199, #KIN ID. LINK. SOLUCIÓN Desactivar la función RTCP o TLC para poder ejecutar el resto de funciones. 1266 'La funcionalidad TLC se desactiva con la sentencia #TLC OFF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar la función TLC mientras estaba activa. SOLUCIÓN El CNC no permite modificar la función TLC mientras está activa. Para modificar la función TLC, hay que desactivarla y volverla a activar. 1267 'La funcionalidad RTCP se desactiva con la sentencia #RTCP OFF' DETECCIÓN Durante la ejecución. CAUSA Con el RTCP activo, hay programada una sentencia #RTCP diferente a #RTCPOFF. SOLUCIÓN Para desactivar la función RTCP programar #RTCPOFF. Si se desea modificar los valores del RTCP, hay que desactivarla primero." .

ns1: a ns1:ModoOperacion ;
    ns1:textoExtracto "Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc. SOLUCIÓN Desactivar la transformación de coordenadas para poder ejecutar el resto de funciones. 1265 'Programación no permitida con RTCP/TLC activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la función RTCP o TLC. Algunas funciones incompatibles son G74, G198, G199, #KIN ID. LINK. SOLUCIÓN Desactivar la función RTCP o TLC para poder ejecutar el resto de funciones. 1266 'La funcionalidad TLC se desactiva con la sentencia #TLC OFF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar la función TLC mientras estaba activa. SOLUCIÓN El CNC no permite modificar la función TLC mientras está activa. Para modificar la función TLC, hay que desactivarla y volverla a activar. 1267 'La funcionalidad RTCP se desactiva con la sentencia #RTCP OFF' DETECCIÓN Durante la ejecución. CAUSA Con el RTCP activo, hay programada una sentencia #RTCP diferente a #RTCPOFF. SOLUCIÓN Para desactivar la función RTCP programar #RTCPOFF. Si se desea modificar los valores del RTCP, hay que desactivarla primero. 1270 'Cálculo de la transformación de coordenadas imposible' DETECCIÓN Durante la ejecución. CAUSA El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés. SOLUCIÓN Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación." .

