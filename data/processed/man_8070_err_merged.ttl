ns1:Error_5025 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5025: Contador de PLC deshabilitado" ;
    ns1:identificador "5025" ;
    ns1:solucionaFallo ns1:RevisionDeManiobraDelPLCParaEvitarPeticionesAsincronas ;
    ns1:textoExtracto "5025 'Contador de PLC deshabilitado' DETECCIÓN Durante el arranque del CNC. CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización." .

ns1:Error_5026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5026: Variable CNCWR con valor no permitido"@es ;
    ns1:identificador "5026" ;
    ns1:textoExtracto "'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable que sólo admite valor 0 (cero). SOLUCIÓN Revisar el programa de PLC. Escribir el valor 0 en la variable o eliminar el comando CNCWR."@es .

ns1:Error_5027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5027: Cortocircuito en salida analógica local"@es ;
    ns1:activaAlarma ns1:AlarmaDeSobrecorrienteEnSalidaAnalogicaLocal_a228bc71d5 ;
    ns1:identificador "5027" ;
    ns1:textoExtracto "'Cortocircuito en salida analógica local (report desde PLC)' DETECCIÓN El PLC ha detectado una alarma de sobrecorriente a la hora de escribir la salida analógica local. CAUSA Cortocircuito en la salida analógica local del CNC. SOLUCIÓN Revisar el conexionado de la salida analógica del CNC."@es .

ns1:Error_5028 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5028: Fallo en recurso remoto (lectura)"@es ;
    ns1:identificador "5028" ;
    ns1:textoExtracto "Error en un recurso remoto. DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de leer datos. SOLUCIÓN Revisar el conexionado de los módulos remotos."@es .

ns1:Error_5029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5029: Fallo en recurso remoto (escritura)"@es ;
    ns1:identificador "5029" ;
    ns1:textoExtracto "Error en un recurso remoto. DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de escribir datos. SOLUCIÓN Revisar el conexionado de los módulos remotos."@es .

ns1:Error_5030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5030: Configuración incorrecta de recursos remotos"@es ;
    ns1:identificador "5030" ;
    ns1:textoExtracto "Error al configurar los recursos remotos. DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos. SOLUCIÓN Revisar la configuración de los módulos remotos."@es .

ns1:Error_5031 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5031: Error interno en configuración de recursos remotos"@es ;
    ns1:identificador "5031" ;
    ns1:textoExtracto "Error interno al configurar los recursos remotos. DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos. SOLUCIÓN Revisar la configuración de los módulos remotos."@es .

ns1:Error_5032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5032: Orden incorrecto en comandos de router de recursos"@es ;
    ns1:identificador "5032" ;
    ns1:textoExtracto "Error en el orden de los comandos de configuración del router de recursos remotos. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos."@es .

