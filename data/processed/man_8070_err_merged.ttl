ns1:Error2513ORBITONYaActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2513: #ORBIT ON ya activo"@es ;
    ns1:identificador "2513" ;
    ns1:solucionaFallo ns1:Solucion_DesactivarORBIT_2513 ;
    ns1:textoExtracto "2513 #ORBIT ON ya activo. [...] SOLUCIÓN Para modificar algún parámetro de la sentencia #ORBIT, es necesario desactivarla primero."@es .

ns1:Error2514MovimientoG0ConORBITActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2514: Movimiento G0 con #ORBIT activo"@es ;
    ns1:identificador "2514" ;
    ns1:solucionaFallo ns1:Solucion_EliminarG0_2514 ;
    ns1:textoExtracto "2514 #ORBIT ON: movimiento en G0 no permitido. [...] SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT."@es .

ns1:Error3027TransformadaInversaDeRTCP a ns1:DiagnosticoFallo ;
