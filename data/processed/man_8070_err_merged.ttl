ns1:Error_80035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 80035: Parámetro Z no permitido" ;
    ns1:identificador "80035" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Uso no permitido del parámetro Z en subrutina" ;
            ns1:textoExtracto "En la subrutina indicada, no está permitido el parámetro Z." ] ;
    ns1:textoExtracto "G%D Z%D: Parámetro Z no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro Z. SOLUCIÓN Revisar la programación." .

ns1:Error_80036 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 80036: Parámetros A..Z no permitidos" ;
    ns1:identificador "80036" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Uso no permitido de parámetros A..Z en subrutina" ;
            ns1:textoExtracto "En la subrutina indicada, no está permitido algún parámetro." ] ;
    ns1:textoExtracto "G%D uno o varios parámetros A..Z no permitidos. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido algún parámetro. SOLUCIÓN Revisar la programación." .

ns1:Error_8004 a ns1:AvisoSeguridad ;
    rdfs:label "Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido" ;
    ns1:activaAlarma ns1:CNC ;
    ns1:identificador "8004" ;
    ns1:textoExtracto "8004 'Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si algún canal se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control. SOLUCIÓN Detener los programas en ejecución." .

ns1:Error_8005 a ns1:AvisoSeguridad ;
    rdfs:label "Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución" ;
    ns1:activaAlarma ns1:CNC ;
    ns1:identificador "8005" ;
    ns1:textoExtracto "8005 'Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución' DETECCIÓN Durante la ejecución. CAUSA No está permitido cambiar de modo si algún canal del grupo se encuentra en ejecución. SOLUCIÓN Detener los programas en ejecución de todos los canales del grupo." .

ns1:Error_8006 a ns1:AvisoSeguridad ;
    rdfs:label "Error iniciando proceso de carga" ;
    ns1:activaAlarma ns1:CNC ;
    ns1:identificador "8006" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Detener programas en ejecución" ;
