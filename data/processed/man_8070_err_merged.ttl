    ns1:activaAlarma ns1:ModoOperacion_CicloMecanizadoMultiple ;
    ns1:identificador "1820" ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados)."@es .

ns1:Alarma_1821 a ns1:Alarma ;
