ns1:Alarma_2333 a ns1:Alarma ;
    rdfs:label "Alarma 2333: 'Programación no permitida fuera de una macro G8736'" ;
    ns1:identificador "2333" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2333 ;
    ns1:textoExtracto "2333 'Programación no permitida fuera de una macro G8736' [...] SOLUCIÓN Revisar la programación. Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." .

ns1:Alarma_2335 a ns1:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8725" ;
    ns1:identificador "2335" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8724 programada fuera de una macro G8725. SOLUCIÓN Revisar la programación. La función G8724 se debe programar a continuación de la macro G8725." .

ns1:Alarma_2336 a ns1:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8726" ;
    ns1:identificador "2336" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8727 o G8728 programada fuera de una macro G8726. SOLUCIÓN Revisar la programación. Las funciones G8727 o G8728 se deben programar a continuación de la macro G8726." .

ns1:Alarma_2337 a ns1:Alarma ;
    rdfs:label "Programación PROGTL3 no permitida en un perfil ISO" ;
    ns1:identificador "2337" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El perfil de la macro está escrito en dos lenguajes, ProGTL3 e ISO. SOLUCIÓN Los perfiles de las macros se pueden definir en lenguaje ProGTL3 o ISO, pero no se permite mezclar ambos en un mismo perfil." .

ns1:Alarma_2338 a ns1:Alarma ;
    rdfs:label "No se admite programar sección H" ;
    ns1:identificador "2338" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Sólo se permite programar H en los bloques del perfil plano definido en G8736 o como parámetro de G8737. SOLUCIÓN Revisar la programación. No programar H en otros bloques." .

ns1:Alarma_2339 a ns1:Alarma ;
    rdfs:label "No es compatible la compensación de radio activa y la 3D" ;
    ns1:identificador "2339" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa. SOLUCIÓN Revisar la programación. Ambos tipos de compensación son incompatibles." .

ns1:Alarma_2341 a ns1:Alarma ;
    rdfs:label "Programación de vector incorrecta" ;
    ns1:identificador "2341" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_Compensacion3D_VectorIncompleto ;
    ns1:textoExtracto "2341 'Programación de vector incorrecta' [...] SOLUCIÓN Revisar la programación. Programar las tres componentes del vector." .

ns1:Alarma_2342 a ns1:Alarma ;
    rdfs:label "Es necesario programar el vector N[-,-,-] para la compensación 3D" ;
    ns1:identificador "2342" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_Compensacion3D_VectorFaltante ;
    ns1:textoExtracto "2342 'Es necesario programar el vector N[-,-,-] para la compensación 3D' [...] SOLUCIÓN Revisar la programación. Con la compensación de herramienta 3D activa, es obligatorio programar un vector en cada bloque de movimiento." .

ns1:Alarma_2343 a ns1:Alarma ;
    rdfs:label "Herramienta activa no adecuada para compensación 3D" ;
    ns1:identificador "2343" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_Compensacion3D_HerramientaInvalida ;
    ns1:textoExtracto "2343 'Herramienta activa no adecuada para compensación 3D' [...] SOLUCIÓN La compensación de herramienta 3D en modo 'NORMAL' sólo admite herramientas de fresado planas, tóricas o esféricas." .

ns1:Alarma_2344 a ns1:Alarma ;
    rdfs:label "Programar #COMP3D ON/OFF [PARAX/NORMAL]" ;
    ns1:identificador "2344" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_Compensacion3D_SintaxisIncorrecta ;
    ns1:textoExtracto "2344 'Programar #COMP3D ON/OFF [PARAX/NORMAL]' [...] SOLUCIÓN Revisar la programación." .

ns1:Alarma_2345 a ns1:Alarma ;
    rdfs:label "Perfil doblemente definido" ;
    ns1:identificador "2345" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_PerfilDuplicado ;
    ns1:textoExtracto "2345 'Perfil doblemente definido' [...] SOLUCIÓN Revisar la programación. Definir un único perfil." .

ns1:Alarma_2346 a ns1:Alarma ;
    rdfs:label "Superado el máximo de bloques para la visualización 2D" ;
    ns1:identificador "2346" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_Visualizacion2D_ExcesoBloques ;
    ns1:textoExtracto "2346 'Superado el máximo de bloques para la visualización 2D' [...] SOLUCIÓN Modificar el programa o visualizarlo por partes." .

ns1:Alarma_2347 a ns1:Alarma ;
    rdfs:label "No se admite perfil PROGTL3 con G91 activa" ;
    ns1:identificador "2347" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_ConfiguracionPerfilInvalida ;
    ns1:textoExtracto "2347 'No se admite perfil PROGTL3 con G91 activa' [...]" .

ns1:Alarma_2370 a ns1:Alarma ;
    rdfs:label "Alarma 2370: Eje para roscar inexistente" ;
    ns1:identificador "2370" ;
    ns1:textoExtracto "de husillo en G34 2370 Eje para roscar inexistente. DETECCIÓN Durante la ejecución. CAUSA El eje de roscado viene definido por la letra con la que se programa el paso de husillo en el bloque. El eje programado no existe. SOLUCIÓN Programar el paso de husillo en un eje válido." .

ns1:Alarma_2377 a ns1:Alarma ;
    rdfs:label "#LSFIT, la instrucción no es válida" ;
    ns1:identificador "2377" ;
    ns1:textoExtracto "2377 #LSFIT, la instrucción no es válida. DETECCIÓN Durante la ejecución. CAUSA La sentencia #LSFIT no se ha programado correctamente. SOLUCIÓN Revisar la programación." .

ns1:Alarma_2378 a ns1:Alarma ;
    rdfs:label "#GAPCTRL: Falta programar el eje o el GAP" ;
    ns1:identificador "2378" ;
    ns1:textoExtracto "2378 #GAPCTRL: Falta programar el eje o el GAP. DETECCIÓN Durante la ejecución. CAUSA En el comando #GAPCTRL no se ha programado el eje o la distancia (gap). SOLUCIÓN Programar el eje y/o el GAP." .

ns1:Alarma_2379 a ns1:Alarma ;
    rdfs:label "#GAPCTRL: Parámetro máquina GAPANAINID nulo o sin asignar" ;
    ns1:activaAlarma ns1:Sensor_GAP ;
    ns1:identificador "2379" ;
    ns1:textoExtracto "2379 #GAPCTRL: Parámetro máquina GAPANAINID nulo o sin asignar. DETECCIÓN Durante la ejecución. CAUSA No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID). SOLUCIÓN Asignar el valor correcto al parámetro máquina GAPANAINID." .

ns1:Alarma_2380 a ns1:Alarma ;
    rdfs:label "#LSFIT, error interno" ;
    ns1:identificador "2380" ;
    ns1:textoExtracto "2380 #LSFIT, error interno. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. Datos incoherentes en el ciclo. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Alarma_2381 a ns1:Alarma ;
    rdfs:label "#ABORT OFF no programado en la misma subrutina que #ABORT" ;
    ns1:identificador "2381" ;
    ns1:textoExtracto "2381 #ABORT OFF no programado en la misma subrutina que #ABORT. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el comando #ABORT OFF. Si se programa el comando #ABORT solo en el bloque, al abortar el programa la ejecución continúa en el comando #ABORT OFF. SOLUCIÓN Programar #ABORT OFF." .

ns1:Alarma_2382 a ns1:Alarma ;
    rdfs:label "#ISO ON[]. Sintaxis incorrecta" ;
    ns1:identificador "2382" ;
    ns1:textoExtracto "2382 #ISO ON[]. Sintaxis incorrecta. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Alarma_2383 a ns1:Alarma ;
    rdfs:label "#ISO ON[]. Nombre de fichero no válido" ;
    ns1:identificador "2383" ;
    ns1:textoExtracto "2383 #ISO ON[]. Nombre de fichero no valido. DETECCIÓN Durante la ejecución." .

ns1:Alarma_2384 a ns1:Alarma ;
    rdfs:label "Alarma 2384: Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque"@es ;
    ns1:identificador "2384" ;
    ns1:textoExtracto "2384 Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque. DETECCIÓN Durante la ejecución. CAUSA Hay programada una llamada a subrutina y un ciclo modal en el mismo bloque, o se ha intentado ejecutar un ciclo fijo dentro durante la ejecución de otro ciclo fijo. SOLUCIÓN Revisar programación. Anular el ciclo modal o programar la llamada a subrutina en un bloque posterior. No es posible ejecutar un ciclo fijo dentro de otro ciclo fijo."@es .

ns1:Alarma_2385 a ns1:Alarma ;
    rdfs:label "Alarma 2385: Zona de trabajo no programada"@es ;
    ns1:identificador "2385" ;
    ns1:textoExtracto "2385 Zona de trabajo no programada. DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el número de zona en G120/G121/G122/G123. SOLUCIÓN Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es .

ns1:Alarma_2386 a ns1:Alarma ;
    rdfs:label "Alarma 2386: Zona de trabajo inexistente"@es ;
    ns1:identificador "2386" ;
    ns1:textoExtracto "2386 Zona de trabajo inexistente. DETECCIÓN Durante la preparación de bloques. CAUSA El número de zona programado en G120/G121/G122/G123 no tiene un valor correcto. SOLUCIÓN Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es .

ns1:Alarma_2387 a ns1:Alarma ;
    rdfs:label "Alarma 2387: Vigilancia de herramienta no válida en zona de trabajo"@es ;
    ns1:identificador "2387" ;
    ns1:textoExtracto "2387 Vigilancia de herramienta no válida en zona de trabajo. DETECCIÓN Durante la preparación de bloques. CAUSA La vigilancia de herramienta en la zona de trabajo no tiene un valor correcto. Existen dos posibilidades. • El valor programado en G122 no es correcto. • El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto. SOLUCIÓN Programar un valor correcto para la vigilancia de herramienta; de 0 a 2. • En el primer caso, programar un valor correcto en el parámetro \"I\" de la función G122. • En el segundo caso, escribir desde el PLC el valor correcto en la variable \"G.ZONETOOLWATCH[zone]\". "@es .

ns1:Alarma_2393 a ns1:Alarma ;
    rdfs:label "Función E doblemente programada" ;
    ns1:identificador "2393" ;
    ns1:textoExtracto "2393 'Función E doblemente programada' DETECCIÓN Durante la preparación de bloques. CAUSA El parámetro \"E\" está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro \"E\" una sola vez en el bloque." .

ns1:Alarma_2394 a ns1:Alarma ;
    rdfs:label "Estado de la zona de trabajo no programado" ;
    ns1:identificador "2394" ;
    ns1:textoExtracto "2394 Estado de la zona de trabajo no programado. DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el estado de la zona de trabajo en" .

ns1:Alarma_2400 a ns1:Alarma ;
    rdfs:label "Número lógico de eje fuera de rango"@es ;
    ns1:identificador "2400" ;
    ns1:textoExtracto "2400 Número lógico de eje fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número lógico programado en la variable no es correcto. SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)."@es .

ns1:Alarma_24001 a ns1:Alarma ;
    rdfs:label "EtherCAT: Datalink no presente" ;
    ns1:identificador "24001" ;
    ns1:monitoreaParametro ns1:Parametro_EtherCAT_Datalink ;
    ns1:textoExtracto "24001 EtherCAT: Datalink no presente. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El cable EtherCAT está desconectado. SOLUCIÓN Conectar el cable de EtherCAT." .

ns1:Alarma_24002 a ns1:Alarma ;
    rdfs:label "EtherCAT: Paquete perdido" ;
    ns1:identificador "24002" ;
    ns1:monitoreaParametro ns1:Parametro_EtherCAT_Paquete ;
    ns1:textoExtracto "24002 EtherCAT: Paquete perdido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o algún esclavo no funciona correctamente. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Alarma_24003 a ns1:Alarma ;
    rdfs:label "EtherCAT: CRC Incorrecto" ;
    ns1:identificador "24003" ;
    ns1:monitoreaParametro ns1:Parametro_EtherCAT_CRC ;
    ns1:textoExtracto "24003 EtherCAT: CRC Incorrecto. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o hay interferencias en el bus. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Alarma_24004 a ns1:Alarma ;
    rdfs:label "EtherCAT: Working Counter error" ;
    ns1:identificador "24004" ;
    ns1:monitoreaParametro ns1:Parametro_EtherCAT_WorkingCounter ;
    ns1:textoExtracto "24004 EtherCAT: Working Counter error. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Funcionamiento incorrecto de alguno de los esclavos de EtherCAT. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Alarma_2401 a ns1:Alarma ;
    rdfs:label "'#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa'"@es ;
    ns1:identificador "2401" ;
    ns1:textoExtracto "2401 '#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa."@es .

ns1:Alarma_24010 a ns1:Alarma ;
    rdfs:label "EtherCAT: Fichero ENI de configuración no existe" ;
    ns1:identificador "24010" ;
    ns1:textoExtracto "24010 EtherCAT: Fichero ENI de configuración no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero ENI de configuración de la red EtherCAT. SOLUCIÓN Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT. El archivo se debe llamar fagor_ethercatConfFile.xml" .

ns1:Alarma_24011 a ns1:Alarma ;
    rdfs:label "EtherCAT: Formato de fichero ENI de configuración incorrecto" ;
    ns1:identificador "24011" ;
    ns1:textoExtracto "24011 EtherCAT: Formato de fichero ENI de configuración incorrecto. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero ENI de configuración de la red EtherCAT tiene un formato ilegible para el CNC. El configurador que ha generado el fichero ENI puede no ser compatible con el CNC. El fichero puede estar incompleto o corrupto. SOLUCIÓN Revisar el fichero." .

ns1:Alarma_2402 a ns1:Alarma ;
    rdfs:label "#PARK: No se permite aparcar un eje que define una zona de trabajo activa"@es ;
    ns1:identificador "2402" ;
    ns1:textoExtracto """\r
    DETECCIÓN Durante la preparación de bloques.\r
    CAUSA El CNC ha intentado aparcar un eje que forma parte de una zona de trabajo activa.\r
    SOLUCIÓN Desactivar la zona de trabajo antes de aparcar el eje.\r
    """@es .

ns1:Alarma_24020 a ns1:Alarma ;
    rdfs:label "EtherCAT: Fichero de rutado no existe" ;
    ns1:identificador "24020" ;
    ns1:textoExtracto "24020 EtherCAT: Fichero de rutado no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor." .

ns1:Alarma_2403 a ns1:Alarma ;
    rdfs:label "No se permite activar una zona con uno de sus ejes aparcado"@es ;
    ns1:identificador "2403" ;
    ns1:textoExtracto """\r
    DETECCIÓN Durante la preparación de bloques.\r
    CAUSA El CNC ha intentado activar una zona de trabajo, pero uno de los ejes que la definen está aparcado.\r
    SOLUCIÓN Desaparcar el eje antes de activar la zona de trabajo.\r
    """@es .

ns1:Alarma_2405 a ns1:Alarma ;
    rdfs:label "Bloque de movimiento anulado por tener un eje con #GAPCTRL"@es ;
    ns1:identificador "2405" ;
    ns1:textoExtracto """\r
    DETECCIÓN Durante la inspección de herramienta o modo MDI.\r
    CAUSA Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL.\r
    SOLUCIÓN Programar #GAPCTRL OFF.\r
    """@es .

ns1:Alarma_2406 a ns1:Alarma ;
    rdfs:label "#LEAP con #GAPCTRL ON: El salto debe empezar y acabar en la misma cota"@es ;
    ns1:identificador "2406" ;
    ns1:textoExtracto "#LEAP con #GAPCTRL ON: El salto debe empezar y acabar en la misma cota."@es .

ns1:Alarma_2410 a ns1:Alarma ;
    rdfs:label "Alarma 2410: Sintaxis incorrecta en #PWRCTRL"@es ;
    ns1:identificador "2410" ;
    ns1:textoExtracto "2410 #PWRCTRL ON/OFF [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Alarma_2417 a ns1:Alarma ;
    rdfs:label "Alarma 2417: #PWRCTRL ON - FZMIN > FZMAX" ;
    ns1:identificador "2417" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN ;
    ns1:textoExtracto "2417 #PWRCTRL ON: FMIN debe ser menor que FMAX. [...] En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo." .

ns1:Alarma_2432 a ns1:Alarma ;
    rdfs:label "Alarma 2432: #DMCON - Programación no permitida con cabezal analógico" ;
    ns1:activaAlarma ns1:Sistema_DMC ;
    ns1:identificador "2432" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el DMC sobre un cabezal analógico. SOLUCIÓN El DMC sólo se puede activar sobre cabezales digitales." .

ns1:Alarma_2433 a ns1:Alarma ;
    rdfs:label "Alarma 2433: Programación obligatoria de ON/OFF en #DMC" ;
    ns1:identificador "2433" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta programar el comando ON/OFF para activar o anular la función. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Incluir el comando ON para activar la función (por ejemplo, #DMCON [...]) o el comando OFF para anularla (por ejemplo, #DMC OFF)." .

ns1:Alarma_2434 a ns1:Alarma ;
    rdfs:label "Alarma 2434: Programación no permitida fuera de macro G8077" ;
    ns1:identificador "2434" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8078 programada fuera de una macro G8077. SOLUCIÓN Revisar la programación. Las funciones G8078 se deben programar a continuación de la macro G8077." .

ns1:Alarma_2435 a ns1:Alarma ;
    rdfs:label "Alarma 2435: Programación no permitida fuera de macro G8079" ;
    ns1:identificador "2435" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8078 programada fuera de una macro G8079. SOLUCIÓN Revisar la programación. Las funciones G8078 se deben programar a continuación de la macro G8079." .

ns1:Alarma_2453 a ns1:Alarma ;
    rdfs:label "Alarma 2453: Falta carácter de cierre '}' en programación de vector"@es ;
    ns1:identificador "2453" ;
    ns1:textoExtracto "2453 Se espera \"}\", programación de fin de vector. DETECCIÓN Durante la preparación de bloques. CAUSA Falta el carácter de cierre \"}\" en la programa de un vector. SOLUCIÓN Revisar la programación. Programar el vector de la forma V{i, j, k}."@es .

ns1:Alarma_2454 a ns1:Alarma ;
    rdfs:label "Alarma 2454: Memoria insuficiente para variables de calibración de cinemáticas"@es ;
    ns1:identificador "2454" ;
    ns1:textoExtracto "2454 No hay memoria para variables de usuario asociadas a la calibración de cinemáticas. DETECCIÓN Durante la preparación de bloques. CAUSA Las variables de usuario asociadas a la calibración de cinemáticas sólo existen si está activa la opción de software \"Calibración de cinemáticas\". SOLUCIÓN Contratar la correspondiente opción de software."@es .

ns1:Alarma_2455 a ns1:Alarma ;
    rdfs:label "Alarma 2455: Error en gestión del árbol de variables"@es ;
    ns1:identificador "2455" ;
    ns1:textoExtracto "2455 Error en la gestión del árbol de variables. DETECCIÓN Durante la preparación de bloques. CAUSA Error al crear una nueva variable de usuario. SOLUCIÓN Contacte con Fagor Automation."@es .

ns1:Alarma_2462 a ns1:Alarma ;
    rdfs:label "Alarma 2462: Eje fuera de plano o triedro" ;
    ns1:identificador "2462" ;
    ns1:textoExtracto "El eje programado debe pertenecer al plano o triedro. DETECCIÓN Durante la ejecución. CAUSA El eje no pertenece al plano principal o triedro. SOLUCIÓN Revisar la programación." .

ns1:Alarma_2463 a ns1:Alarma ;
    rdfs:label "Alarma 2463: Incompatibilidad entre #LEAP y GAP3D" ;
    ns1:identificador "2463" ;
    ns1:textoExtracto "#LEAP incompatible con GAP3D. DETECCIÓN Durante la ejecución." .

ns1:Alarma_2469 a ns1:Alarma ;
    rdfs:label "Alarma 2469: Programación HEAD no permitida"@es ;
    ns1:identificador "2469" ;
    ns1:textoExtracto "2469 Programación HEAD no permitida en cinemáticas sin cabezal. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_2470 a ns1:Alarma ;
    rdfs:label "Alarma 2470: Programación TABLE o COROT no permitida"@es ;
    ns1:identificador "2470" ;
    ns1:textoExtracto "2470 Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución. CAUSA Se ha"@es,
        "Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción TABLE o COROT para una cinemática sin mesa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_2471 a ns1:Alarma ;
    rdfs:label "Alarma 2471: Fichero de material o tabla no programados"@es ;
    ns1:identificador "2471" ;
    ns1:textoExtracto "Es obligatorio programar el nombre del fichero de material y/o la tabla seleccionada. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material ni la tabla seleccionada. SOLUCIÓN Revisar la programación. Tanto el fichero de material como la tabla tecnológica son opcionales, pero hay que programar uno de ellos."@es .

ns1:Alarma_2472 a ns1:Alarma ;
    rdfs:label "Alarma 2472: Fichero de material inactivo"@es ;
    ns1:identificador "2472" ;
    ns1:textoExtracto "No hay fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material, y no hay ninguno activo. SOLUCIÓN Activar un fichero de material. La programación del fichero de material sólo es opcional cuando hay uno activo."@es .

ns1:Alarma_2473 a ns1:Alarma ;
    rdfs:label "Alarma 2473: Número de set fuera de rango"@es ;
    ns1:identificador "2473" ;
    ns1:textoExtracto "Número de set fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número de set (grupo de parámetros) programado en la sentencia #TECHTABLE no es válido o no existe. SOLUCIÓN Revisar la programación. Comprobar que el grupo de parámetros programado existe en la tabla. El rango válido es 1..256."@es .

ns1:Alarma_2474 a ns1:Alarma ;
    rdfs:label "Alarma 2474: Variable Piercing no disponible"@es ;
    ns1:identificador "2474" ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Piercing. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTPIR.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Piercing. SOLUCIÓN Activar un fichero de material que tenga una tabla de Piercing."@es .

ns1:Alarma_2475 a ns1:Alarma ;
    rdfs:label "Alarma 2475: Variable Cutting no disponible"@es ;
    ns1:identificador "2475" ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting."@es .

ns1:Alarma_2509 a ns1:Alarma ;
    rdfs:label "Alarma 2509: Sintaxis #ORBIT incorrecta"@es ;
    ns1:identificador "2509" ;
    ns1:textoExtracto "2509 #ORBIT ON[Rvalor, Jvalor ,Kvalor]."@es .

ns1:Alarma_3008 a ns1:Alarma ;
    rdfs:label "Alarma 3008: Error en proceso de palpador" ;
    ns1:identificador "3008" ;
    ns1:textoExtracto "'Error en el proceso de palpador' DETECCIÓN Tras detectar la señal de palpador. CAUSA Es una seguridad de habilitación del proceso de palpado. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados." .

ns1:Alarma_3010 a ns1:Alarma ;
    rdfs:label "Alarma 3010: Eje no definido como palpador" ;
    ns1:identificador "3010" ;
    ns1:textoExtracto "'El eje no se ha definido como palpador (PROBEAXIS)' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de palpado en un eje que no está definido como eje participante en un movimiento con palpador. SOLUCIÓN El parámetro PROBEAXIS establece si el eje puede participar en movimientos con palpador." .

ns1:Alarma_3011 a ns1:Alarma ;
    rdfs:label "Alarma 3011: Exceso de ejes programados como palpador" ;
    ns1:identificador "3011" ;
    ns1:textoExtracto "'Demasiados ejes programados como palpador' DETECCIÓN Durante la ejecución. CAUSA El número de ejes programados en el movimiento de palpación supera el máximo de ejes del canal. SOLUCIÓN Corregir la programación del bloque de palpado." .

ns1:Alarma_3015 a ns1:Alarma ;
    rdfs:label "Alarma 3015: Búsqueda de referencia omitida" ;
    ns1:identificador "3015" ;
    ns1:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida' DETECCIÓN Durante la ejecución." .

ns1:Alarma_3044 a ns1:Alarma ;
    rdfs:label "No se permite búsqueda de cero de un eje activo como eje independiente"@es ;
    ns1:identificador "3044" ;
    ns1:textoExtracto "3044 'No se permite búsqueda de cero de un eje activo como eje independiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta realizar la búsqueda de referencia de un eje independiente. SOLUCIÓN Si el eje tiene pendiente algún movimiento independiente, esperar a que termine o abortar el movimiento desde el PLC (marca IABORT) o con reset en el canal. Si el eje está sincronizado, anular la sincronización o realizar un reset en el canal."@es .

ns1:Alarma_3045 a ns1:Alarma ;
    rdfs:label "No se admite M6"@es ;
    ns1:identificador "3045" ;
    ns1:textoExtracto "3045 'No se admite M6' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M6 no permitida. SOLUCIÓN El cambio de herramienta no permite continuar la ejecución del programa interrumpido. Pulsar reset y ejecutar M6 desde el modo MDI."@es .

ns1:Alarma_3046 a ns1:Alarma ;
    rdfs:label "El cabezal asociado no pertenece al canal"@es ;
    ns1:identificador "3046" ;
    ns1:textoExtracto "3046 'El cabezal asociado no pertenece al canal' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M o una S referida a un cabezal que no existe en el canal o en el sistema. SOLUCIÓN Asociar la función al cabezal correcto. Acceder al cabezal desde el canal en el que se encuentra."@es .

ns1:Alarma_3047 a ns1:Alarma ;
    rdfs:label "No se admite M3/M4/M5/M19/M41-M44 con G63 activa"@es ;
    ns1:identificador "3047" ;
    ns1:textoExtracto "3047 'No se admite M3/M4/M5/M19/M41-M44 con G63 activa' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Alarma_3058 a ns1:Alarma ;
    rdfs:label "Alarma 3058: Funciones M3/M4/M5/M19 y M41-M44 no enviadas al PLC"@es ;
    ns1:identificador "3058" ;
    ns1:textoExtracto "'Las funciones M3/M4/M5/M19 y M41-M44 del cabezal deben ser enviadas al PLC' DETECCIÓN Durante la ejecución. CAUSA Tras una búsqueda de bloque y antes de continuar con la ejecución del programa, el CNC ha detectado que alguna función del cabezal no ha sido enviada al PLC. SOLUCIÓN Con el programa interrumpido, cambiar al modo MHFS y enviar las funciones necesarias al PLC."@es .

ns1:Alarma_3059 a ns1:Alarma ;
    rdfs:label "Alarma 3059: Incompatibilidad de funciones M3/M4/M5/M19/M41-M44 con M19 o G74"@es ;
    ns1:identificador "3059" ;
    ns1:textoExtracto "'No se admite M3/M4/M5/M19/M41-M44 con M19 o G74 activas' DETECCIÓN Durante la ejecución. CAUSA El usuario ha interrumpido el programa durante la ejecución de M19 o G74 en un cabezal. El CNC no puede enviar las funciones M3, M4, M5, M19 ó M41a M44 al cabezal. SOLUCIÓN Continuar la ejecución hasta que finalice la función M19 o G74. A continuación interrumpir el programa y enviar las funciones deseadas al cabezal."@es .

ns1:Alarma_3060 a ns1:Alarma ;
    rdfs:label "Alarma 3060: Velocidad (S) superior a la gama programada"@es ;
    ns1:identificador "3060" ;
    ns1:textoExtracto "'No se admite una S superior a la gama programada' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha programado una velocidad y una gama nueva, y la velocidad supera la máxima de la gama. SOLUCIÓN Cambiar la velocidad o la gama programada, o programar sólo uno de ellas para que no resulten contradictorias."@es .

ns1:Alarma_3061 a ns1:Alarma ;
    rdfs:label "Alarma 3061: Cabezal master no referenciado en sincronización lazo cerrado"@es ;
    ns1:identificador "3061" ;
    ns1:textoExtracto "Un cabezal master no referenciado no admite sincronización en lazo cerrado. DETECCIÓN Durante la ejecución. CAUSA El CNC no puede sincronizar en lazo cerrado un cabezal master, si éste no ha sido previamente referenciado. SOLUCIÓN Realizar una búsqueda de referencia del cabezal master antes de sincronizar los cabezales."@es .

ns1:Alarma_3072 a ns1:Alarma ;
    rdfs:label "Paso y S de cabezal programados para G33/G34 superan avance máximo permitido" ;
    ns1:identificador "3072" ;
    ns1:textoExtracto "3072 'Paso y S de cabezal programados para G33/G34 superan avance máximo permitido' DETECCIÓN Durante la ejecución." .

ns1:Alarma_3095 a ns1:Alarma ;
    rdfs:label "Punto final mal programado en #GAPCTRL o #LEAP"@es ;
    ns1:identificador "3095" ;
    ns1:textoExtracto "3095 Punto final mal programado en #GAPCTRL o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Durante la sentencia #GAPCTRL o #LEAP, el CNC no puede corregir la posición tras recibir la señal del sensor. SOLUCIÓN Comprobar que el punto final indicado en las sentencias #GAPCTRL o #LEAP es correcto."@es .

ns1:Alarma_3096 a ns1:Alarma ;
    rdfs:label "PWRCTRL DUTY activado en otro canal"@es ;
    ns1:identificador "3096" ;
    ns1:textoExtracto "3096 PWRCTRL DUTY activado en otro canal. [...] SOLUCIÓN El #PWRCTRL DUTY sólo puede estar activo en un canal."@es .

ns1:Alarma_3097 a ns1:Alarma ;
    rdfs:label "PWRCTRL OUT activado en otro canal"@es ;
    ns1:identificador "3097" ;
    ns1:textoExtracto "3097 PWRCTRL OUT activado en otro canal. [...] SOLUCIÓN El #PWRCTRL OUT sólo puede estar activo en un canal."@es .

ns1:Alarma_3098 a ns1:Alarma ;
    rdfs:label "PWRCTRL DUTY requiere PWM activo en el mismo canal"@es ;
    ns1:identificador "3098" ;
    ns1:textoExtracto "3098 PWRCTRL DUTY requiere PWM activo en el mismo canal. [...] SOLUCIÓN Activar el PWM antes de activar #PWRCTRL DUTY."@es .

ns1:Alarma_3099 a ns1:Alarma ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo"@es ;
    ns1:identificador "3099" ;
    ns1:textoExtracto "3099 LEAP no activado por altura de salto inferior a un mínimo. [...] SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_3102 a ns1:Alarma ;
    rdfs:label "Sentencia no compatible con movimiento independiente activo"@es ;
    ns1:identificador "3102" ;
    ns1:textoExtracto "3102 Sentencia no compatible con movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado ejecutar la sentencia #HSC o #SWT en un eje con movimiento independiente."@es .

ns1:Alarma_3105 a ns1:Alarma ;
    rdfs:label "Alarma 3105: Tapping o roscado rígido interrumpido"@es ;
    ns1:identificador "3105" ;
    ns1:textoExtracto "3105 Tapping o roscado rígido interrumpido. Retirada permitida en modo manual. Pulsar ENTER + RESET para confirmar. DETECCIÓN Durante el arranque del CNC o tras interrumpir un roscado con macho o rígido. CAUSA Se ha producido un apagado o un error grave durante la ejecución de un roscado con macho o un roscado rígido. SOLUCIÓN Entrar en modo manual y mover el eje de roscado hasta sacar la herramienta."@es .

ns1:Alarma_3400 a ns1:Alarma ;
    rdfs:label "Alarma 3400: Eje independiente inexistente o no disponible"@es ;
    ns1:identificador "3400" ;
    ns1:textoExtracto "3400 'Eje independiente inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una operación de eje independiente para un eje que no está asignado a ningún canal o está cambiando de canal. SOLUCIÓN Asignar el eje independiente a cualquier canal o esperar a que el CNC finalice el intercambio de eje."@es .

ns1:Alarma_3401 a ns1:Alarma ;
    rdfs:label "Alarma 3401: Leva inexistente o no disponible"@es ;
    ns1:identificador "3401" ;
    ns1:textoExtracto "3401 'Leva inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El número de leva programado en la sentencia #CAM no existe. SOLUCIÓN Programar una leva correcta o definir la leva en los parámetros máquina."@es .

ns1:Alarma_3402 a ns1:Alarma ;
    rdfs:label "Alarma 3402: Operaciones con ejes independientes excedidas"@es ;
    ns1:identificador "3402" ;
    ns1:textoExtracto "3402 No se admiten mas operaciones con ejes independientes. Tabla llena. DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente pero ya hay dos operaciones pendientes. SOLUCIÓN Desde el PLC abortar las sentencias pendientes (marca ABORT) o bien esperar a que haya espacio para almacenarla (marca FREE). Para saber si el interpolador independiente ha terminado todas las operaciones, consultar la marca BUSY."@es .

ns1:Alarma_3502 a ns1:Alarma ;
    rdfs:label "Alarma 3502: Aceleración lineal del tramo 2 menor o igual a cero" ;
    ns1:identificador "3502" ;
    ns1:monitoreaParametro ns1:Parametro_AceleracionLineal_Tramo2 ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 menor o igual a cero' DETECCIÓN Durante el arranque o durante la ejecución. CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:Alarma_3503 a ns1:Alarma ;
    rdfs:label "Alarma 3503: Aceleración lineal del tramo 2 mayor que la máxima" ;
    ns1:identificador "3503" ;
    ns1:monitoreaParametro ns1:Parametro_AceleracionLineal_Tramo2 ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La aceleración programada es mayor que la máxima. SOLUCIÓN Programar un valor menor que el máximo para la aceleración." .

ns1:Alarma_3504 a ns1:Alarma ;
    rdfs:label "Velocidad de cambio de aceleración mayor que la máxima"@es ;
    ns1:identificador "3504" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadCambioAceleracion ;
    ns1:textoExtracto "3504 'Velocidad de cambio de aceleración mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La velocidad programada para el cambio de aceleración es mayor que la máxima. SOLUCIÓN Programar una velocidad menor que la máxima."@es .

ns1:Alarma_3505 a ns1:Alarma ;
    rdfs:label "Límite de jerk sobrepasado"@es ;
    ns1:identificador "3505" ;
    ns1:monitoreaParametro ns1:Parametro_Jerk ;
    ns1:textoExtracto "3505 'Límite de jerk sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Sobrepasamiento de jerk en esa trayectoria. SOLUCIÓN Póngase en contacto con Fagor."@es .

ns1:Alarma_3506 a ns1:Alarma ;
    rdfs:label "El límite de jerk se va a sobrepasar"@es ;
    ns1:identificador "3506" ;
    ns1:monitoreaParametro ns1:Parametro_FrecuenciaMaxima ;
    ns1:textoExtracto "3506 'El límite de jerk se va a sobrepasar' DETECCIÓN Durante la ejecución del comando de análisis de frecuencias. CAUSA La frecuencia es demasiado grande para la amplitud programada. SOLUCIÓN Reducir la frecuencia máxima o reducir la amplitud."@es .

ns1:Alarma_3507 a ns1:Alarma ;
    rdfs:label "Límite de aceleración sobrepasada"@es ;
    ns1:identificador "3507" ;
    ns1:monitoreaParametro ns1:Parametro_AceleracionTrayectoria ;
    ns1:textoExtracto "3507 'Límite de aceleración sobrepasada' DETECCIÓN Durante la ejecución. CAUSA Sobrepasamiento de aceleración en esa trayectoria. SOLUCIÓN Póngase en contacto con Fagor."@es .

ns1:Alarma_3508 a ns1:Alarma ;
    rdfs:label "Frecuencia demasiado grande para la velocidad programada"@es ;
    ns1:identificador "3508" ;
    ns1:monitoreaParametro ns1:Parametro_FrecuenciaMaxima,
        ns1:Parametro_VelocidadAditiva ;
    ns1:textoExtracto "3508 'Frecuencia demasiado grande para la velocidad programada' DETECCIÓN Durante la ejecución del comando de análisis de frecuencias. CAUSA La velocidad aditiva es menor que la resultante para la frecuencia máxima. SOLUCIÓN Reducir la frecuencia máxima o bien programar una velocidad aditiva superior."@es .

ns1:Alarma_3509 a ns1:Alarma ;
    rdfs:label "Límite de error sobrepasado en modo HSC"@es ;
    ns1:identificador "3509" ;
    ns1:monitoreaParametro ns1:Parametro_ToleranciaHSC ;
    ns1:textoExtracto "3509 Límite de error sobrepasado en modo HSC. DETECCIÓN Durante la ejecución. CAUSA La trayectoria teórica supera la tolerancia máxima programada. SOLUCIÓN La precisión de la pieza mecanizada puede ser inferior a la tolerancia programada. Modificar las condiciones de mecanizado."@es .

ns1:Alarma_3510 a ns1:Alarma ;
    rdfs:label "El movimiento programado va a colisionar con la sonda de palpado"@es ;
    ns1:identificador "3510" ;
    ns1:monitoreaParametro ns1:Parametro_LimitePalpado ;
    ns1:textoExtracto "3510 El movimiento programado va a colisionar con la sonda de palpado. DETECCIÓN Durante la ejecución. CAUSA El movimiento del eje va a superar los límites fijados por el movimiento de palpado anterior."@es .

ns1:Alarma_3611 a ns1:Alarma ;
    rdfs:label "El cabezal master de la sincronización no está en la gama adecuada (SYNCSET ó CAXSET)"@es ;
    ns1:identificador "3611" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_M19 ;
    ns1:textoExtracto "3611 'El cabezal master de la sincronización no está en la gama adecuada (SYNCSET ó CAXSET)' DETECCIÓN Durante la ejecución. CAUSA El cabezal maestro o esclavo no están en la gama adecuada, parámetro SYNCSET o parámetro CAXSET si el cabezal maestro está como eje C. SOLUCIÓN Cambiar la gama del cabezal maestro y/o esclavo en su canal o pasar el cabezal maestro al canal del esclavo para que el cambio de gama sea automático."@es .

ns1:Alarma_3612 a ns1:Alarma ;
    rdfs:label "No se admite SPDLEREV si el cabezal está sincronizado o en M19"@es ;
    ns1:identificador "3612" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_M19 ;
    ns1:textoExtracto "3612 No se admite SPDLEREV si el cabezal está sincronizado o en M19. DETECCIÓN Durante la ejecución. CAUSA El PLC ha activado la marca SPDLEREV en un cabezal que está sincronizado, ya sea como maestro o como esclavo. SOLUCIÓN Desactivar la marca SPDLEREV del PLC."@es .

ns1:Alarma_3700 a ns1:Alarma ;
    rdfs:label "Límite de recorrido del eje sobrepasado (PLC)"@es ;
    ns1:identificador "3700" ;
    ns1:textoExtracto "3700 'Límite de recorrido del eje sobrepasado (PLC)' DETECCIÓN Durante el movimiento del eje. CAUSA El PLC ha intentado sobrepasar los límites de recorrido. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_3701 a ns1:Alarma ;
    rdfs:label "La posición de referencia sobrepasa los límites de software"@es ;
    ns1:identificador "3701" ;
    ns1:textoExtracto "3701 'La posición de referencia sobrepasa los límites de software' DETECCIÓN Durante la validación de parámetros máquina. CAUSA El valor del parámetro REFVALUE sobrepasa los límites de software del eje. SOLUCIÓN Revisar el parámetro REFVALUE y los límites de software."@es .

ns1:Alarma_3702 a ns1:Alarma ;
    rdfs:label "Error de seguimiento del eje fuera de límite"@es ;
    ns1:identificador "3702" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_3702 ;
    ns1:monitoreaParametro ns1:Parametro_ESTDELAY,
        ns1:Parametro_FEDYNFAC,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_MINFLWE ;
    ns1:textoExtracto "3702 'Error de seguimiento del eje fuera de límite' DETECCIÓN Durante la ejecución. CAUSA El eje ha superado el error de seguimiento permitido, definido en los parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)."@es,
        "3702 'Error de seguimiento del eje fuera de límite' DETECCIÓN Durante la ejecución. CAUSA El eje ha superado el error de seguimiento permitido, definido en los parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY). Puede ser debido a un ajuste inadecuado del eje, a que falta habilitar el eje, a algún fallo en el motor, en el regulador, en el sistema de captación y/o en la mecánica."@es .

ns1:Alarma_3703 a ns1:Alarma ;
    rdfs:label "Límite de software positivo sobrepasado",
        "Límite de software positivo sobrepasado"@es ;
    ns1:identificador "3703" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_3703 ;
    ns1:monitoreaParametro ns1:Parametro_LIMIT,
        ns1:Variable_V.A.RTPOSLIMIT.xn ;
    ns1:textoExtracto "3703 'software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn. SOLUCIÓN Revisar la programación.",
        "3703 'Límite de software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn."@es .

ns1:Alarma_3704 a ns1:Alarma ;
    rdfs:label "Límite de software negativo sobrepasado" ;
    ns1:identificador "3704" ;
    ns1:monitoreaParametro ns1:Parametro_LIMIT,
        ns1:Variable_V.A.RTNEGLIMIT.xn ;
    ns1:textoExtracto "3704 'Límite de software negativo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT- o por la variable V.A.RTNEGLIMIT.xn. SOLUCIÓN Revisar la programación." .

ns1:Alarma_3705 a ns1:Alarma ;
    rdfs:label "Es necesaria la búsqueda de cero" ;
    ns1:activaAlarma ns1:SistemaCNC ;
    ns1:identificador "3705" ;
    ns1:textoExtracto "3705 'Es necesaria la búsqueda de cero' DETECCIÓN Durante la ejecución. CAUSA El CNC ha perdido la referencia del cabezal en la transición de lazo abierto a lazo cerrado. SOLUCIÓN Póngase en contacto con su proveedor." .

ns1:Alarma_3706 a ns1:Alarma ;
    rdfs:label "Error en la operación con palpador" ;
    ns1:identificador "3706" ;
    ns1:textoExtracto "3706 'Error en la operación con palpador' DETECCIÓN Durante la inicialización del palpador. CAUSA La entrada digital asignada al palpador no es válida. SOLUCIÓN Revisar los parámetros del palpador." .

ns1:Alarma_3707 a ns1:Alarma ;
    rdfs:label "Error en la búsqueda de cero" ;
    ns1:activaAlarma ns1:ModuloContaje,
        ns1:ReguladorSercos,
        ns1:SistemaCaptacion ;
    ns1:identificador "3707" ;
    ns1:textoExtracto "3707 'Error en la búsqueda de cero' DETECCIÓN Durante la búsqueda de referencia. CAUSA Error en el proceso de búsqueda de referencia. Puede ser debido a una parametrización inadecuada del eje, a un fallo en el módulo de contaje o en el regulador Sercos, en el sistema de captación o a un error en el conexionado." .

ns1:Alarma_3708 a ns1:Alarma ;
    rdfs:label "Tiempo máximo para entrar en banda de muerte superado" ;
    ns1:identificador "3708" ;
    ns1:monitoreaParametro ns1:Parametro_INPOMAX ;
    ns1:textoExtracto "3708 'Tiempo máximo para entrar en banda de muerte superado' DETECCIÓN Durante la ejecución. CAUSA El tiempo que necesita el eje para entrar en la banda de muerte, para que el CNC considere que está en posición, supera al definido en el parámetro INPOMAX. SOLUCIÓN Ajustar el parámetro INPOMAX." .

ns1:Alarma_3709 a ns1:Alarma ;
    rdfs:label "Error en el refresco de las entradas analógicas" ;
    ns1:identificador "3709" ;
    ns1:textoExtracto "3709 'Error en el refresco de las entradas analógicas' DETECCIÓN Durante la lectura de entradas analógicas." .

ns1:Alarma_3710 a ns1:Alarma ;
    rdfs:label "'Rango de valores de la consigna de posición sobrepasados'" ;
    ns1:identificador "3710" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_3710 ;
    ns1:textoExtracto "3710 'Rango de valores de la consigna de posición sobrepasados' [...] Overflow en la variable de la consigna de posición."@es .

ns1:Alarma_3711 a ns1:Alarma ;
    rdfs:label "'Error en el refresco de contajes CAN'" ;
    ns1:identificador "3711" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_3711 ;
    ns1:textoExtracto "3711 'Error en el refresco de contajes CAN' [...] El error puede ser debido a un error en el bus CAN, a un fallo en algún contaje, en el módulo de contaje o a la saturación del bus CAN."@es .

ns1:Alarma_3712 a ns1:Alarma ;
    rdfs:label "'Micro del maestro pulsado durante la búsqueda de cero del esclavo'" ;
    ns1:identificador "3712" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_3712 ;
    ns1:textoExtracto "3712 'Micro del maestro pulsado durante la búsqueda de cero del esclavo' [...] Durante la búsqueda de referencia de un eje gantry, el CNC ha detectado el micro del eje maestro antes que el del eje esclavo."@es .

ns1:Alarma_3713 a ns1:Alarma ;
    rdfs:label "'El control tándem no se encuentra activo'" ;
    ns1:identificador "3713" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_3713 ;
    ns1:textoExtracto "3713 'El control tándem no se encuentra activo' [...] El CNC no ha podido inicializar el control de par adicional porque la información de algún parámetro no está disponible."@es .

ns1:Alarma_3719 a ns1:Alarma ;
    rdfs:label "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo" ;
    ns1:identificador "3719" ;
    ns1:textoExtracto "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática activa, de un eje angular activo, del control tangencial activo o de una transformación de coordenadas #CS o #ACS. SOLUCIÓN: El PLC no puede aparcar el eje en esa situación. Pulsar reset para detener el movimiento o desactivar la cinemática activa, el eje angular activo, el control tangencial activo o la transformación de coordenadas #CS o #ACS." .

ns1:Alarma_3720 a ns1:Alarma ;
    rdfs:label "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC" ;
    ns1:identificador "3720" ;
    ns1:textoExtracto "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa. SOLUCIÓN: El PLC no puede aparcar el cabezal en esa situación. Pulsar reset para detener el movimiento, la sincronización, desactivar el eje C o desactivar las funciones G33, G34, G63, G95 o G96." .

ns1:Alarma_3721 a ns1:Alarma ;
    rdfs:label "Palpador no disponible. Ocupado por otro proceso" ;
    ns1:identificador "3721" ;
    ns1:textoExtracto "Palpador no disponible. Ocupado por otro proceso. DETECCIÓN: Durante la ejecución. CAUSA: El CNC ha intentado ejecutar una palpación pero el palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE). SOLUCIÓN: Esperar a que finalice una palpación antes de ejecutar la siguiente." .

ns1:Alarma_3722 a ns1:Alarma ;
    rdfs:label "Error en la inicialización del palpador" ;
    ns1:identificador "3722" ;
    ns1:textoExtracto "Error en la inicialización del palpador. DETECCIÓN: Durante la ejecución. CAUSA: Los parámetros del palpador no son coherentes. SOLUCIÓN: Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ns1:Alarma_3732 a ns1:Alarma ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ns1:identificador "3732" ;
    ns1:textoExtracto "3732 Error en el refresco de contajes locales. DETECCIÓN En la lectura de los contajes analógicos locales desde el lazo de posición. CAUSA Alarma en alguna de las entradas de captación locales." .

ns1:Alarma_3762 a ns1:Alarma ;
    rdfs:label "Alarma 3762: Error en el comando de latcheo de I0" ;
    ns1:identificador "3762" ;
    ns1:textoExtracto "3762 Error en el comando de latcheo de I0. DETECCIÓN Durante el proceso de referenciar el eje/cabezal. CAUSA El comando de latcheo del I0 ha dado un error. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_3763 a ns1:Alarma ;
    rdfs:label "Alarma 3763: Error en el comando de reseteo de errores del regulador" ;
    ns1:identificador "3763" ;
    ns1:textoExtracto "3763 Error en el comando de reseteo de errores del regulador. DETECCIÓN Tras un reset del CNC. error. CAUSA El comando de resetear errores del regulador ha dado un error. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_3764 a ns1:Alarma ;
    rdfs:label "Alarma 3764: Error en el comando de establecer nueva referencia de posición" ;
    ns1:identificador "3764" ;
    ns1:textoExtracto "3764 Error en el comando de establecer nueva referencia de posición. DETECCIÓN Durante el proceso de búsqueda de I0 o G174. CAUSA El comando de establecer nueva referencia de posición ha dado error. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_3801 a ns1:Alarma ;
    rdfs:label "Alarma 3801: Distancia o velocidad en jog incremental igual a cero",
        "Distancia o velocidad en jog incremental igual a cero" ;
    ns1:activaAlarma ns1:Parametro_INCJOGDIST,
        ns1:Parametro_INCJOGFEED,
        ns1:Parametro_JOGFEED ;
    ns1:identificador "3801" ;
    ns1:textoExtracto "3801 'Distancia o velocidad en jog incremental igual a cero' DETECCIÓN Durante la ejecución.",
        "3801 'Distancia o velocidad en jog incremental igual a cero' DETECCIÓN Durante la ejecución. CAUSA El avance o la distancia a moverse en jog incremental es cero." .

ns1:Alarma_3804 a ns1:Alarma ;
    rdfs:label "Índice de volante fuera de rango (posiciones del conmutador 1-3)" ;
    ns1:identificador "3804" ;
    ns1:textoExtracto "3804 'Índice de volante fuera de rango (posiciones del conmutador 1-3)' DETECCIÓN Durante un cambio en la resolución de volante. CAUSA El PLC ha intentado seleccionar una posición de volante que está fuera rango permitido." .

ns1:Alarma_3807 a ns1:Alarma ;
    rdfs:label "Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)",
        "Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)"@es ;
    ns1:identificador "3807" ;
    ns1:textoExtracto "3807 'Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución.",
        "3807 'Indice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado seleccionar una posición de jog incremental que está fuera rango permitido. SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX."@es .

ns1:Alarma_3808 a ns1:Alarma ;
    rdfs:label "Eje inexistente o no disponible"@es ;
    ns1:identificador "3808" ;
    ns1:textoExtracto "3808 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma_4000_5 a ns1:Alarma ;
    rdfs:label "Error en la inicialización del anillo Sercos (4000-5)" ;
    ns1:identificador "4000(5)" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4000_5 ;
    ns1:textoExtracto "4000(5) 'Error en la inicialización del anillo Sercos' VALOR 5. TRANSICIÓN 3. VALOR 35. CAUSA Error en el reset de errores tras inicializar el anillo Sercos." .

ns1:Alarma_4001 a ns1:Alarma ;
    rdfs:label "Parámetro LOOPTIME diferente en CNC y regulador" ;
    ns1:identificador "4001" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4001 ;
    ns1:textoExtracto "4001 'Parámetro LOOPTIME diferente en CNC y regulador' CAUSA Valor del parámetro LOOPTIME diferente en el CNC y en el regulador." .

ns1:Alarma_4002 a ns1:Alarma ;
    rdfs:label "Parámetro OPMODE diferente en CNC y regulador" ;
    ns1:identificador "4002" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4002 ;
    ns1:textoExtracto "4002 'Parámetro OPMODE diferente en CNC y regulador' CAUSA Valor del parámetro OPMODE diferente en el CNC y en el regulador." .

ns1:Alarma_4003 a ns1:Alarma ;
    rdfs:label "Parámetro AXISMODE diferente en CNC y regulador" ;
    ns1:identificador "4003" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4003 ;
    ns1:textoExtracto "4003 'Parámetro AXISMODE diferente en CNC y regulador' CAUSA Valor del parámetro AXISMODE diferente en el CNC y en el regulador." .

ns1:Alarma_4018 a ns1:Alarma ;
    rdfs:label "Alarma 4018: Captación remota Sercos con FEEDBACKTYPE incoherente" ;
    ns1:activaAlarma ns1:Sistema_Sercos ;
    ns1:identificador "4018" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_CorregirParametrizacion_4018 ;
    ns1:textoExtracto "4018 Captación remota Sercos con FEEDBACKTYPE incoherente en diferentes gamas. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA En alguna entrada de captación del módulo RCS-S, el tipo de captación (parámetro FEEDBACKTYPE) no es igual en todos lo sets." .

ns1:Alarma_4019 a ns1:Alarma ;
    rdfs:label "Alarma 4019: Error en el anillo Sercos debido a un Reset de contadora" ;
    ns1:activaAlarma ns1:Sistema_Sercos ;
    ns1:identificador "4019" ;
    ns1:textoExtracto "4019 Error en el anillo Sercos debido a un Reset de contadora." .

ns1:Alarma_4502 a ns1:Alarma ;
    rdfs:label "Time out en la inicialización de Mechatrolink" ;
    ns1:identificador "4502" ;
    ns1:textoExtracto "4502 'Time out en la inicialización de Mechatrolink' DETECCIÓN Durante el arranque del CNC. CAUSA No se ha completado la inicialización de la comunicación Mechatrolink. SOLUCIÓN Verificar la parametrización de la comunicación (protocolo, tamaño de los datos, número de ejes Mechatrolink, etc) y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:Alarma_4503 a ns1:Alarma ;
    rdfs:label "Alarma del comando Mechatrolink" ;
    ns1:identificador "4503" ;
    ns1:textoExtracto "4503 'Alarma del comando Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA La ejecución de un comando Mechatrolink desde el master a un determinado esclavo provoca una situación de alarma en dicho dispositivo. SOLUCIÓN Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:Alarma_4504 a ns1:Alarma ;
    rdfs:label "Error de comunicación en el Bus Mechatrolink" ;
    ns1:identificador "4504" ;
    ns1:textoExtracto "4504 'Error de comunicación en el Bus Mechatrolink' DETECCIÓN Durante la ejecución del CNC. CAUSA Fallo en el trasvase de información cíclica entre el master Mechatrolink y algún esclavo. SOLUCIÓN Revisar el hardware del master y la integridad física del bus (cableado, resistencias terminadoras, asignación de la numeración de cada estación, etc)." .

ns1:Alarma_4506 a ns1:Alarma ;
    rdfs:label "Falta potencia en esclavo Mechatrolink" ;
    ns1:identificador "4506" ;
    ns1:textoExtracto "4506 'Falta potencia en esclavo Mechatrolink' DETECCIÓN Durante la ejecución del CNC, una vez que ha entrado en estado de movimiento interpolado. CAUSA Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia." .

ns1:Alarma_4632 a ns1:Alarma ;
    rdfs:label "Node hardware ID desconocido" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4632" ;
    ns1:textoExtracto "4632 Node hardware id desconocido. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno en la detección de nodos Sercos III. La versión del CNC no reconoce uno de los nodos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4633 a ns1:Alarma ;
    rdfs:label "Error en comunicación con nodo" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4633" ;
    ns1:textoExtracto "4633 Error en comunicación con nodo. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error de comunicación con un esclavo Sercos III tras un reset, lectura de la versión o lectura del ID Hardware. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Alarma_4634 a ns1:Alarma ;
    rdfs:label "Nodo no encontrado en topología" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4634" ;
    ns1:textoExtracto "4634 Nodo no encontrado en topología. DETECCIÓN Durante el arranque del CNC. CAUSA No coinciden los números de serie del nodo Sercos III. El nodo se ha intercambiado o sustituido. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4635 a ns1:Alarma ;
    rdfs:label "Nodo no definido" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4635" ;
    ns1:textoExtracto "4635 Nodo no definido. DETECCIÓN Durante el arranque del CNC, durante la ejecución o tras un reset. CAUSA Se ha producido un error inesperado en uno de los nodos Sercos III. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4636 a ns1:Alarma ;
    rdfs:label "Datos hardware no encontrados" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4636" ;
    ns1:textoExtracto "4636 Datos hardware no encontrados. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno en la lectura de fichero de datos hardware. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4637 a ns1:Alarma ;
    rdfs:label "Error en número de serie de nodo" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4637" ;
    ns1:textoExtracto "4637 Error en número de serie de nodo. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error en la lectura de los números de serie de un nodo Sercos III o números de serie incorrectos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4638 a ns1:Alarma ;
    rdfs:label "Nodo no detectado" ;
    ns1:activaAlarma ns1:Sistema_SercosIII ;
    ns1:identificador "4638" ;
    ns1:textoExtracto "4638 Nodo no detectado. DETECCIÓN Durante el arranque del CNC. CAUSA No se ha detectado un nodo de la topología durante el arranque del CNC." .

ns1:Alarma_4639 a ns1:Alarma ;
    rdfs:label "Nodo encontrado no definido" ;
    ns1:identificador "4639" ;
    ns1:textoExtracto "4639 Nodo encontrado no definido. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un nodo que no está definido en la topología del sistema. SOLUCIÓN Actualizar la topología añadiendo el nodo detectado o desconectarlo del bus si no se desea utilizarlo." .

ns1:Alarma_4640 a ns1:Alarma ;
    rdfs:label "Versión de estructura de nodo no compatible" ;
    ns1:identificador "4640" ;
    ns1:textoExtracto "4640 Versión de estructura de nodo no compatible. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un nodo Sercos III con una versión incompatible con la versión del CNC. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4641 a ns1:Alarma ;
    rdfs:label "Error de configuración de la seguridad integrada en nodo" ;
    ns1:identificador "4641" ;
    ns1:textoExtracto "4641 Error de configuración de la seguridad integrada en nodo. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error en la configuración de un nodo safety. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4642 a ns1:Alarma ;
    rdfs:label "Serial number de la placa powerControl sin grabar" ;
    ns1:identificador "4642" ;
    ns1:textoExtracto "4642 Serial number de la placa powerControl sin grabar, sap-manuf. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un nodo que no está en topología y no tiene grabado el número de serie en la placa powerControl. SOLUCIÓN Póngase en contacto con Fagor Automation. Es necesario grabar un número de serie válido en la placa powerControl." .

ns1:Alarma_4643 a ns1:Alarma ;
    rdfs:label "Serial number de la placa powerModule sin grabar" ;
    ns1:identificador "4643" ;
    ns1:textoExtracto "4643 Serial number de la placa powerModule sin grabar, sap-manuf. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un nodo que no está en topología y no tiene grabado el número de serie en la placa powerModule. SOLUCIÓN Póngase en contacto con Fagor Automation. Es necesario grabar un número de serie válido en la placa powerModule." .

ns1:Alarma_4660 a ns1:Alarma ;
    rdfs:label "Error máquina de estado de Hiperface" ;
    ns1:identificador "4660" ;
    ns1:textoExtracto "4660 Error maquina de estado de Hiperface. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en máquina de estados de la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Alarma_4661 a ns1:Alarma ;
    rdfs:label "Error de comunicaciones con driver Hiperface" ;
    ns1:identificador "4661" ;
    ns1:textoExtracto "4661 Error de comunicaciones con driver Hiperface. DETECCIÓN Durante el arranque del CNC." .

ns1:Alarma_5021 a ns1:Alarma ;
    rdfs:label "CNCEX: El canal indicado no es de PLC" ;
    ns1:identificador "5021" ;
    ns1:textoExtracto "5021 'CNCEX: El canal indicado no es de PLC' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no es de PLC. SOLUCIÓN Comprobar la sintaxis de la instrucción. Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

ns1:Alarma_5022 a ns1:Alarma ;
    rdfs:label "PLC:Demasiados CNCRD y CNCWR de variables asíncronas" ;
    ns1:identificador "5022" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5022 ;
    ns1:textoExtracto "Durante la ejecución de comandos CNCRD y CNCWR de variables asíncronas, así como durante la ejecución de comandos CNCEX. CAUSA Número excesivo de peticiones asíncronas desde PLC." .

ns1:Alarma_5023 a ns1:Alarma ;
    rdfs:label "Error en la lectura de entradas digitales locales" ;
    ns1:identificador "5023" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5023 ;
    ns1:textoExtracto "Error en la lectura de entradas digitales locales. CAUSA Fallo en la lectura de las entradas digitales locales de PLC." .

ns1:Alarma_5024 a ns1:Alarma ;
    rdfs:label "Error en la escritura de salidas digitales locales" ;
    ns1:identificador "5024" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5024 ;
    ns1:textoExtracto "Error en la escritura de salidas digitales locales. CAUSA Fallo en la escritura de las salidas digitales locales de PLC." .

ns1:Alarma_5025 a ns1:Alarma ;
    rdfs:label "Contador de PLC deshabilitado" ;
    ns1:identificador "5025" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5025 ;
    ns1:textoExtracto "Durante el arranque del CNC. CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización." .

ns1:Alarma_5026 a ns1:Alarma ;
    rdfs:label "Alarma 5026: CNCWR - Valor no permitido" ;
    ns1:identificador "5026" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de programa PLC para variable CNCWR" ;
            ns1:textoExtracto "Revisar el programa de PLC. Escribir el valor 0 en la variable o eliminar el comando CNCWR." ] ;
    ns1:textoExtracto "'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable que sólo admite valor 0 (cero)." .

ns1:Alarma_5027 a ns1:Alarma ;
    rdfs:label "Alarma 5027: Cortocircuito en salida analógica local" ;
    ns1:identificador "5027" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado de salida analógica CNC" ;
            ns1:textoExtracto "Revisar el conexionado de la salida analógica del CNC." ] ;
    ns1:textoExtracto "'Cortocircuito en salida analógica local (report desde PLC)' DETECCIÓN El PLC ha detectado una alarma de sobrecorriente a la hora de escribir la salida analógica local. CAUSA Cortocircuito en la salida analógica local del CNC." .

ns1:Alarma_5028 a ns1:Alarma ;
    rdfs:label "Alarma 5028: Error en recurso remoto (lectura)" ;
    ns1:identificador "5028" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado de módulos remotos (lectura)" ;
            ns1:textoExtracto "Revisar el conexionado de los módulos remotos." ] ;
    ns1:textoExtracto "DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de leer datos." .

ns1:Alarma_5029 a ns1:Alarma ;
    rdfs:label "Alarma 5029: Error en recurso remoto (escritura)" ;
    ns1:identificador "5029" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado de módulos remotos (escritura)" ;
            ns1:textoExtracto "Revisar el conexionado de los módulos remotos." ] ;
    ns1:textoExtracto "DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de escribir datos." .

ns1:Alarma_5030 a ns1:Alarma ;
    rdfs:label "Alarma 5030: Error de configuración de recursos remotos" ;
    ns1:identificador "5030" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de configuración de módulos remotos" ;
            ns1:textoExtracto "Revisar la configuración de los módulos remotos." ] ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos." .

ns1:Alarma_5031 a ns1:Alarma ;
    rdfs:label "Alarma 5031: Error interno en configuración de recursos remotos" ;
    ns1:identificador "5031" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de configuración de módulos remotos (error interno)" ;
            ns1:textoExtracto "Revisar la configuración de los módulos remotos." ] ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos." .

ns1:Alarma_5032 a ns1:Alarma ;
    rdfs:label "Alarma 5032: Orden incorrecto en comandos de router de recursos" ;
    ns1:identificador "5032" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de secuencia de inicialización del router" ;
            ns1:textoExtracto "Revisar la configuración de los módulos remotos." ] ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto." .

ns1:Alarma_5041 a ns1:Alarma ;
    rdfs:label "Alarma 5041: Error de rango excedido en entrada analógica remota" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5041" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error de rango excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La tensión aplicada a la entrada analógica es mayor que el rango permitido. SOLUCIÓN Revisar el circuito conectado a la entrada analógica remota." .

ns1:Alarma_5042 a ns1:Alarma ;
    rdfs:label "Alarma 5042: Error de rango mínimo excedido en entrada analógica remota" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5042" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error de rango mínimo excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La tensión aplicada a la entrada analógica es menor que el rango permitido. SOLUCIÓN Revisar el circuito conectado a la entrada analógica remota." .

ns1:Alarma_5043 a ns1:Alarma ;
    rdfs:label "Alarma 5043: Error de conversión en entrada analógica remota" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5043" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error conversión. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La entrada analógica indica que no puede realizar la lectura correctamente. SOLUCIÓN Revisar módulo remoto." .

ns1:Alarma_5044 a ns1:Alarma ;
    rdfs:label "Alarma 5044: Configuración incorrecta en entrada analógica remota" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5044" ;
    ns1:textoExtracto "Una entrada analógica remota esta configurada incorrectamente. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La configuración de una entrada analógica remota no es correcta. SOLUCIÓN Revisar configuración de la entrada analógica remota." .

ns1:Alarma_5045 a ns1:Alarma ;
    rdfs:label "Alarma 5045: Error de alimentación en entrada analógica remota" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5045" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error de alimentación. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La alimentación de la entrada analógica remota no es correcta. SOLUCIÓN Revisar la alimentación de la entrada analógica remota." .

ns1:Alarma_5046 a ns1:Alarma ;
    rdfs:label "Alarma 5046: Error en módulo de entradas analógicas remotas" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5046" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error en el módulo. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas no funciona correctamente. SOLUCIÓN Revisar módulo remoto." .

ns1:Alarma_5047 a ns1:Alarma ;
    rdfs:label "Alarma 5047: Error desconocido en módulo de entradas analógicas remotas" ;
    ns1:activaAlarma ns1:Sistema_PLC ;
    ns1:identificador "5047" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas tiene un error. SOLUCIÓN Revisar módulo remoto." .

ns1:Alarma_5055 a ns1:Alarma ;
    rdfs:label "Alarma 5055: Error de rango excedido en sensor de temperatura remoto" ;
    ns1:activaAlarma ns1:Sensor_Temperatura_Remoto ;
    ns1:identificador "5055" ;
    ns1:textoExtracto "5055 Un sensor de temperatura remoto ha detectado un error de rango excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La temperatura del sensor de temperatura es menor que el rango permitido." .

ns1:Alarma_5056 a ns1:Alarma ;
    rdfs:label "Alarma 5056: Error de ejecución en salida analógica remota" ;
    ns1:identificador "5056" ;
    ns1:textoExtracto "5056 Error de ejecución en el tratamiento de una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos." .

ns1:Alarma_5057 a ns1:Alarma ;
    rdfs:label "Alarma 5057: Error de ejecución en entrada analógica remota" ;
    ns1:identificador "5057" ;
    ns1:textoExtracto "5057 Error de ejecución en el tratamiento de una entrada analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Error en el tratamiento de los datos." .

ns1:Alarma_6000 a ns1:Alarma ;
    rdfs:label "Alarma de captación",
        "Alarma de captación en volante conectado al contaje local" ;
    ns1:activaAlarma ns1:ComponenteElectrico_VolantesLocales ;
    ns1:identificador "6000" ;
    ns1:monitoreaParametro ns1:Parametro_FBACKAL ;
    ns1:textoExtracto """\r
    6000 'Alarma de captación'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Alarma de captación en algún eje analógico (parámetro FBACKAL).\r
    Para señal TTL diferencial.\r
    • Uno o más cables rotos (señales A, B o sus negadas).\r
    • Entrada de captación desconectada en la contadora.\r
    Para señal senoidal diferencial.\r
    • Uno o más cables rotos (señales A, B o sus negadas).\r
    • Entrada de captación desconectada en la contadora.\r
    • Amplitud de señal de entrada por encima de 1,45 Vpp aproximadamente.\r
    • Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente.\r
    • Excesivo desfase entre señales A y B (en cuadratura, en teoría).\r
    SOLUCIÓN Revisar los cables y la conexión de las entradas de captación.""",
        "DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de captación en volante conectado al contaje local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." .

ns1:Alarma_6001 a ns1:Alarma ;
    rdfs:label "Alarma del test de tendencia activada" ;
    ns1:identificador "6001" ;
    ns1:monitoreaParametro ns1:Parametro_AXISCHG,
        ns1:Parametro_ESTDELAY,
        ns1:Parametro_LOOPCHG ;
    ns1:textoExtracto """\r
    6001 'Alarma del test de tendencia activada'\r
    DETECCIÓN Cuando un eje se embala y está activa la vigilancia del test de tendencia.\r
    CAUSA Realimentación positiva en el eje durante un tiempo superior al definido en el parámetro ESTDELAY.\r
    SOLUCIÓN Ajustar el signo de la consigna (parámetro AXISCHG), el contaje (LOOPCHG) y tiempo asignado al parámetro ESTDELAY.""" .

ns1:Alarma_6002 a ns1:Alarma ;
    rdfs:label "El programa PLC no está en marcha" ;
    ns1:identificador "6002" ;
    ns1:textoExtracto """\r
    6002 'El programa PLC no está en marcha'\r
    DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC.\r
    CAUSA El programa de PLC no está en marcha.\r
    • Instalación de una nueva versión de software.\r
    • El usuario ha parado el PLC, olvidando ponerlo en marcha.\r
    SOLUCIÓN Poner en marcha el programa PLC. Si es necesario, compilar el programa de PLC.""" .

ns1:Alarma_6003 a ns1:Alarma ;
    rdfs:label "Emergencia externa activada" ;
    ns1:identificador "6003" ;
    ns1:textoExtracto """\r
    6003 'Emergencia externa activada'\r
    DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC.\r
    CAUSA La marca _EMERGEN del PLC está desactivada.""" .

ns1:Alarma_6012 a ns1:Alarma ;
    rdfs:label "Alarma 6012: Error en controlador de CAN"@es ;
    ns1:identificador "6012" ;
    ns1:textoExtracto "6012 'Error en controlador de CAN' DETECCIÓN Durante la ejecución. CAUSA La COMPCI detecta BUSOFF y el bus cae. Códigos de error para el bus CANopen."@es .

ns1:Alarma_6049 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud" ;
    ns1:identificador "6049" ;
    ns1:textoExtracto "6049 'Alarma de amplitud' DETECCIÓN El lazo ha detectado alarma de amplitud Vpp en el contaje local. CAUSA La señal senoidal conectada al contaje local tiene una amplitud fuera de límites, demasiado pequeña o demasiado grande. SOLUCIÓN Revisar los niveles de la señal Vpp en la captación local del CNC." .

ns1:Alarma_6050 a ns1:Alarma ;
    rdfs:label "Cortocircuito en las IOs locales (alarma de sobrecorriente)",
        "Cortocircuito en las IOs locales (alarma de sobrecorriente)"@es ;
    ns1:identificador "6050" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación de IOs locales"@es ;
            ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
                    rdfs:label "IOs locales del CNC"@es ;
                    ns1:textoExtracto "I/Os locales"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y la alimentación de las IOs locales."@es ] ;
    ns1:textoExtracto "6050 'Cortocircuito en las IOs locales (alarma de sobrecorriente)' DETECCIÓN Durante el funcionamiento del CNC.",
        "6050 'Cortocircuito en las IOs locales (alarma de sobrecorriente)' DETECCIÓN Durante el funcionamiento del CNC. CAUSA Alarma de sobrecorriente en las IOs locales. SOLUCIÓN Revisar el conexionado y la alimentación de las IOs locales."@es .

ns1:Alarma_6051 a ns1:Alarma ;
    rdfs:label "Cortocircuito en palpador local (alarma de sobrecorriente)"@es ;
    ns1:identificador "6051" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación del palpador local"@es ;
            ns1:solucionaFallo [ a ns1:Sensor ;
                    rdfs:label "Palpador local del CNC"@es ;
                    ns1:textoExtracto "palpador local"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y la alimentación del palpador local."@es ] ;
    ns1:textoExtracto "6051 'Cortocircuito en palpador local (alarma de sobrecorriente)' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de sobrecorriente en el palpador local. SOLUCIÓN Revisar el conexionado y la alimentación del palpador local."@es .

ns1:Alarma_6052 a ns1:Alarma ;
    rdfs:label "Cortocircuito en salida analógica local (report desde LR)"@es ;
    ns1:identificador "6052" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado de salida analógica local"@es ;
            ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
                    rdfs:label "Salida analógica local del CNC"@es ;
                    ns1:textoExtracto "salida analógica local"@es ] ;
            ns1:textoExtracto "Revisar el conexionado de la salida analógica del CNC."@es ] ;
    ns1:textoExtracto "6052 'Cortocircuito en salida analógica local (report desde LR)' DETECCIÓN El lazo ha detectado una alarma de sobrecorriente a la hora de escribir la salida analógica local. CAUSA Cortocircuito en la salida analógica local del CNC. SOLUCIÓN Revisar el conexionado de la salida analógica del CNC."@es .

ns1:Alarma_6053 a ns1:Alarma ;
    rdfs:label "Error en inicialización de jog local"@es ;
    ns1:identificador "6053" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación del jog local"@es ;
            ns1:solucionaFallo [ a ns1:InterfazUsuario ;
                    rdfs:label "Panel local de jog del CNC"@es ;
                    ns1:textoExtracto "panel local de jog"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y alimentación del jog local."@es ] ;
    ns1:textoExtracto "6053 'Error en inicialización de jog local' DETECCIÓN Durante el arranque del sistema. CAUSA El panel local de jog no ha podido inicializarse correctamente. SOLUCIÓN Revisar el conexionado y alimentación del jog local."@es .

ns1:Alarma_6054 a ns1:Alarma ;
    rdfs:label "Error en inicialización de volantes locales"@es ;
    ns1:identificador "6054" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación de placa de volantes"@es ;
            ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
                    rdfs:label "Placa local de volantes del CNC"@es ;
                    ns1:textoExtracto "placa local de volantes"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y alimentación de la placa de volantes."@es ] ;
    ns1:textoExtracto "6054 'Error en inicialización de volantes locales' DETECCIÓN Durante el arranque del sistema. CAUSA La placa local de volantes no ha podido inicializarse correctamente. SOLUCIÓN Revisar el conexionado y alimentación de la placa de volantes."@es .

ns1:Alarma_6055 a ns1:Alarma ;
    rdfs:label "Fallo en lectura periódica de volantes locales"@es ;
    ns1:identificador "6055" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación de volantes locales"@es ;
            ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
                    rdfs:label "Volantes locales del CNC"@es ;
                    ns1:textoExtracto "volantes locales"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y alimentación de los volantes locales."@es ] ;
    ns1:textoExtracto "6055 'Fallo en lectura periódica de volantes locales' DETECCIÓN Durante la ejecución del CNC. CAUSA Error en la lectura cíclica de volantes locales. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales."@es .

ns1:Alarma_6056 a ns1:Alarma ;
    rdfs:label "Cortocircuito en volante de jog (alarma de sobrecorriente)"@es ;
    ns1:identificador "6056" ;
    ns1:mitigaRiesgo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Revisión de conexionado y alimentación de volante de jog"@es ;
            ns1:solucionaFallo [ a ns1:ComponenteElectrico ;
                    rdfs:label "Volante de jog local del CNC"@es ;
                    ns1:textoExtracto "volante conectado al jog local"@es ] ;
            ns1:textoExtracto "Revisar el conexionado y alimentación de los volantes locales."@es ] ;
    ns1:textoExtracto "6056 'Cortocircuito en volante de jog (alarma de sobrecorriente)' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de sobrecorriente en el volante conectado al jog local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales."@es .

ns1:Alarma_6058 a ns1:Alarma ;
    rdfs:label "Alarma 6058: Algún nodo CANopen no se encuentra en fase operacional" ;
    ns1:activaAlarma ns1:Sistema_CANopen ;
    ns1:identificador "6058" ;
    ns1:textoExtracto "6058 'Algún nodo CANopen no se encuentra en fase operacional' DETECCIÓN Tras un reset del CNC. CAUSA En la reinicialización de CANopen que se hace durante el reset de CNC, alguno de los nodos no ha conseguido llegar a fase operacional. SOLUCIÓN Revisar el conexionado y configuración de los nodos CANopen." .

ns1:Alarma_6059 a ns1:Alarma ;
    rdfs:label "Alarma 6059: Error en la configuración de una entrada analógica" ;
    ns1:activaAlarma ns1:Sistema_CANopen ;
    ns1:identificador "6059" ;
    ns1:monitoreaParametro ns1:Parametro_EntradasAnalogicas ;
    ns1:textoExtracto "6059 Error en la configuración de una entrada analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen, no se ha conseguido configurar correctamente alguna de las entradas parametrizadas en corriente. SOLUCIÓN Revisar la parametrización de entradas analógicas en corriente." .

ns1:Alarma_6060 a ns1:Alarma ;
    rdfs:label "Alarma 6060: Error en la configuración de una salida analógica" ;
    ns1:activaAlarma ns1:Sistema_CANopen ;
    ns1:identificador "6060" ;
    ns1:monitoreaParametro ns1:Parametro_SalidasAnalogicas ;
    ns1:textoExtracto "6060 Error en la configuración de una salida analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen no se ha conseguido configurar correctamente alguna de las salidas parametrizadas en corriente. SOLUCIÓN Revisar la parametrización de salidas analógicas en corriente." .

ns1:Alarma_6061 a ns1:Alarma ;
    rdfs:label "Alarma 6061: Nodos CANopen no Fagor. Opción de software no permitida" ;
    ns1:activaAlarma ns1:Sistema_CANopen ;
    ns1:identificador "6061" ;
    ns1:textoExtracto "6061 Nodos CANopen no Fagor. Opción de software no permitida. DETECCIÓN En la inicialización del bus CANopen, durante el arranque del CNC o tras un reset. CAUSA Durante la inicialización del bus CANopen, se han detectado nodos de terceros sin disponer de la correspondiente opción de software. SOLUCIÓN Desconectar del bus CANopen aquellos nodos que no sean Fagor, o comprar la opción de software que permita su empleo." .

ns1:Alarma_6062 a ns1:Alarma ;
    rdfs:label "Alarma 6062: Relé de emergencia abierto por error en reinicialización de bus" ;
    ns1:activaAlarma ns1:ComponenteElectrico_Rel_Emergencia,
        ns1:Sistema_CANopen,
        ns1:Sistema_Sercos ;
    ns1:identificador "6062" ;
    ns1:textoExtracto "6062 Relé de emergencia abierto por error en reinicialización de bus. DETECCIÓN Tras un reset del CNC o durante la validación de parámetros máquina. CAUSA En reset o validación de parámetros máquina, no se ha conseguido finalizar correctamente la ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos." .

ns1:Alarma_7001 a ns1:Alarma ;
    rdfs:label "Dos Ts consecutivas en almacén cíclico (M6 necesaria)" ;
    ns1:identificador "7001" ;
    ns1:textoExtracto "'Dos Ts consecutivas en almacén cíclico (M6 necesaria)' DETECCIÓN Durante la ejecución. CAUSA El almacén es cíclico y hay programadas dos herramientas consecutivas sin M06. SOLUCIÓN En un almacén cíclico hay que programar M06 después de cada herramienta." .

ns1:Alarma_7002 a ns1:Alarma ;
    rdfs:label "La herramienta no está en el almacén y no se permiten herramientas de tierra" ;
    ns1:identificador "7002" ;
    ns1:textoExtracto "'La herramienta no está en el almacén y no se permiten herramientas de tierra' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una herramienta que está en la tabla de herramientas, pero no está en la tabla del almacén. En este caso, el CNC entiende que la herramienta es de tierra, pero en los parámetros máquina está especificado que no se admiten herramientas de tierra. SOLUCIÓN Configurar la máquina para aceptar herramientas de tierra o incluir la herramienta en la tabla del almacén." .

ns1:Alarma_7003 a ns1:Alarma ;
    rdfs:label "T no definida en la tabla" ;
    ns1:identificador "7003" ;
    ns1:textoExtracto "'T no definida en la tabla' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada no está definida en la tabla de herramientas. SOLUCIÓN Todas las herramientas deben estar definidas en la tabla de herramientas, incluso las herramientas de tierra." .

ns1:Alarma_7004 a ns1:Alarma ;
    rdfs:label "Herramienta de tierra rechazada o gastada" ;
    ns1:identificador "7004" ;
    ns1:textoExtracto "'Herramienta de tierra rechazada o gastada' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada está gastada o ha sido rechazada por el PLC. SOLUCIÓN Reparar la herramienta o utilizar una herramienta equivalente." .

ns1:Alarma_7005 a ns1:Alarma ;
    rdfs:label "Herramienta rechazada o gastada y sin sustituta" ;
    ns1:identificador "7005" ;
    ns1:textoExtracto "'Herramienta rechazada o gastada y sin sustituta' DETECCIÓN Durante la ejecución. CAUSA La herramienta programada está gastada o ha sido rechazada por el PLC y en el almacén no hay otra herramienta de la misma familia. SOLUCIÓN Reparar la herramienta o habilitar en el almacén una herramienta de la misma familia que pueda ser utilizada." .

ns1:Alarma_7006 a ns1:Alarma ;
    rdfs:label "D no admitida para esta herramienta" ;
    ns1:identificador "7006" ;
    ns1:textoExtracto "'D no admitida para esta herramienta' DETECCIÓN Durante la ejecución. CAUSA Corrector de herramienta no válido. La herramienta tiene menos correctores que el programado. SOLUCIÓN Programar un corrector existente o añadir nuevos correctores a la herramienta." .

ns1:Alarma_7050 a ns1:Alarma ;
    rdfs:label "Alarma 7050: ROTATEMZ - Posición no válida" ;
    ns1:identificador "7050" ;
    ns1:textoExtracto "7050 ROTATEMZ: Posición no válida. DETECCIÓN Durante la ejecución. CAUSA La posición programada en #ROTATEMZ no es válida. SOLUCIÓN Revisar la programación." .

ns1:Alarma_7051 a ns1:Alarma ;
    rdfs:label "Alarma 7051: Número de filo no válido" ;
    ns1:identificador "7051" ;
    ns1:textoExtracto "7051 'Número de filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta tiene menos filos que el programado. SOLUCIÓN Programar un filo existente o añadir nuevos filos a la herramienta." .

ns1:Alarma_80017 a ns1:Alarma ;
    rdfs:label "Alarma 80017: Parámetro H no permitido" ;
    ns1:identificador "80017" ;
    ns1:monitoreaParametro ns1:Parametro_H ;
    ns1:textoExtracto "80017 G%D H%D: Parámetro H no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro H. SOLUCIÓN Revisar la programación." .

ns1:Alarma_80018 a ns1:Alarma ;
    rdfs:label "Alarma 80018: Parámetro I no permitido" ;
    ns1:identificador "80018" ;
    ns1:monitoreaParametro ns1:Parametro_I ;
    ns1:textoExtracto "80018 G%D I%D: Parámetro I no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro I. SOLUCIÓN Revisar la programación." .

ns1:Alarma_80019 a ns1:Alarma ;
    rdfs:label "Alarma 80019: Parámetro J no permitido" ;
    ns1:identificador "80019" ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:textoExtracto "80019 G%D J%D: Parámetro J no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro J. SOLUCIÓN Revisar la programación." .

ns1:Alarma_80020 a ns1:Alarma ;
    rdfs:label "Alarma 80020: Parámetro K no permitido" ;
    ns1:identificador "80020" ;
    ns1:monitoreaParametro ns1:Parametro_K ;
