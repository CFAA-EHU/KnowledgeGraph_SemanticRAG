ns1:Error_1287 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1287: Se espera '['"@es ;
    ns1:identificador "1287" ;
    ns1:textoExtracto "En la expresión o sentencia programada falta el corchete de apertura '['. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1288 a ns1:DiagnosticoFallo ;
