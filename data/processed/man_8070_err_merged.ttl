    ns1:identificador "2327" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2327 ;
    ns1:textoExtracto "2327 'G802/G803 XY elemento anterior debe ser un círculo' [...] SOLUCIÓN Revisar la programación." .

ns1:Alarma_2328 a ns1:Alarma ;
