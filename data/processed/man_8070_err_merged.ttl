    rdfs:label "Error en escritura de T1"@es ;
    ns1:identificador "14" ;
    ns1:textoExtracto "Error en escritura de T1."@es .

ns1:Error_1430 a ns1:DiagnosticoFallo ;
    rdfs:label "Formato numérico sobrepasado" ;
    ns1:identificador "1430" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor asignado a un dato, variable o parámetro es superior al formato establecido. SOLUCIÓN Revisar la programación." .

ns1:Error_1431 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición de cabezal en M19 no válida" ;
    ns1:identificador "1431" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor programado para la posición de cabezal en M19 es demasiado alto. SOLUCIÓN Programar un valor más pequeño." .

ns1:Error_1436 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1436: No se ha programado bloque de parada en búsqueda de bloque"@es ;
    ns1:identificador "1436" ;
    ns1:textoExtracto "1436 'No se ha programado bloque de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque."@es .

ns1:Error_1441 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1441: No se ha activado la cinemática" ;
    ns1:identificador "1441" ;
    ns1:textoExtracto "1441 'No se ha activado la cinemática' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA La cinemática que aplica el CNC por defecto (parámetro KINID) es desconocida o los ejes necesarios para la cinemática no son los adecuados." .

ns1:Error_1447 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1447: 'Opción de software no permitida'"@es ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "1447 'Opción de software no permitida' [...] Durante la ejecución."@es .

ns1:Error_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1479: 'G74: falta asociar subrutina'" ;
    ns1:identificador "1479" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay programada una función G74 sola en el bloque y no existe la subrutina asociada. SOLUCIÓN Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB)." .

ns1:Error_1480 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1480: 'Programar: #EXEC [\"path+programa\",canal]'" ;
    ns1:identificador "1480" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Error_1495 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error 1495: '#PROBE1: eje no válido para ciclo de palpador'"@es,
        "Error 1495: Eje no válido para ciclo de palpador"@es ;
    ns1:identificador "1495" ;
    ns1:solucionaFallo ns1:PROBE1_bdd9bfeed0 ;
    ns1:textoExtracto "1495 '#PROBE1: eje no válido para ciclo de palpador' DETECCIÓN Durante la"@es .

ns1:Error_1496 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1496: '#PROBE1: programación no permitida con #TOOL AX[-] activo'"@es ;
    ns1:identificador "1496" ;
    ns1:textoExtracto "1496 '#PROBE1: programación no permitida con #TOOL AX[-] activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar el ciclo PROBE1 teniendo la herramienta orientada en el sentido negativo del eje. SOLUCIÓN Programar #TOOL AX[+] antes de ejecutar el ciclo PROBE1 para orientar la herramienta en el sentido positivo del eje."@es .

ns1:Error_1497 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1497: 'Operador incorrecto para el tipo de variable'"@es ;
    ns1:identificador "1497" ;
    ns1:textoExtracto "1497 'Operador incorrecto para el tipo de variable' DETECCIÓN Durante la ejecución."@es .

ns1:Error_15 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en escritura de T4"@es ;
    ns1:identificador "15" ;
    ns1:textoExtracto "Error en escritura de T4."@es .

ns1:Error_1501 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiquetas repetidas en #RPT"@es ;
    ns1:identificador "1501" ;
    ns1:textoExtracto "'Etiquetas repetidas en #RPT' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #RPT la etiqueta inicial y final es la misma. SOLUCIÓN Definir etiquetas inicial y final diferentes."@es .

ns1:Error_1502 a ns1:DiagnosticoFallo ;
    rdfs:label "La variable requiere programación de índice de array"@es ;
    ns1:identificador "1502" ;
    ns1:textoExtracto "'La variable requiere programación de índice de array' DETECCIÓN Durante la ejecución. CAUSA La variable es de array y no se ha indicado el índice. SOLUCIÓN Consultar en los manuales la lista de variables."@es .

ns1:Error_1503 a ns1:DiagnosticoFallo ;
    rdfs:label "La variable requiere programación de eje"@es ;
    ns1:identificador "1503" ;
    ns1:textoExtracto "'La variable requiere programación de eje' DETECCIÓN Durante la ejecución. CAUSA La variable es de eje y no se ha indicado el nombre del eje. SOLUCIÓN Consultar en los manuales la lista de variables."@es .

ns1:Error_1504 a ns1:DiagnosticoFallo ;
    rdfs:label "La variable no permite programación de índice de array"@es ;
    ns1:identificador "1504" ;
    ns1:textoExtracto "'La variable no permite programación de índice de array' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la variable es incorrecta. SOLUCIÓN Consultar en los manuales la lista de variables."@es .

ns1:Error_1505 a ns1:DiagnosticoFallo ;
    rdfs:label "La variable no permite programación de eje"@es ;
    ns1:identificador "1505" ;
    ns1:textoExtracto "'La variable no permite programación de eje' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la variable es incorrecta. SOLUCIÓN Consultar en los manuales la lista de variables."@es .

ns1:Error_1506 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta no definida o etiquetas del comando #RPT intercambiadas"@es ;
    ns1:identificador "1506" ;
    ns1:textoExtracto "'Etiqueta no definida o etiquetas del comando #RPT intercambiadas' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Falta definir la segunda etiqueta. • Se ha programado M30 entre la primera y la segunda etiqueta. • En la sentencia #RPT se ha programado primero la segunda etiqueta y luego la primera. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1507 a ns1:DiagnosticoFallo ;
    rdfs:label "La segunda etiqueta del #RPT debe programarse sola en el bloque"@es ;
    ns1:identificador "1507" ;
    ns1:textoExtracto "'La segunda etiqueta del #RPT debe programarse sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA En una repetición de bloques (#RPT), la segunda etiqueta debe programarse sola en el bloque, sin ningún otro tipo de información. SOLUCIÓN La etiqueta final se debe programar sola en el bloque. Programar el comando en la línea anterior si se desea que se ejecute con el #RPT o en la línea inferior si no se desea que se ejecute con el #RPT."@es .

ns1:Error_1549 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1549: Nombre de cajera nulo o incorrecto" ;
    ns1:identificador "1549" ;
    ns1:textoExtracto "1549 'Nombre de cajera nulo o incorrecto' DETECCIÓN Durante la ejecución. CAUSA Cuando se ha definido una cajera 2D ó 3D con el editor de ciclos, no se ha definido el nombre de la cajera o este nombre es incorrecto. No se permiten como nombre de cajera las instrucciones #DATAP2D y #DATAP3D generadas por el editor de ciclos. SOLUCIÓN Asignarle un nombre distinto a la cajera." .

ns1:Error_1550 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1550: No se admite programar dos ejes C en el mismo canal" ;
    ns1:identificador "1550" ;
    ns1:textoExtracto "1550 'No se admite programar dos ejes C en el mismo canal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un eje C con otro activo. SOLUCIÓN Desactivar un eje C antes de activar otro." .

ns1:Error_1551 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1551: Imbricación de parámetros locales sobrepasado" ;
    ns1:identificador "1551" ;
    ns1:textoExtracto "1551 'Imbricación de parámetros locales sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El anidamiento de llamadas a subrutinas mediante la sentencia #PCALL o mediante la función G180-G189 aumenta el nivel de imbricación de parámetros locales. El error se da porque se supera el máximo nivel de imbricación de parámetros locales que es 7. SOLUCIÓN Reducir el anidamiento de subrutinas o utilizar las sentencias #CALL, L o LL para llamarlas, que no aumentan el nivel de imbricación de parámetros locales." .

ns1:Error_1552 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1552: El nombre de la variable debe comenzar por 'V.'" ;
    ns1:identificador "1552" ;
    ns1:textoExtracto "1552 'El nombre de la variable debe comenzar por \"V.\"' DETECCIÓN Durante la ejecución. CAUSA Desde programa pieza o MDI se ha escrito el nombre de una variable sin el prefijo inicial \"V.\" SOLUCIÓN Añadir el prefijo \"V.\" al nombre de la variable." .

ns1:Error_1553 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1553: Número de variables de usuario sobrepasado" ;
    ns1:identificador "1553" ;
    ns1:textoExtracto "1553 'Número de variables de usuario sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el máximo número de variables de usuario (prefijos P y S) permitidas. SOLUCIÓN El máximo número de variables de usuario permitido es 20." .

ns1:Error_16 a ns1:DiagnosticoFallo ;
