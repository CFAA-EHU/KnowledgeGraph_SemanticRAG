    ns1:textoExtracto "No hay herramienta programada. Si una operación no tiene herramienta, el ciclo no la ejecuta." .

ns1:Fallo_1792 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera",
        "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1792" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo.",
        "1792 'CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera' DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el radio de la herramienta es mayor que el radio de la cajera (parámetro R). SOLUCIÓN Elegir una herramienta de menor diámetro."@es .

ns1:Fallo_1793 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1793" ;
    ns1:textoExtracto "1793 'CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las"@es .

ns1:Fallo_1832 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1832: Desbaste I=0" ;
    ns1:identificador "1832" ;
    ns1:textoExtracto "1832 'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta." .

ns1:Fallo_2153 a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria helicoidal cercana al centro de giro del FACE"@es ;
    ns1:identificador "2153" ;
    ns1:textoExtracto "2153 'Trayectoria helicoidal cercana al centro de giro del FACE' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una trayectoria helicoidal de más de una vuelta, en una zona cercana al centro de giro del FACE. SOLUCIÓN Cambiar la trayectoria de mecanizado."@es .

ns1:Fallo_2154 a ns1:DiagnosticoFallo ;
    rdfs:label "Retardo del palpador mal ajustado",
        "Retardo del palpador mal configurado"@es ;
    ns1:identificador "2154" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "PROBEDELAY" ;
            ns1:textoExtracto "Parametrizar PROBEDELAY %f." ;
            ns1:valor "PROBEDELAY" ] ;
    ns1:textoExtracto "2154 Retardo del palpador mal ajustado. Parametrizar PROBEDELAY %f.",
        "DETECCIÓN Durante la ejecución. CAUSA El valor calculado de PROBEDELAY no coincide con el valor definido en el parámetro máquina. SOLUCIÓN Definir el parámetro PROBEDELAY con el valor indicado en el mensaje. También puede utilizar ciclo de calibración de palpador (#PROBE 2) para calcular el valor correcto.",
        "2154 Retardo del palpador mal"@es .

ns1:Fallo_2365 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Doble programación del incremento/decremento del paso de husillo" ;
    ns1:identificador "2365" ;
    ns1:textoExtracto "2365 G34: Doble programación del incremento/decremento del paso de husillo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado más de una vez el incremento/decremento del paso de husillo (K1) SOLUCIÓN Programar el incremento/decremento del paso de husillo una única vez en el bloque." .

ns1:Fallo_2366 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo igual a cero" ;
    ns1:identificador "2366" ;
    ns1:textoExtracto "2366 G34: Incremento/decremento del paso de husillo igual a cero. DETECCIÓN Durante la ejecución. CAUSA El incremento/decremento del paso de husillo (K1) para G34 es cero. SOLUCIÓN Programar un incremento/decremento del paso de husillo (K1) para G34." .

ns1:Fallo_2367 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo fuera de rango" ;
    ns1:identificador "2367" ;
    ns1:textoExtracto "2367 G34: Incremento/decremento del paso de husillo fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El valor del incremento/decremento del paso de husillo en G34 es incorrecto. SOLUCIÓN Programar un valor correcto del incremento/decremento del paso de husillo (K1)." .

ns1:Fallo_2368 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo demasiado grande" ;
    ns1:identificador "2368" ;
    ns1:textoExtracto "2368 G34: Incremento/decremento del paso de husillo demasiado grande. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un incremento del paso de husillo superior a dos veces el paso de rosca. SOLUCIÓN Programar un valor correcto del incremento del paso de husillo (K1)." .

ns1:Fallo_2369 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Paso final de husillo negativo o nulo" ;
    ns1:identificador "2369" ;
    ns1:textoExtracto "2369 G34: Paso final de husillo negativo o nulo. DETECCIÓN Durante la ejecución. CAUSA Con el paso de husillo y el decremento de paso de husillo programados en G34, el paso final de rosca calculado por el control es negativo o cero. SOLUCIÓN Programar correctamente el paso y el decremento de paso de husillo en G34" .

ns1:Fallo_2376_LSFIT a ns1:DiagnosticoFallo ;
