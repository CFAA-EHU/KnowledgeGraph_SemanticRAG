ns1:Error_8015 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Eje en movimiento o en sincronización" ;
    ns1:identificador "8015" ;
    ns1:solucionaFallo ns1:EjeCNC ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ns1:Error_8016 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en marcha" ;
    ns1:identificador "8016" ;
    ns1:solucionaFallo ns1:CabezalCNC ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ns1:Error_8017 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en sincronización" ;
    ns1:identificador "8017" ;
    ns1:solucionaFallo ns1:CabezalCNC ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ns1:Error_8018 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC mientras se encuentre en ejecución o interrumpido" ;
    ns1:identificador "8018" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC." .

ns1:Error_8019 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC mientras algún canal se encuentre en ejecución o interrumpido" ;
    ns1:identificador "8019" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si algún canal se encuentra en ejecución o interrumpido. SOLUCIÓN Detener los programas en ejecución." .

ns1:Error_8020 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Eje en movimiento o en sincronización" ;
    ns1:identificador "8020" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ns1:Error_8021 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Cabezal en marcha" ;
    ns1:identificador "8021" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ns1:Error_8022 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Cabezal en sincronización" ;
    ns1:identificador "8022" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ns1:Error_8023 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria en disco por debajo del mínimo recomendado" ;
    ns1:identificador "8023" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Error_8024 a ns1:DiagnosticoFallo ;
    rdfs:label "CNC trabajando en Modo Puesta a Punto" ;
    ns1:identificador "8024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ns1:Error_8025 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8025: Cambio de fecha detectado"@es ;
    ns1:identificador "8025" ;
    ns1:solucionaFallo ns1:Solucion_8025 ;
    ns1:textoExtracto "'Se ha detectado un cambio de fecha y ha sido necesario restaurarla' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un cambio de fecha u hora y los ha restaurado a sus valores esperados. SOLUCIÓN Compruebe si la fecha y hora son correctos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8026: Protección OEM activada"@es ;
    ns1:identificador "8026" ;
    ns1:solucionaFallo ns1:Solucion_8026 ;
    ns1:textoExtracto "'Protección de OEM activada:Los cambios tendrán carácter temporal' DETECCIÓN Durante la edición de programas, programa PLC o parámetros máquina. CAUSA El CNC está en modo usuario, con la protección de OEM activada, por lo que todo cambio tendrá carácter temporal y se perderá al apagar el CNC. SOLUCIÓN Apagar el CNC y utilizar la utilidad DiskMonitor para pasar a modo puesta a punto. Volver a arrancar el CNC."@es .

ns1:Error_8027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8027: Fallo en arranque del Kernel"@es ;
    ns1:identificador "8027" ;
    ns1:solucionaFallo ns1:Solucion_8027 ;
    ns1:textoExtracto "'Error arrancando Kernel' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel está arrancado pero no está activado. SOLUCIÓN Comprobar si el CNC ha arrancado correctamente. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8028 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8028: Compilador PLC no disponible"@es ;
    ns1:identificador "8028" ;
    ns1:solucionaFallo ns1:Solucion_8028 ;
    ns1:textoExtracto "'Compilador no disponible' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentra instalado el compilador de PLC. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8029: Includes PLC no disponibles"@es ;
    ns1:identificador "8029" ;
    ns1:solucionaFallo ns1:Solucion_8029 ;
    ns1:textoExtracto "'Includes del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instalados los includes necesarios para compilar el PLC. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8030: Librerías PLC no disponibles"@es ;
    ns1:identificador "8030" ;
    ns1:solucionaFallo ns1:Solucion_8030 ;
    ns1:textoExtracto "'Librerias del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC."@es .

ns1:Error_8031 a ns1:AvisoSeguridad ;
    rdfs:label "'La carpeta DRIVERS no existe'" ;
    ns1:identificador "8031" ;
    ns1:mitigaRiesgo ns1:Solucion_8031 ;
    ns1:textoExtracto "CNC no ha encontrado la carpeta en la que se ubicará el PLC una vez generado (C:\\CNC8070\\Drivers). DETECCIÓN Durante el arranque del sistema."@es .

ns1:Error_8032 a ns1:AvisoSeguridad ;
    rdfs:label "'La carpeta USERS no existe'" ;
    ns1:identificador "8032" ;
    ns1:mitigaRiesgo ns1:Solucion_8032 ;
    ns1:textoExtracto "El CNC no ha encontrado la carpeta de trabajo del usuario (C:\\CNC8070\\Users). DETECCIÓN Durante el arranque del sistema."@es .

ns1:Error_8034 a ns1:AvisoSeguridad ;
    rdfs:label "'Puesta a punto incompleta: No se ha encontrado ninguna copia de seguridad'" ;
    ns1:identificador "8034" ;
    ns1:mitigaRiesgo ns1:Solucion_8034 ;
    ns1:textoExtracto "El CNC no ha encontrado ninguna copia de seguridad de la puesta a punto. DETECCIÓN Durante el arranque del sistema, en modo puesta a punto."@es .

ns1:Error_8035 a ns1:AvisoSeguridad ;
    rdfs:label "'Los siguientes passwords de acceso están aún por definir'" ;
    ns1:identificador "8035" ;
    ns1:mitigaRiesgo ns1:Solucion_8035 ;
    ns1:textoExtracto "Los passwords de acceso indicados en el aviso no están definidos. DETECCIÓN Durante el arranque de un CNC abierto, en modo puesta a punto."@es .

ns1:Error_8036 a ns1:AvisoSeguridad ;
    rdfs:label "'Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC'" ;
    ns1:identificador "8036" ;
    ns1:mitigaRiesgo ns1:Solucion_8036 ;
    ns1:textoExtracto "Solo se permite trabajar con el CNC en los modos usuario y modo puesta a punto. DETECCIÓN Durante el arranque del sistema, en modo setup."@es .

ns1:Error_8051 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8051: Datos de CNC corruptos o inaccesibles" ;
    ns1:identificador "8051" ;
    ns1:textoExtracto "usuario no es accesible o está corrupto. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc pueden haberse perdido. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:Error_8052 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8052: Límite de ejes y cabezales superado" ;
    ns1:identificador "8052" ;
    ns1:textoExtracto "8052 La suma de ejes y cabezales no debe superar el valor máximo. DETECCIÓN Durante el arranque del CNC. CAUSA La suma de ejes de cabezales supera el valor máximo. SOLUCIÓN El CNC tiene limitado el número de máximo de ejes, de cabezales y la suma de ambos. La configuración supera el límite de ejes más cabezales." .

ns1:Error_8053 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8053: Licencia temporal a punto de expirar" ;
    ns1:identificador "8053" ;
    ns1:textoExtracto "8053 El periodo de servicio esta a punto de expirar. Contacte con el OEM para obtener un código de actualización. DETECCIÓN Durante el arranque del CNC o cuando haya pasado un día desde el último aviso. CAUSA El CNC tiene activa la licencia de uso temporal y quedan siete días para que la licencia expire." .

ns1:Error_8054 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8054: Licencia temporal expirada" ;
    ns1:identificador "8054" ;
    ns1:textoExtracto "8054 El periodo de servicio ha expirado. Contacte con el OEM para obtener un código de actualización. DETECCIÓN Durante el arranque del CNC, al pulsar la tecla [START] o cuando haya pasado un día desde el último aviso. CAUSA La licencia de uso temporal ha expirado. El CNC no acepta la tecla [START]." .

ns1:Error_8055 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8055: CNC bloqueado por violación de términos" ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "8055 El CNC ha sido bloqueado debido a una violación de los términos de uso. Contacte con el OEM. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC está bloqueado porque ha detectado un cambio de fecha no permitido." .

ns1:Error_8128 a ns1:DiagnosticoFallo ;
    rdfs:label "No se han podido recuperar los datos de FRAM" ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "8128 No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM." .

ns1:Error_8203 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8203: Falta apertura de comentarios" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8203" ;
    ns1:textoExtracto "8203 'Falta apertura de comentarios' DETECCIÓN Durante la edición. CAUSA Programado el carácter de cierre de comentario sin haber programado antes el carácter de comienzo. SOLUCIÓN Comprobar que los comentarios tienen tanto el carácter de apertura \"(\" como el de cierre \")\"." .

ns1:Error_8205 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8205: Falta '$'" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8205" ;
    ns1:textoExtracto "8205 'Falta \"$\"' DETECCIÓN Durante la edición. CAUSA Programada una instrucción de control sin el carácter de inicio \"$\". SOLUCIÓN Programar \"$\" antes del nombre de la instrucción de control." .

ns1:Error_8218 a ns1:AvisoSeguridad ;
    rdfs:label "Carácter no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8218" ;
    ns1:textoExtracto "8218 'Carácter no válido' DETECCIÓN Durante la edición. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque." .

ns1:Error_8219 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de error vacía" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8219" ;
    ns1:textoExtracto "8219' Cadena de error vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8220 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de Warning vacía" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8220" ;
    ns1:textoExtracto "8220 'Cadena de Warning vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8221 a ns1:AvisoSeguridad ;
    rdfs:label "Error sintáctico" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8221" ;
    ns1:textoExtracto "8221 'Error sintáctico' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia o variable programada no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable." .

ns1:Error_8222 a ns1:AvisoSeguridad ;
    rdfs:label "Función M inexistente" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8222" ;
    ns1:textoExtracto "8222 'Función M inexistente' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:Error_8223 a ns1:AvisoSeguridad ;
    rdfs:label "Exclusividad mutua o funciones M iguales" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8223" ;
    ns1:textoExtracto "8223 'Exclusividad mutua o funciones M iguales' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Hay una función M programada más de una vez en el mismo bloque o hay dos funciones M incompatibles en el mismo bloque. SOLUCIÓN Una función M sólo debe programarse una vez en el bloque. Revisar el manual de programación para comprobar la exclusividad mutua de las funciones M." .

ns1:Error_8224 a ns1:AvisoSeguridad ;
    rdfs:label "Función M fuera de rango" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8224" ;
    ns1:textoExtracto "8224 'Función M fuera de rango' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:Error_8225 a ns1:AvisoSeguridad ;
    rdfs:label "Función G fuera de rango" ;
    ns1:identificador "8225" ;
    ns1:textoExtracto "8225 'Función G fuera de rango' DETECCIÓN Durante la edición y ejecución en MDI." .

ns1:Error_8258 a ns1:DiagnosticoFallo ;
    rdfs:label "'Se esperaba expresión tras #TIME'"@es ;
    ns1:identificador "8258" ;
    ns1:textoExtracto "8258 'Se esperaba expresión tras #TIME' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Sentencia #TIME programada incorrectamente. SOLUCIÓN Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde"@es .

ns1:Error_8265 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8265: 'Palabra desconocida o incompleta'" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8265" ;
    ns1:solucionaFallo ns1:FuncionMParaCabezal_a3bb1b61fe,
        ns1:Sentencia_TIME,
        ns1:Sentencia_TOOL_AX ;
    ns1:textoExtracto "8265 'Palabra desconocida o incompleta' DETECCIÓN Durante la edición. CAUSA Las posibles causas son las siguientes: • La función, sentencia o expresión programada no es válida. • Programación incorrecta de la función M para un determinado cabezal. • Programación incorrecta de la sentencia #TOOL AX. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." .

ns1:Error_8267 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8267: 'Variable de ciclo sin permiso de escritura'" ;
    ns1:identificador "8267" ;
    ns1:textoExtracto "8267 'Variable de ciclo sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:Error_8268 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8268: 'Argumento fuera de límites en función'" ;
    ns1:identificador "8268" ;
    ns1:solucionaFallo ns1:FuncionesMatematicas ;
    ns1:textoExtracto "8268 'Argumento fuera de límites en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido. SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

