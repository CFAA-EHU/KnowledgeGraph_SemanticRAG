    ns1:mitigaRiesgo ns1:RadioDeHerramienta ;
    ns1:monitoreaParametro ns1:RadioDeEntradaSalidaTangencial_762943f95c,
        ns1:RadioDeLaHerramientaDeSemiacabado_f00267aa83 ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Alarma1800RANURADORadioDeHerramienta0_422d1a5eb4 a ns1:Alarma ;
    rdfs:label "Alarma 1800: RANURADO - Radio de herramienta = 0" ;
    ns1:identificador "1800" ;
    ns1:monitoreaParametro ns1:RadioDeHerramienta_eeda05fbf1 ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Alarma1801CAJERARECTANGULARAnguloFueraDeRango_afa7cef40c a ns1:Alarma ;
    rdfs:label "Alarma 1801: CAJERA RECTANGULAR - Ángulo β/θ fuera de rango" ;
