    ns1:textoExtracto "Encóder o cabeza de la regla dañado. Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Diagnostico_Encoder_9628 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 9628 (Encoder)" ;
    ns1:solucionaFallo ns1:Alarma_9628 ;
    ns1:textoExtracto "SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado." .

ns1:Diagnostico_ErrorRenombrarHerramienta a ns1:DiagnosticoFallo ;
