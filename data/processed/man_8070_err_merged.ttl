        ns1:ComponenteElectrico_SistemaCaptacion,
        ns1:ComponenteMecanico_Eje ;
    ns1:textoExtracto "Revisar los parámetros máquina, el ajuste del eje, el conexionado, el estado del regulador y el sistema captación-motor."@es .

ns1:DiagnosticoFallo_3703 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de parámetros para límite de software positivo 3703"@es ;
    ns1:solucionaFallo ns1:Parametro_LIMIT,
