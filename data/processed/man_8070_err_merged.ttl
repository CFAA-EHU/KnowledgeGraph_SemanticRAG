    rdfs:label "Programación no permitida con detección de colisiones activa (2017)" ;
    ns1:identificador "2017" ;
    ns1:textoExtracto "'Programación no permitida con detección de colisiones activa' DETECCIÓN Durante la ejecución. CAUSA La detección de colisiones no admite ciertos procesos como búsqueda de cero, movimiento con palpador, etc. SOLUCIÓN No activar la detección de colisiones si hay alguno de estos procesos programado." .

ns1:DiagnosticoFallo_2021 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga de CPU en detección de colisiones (2021)" ;
    ns1:identificador "2021" ;
    ns1:textoExtracto "Sobrecarga de CPU en el cálculo de detección de colisiones. DETECCIÓN Durante la preparación de bloques. CAUSA El modelo de la máquina y/o elementos colisionables es demasiado complejo. SOLUCIÓN Simplificar el modelo de la máquina." .

ns1:DiagnosticoFallo_2051 a ns1:DiagnosticoFallo ;
    rdfs:label "Splines y control tangencial incompatibles (2051)" ;
    ns1:identificador "2051" ;
    ns1:textoExtracto "'Programación de splines y control tangencial incompatibles' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite activar el control tangencial con las splines activas ni viceversa. SOLUCIÓN Desactivar los splines antes activar el control tangencial o viceversa." .

ns1:DiagnosticoFallo_2100 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite software positivo sobrepasado (2100)" ;
    ns1:identificador "2100" ;
    ns1:textoExtracto "'Límite software positivo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_2139 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento nulo en roscado" ;
    ns1:identificador "2139" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El eje de roscado no se encuentra en el canal. SOLUCIÓN Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar la rosca." .

ns1:DiagnosticoFallo_2141 a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria circular no permitida sin dos ejes en el plano principal" ;
    ns1:identificador "2141" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se permiten trayectorias circulares si no hay al menos dos ejes en el canal. SOLUCIÓN Configurar el canal con al menos dos ejes." .

ns1:DiagnosticoFallo_2142 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con eje(s) Hirth" ;
    ns1:identificador "2142" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha programado un comando incompatible con un eje hirth. SOLUCIÓN Revisar programación." .

ns1:DiagnosticoFallo_2143 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede calcular la tangente al spline" ;
    ns1:identificador "2143" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se puede calcular la tangente para deseleccionar el spline. SOLUCIÓN Deseleccionar el spline en otro punto o programar otra tangente." .

ns1:DiagnosticoFallo_2144 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la generación del spline" ;
    ns1:identificador "2144" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se ha programado el primer bloque para activar el spline. SOLUCIÓN Programar un movimiento antes de activar el spline." .

ns1:DiagnosticoFallo_2145 a ns1:DiagnosticoFallo ;
    rdfs:label "Final del programa sin desactivar splines" ;
    ns1:documentadoEn ns1:Maquina_CNC ;
    ns1:identificador "2145" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha alcanzado el final del programa con el modo spline activo. SOLUCIÓN Anular el spline antes de finalizar el programa." .

ns1:DiagnosticoFallo_2146 a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible la desactivación del spline" ;
    ns1:identificador "2146" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Número insuficiente de bloques para desactivar el spline." .

ns1:DiagnosticoFallo_2388 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_2388 ;
    ns1:textoExtracto "Existen dos posibilidades. • El valor programado en G122 no es correcto. • El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto." .

ns1:DiagnosticoFallo_2394 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2394: Estado de zona de trabajo no programado" ;
    ns1:identificador "2394" ;
    ns1:solucionaFallo ns1:Parametro_E ;
    ns1:textoExtracto "2394 Estado de la zona de trabajo no programado. [...] SOLUCIÓN Programar el estado de la zona de trabajo en el parámetro 'E'; de 0 a 2." .

ns1:DiagnosticoFallo_2395 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2395: Ejes rotativos tipo módulo no permitidos" ;
    ns1:identificador "2395" ;
    ns1:textoExtracto "2395 'No se permite programar el centro con ejes rotativos tipo módulo' [...] SOLUCIÓN No se permite definir el centro con ejes rotativos tipo módulo." .

ns1:DiagnosticoFallo_2396 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2396: #GAPCTRL programado en otro canal" ;
    ns1:identificador "2396" ;
    ns1:textoExtracto "2396 #GAPCTRL programado en otro canal. [...] SOLUCIÓN Sólo puede haber activo un control de gap en el CNC." .

ns1:DiagnosticoFallo_2397 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2397: Modificación de parámetros con #GAPCTRL activo" ;
    ns1:identificador "2397" ;
    ns1:textoExtracto "2397 #GAPCTRL ON activo.#GAPCTRL OFF necesario para cambiar parámetros. [...] SOLUCIÓN Desactivar #GAPCTRL antes de modificar sus parámetros." .

ns1:DiagnosticoFallo_2398 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2398: Falta programación de POSLIMIT en #LEAP" ;
    ns1:identificador "2398" ;
    ns1:textoExtracto "2398 #LEAP:falta programación de POSLIMIT. [...] SOLUCIÓN La primera vez que se programa #LEAP es obligatorio programar el comando POSLIMIT." .

ns1:DiagnosticoFallo_2399 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2399: Intento de alterar POS con #LEAP activo" ;
    ns1:identificador "2399" ;
    ns1:textoExtracto "2399 #LEAP activo. No se puede alterar POS, posición final del salto. [...] SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_2400 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2400: Número lógico de eje fuera de rango" ;
    ns1:identificador "2400" ;
    ns1:solucionaFallo ns1:Parametro_NAXIS ;
    ns1:textoExtracto "2400 Número lógico de eje fuera de rango. [...] SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)." .

ns1:DiagnosticoFallo_2437 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2437: Perfil no recto en macro G8077" ;
    ns1:identificador "2437" ;
    ns1:solucionaFallo ns1:Macro_G8077 ;
    ns1:textoExtracto "El perfil de la macro G8077 es poligonal. [...] SOLUCIÓN Modificar el perfil." .

ns1:DiagnosticoFallo_2438 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2438: #GAPCTRL ON no programado antes de #LEAP" ;
    ns1:identificador "2438" ;
    ns1:solucionaFallo ns1:Comando_LEAP ;
    ns1:textoExtracto "#LEAP[GAP] XY sin programar previamente #GAPCTRL ON. [...] SOLUCIÓN Las posibles soluciones son las siguientes: • Programar #GAPCTRL ON antes del #LEAP donde se detecta el error • Eliminar el parámetro GAP de los comandos #LEAP." .

ns1:DiagnosticoFallo_2439 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2439: Nodo no programado tras \".\"" ;
    ns1:identificador "2439" ;
    ns1:solucionaFallo ns1:Nodo_Sercos ;
    ns1:textoExtracto "Programar el número de nodo tras el \".\". [...] SOLUCIÓN Programar un nodo entre 1 y 32." .

ns1:DiagnosticoFallo_2440 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2440: Nodo Sercos inexistente" ;
    ns1:identificador "2440" ;
    ns1:solucionaFallo ns1:Nodo_Sercos ;
    ns1:textoExtracto "Nodo inexistente. [...] SOLUCIÓN Programar un nodo entre 1 y 32." .

ns1:DiagnosticoFallo_2441 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2441: Doble programación de #FINALSUB" ;
    ns1:identificador "2441" ;
    ns1:solucionaFallo ns1:Comando_FINALSUB ;
    ns1:textoExtracto "Doble programación de #FINALSUB. [...] SOLUCIÓN Programar una única vez #FINALSUB." .

ns1:DiagnosticoFallo_2442 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2442: Función G8753 fuera de macro G8754" ;
    ns1:identificador "2442" ;
    ns1:solucionaFallo ns1:Funcion_G8753 ;
    ns1:textoExtracto "Programación no permitida fuera de una macro G8754. [...] SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_2507 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2507: Coordenadas no permitidas en G107"@es ;
    ns1:solucionaFallo ns1:Alarma_2507 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Programar las cotas en coordenadas cartesianas."@es .

ns1:DiagnosticoFallo_2508 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2508: Valor fuera de rango"@es ;
    ns1:solucionaFallo ns1:Alarma_2508 ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor a escribir."@es .

ns1:DiagnosticoFallo_3007 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3007" ;
    ns1:solucionaFallo ns1:Alarma_3007 ;
    ns1:textoExtracto "Proceso de palpado habilitado sin G100 programada." .

ns1:DiagnosticoFallo_3009 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3009" ;
    ns1:solucionaFallo ns1:Alarma_3009 ;
    ns1:textoExtracto "Revisar la parametrización del palpador y señales físicas." .

ns1:DiagnosticoFallo_3013 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3013" ;
    ns1:solucionaFallo ns1:Alarma_3013 ;
    ns1:textoExtracto "Disminuir el avance de palpado o disminuir el error de seguimiento." .

ns1:DiagnosticoFallo_3015 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 3015: búsqueda de referencia ignorada"@es ;
    ns1:identificador "3015" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3015 ;
    ns1:textoExtracto "SOLUCIÓN: Hacer la búsqueda de referencia máquina fuera del programa."@es .

ns1:DiagnosticoFallo_3015_Alternativo a ns1:DiagnosticoFallo ;
    rdfs:label "Solución alternativa para error de seguimiento"@es ;
    ns1:textoExtracto "SOLUCIÓN: Disminuir el avance de palpado o disminuir el error de seguimiento."@es .

ns1:DiagnosticoFallo_3063 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio a lazo cerrado en sincronización"@es ;
    ns1:identificador "3063" ;
    ns1:solucionaFallo ns1:ComponenteMecanico_CabezalMaster ;
    ns1:textoExtracto "El cabezal master de la sincronización pasa a lazo cerrado. DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una sincronización en lazo cerrado (CLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo abierto. SOLUCIÓN El CNC informa del cambio; no es necesaria ninguna acción."@es .

ns1:DiagnosticoFallo_3064 a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal no referenciado para roscado G33/G34"@es ;
    ns1:identificador "3064" ;
    ns1:solucionaFallo ns1:ComponenteMecanico_CabezalRoscado ;
    ns1:textoExtracto "El cabezal para roscar con G33/G34 debe de estar referenciado. DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado en el roscado G33/G34 no está referenciado. SOLUCIÓN Si el CNC utiliza el cabezal master del canal, siempre realiza una búsqueda de referencia antes de G33/G34. Si el PLC selecciona otro cabezal (marca SYNC), realizar una búsqueda de referencia del cabezal."@es .

ns1:DiagnosticoFallo_3065 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de giro supera umbral del encóder en G33/G34"@es ;
    ns1:identificador "3065" ;
    ns1:monitoreaParametro ns1:Sensor_EncoderCabezal ;
    ns1:solucionaFallo ns1:ComponenteMecanico_CabezalRoscado ;
    ns1:textoExtracto "Velocidad de giro de cabezal programada para G33/G34 supera el umbral del encóder. DETECCIÓN Durante la ejecución. CAUSA La velocidad programada para la función G33/G34 superó el umbral permitido por el encóder instalado en el cabezal. SOLUCIÓN El CNC no permite ejecutar la G33/G34 con la velocidad programada, ya que no puede garantizar la validez de la rosca. Si el cabezal ha superado la velocidad umbral, el CNC necesita referenciar el cabezal para recuperar la cota."@es .

ns1:DiagnosticoFallo_3066 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en seguimiento del eje tangencial"@es ;
    ns1:identificador "3066" ;
    ns1:solucionaFallo ns1:ComponenteMecanico_EjeTangencial ;
    ns1:textoExtracto "Error en el seguimiento del eje tangencial sobre la trayectoria. DETECCIÓN Durante la ejecución. CAUSA El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo. SOLUCIÓN Póngase en contacto con FAGOR."@es .

ns1:DiagnosticoFallo_3067 a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal sin encóder para control de posición" ;
    ns1:solucionaFallo ns1:Alarma_3067 ;
    ns1:textoExtracto "CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste no dispone de encóder. SOLUCIÓN El cabezal necesita un encóder." .

ns1:DiagnosticoFallo_3068 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca RETRACE activa tras finalización" ;
    ns1:solucionaFallo ns1:Alarma_3068 ;
    ns1:textoExtracto "Tras finalizar la ejecución en retrace, la marca RETRACE del PLC sigue activa. SOLUCIÓN El PLC debe desactivar la marca RETRACE para que el programa continúe." .

ns1:DiagnosticoFallo_3069 a ns1:DiagnosticoFallo ;
    rdfs:label "Regulador sin respuesta en cambio de gama" ;
    ns1:solucionaFallo ns1:Alarma_3069 ;
    ns1:textoExtracto "El CNC no ha finalizado correctamente el cambio de gama de un eje o cabezal porque el regulador no responde a la petición de cambio de gama. SOLUCIÓN Comprobar estado del regulador." .

ns1:DiagnosticoFallo_3070 a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal parado en funciones G33/G34/G95" ;
    ns1:solucionaFallo ns1:Alarma_3070 ;
    ns1:textoExtracto "El cabezal asociado a la función G33, G34 o G95 está parado. SOLUCIÓN Comprobar la velocidad del cabezal asociado a estas funciones, que será el cabezal master del canal o el cabezal indicado en el registro SYNC, asociado al canal." .

ns1:DiagnosticoFallo_3071 a ns1:DiagnosticoFallo ;
    rdfs:label "Interrupción no permitida durante cambio de gama" ;
    ns1:solucionaFallo ns1:Alarma_3071 ;
    ns1:textoExtracto "El usuario ha interrumpido el programa durante el cambio de gama y ha intentado cambiar las funciones S, M ó H desde el modo MHFS. SOLUCIÓN Continuar la ejecución hasta que finalice el cambio de gama. A continuación interrumpir el programa y enviar las funciones deseadas al cabezal." .

ns1:DiagnosticoFallo_3089 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3089: Transformada inversa del eje virtual (#VIRTAX)" ;
    ns1:identificador "3089" ;
    ns1:textoExtracto "3089 'Error en el cálculo de la transformada inversa del eje virtual de la herramienta, #VIRTAX' [...] CAUSA La transformación de coordenadas pieza a máquina es imposible de ejecutar." .

ns1:DiagnosticoFallo_3090 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3090: Transformada directa del eje virtual (#VIRTAX)" ;
    ns1:identificador "3090" ;
    ns1:textoExtracto "3090 'Error en el cálculo de la transformada directa del eje virtual de la herramienta, #VIRTAX' [...] CAUSA La transformación de coordenadas máquina a pieza es imposible de ejecutar." .

ns1:DiagnosticoFallo_3092 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3092: Límite de zona de trabajo sobrepasado" ;
    ns1:identificador "3092" ;
    ns1:textoExtracto "3092 'Límite de zona de trabajo sobrepasado' [...] CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra fuera de una zona de trabajo de no salida." .

ns1:DiagnosticoFallo_3093 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3093: Punto dentro de zona prohibida" ;
    ns1:identificador "3093" ;
    ns1:textoExtracto "3093 'Punto dentro de zona prohibida' [...] CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra dentro de una zona de trabajo de no entrada." .

ns1:DiagnosticoFallo_3413 a ns1:DiagnosticoFallo ;
