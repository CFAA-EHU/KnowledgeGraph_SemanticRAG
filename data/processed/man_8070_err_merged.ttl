    ns1:identificador "1387" ;
    ns1:textoExtracto "'Límite de funciones M en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones M de las permitidas." .

ns1:Alarma1395LaFuncionG74ConSubrutinaAsociadaSeProgramaSolaEnElBloque_99ff8aadc2 a ns1:Alarma ;
    rdfs:label "Alarma 1395: 'La función G74 con subrutina asociada se programa sola en el bloque'"@es ;
    ns1:identificador "1395" ;
    ns1:textoExtracto "'La función G74 con subrutina asociada se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA Si la función G74 tiene subrutina asociada, se debe programar sola en el bloque o junto a la etiqueta del bloque."@es .

ns1:Alarma1405_130c85fe50 a ns1:Alarma ;
    rdfs:label "Alarma 1405" ;
    ns1:identificador "1405" ;
    ns1:textoExtracto "'El valor de la S supera la gama máxima' DETECCIÓN Durante la ejecución." .

ns1:Alarma1427EjeMalProgramado_5c37d29273 a ns1:Alarma ;
    rdfs:label "Alarma 1427: 'Eje mal programado'"@es ;
    ns1:identificador "1427" ;
    ns1:solucionaFallo ns1:ErrorDeProgramacionDeEjeG74G20 ;
    ns1:textoExtracto "1427 'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1428ElMovimientoEnElPlanoPrincipalDebeProgramarseAntesDeLaGDelCiclo_5a39f35595 a ns1:Alarma ;
    rdfs:label "Alarma 1428: 'El movimiento en el plano principal debe programarse antes de la G del ciclo'"@es ;
    ns1:identificador "1428" ;
    ns1:solucionaFallo ns1:ErrorDeSecuenciaEnProgramacionDeCiclo ;
    ns1:textoExtracto "1428 'El movimiento en el plano principal debe programarse antes de la G del ciclo' DETECCIÓN Durante la ejecución. CAUSA Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo. El ciclo considera las coordenadas del punto inicial como parámetros propios. SOLUCIÓN Programar las cotas de los ejes antes de la función G del ciclo."@es .

ns1:Alarma1429LimiteDeSubrutinasEnUnMismoBloqueSobrepasado_9fd42c28a0 a ns1:Alarma ;
    rdfs:label "Alarma 1429: 'Límite de subrutinas en un mismo bloque sobrepasado'"@es ;
    ns1:identificador "1429" ;
    ns1:solucionaFallo ns1:ExcesoDeSubrutinasEnBloque ;
    ns1:textoExtracto "1429 'Límite de subrutinas en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque."@es .

ns1:Alarma1444EjesNoLinealesEnTransformacion_5453234923 a ns1:Alarma ;
    rdfs:label "Alarma 1444: Ejes no lineales en transformación" ;
    ns1:identificador "1444" ;
    ns1:textoExtracto "1444 'Los tres ejes principales de la transformación deben ser lineales' DETECCIÓN Durante la ejecución. CAUSA Alguno de los tres primeros ejes participantes en la transformación o cinemática programada no es lineal. SOLUCIÓN Los tres primeros ejes de la transformación o cinemática deben ser lineales (parámetro AXISTYPE)." .

ns1:Alarma1466RestriccionDeProgramacionG8EnBloquesG36G37G38G39_f6aca9f71d a ns1:Alarma ;
    rdfs:label "Alarma 1466: Restricción de programación G8 en bloques G36/G37/G38/G39"@es ;
    ns1:identificador "1466" ;
    ns1:textoExtracto "'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1515EjesNoDisponibles_5ed603c7ae a ns1:Alarma ;
    rdfs:label "Alarma 1515: Ejes no disponibles"@es ;
    ns1:identificador "1515" ;
    ns1:mitigaRiesgo ns1:SolucionParaAlarma1515 ;
    ns1:textoExtracto "'Uno o varios ejes de la configuración original no están disponibles' DETECCIÓN Durante la ejecución. CAUSA Un canal ha cedido algún eje con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es .

ns1:Alarma1516ValorEsperado_8fcffc5da5 a ns1:Alarma ;
    rdfs:label "Alarma 1516: Valor esperado"@es ;
    ns1:identificador "1516" ;
    ns1:mitigaRiesgo ns1:SolucionParaAlarma1516 ;
    ns1:textoExtracto "'Se esperaba valor' DETECCIÓN Durante la ejecución. CAUSA Se ha programado incorrectamente la lista de parámetros de llamada a una subrutina con #PCALL o G180-189."@es .

ns1:Alarma1517ValorCeroNoAdmitido_afa39e34e1 a ns1:Alarma ;
    rdfs:label "Alarma 1517: Valor cero no admitido"@es ;
    ns1:identificador "1517" ;
    ns1:mitigaRiesgo ns1:SolucionParaAlarma1517 ;
    ns1:textoExtracto "No se admite valor cero. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un valor nulo en una sentencia o función G."@es .

ns1:Alarma1525NoEstaPermitidoIntercambiarElEje_85dba27e13 a ns1:Alarma ;
    rdfs:label "Alarma 1525: 'No está permitido intercambiar el eje'"@es ;
    ns1:identificador "1525" ;
    ns1:textoExtracto "1525 'No está permitido intercambiar el eje' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE) y el eje no tiene permiso de cambio (parámetro AXISEXCH)."@es .

ns1:Alarma1530CoordenadasPolaresEnG53_89fcd0199f a ns1:Alarma ;
    rdfs:label "Alarma 1530: Coordenadas polares en G53" ;
    ns1:identificador "1530" ;
    ns1:mitigaRiesgo ns1:ProgramacionDeG53ConCoordenadasPolares ;
    ns1:textoExtracto "'No se permite programar G53 con coordenadas polares' DETECCIÓN Durante la ejecución. CAUSA En la función G53, las cotas del punto final están definidas en coordenadas polares o cilíndricas. SOLUCIÓN Programando respecto al cero máquina solo se pueden definir las cotas en coordenadas cartesianas." .

ns1:Alarma1531SintaxisIncorrectaEnEXBLK_c84fa77284 a ns1:Alarma ;
    rdfs:label "Alarma 1531: Sintaxis incorrecta en #EXBLK" ;
    ns1:identificador "1531" ;
    ns1:mitigaRiesgo ns1:SintaxisIncorrectaEnSentenciaEXBLK ;
    ns1:textoExtracto "'Programar: #EXBLK [bloque, canal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más" .

ns1:Alarma1563LaFuncionG74SeProgramaConEjesOSolaEnElBloque_531ce1f560 a ns1:Alarma ;
    rdfs:label "Alarma 1563: 'La función G74 se programa con ejes o sola en el bloque'" ;
    ns1:identificador "1563" ;
    ns1:textoExtracto "'La función G74 se programa con ejes o sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la función G74. SOLUCIÓN La función G74 se puede programar bien con los ejes cuya búsqueda de cero se quiere realizar o bien sola en el bloque. Si la función G74 se programa sola en el bloque, el CNC ejecuta su subrutina asociada (parámetro REFPSUB)." .

ns1:Alarma1567RadioPolarProgramadoConR1OG263_18aefa98a8 a ns1:Alarma ;
    rdfs:label "Alarma 1567: Radio polar programado con R1 o G263"@es ;
    ns1:identificador "1567" ;
    ns1:mitigaRiesgo ns1:ProgramarRadioPolarConParametroR1OFuncionG263 ;
    ns1:textoExtracto "El radio polar sólo se puede programar con R. DETECCIÓN Durante la ejecución. CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263. SOLUCIÓN Programar el radio polar con el parámetro R."@es .

ns1:Alarma1568NumeroDeAlmacenIncorrectoEnComandoMZ_3821bd5b4e a ns1:Alarma ;
    rdfs:label "Alarma 1568: Número de almacén incorrecto en comando MZ"@es ;
    ns1:identificador "1568" ;
    ns1:mitigaRiesgo ns1:ProgramarNumeroDeAlmacenFueraDeRango14EnComandoMZ ;
    ns1:textoExtracto "Número de almacén incorrecto. DETECCIÓN Durante la ejecución. CAUSA El número de almacén programado en el comando MZ no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4."@es .

