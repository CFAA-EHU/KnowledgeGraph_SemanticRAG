ns1:FalloModificacionEjesCinematica_1271 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes de cinemática activa no modificables (1271)"@es ;
    ns1:identificador "1271" ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados' [...] Durante la ejecución. El CNC ha intentado modificar la configuración de ejes de una cinemática mientras ésta"@es .

ns1:FalloPosicionAbsoluta a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de contaje en posición absoluta" ;
    ns1:textoExtracto "No puede calcular la posición absoluta. Pérdida de contaje. La señal analógica < 0,20 Vpp." .

ns1:FalloPosicionInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Posición de almacén inexistente"@es ;
    ns1:identificador "DETECCIÓN: Posición no existe"@es ;
    ns1:textoExtracto "'La posición no existe' DETECCIÓN En carga o descarga de una herramienta del almacén, con o sin maniobra. CAUSA La posición del almacén no existe. SOLUCIÓN Elegir una posición existente"@es .

ns1:FalloRecuperacionDatosFRAM_8128 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo recuperación datos FRAM (8128)" ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM. SOLUCIÓN Reiniciar el CNC." .

ns1:FalloSeguimientoEje a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento del eje (MAXFLWE)" ;
    ns1:solucionaFallo ns1:Error_9711,
        ns1:Error_9712 ;
    ns1:textoExtracto "CAUSA El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE). Posible ajuste inadecuado del eje, falta alguna habilitación, fallo en el motor o regulador, sistema de captación y/o mecánica. SOLUCIÓN Revisar los parámetros, ajuste, conexionado, estado del regulador, sistema de captación, motor, etc." .

ns1:FalloSincronizacionHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en datos de herramienta activa"@es ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Verificación y redefinición de herramienta activa"@es ;
            ns1:textoExtracto "Comprobar cuál es la herramienta correcta antes de continuar. Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta."@es ] ;
    ns1:textoExtracto "Durante el arranque del CNC. [...] La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ns1:FalloSincronizacion_9737 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la sincronización (9737)" ;
    ns1:identificador "9737" ;
    ns1:solucionaFallo ns1:SistemaBusSercosIII ;
    ns1:textoExtracto "Fallo en la sincronización. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC envía un mensaje de sincronismo en cada ciclo (4 ms, normalmente) que hace que los reguladores se sincronicen. Si en algún momento los reguladores no pueden sincronizarse o pierden la sincronización, se origina este error. SOLUCIÓN Posiblemente el CNC no ha enviado este mensaje o si lo ha hecho no ha sido en el momento exacto." .

ns1:FalloSintaxis_8901 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #LEAP"@es ;
    ns1:identificador "8901" ;
    ns1:solucionaFallo ns1:Comando_LEAP ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8901 #LEAP[<,INCPOS> <,G90/G91> <,POSvalor> <,POSLIMITvalor> <,GAPvalor> <,TIMEvalor> <,OVRvalor>] <nombreEje cotaEje>"@es,
        "DETECCIÓN Durante la edición y ejecución."@es .

ns1:FalloSintaxis_8902 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #GAPCTRL"@es ;
    ns1:identificador "8902" ;
    ns1:solucionaFallo ns1:Comando_GAPCTRL ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8902 #GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>]"@es,
        "DETECCIÓN"@es .

ns1:FalloTensionRed_9550 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por tensión de red insuficiente (9550)" ;
    ns1:identificador "9550" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisionTensionRed ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense. 9550 Nivel de tensión por debajo del 70%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red." .

ns1:FalloTransformacionCoordenadas_1270 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en transformación de coordenadas (pieza-máquina)"@es ;
    ns1:identificador "1270" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Reconfiguración manual de transformación de ejes"@es ;
            ns1:textoExtracto "Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación."@es ] ;
    ns1:textoExtracto "El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés."@es .

ns1:Fallo_0048 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje no puede ser esclavo de varios maestros"@es ;
    ns1:identificador "0048" ;
    ns1:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje"@es .

ns1:Fallo_0063 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog incremental supera velocidad máxima del eje"@es ;
    ns1:identificador "0063" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_INCJOGFEED ;
    ns1:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro INCJOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro INCJOGFEED; debe ser inferior a G00FEED."@es .

ns1:Fallo_0064 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de I0TYPE en ejes maestro/esclavo gantry"@es ;
    ns1:identificador "0064" ;
    ns1:monitoreaParametro ns1:Parametro_I0TYPE ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben tener el mismo I0TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA No coinciden el tipo de I0 en ambos ejes de la pareja gantry. SOLUCIÓN Ambos ejes deben tener el mismo tipo de I0 (parámetro I0TYPE)."@es .

ns1:Fallo_0065 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Hirth no compatible con configuración Gantry"@es ;
    ns1:identificador "0065" ;
    ns1:monitoreaParametro ns1:Parametro_HIRTH ;
    ns1:textoExtracto "'Un eje Hirth no puede ser Gantry' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje hirth no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser hirth (parámetro HIRTH). Utilizar otro tipo de eje para construir el eje gantry."@es .

ns1:Fallo_0066 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro REFSHIFT no permitido en ejes Gantry"@es ;
    ns1:identificador "0066" ;
    ns1:monitoreaParametro ns1:Parametro_REFSHIFT ;
    ns1:textoExtracto "'Un eje Gantry no puede tener REFSHIFT' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Alguno de los ejes que forman el eje gantry, en algún set de parámetros tiene definido el parámetro REFSHIFT con un valor distinto de 0. SOLUCIÓN Definir el parámetro REFSHIFT de todas las gamas con valor 0."@es .

ns1:Fallo_0067 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje unidireccional incompatible con configuración Gantry"@es ;
    ns1:identificador "0067" ;
    ns1:monitoreaParametro ns1:Parametro_UNIDIR ;
    ns1:textoExtracto "'Un eje Gantry no puede ser unidireccional' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje rotativo unidireccional no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser unidireccional (parámetro UNIDIR). Utilizar otro tipo de eje para construir el eje gantry."@es .

ns1:Fallo_0068 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden incorrecto de ejes maestro/esclavo en AXISNAME (Gantry/Tandem)"@es ;
    ns1:identificador "0068" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:Fallo_0084 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0084: Eje o cabezal no intercambiable sin asignar a canal" ;
    ns1:identificador "0084" ;
    ns1:textoExtracto "'Un eje o cabezal no intercambiable no puede quedar sin asignar a un canal'" .

ns1:Fallo_0151 a ns1:DiagnosticoFallo ;
    rdfs:label "Acceso de escritura denegado" ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "0151 'Acceso de escritura denegado' [...] El CNC ha intentado escribir en un archivo que no tiene permiso de escritura." .

ns1:Fallo_0152 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede abrir el fichero" ;
    ns1:identificador "0152" ;
    ns1:textoExtracto "0152 'No se puede abrir el fichero' [...] DETECCIÓN Al acceder a un archivo." .

ns1:Fallo_0250_DYNOVR a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0250: DYNOVR fuera del rango permitido" ;
    ns1:identificador "0250" ;
    ns1:monitoreaParametro ns1:Parametro_DYNOVR,
        ns1:Parametro_MAXDYNOVR,
        ns1:Parametro_MINDYNOVR ;
    ns1:textoExtracto "0250 DYNOVR fuera del rango permitido por MINDYNOVR y MAXDYNOVR. DETECCIÓN Durante la ejecución. CAUSA La variable V.G.DYNOVR tiene un valor fuera de los límites fijados por los parámetros MINDYNOVR y MAXDYNOVR. SOLUCIÓN Definir la variable con un valor adecuado o modificar la dinámica con ayuda de la barra-override ([CTRL][H])." .

ns1:Fallo_0251_CompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0251: Compensación volumétrica inexistente" ;
    ns1:identificador "0251" ;
    ns1:monitoreaParametro ns1:Parametro_VOLCOMPn ;
    ns1:textoExtracto "0251 Compensación volumétrica inexistente. DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no existe. SOLUCIÓN Comprobar que está activa la opción de software asociada a la compensación volumétrica. Comprobar la lista de compensaciones volumétricas definidas (parámetro VOLCOMPn)." .

ns1:Fallo_0252_MaterialInactivo a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0252: Variable inexistente sin un material activo" ;
    ns1:identificador "0252" ;
    ns1:textoExtracto "0252 Variable inexistente sin un material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer el nombre del material activo y no hay ninguno. SOLUCIÓN Activar un material desde las tablas tecnológicas." .

ns1:Fallo_0253_COMPID_Invalido a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0253: COMPID no válido" ;
    ns1:identificador "0253" ;
    ns1:monitoreaParametro ns1:Parametro_COMPID ;
    ns1:textoExtracto "0253 COMPID no valido. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPID de la cinemática tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID. SOLUCIÓN Revisar el parámetro COMPID." .

ns1:Fallo_0x00000100 a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de ATs" ;
    ns1:identificador "0x00000100" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_ReemplazoPlacaSercos ;
    ns1:textoExtracto "Pérdida de ATs. CAUSA Pérdida de respuestas de algún regulador, que provoca pérdida de fase 4." .

ns1:Fallo_1017 a ns1:DiagnosticoFallo ;
    rdfs:label "G198: límite de software negativo fuera de rango" ;
    ns1:identificador "1017" ;
    ns1:textoExtracto "1017 'G198: límite de software negativo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite negativo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1018 a ns1:DiagnosticoFallo ;
    rdfs:label "G199: límite de software positivo fuera de rango" ;
    ns1:identificador "1018" ;
    ns1:textoExtracto "1018 'G199: límite de software positivo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El límite positivo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1019 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha realizado medición en el eje(s) solicitado" ;
    ns1:identificador "1019" ;
    ns1:textoExtracto "1019 'No se ha realizado medición en el eje(s) solicitado' DETECCIÓN Durante la ejecución. CAUSA La función G101 intenta incluir el offset de medición en un eje que no ha intervenido en la medición o el offset ha sido cancelado (G102). SOLUCIÓN Para incluir un offset de medición (G101), el eje debe haber realizado una medición." .

ns1:Fallo_1020 a ns1:DiagnosticoFallo ;
    rdfs:label "Tiempo de rampa negativo" ;
    ns1:identificador "1020" ;
    ns1:textoExtracto "1020 'Tiempo de rampa negativo' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es negativo. SOLUCIÓN Programar un valor mayor o igual que cero." .

ns1:Fallo_1021 a ns1:DiagnosticoFallo ;
    rdfs:label "Tiempo de rampa fuera de rango" ;
    ns1:identificador "1021" ;
    ns1:textoExtracto "1021 'Tiempo de rampa fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1022 a ns1:DiagnosticoFallo ;
    rdfs:label "Porcentaje de Feed-Forward fuera de rango" ;
    ns1:identificador "1022" ;
    ns1:textoExtracto "1022 'Porcentaje de Feed-Forward fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto. SOLUCIÓN El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." .

ns1:Fallo_1023 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama no válido" ;
    ns1:identificador "1023" ;
    ns1:textoExtracto "1023 'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

ns1:Fallo_1031 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1031: Falta sentencia #AXIS con G201"@es ;
    ns1:identificador "1031" ;
    ns1:textoExtracto "1031 'Se espera #AXIS' [...] CAUSA En el mismo bloque que la función G201 falta programar la sentencia #AXIS."@es .

ns1:Fallo_1032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1032: Falta posición del cabezal para M19"@es ;
    ns1:identificador "1032" ;
    ns1:textoExtracto "1032 'Falta posición del cabezal para M19' [...] CAUSA En el mismo bloque que la función M19 falta programar la posición del cabezal."@es .

ns1:Fallo_1035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1035: Parámetro #SLOPE fuera de rango"@es ;
    ns1:identificador "1035" ;
    ns1:textoExtracto "1035 '#SLOPE: parámetro fuera de rango' [...] CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto."@es .

ns1:Fallo_1037 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1037: Coordenadas I/J/K ignoradas con G0/G1/G100/G63"@es ;
    ns1:identificador "1037" ;
    ns1:textoExtracto "1037 'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' [...] CAUSA El CNC ha encontrado los parámetros I, J, K con la función G0, G1, G100 o G63 activa."@es .

ns1:Fallo_1038 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1038: Compensación de radio activa en medición (G100)"@es ;
    ns1:identificador "1038" ;
    ns1:textoExtracto "1038 'No se admite compensación de radio activa en medición' [...] CAUSA El CNC intenta ejecutar la función G100 con la compensación de radio activa (G41/G42)."@es .

ns1:Fallo_1039 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1039: Offset de medición previo en eje"@es ;
    ns1:identificador "1039" ;
    ns1:solucionaFallo ns1:Funcion_G102 ;
    ns1:textoExtracto "1039 'Existe un valor de medición previo para el eje(s)' [...] CAUSA El CNC intenta realizar una medición (G100) en un eje que tiene un offset de medición anterior."@es .

ns1:Fallo_1040 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1040: Búsqueda de cero en eje activo con G201"@es ;
    ns1:identificador "1040" ;
    ns1:textoExtracto "1040 'No se permite búsqueda de cero de un eje activo en G201' [...] CAUSA El CNC no puede realizar la búsqueda de referencia de un eje que está en modo manual aditivo (G201)."@es .

ns1:Fallo_1078 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G134/G135)"@es ;
    ns1:identificador "1078" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1079 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G138/G139)"@es ;
    ns1:identificador "1079" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1080 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G6/G261/G262)"@es ;
    ns1:identificador "1080" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1081 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G264/G265)"@es ;
    ns1:identificador "1081" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1082 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G200/G201/G202)"@es ;
    ns1:identificador "1082" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1083 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G36/G37/G38/G39)"@es ;
    ns1:identificador "1083" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas dos o más funciones G incompatibles entre sí. SOLUCIÓN Programar las funciones en bloques diferentes."@es .

ns1:Fallo_1084 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de plano con compensación de radio activa"@es ;
    ns1:identificador "1084" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo o los ejes que componen el plano, con la compensación del radio activa. SOLUCIÓN Anular la compensación para definir el nuevo plano de trabajo."@es .

ns1:Fallo_1085 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G41/G42 si falta el primer o segundo eje del plano activo"@es ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal."@es .

ns1:Fallo_1087 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1087: Sintaxis incorrecta"@es ;
    ns1:identificador "1087" ;
    ns1:textoExtracto "el radio de herramienta si falta uno de los dos ejes del plano activo en el canal. SOLUCIÓN Definir el plano de trabajo. Si el canal ha cedido sus ejes a otro canales, recuperar el eje que falta mediante las sentencias #CALLAX o #SETAX. 1087 'Se espera \"=\"' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia o la función programada no es correcta. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1088 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1088: Offset G159 no válido"@es ;
    ns1:identificador "1088" ;
    ns1:textoExtracto "1088 'G159: número de offset no válido' DETECCIÓN Durante la ejecución. CAUSA En la función G159, el traslado de origen programado no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1089 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1089: Funciones M incompatibles"@es ;
    ns1:identificador "1089" ;
    ns1:textoExtracto "1089 Funciones M incompatibles (M3/M4/M5/M19, M8-M9, M41-M44). DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones M incompatibles entre sí. SOLUCIÓN Programar las funciones M del mismo cabezal en bloques diferentes."@es .

ns1:Fallo_1090 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1090: Función H inexistente"@es ;
    ns1:identificador "1090" ;
    ns1:textoExtracto "1090 'Función H inexistente' DETECCIÓN Durante la ejecución. CAUSA La función H no existe. SOLUCIÓN El número de la función deberá estar entre 1 y 65534."@es .

ns1:Fallo_1091 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1091: Función T duplicada"@es ;
    ns1:identificador "1091" ;
    ns1:textoExtracto "1091 'Función T doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función T en el mismo bloque. SOLUCIÓN Sólo puede haber una función T en cada bloque. Programar ambas funciones en bloques diferentes."@es .

ns1:Fallo_1093 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1093: Función D duplicada"@es ;
    ns1:identificador "1093" ;
    ns1:textoExtracto "1093 'Función D doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función D en el mismo bloque. SOLUCIÓN Sólo puede haber una función D en cada bloque. Programar ambas funciones en bloques diferentes."@es .

ns1:Fallo_1094 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1094: Velocidad F duplicada"@es ;
    ns1:identificador "1094" ;
    ns1:textoExtracto "1094 'Velocidad F doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función F en el mismo bloque. SOLUCIÓN Sólo puede haber una función F en cada bloque. Programar ambas funciones en bloques diferentes."@es .

ns1:Fallo_1095 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1095: Velocidad F no válida"@es ;
    ns1:identificador "1095" ;
    ns1:textoExtracto "1095 'No se admite programar velocidad F negativa o cero' DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1123 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación: $DEFAULT no programada sola en el bloque" ;
    ns1:identificador "1123" ;
    ns1:textoExtracto "'La sentencia $DEFAULT se programa sola en el bloque'",
        "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1124 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación: $ENDSWITCH inesperado" ;
    ns1:identificador "1124" ;
    ns1:textoExtracto "'No se espera $ENDSWITCH'",
        "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1125 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación: $ENDSWITCH programada sola en el bloque" ;
    ns1:identificador "1125" ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque'",
        "DETECCIÓN Durante la ejecución." .

ns1:Fallo_1142 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1142: La sentencia #TIME se programa sola en el bloque" ;
    ns1:identificador "1142" ;
    ns1:textoExtracto "1142 'La sentencia #TIME se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1146 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1146: Trayectoria anterior a G37 no lineal" ;
    ns1:identificador "1146" ;
    ns1:textoExtracto "1146 'La trayectoria anterior a G37 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento anterior a la entrada tangencial no es lineal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1147 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1147: Trayectoria posterior a G38 no lineal" ;
    ns1:identificador "1147" ;
    ns1:textoExtracto "1147 'La trayectoria posterior a G38 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento posterior a la salida tangencial no es lineal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1149 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1149: Imposibilidad de ejecutar G36/G37/G38/G39" ;
    ns1:identificador "1149" ;
    ns1:textoExtracto "1149 'No es posible ejecutar G36/G37/G38/G39 programada' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede realizar la trayectoria de empalme con el radio programado. SOLUCIÓN Revisar el radio programado. Comprobar que el empalme es realmente posible entre los bloques inicial y final." .

ns1:Fallo_1150 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1150: Funciones G36/G37/G38/G39 sin bloque de movimiento posterior" ;
    ns1:identificador "1150" ;
    ns1:textoExtracto "1150 'Las funciones G36/G37/G38/G39 deben estar seguidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un segundo bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el segundo bloque de movimiento." .

ns1:Fallo_1151 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1151: Funciones G8/G36/G37/G38/G39 sin bloque de movimiento previo" ;
    ns1:identificador "1151" ;
    ns1:textoExtracto "1151 'Las funciones G8/G36/G37/G38/G39 deben estar precedidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un primer bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." .

ns1:Fallo_1152 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1152: Anidamiento de subrutinas sobrepasado" ;
    ns1:identificador "1152" ;
    ns1:textoExtracto "1152 'Anidamiento de subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el número de niveles de imbricación permitido." .

ns1:Fallo_1204 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia mal programada o inexistente" ;
    ns1:identificador "1204" ;
    ns1:textoExtracto "'Sentencia mal programada o inexistente' DETECCIÓN Durante la ejecución. CAUSA La sentencia no existe o está mal programada. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1205 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: tipo de offset desconocido" ;
    ns1:identificador "1205" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: tipo de offset desconocido' DETECCIÓN Durante la ejecución. CAUSA El tipo de offset programado en la sentencia no existe. SOLUCIÓN Los tipos de offset válidos son ALL, LOCOF, FIXOF, TOOLOF, ORGOF, MEASOF, MANOF." .

ns1:Fallo_1206 a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera ','" ;
    ns1:identificador "1206" ;
    ns1:textoExtracto "'Se espera \",\"' DETECCIÓN Durante la ejecución. CAUSA Falta programar \",\" en la sentencia o función. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1209 a ns1:DiagnosticoFallo ;
    rdfs:label "Índice de eje fuera de rango" ;
    ns1:identificador "1209" ;
    ns1:textoExtracto "'Indice de eje fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • En las sentencias #CALL AX/#SET AX la posición para algún eje no es correcta; la posición está ocupada, la posición supera el máximo permitido o no hay hueco para el eje. • Programación del nombre del eje con un comodín incorrecto. SOLUCIÓN Las posibles soluciones son las siguientes: • La sentencia puede colocar los ejes en cualquier posición libre comprendida entre 1 y un número igual al total de ejes más cabezales del sistema. • Los posibles comodines son de @1 a @6 y @SM." .

ns1:Fallo_1210 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: nombre de eje repetido" ;
    ns1:identificador "1210" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: nombre de eje repetido' DETECCIÓN Durante la ejecución. CAUSA El mismo eje se ha programado más de una vez en la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1211 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: índice de eje repetido" ;
    ns1:identificador "1211" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: índice de eje repetido' DETECCIÓN Durante la ejecución. CAUSA Dos ejes intentan ocupar la mismo posición en el canal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1212 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: número de eje repetido" ;
    ns1:identificador "1212" ;
    ns1:textoExtracto "'#CALL AX/#SET AX: número de eje repetido' DETECCIÓN Durante la ejecución. CAUSA Dos ejes intentan ocupar la mismo posición en el canal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1248_1249 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de funciones G en roscado rígido"@es ;
    ns1:solucionaFallo ns1:Fallo_1248,
        ns1:Fallo_1249 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). [...] 1248 'No se admite roscado y G192 en el mismo bloque' [...] 1249 'No se admite cambio de gama con G96 activa'"@es .

ns1:Fallo_1251 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite modo manual con G96 activa"@es ;
    ns1:identificador "1251" ;
    ns1:solucionaFallo ns1:Funcion_G96 ;
    ns1:textoExtracto "1251 'No se admite modo manual con G96 activa' [...] CAUSA El CNC ha intentado acceder al modo manual con la función G96 activa. SOLUCIÓN Desactivar la función G96 para acceder al modo manual."@es .

ns1:Fallo_1252 a ns1:DiagnosticoFallo ;
    rdfs:label "#FREE AX: no se permite eliminar el eje de giro frontal con G96 activa"@es ;
    ns1:identificador "1252" ;
    ns1:solucionaFallo ns1:Funcion_G96 ;
    ns1:textoExtracto "1252 '#FREE AX: no se permite eliminar el eje de giro frontal con G96 activa' [...] CAUSA El CNC ha intentado eliminar el eje frontal de la configuración del canal (#FREE AX) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para eliminar el eje frontal de la configuración del canal."@es .

ns1:Fallo_1254 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G192 y M19 en el mismo bloque"@es ;
    ns1:identificador "1254" ;
    ns1:solucionaFallo ns1:Funcion_G192,
        ns1:Funcion_M19 ;
    ns1:textoExtracto "1254 'No se admite G192 y M19 en el mismo bloque' [...] CAUSA El CNC no permite programar las funciones M19 (posicionamiento del cabezal) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

ns1:Fallo_1255 a ns1:DiagnosticoFallo ;
    rdfs:label "Porcentaje de aceleración negativo"@es ;
    ns1:identificador "1255" ;
    ns1:textoExtracto "1255 'Porcentaje de aceleración negativo' [...] CAUSA En la función G130, el porcentaje de aceleración programado es negativo. SOLUCIÓN El porcentaje de aceleración debe ser mayor o igual que cero."@es .

ns1:Fallo_1256 a ns1:DiagnosticoFallo ;
    rdfs:label "Porcentaje de aceleración fuera de rango"@es ;
    ns1:identificador "1256" ;
    ns1:textoExtracto "1256 'Porcentaje de aceleración fuera de rango' [...] CAUSA En la función G130, el porcentaje de aceleración programado es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1257 a ns1:DiagnosticoFallo ;
    rdfs:label "Doble programación del paso de husillo"@es ;
    ns1:identificador "1257" ;
    ns1:textoExtracto "1257 'Doble programación del paso de husillo' [...] CAUSA En la función G33, el paso de la rosca está programado más de una vez."@es .

ns1:Fallo_1347 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #CYL OFF con el tipo de cinemática activa" ;
    ns1:identificador "1347" ;
    ns1:textoExtracto "Durante la ejecución. El CNC ha intentado ejecutar la sentencia #CYL OFF y no hay activo ningún mecanizado en la superficie cilíndrica. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1348 a ns1:DiagnosticoFallo ;
    rdfs:label "#CYL: radio no válido" ;
    ns1:identificador "1348" ;
    ns1:textoExtracto "Durante la ejecución. El radio programado en la sentencia #CYL es negativo o cero. Si el radio es variable, este intenta pasar por el centro del cilindro generando un radio nulo. SOLUCIÓN Revisar la programación. El radio debe ser positivo y en el caso de ser un radio variable, este no puede pasar por el centro del cilindro." .

ns1:Fallo_1349 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota del eje negativa en la activación #FACE" ;
    ns1:identificador "1349" ;
    ns1:textoExtracto "Durante la ejecución. El eje lineal que forma parte de la transformación de eje C frontal, se encuentra posicionado en la parte negativa respecto del centro de giro. El CNC no permite esta opción (parámetro ALINGC). SOLUCIÓN Posicionar el eje en la parte positiva respecto del centro de giro antes de activar el mecanizado en el eje frontal." .

ns1:Fallo_1350 a ns1:DiagnosticoFallo ;
    rdfs:label "Carácter no válido entre las sentencias #VAR/#ENDVAR" ;
    ns1:identificador "1350" ;
    ns1:textoExtracto "Durante la ejecución. En alguno de los bloques comprendidos entre estas sentencias hay programado un carácter no válido. SOLUCIÓN Entre estas sentencias sólo se admite la declaración de variables de usuario (separadas por comas si son varias en una misma línea) o la programación del número de bloque." .

ns1:Fallo_1351 a ns1:DiagnosticoFallo ;
    rdfs:label "#VAR/#ENDVAR/#DELETE: tipo de variable no permitida" ;
    ns1:identificador "1351" ;
    ns1:textoExtracto "Durante la ejecución. El CNC ha intentado definir o borrar una variable que no es de usuario. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1427 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje mal programado" ;
    ns1:identificador "1427" ;
    ns1:solucionaFallo ns1:Parametro_G20,
        ns1:Parametro_G74 ;
    ns1:textoExtracto "Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema." .

ns1:Fallo_1428 a ns1:DiagnosticoFallo ;
    rdfs:label "El movimiento en el plano principal debe programarse antes de la G del ciclo" ;
    ns1:identificador "1428" ;
    ns1:textoExtracto "Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo. El ciclo considera las coordenadas del punto inicial como parámetros propios." .

ns1:Fallo_1429 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de subrutinas en un mismo bloque sobrepasado" ;
    ns1:identificador "1429" ;
    ns1:textoExtracto "Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque." .

ns1:Fallo_1430 a ns1:DiagnosticoFallo ;
    rdfs:label "Formato numérico sobrepasado" ;
    ns1:identificador "1430" ;
    ns1:textoExtracto "El valor asignado a un dato, variable o parámetro es superior al formato establecido." .

ns1:Fallo_1431 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición de cabezal en M19 no válida" ;
    ns1:identificador "1431" ;
    ns1:solucionaFallo ns1:Parametro_M19 ;
    ns1:textoExtracto "El valor programado para la posición de cabezal en M19 es demasiado alto." .

ns1:Fallo_1432 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar un eje esclavo de un acoplo o Gantry" ;
    ns1:identificador "1432" ;
    ns1:textoExtracto "En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." .

ns1:Fallo_1448 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede colocar la herramienta perpendicular al plano activo"@es ;
    ns1:identificador "1448" ;
    ns1:textoExtracto "• Un cabezal angular no permite colocar la herramienta perpendicular al plano. • Colocar la herramienta perpendicular al plano activo implica sobrepasar los límites."@es .

ns1:Fallo_1449 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #PATH mal programada"@es ;
    ns1:identificador "1449" ;
    ns1:textoExtracto "La sintaxis de la sentencia #PATH no es correcta."@es .

ns1:Fallo_1450 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución no válida de cabezal perpendicular al plano activo"@es ;
    ns1:identificador "1450" ;
    ns1:textoExtracto "El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido porque el CNC no puede colocar la herramienta perpendicular al plano activo. Causas: cabezal angular o sobrepasar límites."@es .

ns1:Fallo_1451 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente para el tipo de eje"@es ;
    ns1:identificador "1451" ;
    ns1:textoExtracto "La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal)."@es .

ns1:Fallo_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "G74: falta asociar subrutina" ;
    ns1:identificador "1479" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay programada una función G74 sola en el bloque y no existe la subrutina asociada. SOLUCIÓN Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB)." .

ns1:Fallo_1480 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintaxis #EXEC" ;
    ns1:identificador "1480" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Fallo_1481 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de canal no válido" ;
    ns1:identificador "1481" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT. SOLUCIÓN El número de canal debe estar comprendido entre 1 y 4." .

ns1:Fallo_1483 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintaxis #WAIT/#MEET" ;
    ns1:identificador "1483" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Fallo_1484 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de señal fuera de rango" ;
    ns1:identificador "1484" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El número de señal programada en la sentencia #WAIT, #MEET o #SIGNAL no es correcto. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1485 a ns1:DiagnosticoFallo ;
    rdfs:label "#WAIT/#MEET no efectivo" ;
    ns1:identificador "1485" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1486 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintaxis #SIGNAL" ;
    ns1:identificador "1486" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:Fallo_1523 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar T en el bloque" ;
    ns1:identificador "1523" ;
    ns1:textoExtracto "1523 Falta programar T en el bloque. DETECCIÓN Durante la ejecución." .

ns1:Fallo_1525 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de comandos POS/MZ sin herramienta" ;
    ns1:identificador "1525" ;
    ns1:textoExtracto "CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta." .

ns1:Fallo_1545 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama de cabezal con G63 o #CAX activos"@es ;
    ns1:identificador "1545" ;
    ns1:textoExtracto "El CNC no puede cambiar la gama del cabezal si está activo el roscado G63 o el cabezal está trabajando como eje C. SOLUCIÓN Para cambiar la gama del cabezal, desactivar el roscado y el eje C."@es .

ns1:Fallo_1546 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G63 sin gama previa en el cabezal"@es ;
    ns1:identificador "1546" ;
    ns1:textoExtracto "Esta situación sólo es posible si tras el arranque del sistema o un reset, el PLC no indica ninguna gama con GEAR1 a GEAR4 para el cabezal. SOLUCIÓN Antes de iniciar un roscado G63 el cabezal debe tener una gama activada."@es .

ns1:Fallo_1547 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #CAX con G63 activa"@es ;
    ns1:identificador "1547" ;
    ns1:textoExtracto "No se puede activar un cabezal como eje C si éste mismo está siendo usado por la función G63. SOLUCIÓN Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C."@es .

ns1:Fallo_1548 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas"@es ;
    ns1:identificador "1548" ;
    ns1:textoExtracto "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas. DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1560 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #FOLLOW"@es ;
    ns1:identificador "1560" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1560 'Programar #FOLLOW ON/OFF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #FOLLOW es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON/OFF y a continuación los parámetros de llamada entre corchetes."@es .

ns1:Fallo_1561 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje maestro no válido"@es ;
    ns1:identificador "1561" ;
    ns1:textoExtracto "1561 'Eje maestro no válido' DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto. SOLUCIÓN El eje debe pertenecer al canal."@es .

ns1:Fallo_1562 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje esclavo no válido"@es ;
    ns1:identificador "1562" ;
    ns1:textoExtracto "1562 'Eje esclavo no válido' DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1625 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1625: Configuración inválida de eje en control tangencial"@es ;
    ns1:identificador "1625" ;
    ns1:textoExtracto "1625 'Un eje en control tangencial activo debe ser rotativo no HIRTH y no pertenecer al triedro activo' [...] CAUSA Los ejes a activar en el control tangencial debe ser"@es .

ns1:Fallo_1651 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1651: LINK mantenido con ejes temporales de otro canal" ;
    ns1:identificador "1651" ;
    ns1:solucionaFallo ns1:Parametro_AXISEXCH,
        ns1:Parametro_LINKCANCEL ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL). SOLUCIÓN Acoplar los ejes en su canal." .

ns1:Fallo_1652 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1652: Sintaxis #DEF incorrecta" ;
    ns1:identificador "1652" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Sentencia mal programada. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1653 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1653: Eje esclavo en plano inclinado" ;
    ns1:identificador "1653" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado. SOLUCIÓN Desactivar el plano inclinado para poder activar el acoplo. Un eje que forma parte de un plano inclinado no puede ser el eje esclavo en un acoplo; sí puede ser el eje maestro de un acoplo." .

ns1:Fallo_1654 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1654: Bus digital no preparado para lectura" ;
    ns1:identificador "1654" ;
    ns1:solucionaFallo ns1:Parametro_MLINKRDY,
        ns1:Parametro_SERCOSRDY ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. El anillo Sercos no está en fase 4. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink." .

ns1:Fallo_1655 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1655: Bus digital no preparado para escritura" ;
    ns1:identificador "1655" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:Fallo_1686 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de longitud de path" ;
    ns1:identificador "1686" ;
    ns1:textoExtracto "El path del fichero es demasiado largo. [...] La longitud máxima permitida para el path es de 120 caracteres." .

ns1:Fallo_1687 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en sentencia #REPOS" ;
    ns1:identificador "1687" ;
    ns1:textoExtracto "'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' [...] La sentencia #REPOS está mal programada." .

ns1:Fallo_1688 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1688: Sentencias #REPOS de distinto tipo"@es ;
    ns1:identificador "1688" ;
    ns1:textoExtracto "No se admiten sentencias #REPOS de distinto tipo. [...] Todas las sentencias #REPOS deben ser del mismo tipo."@es .

ns1:Fallo_1689 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1689: Bloques tras #REPOS"@es ;
    ns1:identificador "1689" ;
    ns1:textoExtracto "No se admiten bloques tras #REPOS. [...] Las sentencia #REPOS deben ser los últimos bloques de la subrutina de interrupción, excepto el bloque de fin de subrutina."@es .

ns1:Fallo_1690 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1690: Eje múltiple doblemente programado"@es ;
    ns1:identificador "1690" ;
    ns1:textoExtracto "No se permite programar en el mismo bloque más de un eje del mismo grupo multieje. [...] Programar únicamente el eje activo del grupo múltiple."@es .

ns1:Fallo_1691 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1691: Subrutina de G anidada"@es ;
    ns1:identificador "1691" ;
    ns1:textoExtracto "En una subrutina asociada a una función G no se puede programar la función G que llama a esa misma subrutina. [...] En el caso de G74, sí se permite programar la función dentro de la subrutina siempre que vaya seguida de los ejes a referenciar."@es .

ns1:Fallo_1692 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1692: Programación incorrecta de #VOLCOMP"@es ;
    ns1:identificador "1692" ;
    ns1:textoExtracto "La sentencia #VOLCOMP ON/OFF [n] y/o alguno de sus parámetros están mal programados."@es .

ns1:Fallo_1693 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1693: Cinemática no compatible con #RTCP"@es ;
    ns1:identificador "1693" ;
    ns1:textoExtracto "No se permite programar #RTCP con la actual cinemática. Programar #FACE o #CYL."@es .

ns1:Fallo_1729 a ns1:DiagnosticoFallo ;
    rdfs:label "TALADRADO 3: T = 0" ;
    ns1:identificador "1729" ;
    ns1:solucionaFallo ns1:Parametro_T_1729 ;
    ns1:textoExtracto "1729 'TALADRADO 3: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1730 a ns1:DiagnosticoFallo ;
    rdfs:label "TALADRADO 3: P = 0" ;
    ns1:identificador "1730" ;
    ns1:solucionaFallo ns1:Parametro_P_1730 ;
    ns1:textoExtracto "1730 'TALADRADO 3: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1731 a ns1:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: F = 0" ;
    ns1:identificador "1731" ;
    ns1:solucionaFallo ns1:Parametro_F_1731 ;
    ns1:textoExtracto "1731 'MANDRINADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1732 a ns1:DiagnosticoFallo ;
    rdfs:label "MANDRINADO 2: S = 0" ;
    ns1:identificador "1732" ;
    ns1:solucionaFallo ns1:Parametro_S_1732 ;
    ns1:textoExtracto "1732 'MANDRINADO 2: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1787 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: F = 0" ;
    ns1:identificador "1787" ;
    ns1:solucionaFallo ns1:Parametro_F_1787 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1788 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: S = 0" ;
    ns1:identificador "1788" ;
    ns1:solucionaFallo ns1:Parametro_S_1788 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1789 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: T = 0" ;
    ns1:identificador "1789" ;
    ns1:solucionaFallo ns1:Parametro_T_1789 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:Fallo_1790 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: P = 0" ;
    ns1:identificador "1790" ;
    ns1:solucionaFallo ns1:Parametro_P_1790 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Fallo_1791 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta menor que DELTA" ;
    ns1:identificador "1791" ;
    ns1:solucionaFallo ns1:Parametro_Delta_1791 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:Fallo_1805 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1805" ;
    ns1:solucionaFallo ns1:Solucion_1805 ;
    ns1:textoExtracto "El radio de la herramienta es mayor que las dimensiones de la cajera (parámetros)"@es .

ns1:Fallo_1806 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que L"@es ;
    ns1:identificador "1806" ;
    ns1:textoExtracto "1806 'G87: Diámetro de herramienta menor que L'"@es .

ns1:Fallo_1813 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta = 0" ;
    ns1:textoExtracto "1813 'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1814 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: No hay herramienta" ;
    ns1:textoExtracto "1814 'G88: No hay herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal." .

ns1:Fallo_1815 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta menor que C" ;
    ns1:textoExtracto "1815 'G88: Diámetro de herramienta menor que C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:Fallo_1816 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro X no múltiplo de I" ;
    ns1:textoExtracto "1816 'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:Fallo_1817 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta parámetro I o K" ;
    ns1:textoExtracto "1817 'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar el paso entre mecanizados (parámetro I) o el número de mecanizados (parámetro K). SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1818 a ns1:DiagnosticoFallo ;
    rdfs:label "J = 0 en mecanizado múltiple" ;
    ns1:textoExtracto "1818 'J = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0. SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1834 a ns1:DiagnosticoFallo ;
    rdfs:label "ACABADO: Delta z mayor que longitud de corte de herramienta" ;
    ns1:identificador "1834" ;
    ns1:textoExtracto "1834 'ACABADO: Delta z mayor que longitud de corte de herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro δz (demasía de acabado en el fondo) supera la longitud de corte de la herramienta de acabado. SOLUCIÓN Programar una demasía de acabado menor (parámetro δz) o utilizar otra herramienta." .

ns1:Fallo_1835 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Z de seguridad no válida" ;
    ns1:identificador "1835" ;
    ns1:textoExtracto "1835 'Cajera con islas: Z de seguridad no válida' DETECCIÓN Durante la ejecución del ciclo. de la pieza. CAUSA El plano de seguridad (parámetro Zs) se encuentra dentro SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1836 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en Z no válido" ;
    ns1:identificador "1836" ;
    ns1:textoExtracto "1836 'Cajera con islas: Perfil en Z no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada. SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ns1:Fallo_1837 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY se corta a si mismo" ;
    ns1:identificador "1837" ;
    ns1:textoExtracto "1837 'Cajera con islas: Perfil en XY se corta a si mismo' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie forma más de un perfil cerrado. SOLUCIÓN Comprobar que los perfiles de superficie no se cortan a sí mismos y que sólo tienen el punto inicial en común." .

ns1:Fallo_1838 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no es cerrado" ;
    ns1:identificador "1838" ;
    ns1:textoExtracto "1838 'Cajera con islas: Perfil en XY no es cerrado' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo. SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ns1:Fallo_1839 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Intersección de perfiles en XY no válida" ;
    ns1:identificador "1839" ;
    ns1:textoExtracto "1839 'Cajera con islas: Intersección de perfiles en XY no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común." .

ns1:Fallo_1846 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio del arco nulo"@es ;
    ns1:identificador "1846" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "Radio del arco"@es ;
            ns1:textoExtracto "En el perfil hay un tramo curvo con radio cero."@es ] ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple. Las posibles causas son las siguientes: • En el perfil hay un tramo curvo con radio cero. • En un mecanizado múltiple en arco o circunferencia, ambas coordenadas del centro coinciden con el punto inicial. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1847 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Q = 0"@es ;
    ns1:identificador "1847" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "Q (material a eliminar, modo rectangular)"@es ;
            ns1:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0."@es ;
            ns1:valor "0" ] ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es .

ns1:Fallo_1848 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Q = 0"@es ;
    ns1:identificador "1848" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "Q (material a eliminar, modo circular)"@es ;
            ns1:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0."@es ;
            ns1:valor "0" ] ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es .

ns1:Fallo_1849 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera"@es ;
    ns1:identificador "1849" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "δ (demasía de acabado lateral)"@es ;
            ns1:textoExtracto "dos veces el parámetro δ"@es ] ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El tamaño de la cajera menos el diámetro de la herramienta es menor que las demasías de acabado laterales (dos veces el parámetro δ). SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Fallo_1850 a ns1:DiagnosticoFallo ;
    rdfs:label "Lx ha de ser múltiplo de Ix"@es ;
    ns1:identificador "1850" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "Lx (longitud del mecanizado)"@es ;
            ns1:textoExtracto "parámetro Lx"@es ],
        [ a ns1:Parametro ;
            rdfs:label "Ix (distancia entre mecanizados)"@es ;
            ns1:textoExtracto "parámetro Ix"@es ] ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple. La longitud del mecanizado (parámetro Lx) ha de ser múltiplo de la distancia entre mecanizados (parámetro Ix). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Fallo_1851 a ns1:DiagnosticoFallo ;
    rdfs:label "Ly ha de ser múltiplo de Iy"@es ;
    ns1:identificador "1851" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "Ly"@es ;
            ns1:textoExtracto "parámetro Ly (implícito en contexto de mecanizado múltiple)"@es ],
        [ a ns1:Parametro ;
            rdfs:label "Iy"@es ;
            ns1:textoExtracto "parámetro Iy (implícito en contexto de mecanizado múltiple)"@es ] ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de mecanizado múltiple."@es .

ns1:Fallo_1858 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1858: Programar I = 0/1"@es ;
    ns1:identificador "1858" ;
    ns1:monitoreaParametro ns1:Parametro_I ;
    ns1:solucionaFallo ns1:CicloPalpador_PROBE ;
    ns1:textoExtracto "SOLUCIÓN Programar el corrector (función D) antes del ciclo. 1858 'Programar I = 0/1' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El parámetro I (tipo de calibración) tiene un valor incorrecto. SOLUCIÓN El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)."@es .

ns1:Fallo_1859 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1859: Plano activo incorrecto para calibrado de palpador"@es ;
    ns1:identificador "1859" ;
    ns1:monitoreaParametro ns1:PlanoTrabajo_G20 ;
    ns1:solucionaFallo ns1:CicloPalpador_PROBE2 ;
    ns1:textoExtracto "1859 'El plano activo para calibrado de palpador debe ser G17, G18 o G19' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2. CAUSA A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. SOLUCIÓN Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ns1:Fallo_1903 a ns1:DiagnosticoFallo ;
    rdfs:label "Arco mal programado" ;
    ns1:identificador "1903" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Arco mal definido en la geometría del ciclo fijo. SOLUCIÓN Corregir la programación." .

ns1:Fallo_1904 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado herramienta" ;
    ns1:identificador "1904" ;
    ns1:solucionaFallo ns1:Herramienta_Generica ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta programada. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal." .

ns1:Fallo_1905 a ns1:DiagnosticoFallo ;
    rdfs:label "RANURADO: Anchura de la cuchilla nula" ;
    ns1:identificador "1905" ;
    ns1:solucionaFallo ns1:Herramienta_Ranurado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La anchura de la herramienta tiene valor 0. SOLUCIÓN Corregir el valor de la anchura de la herramienta o seleccionar otra herramienta." .

ns1:Fallo_1906 a ns1:DiagnosticoFallo ;
    rdfs:label "Factor de forma de la herramienta no válido" ;
    ns1:identificador "1906" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El factor de forma no es válido para el ciclo programado. SOLUCIÓN Corregir el factor de forma o seleccionar otra herramienta." .

ns1:Fallo_1907 a ns1:DiagnosticoFallo ;
    rdfs:label "Avance F nulo anterior al ciclo" ;
    ns1:identificador "1907" ;
    ns1:monitoreaParametro ns1:Parametro_AvanceF ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance de mecanizado tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." .

ns1:Fallo_1908 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado sobrante de material" ;
    ns1:identificador "1908" ;
    ns1:monitoreaParametro ns1:Parametro_SobranteMaterial ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía para el acabado tiene valor 0. SOLUCIÓN Definir una demasía para el acabado mayor que 0." .

ns1:Fallo_1909 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de desbaste nulo" ;
    ns1:identificador "1909" ;
    ns1:monitoreaParametro ns1:Parametro_PasoDesbaste ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado tiene valor 0. SOLUCIÓN Definir un paso de mecanizado mayor que 0." .

ns1:Fallo_1910 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de desbaste mayor que la anchura de la cuchilla" ;
    ns1:identificador "1910" ;
    ns1:monitoreaParametro ns1:Parametro_PasoDesbaste ;
    ns1:textoExtracto "1910 'Paso de desbaste mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de desbaste es mayor que la anchura de la cuchilla. SOLUCIÓN Programar un paso de desbaste menor o igual que la anchura de la cuchilla.",
        "DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de desbaste es mayor que la anchura de la cuchilla." .

ns1:Fallo_1911 a ns1:DiagnosticoFallo ;
    rdfs:label "Factor de forma no válido en ciclo de desbaste" ;
    ns1:identificador "1911" ;
    ns1:textoExtracto "1911 'Factor de forma no válido en ciclo de desbaste' DETECCIÓN Durante la ejecución del ciclo. CAUSA El factor de forma no es válido para el ciclo programado. SOLUCIÓN Corregir" .

ns1:Fallo_1928 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de ranurado mayor que la anchura de la cuchilla" ;
    ns1:identificador "1928" ;
    ns1:textoExtracto "'Paso de ranurado mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de ranurado es mayor que la anchura de la cuchilla. SOLUCIÓN Programar un paso de ranurado menor o igual que la anchura de la cuchilla." .

ns1:Fallo_1929 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado avance del cabezal" ;
    ns1:identificador "1929" ;
    ns1:solucionaFallo ns1:Parametro_AvanceCabezal ;
    ns1:textoExtracto "'No se ha programado avance del cabezal' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad del cabezal tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." .

ns1:Fallo_1930 a ns1:DiagnosticoFallo ;
    rdfs:label "Programado paso de taladrado nulo" ;
    ns1:identificador "1930" ;
    ns1:solucionaFallo ns1:Parametro_PasoTaladrado ;
    ns1:textoExtracto "'Programado paso de taladrado nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de taladrado tiene valor 0. SOLUCIÓN Definir un paso de taladrado diferente de 0." .

ns1:Fallo_1931 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado profundidad" ;
    ns1:identificador "1931" ;
    ns1:solucionaFallo ns1:Parametro_ProfundidadMecanizado ;
    ns1:textoExtracto "'No se ha programado profundidad' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad de mecanizado tiene valor 0. SOLUCIÓN Definir una profundidad de mecanizado diferente de 0." .

ns1:Fallo_1932 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay cabezal para ejecutar el ciclo" ;
    ns1:identificador "1932" ;
    ns1:solucionaFallo ns1:Componente_Cabezal ;
    ns1:textoExtracto "'No hay cabezal para ejecutar el ciclo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal. SOLUCIÓN Ceder un cabezal al canal o ejecutar el ciclo en un canal con cabezal." .

ns1:Fallo_1933 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay herramienta motorizada para ejecutar el ciclo" ;
    ns1:identificador "1933" ;
    ns1:solucionaFallo ns1:HerramientaMotorizada ;
    ns1:textoExtracto "'No hay herramienta motorizada para ejecutar el ciclo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal para la herramienta motorizada. SOLUCIÓN Ceder una herramienta motorizada al canal o ejecutar el ciclo en un canal con herramienta motorizada." .

ns1:Fallo_1934 a ns1:DiagnosticoFallo ;
    rdfs:label "Anchura de la cuchilla no válida" ;
    ns1:identificador "1934" ;
    ns1:solucionaFallo ns1:Herramienta ;
    ns1:textoExtracto "'Anchura de la cuchilla no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada. SOLUCIÓN Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada." .

ns1:Fallo_1951 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de seguridad"@es ;
    ns1:identificador "1951" ;
    ns1:solucionaFallo ns1:Parametro_Z ;
    ns1:textoExtracto "CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación. 1951 'No programada la cota Z de seguridad' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Fallo_1952 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la profundidad de la pieza"@es ;
    ns1:identificador "1952" ;
    ns1:solucionaFallo ns1:Parametro_Zs ;
    ns1:textoExtracto "CAUSA Falta programar el plano de seguridad (parámetro Zs). SOLUCIÓN Corregir la programación. 1952 'No programada la profundidad de la pieza' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Fallo_1953 a ns1:DiagnosticoFallo ;
    rdfs:label "No programado el paso de profundidad",
        "No programado el paso de la pieza"@es ;
