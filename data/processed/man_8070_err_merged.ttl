ns1:AvisoSeguridad_960_01 a ns1:AvisoSeguridad ;
    rdfs:label "Perfil sin resolver" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Perfil sin resolver' CAUSA El perfil a salvar no está resuelto completamente. SOLUCIÓN Resolver el perfil que se desea salvar. El CNC sólo permite salvar perfiles resueltos." .

ns1:AvisoSeguridad_960_02 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria insuficiente" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Memoria insuficiente' CAUSA No hay memoria de sistema para seguir con el editor de perfiles. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:AvisoSeguridad_960_03 a ns1:AvisoSeguridad ;
    rdfs:label "Error de geometría" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Error de geometría' CAUSA El perfil seleccionado tiene una geometría no válida. El perfil seleccionado tiene algún dato erróneo en la definición de las trayectorias. SOLUCIÓN Corregir el perfil. Todas las trayectorias que definen el perfil deben estar correctamente definidas." .

ns1:AvisoSeguridad_960_04 a ns1:AvisoSeguridad ;
    rdfs:label "Error en datos del elemento" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Error en datos del elemento' CAUSA Los datos introducidos en un elemento son incorrectos. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_05 a ns1:AvisoSeguridad ;
    rdfs:label "Error en datos del perfil" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Error en datos del perfil' CAUSA Datos no válidos en la edición de un perfil 'círculo' o 'rectángulo'. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_06 a ns1:AvisoSeguridad ;
    rdfs:label "El arco no pasa por su coordenada inicial" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'El arco no pasa por su coordenada inicial' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto inicial. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_07 a ns1:AvisoSeguridad ;
    rdfs:label "El arco no pasa por su coordenada final" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'El arco no pasa por su coordenada final' CAUSA En un elemento arco no son coherentes los datos del centro, radio y punto final. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_08 a ns1:AvisoSeguridad ;
    rdfs:label "No hay arco que cumpla todos los datos" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'No hay arco que cumpla todos los datos' CAUSA El editor no puede encontrar un elemento arco coherente con todos los datos conocidos. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_09 a ns1:AvisoSeguridad ;
    rdfs:label "Elemento no tangente al anterior" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Elemento no tangente al anterior' CAUSA La tangencia de un elemento no es coherente con el elemento anterior. SOLUCIÓN Corregir los datos del elemento." .

ns1:AvisoSeguridad_960_10 a ns1:AvisoSeguridad ;
    rdfs:label "Valor no válido" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Valor no válido' CAUSA El valor introducido para modificar una arista (redondeo, chaflán, entrada tangencial o salida tangencial) no es válido. SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido." .

ns1:AvisoSeguridad_960_11 a ns1:AvisoSeguridad ;
    rdfs:label "Error en eje del plano" ;
    ns1:ilustradoEn ns1:InterfazUsuario_EditorPerfiles ;
    ns1:textoExtracto "'Error en eje del plano' CAUSA Algún eje del plano no es válido." .

ns1:AvisoSeguridad_AplicacionesNoDocumentadas a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Aplicaciones no documentadas del CNC" ;
    ns1:mitigaRiesgo ns1:CNC_Generic ;
    ns1:textoExtracto "Es posible que el CNC pueda ejecutar más funciones que las recogidas en la documentación asociada; [...] cualquier aplicación del CNC que no se encuentre recogida en la documentación se debe considerar como 'imposible'." .

ns1:AvisoSeguridad_AsistenciaTecnica a ns1:AvisoSeguridad ;
    rdfs:label "Contactar con asistencia técnica" ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica." .

ns1:AvisoSeguridad_CargaLeva a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: Esperar finalización de carga/execución de leva" ;
    ns1:textoExtracto "CAUSA El CNC ha solicitado la carga de una leva que está en ejecución o en un proceso previo de carga. SOLUCIÓN Esperar a que finalice la ejecución o la carga de la leva." .

