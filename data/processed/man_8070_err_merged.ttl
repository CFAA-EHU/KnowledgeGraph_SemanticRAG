ns1:Error_8788 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8788: Índice final menor que inicial en ERA" ;
    ns1:identificador "8788" ;
    ns1:textoExtracto "8788 Índice final menor que inicial en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA En la instrucción ERA, el segundo argumento es menor que el primero. SOLUCIÓN Programar 'ERA recurso índice'. El índice debe ser mayor que el recurso." .

ns1:Error_8789 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8789: Índice final fuera de rango en ERA" ;
    ns1:documentadoEn ns1:RangosRecursosPLC ;
    ns1:identificador "8789" ;
    ns1:textoExtracto "8789 Índice final fuera de rango en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA El segundo indice no es un recurso válido. SOLUCIÓN El rango válido para cada recurso es el siguiente. • Entradas (I1-I1024). • Salidas (O1-O1024). • Entradas locales (LI1-LI16). • Salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Estado de los temporizadores (T1-T512). • Estado de los contadores (C1-C256)." .

