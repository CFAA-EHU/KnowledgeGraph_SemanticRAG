ns1:Error3041 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3041: No se ha definido cabezal para G33/G34/G95" ;
    ns1:documentadoEn ns1:Seccion3000 ;
    ns1:identificador "3041" ;
    ns1:textoExtracto "3041 'No se ha definido cabezal para G33/G34/G95' [...] SOLUCIÓN Definir un cabezal master en el canal o asignar un cabezal al registro SYNC del PLC." .

ns1:Error3042 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3042: El cabezal indicado en el registro SYNC no existe" ;
    ns1:documentadoEn ns1:Seccion3000 ;
    ns1:identificador "3042" ;
    ns1:textoExtracto "3042 'El cabezal indicado en el registro SYNC no existe' [...] SOLUCIÓN El valor del registro SYNC del PLC debe ser un valor comprendido entre 1 y el número de cabezales del sistema." .

ns1:Error3066 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el seguimiento del eje tangencial sobre la trayectoria"@es ;
    ns1:identificador "3066" ;
    ns1:solucionaFallo ns1:FalloSeguimientoEjeTangencial ;
