ns1:Alarma1619ValorQ1DoblementeProgramado_3ced04c682 a ns1:Alarma ;
    rdfs:label "Alarma 1619: Valor Q1 doblemente programado",
        "Valor Q doblemente programado" ;
    ns1:identificador "1619" ;
    ns1:monitoreaParametro ns1:ParametroQCoordenadasPolares_60f124ef89 ;
    ns1:textoExtracto "'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

ns1:Alarma1633ProgramacionDeCabezalNoEspecificada_67e027b9e4 a ns1:Alarma ;
    rdfs:label "Alarma 1633: Programación de cabezal no especificada",
        "Alarma 1633: Error de sintaxis en programación de cabezal"@es ;
    ns1:identificador "1633" ;
    ns1:monitoreaParametro ns1:ParametroDeProgramacionDeCabezalesDGSPSL_7f1bb410f4 ;
    ns1:textoExtracto "'Programar: #DGSPSL <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1656EjesDelPlanoEnDiametros_4e38d90b4a a ns1:Alarma ;
    rdfs:label "Alarma 1656: Ejes del plano en diámetros"@es ;
    ns1:identificador "1656" ;
    ns1:textoExtracto "1656 'Alguno de los ejes del plano esta en diámetros' DETECCIÓN Al simular o ejecutar en un torno un ciclo fijo de fresadora que contiene movimientos en los ejes del plano, CAUSA Los datos de las cotas de los ciclos fijos de fresadora se consideran en radios. Si alguno de los ejes del plano esta en diámetros, el CNC interpreta sus datos como radios, por lo que avisa al usuario por si al programarlos lo estaba haciendo en diámetros. CONSECUENCIA El ciclo puede ejecutar una geometria diferente a la esperada. SOLUCIÓN Programar los datos en radios."@es .

ns1:Alarma1657VariableNoValidaParaCabezalNoEjeC_fdce1e6ffa a ns1:Alarma ;
    rdfs:label "Alarma 1657: Variable no válida para cabezal no eje C"@es,
        "Variable no válida para cabezal que no es eje C"@es ;
    ns1:identificador "1657" ;
    ns1:textoExtracto "1657 'Variable no válida para cabezal que no es eje C' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1676RecuperacionDePlanoInclinadoActivo_29bcfa2b01 a ns1:Alarma ;
    rdfs:label "Alarma 1676: Recuperación de plano inclinado activo"@es ;
    ns1:identificador "1676" ;
    ns1:textoExtracto "1676 'Se ha recuperado el plano inclinado activo' [...] DETECCIÓN Durante la ejecución. CAUSA Tras el encendido, el CNC ha recuperado el plano inclinado que se encontraba activo al apagarlo. SOLUCIÓN El plano inclinado se puede desactivar con la sentencia #CS OFF."@es .

ns1:Alarma1920NoSeHaProgramadoPerfil_886b30f98a a ns1:Alarma ;
    rdfs:label "Alarma 1920: 'No se ha programado perfil'"@es ;
    ns1:identificador "1920" ;
    ns1:mitigaRiesgo ns1:FaltaDeProgramacionDePerfilEnCicloFijo ;
    ns1:textoExtracto "'No se ha programado perfil' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el perfil que define la geometría del ciclo fijo. SOLUCIÓN Definir el perfil que define la geometría del ciclo."@es .

ns1:Alarma1921GeometriaProgramadaNoExterior_8d892f5b19 a ns1:Alarma ;
    rdfs:label "Alarma 1921: 'Geometría programada no exterior'"@es ;
    ns1:identificador "1921" ;
    ns1:mitigaRiesgo ns1:GeometriaProgramadaNoValidaExterior ;
    ns1:textoExtracto "'Geometría programada no exterior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría exterior, tal y como se indica en el ciclo. SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es interior."@es .

ns1:Alarma1922GeometriaProgramadaNoInterior_10107b5621 a ns1:Alarma ;
    rdfs:label "Alarma 1922: 'Geometría programada no interior'"@es ;
    ns1:identificador "1922" ;
    ns1:mitigaRiesgo ns1:GeometriaProgramadaNoValidaInterior ;
    ns1:textoExtracto "'Geometría programada no interior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría interior, tal y como se indica en el ciclo. SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es exterior."@es .

ns1:Alarma1923GeometriaNoValida_673ff5d6aa a ns1:Alarma ;
    rdfs:label "Alarma 1923: 'Geometría no válida'"@es ;
    ns1:identificador "1923" ;
    ns1:mitigaRiesgo ns1:GeometriaIncorrectaEnCicloFijo ;
    ns1:textoExtracto "'Geometría no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta. SOLUCIÓN Corregir la programación."@es .

ns1:Alarma1924MemoriaInsuficiente_ad0f0d74fd a ns1:Alarma ;
    rdfs:label "Alarma 1924: 'Memoria insuficiente'"@es ;
    ns1:identificador "1924" ;
    ns1:mitigaRiesgo ns1:MemoriaInsuficienteEnSistema ;
    ns1:textoExtracto "'Memoria insuficiente' DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no dispone de memoria para seguir resolviendo la cajera. SOLUCIÓN Póngase en contacto con FAGOR."@es .

ns1:Alarma1925NoProgramadoDesbasteNiAcabado_43352311cb a ns1:Alarma ;
    rdfs:label "Alarma 1925: 'No programado desbaste ni acabado'"@es ;
    ns1:identificador "1925" ;
    ns1:mitigaRiesgo ns1:FaltaDeProgramacionDeOperacionesDesbasteAcabado ;
    ns1:textoExtracto "'No programado desbaste ni acabado' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definida ninguna operación en el ciclo fijo. SOLUCIÓN En el ciclo fijo debe estar definida la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Alarma1926VerticeMalProgramado_6fe5e8fba6 a ns1:Alarma ;
    rdfs:label "Alarma 1926: 'Vértice mal programado'"@es ;
    ns1:identificador "1926" ;
    ns1:mitigaRiesgo ns1:ErrorDeProgramacionEnVerticeDeGeometria ;
    ns1:textoExtracto "'Vértice mal programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta. SOLUCIÓN Corregir la programación."@es .

ns1:Alarma1927CuchillaNoValidaParaPerfilProgramado_535ff21fc0 a ns1:Alarma ;
    rdfs:label "Alarma 1927: 'Cuchilla no válida para perfil programado'"@es ;
    ns1:identificador "1927" ;
    ns1:mitigaRiesgo ns1:CuchillaIncompatibleConPerfilProgramado ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Alarma1975NoSeHaProducidoPalpacion_3bb8fea624 a ns1:Alarma ;
    rdfs:label "Alarma 1975: No se ha producido palpación"@es ;
    ns1:identificador "1975" ;
    ns1:solucionaFallo ns1:FalloEnPalpacionCicloMalDefinido ;
    ns1:textoExtracto "'No se ha producido palpación' DETECCIÓN Durante la ejecución de un ciclo de palpador. CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación."@es .

ns1:Alarma2146NoEsPosibleLaDesactivacionDelSpline_ccb254830e a ns1:Alarma ;
    rdfs:label "Alarma 2146: No es posible la desactivación del spline" ;
    ns1:identificador "2146" ;
    ns1:textoExtracto "2146 'No es posible la desactivación del spline' DETECCIÓN Durante la ejecución. CAUSA Número insuficiente de bloques para desactivar el spline. SOLUCIÓN No programar el spline para ejecutar un solo bloque." .

ns1:Alarma2147ProgramacionDeSplinesNoPermitidaEnModoHSC_89aaa38d12 a ns1:Alarma ;
    rdfs:label "Alarma 2147: Programación de splines no permitida en modo HSC" ;
    ns1:identificador "2147" ;
    ns1:solucionaFallo ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "2147 'Programación de splines no permitida en modo HSC' DETECCIÓN Durante la ejecución. CAUSA No se permite activar el spline con el modo HSC activo." .

ns1:Alarma2149ErrorInternoEnControlTangencialTANGCTRL_3ddfdd04bf a ns1:Alarma ;
    rdfs:label "Alarma 2149: Error interno en control tangencial (#TANGCTRL)" ;
    ns1:identificador "2149" ;
    ns1:solucionaFallo ns1:Sistema_ControlTangencial ;
    ns1:textoExtracto "2149 #TANGCTRL:Error interno en control tangencial. DETECCIÓN Durante la ejecución. CAUSA No es posible realizar el control tangencial." .

ns1:Alarma2309ProgramacionNoPermitidaConVIRTAXActivo_e0e7d8c05a a ns1:Alarma ;
    rdfs:label "Alarma 2309: Programación no permitida con #VIRTAX activo"@es ;
    ns1:identificador "2309" ;
    ns1:textoExtracto "#VIRTAX: Programación no permitida con el eje virtual de la herramienta activo."@es .

ns1:Alarma2401EjeEnZonaDeTrabajoActiva_405a6b72db a ns1:Alarma ;
    rdfs:label "Alarma 2401: Eje en zona de trabajo activa" ;
    ns1:identificador "2401" ;
    ns1:mitigaRiesgo ns1:LiberarEjeSinDesactivarZonaDeTrabajo ;
    ns1:textoExtracto "un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa. SOLUCIÓN Desactivar la zona de trabajo antes de liberar el eje." .

ns1:Alarma2402AparcamientoDeEjeEnZonaActiva_8dd0508ecd a ns1:Alarma ;
    rdfs:label "Alarma 2402: Aparcamiento de eje en zona activa" ;
    ns1:identificador "2402" ;
    ns1:mitigaRiesgo ns1:AparcarEjeSinDesactivarZonaDeTrabajo ;
    ns1:textoExtracto "'#PARK: No se permite aparcar un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado aparcar un eje que forma parte de una zona de trabajo activa. SOLUCIÓN Desactivar la zona de trabajo antes de aparcar el eje." .

ns1:Alarma2403ActivacionDeZonaConEjeAparcado_60a83f0d0d a ns1:Alarma ;
    rdfs:label "Alarma 2403: Activación de zona con eje aparcado" ;
    ns1:identificador "2403" ;
    ns1:mitigaRiesgo ns1:ActivarZonaConEjeAparcado ;
    ns1:textoExtracto "'No se permite activar una zona con uno de sus ejes aparcado' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado activar una zona de trabajo, pero uno de los ejes que la definen está aparcado. SOLUCIÓN Desaparcar el eje antes de activar la zona de trabajo." .

ns1:Alarma2488FaltaCargaDeGAPTABLEAntesDeGAPCTRLLEAP_18e524547d a ns1:Alarma ;
    rdfs:label "Alarma 2488: Calibración de gap no activada",
        "Alarma 2488: Falta carga de GAPTABLE antes de GAPCTRL/LEAP"@es ;
    ns1:identificador "2488" ;
    ns1:mitigaRiesgo ns1:OmisionDeLOADGAPTABLEAntesDeGAPCTRLLEAP ;
    ns1:textoExtracto "Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina"@es .

ns1:Alarma2489RTCPNoPermitidoEnInspeccionConKINIDTIP_bbf48382c3 a ns1:Alarma ;
    rdfs:label "Alarma 2489: RTCP no permitido en inspección con KINID TIP" ;
    ns1:identificador "2489" ;
    ns1:textoExtracto "No se permite programar #RTCP en INSPECCIÓN, con KINID TIP activo. [...] SOLUCIÓN Mantener en el sistema #KIN ID [TIP] o #RTCP durante la inspección de herramienta." .

ns1:Alarma2490SecuenciaIncorrectaDeRTCPCS_afde421f6b a ns1:Alarma ;
    rdfs:label "Alarma 2490: Secuencia incorrecta de RTCP/CS" ;
    ns1:identificador "2490" ;
    ns1:textoExtracto "#RTCP ON/OFF: Programación no permitida con CS/ACS activo. [...] SOLUCIÓN Revisar la programación. Programar la secuencia correcta." .

ns1:Alarma2491ProgramacionInvalidaEnSubrutinaCAX_c734c6c2bb a ns1:Alarma ;
    rdfs:label "Alarma 2491: Programación inválida en subrutina #CAX" ;
    ns1:identificador "2491" ;
    ns1:textoExtracto "Programación no permitida dentro de la subrutina asociada a #CAX. [...] SOLUCIÓN Revisar la programación. Dentro de la subrutina, programar #CAX sin parámetros." .

ns1:Alarma2492ComodinFueraDeSubrutinaCAX_18097a5f21 a ns1:Alarma ;
    rdfs:label "Alarma 2492: Comodín fuera de subrutina #CAX" ;
    ns1:identificador "2492" ;
    ns1:textoExtracto "Comodín no permitido fuera de la subrutina asociada a #CAX. [...] SOLUCIÓN Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

ns1:Alarma2504FaltaProgramarElSegundoPuntoXYZ_b134b672e9 a ns1:Alarma ;
    rdfs:label "Alarma 2504: Falta programación del segundo punto en G107"@es,
        "Alarma 2504: Falta programar el segundo punto (XYZ)"@es ;
    ns1:identificador "2504" ;
    ns1:mitigaRiesgo ns1:ProgramarG107SinDefinirCoordenadasXYZDelSegundoPunto ;
    ns1:textoExtracto "2504 G107: Falta programar el segundo punto (XYZ). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma2505FaltaProgramarElPrimerPuntoIJK_cef0d56893 a ns1:Alarma ;
    rdfs:label "Alarma 2505: Falta programar el primer punto (IJK)"@es ;
    ns1:identificador "2505" ;
    ns1:mitigaRiesgo ns1:ProgramarG107SinDefinirCoordenadasIJKDelPrimerPunto ;
    ns1:textoExtracto "2505 G107: Falta programar el primer punto (IJK). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma2506G107IncompatibleConG106YSPLINEON_b33c74459f a ns1:Alarma ;
    rdfs:label "Alarma 2506: G107 incompatible con G106 y #SPLINE ON"@es ;
    ns1:identificador "2506" ;
    ns1:mitigaRiesgo ns1:ActivarG107ConG106ActivaOSPLINEON ;
    ns1:textoExtracto "2506 G107 incompatible con G106 y #SPLINE ON. DETECCIÓN Durante la ejecución. CAUSA No es posible programar splines con G107 activa. Tampoco es posible programar G107 sin desactivar previamente G106 mediante una G0, G1. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma2507CoordenadasPolaresRQOCartesianaAnguloXZQNoPermitidas_27b1cd7243 a ns1:Alarma ;
    rdfs:label "Alarma 2507: Coordenadas polares RQ o cartesiana/ángulo (X..ZQ) no permitidas"@es ;
    ns1:identificador "2507" ;
    ns1:mitigaRiesgo ns1:UsarCoordenadasPolaresRQOCartesianasAnguloXZQEnG107 ;
    ns1:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución."@es .

ns1:Alarma3077NoSeAdmiteBloqueABloqueEnEsteProcesoDeRETRACE_6327f12aec a ns1:Alarma ;
    rdfs:label "Alarma 3077: No se admite Bloque a Bloque en este proceso de RETRACE" ;
    ns1:identificador "3077" ;
    ns1:textoExtracto "'No se admite Bloque a Bloque en este proceso de RETRACE; desactivar Bloque a Bloque' DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos." .

ns1:Alarma9033NoHayMemoriaParaCrearLaListaDeSimbolos_225a1cb744 a ns1:Alarma ;
    rdfs:label "Alarma 9033: No hay memoria para crear la lista de símbolos"@es ;
    ns1:identificador "9033" ;
    ns1:textoExtracto "9033 No hay memoria para crear la lista de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos."@es .

ns1:Alarma9034NoSePuedeAbrirElFicheroDeRecursosConSimbolo_8e0124e8fe a ns1:Alarma ;
    rdfs:label "Alarma 9034: No se puede abrir el fichero de recursos con símbolo"@es ;
    ns1:identificador "9034" ;
    ns1:textoExtracto "9034 No se puede abrir el fichero de recursos con símbolo. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear"@es .

ns1:Alarma9035NoHayEjeFisicoCorrespondienteAlEjeLogico_c136daa9f4 a ns1:Alarma ;
    rdfs:label "Alarma 9035: No hay eje físico correspondiente al eje lógico"@es ;
    ns1:identificador "9035" ;
    ns1:textoExtracto "9035 No hay eje físico correspondiente al eje lógico. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa contiene una referencia a un eje que no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma9036SimboloDesconocido_0b22bb2f25 a ns1:Alarma ;
    rdfs:label "Alarma 9036: Símbolo desconocido"@es ;
    ns1:identificador "9036" ;
    ns1:textoExtracto "9036 Símbolo desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa utiliza un símbolo que está definido. SOLUCIÓN Utilizar la directiva DEF o PDEF para definir los símbolos."@es .

ns1:Alarma9037MarcaORegistroDeSistemaObsoleto_194b43b84c a ns1:Alarma ;
    rdfs:label "Alarma 9037: Marca o registro de sistema obsoleto"@es ;
    ns1:identificador "9037" ;
    ns1:textoExtracto "9037 Marca o registro de sistema obsoleto. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Eliminar la marca o registro del programa PLC."@es .

ns1:Alarma9038MarcaORegistroDeSistemaObsoletoUsar_7d4678389b a ns1:Alarma ;
    rdfs:label "Alarma 9038: Marca o registro de sistema obsoleto (usar %)"@es ;
    ns1:identificador "9038" ;
    ns1:textoExtracto "9038 Marca o registro de sistema obsoleto. En su lugar use %. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Utilice la marca la marca o registro sugerida."@es .

ns1:Alarma9039MarcaORegistroDeSistemaPendienteDeImplementar_6aa7d27495 a ns1:Alarma ;
    rdfs:label "Alarma 9039: Marca o registro de sistema pendiente de implementar"@es ;
    ns1:identificador "9039" ;
    ns1:textoExtracto "9039 Marca o registro de sistema pendiente de ser implementado. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro todavía no ha sido implementada. SOLUCIÓN No se puede usar la marca o registro."@es .

ns1:Alarma9040LineaDeComentariosDemasiadoLarga_b99e69b51a a ns1:Alarma ;
    rdfs:label "Alarma 9040: Línea de comentarios demasiado larga"@es ;
    ns1:identificador "9040" ;
    ns1:textoExtracto "9040 Linea de comentarios demasiado larga. DETECCIÓN Durante la compilación del programa PLC. CAUSA El comentario es demasiado largo. SOLUCIÓN Escribir un comentario mas corto o dividir el comentario en dos."@es .

ns1:Alarma9041MarcaORegistroDeSistemaSustituidoPor_b2d898cb84 a ns1:Alarma ;
    rdfs:label "Alarma 9041: Marca o registro de sistema sustituido por %"@es ;
    ns1:identificador "9041" ;
    ns1:textoExtracto "9041 Marca o registro de sistema sustituido por %. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro es incorrecto; el PLC lo ha sustituido en el programa compilado por el recurso sugerido. SOLUCIÓN Sustituir la marca o registro por el recurso sugerido."@es .

ns1:Alarma9042SustituidoPor_6165dacbc9 a ns1:Alarma ;
    rdfs:label "Alarma 9042: '/' sustituido por '_'"@es ;
    ns1:identificador "9042" ;
    ns1:textoExtracto "9042 '/' sustituido por '_' DETECCIÓN Durante la compilación del programa PLC."@es .

ns1:Alarma9312ConflictoConfiguracionEjeGANTRYMULTIAXIS_122a88021d a ns1:Alarma ;
    rdfs:label "Alarma 9312: Conflicto configuración eje GANTRY/MULTIAXIS"@es ;
    ns1:identificador "9312" ;
    ns1:textoExtracto "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es .

ns1:Alarma9352CAXSETNoCoincideConM41SETM44SET_9cd4503c47 a ns1:Alarma ;
    rdfs:label "Alarma 9352: CAXSET no coincide con M41SET..M44SET" ;
    ns1:identificador "9352" ;
    ns1:textoExtracto "9352 CAXSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:Alarma9353SYNCSETNoCoincideConM41SETM44SET_880dc175e3 a ns1:Alarma ;
    rdfs:label "Alarma 9353: SYNCSET no coincide con M41SET..M44SET" ;
    ns1:identificador "9353" ;
    ns1:textoExtracto "9353 SYNCSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:Alarma9355EjesMaestroEsclavoConOPMODEDistinto_db256932b7 a ns1:Alarma ;
    rdfs:label "Alarma 9355: Ejes maestro/esclavo con OPMODE distinto" ;
    ns1:identificador "9355" ;
    ns1:textoExtracto "9355 Los ejes maestro y esclavo deben tener el mismo OPMODE. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En un eje gantry, el eje maestro y esclavo no tiene el parámetro OPMODE igual. SOLUCIÓN El parámetro OPMODE debe ser igual en ambos ejes." .

ns1:Alarma9356CompensacionDeHusilloDoblementeDefinida_3173abfb8f a ns1:Alarma ;
    rdfs:label "Alarma 9356: Compensación de husillo doblemente definida" ;
    ns1:identificador "9356" ;
    ns1:textoExtracto "9356 Compensación de husillo doblemente definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay asignadas dos compensaciones de husillo iguales (parámetros MOVAXIS y COMPAXIS iguales) a un mismo eje. SOLUCIÓN Asignar al eje una única compensación de husillo." .

ns1:Alarma9357EjeCOMPAXISDeCompensacionNoValido_7b07cbc332 a ns1:Alarma ;
    rdfs:label "Alarma 9357: Eje COMPAXIS de compensación no válido" ;
    ns1:identificador "9357" ;
    ns1:textoExtracto "9357 El eje COMPAXIS de la compensación seleccionada no es válido. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje tiene asignada una compensación cuyo eje compensado no coincide con el eje. La compensación no tiene ningún efecto en el movimiento del eje. SOLUCIÓN Asignar a COMPTABLEID un valor adecuado." .

ns1:Alarma9358CompensacionNoDefinida_9de889f5a8 a ns1:Alarma ;
    rdfs:label "Alarma 9358: Compensación no definida" ;
    ns1:identificador "9358" ;
    ns1:textoExtracto "9358 Compensación no definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada." .

