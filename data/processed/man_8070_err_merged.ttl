ns1:Fallo_9700 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite del recorrido del eje sobrepasado" ;
    ns1:identificador "9700" ;
    ns1:textoExtracto "Límite del recorrido del eje sobrepasado. SOLUCIÓN Tras recuperar potencia en el accionamiento, es posible desplazar el eje a la zona permitida." .

ns1:Fallo_9702 a ns1:DiagnosticoFallo ;
    rdfs:label "Temperatura superior a la permitida en el drive" ;
    ns1:identificador "9702" ;
    ns1:monitoreaParametro ns1:Parametro_TemperaturaDrive ;
    ns1:textoExtracto "El entorno de ubicación del regulador se encuentra a temperatura excesivamente elevada. SOLUCIÓN Reducir la temperatura ambiente y del armario." .

ns1:Fallo_9703 a ns1:DiagnosticoFallo ;
    rdfs:label "Temperatura superior a la permitida en el motor" ;
    ns1:identificador "9703" ;
    ns1:monitoreaParametro ns1:Parametro_TemperaturaMotor ;
    ns1:textoExtracto "El motor supera la temperatura máxima permitida. Las posibles causas son: el cableado de medición de temperatura del motor (manguera del sensor de posición) o el termistor están en malas condiciones; la aplicación exige fuertes picos de corriente. SOLUCIÓN Detener el sistema unos minutos y disminuir el grado de esfuerzo exigido al regulador; ventilar el motor." .

ns1:Fallo_9706 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad real fuera de límites" ;
    ns1:identificador "9706" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "El eje o cabezal ha superado el valor máximo definido en el parámetro G00FEED. SOLUCIÓN Revisar el parámetro G00FEED." .

ns1:Fallo_9709 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento excesivo" ;
    ns1:identificador "9709" ;
    ns1:monitoreaParametro ns1:Parametro_MAXFLWE ;
    ns1:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)." .

ns1:Fallo_9722 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor" ;
    ns1:monitoreaParametro [ a ns1:Parametro ;
