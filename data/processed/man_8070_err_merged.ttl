    ns1:textoExtracto "Error de CAN."@es .

ns1:ErrorCAN_6015 a ns1:AvisoSeguridad ;
    rdfs:label "Contador de errores CAN sobrepaso nivel 1"@es ;
    ns1:identificador "6015" ;
    ns1:monitoreaParametro ns1:ParametroCAN_6015_RxTx ;
    ns1:textoExtracto "6015 'Contador de errores CAN sobrepaso nivel 1' DETECCIÓN Durante la ejecución. CAUSA El contador de tramas de error (Rx/Tx) supera el nivel 1 (96). SOLUCIÓN Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:ErrorCAN_BusOFF a ns1:AvisoSeguridad ;
    rdfs:label "BusOFF"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "2" ;
    ns1:textoExtracto "BusOFF. El nodo detecta que cae el bus."@es .

ns1:ErrorCAN_COMPCINoResponde a ns1:AvisoSeguridad ;
    rdfs:label "COMPCI no responde"@es ;
