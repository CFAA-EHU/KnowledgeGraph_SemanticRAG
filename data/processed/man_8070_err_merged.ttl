ns1:Error_0021 a ns1:AvisoSeguridad ;
    rdfs:label "No hay teclado de CAN" ;
    ns1:identificador "0021" ;
    ns1:solucionaFallo ns1:ModoDiagnosis ;
    ns1:textoExtracto "0021 No hay teclado de CAN. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN." .

ns1:Error_0041 a ns1:DiagnosticoFallo ;
    rdfs:label "M duplicada en la tabla" ;
    ns1:identificador "0041" ;
    ns1:textoExtracto "0041 'M duplicada en la tabla' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de funciones M, hay una función repetida. SOLUCIÓN Corregir la definición de las funciones. En la tabla no puede haber dos funciones M con el mismo número." .

ns1:Error_0042 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de parámetro máquina no válido" ;
    ns1:identificador "0042" ;
    ns1:textoExtracto "0042 'Valor de parámetro máquina no válido' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro máquina tiene un valor no válido. límites permitidos. En la ventana SOLUCIÓN Asignar al parámetro máquina un valor dentro de los de error aparece cuál es el parámetro erróneo y el valor máximo y mínimo permitido." .

ns1:Error_0043 a ns1:DiagnosticoFallo ;
    rdfs:label "Para asumir nuevo valor es necesario rearrancar el CNC" ;
    ns1:identificador "0043" ;
    ns1:textoExtracto "0043 'Para asumir nuevo valor es necesario rearrancar el CNC' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha modificado un parámetro máquina y es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor." .

ns1:Error_0127 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0127: Error en grabación PLD dispositivo S3"@es,
        "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD"@es ;
    ns1:identificador "0127" ;
    ns1:textoExtracto "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC."@es .

ns1:Error_0129 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0129: Dispositivo inválido"@es ;
    ns1:identificador "0129" ;
    ns1:textoExtracto "0129 Dispositivo inválido. DETECCIÓN Durante la ejecución. CAUSA El dispositivo asociado a la variable de regulador que se quiere leer o escribir no es válido. SOLUCIÓN Si el error se ha generado en la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0167 a ns1:DiagnosticoFallo ;
    rdfs:label "No RT IT" ;
    ns1:identificador "0167" ;
    ns1:textoExtracto "0167 'No RT IT' DETECCIÓN Durante el funcionamiento del CNC. CAUSA No entra la interrupción de tiempo real." .

ns1:Error_0168 a ns1:DiagnosticoFallo ;
    rdfs:label "Position Loop Overflow" ;
    ns1:identificador "0168" ;
    ns1:monitoreaParametro ns1:LOOPTIME_38c47af3e5 ;
    ns1:textoExtracto "0168 Position Loop Overflow. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido." .

ns1:Error_1109 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1109: Índice de eje incorrecto" ;
    ns1:identificador "1109" ;
    ns1:textoExtracto "1109 'Indice de eje incorrecto' DETECCIÓN Durante la ejecución. CAUSA En las funciones G20 y G74, el índice programado junto al nombre del eje es incorrecto. SOLUCIÓN El índice del eje debe ser un valor entre 1 y el número máximo de ejes del sistema o del canal." .

ns1:Error_1442 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1442: Se ha desactivado la cinemática" ;
    ns1:identificador "1442" ;
    ns1:textoExtracto "1442 'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza." .

ns1:Error_1443 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1443: 'Se ha desactivado #CS/ACS'"@es ;
    ns1:identificador "1443" ;
    ns1:textoExtracto "1443 'Se ha desactivado #CS/ACS' DETECCIÓN Tras un reset del CNC, al iniciar la ejecución de un programa pieza o durante la búsqueda de referencia. CAUSA Los ejes utilizados en el plano inclinado no son los adecuados. El CNC ha intentado hacer una búsqueda de referencia con la función #CS/ACS activa."@es .

ns1:Error_1481 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1481: 'Número de canal no válido'" ;
    ns1:identificador "1481" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT." .

ns1:Error_24508 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo genérico de bus local"@es ;
    ns1:identificador "24508" ;
    ns1:textoExtracto "24508 Fallo genérico de bus local. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24509 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha encontrado ningún módulo"@es ;
    ns1:identificador "24509" ;
    ns1:textoExtracto "24509 No se ha encontrado ningún módulo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24510 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo incorrecto encontrado en la posición %u"@es ;
    ns1:identificador "24510" ;
    ns1:textoExtracto "24510 Módulo incorrecto encontrado en la posición %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24511 a ns1:DiagnosticoFallo ;
    rdfs:label "Más dispositivos de los esperados"@es ;
    ns1:identificador "24511" ;
    ns1:textoExtracto "24511 Más dispositivos de los esperados. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24512 a ns1:DiagnosticoFallo ;
    rdfs:label "Aplicación en el módulo %u no listo"@es ;
    ns1:identificador "24512" ;
    ns1:textoExtracto "24512 Aplicación en el módulo %u no listo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_2480 a ns1:DiagnosticoFallo ;
    rdfs:label "START no admitido por datos no válidos en continuación de perfil"@es ;
    ns1:identificador "2480" ;
    ns1:textoExtracto "2480 No se admite START para continuar perfil por datos no válidos. DETECCIÓN Al pulsar [START] después de seleccionar un modo de continuación parcial del mecanizado anterior; \"Punto de reinicio\", \"Restart PP\", \"PP interrumpido\" o \"BreakPP\". CAUSA Error en el fichero que guardan los datos para continuar. SOLUCIÓN Repetir el proceso (interrupción del programa y seleccionar tipo de continuación)."@es .

ns1:Error_3735 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en la activación/desactivación del PWM'" ;
    ns1:identificador "3735" ;
    ns1:solucionaFallo ns1:VerificacionDeParametrosPWM ;
    ns1:textoExtracto "'Error en la activación/desactivación del PWM' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA La parametrización del PWM es incorrecta. SOLUCIÓN Verificar las siguientes condiciones: • El parámetro NLOCOUT debe ser 8. • El parámetro PWMOUTPUT no puede ser superior a 2 (1, 2)." .

ns1:Error_4204 a ns1:AvisoSeguridad ;
    rdfs:label "Error al resetear el driver de SERCOS",
        "Error 4204: Error al resetear el driver de SERCOS"@es ;
    ns1:documentadoEn ns1:Regulador_AXD_v9.10 ;
