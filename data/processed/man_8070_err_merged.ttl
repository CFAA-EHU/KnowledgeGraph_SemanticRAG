    ns1:identificador "1133" ;
    ns1:textoExtracto "1133 'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDWHILE sin una instrucción $WHILE previa. SOLUCIÓN Revisar la programación.",
        "'No se espera $ENDWHILE' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Error1220 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1220: '#FREE AX: no se permite eliminar un eje activo en modo manual'"@es ;
    ns1:identificador "1220" ;
    ns1:solucionaFallo ns1:ModoOperacion_G202 ;
    ns1:textoExtracto "CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación. 1220 '#FREE AX: no se permite eliminar un eje activo en modo manual' DETECCIÓN Durante la ejecución. CAUSA Un eje en modo manual aditivo (G201) no se puede eliminar del canal. SOLUCIÓN Anular el modo manual aditivo del eje mediante la función G202 para realizar eliminar el eje del canal."@es .

ns1:Error1318_CambioParametrosSistemaCoordenadasActivo a ns1:AvisoSeguridad ;
    rdfs:label "Error 1318: Cambio de parámetros en sistema de coordenadas activo"@es ;
    ns1:identificador "1318" ;
    ns1:mitigaRiesgo ns1:SistemaCoordenadasActivo ;
    ns1:textoExtracto "CAUSA El CNC ha intentado cambiar los parámetros de un sistema de coordenadas activo. SOLUCIÓN Revisar la programación. El CNC no permite modificar los parámetros de un sistema de coordenadas activo; si permite modificar los parámetros de un sistema de coordenadas ya definido pero no activo."@es .

ns1:Error1738 a ns1:AvisoSeguridad ;
