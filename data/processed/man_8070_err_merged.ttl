ns1:FalloLexerEnteros_8200 a ns1:DiagnosticoFallo ;
    rdfs:label "'Fallo del lexer al reconocer enteros' (8200)" ;
    ns1:identificador "8200" ;
    ns1:textoExtracto "'Fallo del lexer al reconocer enteros' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto. SOLUCIÓN Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable." .

ns1:FalloLexerFlotantes_8201 a ns1:DiagnosticoFallo ;
    rdfs:label "'Fallo del lexer al reconocer flotantes' (8201)" ;
