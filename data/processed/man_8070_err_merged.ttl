ns1:ErrorSistema_0001 a ns1:AvisoSeguridad ;
    rdfs:label "ERROR DEL SISTEMA" ;
    ns1:activaAlarma ns1:AlarmaDeErrorCriticoDelSistema_fda9ad06e8 ;
    ns1:identificador "0001" ;
    ns1:textoExtracto "'ERROR DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Errores de software o hardware que provocan datos corruptos y/o resultados incongruentes. SOLUCIÓN Este tipo de errores normalmente fuerzan la salida del CNC." .

ns1:ErrorSobraParametro a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "'Sobra parámetro'." .

ns1:ErrorTensionAlimentacion_9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de tensión de alimentación en captación digital"@es ;
    ns1:identificador "9647" ;
    ns1:solucionaFallo ns1:ComprobacionCableAlimentacion_9647,
        ns1:ComprobacionConexionCableado_9647 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es .

ns1:ErrorTransmisionATs_0x00008000 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la transmisión de ATs (0x00008000)"@es ;
    ns1:identificador "0x00008000" ;
    ns1:textoExtracto "Error en la transmisión de ATs. ( Fibra óptica o regulador reseteado)"@es .

ns1:ErrorTransmisionCAN_6021 a ns1:DiagnosticoFallo ;
    rdfs:label "Problemas en la transmisión de CAN" ;
    ns1:identificador "6021" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos transmisión de salidas digitales, analógicas, etc. Posible colapso del bus. SOLUCIÓN Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN; si existen errores, realizar las comprobaciones oportunas para garantizar la integridad del bus CAN. En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:ErrorValidacion_0114 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0114: Validación de parámetros durante simulación"@es ;
    ns1:identificador "0114" ;
    ns1:solucionaFallo ns1:ValidarParametrosMaquinaDuranteSimulacionDePrograma ;
    ns1:textoExtracto "No es posible validar parámetros durante la simulación de un programa en el canal. [...] SOLUCIÓN Detener la simulación del programa para validar los parámetros."@es .

ns1:ErrorValorParametroK a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:ManualDeProgramacionDelSistema8055 ;
    ns1:textoExtracto "'Valor de parámetro K incorrecto'. Valor incorrecto del parámetro K para la función G programada." .

ns1:ErrorVariableCNCWR a ns1:DiagnosticoFallo ;
    rdfs:label "Error CNCWR: Variable con valor no permitido" ;
    ns1:identificador "5026" ;
    ns1:monitoreaParametro ns1:ParametroCNCWRValorPermitido0_f1fe3a9cf6 ;
    ns1:textoExtracto "5026 'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable" .

ns1:ErrorVersionXCA a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de versión en archivo xca"@es ;
    ns1:textoExtracto "CAUSA El archivo xca es v1.0 y debe ser v2.0. SOLUCIÓN Convertir el archivo a v2.0."@es .

ns1:Error_0011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum en los datos de búsqueda de bloque" ;
    ns1:identificador "0011" ;
    ns1:textoExtracto "0011 'Error de checksum en los datos de búsqueda de bloque' DETECCIÓN Durante el arranque del CNC. CAUSA Error de cheksum de los datos necesarios para ejecutar una búsqueda de bloque automática. CONSECUENCIA No es posible ejecutar una búsqueda de bloque automática. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:Error_0013 a ns1:DiagnosticoFallo ;
    rdfs:label "ASSERT DEL SISTEMA" ;
    ns1:identificador "0013" ;
    ns1:textoExtracto "0013 ASSERT DEL SISTEMA. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha generado un error sin determinar. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0014 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado Watchdog en la última sesión" ;
    ns1:identificador "0014" ;
    ns1:textoExtracto "0014 Detectado Watchdog en la última sesión. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC se ha cerrado debido a un reset por watchdog. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0015 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio del equipo" ;
    ns1:identificador "0015" ;
    ns1:textoExtracto "0015 Detectado apagado/reinicio del equipo. DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0017 a ns1:AvisoSeguridad ;
    rdfs:label "Detectado apagado/reinicio por caída de alimentación" ;
    ns1:identificador "0017" ;
    ns1:mitigaRiesgo ns1:Solucion_0017 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado un apagado inesperado por una caída de alimentación. SOLUCIÓN Revisar la alimentación del CNC. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." .

ns1:Error_0018 a ns1:AvisoSeguridad ;
    rdfs:label "Detectado apagado/reinicio por pantalla azul" ;
    ns1:identificador "0018" ;
    ns1:mitigaRiesgo ns1:Solucion_0018 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El cierre anterior del CNC fue debido a una excepción de bajo nivel (pantalla azul). SOLUCIÓN Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." .

ns1:Error_0020 a ns1:AvisoSeguridad ;
    rdfs:label "Acceso a variable incorrecto" ;
    ns1:identificador "0020" ;
    ns1:mitigaRiesgo ns1:Solucion_0020 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o al cambiar de página. CAUSA El CNC está accediendo a una variable de interfaz que no existe. SOLUCIÓN Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:Error_0023 a ns1:AvisoSeguridad ;
    rdfs:label "Es necesario parar el programa para iniciar la traza por primera vez"@es ;
    ns1:identificador "0023" ;
    ns1:solucionaFallo ns1:Solucion_0023 ;
    ns1:textoExtracto "DETECCIÓN Al iniciar una traza en el osciloscopio. CAUSA Es la primera vez que el osciloscopio inicia una traza y hay un programa en ejecución. La traza utiliza variables del regulador que o bien no están en la tabla de parámetros máquina o bien están en dicha tabla pero son asíncronas. SOLUCIÓN Parar el programa en ejecución."@es .

ns1:Error_0024 a ns1:AvisoSeguridad ;
    rdfs:label "Error iniciando la traza"@es ;
    ns1:identificador "0024" ;
    ns1:textoExtracto "DETECCIÓN Al iniciar una traza en el osciloscopio."@es .

ns1:Error_0026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0026: Variable no permitida en el entorno del osciloscopio" ;
    ns1:identificador "0026" ;
    ns1:solucionaFallo ns1:ConsultarDocumentacionDeVariablesPermitidas ;
    ns1:textoExtracto "'Variable no permitida en el entorno del oscilo' DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA La variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña." .

ns1:Error_0037 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta siguiente"@es ;
    ns1:identificador "0037" ;
    ns1:solucionaFallo ns1:HerramientaSiguiente ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la herramienta siguiente. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta siguiente guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto. SOLUCIÓN Comprobar cuál es la herramienta correcta antes de continuar. Definir en el CNC cuál es la herramienta siguiente (por ejemplo desde MDI), y en caso necesario, realizar un cambio de herramienta."@es .

ns1:Error_0038 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de los correctores de herramienta"@es ;
    ns1:identificador "0038" ;
    ns1:solucionaFallo ns1:CorrectoresHerramienta ;
    ns1:textoExtracto "Inconsistencia en la recuperación de los correctores de herramienta. DETECCIÓN Durante el arranque del CNC. CAUSA La información de los correctores guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto. SOLUCIÓN Comprobar cuáles son los correctores correctos antes de continuar. Definir en la tabla de herramientas los correctores de herramienta, y en caso necesario, realizar un cambio de herramienta."@es .

ns1:Error_0039 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal"@es ;
    ns1:identificador "0039" ;
    ns1:solucionaFallo ns1:AlmacenDeHerramientas_c53bc752d6 ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal. DETECCIÓN Durante el arranque del CNC. CAUSA La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es .

ns1:Error_0068 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0068: Ejes Gantry/Tandem - Esclavo precede a maestro"@es ;
    ns1:identificador "0068" ;
    ns1:monitoreaParametro ns1:AXISNAMENombresDeEjes ;
    ns1:textoExtracto "0068 'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de asignación de nombres de ejes (parámetro AXISNAME), el eje esclavo está definido antes del eje maestro. SOLUCIÓN Definir en la tabla el eje maestro antes que el eje esclavo o intercambiar el eje maestro y esclavo en la pareja gantry o tándem."@es .

ns1:Error_0069 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene"@es,
        "Error 0069: Ejes Gantry - DECINPUT en esclavo sin maestro"@es ;
    ns1:identificador "0069" ;
    ns1:monitoreaParametro ns1:Param_DECINPUT,
        ns1:ParametroDECINPUTMicroDeReferencia_cbf45f752c ;
    ns1:textoExtracto "0069 'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:Error_0070 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo"@es ;
    ns1:identificador "0070" ;
    ns1:monitoreaParametro ns1:Param_LIMIT ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)."@es .

ns1:Error_0071 a ns1:DiagnosticoFallo ;
    rdfs:label "Vigilancia de error de seguimiento no activa en el CNC"@es ;
    ns1:identificador "0071" ;
    ns1:monitoreaParametro ns1:Param_FLWEMONITOR ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)."@es .

ns1:Error_0072 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de captación sin activar"@es ;
    ns1:activaAlarma ns1:AlarmaDeCaptacionDeEjesCabezalesAnalogicos_6d41411e45 ;
    ns1:identificador "0072" ;
    ns1:monitoreaParametro ns1:Param_FBACKAL ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)."@es .

ns1:Error_0110 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0110: 'No se pudo cargar la cinemática de usuario'" ;
    ns1:identificador "0110" ;
    ns1:textoExtracto "0110 'No se pudo cargar la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no encuentra el fichero c:\\FagorCNC\\drivers\\kinematic.sys (o c:\\Cnc8070\\drivers\\kinematic.sys). SOLUCIÓN Compruebe que al hacer el make de cinemática de usuario no se producen errores y que el driver kinematic.sys se genera correctamente." .

ns1:Error_0111 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0111: 'Error en la inicialización de datos de la cinemática de usuario'" ;
    ns1:identificador "0111" ;
    ns1:textoExtracto "0111 'Error en la inicialización de datos de la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la función de inicialización y carga de datos de la cinemática de usuario (UserTransforDataInit) implementada en el fichero Kin_iniData.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0112 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0112: 'Error en la inicialización de la cinemática de usuario'" ;
    ns1:identificador "0112" ;
    ns1:textoExtracto "0112 'Error en la inicialización de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0113 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0113: 'Error en la inicialización de parámetros de la cinemática de usuario'" ;
    ns1:identificador "0113" ;
    ns1:textoExtracto "0113 'Error en la inicialización de parámetros de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforParamInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0114 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0114: 'No es posible validar parámetros durante la simulación de un programa en el canal'" ;
    ns1:identificador "0114" ;
    ns1:textoExtracto "0114 No es posible validar parámetros durante la simulación de un programa en el canal. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar los parámetros durante la simulación de un programa. SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:Error_0115 a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación -tipo de CPU- no coherente con el hardware" ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "0115 Código de validación -tipo de CPU-, NO coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El tipo de CPU definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Error_0116 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al leer la tabla tecnológica" ;
    ns1:identificador "0116" ;
    ns1:solucionaFallo ns1:TablaTecnologica ;
    ns1:textoExtracto "'Error al leer la tabla tecnológica' DETECCIÓN Durante el arranque del CNC, acceso a la tabla tecnológica o ejecución del comando #TECHTABLE. CAUSA El fichero ..\\mtb\\data\\techTable\\TTDsc.xml que define la tabla o tabla no existe o no es ..\\mtb\\data\\techTable\\Material Files\\*xml con los datos de la correcto. Es posible que haya cambios en la tabla (nuevas variables, nuevos tipos enumerados) y no se ha reiniciado el CNC. SOLUCIÓN Comprobar el nombre y contenido de la tabla. Si la tabla existe, reiniciar el CNC." .

ns1:Error_0117 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de cores no coherente con el hardware" ;
    ns1:identificador "0117" ;
    ns1:textoExtracto "0117 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Error_0118 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en hardware de SERCOS III o error en driver" ;
    ns1:identificador "0118" ;
    ns1:solucionaFallo ns1:HardwareSERCOSIII ;
    ns1:textoExtracto "0118 No hay hardware de SERCOS III o error en la carga del driver. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El CNC no detecta el hardware asociado a Sercos III o no puede cargar el driver. SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0119 a ns1:DiagnosticoFallo ;
    rdfs:label "Actualización de SW correcta de dispositivos PwC conectados a SERCOS3" ;
    ns1:identificador "0119" ;
    ns1:solucionaFallo ns1:DispositivosPwC ;
    ns1:textoExtracto "0119 Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción." .

ns1:Error_0130_EtherCAT_NoDisponible a ns1:AvisoSeguridad ;
    rdfs:label "Error 0130: EtherCAT no disponible"@es ;
    ns1:identificador "0130" ;
    ns1:solucionaFallo ns1:Solucion_ContactoFagorAutomation ;
    ns1:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo."@es .

ns1:Error_0131 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo ns1:RevisionDeParametrosEnTablaDRVParaError0131 ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0131_LecturaVariableRegulador a ns1:AvisoSeguridad ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo ns1:Solucion_ContactoFagorAutomation ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las"@es .

ns1:Error_0132 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0132: Error en la escritura de variable de regulador"@es ;
    ns1:identificador "0132" ;
    ns1:solucionaFallo ns1:RevisionDeParametrosEnTablaDRVParaError0132 ;
    ns1:textoExtracto "0132 Error en la escritura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de escritura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la escritura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0150_Handle a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: #OPEN: handle de fichero en uso"@es ;
    ns1:identificador "0150" ;
    ns1:solucionaFallo ns1:CambioDeHandleDeFicheroParaError0150 ;
    ns1:textoExtracto "0150 #OPEN: handle de fichero en uso. DETECCIÓN Durante la ejecución. CAUSA El handle de fichero indicado en la sentencia #OPEN está siendo usado por el #OPEN de otro fichero. SOLUCIÓN Utilizar un handle de fichero diferente."@es .

ns1:Error_0150_MaxFicheros a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: Número máximo de ficheros abiertos sobrepasado"@es ;
    ns1:identificador "0150" ;
    ns1:solucionaFallo ns1:ReduccionDeSubrutinasExternasParaError0150 ;
    ns1:textoExtracto "0150 'Número máximo de ficheros abiertos sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza con subrutinas globales. CAUSA El número de ficheros abiertos (programa principal más subrutinas externas) es superior a 20. SOLUCIÓN Reducir el número de subrutinas externas abiertas simultáneamente en el programa pieza."@es .

ns1:Error_0151 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Permiso de escritura denegado" ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "El CNC ha intentado escribir en un archivo que no tiene permiso de escritura. SOLUCIÓN Dar al fichero permiso de escritura." .

ns1:Error_0151_Archivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: #WRITE: texto o fichero cncWrite.txt no encontrado"@es ;
    ns1:identificador "0151" ;
    ns1:solucionaFallo ns1:VerificacionDeArchivoCncWriteTxtParaError0151 ;
    ns1:textoExtracto "0151 #WRITE: texto o fichero cncWrite.txt no encontrado. DETECCIÓN Durante la ejecución. CAUSA No se encuentra el texto correspondiente al identificador programado. Es posible que no exista el archivo cncWrite.txt o que no esté definido el identificador. SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador."@es .

ns1:Error_0151_Permiso a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Acceso de escritura denegado"@es ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "0151 'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura."@es .

ns1:Error_0153 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0153: Acceso de lectura denegado" ;
    ns1:identificador "0153" ;
    ns1:textoExtracto "'Acceso de lectura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado leer un archivo que no tiene permiso de lectura. SOLUCIÓN Dar al fichero permiso de lectura." .

ns1:Error_0154 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0154: Programa o rutina protegida" ;
    ns1:identificador "0154" ;
    ns1:textoExtracto "'Programa o rutina protegida' DETECCIÓN Durante al acceso a un archivo. CAUSA El CNC ha intentado leer un archivo encriptado, sin tener permiso de acceso. SOLUCIÓN Póngase en contacto con el fabricante de la máquina para obtener los códigos de encriptación del fichero." .

ns1:Error_0155 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0155: No es posible carga rápida de fichero" ;
    ns1:identificador "0155" ;
    ns1:textoExtracto "'No es posible carga rápida de fichero' DETECCIÓN Durante al acceso a un archivo. CAUSA El CNC ha intentado leer un fichero cuyo tamaño supera el espacio libre de la zona de memoria asignada para carga rápida de ficheros. SOLUCIÓN Ejecutar desde memoria RAM (subrutinas con extensión fst) sólo a aquellos ficheros que son llamados con mayor frecuencia." .

ns1:Error_0156 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0156: Demasiados ficheros abiertos para escritura" ;
    ns1:identificador "0156" ;
    ns1:textoExtracto "Demasiados ficheros abiertos para escritura. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha intentado abrir demasiados archivos. SOLUCIÓN Cerrar algún archivo." .

ns1:Error_0157 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0157: #OPEN/#CLOSE: Handle de fichero no válido" ;
    ns1:identificador "0157" ;
    ns1:textoExtracto "#OPEN/#CLOSE: Handle de fichero no válido. DETECCIÓN Durante la edición y ejecución. CAUSA El identificador del archivo no es correcto. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Los identificadores válidos son F1 a F4, y su programación es opcional. El identificador del archivo permite que un canal pueda escribir en un archivo abierto por otro canal." .

ns1:Error_0158 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0158: #WRITE necesita un #OPEN previo" ;
    ns1:identificador "0158" ;
    ns1:textoExtracto "#WRITE necesita un #OPEN previo." .

ns1:Error_0163 a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "0163 #OPEN:El fichero o path indicado no existe. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha comprobado que el archivo no existe (comando \"R\"). SOLUCIÓN La sentencia #OPEN está programada para mostrar este error. Para continuar con la ejecución sin dar error, utilizar el comando \"MUTED\"." .

ns1:Error_0169 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrepasada temperatura de seguridad" ;
    ns1:identificador "0169" ;
    ns1:textoExtracto "0169 Sobrepasada temperatura de seguridad." .

ns1:Error_0x00000002 a ns1:AvisoSeguridad ;
    rdfs:label "Rotura de fibra óptica"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000002" ;
    ns1:textoExtracto "Rotura de fibra óptica."@es .

ns1:Error_0x00000100 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de ATs"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000100" ;
    ns1:solucionaFallo ns1:CambioNoAutorizadoDePlacaSercosOReguladorSinDiagnosticoPrevio ;
    ns1:textoExtracto "0x00000100 | Pérdida de ATs. CAUSA Pérdida de respuestas de algún regulador, que provoca pérdida de fase 4. SOLUCIÓN Determinar el regulador defectuoso y cambiar la placa Sercos o el mismo regulador."@es .

ns1:Error_0x00000200 a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de MSTs"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000200" ;
    ns1:textoExtracto "Pérdida de MSTs."@es .

ns1:Error_0x00008000 a ns1:AvisoSeguridad ;
    rdfs:label "Error en transmisión de ATs"@es ;
