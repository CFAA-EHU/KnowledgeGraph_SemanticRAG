        ns1:FalloDeProgramacionCambioDePlanoNoPermitido ;
    ns1:textoExtracto "1344 'No se admite cambio de plano durante el mecanizado en superficie lateral' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1350CaracterNoValidoEntreLasSentenciasVARENDVAR_cba89dd820 a ns1:Alarma ;
    rdfs:label "Alarma 1350: Carácter no válido entre las sentencias #VAR/#ENDVAR" ;
    ns1:identificador "1350" ;
    ns1:textoExtracto "1350 'Carácter no válido entre las sentencias #VAR/#ENDVAR' DETECCIÓN Durante la ejecución. CAUSA En alguno de los bloques comprendidos entre estas sentencias hay programado un carácter no válido. SOLUCIÓN Entre estas sentencias sólo se admite la declaración de variables de usuario (separadas por comas si son varias en una misma línea) o la programación del número de bloque." .

ns1:Alarma1351TipoDeVariableNoPermitida_964565126d a ns1:Alarma ;
    rdfs:label "Alarma 1351: Tipo de variable no permitida" ;
    ns1:identificador "1351" ;
    ns1:textoExtracto "'#VAR/#ENDVAR/#DELETE: tipo de variable no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir o borrar una variable que no es de usuario. SOLUCIÓN Revisar la programación." .

ns1:Alarma1352VariableDefinidaYaExiste_5824728738 a ns1:Alarma ;
    rdfs:label "Alarma 1352: Variable definida ya existe" ;
    ns1:identificador "1352" ;
    ns1:textoExtracto "'#VAR/#ENDVAR: la variable definida ya existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación." .

ns1:Alarma1387LimiteDeFuncionesMEnUnMismoBloqueSobrepasado_cef2c9ad01 a ns1:Alarma ;
