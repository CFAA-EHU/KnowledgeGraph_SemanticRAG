    rdfs:label "Error en la inicialización del volante del teclado" ;
    ns1:identificador "6024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error. SOLUCIÓN Revisar los parámetros máquina." .

ns1:ErrorIniciandoLaTraza a ns1:AvisoSeguridad ;
    rdfs:label "Error iniciando la traza" ;
    ns1:identificador "0024" ;
    ns1:mitigaRiesgo ns1:ComprobarLasVariablesDefinidasEnLosCanalesDelOsciloscopio ;
    ns1:textoExtracto "0024 'Error iniciando la traza' DETECCIÓN Al iniciar una traza en el osciloscopio. CAUSA No hay ninguna variable definida en los canales del osciloscopio, hay más de dos variables Sercos del mismo regulador o la sintaxis de alguna de las variables no es correcta. SOLUCIÓN Comprobar las variables definidas en los canales del osciloscopio. El osciloscopio sólo puede acceder a dos variables Sercos de cada regulador." .

ns1:ErrorLSFIT2380 a ns1:DiagnosticoFallo ;
    rdfs:label "Error #LSFIT (2380)" ;
    ns1:solucionaFallo ns1:DatosDeEntradaONumeroPosicionesDePalpacion ;
    ns1:textoExtracto "2380 #LSFIT, error interno. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. Datos incoherentes en el ciclo. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:ErrorMemoria_0003 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la petición de memoria" ;
    ns1:activaAlarma ns1:AlarmaDeMemoriaInsuficiente_41c3cf3dcc ;
    ns1:identificador "0003" ;
    ns1:textoExtracto "'Error en la petición de memoria. Reiniciar Windows y CNC' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no dispone de suficiente memoria o la memoria se encuentra excesivamente fragmentada." .

ns1:ErrorModoSetting a ns1:AvisoSeguridad ;
    rdfs:label "Error: Almacén en modo setting (M06 no permitido)" ;
