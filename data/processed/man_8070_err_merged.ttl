ns1:Error_5044 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración incorrecta en entrada analógica remota" ;
    ns1:identificador "5044" ;
    ns1:solucionaFallo ns1:RevisarConfiguracionDeEntradaAnalogicaRemotaError5044 ;
    ns1:textoExtracto "Una entrada analógica remota esta configurada incorrectamente. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La configuración de una entrada analógica remota no es correcta. SOLUCIÓN Revisar configuración de la entrada analógica remota." .

ns1:Error_5045 a ns1:DiagnosticoFallo ;
