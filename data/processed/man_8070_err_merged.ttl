            rdfs:label "Configuración de teclados 8065"@es ;
            ns1:ejecutadoPor ns1:ServicioAsistenciaTecnica ;
            ns1:textoExtracto "Identificar los teclados 8065 (qwerty y jog) y configurarlos correctamente."@es ] ;
    ns1:textoExtracto "El CNC ha detectado un teclado 8065 (qwerty o jog) configurado para comunicarse con versiones anteriores a la V04.10."@es .

ns1:FalloCorteRed_BateriaPC a ns1:AvisoSeguridad ;
    rdfs:label "Corte en la red: PC alimentado con batería"@es ;
    ns1:identificador "0201" ;
    ns1:textoExtracto "0201 'Corte en la red. PC alimentado con batería' DETECCIÓN Al leer el estado de la batería. CAUSA Hay un corte en la alimentación del CNC y la batería de emergencia está alimentado el CNC."@es .

ns1:FalloEncoderVelocidadMaxima a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por exceso de velocidad en encoder de eje/cabezal"@es ;
    ns1:solucionaFallo ns1:TareaBusquedaReferenciaMaquina ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El encóder del eje o cabezal ha superado la velocidad de giro máxima permitida. Al superar este límite, el eje o cabezal ha perdido el punto de referencia, por lo que las cotas leídas no son correctas."@es .

ns1:FalloEncoder_9538 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en encóder o cabeza de regla (código 9538)"@es ;
    ns1:identificador "9538" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_LimpiezaEncoder_9538,
        ns1:TareaMantenimiento_ReemplazoEncoder_9538 ;
    ns1:textoExtracto "CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode). [...] 9538 Captación digital Fagor. Tensión de alimentación fuera de rango."@es .

ns1:FalloHerramientaEnCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Herramienta en cabezal"@es ;
    ns1:identificador "DETECCIÓN: Herramienta en brazo cambiador 1"@es ;
    ns1:textoExtracto "No se puede poner en el cabezal la herramienta del brazo cambiador' DETECCIÓN Al forzar una herramienta como herramienta de cabezal. CAUSA La herramienta está en el brazo cambiador 1. SOLUCIÓN Quitar la herramienta del brazo cambiador 1."@es .

ns1:FalloLexerContadores_8829 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer contadores (8829)" ;
    ns1:identificador "8829" ;
    ns1:textoExtracto "Fallo del lexer al reconocer contadores. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a contadores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:FalloLexerDecimales_8830 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer números decimales (8830)" ;
