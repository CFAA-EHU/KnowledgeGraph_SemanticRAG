    ns1:solucionaFallo ns1:ComponenteElectrico_ABSIND ;
    ns1:textoExtracto "Fallo en la alimentación del módulo ABSIND. SOLUCIÓN Comprobar la alimentación del módulo ABSIND."@es .

ns1:DiagnosticoFallo_9533 a ns1:DiagnosticoFallo ;
