ns1:Alarma8316ParametroNoPermitido_30c63a131c a ns1:Alarma ;
    rdfs:label "Alarma 8316: Parámetro no permitido" ;
    ns1:identificador "8316" ;
    ns1:mitigaRiesgo ns1:DiagnosticoParametroInvalidoEnCicloSentencia ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'Parámetro no permitido' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Algún parámetro del ciclo o la sentencia no es válido. SOLUCIÓN Revisar en el manual de programación los parámetros válidos para cada ciclo y sentencia." .

ns1:Alarma8317FuncionDNegativa_55af40bae9 a ns1:Alarma ;
    rdfs:label "Alarma 8317: Función D negativa" ;
    ns1:identificador "8317" ;
    ns1:mitigaRiesgo ns1:DiagnosticoCorrectorDeHerramientaNegativo ;
    ns1:textoExtracto "'Función D negativa' DETECCIÓN Durante la edición. CAUSA Corrector de herramienta negativo. SOLUCIÓN El corrector de herramienta debe ser positivo." .

ns1:Alarma8318EjeActivoDuplicadoEnBloque_7dcd3d35bc a ns1:Alarma ;
