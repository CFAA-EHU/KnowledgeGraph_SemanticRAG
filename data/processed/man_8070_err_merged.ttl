    rdfs:label "Registro de sistema redefinido" ;
    ns1:identificador "8856" ;
    ns1:textoExtracto "Registro de sistema redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (registros) con el mismo nombre. SOLUCIÓN Revisar el nombre de las registros." .

ns1:Error_8857 a ns1:DiagnosticoFallo ;
    rdfs:label "Múltiples módulos PRG" ;
    ns1:identificador "8857" ;
    ns1:textoExtracto "No puede haber mas de un módulo PRG. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programados dos módulos PRG. SOLUCIÓN Sólo puede haber un módulo PRG en el proyecto. Programar las instrucciones de ambos módulos en uno solo." .

ns1:Error_8858 a ns1:DiagnosticoFallo ;
    rdfs:label "Múltiples módulos CY1" ;
    ns1:identificador "8858" ;
    ns1:textoExtracto "No puede haber mas de un módulo CY1. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programados dos módulos CY1. SOLUCIÓN Sólo puede haber un módulo CY1 en el proyecto. Programar las instrucciones de ambos módulos en uno solo." .

ns1:Error_8859 a ns1:DiagnosticoFallo ;
    rdfs:label "Exceso de módulos periódicos" ;
    ns1:identificador "8859" ;
    ns1:textoExtracto "Demasiados módulos periódicos. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay demasiados módulos periódicos en el programa. SOLUCIÓN Agrupar varios módulos periódicos en una solo." .

ns1:Error_8860 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo periódico redefinido" ;
    ns1:identificador "8860" ;
    ns1:textoExtracto "Módulo periódico redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos módulos periódicos con el mismo periodo. SOLUCIÓN Un proyecto puede tener varios módulos periódicos, pero con diferente periodo. Revisar el periodo de los módulos periódicos. Si dos módulos deben tener el mismo periodo, programarlos en un único módulo." .

