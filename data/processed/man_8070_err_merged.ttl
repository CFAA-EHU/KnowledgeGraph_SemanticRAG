ns1:FalloComunicacion_9733 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación double AT Miss (9733)" ;
    ns1:identificador "9733" ;
    ns1:solucionaFallo ns1:SistemaBusSercosIII ;
    ns1:textoExtracto "Fallo en la comunicación double AT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador. SOLUCIÓN Revisar la conexión Sercos III." .

ns1:FalloComunicacion_9734 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación AT (9734)" ;
    ns1:identificador "9734" ;
    ns1:solucionaFallo ns1:SistemaBusSercosIII ;
    ns1:textoExtracto "Fallo en la comunicación AT. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador. SOLUCIÓN Revisar la conexión Sercos III." .

