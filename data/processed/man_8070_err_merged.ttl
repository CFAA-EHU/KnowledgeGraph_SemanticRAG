    ns1:mitigaRiesgo ns1:DiagnosticoFallo_EtherCAT_24594 ;
    ns1:textoExtracto "Módulo %u: Error de entrada del encoder incremental Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:ErrorEscrituraArchivoCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error de escritura en archivo CNC (#WRITE sin #OPEN)"@es ;
    ns1:identificador "0158" ;
    ns1:requiereMantenimiento ns1:OperacionOpen ;
    ns1:solucionaFallo ns1:OperacionWrite ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. [...] 0158 #WRITE necesita un #OPEN previo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir (#WRITE) en un archivo que no está abierto."@es .

ns1:ErrorEscrituraVariable_1513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1513: Error en la escritura de la variable" ;
    ns1:identificador "1513" ;
    ns1:textoExtracto "1513 'Error en la escritura de la variable' DETECCIÓN: Durante la ejecución. CAUSA: Las posibles causas son las siguientes: • La variable no existe. • La" .

ns1:ErrorEtherCAT_24626 a ns1:DiagnosticoFallo ;
