ns1:DiagnosticoFallo_4004 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro G00FEED mayor en CNC que en Regulador" ;
    ns1:identificador "4004" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED_CNC,
        ns1:Parametro_G00FEED_Regulador ;
    ns1:solucionaFallo [ a ns1:AvisoSeguridad ;
            ns1:textoExtracto "Valor del parámetro G00FEED diferente en el CNC y en el regulador." ] ;
    ns1:textoExtracto "Parámetro G00FEED mayor en CNC que en Regulador. SOLUCIÓN Poner en mismo valor en el CNC y el regulador." .

ns1:DiagnosticoFallo_4005 a ns1:DiagnosticoFallo ;
