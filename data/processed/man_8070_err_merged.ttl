ns1:Error4610 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus sin conexión" ;
    ns1:identificador "4610" ;
    ns1:mitigaRiesgo ns1:BusSercosIII ;
    ns1:textoExtracto "4610 Error bus sin conexión. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Se ha perdido la conexión física en el bus Sercos III; cable desconectado o esclavo apagado sin alimentación. y los esclavos. SOLUCIÓN Revisar el cableado, conexionado y alimentación del CNC" .

ns1:Error4611 a ns1:AvisoSeguridad ;
    rdfs:label "Error Bus, mensaje de bus no válido en fase 0" ;
    ns1:identificador "4611" ;
    ns1:mitigaRiesgo ns1:BusSercosIII ;
    ns1:textoExtracto "4611 Error Bus, mensaje de bus no valido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la comunicación con los esclavos en el bus SercosIII. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error4612 a ns1:AvisoSeguridad ;
