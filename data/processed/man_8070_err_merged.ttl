ns1:Error_3733 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3733: Error en el refresco de entradas analógicas locales",
        "Error en el refresco de entradas analógicas locales" ;
    ns1:identificador "3733" ;
    ns1:textoExtracto "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas",
        "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas analógicas locales desde el lazo de posición. CAUSA Alarma en una entrada analógica local. SOLUCIÓN Revisar el conexionado de las entradas y la sonda conectada." .

ns1:Error_3734 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3734: Opción de software PWM no permitida" ;
    ns1:identificador "3734" ;
    ns1:textoExtracto "3734 'Opción de software PWM no permitida' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no tiene activa la opción de software para la prestación PWM. SOLUCIÓN Contratar la correspondiente opción." .

ns1:Error_3736 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3736: El parámetro máquina PWMOUTPUT es 0" ;
    ns1:identificador "3736" ;
    ns1:solucionaFallo ns1:Parametro_PWMOUTPUT ;
    ns1:textoExtracto "3736 'El parámetro máquina PWMOUTPUT es 0' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA El parámetro PWMOUTPUT no puede tomar valor 0. SOLUCIÓN Asignar al parámetro PWMOUTPUT un valor dentro de rango (1-2)." .

ns1:Error_3745 a ns1:AvisoSeguridad ;
    rdfs:label "Colisión de sonda" ;
    ns1:identificador "3745" ;
    ns1:mitigaRiesgo ns1:Sensor_Sonda ;
    ns1:textoExtracto "La sonda ha colisionado. DETECCIÓN Durante la ejecución. CAUSA El PLC ha indicado mediante la marca GAPCOLLISION que se ha producido una colisión en el sensor." .

ns1:Error_3746 a ns1:AvisoSeguridad ;
    rdfs:label "Posición inicial fuera de rango" ;
    ns1:identificador "3746" ;
    ns1:textoExtracto "Posición inicial fuera de rango. DETECCIÓN En el arranque o recuperación de la fase operativa del bus. CAUSA El CNC ha calculado una posición que excede el rango permitido." .

ns1:Error_3749 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo de señal de sonda" ;
    ns1:identificador "3749" ;
    ns1:mitigaRiesgo ns1:Sensor_Sonda ;
    ns1:textoExtracto "No se ha detectado señal de sonda en #GAPCTRL o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Durante #GAPCTRL o #LEAP, el eje ha alcanzado el punto de acercamiento sin recibir la señal de sonda." .

ns1:Error_3753 a ns1:AvisoSeguridad ;
    rdfs:label "Diferencia de posición mayor que MAXDIFREF" ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "3753 Diferencia de posición mayor que MAXDIFREF. Pulsar ENTER + RESET para confirmar. DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del captador no se corresponde con la cota salvada en la última sesión del CNC. SOLUCIÓN Las posibles soluciones son las siguientes: • Verificar que la posición del eje indicada en 'Cota Actual' es correcta. Si es así, pulsar [ENTER] y luego [RESET] para quitar el error y continuar. Si la posición del eje no es correcta, es posible que haya un error en el captador. • Si la posición que debería tener el eje no es 'Cota Actual' sino 'Cota Esperada', quitar el error pulsando [ENTER] y luego [RESET]. A continuación, ejecutar G174 con la posición indicada en 'Cota Esperada' y finalmente reiniciar el CNC para recuperar dicha posición." .

ns1:Error_3755 a ns1:AvisoSeguridad ;
    rdfs:label "Parámetro máquina PLOOPRESOL incompatible con versión del regulador" ;
    ns1:identificador "3755" ;
    ns1:textoExtracto "3755 Parámetro máquina PLOOPRESOL incompatible con versión del regulador." .

ns1:Error_38 a ns1:AvisoSeguridad ;
    rdfs:label "Error en lectura de OpMode"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError_4000_4999 ;
