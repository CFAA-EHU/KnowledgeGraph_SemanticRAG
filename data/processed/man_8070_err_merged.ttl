ns1:AvisoSeguridad_1169 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1169: Sentencia #GET IPOOFFSET mal programada"@es ;
    ns1:identificador "1169" ;
    ns1:textoExtracto "La sentencia #GET IPOOFFSET se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1170 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1170: Sentencia #SYNC POS mal programada"@es ;
    ns1:identificador "1170" ;
