    rdfs:label "CNCEX(bloque,marca <,canal>)" ;
    ns1:identificador "8885" ;
    ns1:textoExtracto "CNCEX(bloque,marca <,canal>). DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_8886 a ns1:DiagnosticoFallo ;
    rdfs:label "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)" ;
    ns1:identificador "8886" ;
    ns1:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace) DETECCIÓN Durante la edición del programa PLC." .

ns1:Error_8894 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8894: 'Instrucción anterior incorrecta'"@es ;
    ns1:identificador "8894" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "No ignorar errores de compilación PLC"@es ;
            ns1:textoExtracto "SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta."@es ] ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador, antes de su conversión a C, ha detectado una instrucción incorrecta. La salida de errores señala la instrucción siguiente a la incorrecta. SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta."@es .

ns1:Error_8895 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8895: 'Instrucción incorrecta'"@es ;
    ns1:identificador "8895" ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador..."@es .

ns1:Error_8902 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #GAPCTRL" ;
    ns1:identificador "8902" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "#GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_8903 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #TECHTABLE" ;
    ns1:identificador "8903" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "#TECHTABLE<[N\"nombreFicheroMaterial\",> \"nombreTabla\" <OFF]> <Tvalor params> [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_8904 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en CNCRD" ;
    ns1:identificador "8904" ;
    ns1:solucionaFallo ns1:ManualInstalacion ;
    ns1:textoExtracto "CNCRD(idVar, canal, ejeLog, idxArray1, idxArray2, registro, marca <,registroError>) [...] DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La sintaxis del comando no es correcta." .

ns1:Error_8905 a ns1:DiagnosticoFallo ;
