ns1:ComponenteMecanico_HEAD2 a ns1:ComponenteMecanico ;
    ns1:identificador "HEAD2" ;
    ns1:textoExtracto "Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2."@es .

ns1:ComponenteMecanico_TABLE1 a ns1:ComponenteMecanico ;
