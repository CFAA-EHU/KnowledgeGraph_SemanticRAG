@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AccionBorradoEtiqueta a ns1:AccionProhibida ;
    rdfs:label "Borrado de etiqueta no utilizada en PLC"@es ;
    ns1:mitigaRiesgo ns1:Error8870 ;
    ns1:textoExtracto "borrar la etiqueta si no se [utiliza]."@es .

ns1:AccionProhibida_1264_CoordenadasActivas a ns1:AccionProhibida ;
    rdfs:label "Ejecución de funciones G74, G198, G199, #LINK o ciclos de palpado con transformación de coordenadas (CS/ACS) activa"@es ;
    ns1:activaAlarma ns1:Alarma_1264 ;
    ns1:textoExtracto "El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas. Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc."@es .

ns1:AccionProhibida_2449_Hirth a ns1:AccionProhibida ;
    rdfs:label "Programación de ejes Hirth en #PARALAX"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_2449 ;
    ns1:textoExtracto "Los ejes programados no pueden ser Hirth."@es .

ns1:AccionProhibida_2450_ExclusionEjes a ns1:AccionProhibida ;
    rdfs:label "Exclusión de ejes activos en transformación #PARALAX"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_2450 ;
    ns1:textoExtracto "Los ejes de la transformación activa, no pueden excluirse."@es .

ns1:AccionProhibida_8584 a ns1:AccionProhibida ;
    rdfs:label "Programación de sentencia o función G no permitida con compensación de radio activa (G41/G42)"@es ;
    ns1:activaAlarma ns1:Alarma_8584 ;
    ns1:textoExtracto "Se ha programado una sentencia o función G no permitida cuando está activa la compensación de radio (G41/G42)."@es .

ns1:AccionProhibida_8585 a ns1:AccionProhibida ;
    rdfs:label "Programación de sentencia o función G no permitida sin movimiento independiente activo"@es ;
    ns1:activaAlarma ns1:Alarma_8585 ;
    ns1:textoExtracto "Se ha programado una sentencia o función G no permitida"@es .

ns1:AccionProhibida_AparcarCabezalTandem a ns1:AccionProhibida ;
    rdfs:label "Aparcamiento de cabezales TANDEM"@es ;
    ns1:activaAlarma ns1:Alerta_1643 ;
    ns1:textoExtracto "No se permite aparcar cabezales TANDEM"@es .

ns1:AccionProhibida_AparcarEjesAcoplados a ns1:AccionProhibida ;
    rdfs:label "Aparcar ejes acoplados (Gantry/Tándem)" ;
    ns1:activaAlarma ns1:Alarma_1419 ;
    ns1:textoExtracto "No se permite aparcar ejes acoplados, Gantry o Tandem" .

ns1:AccionProhibida_CompensacionRadioActiva a ns1:AccionProhibida ;
    rdfs:label "Realizar cambios en configuración de ejes con compensación de radio activa"@es ;
    ns1:activaAlarma ns1:Alarma_1334 ;
    ns1:textoExtracto "Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo."@es .

ns1:AccionProhibida_DesplazarCabezalEsclavo a ns1:AccionProhibida ;
    rdfs:label "Desplazamiento individual de cabezal esclavo tándem"@es ;
    ns1:activaAlarma ns1:Alerta_1643 ;
    ns1:textoExtracto "El cabezal esclavo de una pareja tándem [...] no se puede desplazar individualmente."@es .

ns1:AccionProhibida_ModificarEjeAparcado a ns1:AccionProhibida ;
    rdfs:label "Modificar configuración de eje aparcado" ;
    ns1:activaAlarma ns1:Alarma_1433 ;
    ns1:textoExtracto "No se puede modificar la configuración de un eje aparcado." .

ns1:AccionProhibida_PerfilPoligonalMacroG8077 a ns1:AccionProhibida ;
    rdfs:label "Perfil poligonal en macro G8077" ;
    ns1:activaAlarma ns1:Alarma_2437 ;
    ns1:textoExtracto "El perfil debe estar construido con tramos rectos." .

ns1:AccionProhibida_ProgramaPrincipal a ns1:AccionProhibida ;
    rdfs:label "Uso de caracteres prohibidos en nombre de programa principal"@es ;
    ns1:identificador "\\ / : * ? \" < > |" ;
    ns1:textoExtracto "Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco."@es .

ns1:AccionProhibida_ProgramacionConjunta a ns1:AccionProhibida ;
    rdfs:label "Programación conjunta de T con G801-G851"@es ;
    ns1:textoExtracto "La función T no puede programarse en el mismo bloque que G801 a G813, G820, G821, G8331 a G833, G840 a G842, G850 o G851."@es .

ns1:AccionProhibida_ProgramacionEntreGYPrimerBloqueMovimiento a ns1:AccionProhibida ;
    rdfs:label "Programar entre la función G de trayectoria de empalme y el primer bloque de movimiento"@es ;
    ns1:textoExtracto "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento."@es .

ns1:AccionProhibida_ProgramacionFueraMacroG8777 a ns1:AccionProhibida ;
    rdfs:label "Programar funciones G8778, G8701 o G8702 fuera de macro G8777" ;
    ns1:activaAlarma ns1:Alarma_2436 ;
    ns1:textoExtracto "Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777." .

ns1:AccionProhibida_ProgramarEjeEsclavoAcoplo a ns1:AccionProhibida ;
    rdfs:label "Programar eje esclavo de acoplo activo o Gantry" ;
    ns1:activaAlarma ns1:Alarma_1432 ;
    ns1:textoExtracto "No se puede programar un eje esclavo de un acoplo o Gantry" .

ns1:AccionProhibida_ProgramarG_en_ProGTL3 a ns1:AccionProhibida ;
    rdfs:label "Programar la función G dentro de un perfil ProGTL3"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_2314 ;
    ns1:textoExtracto "SOLUCIÓN Programar la función G tras el inicio de un perfil con G841 o G842. [...] La función programada no está permitida dentro de la definición de un perfil ProGTL3."@es .

ns1:AccionProhibida_ResetNoJustificado a ns1:AccionProhibida ;
    rdfs:label "Pulsar RESET sin analizar causas" ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso" .

ns1:AccionProhibida_RevisarProgramacion_1451 a ns1:AccionProhibida ;
    rdfs:label "Revisar programación para alarma 1451"@es ;
    ns1:solucionaFallo ns1:Alarma_1451 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:AccionProhibida_SaltoEnBucle a ns1:AccionProhibida ;
    rdfs:label "Salto al interior de un bucle" ;
    ns1:textoExtracto "No se permite realizar saltos al interior de un bucle." .

ns1:AccionProhibida_SubrutinaLocal a ns1:AccionProhibida ;
    rdfs:label "Uso de caracteres prohibidos en nombre de subrutina local"@es ;
    ns1:identificador "/ ? \" < > | )" ;
    ns1:textoExtracto "Subrutina local: / ? \" < > | ) y espacio en blanco."@es .

ns1:AccionResetAparcamiento a ns1:AccionProhibida ;
    rdfs:label "RESET durante aparcamiento de ejes activos"@es ;
    ns1:identificador "3718" ;
    ns1:textoExtracto "3718 'RESET para aparcar ejes en movimiento o de la transformación/acoplo activo'"@es .

ns1:Accion_ComprobarConexion a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión y cableado" ;
    ns1:solucionaFallo ns1:Error_9632_ABSIND ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios."@es .

ns1:Accion_Comprobar_Tierra a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de conexiones de tierra en el armario" ;
    ns1:mitigaRiesgo ns1:Error_9529 ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:Accion_ConfiguracionBus a ns1:AccionProhibida ;
    rdfs:label "Configuración incorrecta de Mechatrolink II"@es ;
    ns1:solucionaFallo ns1:Fallo_9332 ;
    ns1:textoExtracto "Sólo es posible enviar los subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes. SOLUCIÓN Para poder acceder a las variables y parámetros del regulador (DRV) hay que configurar el bus como Mechatrolink II a 32 bytes"@es .

ns1:Accion_ContactarSoporte a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation" ;
    ns1:solucionaFallo ns1:Error_9632_ABSIND ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Accion_ContactoSoporte a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation para fichero corrupto"@es ;
    ns1:solucionaFallo ns1:Fallo_CorrupcionFichero ;
    ns1:textoExtracto "Si está corrupto, póngase en contacto con Fagor Automation."@es .

ns1:Accion_DetachMaster a ns1:TareaMantenimiento ;
    rdfs:label "Realizar 'Detach Master' en el configurador KPA"@es ;
    ns1:solucionaFallo ns1:Error_4606 ;
    ns1:textoExtracto "Realizar un 'Detach Master' en el configurador KPA antes de exportar el fichero ENI."@es .

ns1:Accion_PonerMarchaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Poner en marcha el programa PLC" ;
    ns1:textoExtracto "SOLUCIÓN Poner en marcha el programa PLC. Si es necesario, compilar el programa de PLC." .

ns1:Accion_RecompilarPLC a ns1:TareaMantenimiento ;
    rdfs:label "Borrar archivo plc_prg.sym y recompilar programa PLC"@es ;
    ns1:textoExtracto "Borrar el archivo plc_prg.sym y compilar el programa PLC para volver a crear este archivo."@es .

ns1:Accion_ServoOff a ns1:AccionProhibida ;
    rdfs:label "#SERVO OFF"@es ;
    ns1:solucionaFallo ns1:Fallo_ServoOff_M19 ;
    ns1:textoExtracto "sentencia #SERVO OFF [...] cancela la sentencia #SERVO ON y si puede abre el lazo."@es .

ns1:Accion_ServoOn a ns1:AccionProhibida ;
    rdfs:label "#SERVO ON"@es ;
    ns1:textoExtracto "sentencia #SERVO OFF cancela la sentencia #SERVO ON"@es .

ns1:Accion_Sustitucion_ABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Sustitución del módulo ABSIND o cable asociado" ;
    ns1:requiereConsumible ns1:Cable_Captacion_ABSIND,
        ns1:Modulo_ABSIND ;
    ns1:solucionaFallo ns1:Error_9529 ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

ns1:AlarmaArranqueCNC a ns1:Alarma ;
    rdfs:label "Alarma de fallo en arranque del CNC"@es ;
    ns1:activaAlarma ns1:FalloPosicionHerramienta ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC."@es .

ns1:AlarmaCableRoto_6043 a ns1:Alarma,
        ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de cable roto (6043)"@es ;
    ns1:identificador "6043" ;
    ns1:textoExtracto "El lazo ha detectado una alarma de cable roto."@es .

ns1:AlarmaSobrecorriente_6042 a ns1:Alarma,
        ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de sobrecorriente (6042)"@es ;
    ns1:identificador "6042" ;
    ns1:solucionaFallo [ a ns1:TareaMantenimiento ;
            rdfs:label "Revisión de conexionado y niveles de señal"@es ;
            ns1:textoExtracto "Revisar el correcto conexionado y niveles de señal de la captación local del CNC."@es ] ;
    ns1:textoExtracto "Alarma de sobrecorriente en la lectura de la entrada local de captación."@es,
        "Cortocircuito en el contaje local del CNC."@es .

ns1:Alarma_0006 a ns1:Alarma ;
    rdfs:label "Preparación sobrepasa la mitad del tiempo de ciclo"@es ;
    ns1:activaAlarma ns1:Parametro_PREPFREQ ;
    ns1:identificador "0006" ;
    ns1:solucionaFallo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Ajuste de PREPFREQ"@es ;
            ns1:textoExtracto "Disminuir el valor del parámetro PREPFREQ del canal."@es ] ;
    ns1:textoExtracto "0006 'La preparación sobrepasa la mitad del tiempo de ciclo' [...] SOLUCIÓN Disminuir el valor del parámetro PREPFREQ del canal."@es .

ns1:Alarma_0007 a ns1:Alarma ;
    rdfs:label "Reset incompleto del CNC"@es ;
    ns1:identificador "0007" ;
    ns1:solucionaFallo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Reinicio forzado del CNC"@es ;
            ns1:textoExtracto "Reiniciar el CNC. Si el usuario pulsa la tecla [RESET] por tercera vez, la aplicación CNC se cierra."@es ] ;
    ns1:textoExtracto "0007 'Para finalizar el reset es necesario reiniciar el CNC' [...] SOLUCIÓN Reiniciar el CNC."@es .

ns1:Alarma_0008 a ns1:Alarma ;
    rdfs:label "Tecla rechazada"@es ;
    ns1:identificador "0008" ;
    ns1:solucionaFallo [ a ns1:DiagnosticoFallo ;
            rdfs:label "Verificación de teclado"@es ;
            ns1:textoExtracto "Comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)."@es ] ;
    ns1:textoExtracto "0008 'La tecla ha sido rechazada' [...] SOLUCIÓN Si ha sido un acto involuntario del usuario, ignorar el error. Si el error persiste [...] comprobar en el teclado que no hay ninguna tecla pulsada (enganchada)."@es .

ns1:Alarma_0009 a ns1:Alarma ;
    rdfs:label "Fallo en gestión de FIFO de AEP"@es ;
    ns1:identificador "0009" ;
    ns1:textoExtracto "0009 Aviso de sistema: fallo en la gestión de la fifo de aep. [...] CAUSA El programa tiene un gran número de funciones G o parámetros aritméticos."@es .

ns1:Alarma_0045 a ns1:Alarma ;
    rdfs:label "Alarma 0045: Nombre de cabezal no válido" ;
    ns1:activaAlarma ns1:Parametro_SPDLNAME ;
    ns1:identificador "0045" ;
    ns1:textoExtracto "0045 'Nombre de cabezal no válido' [...] CAUSA El usuario ha definido el parámetro máquina con un nombre de cabezal incorrecto." .

ns1:Alarma_0046 a ns1:Alarma ;
    rdfs:label "Alarma 0046: Eje inexistente" ;
    ns1:activaAlarma ns1:Parametro_AXISNAME,
        ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:identificador "0046" ;
    ns1:textoExtracto "0046 'Eje inexistente' [...] CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." .

ns1:Alarma_0047 a ns1:Alarma ;
    rdfs:label "Alarma 0047: Un eje principal no puede definirse como esclavo" ;
    ns1:identificador "0047" ;
    ns1:textoExtracto "0047 'Un eje principal no puede definirse como esclavo' [...] DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:Alarma_0048 a ns1:Alarma ;
    rdfs:label "Alarma 0048: Un eje no puede ser esclavo de varios maestros"@es ;
    ns1:identificador "0048" ;
    ns1:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry ya está definido como eje esclavo en otro eje gantry. SOLUCIÓN Corregir la tabla de ejes gantry."@es .

ns1:Alarma_0049 a ns1:Alarma ;
    rdfs:label "Alarma 0049: Un eje maestro no puede ser a su vez esclavo y viceversa"@es ;
    ns1:identificador "0049" ;
    ns1:textoExtracto "0049 'Un eje maestro no puede ser a su vez esclavo y viceversa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje maestro de un eje gantry es el eje esclavo en otro eje gantry o viceversa. SOLUCIÓN Corregir la tabla de ejes gantry."@es .

ns1:Alarma_0050 a ns1:Alarma ;
    rdfs:label "Alarma 0050: Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)"@es ;
    ns1:identificador "0050" ;
    ns1:textoExtracto "0050 'Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no son del mismo tipo; lineales o rotativos. SOLUCIÓN Los ejes de una pareja gantry tienen que ser del mismo tipo, lineales o rotativos (parámetro AXISTYPE)."@es .

ns1:Alarma_0051 a ns1:Alarma ;
    rdfs:label "Alarma 0051: Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor"@es ;
    ns1:identificador "0051" ;
    ns1:textoExtracto "0051 'Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de un eje gantry no tienen las mismas propiedades. SOLUCIÓN Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes. • Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales. • Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales."@es .

ns1:Alarma_0053 a ns1:Alarma ;
    rdfs:label "Alarma 0053: Parámetro MPGAXIS repetido en varios volantes" ;
    ns1:identificador "0053" ;
    ns1:monitoreaParametro ns1:Parametro_MPGAXIS ;
    ns1:textoExtracto "0053 'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros de manual, hay dos o más volantes asignados al mismo eje. SOLUCIÓN Un eje sólo puede tener asignando un volante." .

ns1:Alarma_0054 a ns1:Alarma ;
    rdfs:label "Alarma 0054: Los ejes MOVAXIS y COMPAXIS deben ser distintos" ;
    ns1:identificador "0054" ;
    ns1:monitoreaParametro ns1:Parametro_COMPAXIS,
        ns1:Parametro_MOVAXIS ;
    ns1:textoExtracto "0054 'Los ejes MOVAXIS y COMPAXIS deben ser distintos' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una de las tablas de compensación cruzada coinciden el eje compensado y el eje cuyo movimiento altera al eje que se compensa. SOLUCIÓN En cada tabla de compensación cruzada, ambos ejes deben ser distintos (parámetros MOVAXIS y COMPAXIS)." .

ns1:Alarma_0055 a ns1:Alarma ;
    rdfs:label "Alarma 0055: Un mismo eje es a la vez causa y efecto de la compensación cruzada" ;
    ns1:identificador "0055" ;
    ns1:monitoreaParametro ns1:Parametro_COMPAXIS,
        ns1:Parametro_MOVAXIS ;
    ns1:textoExtracto "0055 'Un mismo eje es a la vez causa y efecto de la compensación cruzada' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación cruzada, siguiendo las diferentes asociaciones de ejes compensados (parámetro COMPAXIS) y ejes cuyos movimientos alteran a los ejes que se compensan (parámetro MOVAXIS), hay un eje cuyo movimiento depende de sí mismo. SOLUCIÓN Revisar la relación entre las compensaciones cruzadas definidas. Comprobar los parámetros MOVAXIS y COMPAXIS de las compensaciones cruzadas definidas." .

ns1:Alarma_0056 a ns1:Alarma ;
    rdfs:label "Alarma 0056: Posiciones de la tabla de compensación no ascendentes" ;
    ns1:identificador "0056" ;
    ns1:monitoreaParametro ns1:Parametro_POSITION ;
    ns1:textoExtracto "0056 'Posiciones de la tabla de compensación no ascendentes' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de compensación, los puntos a compensar no están ordenados correctamente o el valor a compensar en todos los puntos tienen valor cero. SOLUCIÓN El parámetro POSITION dentro de las tablas de compensación tiene que tomar valores ascendentes. El valor a compensar no puede ser cero en todos los puntos." .

ns1:Alarma_0057 a ns1:Alarma ;
    rdfs:label "Alarma 0057: Tabla de compensación con pendiente de error superior a 1" ;
    ns1:identificador "0057" ;
    ns1:textoExtracto "0057 'Tabla de compensación con pendiente de error superior a 1' DETECCIÓN Durante la validación de los parámetros máquina (tabla de compensación de husillo)." .

ns1:Alarma_0058 a ns1:Alarma ;
    rdfs:label "Alarma 0058: Reinicio requerido para cambios en tabla HMI"@es ;
    ns1:activaAlarma ns1:TablaHMI ;
    ns1:identificador "0058" ;
    ns1:textoExtracto "Para asumir los cambios en la tabla de HMI es necesario rearrancar el CNC. SOLUCIÓN: Reiniciar el CNC."@es .

ns1:Alarma_0059 a ns1:Alarma ;
    rdfs:label "Alarma 0059: Reinicio requerido para cambios en tabla de almacén"@es ;
    ns1:activaAlarma ns1:TablaAlmacen ;
    ns1:identificador "0059" ;
    ns1:textoExtracto "Para asumir los cambios en la tabla del almacén es necesario rearrancar el CNC. SOLUCIÓN: Reiniciar el CNC."@es .

ns1:Alarma_0060 a ns1:Alarma ;
    rdfs:label "Alarma 0060: Velocidad manual excede límite del eje"@es ;
    ns1:activaAlarma ns1:Parametro_MAXMANFEED ;
    ns1:identificador "0060" ;
    ns1:textoExtracto "'La velocidad máxima de manual supera la velocidad máxima del eje'. CAUSA: El parámetro MAXMANFEED es superior a G00FEED. SOLUCIÓN: Disminuir el valor del parámetro MAXMANFEED; debe ser inferior a G00FEED."@es .

ns1:Alarma_0061 a ns1:Alarma ;
    rdfs:label "Alarma 0061: Velocidad rápida manual excede límite del eje"@es ;
    ns1:activaAlarma ns1:Parametro_JOGRAPFEED ;
    ns1:identificador "0061" ;
    ns1:textoExtracto "'La velocidad rápida de manual supera la velocidad máxima del eje'. CAUSA: El parámetro JOGRAPFEED es superior a G00FEED. SOLUCIÓN: Disminuir el valor del parámetro JOGRAPFEED; debe ser inferior a G00FEED."@es .

ns1:Alarma_0062 a ns1:Alarma ;
    rdfs:label "Alarma 0062: Velocidad de jog continuo excede límite del eje"@es ;
    ns1:activaAlarma ns1:Parametro_JOGFEED ;
    ns1:identificador "0062" ;
    ns1:textoExtracto "'La velocidad de jog continuo supera la velocidad máxima del eje'. CAUSA: El parámetro JOGFEED es superior a G00FEED. SOLUCIÓN: Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED."@es .

ns1:Alarma_0069 a ns1:Alarma ;
    rdfs:label "Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene" ;
    ns1:activaAlarma ns1:Parametro_DECINPUT ;
    ns1:identificador "0069" ;
    ns1:textoExtracto "0069 'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry tiene micro y el eje maestro no. SOLUCIÓN En un eje gantry podrá tener micro de referencia el eje maestro, ambos ejes o ninguno (parámetro DECINPUT)." .

ns1:Alarma_0070 a ns1:Alarma ;
    rdfs:label "Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo" ;
    ns1:activaAlarma ns1:Parametro_LIMIT ;
    ns1:identificador "0070" ;
    ns1:textoExtracto "0070 'Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En alguna pareja gantry o tándem, los límites de software de ambos ejes son distintos. SOLUCIÓN Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)." .

ns1:Alarma_0071 a ns1:Alarma ;
    rdfs:label "Vigilancia de error de seguimiento no activa en el CNC" ;
    ns1:activaAlarma ns1:Parametro_FLWEMONITOR ;
    ns1:identificador "0071" ;
    ns1:textoExtracto "0071 'Vigilancia de error de seguimiento no activa en el CNC' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En algún set de parámetros, no está activa la vigilancia del error de seguimiento. Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada. SOLUCIÓN Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)." .

ns1:Alarma_0072 a ns1:Alarma ;
    rdfs:label "Alarma de captación sin activar" ;
    ns1:activaAlarma ns1:Parametro_FBACKAL ;
    ns1:identificador "0072" ;
    ns1:textoExtracto "0072 'Alarma de captación sin activar' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En algún set de parámetros de un eje o cabezal analógico, no está activa la alarma de captación. Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada. SOLUCIÓN En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)." .

ns1:Alarma_0074 a ns1:Alarma ;
    rdfs:label "Alarma 0074: Test de tendencia sin activar" ;
    ns1:identificador "0074" ;
    ns1:textoExtracto "0074 'Test de tendencia sin activar'" .

ns1:Alarma_0080 a ns1:Alarma ;
    rdfs:label "Alarma 0080: Validación de parámetros generales"@es ;
    ns1:identificador "0080" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0080 ;
    ns1:textoExtracto "'Para validar el eje, hay que validar la tabla de PARAMETROS GENERALES' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha añadido algún eje al sistema (parámetro NAXIS), y sin validar la tabla de parámetros generales, ha intentado validar la tabla de parámetros de uno de los nuevos ejes."@es .

ns1:Alarma_0081 a ns1:Alarma ;
    rdfs:label "Alarma 0081: Banda de muerte inferior a resolución del eje"@es ;
    ns1:identificador "0081" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0081 ;
    ns1:textoExtracto "'La banda de muerte no puede ser menor que la resolución del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La banda de muerte es menor que la resolución del eje."@es .

ns1:Alarma_0082 a ns1:Alarma ;
    rdfs:label "Alarma 0082: Compensación de husillo o cruzada imposible"@es ;
    ns1:identificador "0082" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0082 ;
    ns1:textoExtracto "'Compensación de husillo o cruzada imposible para todas las gamas del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En una compensación, el eje que se mueve (parámetro MOVAXIS) es rotativo y no tiene los mismos límites de módulo en todos los sets de parámetros."@es .

ns1:Alarma_0083 a ns1:Alarma ;
    rdfs:label "Alarma 0083: Tipos de regulador incompatibles en ejes gantry"@es ;
    ns1:identificador "0083" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0083 ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben ser del mismo tipo (DRIVETYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink."@es .

ns1:Alarma_0085 a ns1:Alarma ;
    rdfs:label "No hay ningún eje digital (Sercos/Mechatrolink)"@es ;
    ns1:identificador "0085" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_AsignacionEjes ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros OEM hay definidas variables de regulador (DRV) y no hay ejes digitales (Sercos/Mechatrolink) en el sistema."@es .

ns1:Alarma_0086 a ns1:Alarma ;
    rdfs:label "No es eje digital (Sercos/Mechatrolink)"@es ;
    ns1:identificador "0086" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_AsignacionEjes ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA Hay definida una variable de regulador (DRV) para un eje que no es digital (Sercos/Mechatrolink)."@es .

ns1:Alarma_0087 a ns1:Alarma ;
    rdfs:label "Número máximo de variables DRV sobrepasado"@es ;
    ns1:identificador "0087" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_AsignacionEjes ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros OEM hay definidas más variables de regulador (DRV) de las permitidas."@es .

ns1:Alarma_0088 a ns1:Alarma ;
    rdfs:label "Traza de variables internas activada"@es ;
    ns1:identificador "0088" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA El CNC está ejecutando la traza de una variable interna."@es .

ns1:Alarma_0089 a ns1:Alarma ;
    rdfs:label "Se arranca con un único canal debido a errores detectados en parámetros máquina"@es ;
    ns1:identificador "0089" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. CAUSA La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal. Por ejemplo, un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema."@es .

ns1:Alarma_0120 a ns1:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED"@es ;
    ns1:activaAlarma ns1:Maquina_CNC ;
    ns1:identificador "0120" ;
    ns1:textoExtracto "0120 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Alarma_0121 a ns1:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED"@es ;
    ns1:activaAlarma ns1:Maquina_CNC ;
    ns1:identificador "0121" ;
    ns1:textoExtracto "0121 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Alarma_0122 a ns1:Alarma ;
    rdfs:label "No es posible validar cambio de parámetro máquina"@es ;
    ns1:activaAlarma ns1:Maquina_CNC ;
    ns1:identificador "0122" ;
    ns1:textoExtracto "0122 No es posible validar cambio de parámetro máquina. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no puede validar los parámetros máquina porque no ha terminado de arrancar. SOLUCIÓN Esperar a que el CNC arranque para validar los parámetros máquina."@es .

ns1:Alarma_0123 a ns1:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error"@es ;
    ns1:activaAlarma ns1:Maquina_CNC ;
    ns1:identificador "0123" ;
    ns1:textoExtracto "0123 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Alarma_0124 a ns1:Alarma ;
    rdfs:label "El número de cores definidos en el código de validación NO es coherente con el hardware"@es ;
    ns1:activaAlarma ns1:Maquina_CNC ;
    ns1:identificador "0124" ;
    ns1:textoExtracto "0124 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido."@es .

ns1:Alarma_0174 a ns1:Alarma ;
    rdfs:label "Ejes rotativos incompletos" ;
    ns1:identificador "0174" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0174 ;
    ns1:textoExtracto "0174 Ejes rotativos, es necesario completar la vuelta completa. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El CNC no puede activar la compensación volumétrica porque entre los ejes que se mueven (parámetro MOVAXIS) hay más de un eje rotativo módulo, y el recorrido del segundo eje no es completo (0 a 360º)." .

ns1:Alarma_0200 a ns1:Alarma ;
    rdfs:label "Fallo en la petición a un VxD" ;
    ns1:identificador "0200" ;
    ns1:textoExtracto "0200 'Fallo en la petición a un VxD' DETECCIÓN Al leer el estado de la batería. CAUSA El CNC no se puede conectar con VcompciD." .

ns1:Alarma_0201 a ns1:Alarma ;
    rdfs:label "Corte en la red. PC alimentado con batería" ;
    ns1:identificador "0201" ;
    ns1:textoExtracto "0201 'Corte en la red. PC alimentado con batería' DETECCIÓN Al leer el estado de la batería." .

