ns1:Fallo_1084 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de plano con compensación de radio activa"@es ;
    ns1:identificador "1084" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo o los ejes que componen el plano, con la compensación del radio activa. SOLUCIÓN Anular la compensación para definir el nuevo plano de trabajo."@es .

ns1:Fallo_1085 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G41/G42 si falta el primer o segundo eje del plano activo"@es ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal."@es .

ns1:Fallo_1108_EjeDoblementeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1108: Eje doblemente programado"@es ;
    ns1:identificador "1108" ;
    ns1:solucionaFallo ns1:ModoOperacion_CYL,
        ns1:ModoOperacion_FACE,
        ns1:ModoOperacion_G0,
        ns1:ModoOperacion_G1,
        ns1:ModoOperacion_G2,
        ns1:ModoOperacion_G20,
        ns1:ModoOperacion_G3,
        ns1:ModoOperacion_G33,
        ns1:ModoOperacion_G63,
        ns1:ModoOperacion_G8,
        ns1:ModoOperacion_G9 ;
    ns1:textoExtracto "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución. CAUSA En alguna de las siguientes funciones hay programado algún eje más de una vez. • Movimiento de ejes en G0, G1, G2, G3, G8 o G9. • Roscado G33 o G63. • Sentencias #FACE o #CYL. • Selección de plano, G20."@es .

ns1:Fallo_1142 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1142: Sentencia #TIME mal programada" ;
    ns1:identificador "1142" ;
    ns1:textoExtracto "'La sentencia #TIME se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1146 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1146: Trayectoria no lineal antes de G37" ;
    ns1:identificador "1146" ;
    ns1:textoExtracto "'La trayectoria anterior a G37 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento anterior a la entrada tangencial no es lineal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1147 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1147: Trayectoria no lineal después de G38" ;
    ns1:identificador "1147" ;
    ns1:textoExtracto "'La trayectoria posterior a G38 debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA El bloque de movimiento posterior a la salida tangencial no es lineal. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1149 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1149: Empalme de trayectoria imposible (G36/G37/G38/G39)" ;
    ns1:identificador "1149" ;
    ns1:textoExtracto "'No es posible ejecutar G36/G37/G38/G39 programada' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede realizar la trayectoria de empalme con el radio programado. SOLUCIÓN Revisar el radio programado. Comprobar que el empalme es realmente posible entre los bloques inicial y final." .

ns1:Fallo_1150 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1150: Funciones G36/G37/G38/G39 sin bloque de movimiento siguiente" ;
    ns1:identificador "1150" ;
    ns1:textoExtracto "'Las funciones G36/G37/G38/G39 deben estar seguidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un segundo bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el segundo bloque de movimiento." .

ns1:Fallo_1151 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1151: Funciones G8/G36/G37/G38/G39 sin bloque de movimiento previo" ;
    ns1:identificador "1151" ;
    ns1:textoExtracto "'Las funciones G8/G36/G37/G38/G39 deben estar precedidas de un bloque de movimiento' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de un primer bloque de movimiento para realizar la trayectoria de empalme. SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." .

ns1:Fallo_1152 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1152: Anidamiento de subrutinas excedido" ;
    ns1:identificador "1152" ;
    ns1:textoExtracto "'Anidamiento de subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el número de niveles de imbricación permitido." .

ns1:Fallo_1180 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de tipo de eje (AXISTYPE)" ;
    ns1:identificador "1180" ;
    ns1:monitoreaParametro ns1:Parametro_AXISTYPE ;
    ns1:textoExtracto "Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo. Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)." .

ns1:Fallo_1181 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de modo de eje rotativo (AXISMODE)",
        "Error de acoplo en modo manual aditivo (G201)"@es ;
    ns1:identificador "1181" ;
    ns1:monitoreaParametro ns1:AXISMODEModoDeEje ;
    ns1:textoExtracto "#LINK: no se puede definir como esclavo un eje activo en G201. DETECCIÓN: Durante la ejecución. CAUSA: El eje esclavo de un acoplo está activo en modo manual aditivo (G201). SOLUCIÓN: Anular el modo manual aditivo para poder acoplar el eje."@es .

ns1:Fallo_1182 a ns1:DiagnosticoFallo ;
    rdfs:label "Exceso de acoplos programados"@es ;
    ns1:identificador "1182" ;
    ns1:textoExtracto "#LINK: demasiados acoplos programados. DETECCIÓN: Durante la ejecución. CAUSA: El número de acoplos definidos supera el máximo permitido. SOLUCIÓN: El máximo número de acoplos que pueden estar activos en un canal es igual al número de ejes del canal menos tres."@es .

ns1:Fallo_1183 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #LINK mal programada"@es ;
    ns1:identificador "1183" ;
    ns1:textoExtracto "La sentencia #LINK se programa sola en el bloque. DETECCIÓN: Durante la ejecución. CAUSA: La sentencia no está programada sola en el bloque. SOLUCIÓN: Revisar la programación."@es .

ns1:Fallo_1184 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes maestro/esclavo idénticos"@es ;
    ns1:identificador "1184" ;
    ns1:textoExtracto "#LINK: el eje maestro y esclavo coinciden. DETECCIÓN: Durante la ejecución. CAUSA: Los ejes maestro y esclavo del acoplo son el mismo eje. SOLUCIÓN: Los ejes maestro y esclavo han de ser diferentes."@es .

ns1:Fallo_1185 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje esclavo con múltiples maestros"@es ;
    ns1:identificador "1185" ;
    ns1:textoExtracto "#LINK: un eje no puede ser esclavo de varios maestros. DETECCIÓN: Durante la ejecución. CAUSA: Un eje es esclavo de varios maestros. SOLUCIÓN: Un eje sólo puede ser esclavo de un maestro."@es .

ns1:Fallo_1186 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de roles maestro/esclavo"@es ;
    ns1:identificador "1186" ;
    ns1:textoExtracto "#LINK: un eje maestro no puede ser esclavo en otro acoplo y viceversa. DETECCIÓN: Durante la ejecución. CAUSA: Un eje no puede ser esclavo en un acoplo y maestro en otro. SOLUCIÓN: Un eje no puede ser maestro en un acoplo y esclavo en otro."@es .

ns1:Fallo_1187 a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de eje repetido"@es ;
    ns1:identificador "1187" ;
    ns1:textoExtracto "#AXIS: nombre de eje repetido. DETECCIÓN: Durante la ejecución. CAUSA: El mismo eje se ha programado más de una vez en la sentencia."@es .

ns1:Fallo_1204 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia mal programada o inexistente"@es ;
    ns1:identificador "1204" ;
    ns1:textoExtracto "1204 'Sentencia mal programada o inexistente' DETECCIÓN Durante la ejecución. CAUSA La sentencia no existe o está mal programada. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1205 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: tipo de offset desconocido"@es ;
    ns1:identificador "1205" ;
    ns1:textoExtracto "1205 '#CALL AX/#SET AX: tipo de offset desconocido' DETECCIÓN Durante la ejecución. CAUSA El tipo de offset programado en la sentencia no existe. SOLUCIÓN Los tipos de offset válidos son ALL, LOCOF, FIXOF, TOOLOF, ORGOF, MEASOF, MANOF."@es .

ns1:Fallo_1206 a ns1:DiagnosticoFallo ;
    rdfs:label "Se espera ','"@es ;
    ns1:identificador "1206" ;
    ns1:textoExtracto "1206 'Se espera \",\"' DETECCIÓN Durante la ejecución. CAUSA Falta programar \",\" en la sentencia o función. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1209 a ns1:DiagnosticoFallo ;
    rdfs:label "Índice de eje fuera de rango"@es ;
    ns1:identificador "1209" ;
    ns1:textoExtracto "1209 'Indice de eje fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • En las sentencias #CALL AX/#SET AX la posición para algún eje no es correcta; la posición está ocupada, la posición supera el máximo permitido o no hay hueco para el eje. • Programación del nombre del eje con un comodín incorrecto. SOLUCIÓN Las posibles soluciones son las siguientes: • La sentencia puede colocar los ejes en cualquier posición libre comprendida entre 1 y un número igual al total de ejes más cabezales del sistema. • Los posibles comodines son de @1 a @6 y @SM."@es .

ns1:Fallo_1210 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: nombre de eje repetido"@es ;
    ns1:identificador "1210" ;
    ns1:textoExtracto "1210 '#CALL AX/#SET AX: nombre de eje repetido' DETECCIÓN Durante la ejecución. CAUSA El mismo eje se ha programado más de una vez en la sentencia. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1211 a ns1:DiagnosticoFallo ;
    rdfs:label "#CALL AX/#SET AX: índice de eje repetido"@es ;
    ns1:identificador "1211" ;
    ns1:textoExtracto "1211 '#CALL AX/#SET AX: índice de eje repetido' DETECCIÓN Durante la ejecución. CAUSA Dos ejes intentan ocupar la mismo posición en el canal. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1214 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1214: Demasiados ejes en configuración"@es ;
    ns1:identificador "1214" ;
    ns1:textoExtracto "#CALL AX/#SET AX: demasiados ejes"@es .

ns1:Fallo_1221 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1221: Sentencia #SET AX no programada sola en bloque"@es ;
    ns1:identificador "1221" ;
    ns1:textoExtracto "'La sentencia #SET AX se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1222 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1222: Bloque #COMMENT END sin apertura"@es ;
    ns1:identificador "1222" ;
    ns1:textoExtracto "'No se espera #COMMENT END' DETECCIÓN Durante la ejecución. CAUSA Hay un bloque de fin de comentario (#COMMENT END) pero falta el bloque de abrir comentario (#COMMENT BEGIN). SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1223 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1223: Fin de fichero dentro de bloque comentario"@es ;
    ns1:identificador "1223" ;
    ns1:textoExtracto "'Carácter de fin de fichero dentro de bloque comentario' DETECCIÓN Durante la ejecución. CAUSA El CNC no encuentra el final de programa. Es probable que haya un bloque de abrir comentario (#COMMENT BEGIN) pero falta el bloque de fin de comentario (#COMMENT END). SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1224 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1224: Operador de asignación faltante o desconocido"@es ;
    ns1:identificador "1224" ;
    ns1:textoExtracto "'Falta operador u operador desconocido' DETECCIÓN Durante la ejecución. CAUSA Falta un operador de asignación tras la variable o parámetro. SOLUCIÓN Los operadores de asignación válidos son '=', '+=', '-=', '*=', '/=.'"@es .

ns1:Fallo_1225 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1225: División por cero"@es ;
    ns1:identificador "1225" ;
    ns1:textoExtracto "'División por cero' DETECCIÓN Durante la ejecución. CAUSA Una de las operaciones programadas realiza una división por cero. SOLUCIÓN Revisar la programación. Si está trabajando con parámetros es posible que en la historia del programa ese parámetro haya adquirido valor cero. Comprobar que el parámetro no llega a la operación con ese valor."@es .

ns1:Fallo_1226 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1226: Falta eje frontal para compensación de herramienta"@es ;
    ns1:identificador "1226" ;
    ns1:textoExtracto "No hay eje frontal en el plano para compensar el factor de forma de herramienta de torno. [...] SOLUCIÓN Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)."@es .

ns1:Fallo_1227 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1227: Falta eje lateral para compensación de herramienta"@es ;
    ns1:identificador "1227" ;
    ns1:textoExtracto "No hay eje lateral en el plano para compensar el factor de forma de herramienta de torno. [...] SOLUCIÓN Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)."@es .

ns1:Fallo_1228 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1228: Eje longitudinal no definido"@es ;
    ns1:identificador "1228" ;
    ns1:solucionaFallo ns1:LONGAXIS_3b1e99e02b ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje longitudinal. SOLUCIÓN Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)."@es .

ns1:Fallo_1229 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1229: Anidamiento de sentencias condicionales excedido"@es,
        "Fallo 1229: Anidamiento de sentencias condicionales sobrepasado"@es ;
    ns1:identificador "1229" ;
    ns1:textoExtracto "1229 Anidamiento de sentencias condicionales sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR,"@es .

ns1:Fallo_1309 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1309: 'Se espera nombre de fichero'"@es ;
    ns1:identificador "1309" ;
    ns1:textoExtracto "1309 'Se espera nombre de fichero' [...] DETECCIÓN Durante la ejecución. CAUSA No hay ningún programa seleccionado para la ejecución. SOLUCIÓN Seleccionar el programa a ejecutar."@es .

ns1:Fallo_1310 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1310: 'Línea de programa demasiado larga'"@es ;
    ns1:identificador "1310" ;
    ns1:textoExtracto "1310 'Línea de programa demasiado larga' [...] DETECCIÓN Durante la ejecución. CAUSA El número de caracteres en la"@es .

ns1:Fallo_1326 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1326: Valor erróneo para asignar a variable",
        "Valor erróneo para asignar a variable" ;
    ns1:identificador "1326" ;
    ns1:textoExtracto "1326 'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución." .

ns1:Fallo_1327 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición del cabezal doblemente programada" ;
    ns1:identificador "1327" ;
    ns1:textoExtracto "1327 Posición del cabezal doblemente programada. DETECCIÓN Durante la ejecución. CAUSA La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque. SOLUCIÓN Revisar la programación. Programar la velocidad de posicionamiento una única vez en el bloque." .

ns1:Fallo_1328 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia $FOR sin $ENDFOR" ;
    ns1:identificador "1328" ;
    ns1:textoExtracto "1328 'Sentencia $FOR sin $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA Hay programada una instrucción $FOR pero falta su $ENDFOR. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1330 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de imagen espejo incorrecta" ;
    ns1:identificador "1330" ;
    ns1:textoExtracto "1330 'Programación de imagen espejo incorrecta' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la función G14 (imagen espejo). SOLUCIÓN Revisar la programación." .

ns1:Fallo_1347 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #CYL OFF con el tipo de cinemática activa" ;
    ns1:identificador "1347" ;
    ns1:solucionaFallo ns1:Sentencia_CYL_OFF ;
    ns1:textoExtracto "1347 'No se admite #CYL OFF con el tipo de cinemática activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #CYL OFF y no hay activo ningún mecanizado en la superficie cilíndrica. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1348 a ns1:DiagnosticoFallo ;
    rdfs:label "#CYL: radio no válido" ;
    ns1:identificador "1348" ;
    ns1:solucionaFallo ns1:Sentencia_CYL_Radio ;
    ns1:textoExtracto "1348 '#CYL: radio no válido' DETECCIÓN Durante la ejecución. CAUSA El radio programado en la sentencia #CYL es negativo o cero. Si el radio es variable, este intenta pasar por el centro del cilindro generando un radio nulo. SOLUCIÓN Revisar la programación. El radio debe ser positivo y en el caso de ser un radio variable, este no puede pasar por el centro del cilindro." .

ns1:Fallo_1365 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1365: Velocidad del cabezal negativa" ;
    ns1:identificador "1365" ;
    ns1:solucionaFallo ns1:G63_73c48908e7,
        ns1:VelocidadDelCabezal_6d960e6e88 ;
    ns1:textoExtracto "1365 'No se admite velocidad del cabezal negativa' [...] CAUSA Velocidad de cabezal negativa. SOLUCIÓN La velocidad de cabezal debe ser positiva; sólo se permite un valor negativo si se programa en el mismo bloque que la función G63." .

ns1:Fallo_1367 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1367: Cambio de gama y movimiento del cabezal simultáneos" ;
    ns1:identificador "1367" ;
    ns1:solucionaFallo ns1:FuncionG112CambioDeSetDeParametros_eb134dec2f,
        ns1:FuncionMMovimientoDeCabezal_578afd71ae ;
    ns1:textoExtracto "1367 'No se permite un cambio de gama y movimiento del cabezal simultáneos' [...] CAUSA En el mismo bloque hay programada una función M de movimiento de cabezal y la función G112 de cambio del set de parámetros." .

ns1:Fallo_1368 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1368: Centro y radio del círculo programados simultáneamente" ;
    ns1:identificador "1368" ;
    ns1:solucionaFallo ns1:CentroDelCirculo,
        ns1:RadioDelCirculo ;
    ns1:textoExtracto "1368 'No se permite programar centro y radio del círculo simultáneamente' [...] CAUSA La interpolación circular está definida con el radio y el centro. SOLUCIÓN En una interpolación circular hay que programar las cotas del punto final y además el radio o el centro del círculo." .

ns1:Fallo_1380 a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo fijo mal programado" ;
    ns1:identificador "1380" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_cfd5090cf7 ;
    ns1:textoExtracto "'Ciclo fijo mal programado' DETECCIÓN Durante la ejecución. CAUSA En el bloque de definición de un ciclo fijo, no se puede programar nada tras los parámetros del ciclo. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1381 a ns1:DiagnosticoFallo ;
    rdfs:label "Ciclo fijo inexistente" ;
    ns1:identificador "1381" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion_cfd5090cf7 ;
    ns1:textoExtracto "'Ciclo fijo inexistente' DETECCIÓN Durante la ejecución. CAUSA El ciclo fijo programado no existe. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1382 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no permitido en ciclo fijo" ;
    ns1:identificador "1382" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLosParametrosObligatoriosYPermitidosParaCadaCicloFijo ;
    ns1:textoExtracto "'Parámetro no permitido en ciclo fijo' DETECCIÓN Durante la ejecución. CAUSA Uno de los parámetros programados no está permitido para ese ciclo fijo. SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:Fallo_1383 a ns1:DiagnosticoFallo ;
    rdfs:label "No programado parámetro obligatorio en ciclo fijo" ;
    ns1:identificador "1383" ;
    ns1:solucionaFallo ns1:RevisarEnElManualDeProgramacionLosParametrosObligatoriosYPermitidosParaCadaCicloFijo ;
    ns1:textoExtracto "'No programado parámetro obligatorio en ciclo fijo' DETECCIÓN Durante la ejecución. CAUSA Falta programar algún parámetro obligatorio del ciclo fijo. SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:Fallo_1466 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación G8 como segundo bloque de movimiento"@es ;
    ns1:identificador "1466" ;
    ns1:solucionaFallo ns1:ParametroDeFuncionesG36G37G38G39BloquesDeMovimiento_95de931c6b ;
    ns1:textoExtracto "'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39' [...] SOLUCIÓN El segundo bloque de movimiento de una función G36/G37/G38/G39 debe ser G0/G1/G2/G3."@es .

ns1:Fallo_1467 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite POSLIMIT/NEGLIMIT excede parámetro máquina"@es ;
    ns1:identificador "1467" ;
    ns1:monitoreaParametro ns1:LimitesPOSLIMITYNEGLIMITPorEje ;
    ns1:textoExtracto "'POSLIMIT/NEGLIMIT no puede superar el valor del parámetro máquina' [...] SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1468 a ns1:DiagnosticoFallo ;
    rdfs:label "Origen polar incompleto en G30"@es ;
    ns1:identificador "1468" ;
    ns1:solucionaFallo ns1:ParametroG30OrigenPolar_a28ac51023 ;
    ns1:textoExtracto "'G30: Programación incorrecta del origen polar' [...] SOLUCIÓN Es necesario programar las coordenadas del origen polar en los dos ejes principales."@es .

ns1:Fallo_1469 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio polar nulo o negativo"@es ;
    ns1:identificador "1469" ;
    ns1:monitoreaParametro ns1:RadioPolarEnCoordenadasPolares ;
    ns1:textoExtracto "'Radio negativo o nulo no permitido' [...] SOLUCIÓN El radio polar ha de ser siempre mayor que cero."@es .

ns1:Fallo_1510 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible en el canal" ;
    ns1:identificador "1510" ;
    ns1:textoExtracto "1510 'Eje inexistente o no disponible en el canal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El CNC ha intentado mover un eje que no existe o que no está disponible en el canal. • El CNC ha intentado ejecutar una sentencia que involucra a un eje que no existe o que no está disponible en el canal. • El CNC ha intentado leer o escribir una variable de un eje que no existe o que no está disponible en el canal." .

ns1:Fallo_1512 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición del almacén libre o inexistente" ;
    ns1:identificador "1512" ;
    ns1:textoExtracto "1512 'Posición del almacén libre o inexistente' DETECCIÓN Durante la ejecución." .

ns1:Fallo_1523 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar T en el bloque"@es ;
    ns1:identificador "1523" ;
    ns1:textoExtracto "1523 Falta programar T en el bloque. DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1525 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de comandos POS/MZ sin herramienta"@es ;
    ns1:identificador "1525" ;
    ns1:solucionaFallo ns1:HerramientaDeProgramacionCNC_c6c26be0a9 ;
    ns1:textoExtracto "1525 'No está permitido... CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta."@es .

ns1:Fallo_1545 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de gama de cabezal con G63 o #CAX activos"@es ;
    ns1:identificador "1545" ;
    ns1:textoExtracto "No se admite cambio de gama de cabezal con G63 o #CAX activos. DETECCIÓN: Durante la ejecución. CAUSA: El CNC no puede cambiar la gama del cabezal si está activo el roscado G63 o el cabezal está trabajando como eje C. SOLUCIÓN: Para cambiar la gama del cabezal, desactivar el roscado y el eje C."@es .

ns1:Fallo_1546 a ns1:DiagnosticoFallo ;
    rdfs:label "G63 sin gama previa en el cabezal"@es ;
    ns1:identificador "1546" ;
    ns1:textoExtracto "No se admite G63 sin gama previa en el cabezal. DETECCIÓN: Durante la ejecución. CAUSA: Esta situación sólo es posible si tras el arranque del sistema o un reset, el PLC no indica ninguna gama con GEAR1 a GEAR4 para el cabezal. SOLUCIÓN: Antes de iniciar un roscado G63 el cabezal debe tener una gama activada."@es .

ns1:Fallo_1547 a ns1:DiagnosticoFallo ;
    rdfs:label "#CAX con G63 activa"@es ;
    ns1:identificador "1547" ;
    ns1:textoExtracto "No se admite #CAX con G63 activa. DETECCIÓN: Durante la ejecución. CAUSA: No se puede activar un cabezal como eje C si éste mismo está siendo usado por la función G63. SOLUCIÓN: Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C."@es .

ns1:Fallo_1548 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de cabezal master con G33/G63/G95/G96 activas"@es ;
    ns1:identificador "1548" ;
    ns1:textoExtracto "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas. DETECCIÓN: Durante la ejecución."@es .

ns1:Fallo_1560 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #FOLLOW"@es ;
    ns1:identificador "1560" ;
    ns1:solucionaFallo ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 1560 'Programar #FOLLOW ON/OFF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #FOLLOW es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON/OFF y a continuación los parámetros de llamada entre corchetes."@es .

ns1:Fallo_1561 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje maestro no válido"@es ;
    ns1:identificador "1561" ;
    ns1:solucionaFallo ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "1561 'Eje maestro no válido' DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto. SOLUCIÓN El eje debe pertenecer al canal."@es .

ns1:Fallo_1562 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje esclavo no válido"@es ;
    ns1:identificador "1562" ;
    ns1:solucionaFallo ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "1562 'Eje esclavo no válido' DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1586 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el número de almacén (MZ)"@es ;
    ns1:identificador "1586" ;
    ns1:solucionaFallo ns1:SistemaMultialmacen ;
    ns1:textoExtracto "1586 'Falta programar el número de almacén (MZ)' DETECCIÓN Durante la ejecución. CAUSA En un sistema con varios almacenes, hay programar en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta. SOLUCIÓN En un sistema multialmacén, hay que programar en el mismo bloque la herramienta, la posición y el almacén."@es .

ns1:Fallo_1587 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no modificable desde la puesta a punto"@es ;
    ns1:identificador "1587" ;
    ns1:monitoreaParametro ns1:ParametroMaquinaNoModificableEnPuestaAPunto_9d71653fea ;
    ns1:textoExtracto "1587 'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de"@es .

ns1:Fallo_1600 a ns1:DiagnosticoFallo ;
    rdfs:label "Sincronización de cabezal con eje C o G63 activa"@es ;
    ns1:identificador "1600" ;
    ns1:solucionaFallo ns1:Eje_C,
        ns1:G63_73c48908e7 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa. El CNC ha intentado activar el cabezal como eje C o la función G63 y el cabezal está sincronizado. SOLUCIÓN Desactivar el eje C o la función G63 para sincronizar los cabezales. Para trabajar con el eje C o la función G63, cancelar la sincronización de cabezales."@es .

ns1:Fallo_1601 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite liberar un cabezal sincronizado"@es ;
    ns1:identificador "1601" ;
    ns1:textoExtracto "CAUSA Las sentencias #SET SP y #FREE SP no pueden eliminar un cabezal si éste está sincronizado. SOLUCIÓN Cancelar la sincronización para eliminar el cabezal de la configuración."@es .

ns1:Fallo_1602 a ns1:DiagnosticoFallo ;
    rdfs:label "Aparcamiento de cabezal sin parada previa (M5)"@es ;
    ns1:identificador "1602" ;
    ns1:textoExtracto "CAUSA El CNC ha intentado aparcar un cabezal que no está parado. SOLUCIÓN Detener el cabezal antes de aparcarlo."@es .

ns1:Fallo_1603 a ns1:DiagnosticoFallo ;
    rdfs:label "FOLLOW OFF: Eje no esclavo programado"@es ;
    ns1:identificador "1603" ;
    ns1:textoExtracto "CAUSA El eje programado no es esclavo en ninguna sincronización. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1604 a ns1:DiagnosticoFallo ;
    rdfs:label "G31 requiere interpolación circular activa (G02/G03)"@es ;
    ns1:identificador "1604" ;
    ns1:solucionaFallo ns1:Funcion_G31 ;
    ns1:textoExtracto "CAUSA La función G31 sólo se puede programar si existe una interpolación circular activa. SOLUCIÓN Programar G02/G03 en el bloque de G31."@es .

ns1:Fallo_1605 a ns1:DiagnosticoFallo ;
    rdfs:label "G31 requiere ángulo polar y centro de interpolación"@es ;
    ns1:identificador "1605" ;
    ns1:textoExtracto "CAUSA En la función G31 falta programar el ángulo polar o alguna coordenadas del centro. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1606 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes angular y ortogonal deben pertenecer al mismo canal (#ANGAX)"@es ;
    ns1:identificador "1606" ;
    ns1:textoExtracto "CAUSA El CNC ha intentando activar una transformación angular con dos ejes que no pertenecen al mismo canal."@es .

ns1:Fallo_1650 a ns1:AvisoSeguridad ;
    rdfs:label "Falta la función de coordenadas McsToPcs"@es ;
    ns1:solucionaFallo ns1:Sistema_CinematicaUsuario ;
    ns1:textoExtracto "Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario. SOLUCIÓN Revisar el proceso de integración de cinemáticas de usuario."@es .

ns1:Fallo_1651 a ns1:AvisoSeguridad ;
    rdfs:label "No se admite LINK mantenido con ejes temporales de otro canal"@es ;
    ns1:identificador "1651" ;
    ns1:textoExtracto "El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL). SOLUCIÓN Acoplar los ejes en su canal."@es .

ns1:Fallo_1652 a ns1:AvisoSeguridad ;
    rdfs:label "Se esperaba #DEF 'macro'='comando' 'macro'='comando'..."@es ;
    ns1:identificador "1652" ;
    ns1:textoExtracto "Sentencia mal programada. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1653 a ns1:AvisoSeguridad ;
    rdfs:label "Un eje de la transformación de plano inclinado no puede ser esclavo"@es ;
    ns1:identificador "1653" ;
    ns1:textoExtracto "El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado. SOLUCIÓN Desactivar el plano inclinado para poder activar el acoplo. Un eje que forma parte de un plano inclinado no puede ser el eje esclavo en un acoplo; sí puede ser el eje maestro de un acoplo."@es .

ns1:Fallo_1654 a ns1:AvisoSeguridad ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la lectura de la variable"@es ;
    ns1:identificador "1654" ;
    ns1:mitigaRiesgo ns1:MLINKRDY_5765efc5d8,
        ns1:SERCOSRDY_bb9ccd6f74 ;
    ns1:textoExtracto "Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink."@es .

ns1:Fallo_1655 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable"@es ;
    ns1:identificador "1655" ;
    ns1:solucionaFallo ns1:MLINKRDY_5765efc5d8,
        ns1:SERCOSRDY_bb9ccd6f74 ;
    ns1:textoExtracto "1655 'Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink."@es .

ns1:Fallo_1656 a ns1:DiagnosticoFallo ;
    rdfs:label "Alguno de los ejes del plano está en diámetros"@es ;
    ns1:identificador "1656" ;
    ns1:textoExtracto "1656 'Alguno de los ejes del plano esta en diámetros' DETECCIÓN Al simular o ejecutar en un torno un ciclo fijo de fresadora"@es .

ns1:Fallo_1686 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de longitud de path en programación" ;
    ns1:identificador "1686" ;
    ns1:monitoreaParametro ns1:LongitudMaximaDePath ;
    ns1:textoExtracto "El path del fichero es demasiado largo. [...] La longitud máxima permitida para el path es de 120 caracteres." .

ns1:Fallo_1687 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia #REPOS" ;
    ns1:identificador "1687" ;
    ns1:monitoreaParametro ns1:SintaxisDeSentenciaREPOS ;
    ns1:textoExtracto "'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' [...] La sentencia #REPOS está mal programada." .

ns1:Fallo_1688 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1688: Sentencias #REPOS de distinto tipo"@es ;
    ns1:identificador "1688" ;
    ns1:requiereMantenimiento ns1:RevisionDeConsistenciaDeParametrosREPOS ;
    ns1:solucionaFallo ns1:Sentencia_REPOS ;
    ns1:textoExtracto "1688 'No se admiten sentencias #REPOS de distinto tipo' [...] CAUSA Hay programadas sentencias #REPOS de distinto tipo (INT/INI) en la misma subrutina de interrupción. SOLUCIÓN Todas las sentencias #REPOS deben ser del mismo tipo."@es .

ns1:Fallo_1689 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1689: Bloques tras #REPOS no admitidos"@es ;
    ns1:identificador "1689" ;
    ns1:requiereMantenimiento ns1:ReubicacionDeSentenciasREPOSAlFinalDeSubrutina ;
    ns1:solucionaFallo ns1:Sentencia_REPOS ;
    ns1:textoExtracto "1689 'No se admiten bloques tras #REPOS' [...] CAUSA En una subrutina de interrupción hay programado algún bloque entre las sentencias #REPOS y el bloque de fin de subrutina. SOLUCIÓN Las sentencia #REPOS deben ser los últimos bloques de la subrutina de interrupción, excepto el bloque de fin de subrutina."@es .

ns1:Fallo_1690 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1690: Eje múltiple doblemente programado"@es ;
    ns1:identificador "1690" ;
    ns1:textoExtracto "1690 'Eje múltiple doblemente programado' [...] CAUSA No se permite programar en el mismo bloque más de un eje del mismo grupo multieje. SOLUCIÓN Revisar la programación. Programar únicamente el eje activo del grupo múltiple."@es .

ns1:Fallo_1691 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1691: Subrutina de G anidada"@es ;
    ns1:identificador "1691" ;
    ns1:requiereMantenimiento ns1:RevisionDeAnidamientoDeFuncionesG ;
    ns1:textoExtracto "1691 'Subrutina de G anidada' [...] CAUSA En una subrutina asociada a una función G no se puede programar la función G que llama a esa misma subrutina. SOLUCIÓN Revisar la programación. No programar la función G dentro de la subrutina. En el caso de G74, sí se permite programar la función dentro de la subrutina siempre que vaya seguida de los ejes a referenciar."@es .

ns1:Fallo_1692 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1692: Programación incorrecta de #VOLCOMP"@es ;
    ns1:identificador "1692" ;
    ns1:requiereMantenimiento ns1:RevisionDeSintaxisDeVOLCOMP ;
    ns1:solucionaFallo ns1:Sentencia_VOLCOMP ;
    ns1:textoExtracto "1692 'Programar #VOLCOMP ON/OFF [n]' [...] CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1693 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación de #RTCP con cinemática incompatible",
        "Error 1693: Cinemática incompatible con #RTCP"@es ;
    ns1:identificador "1693" ;
    ns1:requiereMantenimiento ns1:SustitucionDeRTCPPorFACEOCYLSegunCinematica ;
    ns1:solucionaFallo ns1:ParametroCYL_877b124b0f,
        ns1:ParametroFACE_c5b9e0400a,
        ns1:Sentencia_RTCP ;
    ns1:textoExtracto "1693 'No se permite programar #RTCP con la actual cinemática. Programar #FACE o #CYL' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1747 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1747" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN: Elegir una herramienta de menor diámetro."@es .

ns1:Fallo_1754 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Diámetro de herramienta menor que DELTA" ;
