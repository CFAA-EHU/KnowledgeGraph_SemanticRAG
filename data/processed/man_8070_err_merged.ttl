ns1:Fallo_9502 a ns1:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en regulador"@es ;
    ns1:identificador "9502" ;
    ns1:textoExtracto "9502 Cortocircuito. [...] SOLUCIÓN [...] conexión de los cables de potencia sea errónea o que estén en contacto, provocando un cortocircuito."@es .

