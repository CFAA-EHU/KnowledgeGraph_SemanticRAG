ns1:Soluci_C3_B3n1555 a ns1:AvisoSeguridad ;
    ns1:detalladoEnEsquema ns1:Soluci_C3_B3n1555 ;
    ns1:documentadoEn ns1:Manual_47d6ac45de ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC. 1555 'Programar #MOVE / #MOVE ABS/ADD/INF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #MOVE es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ABS/ADD/INF y a continuación los parámetros de llamada entre corchetes." .

ns1:Soluci_C3_B3n1556 a ns1:AvisoSeguridad ;
