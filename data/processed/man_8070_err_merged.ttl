ns1:AvisoSeguridad_1412 a ns1:AvisoSeguridad ;
    rdfs:label "Error '#DGWZ: zona de visualización para gráficos mal definida'"@es,
        "Zona de visualización para gráficos mal definida"@es ;
    ns1:identificador "1412" ;
    ns1:textoExtracto """\r
    '#DGWZ: zona de visualización para gráficos mal definida'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: En la sentencia se han definido mal los límites de los ejes.\r
    SOLUCIÓN: Ambos límites pueden ser positivos o negativos pero siempre los límites inferiores de un eje deberán ser menores que los límites superiores de ese mismo eje.\r
    """@es,
        "1412 '#DGWZ: zona de visualización para gráficos mal definida' [...] CAUSA En la"@es .

ns1:AvisoSeguridad_1413 a ns1:AvisoSeguridad ;
    rdfs:label "No se admite velocidad cero para posicionamiento de cabezal"@es ;
    ns1:identificador "1413" ;
    ns1:textoExtracto """\r
    'No se admite velocidad cero para posicionamiento de cabezal'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: La velocidad de posicionamiento programada para la función M19 es cero.\r
    SOLUCIÓN: Programar una velocidad de posicionamiento mayor que cero mediante el comando "S.POS".\r
    """@es .

ns1:AvisoSeguridad_1414 a ns1:AvisoSeguridad ;
    rdfs:label "Sentencia #PARK solo admite un eje"@es ;
    ns1:identificador "1414" ;
    ns1:textoExtracto """\r
    '#PARK: la sentencia sólo admite un eje'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: La sentencia #PARK solo permite aparcar un eje.\r
    SOLUCIÓN: Programar un bloque #PARK por cada eje que se desea aparcar.\r
    """@es .

ns1:AvisoSeguridad_1417 a ns1:AvisoSeguridad ;
    rdfs:label "Path de fichero demasiado largo"@es ;
    ns1:identificador "1417" ;
    ns1:textoExtracto """\r
    'Path de fichero demasiado largo'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: Se ha superado el máximo número de caracteres permitido para el path de un programa o subrutina.\r
    SOLUCIÓN: El path de un programa o subrutina puede tener un máximo de 120 caracteres. Mover de directorio el programa o subrutina para reducir el número de caracteres en el path.\r
    """@es .

ns1:AvisoSeguridad_1418 a ns1:AvisoSeguridad ;
    rdfs:label "No se permite aparcar ejes de cinemática o transformadas activas"@es ;
    ns1:identificador "1418" ;
    ns1:textoExtracto """\r
    'No se permite aparcar ejes de la cinemática o tranformadas activas'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: El CNC ha intentado aparcar un eje que forma parte de la cinemática activa o de las transformadas #CS, #ACS, #ANGAX, #TANGCTRL.\r
    SOLUCIÓN: Revisar la programación. Si se desea aparcar dicho eje debe desactivarse la cinemática o transformación activa.\r
    """@es .

