ns1:Fallo_7044 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 7044: Herramienta activa con número de filos no modificable"@es,
        "No se puede modificar el número de filos de la herramienta activa"@es ;
    ns1:identificador "7044" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
