ns1:AvisoSeguridad_1171 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1171: Sentencias # programadas incorrectamente"@es ;
    ns1:identificador "1171" ;
    ns1:textoExtracto "'Las sentencias # se programan solas en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. La única excepción es la sentencia #AXIS que se debe programar en el mismo bloque que la función G201."@es .

ns1:AvisoSeguridad_1172 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1172: Sentencia incompatible con compensación de radio activa"@es ;
    ns1:identificador "1172" ;
    ns1:textoExtracto "'Sentencia no permitida con compensación de radio de herramienta activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una sentencia incompatible con la compensación de radio. SOLUCIÓN Desactivar la compensación de radio para ejecutar la sentencia."@es .

ns1:AvisoSeguridad_1173 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1173: Sentencia #UNLINK mal programada"@es ;
    ns1:identificador "1173" ;
