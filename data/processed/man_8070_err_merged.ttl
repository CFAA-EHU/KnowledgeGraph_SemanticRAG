    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:identificador "0026" ;
    ns1:textoExtracto "0026 'Variable no permitida en el entorno del oscilo' [...]",
        "0026 'Variable no permitida en el entorno del oscilo' DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA La variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña."@es .

ns1:Error_0068 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0068: Ejes Gantry/Tandem - Esclavo precede al maestro"@es ;
    ns1:identificador "0068" ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de asignación de nombres de ejes (parámetro AXISNAME), el eje esclavo está definido antes del eje maestro."@es .

ns1:Error_0069 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0069: Ejes Gantry - Configuración DECINPUT inconsistente"@es ;
    ns1:identificador "0069" ;
    ns1:textoExtracto "'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:Error_0114 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0114: Validación de parámetros durante simulación" ;
    ns1:identificador "0114" ;
    ns1:textoExtracto "No es posible validar parámetros durante la simulación de un programa en el canal. [...] SOLUCIÓN Detener la simulación del programa para validar los parámetros."@es .

ns1:Error_0155 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0155: No es posible carga rápida de fichero" ;
    ns1:identificador "0155" ;
    ns1:textoExtracto "0155 'No es posible carga rápida de fichero' DETECCIÓN Durante al acceso a un archivo. CAUSA El CNC ha intentado leer un fichero cuyo tamaño supera el espacio libre de la zona de memoria asignada para carga rápida de ficheros. SOLUCIÓN Ejecutar desde memoria RAM (subrutinas con extensión fst) sólo a aquellos ficheros que son llamados con mayor frecuencia." .

ns1:Error_0156 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0156: Demasiados ficheros abiertos para escritura" ;
    ns1:identificador "0156" ;
    ns1:textoExtracto "0156 Demasiados ficheros abiertos para escritura. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha intentado abrir demasiados archivos. SOLUCIÓN Cerrar algún archivo." .

ns1:Error_0158 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0158: #WRITE necesita un #OPEN previo" ;
    ns1:identificador "0158" ;
    ns1:textoExtracto "#WRITE necesita un #OPEN previo." .

ns1:Error_0165 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0165: RT IT Overflow" ;
    ns1:identificador "0165" ;
    ns1:textoExtracto "0165 'RT IT Overflow' DETECCIÓN Durante el funcionamiento del CNC. CAUSA Las interrupciones de tiempo real superan el tiempo permitido. Algunas posibles causas pueden ser la instalación de algún dispositivo, driver o aplicación incompatible con el CNC. SOLUCIÓN Si el error se repite con frecuencia, puede ser necesario ajustar el parámetro LOOPTIME. Analice los casos en los que ocurre el error y póngase en contacto con su proveedor." .

ns1:Error_0168 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0168: Position Loop Overflow" ;
    ns1:identificador "0168" ;
    ns1:textoExtracto "0168 Position Loop Overflow. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido. SOLUCIÓN Ajustar el parámetro LOOPTIME." .

ns1:Error_0169 a ns1:Alarma ;
    rdfs:label "Error 0169: Sobrepasada temperatura de seguridad" ;
    ns1:identificador "0169" ;
    ns1:textoExtracto "0169 Sobrepasada temperatura de seguridad. En riesgo la integridad del equipo. Contactar con el SAT. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Está en riesgo la integridad del equipo." .

