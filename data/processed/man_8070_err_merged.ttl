    ns1:solucionaFallo ns1:RevisarParametrosOVRMINYOVRMAX ;
    ns1:textoExtracto "#PWRCTRL ON: OVRMIN debe ser menor que OVRMAX. DETECCIÓN Durante la ejecución. CAUSA En la función #PWRCTRL, el override mínimo es mayor que el override máximo." .

ns1:Fallo_2430 a ns1:DiagnosticoFallo ;
    rdfs:label "#DMC ON: FZMIN debe ser menor que FZMAX" ;
