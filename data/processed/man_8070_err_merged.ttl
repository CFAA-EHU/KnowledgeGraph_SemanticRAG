    ns1:solucionaFallo ns1:DiagnosticoFallo_2326 ;
    ns1:textoExtracto "2326 'Falta punto final en G802/G803' [...] SOLUCIÓN Revisar la programación." .

ns1:Alarma_2327 a ns1:Alarma ;
