    rdfs:label "Alarma 1124: Instrucción $ENDSWITCH sin $SWITCH previa"@es ;
    ns1:identificador "1124" ;
    ns1:textoExtracto "El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1125SentenciaENDSWITCHNoProgramadaSolaEnBloque_f289341b35 a ns1:Alarma ;
