    rdfs:label "Parámetro F3DPvalor",
        "F3DPvalor"@es ;
    ns1:identificador "F3DPvalor" ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[...,<F3DPvalor>..."@es .

ns1:FACEAXIS_dc77a4579e a ns1:Parametro ;
    rdfs:label "FACEAXIS",
        "FACEAXIS"@es ;
    ns1:textoExtracto "parámetro máquina FACEAXIS" ;
    ns1:valor true,
        "TRUE" .

ns1:FREQFrecuenciaPWM a ns1:Parametro ;
    rdfs:label "FREQ (frecuencia PWM)"@es ;
    ns1:monitoreaParametro ns1:Sistema_PWM ;
    ns1:textoExtracto "FREQ/F valor"@es .

ns1:FZMAXAvanceMaximo a ns1:Parametro ;
    rdfs:label "Avance máximo (FZMAX)",
        "FZMAX (avance máximo)",
        "Avance máximo (FZMAX)"@es ;
    ns1:monitoreaParametro ns1:Fallo_2417,
        ns1:Fallo_2430 ;
    ns1:textoExtracto "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)."@es ;
    ns1:valor "avance máximo" .

ns1:Fallo2488TablaDeCalibracionDeGapNoCargada a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2488: Tabla de calibración de gap no cargada" ;
    ns1:solucionaFallo ns1:Alarma2488FaltaCargaDeGAPTABLEAntesDeGAPCTRLLEAP_18e524547d ;
    ns1:textoExtracto "CAUSA Por parámetro máquina se ha definido una calibración no lineal de gap. Se ha intentado usar la sonda del gap (#GAPCTRL ON o #LEAP) sin activar dicha tabla." .

ns1:Fallo4017RecalcularPP4HomingSwitchOffset a ns1:DiagnosticoFallo ;
    rdfs:label "Parametrización incorrecta de PP4",
        "Fallo 4017: Recalcular PP4 (HomingSwitchOffset)"@es ;
    ns1:identificador "4017" ;
    ns1:solucionaFallo ns1:PP4HomingSwitchOffset,
        ns1:RecalculoDePP4MedianteComandoGC6 ;
    ns1:textoExtracto "'Es necesario recalcular el valor del parámetro PP4(HomingSwitchOffset) del regulador' DETECCIÓN En el encendido del CNC."@es .

ns1:Fallo_1336 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración errónea: dos ejes CAXIS" ;
    ns1:identificador "1336" ;
    ns1:textoExtracto "1336 'Configuración errónea: dos ejes CAXIS' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes programados en la sentencia #FACE/#CYL son eje C. SOLUCIÓN Sólo uno de los dos ejes programados puede ser eje C (parámetro CAXIS)." .

ns1:Fallo_1337 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido eje CAXIS" ;
    ns1:identificador "1337" ;
    ns1:textoExtracto "1337 'No se ha definido eje CAXIS' DETECCIÓN Durante la ejecución. CAUSA Ninguno de los ejes programados en la sentencia #FACE/#CYL es eje C. SOLUCIÓN Uno de los dos ejes programados debe ser eje C (parámetro CAXIS)." .

ns1:Fallo_1369 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1369: '#HSC: programación no permitida'"@es ;
    ns1:identificador "1369" ;
    ns1:textoExtracto "1369 '#HSC: programación no permitida' [...] CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Fallo_1370 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1370: '#HSC: doble programación'"@es ;
    ns1:identificador "1370" ;
    ns1:textoExtracto "1370 '#HSC: doble programación' [...] CAUSA En un mismo bloque está programada la activación y desactivación del modo HSC."@es .

ns1:Fallo_1376 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1376: 'No se ha definido nombre por defecto para el eje C'" ;
    ns1:identificador "1376" ;
    ns1:textoExtracto "1376 'No se ha definido nombre por defecto para el eje C' [...] CAUSA En la sentencia #CAX falta indicar el nombre del eje C y en los parámetros máquina no está indicado el nombre por defecto (parámetro CAXIS)." .

ns1:Fallo_1419 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite aparcar ejes acoplados, Gantry o Tandem"@es ;
    ns1:identificador "1419" ;
    ns1:textoExtracto "1419 'No se permite aparcar ejes acoplados, Gantry o Tandem' [...] SOLUCIÓN Revisar la programación. Si se desea aparcar dicho eje debe desactivarse la cinemática o transformación activa."@es .

ns1:Fallo_1420 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes gantry o tándem no pueden aparcarse"@es ;
    ns1:identificador "1420" ;
    ns1:textoExtracto "Los ejes que forman parte de una pareja gantry o tándem no se pueden aparcar. [...] Si se desea aparcar dicho eje se debe desactivar el acoplo."@es .

ns1:Fallo_1486 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en programación de #SIGNAL"@es ;
    ns1:identificador "1486" ;
    ns1:textoExtracto "1486 'Programar: #SIGNAL [señal, señal, señal, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Fallo_1487 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en programación de #CLEAR"@es ;
    ns1:identificador "1487" ;
    ns1:textoExtracto "1487 'Programar: #CLEAR [señal, señal, señal, ...]' CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1511 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta no disponible en el almacén" ;
    ns1:identificador "1511" ;
    ns1:solucionaFallo ns1:Solucion_1511 ;
    ns1:textoExtracto "1511 'La herramienta no está en el almacén' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer mediante la variable V.TM.P la posición en el almacén de una herramienta que no está presente en el mismo." .

ns1:Fallo_1741 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1741" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Fallo_1746 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1746" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN: Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Fallo_1748 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1748" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN: Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Fallo_1749 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: R < r"@es ;
    ns1:identificador "1749" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r). SOLUCIÓN: El radio de la cajera (radio exterior) debe ser mayor que el radio de prevaciado (radio interior)."@es .

ns1:Fallo_1850 a ns1:DiagnosticoFallo ;
    rdfs:label "Lx ha de ser múltiplo de Ix" ;
    ns1:identificador "1850" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro Lx) ha de ser múltiplo de la distancia entre mecanizados (parámetro Ix). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:Fallo_1851 a ns1:DiagnosticoFallo ;
    rdfs:label "Ly ha de ser múltiplo de Iy" ;
    ns1:identificador "1851" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple." .

ns1:Fallo_1872 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Paso de acabado no válido" ;
    ns1:identificador "1872" ;
    ns1:monitoreaParametro ns1:PasoDeMecanizadoParaAcabado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En una cajera 2D, el paso de mecanizado para el acabado (parámetro Δ) es mayor que el diámetro de la herramienta. En una cajera 3D, el paso de mecanizado para el acabado (parámetro ε) es cero." .

ns1:Fallo_1910 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de desbaste mayor que la anchura de la cuchilla",
        "Paso de desbaste mayor que la anchura de la cuchilla"@es ;
    ns1:identificador "1910" ;
    ns1:textoExtracto "1910 'Paso de desbaste mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de desbaste es mayor que la anchura de la cuchilla." .

ns1:Fallo_1911 a ns1:DiagnosticoFallo ;
    rdfs:label "Factor de forma no válido en ciclo de desbaste"@es ;
    ns1:identificador "1911" ;
    ns1:textoExtracto "1911 'Factor de forma no válido en ciclo de desbaste' DETECCIÓN Durante la ejecución del ciclo. CAUSA El factor de forma no es válido para el ciclo programado. SOLUCIÓN Corregir"@es .

ns1:Fallo_2153 a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria helicoidal cercana al centro de giro del FACE" ;
    ns1:identificador "2153" ;
    ns1:textoExtracto "2153 'Trayectoria helicoidal cercana al centro de giro del FACE' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una trayectoria helicoidal de más de una vuelta, en una zona cercana al centro de giro del FACE. SOLUCIÓN Cambiar la trayectoria de mecanizado." .

ns1:Fallo_2347_G91_Activa a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre perfil PROGTL3 y código G91"@es ;
    ns1:textoExtracto "No se permite iniciar un perfil con G91 activa, ni programar G91 dentro de un perfil G841-G842."@es .

ns1:Fallo_2365 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Doble programación del incremento/decremento del paso de husillo" ;
    ns1:identificador "2365" ;
    ns1:textoExtracto "2365 G34: Doble programación del incremento/decremento del paso de husillo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado más de una vez el incremento/decremento del paso de husillo (K1) SOLUCIÓN Programar el incremento/decremento del paso de husillo una única vez en el bloque." .

ns1:Fallo_2366 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo igual a cero" ;
    ns1:identificador "2366" ;
    ns1:textoExtracto "2366 G34: Incremento/decremento del paso de husillo igual a cero. DETECCIÓN Durante la ejecución. CAUSA El incremento/decremento del paso de husillo (K1) para G34 es cero. SOLUCIÓN Programar un incremento/decremento del paso de husillo (K1) para G34." .

ns1:Fallo_2367 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo fuera de rango" ;
    ns1:identificador "2367" ;
    ns1:textoExtracto "2367 G34: Incremento/decremento del paso de husillo fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El valor del incremento/decremento del paso de husillo en G34 es incorrecto. SOLUCIÓN Programar un valor correcto del incremento/decremento del paso de husillo (K1)." .

ns1:Fallo_2368 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Incremento/decremento del paso de husillo demasiado grande" ;
    ns1:identificador "2368" ;
    ns1:textoExtracto "2368 G34: Incremento/decremento del paso de husillo demasiado grande. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un incremento del paso de husillo superior a dos veces el paso de rosca. SOLUCIÓN Programar un valor correcto del incremento del paso de husillo (K1)." .

ns1:Fallo_2369 a ns1:DiagnosticoFallo ;
    rdfs:label "G34: Paso final de husillo negativo o nulo" ;
    ns1:identificador "2369" ;
    ns1:textoExtracto "2369 G34: Paso final de husillo negativo o nulo. DETECCIÓN Durante la ejecución. CAUSA Con el paso de husillo y el decremento de paso de husillo programados en G34, el paso final de rosca calculado por el control es negativo o cero. SOLUCIÓN Programar correctamente el paso y el decremento de paso de husillo en G34." .

ns1:Fallo_2417 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2417: #PWRCTRL ON - FZMIN > FZMAX" ;
    ns1:identificador "2417" ;
    ns1:solucionaFallo ns1:RevisarParametrosFZMINYFZMAX ;
    ns1:textoExtracto "#PWRCTRL ON: FMIN debe ser menor que FMAX. DETECCIÓN Durante la ejecución. CAUSA En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo." .

ns1:Fallo_2418 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2418: #PWRCTRL ON - OVRMIN > OVRMAX" ;
