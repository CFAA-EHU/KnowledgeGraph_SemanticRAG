ns1:Error_8012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ns1:identificador "8012" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8013 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclados compactos" ;
    ns1:identificador "8013" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga del nodo del teclado de 10\". SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8014 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de RIOS" ;
    ns1:identificador "8014" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos RIOS (I/Os CANopen). SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8015 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Eje en movimiento o en sincronización" ;
    ns1:identificador "8015" ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ns1:Error_8016 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en marcha" ;
    ns1:identificador "8016" ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ns1:Error_8017 a ns1:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en sincronización" ;
    ns1:identificador "8017" ;
    ns1:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ns1:Error_8018 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC mientras se encuentre en ejecución o interrumpido" ;
    ns1:identificador "8018" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC." .

ns1:Error_8019 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8019: No se permite generar el PLC mientras algún canal se encuentre en ejecución o interrumpido" ;
    ns1:identificador "8019" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si algún canal se encuentra en ejecución o interrumpido. SOLUCIÓN Detener los programas en ejecución." .

ns1:Error_8020 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8020: No se permite generar el PLC: Eje en movimiento o en sincronización" ;
    ns1:identificador "8020" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún eje algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ns1:Error_8021 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8021: No se permite generar el PLC: Cabezal en marcha" ;
    ns1:identificador "8021" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ns1:Error_8022 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8022: No se permite generar el PLC: Cabezal en sincronización" ;
    ns1:identificador "8022" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ns1:Error_8023 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8023: Memoria en disco por debajo del mínimo recomendado" ;
    ns1:identificador "8023" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Error_8024 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8024: CNC trabajando en Modo Puesta a Punto" ;
    ns1:documentadoEn ns1:ModoPuestaPunto ;
    ns1:identificador "8024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ns1:Error_8031 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8031: 'La carpeta DRIVERS no existe'" ;
    ns1:identificador "8031" ;
    ns1:textoExtracto "8031 'La carpeta DRIVERS no existe' [...] DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se ubicará el PLC una vez generado (C:\\CNC8070\\Drivers). SOLUCIÓN Desde el modo utilidades, usar la opción \"Nuevo directorio\" del menú de softkeys para crear la carpeta." .

ns1:Error_8032 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8032: 'La carpeta USERS no existe'" ;
    ns1:identificador "8032" ;
    ns1:textoExtracto "8032 'La carpeta USERS no existe' [...] DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta de trabajo del usuario (C:\\CNC8070\\Users). SOLUCIÓN Desde el modo utilidades, usar la opción \"Nuevo directorio\" del menú de softkeys para crear la carpeta." .

ns1:Error_8034 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8034: 'Puesta a punto incompleta: No se ha encontrado ninguna copia de seguridad'" ;
    ns1:identificador "8034" ;
    ns1:textoExtracto "8034 'Puesta a punto incompleta:No se ha encontrado ninguna copia de seguridad' [...] DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC no ha encontrado ninguna copia de seguridad de la puesta a punto. SOLUCIÓN Al apagar el CNC, seleccionar la opción \"Cerrar y hacer copia de seguridad\", para que el CNC haga una copia de seguridad de la puesta a punto." .

ns1:Error_8035 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8035: 'Los siguientes passwords de acceso están aún por definir'" ;
    ns1:identificador "8035" ;
    ns1:textoExtracto "8035 'Los siguientes passwords de acceso están aún por definir' [...] DETECCIÓN Durante el arranque de un CNC abierto, en modo puesta a punto. CAUSA Los passwords de acceso indicados en el aviso no están definidos. SOLUCIÓN Con el CNC arrancado, acceder al modo utilidades y desde la opción \"Códigos de acceso\" del menú de softkeys introducir los passwords indicados." .

ns1:Error_8036 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8036: 'Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC'" ;
    ns1:identificador "8036" ;
    ns1:textoExtracto "8036 'Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC' [...] DETECCIÓN Durante el arranque del sistema, en modo setup. CAUSA Solo se permite trabajar con el CNC en los modos usuario y modo puesta a punto. SOLUCIÓN Utilizar la utilidad DiskMonitor para pasar a modo usuario o modo puesta a punto y volver a arrancar el CNC." .

ns1:Error_8037 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8037: 'Memoria por debajo del mínimo recomendado'" ;
    ns1:identificador "8037" ;
    ns1:textoExtracto "8037 'Memoria por debajo del mínimo recomendado." .

ns1:Error_8056 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén" ;
    ns1:identificador "8056" ;
    ns1:textoExtracto "8056 Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido recuperar la información de las posiciones de las herramientas en el almacén. SOLUCIÓN Definir manualmente las herramientas en las posiciones del almacén." .

ns1:Error_8057 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición de la herramienta activa en el almacén" ;
    ns1:identificador "8057" ;
    ns1:textoExtracto "8057 Inconsistencia en la recuperación de la posición de la herramienta activa en el almacén. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido recuperar la información de la herramienta activa en el almacén. SOLUCIÓN Definir manualmente cual es la herramientas activa." .

ns1:Error_8058 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de memoria" ;
    ns1:identificador "8058" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_8058 ;
    ns1:textoExtracto "8058 Error de memoria. Es necesario reiniciar el CNC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La memoria se encuentra debajo del mínimo recomendado para el correcto funcionamiento del CNC. SOLUCIÓN Reiniciar el CNC. El CNC puede tener problemas para funcionar correctamente." .

ns1:Error_8059 a ns1:DiagnosticoFallo ;
    rdfs:label "Vida restante del disco por debajo del 25%" ;
    ns1:identificador "8059" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_8059 ;
    ns1:textoExtracto "8059 Vida restante del disco por debajo del 25%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El disco se acerca al fin de su vida útil. SOLUCIÓN Póngase en contacto con Fagor Automation. El CNC puede tener problemas para funcionar correctamente." .

ns1:Error_8060 a ns1:DiagnosticoFallo ;
    rdfs:label "Vida restante del disco por debajo del 10%" ;
    ns1:identificador "8060" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_8060 ;
    ns1:textoExtracto "8060 Vida restante del disco por debajo del 10%. Cierre el CNC y póngase en contacto con Fagor Automation S. Coop. para obtener asistencia técnica. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El disco está a punto de terminar su vida útil. SOLUCIÓN Póngase en contacto con Fagor Automation. El CNC puede tener problemas para funcionar correctamente." .

ns1:Error_8127 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de RIOR-ETHERCAT" ;
    ns1:identificador "8127" ;
    ns1:textoExtracto "8127 Error cargando software de RIOR-ETHERCAT. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga de los nodos RIOR-ETHERCAT. SOLUCIÓN Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos." .

ns1:Error_8128 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en recuperación de datos de FRAM" ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "8128 No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM." .

ns1:Error_8207 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8207: Nombre de programa o subrutina demasiado largo" ;
    ns1:identificador "8207" ;
    ns1:textoExtracto """\r
    8207 'Nombre de programa o subrutina demasiado largo'\r
    DETECCIÓN Durante la edición.\r
    CAUSA Superado el máximo número de caracteres permitido para el nombre de programa o subrutina.\r
    SOLUCIÓN El máximo número de caracteres permitido es 14.\r
    """ .

ns1:Error_8209 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8209: Eje activo inválido" ;
    ns1:identificador "8209" ;
    ns1:textoExtracto """\r
    8209 'Eje activo inválido'\r
    DETECCIÓN Durante la edición.\r
    CAUSA Programado el nombre del eje con un comodín no válido.\r
    SOLUCIÓN Los nombres de eje con comodín válidos son @1 a @5.\r
    """ .

ns1:Error_8210 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8210: Excedidos límites para enteros" ;
    ns1:identificador "8210" ;
    ns1:textoExtracto """\r
    8210 'Excedidos límites para enteros'\r
    DETECCIÓN Durante la edición.\r
    CAUSA Programado un número entero demasiado alto.\r
    SOLUCIÓN El máximo valor admisible para un valor entero es 4294967295.\r
    """ ;
    ns1:valor "4294967295" .

ns1:Error_8211 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8211: Excedidos límites para parte entera" ;
    ns1:identificador "8211" ;
    ns1:textoExtracto """\r
    8211 'Excedidos límites para parte entera'\r
    DETECCIÓN Durante la edición.\r
    CAUSA La parte entera del número tiene un valor no válido.\r
    SOLUCIÓN El rango de valores válidos para la parte entera de un número es ±99999.\r
    """ ;
    ns1:valor "±99999" .

ns1:Error_8212 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8212: Excedidos límites para parte fraccionaria" ;
    ns1:identificador "8212" ;
    ns1:textoExtracto """\r
    8212 'Excedidos límites para parte fraccionaria'\r
    DETECCIÓN Durante la edición.\r
    CAUSA La parte decimal del número tiene un valor no válido.\r
    SOLUCIÓN El rango de valores válidos para la parte decimal de un número es ±0.99999.\r
    """ ;
    ns1:valor "±0.99999" .

ns1:Error_8213 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8213: Excedido formato para parte fraccionaria" ;
    ns1:identificador "8213" ;
    ns1:textoExtracto """\r
    8213 'Excedido formato para parte fraccionaria'\r
    DETECCIÓN Durante la edición.\r
    CAUSA Superado el máximo número de dígitos permitido para la parte decimal de un número.\r
    SOLUCIÓN El máximo número de dígitos permitido para la parte decimal de un número es 5.\r
    """ ;
    ns1:valor "5" .

ns1:Error_8214 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8214: Instrucción de control de flujo desconocida" ;
    ns1:identificador "8214" ;
    ns1:textoExtracto """\r
    8214 'Instrucción de control de flujo desconocida'\r
    DETECCIÓN Durante la edición.\r
    CAUSA La instrucción programada tras el carácter "$" no es correcta.\r
    SOLUCIÓN Revisar la sintaxis de la instrucción.\r
    """ .

ns1:Error_8215 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8215: Excedido formato para función",
        "Excedido formato para función" ;
    ns1:identificador "8215" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto """\r
    8215 'Excedido formato para función'\r
    DETECCIÓN Durante la edición y ejecución.\r
    CAUSA La sintaxis de la sentencia no es correcta.\r
    SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia.\r
    """,
        "'Excedido formato para función' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8217 a ns1:DiagnosticoFallo ;
    rdfs:label "Excedidos límites para flotantes" ;
    ns1:identificador "8217" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'Excedidos límites para flotantes' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8218 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Carácter no válido" ;
    ns1:identificador "8218" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'Carácter no",
        "8218 'Carácter no válido' DETECCIÓN Durante la edición. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque." .

ns1:Error_8219 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de error vacía" ;
    ns1:identificador "8219" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8219' Cadena de error vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8220 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de Warning vacía" ;
