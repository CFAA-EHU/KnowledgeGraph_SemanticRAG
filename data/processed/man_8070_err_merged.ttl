    ns1:identificador "1129" ;
    ns1:monitoreaParametro ns1:ParametroInstruccionENDFOR_bdc0d66951 ;
    ns1:textoExtracto "'No se espera $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDFOR sin una instrucción $FOR previa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1130SentenciaENDFORNoProgramadaSolaEnBloque_cebcff3b51 a ns1:Alarma ;
    rdfs:label "Alarma 1130: Sentencia $ENDFOR no programada sola en bloque"@es ;
    ns1:identificador "1130" ;
    ns1:monitoreaParametro ns1:ParametroInstruccionENDFOR_bdc0d66951 ;
    ns1:textoExtracto "'La sentencia $ENDFOR se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1131SentenciaWHILECondicionNoProgramadaSolaEnBloque_645a05c5db a ns1:Alarma ;
    rdfs:label "Alarma 1131: Sentencia $WHILE <condición> no programada sola en bloque"@es ;
    ns1:identificador "1131" ;
    ns1:monitoreaParametro ns1:ParametroCondicionWHILE_f530c2a43c ;
    ns1:textoExtracto "'La sentencia $WHILE <condición> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1132ExcesoDeCaracteresEnCondicionWHILE_eadad13017 a ns1:Alarma ;
    rdfs:label "Alarma 1132: Exceso de caracteres en condición $WHILE"@es ;
    ns1:identificador "1132" ;
    ns1:monitoreaParametro ns1:ParametroLongitudMaximaCondicionWHILE_d21bb410e2 ;
    ns1:textoExtracto "'$WHILE: demasiados caracteres en la condición' DETECCIÓN Durante la ejecución. CAUSA La condición de la instrucción $WHILE supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 5000."@es .

ns1:Alarma1133InstruccionENDWHILESinWHILEPrevia_83a6fb0e0b a ns1:Alarma ;
    rdfs:label "Alarma 1133: Instrucción $ENDWHILE sin $WHILE previa"@es ;
    ns1:identificador "1133" ;
    ns1:textoExtracto "'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1157SubrutinaGlobalNoEncontrada_fede01eabc a ns1:Alarma ;
    rdfs:label "Alarma 1157: Subrutina global no encontrada" ;
    ns1:documentadoEn ns1:Manual_Programacion_CNC ;
    ns1:identificador "1157" ;
    ns1:textoExtracto "'Subrutina global no encontrada' DETECCIÓN Durante la ejecución. CAUSA El CNC no encuentra la subrutina global. SOLUCIÓN Comprobar que el nombre y path de la subrutina son correctos. Si en la llamada a la subrutina no está definido el path, el CNC aplicará el criterio de búsqueda por defecto (consulte el manual de programación)." .

ns1:Alarma1158NoExisteSubrutinaAsociadaAG_e27191590e a ns1:Alarma ;
    rdfs:label "Alarma 1158: No existe subrutina asociada a G" ;
    ns1:documentadoEn ns1:Manual_Programacion_CNC ;
    ns1:identificador "1158" ;
    ns1:textoExtracto "No existe subrutina asociada a G. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un subrutina de usuario (G500-G599) o subrutina OEM (G180-G189/G380-G399) y no existe la subrutina. SOLUCIÓN Comprobar que la función G es correcta o definir la subrutina asociada." .

ns1:Alarma1159NombreDeSubrutinaLocalDemasiadoLargo_f9ba9c26c3 a ns1:Alarma ;
    rdfs:label "Alarma 1159: Nombre de subrutina local demasiado largo" ;
    ns1:identificador "1159" ;
    ns1:textoExtracto "'Nombre de subrutina local demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la subrutina supera el número de caracteres permitido por el CNC. El nombre de una subrutina puede tener un máximo de 63 caracteres." .

ns1:Alarma1175LINKNoSeHaDefinidoAcoplo_f6e95f09c2 a ns1:Alarma ;
    rdfs:label "Alarma 1175: '#LINK: no se ha definido acoplo'"@es ;
    ns1:identificador "1175" ;
    ns1:textoExtracto "1175 '#LINK: no se ha definido acoplo' DETECCIÓN Durante la ejecución. CAUSA No hay ningún acoplo de ejes definido en la sentencia #LINK. SOLUCIÓN Programar los ejes maestro y esclavo en la sentencia #LINK."@es .

ns1:Alarma1176LINKElEjeMaestroNoPerteneceALaConfiguracionDeEjesActual_e1d84ff9dd a ns1:Alarma ;
    rdfs:label "Alarma 1176: '#LINK: el eje maestro no pertenece a la configuración de ejes actual'"@es ;
    ns1:identificador "1176" ;
    ns1:textoExtracto "1176 '#LINK: el eje maestro no pertenece a la configuración de ejes actual' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El eje maestro del acoplo no existe o no está disponible en el canal. • El CNC ha intentado anular un acoplo cuyo eje maestro no existe o no está disponible en el canal. SOLUCIÓN Los ejes maestro y esclavo deben existir en el canal que ejecuta la sentencia."@es .

ns1:Alarma1177LINKElEjeEsclavoNoPerteneceALaConfiguracionDeEjesActual_9d48ab4f3f a ns1:Alarma ;
    rdfs:label "Alarma 1177: '#LINK: el eje esclavo no pertenece a la configuración de ejes actual'"@es ;
    ns1:identificador "1177" ;
    ns1:textoExtracto "1177 '#LINK: el eje esclavo no pertenece a la configuración de ejes actual' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El eje esclavo del acoplo no existe o no está disponible en el canal. • El CNC ha intentado anular un acoplo cuyo eje esclavo no existe o no está disponible en el canal. SOLUCIÓN Los ejes maestro y esclavo deben existir en el canal que ejecuta la sentencia."@es .

ns1:Alarma1178LINKElEjeEsclavoNoPuedeSerUnEjeDelPlanoPrincipal_517f01067a a ns1:Alarma ;
    rdfs:label "Alarma 1178: '#LINK: el eje esclavo no puede ser un eje del plano principal'"@es ;
    ns1:identificador "1178" ;
    ns1:textoExtracto "1178 '#LINK: el eje esclavo no puede ser un eje del plano principal' DETECCIÓN Durante la ejecución. CAUSA El eje esclavo del acoplo es uno de los tres ejes principales. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1179LINKLosEjesMaestroYEsclavoDebenSerDelMismoTipoAXISTYPE_0b015087e5 a ns1:Alarma ;
    rdfs:label "Alarma 1179: '#LINK: los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)'"@es ;
    ns1:identificador "1179" ;
    ns1:textoExtracto "1179 '#LINK: los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)' DETECCIÓN Durante la ejecución. CAUSA Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)."@es .

ns1:Alarma1213ProgramacionNoPermitidaConG63Activa_3f86bc00ec a ns1:Alarma ;
    rdfs:label "Alarma 1213: Programación no permitida con G63 activa"@es ;
    ns1:identificador "1213" ;
    ns1:mitigaRiesgo ns1:ProgramarCALLAXConG63Activa ;
    ns1:textoExtracto "#CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ns1:Alarma1214DemasiadosEjesRequeridos_54e416a146 a ns1:Alarma ;
    rdfs:label "Alarma 1214: Demasiados ejes requeridos"@es ;
    ns1:identificador "1214" ;
    ns1:mitigaRiesgo ns1:SuperarNumeroDeEjesDelSistema ;
    ns1:textoExtracto "#CALL AX/#SET AX: demasiados ejes requeridos. SOLUCIÓN Repasar la configuración de ejes definida para el canal."@es .

ns1:Alarma1215SentenciaNoProgramadaSolaEnBloque_1c64aedf43 a ns1:Alarma ;
    rdfs:label "Alarma 1215: Sentencia no programada sola en bloque"@es ;
    ns1:identificador "1215" ;
    ns1:mitigaRiesgo ns1:ProgramarSentenciaCALLAXSETAXSinBloqueExclusivo ;
    ns1:textoExtracto "La sentencia #CALL AX/#SET AX se programa sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1216NombreDeEjeEnUso_8855645153 a ns1:Alarma ;
    rdfs:label "Alarma 1216: Nombre de eje en uso"@es ;
    ns1:identificador "1216" ;
    ns1:mitigaRiesgo ns1:UsarNombreDeEjeYaAsignadoAEjeC ;
    ns1:textoExtracto "#CALL AX/#CAX: nombre de eje en uso. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1241FaltaTextoDeSustitucionDeMacro_a8b42078fd a ns1:Alarma ;
    rdfs:label "Alarma 1241: Falta texto de sustitución de macro" ;
    ns1:identificador "1241" ;
    ns1:textoExtracto "1241 'Falta el texto de sustitución de la macro' DETECCIÓN Durante la ejecución. CAUSA El texto de sustitución asociado a la macro es una cadena de caracteres vacía. SOLUCIÓN Asociar a la macro el texto de sustitución adecuado según la funcionalidad que se le quiera dar. El texto de sustitución debe ir escrito entre comillas." .

ns1:Alarma1244VelocidadDelCabezalLimitadaEnG96_d409698aa8 a ns1:Alarma ;
    rdfs:label "Alarma 1244: Velocidad del cabezal limitada en G96" ;
    ns1:activaAlarma ns1:Cabezal_473f61fb80 ;
    ns1:identificador "1244" ;
    ns1:monitoreaParametro ns1:VelocidadDeCorteConstanteG96 ;
    ns1:textoExtracto "1244 'Eje frontal próximo al centro: la velocidad del cabezal en G96 ha sido limitada' DETECCIÓN Durante la ejecución. CAUSA Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal debido a la proximidad del eje frontal al centro de giro. SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación." .

ns1:Alarma1249NoSeAdmiteCambioDeGamaConG96Activa_d64bc8670c a ns1:Alarma ;
    rdfs:label "Alarma 1249: 'No se admite cambio de gama con G96 activa'"@es ;
    ns1:identificador "1249" ;
    ns1:textoExtracto "1249 'No se admite cambio de gama con G96 activa' DETECCIÓN Durante"@es .

ns1:Alarma1281NoCoincideElNumeroDeParametrosYDeEspecificadoresDeFormato_c7f0819c9c a ns1:Alarma ;
    rdfs:label "Alarma 1281: No coincide el número de parámetros y de especificadores de formato" ;
    ns1:identificador "1281" ;
    ns1:textoExtracto "1281 'No coincide el número de parámetros y de especificadores de formato' DETECCIÓN Durante la ejecución." .

ns1:Alarma1304VelocidadDeCabezalNoValida_893d229165 a ns1:Alarma ;
    rdfs:label "Alarma 1304: Velocidad de cabezal no válida" ;
    ns1:activaAlarma ns1:Cabezal_473f61fb80 ;
    ns1:identificador "1304" ;
    ns1:monitoreaParametro ns1:VelocidadDeCabezal ;
    ns1:textoExtracto "'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución. CAUSA La velocidad programada es demasiado pequeña. SOLUCIÓN Revisar la programación." .

ns1:Alarma1305ProgramacionNoPermitidaConMCSActivo_332fe923d2 a ns1:Alarma ;
    rdfs:label "Alarma 1305: Programación no permitida con #MCS activo" ;
    ns1:activaAlarma ns1:Sistema_MCS ;
    ns1:identificador "1305" ;
    ns1:textoExtracto "'Programación no permitida con #MCS activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la función MCS." .

ns1:Alarma1319AnidamientoDeSentenciasCSONACSONSobrepasado_831ac74fc0 a ns1:Alarma ;
    rdfs:label "Alarma 1319: Anidamiento de sentencias #CS ON/#ACS ON sobrepasado" ;
    ns1:identificador "1319" ;
    ns1:textoExtracto "1319 'Anidamiento de sentencias #CS ON/#ACS ON sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el límite de combinaciones de sistemas de coordenadas. SOLUCIÓN El CNC permite combinar diferentes sistemas de coordenadas entre sí para construir otros nuevos. El CNC permite combinar 10 sistemas de coordenadas." .

ns1:Alarma1320NumeroMaximoDeEtiquetasSobrepasado_68847f67b3 a ns1:Alarma ;
    rdfs:label "Alarma 1320: Número máximo de etiquetas sobrepasado" ;
    ns1:identificador "1320" ;
    ns1:textoExtracto "1320 'Número máximo de etiquetas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El programa tiene más etiquetas de bloque que las permitidas. SOLUCIÓN El máximo número de etiquetas permitidas de cada tipo es 128." .

ns1:Alarma1321NombreDeEtiquetaDemasiadoLargo_bbcd581860 a ns1:Alarma ;
    rdfs:label "Alarma 1321: Nombre de etiqueta demasiado largo" ;
    ns1:identificador "1321" ;
    ns1:textoExtracto "1321 'Nombre de etiqueta demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la etiqueta supera el número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitido es 15." .

ns1:Alarma1322EtiquetaDefinidaVariasVeces_39d184b205 a ns1:Alarma ;
    rdfs:label "Alarma 1322: Etiqueta definida varias veces" ;
    ns1:identificador "1322" ;
    ns1:textoExtracto "1322 'Etiqueta definida varias veces' DETECCIÓN Durante la ejecución. CAUSA La etiqueta del bloque está repetida en el programa. SOLUCIÓN Eliminar las etiquetas repetidas." .

ns1:Alarma1323GOTOEtiquetaNoValida_ca19fda789 a ns1:Alarma ;
    rdfs:label "Alarma 1323: $GOTO: Etiqueta no válida" ;
    ns1:identificador "1323" ;
    ns1:textoExtracto "1323 '$GOTO: Etiqueta no válida' DETECCIÓN Durante la ejecución. CAUSA Una etiqueta sólo se puede definir con una cadena de caracteres entre corchetes o con el carácter \"N\" seguido de un número positivo y menor que 2147483646. SOLUCIÓN Revisar la programación." .

ns1:Alarma1324EtiquetaNoDefinidaEnLaMismaSubrutina_b34be5842a a ns1:Alarma ;
    rdfs:label "Alarma 1324: Etiqueta no definida en la misma subrutina" ;
    ns1:identificador "1324" ;
    ns1:textoExtracto "1324 Etiqueta no definida en la misma subrutina que el $GOTO, #RPT ó #ABORT. DETECCIÓN Durante la ejecución. CAUSA La etiqueta programada en $GOTO, #RPT o #ABORT no existe en la subrutina o programa. SOLUCIÓN Definir la etiqueta de salto en el mismo programa o subrutina que las sentencias." .

ns1:Alarma1325NumeroDeBloqueDefinidoVariasVeces_0e05c3ab2b a ns1:Alarma ;
    rdfs:label "Alarma 1325: Número de bloque definido varias veces" ;
    ns1:identificador "1325" ;
    ns1:textoExtracto "1325 'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" está repetido en el programa." .

ns1:Alarma1345ProgramacionIncorrectaDeEjesEnG20_8ddda07868 a ns1:Alarma ;
    rdfs:label "Alarma 1345: Programación incorrecta de ejes en G20"@es ;
    ns1:identificador "1345" ;
    ns1:mitigaRiesgo ns1:ProgramacionIncorrectaDeEjesEnFuncionG20Parametros1Y2NoValidos ;
    ns1:textoExtracto "'G20: programación incorrecta de ejes' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos. SOLUCIÓN Ambos ejes han de ser diferentes y estar entre los tres primeros ejes"@es .

ns1:Alarma1361FuncionGNoPermitidaConEjeCActivo_58d975d840 a ns1:Alarma ;
    rdfs:label "Alarma 1361: 'Función G no permitida con eje C activo'" ;
    ns1:identificador "1361" ;
    ns1:textoExtracto "'con eje C activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una función G33/G63/G95/G96/G97 con el eje C activo. SOLUCIÓN Desactivar el eje C para ejecutar la función." .

ns1:Alarma1362DimensionDeArrayIncorrecta_3fdbd4df38 a ns1:Alarma ;
    rdfs:label "Alarma 1362: 'Dimensión de array incorrecta'" ;
    ns1:identificador "1362" ;
    ns1:textoExtracto "'Dimensión de array incorrecta' DETECCIÓN Durante la ejecución. CAUSA La variable es de array pero el número de arrays programados es incorrecto. SOLUCIÓN Verificar la sintaxis de la variable." .

ns1:Alarma1363DeclaracionIncorrectaDeVariablesDeArray_e2ab8ed00f a ns1:Alarma ;
    rdfs:label "Alarma 1363: 'Declaración incorrecta de variables de array'" ;
    ns1:identificador "1363" ;
    ns1:textoExtracto "'Declaración incorrecta de variables de array' DETECCIÓN Durante la ejecución. CAUSA Las variables de usuario que son array deben declararse entre las sentencias #VAR y #ENDVAR. SOLUCIÓN Revisar la programación." .

ns1:Alarma1364NumeroDeIndicesEnVariableDeArraySobrepasado_3aa1d30411 a ns1:Alarma ;
    rdfs:label "Alarma 1364: 'Número de índices en variable de array sobrepasado'" ;
    ns1:identificador "1364" ;
    ns1:textoExtracto "'Número de índices en variable de array sobrepasado' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario es un array multidimensional con más de 4 dimensiones. SOLUCIÓN Revisar la programación." .

ns1:Alarma1365NoSeAdmiteVelocidadDelCabezalNegativa_53c350d427 a ns1:Alarma ;
    rdfs:label "Alarma 1365: 'No se admite velocidad del cabezal negativa'" ;
    ns1:identificador "1365" ;
    ns1:textoExtracto "'No se admite velocidad del cabezal negativa' DETECCIÓN Durante la ejecución." .

ns1:Alarma1388NoSeAdmitenMasFuncionesH_4f41538189 a ns1:Alarma ;
    rdfs:label "Alarma 1388: No se admiten más funciones H" ;
    ns1:identificador "1388" ;
    ns1:textoExtracto "'No se admiten más funciones H' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones H de las permitidas." .

ns1:Alarma1389FuncionesGIncompatiblesG10G11G12G13G14_30610c926f a ns1:Alarma ;
    rdfs:label "Alarma 1389: Funciones G incompatibles (G10/G11/G12/G13/G14)" ;
    ns1:identificador "1389" ;
    ns1:textoExtracto "'Funciones G incompatibles (G10/G11/G12/G13/G14)' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí." .

ns1:Alarma1396ProgramacionNoPermitidaEnMDI_ac79bbf483 a ns1:Alarma ;
    rdfs:label "Alarma 1396: Programación no permitida en MDI" ;
    ns1:identificador "1396" ;
    ns1:solucionaFallo ns1:ProgramacionNoPermitidaEnMDI ;
    ns1:textoExtracto "1396 'Programación no permitida en MDI' DETECCIÓN Durante la ejecución. CAUSA No se permite ejecutar esa orden en MDI. SOLUCIÓN Ejecutar esa orden dentro de un programa." .

ns1:Alarma1397PosicionIncorrectaParaElEjeHirth_c45777b93e a ns1:Alarma ;
    rdfs:label "Alarma 1397: Posición incorrecta para el eje Hirth" ;
    ns1:identificador "1397" ;
    ns1:solucionaFallo ns1:PosicionIncorrectaParaElEjeHirth ;
    ns1:textoExtracto "1397 'La posición programada para el eje Hirth es incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota programada para el eje Hirth no se corresponde a un paso entero. SOLUCIÓN El eje hirth sólo admite cotas múltiplo de su paso." .

ns1:Alarma1398EjeNoConfiguradoComoHirth_67cc9e9abc a ns1:Alarma ;
    rdfs:label "Alarma 1398: Eje no configurado como Hirth" ;
    ns1:identificador "1398" ;
    ns1:solucionaFallo ns1:EjeNoConfiguradoComoHirth ;
    ns1:textoExtracto "1398 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar (G171) o desactivar (G170) como eje hirth un eje que no lo es (parámetro HIRTH). SOLUCIÓN Revisar la programación. El eje no se puede activar como eje hirth." .

ns1:Alarma1399ActivacionFallidaDelEjeHirth_8d438ed450 a ns1:Alarma ;
    rdfs:label "Alarma 1399: Activación fallida del eje Hirth" ;
    ns1:identificador "1399" ;
    ns1:textoExtracto "1399 'No puede activarse el eje como Hirth' DETECCIÓN Durante la ejecución." .

ns1:Alarma1409AnidamientoDeFuncionesTConSubrutinaNoPermitido_51e7ad8d3b a ns1:Alarma ;
    rdfs:label "Alarma 1409: Anidamiento de funciones T con subrutina no permitido" ;
    ns1:identificador "1409" ;
    ns1:monitoreaParametro ns1:Parametro_TOOLSUB ;
    ns1:textoExtracto "'Anidamiento de funciones T con subrutina no permitido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un cambio de herramienta y en la subrutina asociada a la función T (parámetro TOOLSUB) hay programado otro cambio de herramienta. SOLUCIÓN No es posible programar una función T dentro de la subrutina asociada al cambio de herramienta." .

ns1:Alarma1411NumeroDeBloquesNoValido_f79bf4e85b a ns1:Alarma ;
    rdfs:label "Alarma 1411: Número de bloques no válido" ;
    ns1:identificador "1411" ;
    ns1:monitoreaParametro ns1:ParametroCDNumeroDeBloques_d2fd23232b ;
    ns1:textoExtracto "'#CD: número de bloques no válido' DETECCIÓN Durante la ejecución. CAUSA El número de bloques programado en la sentencia es incorrecto. SOLUCIÓN El número máximo de bloques a analizar depende del modelo de CNC; 200 bloques (CNC 6065) o 40 (CNC 8060)." .

ns1:Alarma1412ZonaDeVisualizacionParaGraficosMalDefinida_0f2a8e626b a ns1:Alarma ;
    rdfs:label "Alarma 1412: Zona de visualización para gráficos mal definida" ;
    ns1:identificador "1412" ;
    ns1:monitoreaParametro ns1:ParametroDGWZZonaDeVisualizacionGrafica_cd08d8e50b ;
    ns1:textoExtracto "'#DGWZ: zona de visualización para gráficos mal definida' DETECCIÓN Durante la ejecución." .

ns1:Alarma1445ValorDeParametroNoValido_0bf29727b3 a ns1:Alarma ;
    rdfs:label "Alarma 1445: Valor de parámetro no válido" ;
    ns1:identificador "1445" ;
    ns1:textoExtracto "1445 'Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA En una sentencia o en un ciclo fijo, un parámetro tiene un valor no válido. SOLUCIÓN Revisar la programación." .

ns1:Alarma1446BloqueDeInicioNoPermitidoEnSubrutinaLocal_e40576ed29 a ns1:Alarma ;
    rdfs:label "Alarma 1446: Bloque de inicio no permitido en subrutina local" ;
    ns1:identificador "1446" ;
    ns1:textoExtracto "1446 'Bloque de inicio no permitido en subrutina local' DETECCIÓN Durante la ejecución. CAUSA El bloque de inicio no puede ser un bloque de una subrutina local. SOLUCIÓN Seleccionar otro bloque inicial." .

ns1:Alarma1447OpcionDeSoftwareNoPermitida_82397b1b30 a ns1:Alarma ;
    rdfs:label "Alarma 1447: Opción de software no permitida" ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "1447 'Opción de software no permitida' DETECCIÓN Durante la ejecución." .

ns1:Alarma1471G73ProgramacionIncorrectaDelCentroDeGiro_9fc0796c8d a ns1:Alarma ;
    rdfs:label "Alarma 1471: G73 - Programación incorrecta del centro de giro"@es ;
    ns1:identificador "1471" ;
    ns1:mitigaRiesgo ns1:FaltaProgramacionDeCoordenadasEnG73 ;
    ns1:textoExtracto "1471 'G73: programación incorrecta del centro de giro' DETECCIÓN Durante la ejecución. CAUSA En la función G73 falta programar una de las dos coordenadas del centro de giro. SOLUCIÓN Revisar la programación. Es necesario programar las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:Alarma1472G73FaltaProgramarAnguloDeGiro_8f414d749a a ns1:Alarma ;
    rdfs:label "Alarma 1472: G73 - Falta programar ángulo de giro"@es ;
    ns1:identificador "1472" ;
    ns1:mitigaRiesgo ns1:FaltaProgramacionDeAnguloEnG73 ;
    ns1:textoExtracto "1472 'G73: falta programar ángulo de giro' DETECCIÓN Durante la ejecución. CAUSA En la función G73 falta programar el ángulo de giro. SOLUCIÓN Revisar la programación. Es necesario programar el ángulo de giro del sistema de coordenadas junto con las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:Alarma1473ProgramacionPOLYNoPermitidaConGiroActivo_059d0ceb4d a ns1:Alarma ;
    rdfs:label "Alarma 1473: Programación #POLY no permitida con giro activo"@es ;
    ns1:identificador "1473" ;
    ns1:mitigaRiesgo ns1:ConflictoEntrePOLYYG73 ;
    ns1:textoExtracto "1473 'Programación #POLY no permitida con giro activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #POLY con un giro del sistema de coordenadas activo (G73). SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1475RadioDoblementeProgramado_84786d48ad a ns1:Alarma ;
    rdfs:label "Alarma 1475: Radio doblemente programado"@es ;
    ns1:identificador "1475" ;
    ns1:mitigaRiesgo ns1:RadioDuplicadoEnBloque ;
    ns1:textoExtracto "1475 'Radio doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El radio (\"R\" o \"R1\") está programado más de una vez en el mismo bloque. SOLUCIÓN Definir un solo radio en el bloque."@es .

ns1:Alarma1476RadioDePuntaDeHerramientaInconsistente_cee7b86967 a ns1:Alarma ;
    rdfs:label "Alarma 1476: Radio de punta de herramienta inconsistente"@es ;
    ns1:identificador "1476" ;
    ns1:mitigaRiesgo ns1:InconsistenciaEnRadioDeHerramienta ;
    ns1:textoExtracto "1476 'La cajera fue resuelta con diferente radio de la punta de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con un radio de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Alarma1477LongitudDeCorteDeHerramientaInconsistente_137ea7b85e a ns1:Alarma ;
    rdfs:label "Alarma 1477: Longitud de corte de herramienta inconsistente"@es ;
    ns1:identificador "1477" ;
    ns1:mitigaRiesgo ns1:InconsistenciaEnLongitudDeCorte ;
    ns1:textoExtracto "1477 'La cajera fue resuelta con diferente longitud de corte de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con una longitud de corte de herramienta diferente a la actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Alarma1490G63NecesitaProgramarPreviamenteM19_375d14ebf6 a ns1:Alarma ;
    rdfs:label "Alarma 1490: 'G63 necesita programar previamente M19'"@es ;
    ns1:identificador "1490" ;
    ns1:textoExtracto "'G63 necesita programar previamente M19' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer un roscado G63 con un cabezal Sercos sin posicionarlo previamente con M19. SOLUCIÓN Programar M19 antes de realizar el roscado."@es .

ns1:Alarma1491NumeroDePalpadorIncorrecto_f5980d054c a ns1:Alarma ;
    rdfs:label "Alarma 1491: 'Número de palpador incorrecto'"@es ;
    ns1:identificador "1491" ;
    ns1:textoExtracto "'Número de palpador incorrecto' DETECCIÓN Durante la ejecución. CAUSA El número de palpador seleccionado con la sentencia #SELECT PROBE no es correcto. SOLUCIÓN El número de palpador seleccionado deber ser 1 ó 2."@es .

ns1:Alarma1492NoExisteEntradaDigitalAsociadaAlPalpadorPRBDI12_8e6811f3ce a ns1:Alarma ;
    rdfs:label "Alarma 1492: 'No existe entrada digital asociada al palpador (PRBDI1/2)'"@es ;
    ns1:identificador "1492" ;
    ns1:monitoreaParametro ns1:PRBDI2EntradaDigitalParaPalpador,
        ns1:ParametroPRBDI1_5988800d4d ;
    ns1:textoExtracto "'No existe entrada digital asociada al palpador (PRBDI1/2)' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado seleccionar un palpador (#SELECT PROBE) o realizar un movimiento de palpado (G100) y no existe ninguna entrada digital asociada al palpador. SOLUCIÓN Asociar una entrada digital al palpador (parámetro PRBDI1 ó PRBDI2)."@es .

ns1:Alarma1526EXECElCanalIndicadoNoEsDeCNC_fe9b91713c a ns1:Alarma ;
    rdfs:label "Alarma 1526: '#EXEC: el canal indicado no es de CNC'"@es ;
    ns1:identificador "1526" ;
    ns1:textoExtracto "1526 '#EXEC: el canal indicado no es de CNC' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1561EjeMaestroNoValido_d78e70dcaa a ns1:Alarma ;
    rdfs:label "Alarma 1561: 'Eje maestro no válido'" ;
    ns1:identificador "1561" ;
    ns1:textoExtracto "'Eje maestro no válido' DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto. SOLUCIÓN El eje debe pertenecer al canal." .

ns1:Alarma1562EjeEsclavoNoValido_ee6de496f2 a ns1:Alarma ;
    rdfs:label "Alarma 1562: 'Eje esclavo no válido'" ;
    ns1:identificador "1562" ;
    ns1:textoExtracto "'Eje esclavo no válido' DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje esclavo es incorrecto. SOLUCIÓN El eje debe pertenecer al canal." .

ns1:Alarma1564NoSePuedeProgramarUnEjeAparcado_0b744ca5e3 a ns1:Alarma ;
    rdfs:label "Alarma 1564: 'No se puede programar un eje aparcado'" ;
    ns1:identificador "1564" ;
    ns1:textoExtracto "'No se puede programar un eje aparcado' DETECCIÓN Durante la ejecución. CAUSA La instrucción programada no se puede ejecutar sobre un eje aparcado." .

ns1:Alarma1587ParametroNoModificableDesdeLaPuestaAPunto_283708e2f9 a ns1:Alarma ;
    rdfs:label "Alarma 1587: Parámetro no modificable desde la puesta a punto" ;
    ns1:identificador "1587" ;
    ns1:monitoreaParametro ns1:ParametroMaquinaNoModificableEnPuestaAPunto_9d71653fea ;
    ns1:textoExtracto "1587 'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de puesta a punto. SOLUCIÓN El parámetro máquina se podrá modificar directamente en la tabla de parámetros máquina." .

ns1:Alarma1588CabezalEsclavoDebePertenecerAlCanal_1c30366308 a ns1:Alarma ;
    rdfs:label "Alarma 1588: Cabezal esclavo debe pertenecer al canal" ;
    ns1:activaAlarma ns1:SistemaSincronizacion ;
    ns1:identificador "1588" ;
    ns1:textoExtracto "1588 'El cabezal esclavo a sincronizar debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA El cabezal master de una sincronización puede ser de cualquier canal, pero el cabezal esclavo debe ser del canal en el que se programa la sincronización. SOLUCIÓN Sincronizar el cabezal esclavo desde su canal, añadirlo a la configuración del canal actual o utilizar otro cabezal del canal como esclavo." .

ns1:Alarma1589CabezalEsclavoCoincideConElMaestro_fd1ddf9567 a ns1:Alarma ;
    rdfs:label "Alarma 1589: Cabezal esclavo coincide con el maestro" ;
    ns1:activaAlarma ns1:SistemaSincronizacion ;
    ns1:identificador "1589" ;
    ns1:textoExtracto "1589 'El cabezal esclavo no puede coincidir con el maestro' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el cabezal esclavo es el mismo que el maestro." .

ns1:Alarma1612EjesDeTransformacionAngularNoExcluibles_49dba0f98b a ns1:Alarma ;
    rdfs:label "Alarma 1612: Ejes de transformación angular no excluibles"@es ;
    ns1:identificador "1612" ;
    ns1:mitigaRiesgo ns1:TransformacionAngular_ANGAX ;
    ns1:textoExtracto "'Los ejes de la transformación angular activa, #ANGAX, no pueden excluirse'"@es .

ns1:Alarma1613TransformacionAngularDesactivada_2b69d8d589 a ns1:Alarma ;
    rdfs:label "Alarma 1613: Transformación angular desactivada"@es ;
    ns1:identificador "1613" ;
    ns1:mitigaRiesgo ns1:TransformacionAngular_ANGAX ;
    ns1:monitoreaParametro ns1:ParametroANGAXTransformacionAngular_0e48746196 ;
    ns1:textoExtracto "1613 'Se ha desactivado la transformación angular #ANGAX' [...] SOLUCIÓN La transformación angular está desactivada; para activarla, volver a poner en el canal los ejes que forman la transformación angular."@es .

ns1:Alarma1614ProgramacionNoPermitidaConTransformacionAngularActiva_4e38f8bd10 a ns1:Alarma ;
    rdfs:label "Alarma 1614: Programación no permitida con transformación angular activa"@es ;
    ns1:identificador "1614" ;
    ns1:monitoreaParametro ns1:ParametroANGAXTransformacionAngular_0e48746196 ;
    ns1:textoExtracto "1614 'Programación no permitida con la transformación angular #ANGAX activa' [...] SOLUCIÓN Desactivar la transformación angular activa para ejecutar las funciones incompatibles."@es .

ns1:Alarma1615ConflictoConEjeHirthEnTransformacionAngular_0cf6519e81 a ns1:Alarma ;
    rdfs:label "Alarma 1615: Conflicto con eje Hirth en transformación angular"@es ;
    ns1:identificador "1615" ;
    ns1:monitoreaParametro ns1:ParametroANGAXTransformacionAngular_0e48746196 ;
    ns1:textoExtracto "1615 'No se puede activar el eje como Hirth, por formar parte de la transformación #ANGAX' [...] SOLUCIÓN Desactivar la transformación angular para activar el eje hirth."@es .

ns1:Alarma1616RadioPolarNoPermitidoEnG31_0f60d9bfa2 a ns1:Alarma ;
    rdfs:label "Alarma 1616: Radio polar no permitido en G31"@es ;
    ns1:identificador "1616" ;
    ns1:textoExtracto "1616 'G31 no permite la programación del radio polar' [...] SOLUCIÓN La función G31 no admite la programación del radio polar. La función G31 sólo admite coordenadas polares de la forma G31 Q I J."@es .

ns1:Alarma1617IndiceQNoPermitido_454ff8ff19 a ns1:Alarma ;
    rdfs:label "Alarma 1617: Índice Q no permitido"@es ;
    ns1:identificador "1617" ;
    ns1:monitoreaParametro ns1:ParametroQ1_9252650153,
        ns1:ParametroQCoordenadasPolares_60f124ef89 ;
    ns1:textoExtracto "1617 'Indice de Q no permitido' [...] SOLUCIÓN Revisar la programación. Para la programación en polares utilizar el parámetro Q. Para la función G33 utilizar el parámetro Q1."@es .

ns1:Alarma1634ErrorEnSentenciaMOVEEjeCanalInvalido_1795a32844 a ns1:Alarma ;
    rdfs:label "Alarma 1634: Error en sentencia #MOVE (eje/canal inválido)"@es ;
    ns1:identificador "1634" ;
    ns1:monitoreaParametro ns1:ParametroDeAsignacionEjeCanalSentenciaMOVE_5fa3709471 ;
    ns1:textoExtracto "'La sentencia #MOVE sólo admite un eje y debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA No se ha programado un nombre de eje correcto, el eje está en otro canal o no es un eje del sistema. No se permite la programación de cabezales, excepto cuando estén trabajando como eje C, en cuyo caso se debe programar con el nombre del eje C. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1635ExcesoDeEjesEnTransformacionDeCoordenadas_d1655309f0 a ns1:Alarma ;
    rdfs:label "Alarma 1635: Exceso de ejes en transformación de coordenadas"@es ;
    ns1:identificador "1635" ;
    ns1:monitoreaParametro ns1:ParametroNKINAXNumeroDeEjesEnTransformacionDeCoordenadas_96ef2c218a ;
    ns1:textoExtracto "'El número de ejes en la transformación excede al permitido' DETECCIÓN Durante la ejecución. CAUSA La transformación de coordenadas tiene definido en el parámetro NKINAX más ejes de los permitidos en el CNC. SOLUCIÓN Corregir el parámetro máquina NKINAX."@es .

ns1:Alarma1674ErrorDeSintaxisEnProgramacionDePalpador_f44f9b8e49 a ns1:Alarma ;
    rdfs:label "Alarma 1674: Error de sintaxis en programación de palpador"@es ;
    ns1:identificador "1674" ;
    ns1:mitigaRiesgo ns1:ProgramacionIncorrectaDeSentenciaSELECTPROBE ;
    ns1:textoExtracto "1674 'Programar #SELECT PROBE [ Nº palpador, POS/NEG]' [...] DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1675VariableNoAccesibleParaCanal_54915e63bd a ns1:Alarma ;
    rdfs:label "Alarma 1675: Variable no accesible para canal"@es ;
    ns1:identificador "1675" ;
    ns1:textoExtracto "1675 Variable no accesible para su canal. [...] DETECCIÓN Durante la ejecución. CAUSA La variable no es accesible desde el canal. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables."@es .

ns1:Alarma1677DesactivacionDeRTCPTLC_2499cd8bd4 a ns1:Alarma ;
    rdfs:label "Alarma 1677: Desactivación de #RTCP/TLC"@es ;
    ns1:identificador "1677" ;
    ns1:textoExtracto "1677 'Se ha desactivado #RTCP/TLC' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Alarma1697ProgramarCSROTONOFF_47d9548bea a ns1:Alarma ;
    rdfs:label "Alarma 1697: Programar #CSROT [ON]/OFF"@es ;
    ns1:identificador "1697" ;
    ns1:monitoreaParametro ns1:FuncionDeOrientacionCSROT_717c5db5cd ;
    ns1:textoExtracto "'Programar #CSROT [ON]/OFF' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1698ProgramarDEFROTActuacionCriterioAngulo_99fcf2ade8 a ns1:Alarma ;
    rdfs:label "Alarma 1698: Programar #DEFROT [actuación, criterio, ángulo]"@es ;
    ns1:identificador "1698" ;
    ns1:monitoreaParametro ns1:ParametroDEFROTActuacion_2598b58779,
        ns1:ParametroDEFROTAngulo_8e42418afb,
        ns1:ParametroDEFROTCriterio_7d8b36815c ;
    ns1:textoExtracto "'Programar #DEFROT [actuación, criterio, ángulo]' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1699LaFuncionCSROTNoEsAplicableACinematicasConEjesManualesOHirth_fb70886990 a ns1:Alarma ;
    rdfs:label "Alarma 1699: La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth"@es ;
    ns1:identificador "1699" ;
    ns1:monitoreaParametro ns1:FuncionDeOrientacionCSROT_717c5db5cd ;
    ns1:textoExtracto "'La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos de la cinemática tienen que ser servocontrolados de forma continua. SOLUCIÓN Desactivar la sentencia #CSROT."@es .

ns1:Alarma1700PUNTEADOF0_ca829ccdb2 a ns1:Alarma ;
    rdfs:label "Alarma 1700: PUNTEADO: F = 0"@es ;
    ns1:identificador "1700" ;
    ns1:monitoreaParametro ns1:ParametroFAvance_214aee5658 ;
    ns1:textoExtracto "'PUNTEADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Alarma1701PUNTEADOS0_2222e7a2c3 a ns1:Alarma ;
    rdfs:label "Alarma 1701: PUNTEADO: S = 0" ;
    ns1:activaAlarma ns1:ParametroSComienzoDePerfil_21bf4d7b09 ;
    ns1:textoExtracto "1701 'PUNTEADO: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada." .

ns1:Alarma1702PUNTEADOT0_533d388539 a ns1:Alarma ;
    rdfs:label "Alarma 1702: PUNTEADO: T = 0" ;
    ns1:activaAlarma ns1:ParametroTHerramienta_6ae1d7b59b ;
    ns1:textoExtracto "1702 'PUNTEADO: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada." .

ns1:Alarma1703PUNTEADOP0_c909d08aca a ns1:Alarma ;
    rdfs:label "Alarma 1703: PUNTEADO: P = 0" ;
    ns1:activaAlarma ns1:ProfundidadDePasadaP ;
    ns1:textoExtracto "1703 'PUNTEADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P" .

ns1:Alarma1771PerfilDePuntosP0_e987e128f7 a ns1:Alarma ;
    rdfs:label "Alarma 1771: Perfil de puntos P=0"@es ;
    ns1:identificador "1771" ;
    ns1:monitoreaParametro ns1:ProfundidadDePasadaP ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Alarma1772PerfilNulo_edd5af44a5 a ns1:Alarma ;
    rdfs:label "Alarma 1772: Perfil nulo"@es ;
    ns1:identificador "1772" ;
    ns1:textoExtracto "'PERFIL DE PUNTOS: Perfil nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA Los dos primeros puntos del perfil (P1 y P2) son iguales; el ciclo considera que no hay perfil definido. SOLUCIÓN Definir correctamente los puntos del perfil. Dos puntos iguales indican el final del perfil."@es .

ns1:Alarma1773RadioDeHerramientaVsRadioTangencial_46162b826c a ns1:Alarma ;
    rdfs:label "Alarma 1773: Radio de herramienta vs. radio tangencial"@es,
        "PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial"@es ;
