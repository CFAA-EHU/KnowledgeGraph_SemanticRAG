ns1:Error_2476 a ns1:DiagnosticoFallo ;
    rdfs:label "Tabla inexistente en el fichero de material activo" ;
    ns1:identificador "2476" ;
    ns1:solucionaFallo ns1:FicheroMaterialActivo ;
    ns1:textoExtracto "Tabla inexistente en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una tabla tecnológica que no existe en el fichero de material activo. SOLUCIÓN Revisar la programación y qué tablas existen." .

ns1:Error_2477 a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de tabla no permitido" ;
    ns1:identificador "2477" ;
    ns1:solucionaFallo ns1:Sentencia_TECHTABLE ;
    ns1:textoExtracto "Nombre de tabla no permitido. DETECCIÓN Durante la ejecución. CAUSA La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting. SOLUCIÓN La sentencia #TECHTABLE permite activar una tabla tecnológica genérica. Esta sentencia no permite cargar las tablas de Piercing y Cutting, las cuales se gestionan con las sentencias #PIERCING y #CUTTING." .

ns1:Error_2478 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida sin tabla PIERCING en el fichero de material activo" ;
    ns1:identificador "2478" ;
    ns1:solucionaFallo ns1:FicheroMaterialActivo ;
    ns1:textoExtracto "Sentencia no permitida sin tabla PIERCING en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #PIERCING pero el fichero de material activo no tiene tabla de Piercing. SOLUCIÓN Cargar un fichero de material con tabla de Piercing." .

ns1:Error_2479 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida sin tabla CUTTING en el fichero de material activo" ;
    ns1:identificador "2479" ;
    ns1:solucionaFallo ns1:FicheroMaterialActivo ;
    ns1:textoExtracto "Sentencia no permitida sin tabla CUTTING en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #CUTTING pero el fichero de material activo no tiene tabla de Cutting. SOLUCIÓN Cargar un fichero de material con tabla de Cutting." .

ns1:Error_2480 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite START para continuar perfil por datos no válidos" ;
    ns1:identificador "2480" ;
    ns1:textoExtracto "No se admite START para continuar perfil por datos no válidos. DETECCIÓN Al pulsar [START] después de seleccionar un modo de continuación parcial del mecanizado anterior; \"Punto de reinicio\", \"Restart PP\", \"PP interrumpido\" o \"BreakPP\". CAUSA Error en el fichero que guardan los datos para continuar. SOLUCIÓN Repetir el proceso (interrupción del programa y seleccionar tipo de continuación). Si el error persiste, póngase en contacto con Fagor Automation." .

