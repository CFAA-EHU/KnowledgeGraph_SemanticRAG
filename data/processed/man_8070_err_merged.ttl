    rdfs:label "Error desconocido en módulo ABSIND"@es ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ABSIND ;
    ns1:textoExtracto "El módulo ABSIND ha generado un error desconocido. SOLUCIÓN Si el error es repetitivo y persiste pruebe a sustituir el módulo ABSIND asociado a esa captación."@es .

ns1:DiagnosticoFallo_9531 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia SSITYPE en módulo ABSIND"@es ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ABSIND ;
    ns1:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND. Revise el estado del dipswitch S50 del módulo ABSIND."@es .

