    ns1:identificador "8008" ;
    ns1:monitoreaParametro ns1:Parametro_CANMODE ;
    ns1:textoExtracto "'Error almacenado configuración del sistema' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la configuración CAN durante el proceso de carga. SOLUCIÓN Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos." .

ns1:Error_8009 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de los nodos IO" ;
    ns1:identificador "8009" ;
    ns1:solucionaFallo ns1:Nodo_IO ;
    ns1:textoExtracto "'Error cargando software de los nodos IO' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos de I/Os. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8010 a ns1:DiagnosticoFallo ;
