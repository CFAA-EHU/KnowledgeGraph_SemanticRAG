    ns1:identificador "4010" ;
    ns1:textoExtracto "4010 'No se puede escribir parámetro"@es .

ns1:Error_4022 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos por Reset de contadora (Watchdog)" ;
    ns1:identificador "4022" ;
    ns1:textoExtracto "Error en el anillo Sercos debido a un Reset de contadora por Watchdog. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha producido un reset por watchdog en el módulo RCS-S, por una causa interna del software del nodo. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:Error_4024 a ns1:DiagnosticoFallo ;
