ns1:Error_24255 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Error desconocido" ;
    ns1:identificador "24255" ;
    ns1:textoExtracto "EtherCAT: Error desconocido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error de causa desconocida en el bus EtherCAT. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_2444 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2444: #OPEN/#CLOSE/#WRITE - Valor de handle de fichero fuera de rango" ;
    ns1:identificador "2444" ;
    ns1:textoExtracto "#OPEN/#CLOSE/#WRITE:valor de handle de fichero fuera de rango. DETECCIÓN Durante la preparación de bloques. CAUSA Identificador de fichero (comando F) es incorrecto. SOLUCIÓN El identificador de fichero (comando F) debe tener un valor entre 1 y 4." .

ns1:Error_2445 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2445: #OPEN/#CLOSE/#WRITE - Doble programación" ;
    ns1:identificador "2445" ;
    ns1:textoExtracto "#OPEN/#CLOSE/#WRITE:doble programación. DETECCIÓN Durante la preparación de bloques. CAUSA Algún parámetro de la sentencia ha sido programado más de una vez. SOLUCIÓN Programar una única vez cada parámetro de la sentencia." .

ns1:Error_2446 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2446: Prefijo de variable inexistente" ;
    ns1:identificador "2446" ;
    ns1:textoExtracto "Prefijo de variable inexistente. DETECCIÓN Durante la ejecución. CAUSA El prefijo de la variable no existe. SOLUCIÓN Consulte en la documentación la lista de variables permitidas." .

ns1:Error_2447 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2447: #PARALAX - Ejes paralelos deben pertenecer al mismo canal" ;
    ns1:identificador "2447" ;
    ns1:textoExtracto "#PARALAX: Los ejes paralelos deben pertenecer al mismo canal. DETECCIÓN Durante la ejecución. CAUSA Los ejes programados no pertenecen al mismo canal. SOLUCIÓN Los ejes programados deben pertenecer al mismo canal." .

ns1:Error_2448 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2448: Programación no permitida con transformación #PARALAX activa" ;
    ns1:identificador "2448" ;
    ns1:textoExtracto "Programación no permitida con la transformación #PARALAX activa. DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la transformación de ejes paralelos. SOLUCIÓN Desactivar la transformación de ejes paralelos para poder ejecutar el resto de funciones." .

ns1:Error_2449 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2449: Eje Hirth en transformación #PARALAX",
        "Error 2449: Eje Hirth no compatible con transformación #PARALAX" ;
    ns1:identificador "2449" ;
    ns1:solucionaFallo ns1:Transformacion_PARALAX ;
    ns1:textoExtracto "2449 No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes programados es un eje Hirth. SOLUCIÓN Los ejes programados no pueden ser Hirth." .

ns1:Error_24499 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Error en nodo" ;
    ns1:identificador "24499" ;
    ns1:textoExtracto "EtherCAT: Error en nodo. Más información en diagnosis. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error en un nodo. SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

ns1:Error_24513 a ns1:DiagnosticoFallo ;
    rdfs:label "Reset del dispositivo en módulo EtherCAT"@es ;
    ns1:identificador "24513" ;
    ns1:textoExtracto "Módulo %u reset del dispositivo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24514 a ns1:DiagnosticoFallo ;
    rdfs:label "Timeout de comunicación en módulo EtherCAT"@es ;
    ns1:identificador "24514" ;
    ns1:textoExtracto "Módulo %u timeout de comunicación. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24515 a ns1:DiagnosticoFallo ;
    rdfs:label "Múltiples errores de comunicación en módulo EtherCAT"@es ;
    ns1:identificador "24515" ;
    ns1:textoExtracto "Múltiples errores de comunicación en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24516 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación de datos de E/S en módulo EtherCAT"@es ;
    ns1:identificador "24516" ;
    ns1:textoExtracto "Error de comunicación de datos de E/S en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24517 a ns1:DiagnosticoFallo ;
