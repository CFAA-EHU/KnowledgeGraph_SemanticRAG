ns1:Alarma_EmergenciaCANopen a ns1:Alarma ;
    rdfs:label "Alarma por emergencia en nodo CANopen" ;
    ns1:documentadoEn ns1:FalloNodoCANopen_6011 ;
    ns1:textoExtracto "'Report de nodo CANopen:Emergencia indeterminada.' 'Report de nodo CANopen:Emergencia genérica.' [...] 'Report de nodo CANopen:Emergencia específica de fabricante.'" .

ns1:Alarma_Encoder_Vpp a ns1:Alarma ;
    rdfs:label "Alarma de error en señales Vpp del encoder" ;
    ns1:solucionaFallo ns1:Fallo_Encoder_Vpp ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en las señales Vpp del encoder." .

ns1:Alarma_Generica_PerdidaDatos a ns1:Alarma ;
    rdfs:label "Pérdida de datos en el CNC"@es ;
    ns1:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido."@es .

ns1:Alarma_Pulsos_I0s a ns1:Alarma ;
    rdfs:label "Alarma de pulsos entre I0s" ;
    ns1:identificador "9505" ;
    ns1:solucionaFallo ns1:Fallo_Pulsos_I0s ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación de los pulsos entre dos señales de I0" .

ns1:Alarma_RoscadoElectronico a ns1:Alarma ;
    rdfs:label "Detección de fallo en roscado electrónico (G33/G34)"@es ;
    ns1:textoExtracto "electrónico' DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34. SOLUCIÓN El cabezal utilizado para el roscado electrónico debe estar en marcha. Poner en marcha el cabezal en un bloque anterior o en el mismo bloque que G33/G34."@es .

ns1:Alarma_VariablesCNC a ns1:Alarma ;
    rdfs:label "Alarma: Intento de modificación de variables predefinidas del CNC" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC.",
        "SOLUCIÓN No se pueden borrar las variables predefinidas del CNC. Estos comandos sólo son aplicables a variables con prefijo P y S." .

ns1:AlimentacionIOsLocales_24V a ns1:AccionProhibida ;
    rdfs:label "Alimentar las I/Os locales con 24 V"@es ;
    ns1:textoExtracto "SOLUCIÓN Alimentar las I/Os locales con 24 V."@es .

ns1:AlmacenHerramientas a ns1:ComponenteMecanico,
        ns1:Sistema ;
    rdfs:label "Almacén de herramientas (modo descarga/torreta)",
        "Almacén de herramientas"@es ;
    ns1:textoExtracto "Almacén en modo descarga... El almacén de tipo torreta no admite T0... cambio de herramienta se realiza girando la torreta.",
        "carga o descarga de una herramienta del almacén"@es .

ns1:AnalisisCodigosError_4204 a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de códigos de error para fuente del fallo (Error 4204)"@es ;
    ns1:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente."@es .

ns1:AnalisisManiobraPLC_4204 a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de maniobra de PLC para señal SPENA"@es ;
    ns1:textoExtracto "SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA."@es .

ns1:AnilloFibraOptica_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica del módulo RCS-S" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_RevisionConexionesFibra ;
    ns1:textoExtracto "Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:ArchivoENI a ns1:InterfazUsuario ;
    rdfs:label "Archivo ENI de configuración" ;
    ns1:identificador "ENI" ;
    ns1:textoExtracto "es posible que el archivo ENI de configuración sea incorrecto porque algún archivo ESI de los esclavos no sea adecuado." .

ns1:AsistenciaTecnica_Contacto a ns1:TareaMantenimiento ;
    rdfs:label "Contacto con servicio de asistencia técnica" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica." .

ns1:AvisoSeguridad_0032 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 0032: Parámetro o variable Mechatrolink fuera de rango" ;
    ns1:identificador "0032" ;
    ns1:textoExtracto "0032 Parámetro o variable mechatrolink fuera de rango. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro o variable tiene un valor no válido. SOLUCIÓN El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF. El rango de variables Mechatrolink válido es P0 a PFFFF" .

ns1:AvisoSeguridad_0033 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 0033: Array no permitido en parámetros y variables Mechatrolink" ;
    ns1:identificador "0033" ;
    ns1:textoExtracto "0033 Array no permitido en parámetros y variables Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Los parámetros y variables Mechatrolink (parámetros máquina OEM) no admiten arrays. SOLUCIÓN Revisar la programación. Cada parámetro y variable Mechatrolink sólo puede estar asociada a un eje" .

ns1:AvisoSeguridad_0034 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 0034: Falta programar el eje en el parámetro o variable Mechatrolink" ;
    ns1:identificador "0034" ;
    ns1:textoExtracto "0034 Falta programar el eje en el parámetro o variable Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Falta programar el eje en el parámetro o variable Mechatrolink (parámetros máquina OEM). SOLUCIÓN Revisar la programación. Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje" .

ns1:AvisoSeguridad_0036 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 0036: Inconsistencia en la recuperación de la herramienta activa" ;
    ns1:identificador "0036" ;
    ns1:textoExtracto "0036 Inconsistencia en la recuperación de la herramienta activa. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto" .

ns1:AvisoSeguridad_0173 a ns1:AvisoSeguridad ;
    rdfs:label "Recomendaciones para ventilación del habitáculo" ;
    ns1:identificador "0173" ;
    ns1:textoExtracto "Respetar las dimensiones recomendadas para el habitáculo y las distancia mínima recomendada entre las paredes del habitáculo y la unidad central. En caso necesario, instalar ventiladores para airear el habitáculo." .

ns1:AvisoSeguridad_1268 a ns1:AvisoSeguridad ;
    rdfs:label "#CS ON/#ACS ON: error de sintaxis"@es ;
    ns1:identificador "1268" ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta. SOLUCIÓN: Revisar la programación."@es .

ns1:AvisoSeguridad_1352 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1352: Variable duplicada" ;
    ns1:identificador "1352" ;
    ns1:textoExtracto "#VAR/#ENDVAR: la variable definida ya existe. DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1353 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1353: Exceso de valores en inicialización de array" ;
    ns1:identificador "1353" ;
    ns1:textoExtracto "'Demasiados valores para inicializar el array' DETECCIÓN Durante la ejecución. CAUSA En la inicialización de una variable de array de usuario, el CNC inicializa más posiciones de las que tiene. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1354 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1354: Fallo en lectura de variable" ;
    ns1:identificador "1354" ;
    ns1:textoExtracto "'Error en la lectura de la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede leer la variable. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1355 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1355: Borrado de variable no permitido" ;
    ns1:identificador "1355" ;
    ns1:textoExtracto "'No se puede borrar la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado borrar una variable del sistema. SOLUCIÓN El CNC sólo puede borrar variables de usuario (prefijos P y S)." .

ns1:AvisoSeguridad_1356 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1356: Sintaxis incorrecta en $IF EXIST" ;
    ns1:identificador "1356" ;
    ns1:textoExtracto "'Se espera variable o parámetro' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la sentencia $IF EXIST. SOLUCIÓN La instrucción $IF EXIST sólo permite parámetros aritméticos o variables." .

ns1:AvisoSeguridad_1357 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1357: Carácter inválido en #DELETE" ;
    ns1:identificador "1357" ;
    ns1:textoExtracto "'#DELETE: carácter no válido' DETECCIÓN Durante la ejecución. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque. La sentencia se debe programar sola en el bloque o junto a la etiqueta del bloque. Este sentencia sólo permite variables de usuario." .

ns1:AvisoSeguridad_1358 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1358: Variable inexistente en #DELETE" ;
    ns1:identificador "1358" ;
    ns1:textoExtracto "'#DELETE: la variable a borrar no existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario no existe. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1359 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1359: Operación no permitida en variables del sistema" ;
    ns1:identificador "1359" ;
    ns1:textoExtracto "Los comandos #VAR/#ENDVAR/#DELETE no permiten este tipo de variable. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC. SOLUCIÓN No se pueden borrar las variables predefinidas del CNC." .

ns1:AvisoSeguridad_1405 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1405: 'El valor de la S supera la gama máxima'" ;
    ns1:identificador "1405" ;
    ns1:textoExtracto "1405 'El valor de la S supera la gama máxima' [...] DETECCIÓN Durante la ejecución. CAUSA El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal." .

ns1:AvisoSeguridad_1594 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1594: Cabezal esclavo ya sincronizado"@es ;
    ns1:identificador "1594" ;
    ns1:textoExtracto "'El cabezal esclavo ya está sincronizado a otro cabezal' [...] Un cabezal sólo puede ser esclavo de un maestro. Deshacer la sincronización anterior o sincronizar otro cabezal que esté disponible."@es .

ns1:AvisoSeguridad_1595 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1595: Cabezal maestro/esclavo simultáneo"@es ;
    ns1:identificador "1595" ;
    ns1:textoExtracto "'Un cabezal no puede ser a la vez maestro y esclavo de una sincronización' [...] El cabezal esclavo de una sincronización es el cabezal maestro de otra. Revisar la programación."@es .

ns1:AvisoSeguridad_1596 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1596: Cabezal no sincronizado"@es ;
    ns1:identificador "1596" ;
    ns1:textoExtracto "'El cabezal no está sincronizado' [...] El CNC ha intentado desincronizar un cabezal esclavo que no está actualmente sincronizado. Revisar la programación."@es .

ns1:AvisoSeguridad_1597 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1597: Doble sincronización de cabezal esclavo"@es ;
    ns1:identificador "1597" ;
    ns1:textoExtracto "'No se puede sincronizar el mismo cabezal esclavo a dos maestros' [...] No se puede sincronizar de forma simultánea un cabezal esclavo a dos maestros distintos. Decidir qué sincronización de las dos es la que se quiere activar."@es .

ns1:AvisoSeguridad_1598 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1598: Programación durante sincronización"@es ;
    ns1:identificador "1598" ;
    ns1:textoExtracto "'No se permite programar un cabezal esclavo durante la sincronización' [...] Hay programada una velocidad S o una función M para el cabezal esclavo de una sincronización. Eliminar esta programación o desincronizar el cabezal."@es .

ns1:AvisoSeguridad_1599 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1599: Cambio de gama en sincronización"@es ;
    ns1:identificador "1599" ;
    ns1:textoExtracto "'No se admite cambio de gama en cabezales sincronizados' [...] Durante la sincronización de dos cabezales, el CNC no permite el cambio de gama en ninguno de ellos. Cancelar la sincronización para cambiar la gama del cabezal."@es .

ns1:AvisoSeguridad_1638 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1638: Los ejes de la transformación angular (#ANGAX) deben ser lineales"@es ;
    ns1:identificador "1638" ;
    ns1:textoExtracto "1638 'Los ejes de la transformación angular, #ANGAX, deben ser lineales' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación angular con un eje rotativo. SOLUCIÓN Los ejes de la transformación angular deben ser lineales."@es .

ns1:AvisoSeguridad_1641 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1641: Falta radio de desarrollo en programación #CYL"@es ;
    ns1:identificador "1641" ;
    ns1:textoExtracto "1641 '#CYL: Se espera la programación del radio de desarrollo del cilindro' DETECCIÓN Durante la ejecución. CAUSA Falta el valor del radio de desarrollo en la sentencia #CYL. SOLUCIÓN Revisar la programación. Para un radio variable, definir valor cero para que el CNC calcule el radio en función de donde se encuentre la herramienta."@es .

ns1:AvisoSeguridad_1674 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1674: Programar #SELECT PROBE" ;
    ns1:identificador "1674" ;
    ns1:textoExtracto "'Programar #SELECT PROBE [ Nº palpador, POS/NEG]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1675 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1675: Variable no accesible para su canal" ;
    ns1:identificador "1675" ;
    ns1:textoExtracto "1675 'Variable no accesible para su canal.' DETECCIÓN Durante la ejecución. CAUSA La variable no es accesible desde el canal. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables." .

ns1:AvisoSeguridad_1676 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1676: Plano inclinado activo recuperado" ;
    ns1:identificador "1676" ;
    ns1:textoExtracto "'Se ha recuperado el plano inclinado activo' DETECCIÓN Durante la ejecución. CAUSA Tras el encendido, el CNC ha recuperado el plano inclinado que se encontraba activo al apagarlo. SOLUCIÓN El plano inclinado se puede desactivar con la sentencia #CS OFF." .

ns1:AvisoSeguridad_1677 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1677: #RTCP/TLC desactivado" ;
    ns1:identificador "1677" ;
    ns1:textoExtracto "'Se ha desactivado #RTCP/TLC' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer una búsqueda de referencia con la función #RTCP ó #TLC activa. SOLUCIÓN Para ejecutar un búsqueda de referencia hay que desactivar las funciones #RTCP/TLC." .

ns1:AvisoSeguridad_1678 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1678: Variable para captación externa analógica" ;
    ns1:identificador "1678" ;
    ns1:textoExtracto "'Variable existente sólo para captación externa analógica' DETECCIÓN Durante la ejecución. CAUSA La variable programada sólo existe para ejes con captación externa analógica y el eje indicado no cumple esa condición. SOLUCIÓN Revisar la programación. Consultar en los manuales las variables accesibles según el tipo de eje." .

ns1:AvisoSeguridad_1679 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1679: #CAM SELECT no admitido" ;
    ns1:identificador "1679" ;
    ns1:textoExtracto "'No se admite #CAM SELECT con la leva en ejecución o en proceso de carga' DETECCIÓN Durante la ejecución. CAUSA El CNC ha solicitado la carga de una leva que está en ejecución o en un proceso previo de carga. SOLUCIÓN Esperar a que finalice la ejecución o la carga de la leva." .

ns1:AvisoSeguridad_1680 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1680: Número de pieza no válido",
        "Error 1680: Número de pieza no válido"@es ;
    ns1:identificador "1680" ;
    ns1:textoExtracto "'Número de pieza no válido' DETECCIÓN Durante la ejecución.",
        "programado un número de pieza no válido. SOLUCIÓN Programar el número de pieza dentro del rango P1-P4."@es .

ns1:AvisoSeguridad_1701_F a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1701: Punteado (F = 0)"@es ;
    ns1:identificador "1701" ;
    ns1:monitoreaParametro ns1:Parametro_F_1701 ;
    ns1:textoExtracto "1701 'PUNTEADO: S = 0' [...] CAUSA El parámetro F tiene valor 0. No hay avance programado."@es .

ns1:AvisoSeguridad_1701_S a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1701: Punteado (S = 0)"@es ;
    ns1:identificador "1701" ;
    ns1:monitoreaParametro ns1:Parametro_S_1701 ;
    ns1:textoExtracto "1701 'PUNTEADO: S = 0' [...] CAUSA El parámetro S tiene valor 0. No hay velocidad programada."@es .

ns1:AvisoSeguridad_1702 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1702: Punteado (T = 0)"@es ;
    ns1:identificador "1702" ;
    ns1:monitoreaParametro ns1:Parametro_T_1702 ;
    ns1:textoExtracto "1702 'PUNTEADO: T = 0' [...] CAUSA El parámetro T tiene valor 0. No hay herramienta programada."@es .

ns1:AvisoSeguridad_1745 a ns1:AvisoSeguridad ;
    rdfs:label "CAJERA PREVACIADA: P = 0" ;
    ns1:mitigaRiesgo [ a ns1:Parametro ;
            rdfs:label "Parámetro P (profundidad)" ;
            ns1:monitoreaParametro ns1:Sistema_CicloOperacion ;
            ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." ;
            ns1:valor "0" ] ;
    ns1:textoExtracto "1745 'CAJERA PREVACIADA: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:AvisoSeguridad_1974 a ns1:AvisoSeguridad ;
    rdfs:label "Intersección de perfiles no válida" ;
    ns1:identificador "1974" ;
    ns1:textoExtracto "1974 'Intersección de perfiles no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ns1:AvisoSeguridad_1975 a ns1:AvisoSeguridad ;
    rdfs:label "No se ha producido palpación" ;
    ns1:identificador "1975" ;
    ns1:textoExtracto "1975 'No se ha producido palpación' DETECCIÓN Durante la ejecución" .

ns1:AvisoSeguridad_2314 a ns1:AvisoSeguridad ;
    rdfs:label "Programación no permitida dentro de un perfil PROGTL3"@es ;
    ns1:identificador "2314" ;
    ns1:textoExtracto "2314 Programación no permitida dentro de un perfil PROGTL3. DETECCIÓN Durante la ejecución. CAUSA La función programada no está permitida dentro de la definición de un perfil ProGTL3."@es .

ns1:AvisoSeguridad_2449 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2449: Eje Hirth en transformación #PARALAX"@es ;
    ns1:identificador "2449" ;
    ns1:textoExtracto "No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. [...] SOLUCIÓN Los ejes programados no pueden ser Hirth."@es .

ns1:AvisoSeguridad_2450 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2450: Exclusión de ejes en transformación #PARALAX"@es ;
    ns1:identificador "2450" ;
    ns1:textoExtracto "#PARALAX: Los ejes de la transformación activa, no pueden excluirse. [...] CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una"@es .

ns1:AvisoSeguridad_2464 a ns1:AvisoSeguridad ;
    rdfs:label "Movimiento no permitido en selección de piercing con G92"@es ;
    ns1:identificador "2464" ;
    ns1:textoExtracto "Movimiento no permitido en selección de piercing con G92. Programar #MOVE. DETECCIÓN Durante la ejecución. CAUSA En la selección de piercing, se ha elegido la opción de repetir el programa en el mismo punto que la ejecución anterior, y el programa realiza una preselección (G92) en los bloques iniciales. El programa tiene un bloque de movimiento anterior en #INITIALSUB o antes de la primera G1 del programa. SOLUCIÓN Realizar otra selección de piercing o sustituir el movimiento por un movimiento independiente (#MOVE)."@es .

ns1:AvisoSeguridad_2465 a ns1:AvisoSeguridad ;
    rdfs:label "#RPT: la etiqueta N y el número de repeticiones deben ser números enteros"@es ;
    ns1:identificador "2465" ;
    ns1:textoExtracto "#RPT: la etiqueta N y el número de repeticiones deben ser números enteros. DETECCIÓN Durante la ejecución. CAUSA En la sentencia #RPT se ha programado para la etiqueta N o para el número de repeticiones un valor no entero. SOLUCIÓN El valor de la etiqueta N y el número de repeticiones deben ser números enteros."@es .

ns1:AvisoSeguridad_2466 a ns1:AvisoSeguridad ;
    rdfs:label "Se espera nombre de subrutina"@es ;
    ns1:identificador "2466" ;
    ns1:textoExtracto "Se espera nombre de subrutina. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una subrutina local (%L) sin definir su nombre. SOLUCIÓN Definir el inicio de la subrutina local con \"%L nombre\"."@es .

ns1:AvisoSeguridad_2467 a ns1:AvisoSeguridad ;
    rdfs:label "Subrutina local ya existente"@es ;
    ns1:identificador "2467" ;
    ns1:textoExtracto "Subrutina local ya existente. DETECCIÓN Durante la ejecución. CAUSA Hay definidas más de una subrutina local (%L) con el mismo nombre. SOLUCIÓN En un programa no puede haber dos subrutinas locales con el mismo nombre."@es .

ns1:AvisoSeguridad_2468 a ns1:AvisoSeguridad ;
    rdfs:label "Programación COROT=FIX no permitida en cinemáticas cabezal-mesa, TYPE=13..16"@es ;
    ns1:identificador "2468" ;
    ns1:textoExtracto "Programación COROT=FIX no permitida en cinemáticas cabezal-mesa, TYPE=13..16. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP sin giro del sistema de coordenadas para una cinemática cabezal+mesa (TYPE=13..16). SOLUCIÓN Este tipo de cinemática no admite esa programación. Programar el RTCP con giro del sistema de coordenadas o redefinir la cinemática como vectorial (TYPE 52)."@es .

ns1:AvisoSeguridad_2469 a ns1:AvisoSeguridad ;
    rdfs:label "Programación HEAD no permitida en cinemáticas sin cabezal"@es ;
    ns1:identificador "2469" ;
    ns1:textoExtracto "Programación HEAD no permitida en cinemáticas sin cabezal. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal."@es .

ns1:AvisoSeguridad_2488 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2488: Calibración de gap no cargada" ;
    ns1:identificador "2488" ;
    ns1:textoExtracto "Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43. 2488 Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina se ha definido una calibración no lineal de gap. Se ha intentado usar la sonda del gap (#GAPCTRL ON o #LEAP) sin activar dicha tabla. SOLUCIÓN Activar una tabla de calibración del gap mediante el comando #LOAD GAPTABLE." .

ns1:AvisoSeguridad_2489 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2489: RTCP en inspección con KINID TIP" ;
    ns1:identificador "2489" ;
    ns1:textoExtracto "2489 No se permite programar #RTCP en INSPECCIÓN, con KINID TIP activo. DETECCIÓN Durante la ejecución. CAUSA Durante la inspección de herramienta, se ha intenta rehacer el sistema de coordenadas en un orden distinto en el que ha activado. SOLUCIÓN Mantener en el sistema #KIN ID [TIP] o #RTCP durante la inspección de herramienta." .

ns1:AvisoSeguridad_2491 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2491: Programación de #CAX en subrutina" ;
    ns1:identificador "2491" ;
    ns1:textoExtracto "2491 Programación no permitida dentro de la subrutina asociada a #CAX. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #CAX con parámetros de llamada, dentro de la subrutina asociada a #CAX. SOLUCIÓN Revisar la programación. Dentro de la subrutina, programar #CAX sin parámetros." .

ns1:AvisoSeguridad_2492 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2492: Comodín fuera de subrutina #CAX" ;
    ns1:identificador "2492" ;
    ns1:textoExtracto "2492 Comodín no permitido fuera de la subrutina asociada a #CAX. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

ns1:AvisoSeguridad_2501 a ns1:AvisoSeguridad ;
    rdfs:label "Conflicto de movimiento eje lineal/rotativo (RTCP STATIC)" ;
    ns1:identificador "2501" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ns1:AvisoSeguridad_2502 a ns1:AvisoSeguridad ;
    rdfs:label "Movimiento de eje rotativo no permitido (RTCP STATIC)" ;
    ns1:identificador "2502" ;
    ns1:textoExtracto "2502 Movimiento de eje rotativo no permitido, en inspección, con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA Durante la inspección de herramienta, se ha intentado mover un eje rotativo de la cinemática RTCP STATIC activo. SOLUCIÓN Desactivar la funcionalidad de RTCP STATIC para poder mover el eje rotativo." .

ns1:AvisoSeguridad_2504 a ns1:AvisoSeguridad ;
    rdfs:label "Falta segundo punto (XYZ) en G107" ;
    ns1:identificador "2504" ;
    ns1:textoExtracto "2504 G107: Falta programar el segundo punto (XYZ). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2505 a ns1:AvisoSeguridad ;
    rdfs:label "Falta primer punto (IJK) en G107" ;
    ns1:identificador "2505" ;
    ns1:textoExtracto "2505 G107: Falta programar el primer punto (IJK). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2506 a ns1:AvisoSeguridad ;
    rdfs:label "Incompatibilidad G107 con G106/#SPLINE ON" ;
    ns1:identificador "2506" ;
    ns1:textoExtracto "2506 G107 incompatible con G106 y #SPLINE ON. DETECCIÓN Durante la ejecución. CAUSA No es posible programar splines con G107 activa. Tampoco es posible programar G107 sin desactivar previamente G106 mediante una G0, G1. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2507 a ns1:AvisoSeguridad ;
    rdfs:label "Coordenadas no permitidas en G107" ;
    ns1:identificador "2507" ;
    ns1:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución." .

ns1:AvisoSeguridad_3015 a ns1:AvisoSeguridad ;
    rdfs:label "Búsqueda de referencia máquina omitida en búsqueda de bloque"@es ;
    ns1:identificador "3015" ;
    ns1:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida'"@es,
        "DETECCIÓN: Durante la ejecución. CAUSA: Durante una búsqueda de bloque, el CNC ha encontrado una búsqueda de referencia y la ha ignorado. SOLUCIÓN: Hacer la búsqueda de referencia máquina fuera del programa."@es .

ns1:AvisoSeguridad_7007 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 7007: 'En modo carga: T0 no admitida'"@es ;
    ns1:identificador "7007" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0."@es,
        "'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0. SOLUCIÓN Programar la herramienta a cargar en el almacén."@es .

ns1:AvisoSeguridad_8058 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Error de memoria" ;
    ns1:textoExtracto "El CNC puede tener problemas para funcionar correctamente" .

ns1:AvisoSeguridad_8059 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Vida restante del disco por debajo del 25%" ;
    ns1:textoExtracto "El CNC puede tener problemas para funcionar correctamente" .

ns1:AvisoSeguridad_8060 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Vida restante del disco por debajo del 10%" ;
    ns1:textoExtracto "Cierre el CNC y póngase en contacto con Fagor Automation S. Coop. para obtener asistencia técnica. El CNC puede tener problemas para funcionar correctamente." .

ns1:AvisoSeguridad_8847 a ns1:AvisoSeguridad ;
    rdfs:label "Demasiados símbolos de usuario (8847)"@es ;
    ns1:identificador "8847" ;
    ns1:textoExtracto "8847 Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definidos más de 100 símbolos PDEF. SOLUCIÓN Programar algunos símbolos PDEF como símbolos DEF. El PLC permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF."@es .

ns1:AvisoSeguridad_8848 a ns1:AvisoSeguridad ;
    rdfs:label "Demasiados errores (8848)"@es ;
    ns1:identificador "8848" ;
    ns1:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores y"@es .

ns1:AvisoSeguridad_RevisarCableado a ns1:AvisoSeguridad ;
    rdfs:label "Revisar estado del cableado, conexionado y captador" ;
    ns1:textoExtracto "Revise el estado del cable, del conexionado y del captador. Si el problema persiste, contacte con Fagor Automation" .

ns1:Aviso_SoftwareEjes a ns1:AvisoSeguridad ;
    rdfs:label "Límites de software de ejes"@es ;
    ns1:mitigaRiesgo ns1:Fallo_3408 ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:BaseDatosHerramientas_bd8070 a ns1:InterfazUsuario ;
    rdfs:label "Base de datos de herramientas (bd8070.mdb)"@es ;
    ns1:identificador "bd8070.mdb" ;
    ns1:textoExtracto "No puede crear la herramienta en la base de datos (bd8070.mdb). [...] esperar a que se libere."@es .

ns1:Brazo1 a ns1:ComponenteMecanico ;
    rdfs:label "Brazo 1"@es ;
    ns1:textoExtracto "7040 'Error en operación: Vaciar primero el brazo 1' [...] El almacén pide la misma herramienta que está en el brazo 1."@es .

ns1:Brazo2 a ns1:ComponenteMecanico ;
    rdfs:label "Brazo 2"@es ;
    ns1:textoExtracto "7039 'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente' [...] El almacén pide la misma herramienta que está en el brazo 2."@es .

ns1:Bus_CAN a ns1:ComponenteElectrico ;
    rdfs:label "Bus CAN" ;
    ns1:textoExtracto "revisar la coherencia y el nivel de comunicación del bus correspondiente" .

ns1:Bus_EtherCAT_Fagor a ns1:ComponenteElectrico ;
    rdfs:label "Bus EtherCAT"@es ;
    ns1:monitoreaParametro ns1:Parametro_Rutado_EtherCAT ;
    ns1:textoExtracto "bus EtherCAT"@es .

ns1:CCD_Captador a ns1:Sensor ;
    rdfs:label "Captador de imagen (CCD)"@es ;
    ns1:textoExtracto "Error en el captador de imagen (CCD)"@es .

ns1:COMPCI a ns1:ComponenteElectrico ;
    rdfs:label "COMPCI",
        "COMPCI"@es ;
    ns1:identificador "COMPCI" ;
    ns1:monitoreaParametro ns1:Error_3709,
        ns1:ParametroChecksum ;
    ns1:textoExtracto "COMPCI",
        "Error en el test de hardware de la COMPCI. En el arranque se realizan los siguientes test; Flash, RAM común, RAM externa, RAM interna y controlador CAN.",
        "Error en la preparación del proceso de carga de la COMPCI o los módulos remotos.",
        "Verificar el reconocimiento de la COMPCI, el valor del parámetro CANMODE y la instalación del driver de comunicaciones.",
        "COMPCI"@es,
        "Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es ;
    ns1:tieneComponente [ a ns1:ComponenteElectrico ;
            rdfs:label "Controlador CAN de COMPCI" ;
            ns1:textoExtracto "controlador CAN" ],
        [ a ns1:ComponenteElectrico ;
            rdfs:label "Flash de COMPCI" ;
            ns1:textoExtracto "Flash" ],
        [ a ns1:ComponenteElectrico ;
            rdfs:label "RAM común de COMPCI" ;
            ns1:textoExtracto "RAM común" ],
