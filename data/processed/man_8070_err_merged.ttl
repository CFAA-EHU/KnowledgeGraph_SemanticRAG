ns1:Error_2102 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2102: Parámetro #ROUNDPAR demasiado pequeño"@es ;
    ns1:identificador "2102" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado. SOLUCIÓN Programar la sentencia con un error de contorno superior a 20 micras."@es .

ns1:Error_2103 a ns1:DiagnosticoFallo ;
