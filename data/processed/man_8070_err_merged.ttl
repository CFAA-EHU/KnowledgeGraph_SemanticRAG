ns1:DiagnosticoFallo_8895 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción incorrecta en programa PLC" ;
    ns1:identificador "8895" ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador, antes de su conversión a C, ha detectado una instrucción incorrecta. La salida de errores señala la instrucción incorrecta. SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta." .

ns1:DiagnosticoFallo_8896 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo vacío no permitido en CY1" ;
    ns1:identificador "8896" ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA En el programa PLC hay programado un módulo PRG, PE o SUB vacío. SOLUCIÓN Ante un módulo vacío hay dos alternativas; eliminarlo o poner una única instrucción que sea ';'." .

ns1:DiagnosticoFallo_8897 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca del sistema sin permiso de escritura para el PLC" ;
    ns1:identificador "8897" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La señal (marca) no es modificable; es una señal de consulta. SOLUCIÓN Utilizar la señal en instrucciones de consulta." .

ns1:DiagnosticoFallo_8898 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #CAM SELECT" ;
    ns1:identificador "8898" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:DiagnosticoFallo_8899 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #MSGVAR" ;
    ns1:identificador "8899" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:DiagnosticoFallo_8900 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #LEAP" ;
    ns1:identificador "8900" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:DiagnosticoFallo_9318 a ns1:DiagnosticoFallo ;
    rdfs:label "Dos ejes en diferentes grupos multieje con el mismo COUNTERID en alguno de sus SETs" ;
    ns1:identificador "9318" ;
    ns1:solucionaFallo ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "Dos ejes en diferentes grupos multieje con el mismo COUNTERID en alguno de sus SETs. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay ejes en diferentes grupos MULTIAXIS que comparten la misma entrada de captación. SOLUCIÓN Cambiar el parámetro CONTERID de los ejes implicados para que no compartan la misma entrada de captación." .

ns1:DiagnosticoFallo_9319 a ns1:DiagnosticoFallo ;
    rdfs:label "Dos ejes en diferentes grupos multieje con el mismo ANAOUTID en alguno de sus SETs" ;
    ns1:identificador "9319" ;
    ns1:solucionaFallo ns1:Parametro_ANAOUTID ;
    ns1:textoExtracto "Dos ejes en diferentes grupos multieje con el mismo ANAOUTID en alguno de sus SETs. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay ejes en diferentes grupos MULTIAXIS que comparten la misma salida analógica. SOLUCIÓN Cambiar el parámetro ANAOUTID de los ejes implicados para que no compartan la misma salida analógica." .

ns1:DiagnosticoFallo_9320 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben tener el mismo ABSFEEDBACK" ;
    ns1:identificador "9320" ;
    ns1:solucionaFallo ns1:Parametro_ABSFEEDBACK ;
    ns1:textoExtracto "Los ejes maestro y esclavo deben tener el mismo ABSFEEDBACK. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro ABSFEEDBACK. SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro ABSFEEDBACK igual." .

ns1:DiagnosticoFallo_9321 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes del grupo multiaxis tienen que tener el mismo DRIVETYPE" ;
    ns1:identificador "9321" ;
    ns1:solucionaFallo ns1:Parametro_DRIVETYPE ;
    ns1:textoExtracto "Los ejes del grupo multiaxis tienen que tener el mismo DRIVETYPE. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE. SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos." .

ns1:DiagnosticoFallo_9323 a ns1:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Tandem" ;
    ns1:identificador "9323" ;
    ns1:solucionaFallo ns1:Sistema_Mechatrolink ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay un regulador Mechatrolink que forma parte de una pareja tandem. SOLUCIÓN Un regulador Mechatrolink no puede formar parte de un eje tandem. Eliminar el eje Mechatrolink de la pareja tandem o usar reguladores Sercos." .

ns1:DiagnosticoFallo_9324 a ns1:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten grupos MULTIAXIS" ;
    ns1:identificador "9324" ;
    ns1:solucionaFallo ns1:Sistema_Mechatrolink ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay un regulador Mechatrolink que forma parte de un grupo MULTIAXIS. SOLUCIÓN Un regulador Mechatrolink no puede formar parte de un grupo MULTIAXIS. Eliminar el eje Mechatrolink del grupo MULTIAXIS o usar reguladores Sercos." .

ns1:DiagnosticoFallo_9325 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Mechatrolink: Los inverter tienen que ser cabezales" ;
    ns1:identificador "9325" ;
    ns1:solucionaFallo ns1:Sistema_Mechatrolink ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En una configuración Mechatrolink, los inverters siempre deben ser cabezales. SOLUCIÓN Revisar los parámetros máquina." .

ns1:DiagnosticoFallo_9326 a ns1:DiagnosticoFallo ;
    rdfs:label "Mechatrolink I: Looptime 2 ms" ;
    ns1:identificador "9326" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME ;
    ns1:solucionaFallo ns1:Sistema_Mechatrolink ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El modo Mlink-I de Mechatrolink sólo admite un tiempo de ciclo de 2ms. SOLUCIÓN Para el modo Mlink-I asignar un tiempo de ciclo de 2 ms (parámetro LOOPTIME) o utilizar el modo Mlink II (parámetro MLINK)." .

ns1:DiagnosticoFallo_9327 a ns1:DiagnosticoFallo ;
    rdfs:label "Mechatrolink: Número máximo de ejes y cabezales sobrepasado" ;
    ns1:identificador "9327" ;
    ns1:solucionaFallo ns1:Sistema_Mechatrolink ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA La configuración Mechatrolink supera el máximo permitido de ejes y cabezales (servos e inverters)." .

ns1:DiagnosticoFallo_9328 a ns1:DiagnosticoFallo ;
    rdfs:label "MECHATROLINK II: Máximo 2 variables DRV por eje" ;
    ns1:identificador "9328" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En la tabla de parámetros OEM hay asignadas más de dos variables DRV a un mismo eje. SOLUCIÓN Asignar un máximo de dos variables DRV a cada eje." .

ns1:DiagnosticoFallo_9329 a ns1:DiagnosticoFallo ;
    rdfs:label "MECHATROLINK II: No se permiten variables y parámetros DRV en el mismo eje" ;
    ns1:identificador "9329" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En la tabla de variables del regulador (DRV) de los parámetros OEM, hay asignados parámetros y variables a un mismo eje. SOLUCIÓN La definición de parámetros y variables para un mismo eje es excluyente, o se definen parámetros o variables." .

ns1:DiagnosticoFallo_9330 a ns1:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Sercos" ;
    ns1:identificador "9330" ;
    ns1:textoExtracto "Los buses digitales Sercos y Mechatrolink son incompatibles. SOLUCIÓN Revisar los parámetros máquina. • Con bus Sercos, definir en todos los ejes el parámetro MLINK = No y además DRIVETYPE no puede valer 'Mlink'. • Con bus Mechatrolink, definir en todos los ejes el parámetro MLINK distinto de 'no' y además DRIVETYPE no puede valer 'Sercos'." .

ns1:DiagnosticoFallo_9331 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten variables o parámetros DRV con Mechatrolink I ó Mechatrolink II a 17 bytes" ;
    ns1:identificador "9331" ;
    ns1:textoExtracto "Sólo es posible enviar los subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes." .

ns1:DiagnosticoFallo_9347 a ns1:DiagnosticoFallo ;
    rdfs:label "9347 'Eje repetido en VOLCOMP'" ;
    ns1:identificador "9347" ;
    ns1:textoExtracto "9347 'Eje repetido en VOLCOMP' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces. SOLUCIÓN Corregir los parámetros máquina." .

ns1:DiagnosticoFallo_9348 a ns1:DiagnosticoFallo ;
    rdfs:label "9348 Ajuste del eje rotativo fuera de rango" ;
    ns1:identificador "9348" ;
    ns1:textoExtracto "9348 Ajuste del eje rotativo, (valor medido=%d) fuera del rango permitido por el valor máximo (V.K.MAXROTCOMP=%d) en el eje %s. DETECCIÓN Durante la calibración de cinemáticas. CAUSA El valor medido es mayor que el máximo permitido (V.K.MAXROTCOMP). SOLUCIÓN Cambiar el valor de V.K.MAXROTCOMP en la subrutina KINCAL_BEGIN.NC o el valor compensado quedará limitado a ese valor." .

ns1:DiagnosticoFallo_9349 a ns1:DiagnosticoFallo ;
    rdfs:label "9349 Feedback del SET activo del eje no conectado" ;
    ns1:identificador "9349" ;
    ns1:textoExtracto "9349 El feedback del SET activo del eje no está conectado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El feedback definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones." .

ns1:DiagnosticoFallo_9350 a ns1:DiagnosticoFallo ;
    rdfs:label "9350 Motor del SET activo del eje no conectado" ;
    ns1:identificador "9350" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_MotorSET ;
    ns1:textoExtracto "9350 El motor del SET activo del eje no está conectado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El motor definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones." .

ns1:DiagnosticoFallo_9351 a ns1:DiagnosticoFallo ;
    rdfs:label "9351 DEFAULTSET no coincide con M41SET..M44SET" ;
    ns1:identificador "9351" ;
    ns1:textoExtracto "9351 DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:DiagnosticoFallo_9558_ResistenciaBallast a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de corriente en la resistencia de Ballast" ;
    ns1:monitoreaParametro ns1:ResistenciaBallast ;
    ns1:solucionaFallo ns1:Fallo_9558 ;
    ns1:textoExtracto "CAUSA Límite de corriente en la resistencia de Ballast. SOLUCIÓN Revisar el conexionado e integridad de la resistencia de Ballast." .

ns1:DiagnosticoFallo_9610 a ns1:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en regulador" ;
    ns1:identificador "9610" ;
    ns1:solucionaFallo ns1:Regulador_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Detección de cortocircuito en el regulador. SOLUCIÓN Las posibles soluciones son las siguientes: • Realizar un reset del error. Si el error persiste, es posible que la conexión de los cables de potencia sea errónea o que estén en contacto, provocando un cortocircuito. • Es posible que los parámetros sean incorrectos o se deba a un fallo del regulador." .

ns1:DiagnosticoFallo_9611 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en regulador" ;
    ns1:identificador "9611" ;
    ns1:solucionaFallo ns1:Regulador_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Regulador en estado de error. SOLUCIÓN Eliminar la causa del error y resetear el regulador." .

ns1:DiagnosticoFallo_9612 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma en señales de captación (Vpp del encoder)" ;
    ns1:identificador "9612" ;
    ns1:monitoreaParametro ns1:Parametro_VppEncoder ;
    ns1:solucionaFallo ns1:Encoder_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en las señales Vpp del encoder. SOLUCIÓN Revisar el conexionado del encoder." .

ns1:DiagnosticoFallo_9613 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de pulsos entre I0s del encoder" ;
    ns1:identificador "9613" ;
    ns1:monitoreaParametro ns1:Parametro_I0Encoder ;
    ns1:solucionaFallo ns1:Encoder_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." .

ns1:DiagnosticoFallo_9614 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comprobación de CRC de PM" ;
    ns1:identificador "9614" ;
    ns1:solucionaFallo ns1:Regulador_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:DiagnosticoFallo_9615 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la detección de PM" ;
    ns1:identificador "9615" ;
    ns1:solucionaFallo ns1:Regulador_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:DiagnosticoFallo_9616 a ns1:DiagnosticoFallo ;
    rdfs:label "Watchdog de regulador" ;
    ns1:identificador "9616" ;
    ns1:solucionaFallo ns1:Regulador_Generico ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc. SOLUCIÓN Contacte con Fagor Automation." .

ns1:DiagnosticoFallo_9617 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ns1:identificador "9617" ;
    ns1:solucionaFallo ns1:SistemaElectrico_Generico ;
    ns1:textoExtracto "Fallo 24 Vdc inesperado." .

ns1:DiagnosticoFallo_ABSIND_Arranque a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de identificación del módulo ABSIND en arranque" ;
    ns1:solucionaFallo ns1:Modulo_ABSIND ;
    ns1:textoExtracto "No se ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema" .

ns1:DiagnosticoFallo_AcoploEjesIncompatibles a ns1:DiagnosticoFallo ;
    rdfs:label "Acoplo con ejes de tipo incompatible" ;
    ns1:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)." .

ns1:DiagnosticoFallo_ArrayNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Arrays no permitidos en Mechatrolink" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0033 ;
    ns1:textoExtracto "Los parámetros y variables Mechatrolink (parámetros máquina OEM) no admiten arrays. SOLUCIÓN Revisar la programación. Cada parámetro y variable Mechatrolink sólo puede estar asociada a un eje" .

ns1:DiagnosticoFallo_CompensacionRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en compensación de radio durante trayectoria circular"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_RevisionProgramacion ;
    ns1:solucionaFallo ns1:Alarma_2009,
        ns1:Alarma_2010,
        ns1:Alarma_2011,
        ns1:Alarma_2013,
        ns1:Alarma_2014 ;
    ns1:textoExtracto "Si no es posible programar este bloque, utiliza el modo indirecto (G139) para activar la compensación de radio."@es .

ns1:DiagnosticoFallo_ConflictoFuncionesCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de funciones activas en CNC" ;
    ns1:solucionaFallo ns1:Alarma_1494 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado tener activas simultáneamente las funciones #SPLINE ON, G41, G42 y G136. SOLUCIÓN Desactivar alguna de estas funciones." .

ns1:DiagnosticoFallo_CortocircuitoCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en el contaje local del CNC" ;
    ns1:solucionaFallo ns1:Alarma_CortocircuitoCNC ;
    ns1:textoExtracto "CAUSA Cortocircuito en el contaje local del CNC. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." .

ns1:DiagnosticoFallo_EjesPlano_961 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes del plano no válidos o duplicados"@es ;
    ns1:solucionaFallo ns1:ErrorEjePlano_961 ;
    ns1:textoExtracto "Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC."@es .

ns1:DiagnosticoFallo_FaltaEjeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta programación de eje en Mechatrolink" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0034 ;
    ns1:textoExtracto "Falta programar el eje en el parámetro o variable Mechatrolink. SOLUCIÓN Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje" .

ns1:DiagnosticoFallo_FormatoVCOMPFILE a ns1:DiagnosticoFallo ;
    rdfs:label "Error de formato en VCOMPFILE" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto."@es .

ns1:DiagnosticoFallo_General_Sercos a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_4000_4 ;
    ns1:textoExtracto "Fallo en el proceso de inicialización del anillo Sercos debido a problemas de conexión en la fibra óptica, parametrización en CNC y regulador, problemas en las placas de Sercos o reguladores, etc." .

ns1:DiagnosticoFallo_Generico_CANopen a ns1:DiagnosticoFallo ;
    rdfs:label "Solución genérica para errores CANopen"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_6007,
        ns1:DiagnosticoFallo_6008,
        ns1:DiagnosticoFallo_6009 ;
    ns1:textoExtracto """\r
SOLUCIÓN: Comprobar en el modo diagnosis que el CNC reconoce todos los módulos. Comprobar el pinout del cable CAN. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."""@es .

ns1:DiagnosticoFallo_HerramientaNoEncontrada_954 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Herramienta no encontrada por CNC"@es ;
    ns1:textoExtracto "CAUSA El CNC no encuentra la herramienta."@es,
        "DETECCIÓN Al borrar una herramienta o al cargar la tabla de herramientas."@es,
        "SOLUCIÓN La herramienta no está, luego no puede ser eliminada. Si se produce al cargar la tabla, inicializar la tabla mediante"@es .

ns1:DiagnosticoFallo_IncompatibilidadMotor a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad tipo motor/control"@es ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Topología no validada"@es ;
            ns1:textoExtracto "Validar la topología."@es ] ;
    ns1:textoExtracto "no coincide con el tipo de motor conectado. DETECCIÓN Durante la puesta en marcha, asignación de conexiones y/o cambio en los tipos de motor o fuente RPS. CAUSA El tipo motor conectado a la referencia no coincide con el tipo de control del regulador asociado. SOLUCIÓN Validar la topología."@es .

ns1:DiagnosticoFallo_IncompatibilidadRTCP_TLC a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre funciones RTCP y TLC" ;
    ns1:solucionaFallo ns1:Alarma_1465 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado activar una de las funciones estando la otra activa." .

ns1:DiagnosticoFallo_InconsistenciaHerramientaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Inconsistencia en herramienta activa" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0036 ;
    ns1:textoExtracto "La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto" .

ns1:DiagnosticoFallo_InterpolacionPolinomica a ns1:DiagnosticoFallo ;
    rdfs:label "Exceso de ejes en interpolación polinómica" ;
    ns1:solucionaFallo ns1:Alarma_1459 ;
    ns1:textoExtracto "CAUSA Hay más de tres ejes en el polinomio. SOLUCIÓN En la interpolación polinómica sólo pueden intervenir tres ejes." .

ns1:DiagnosticoFallo_InterseccionPerfiles a ns1:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no válida" ;
    ns1:solucionaFallo ns1:Alarma_1974 ;
    ns1:textoExtracto "Dos perfiles de superficie generan alguna intersección no válida." .

ns1:DiagnosticoFallo_ParametroCero a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Parámetro con valor cero en ciclo" ;
    ns1:solucionaFallo ns1:Alarma_1732,
        ns1:Alarma_1733,
        ns1:Alarma_1734,
        ns1:Alarma_1735,
        ns1:Alarma_1736 ;
    ns1:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_ParametroF a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro F no configurado"@es ;
    ns1:solucionaFallo ns1:Parametro_F_1751 ;
    ns1:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_ParametroFueraRango a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Parámetro o variable Mechatrolink fuera de rango" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0032 ;
    ns1:textoExtracto "El parámetro o variable tiene un valor no válido. SOLUCIÓN El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF. El rango de variables Mechatrolink válido es P0 a PFFFF" .

ns1:DiagnosticoFallo_ParametroS a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro S no configurado"@es ;
    ns1:solucionaFallo ns1:Parametro_S_1751 ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_ParametroT a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro T no configurado"@es ;
    ns1:solucionaFallo ns1:Parametro_T_1752 ;
    ns1:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es .

ns1:DiagnosticoFallo_Parametro_S a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro S = 0" ;
    ns1:solucionaFallo ns1:Parametro_S ;
    ns1:textoExtracto "CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_ParametrosDRV a ns1:DiagnosticoFallo ;
    rdfs:label "Variables DRV con identificador Sercos (ID), tipo de acceso (TYPE) o modo de acceso (MODE) inconsistentes" ;
    ns1:solucionaFallo ns1:Parametro_ID,
        ns1:Parametro_MODE,
        ns1:Parametro_TYPE ;
    ns1:textoExtracto "Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)." .

ns1:DiagnosticoFallo_PasoMecanizadoExcesivo a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:AccionProhibida_PasoMecanizadoInvalido ;
    ns1:textoExtracto "CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta." .

ns1:DiagnosticoFallo_ProgramacionG9 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de coordenadas en programación G9" ;
    ns1:solucionaFallo ns1:Alarma_1461 ;
    ns1:textoExtracto "CAUSA Falta programar una o las dos coordenadas del punto intermedio del arco. SOLUCIÓN La función G9 exige la programación de las dos coordenadas del punto intermedio del arco." .

ns1:DiagnosticoFallo_PuntosFaltantesVCOMPFILE a ns1:DiagnosticoFallo ;
    rdfs:label "Faltan puntos en VCOMPFILE" ;
    ns1:monitoreaParametro ns1:Parametro_NPOINTSAX1,
        ns1:Parametro_NPOINTSAX2,
        ns1:Parametro_NPOINTSAX3 ;
    ns1:solucionaFallo ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El fichero definido en VCOMPFILE no tiene definidos todos los puntos."@es .

ns1:DiagnosticoFallo_RangoEjeRotativo a ns1:DiagnosticoFallo ;
    rdfs:label "Eje rotativo fuera de rango" ;
    ns1:solucionaFallo ns1:Alarma_1464 ;
    ns1:textoExtracto "CAUSA La cota absoluta (G90) programada para el eje rotativo tipo MODULO no es válida. SOLUCIÓN La cota programada para el eje debe encontrarse entre los límites fijados por sus parámetros máquina MODUPLIM y MODLOWLIM." .

ns1:DiagnosticoFallo_ReguladorEnError a ns1:DiagnosticoFallo ;
    rdfs:label "Regulador en error o estado no esperado" ;
    ns1:solucionaFallo ns1:Alarma_3758 ;
    ns1:textoExtracto "El regulador se encuentra en error o en un estado no esperado por el CNC." .

ns1:DiagnosticoFallo_ReguladorIncompatible a ns1:DiagnosticoFallo ;
    rdfs:label "Regulador con versión incompatible para PLOOPRESOL" ;
    ns1:solucionaFallo ns1:Alarma_3756 ;
    ns1:textoExtracto "El regulador no tiene la versión adecuada para el valor de PLOOPRESOL." .

ns1:DiagnosticoFallo_Setup a ns1:DiagnosticoFallo ;
    rdfs:label "Diagrama de tiempos de Sercos no óptimo"@es ;
    ns1:textoExtracto "Setup. CAUSA El diagrama de tiempos de Sercos no es bastante óptimo para garantizar el sincronismo del sistema. SOLUCIÓN Desde la página de diagnosis Sercos, realizar el reajuste de tiempos y aceptar el nuevo diagrama propuesto."@es .

ns1:DiagnosticoFallo_SincronizacionCabezales a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sincronización entre cabezales"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1594,
        ns1:AvisoSeguridad_1595,
        ns1:AvisoSeguridad_1596,
        ns1:AvisoSeguridad_1597,
        ns1:AvisoSeguridad_1598,
        ns1:AvisoSeguridad_1599 ;
    ns1:textoExtracto "CAUSA Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal. SOLUCIÓN Cancelar la sincronización desde el canal al que pertenece el cabezal."@es .

ns1:DiagnosticoFallo_SincronizacionPlacaSense a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en sincronización de placa sense (sin tensión en ramas)" ;
    ns1:solucionaFallo ns1:Alarma_3757 ;
    ns1:textoExtracto "No se detecta tensión en alguna de las ramas de la placa sense durante el comando de sincronización." .

ns1:DiagnosticoFallo_SintaxisParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis: parámetros entre corchetes"@es ;
    ns1:textoExtracto "CAUSA La sentencia programada exige que su lista de parámetros se programe entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:DiagnosticoFallo_SobrecorrienteX12 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente en salida X12 (freno-contactor)" ;
    ns1:solucionaFallo ns1:Alarma_3759 ;
    ns1:textoExtracto "Sobrecorriente en la salida del freno-contactor." .

ns1:DiagnosticoFallo_TensionBusInestable a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de bus no establecida en tiempo SSTIME" ;
    ns1:solucionaFallo ns1:Alarma_3756 ;
    ns1:textoExtracto "No se carga la tensión de bus en el tiempo estimado." .

ns1:DiagnosticoFallo_TrayectoriaCircular a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria circular mal definida" ;
    ns1:solucionaFallo ns1:Alarma_1463 ;
    ns1:textoExtracto "CAUSA Es imposible realizar un arco que pase por los tres puntos disponibles. SOLUCIÓN Definir dos puntos en el bloque junto a G9, que junto con el punto final del movimiento anterior definan un arco. Hay que tener en cuenta que los tres puntos han de ser diferentes y no deben estar alineados." .

ns1:DiagnosticoFallo_TrayectoriaTangente a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria tangente no calculable" ;
    ns1:solucionaFallo ns1:Alarma_1462 ;
    ns1:textoExtracto "CAUSA No se puede realizar un arco tangente a la trayectoria anterior con el radio y punto final programados. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_VariablesCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Restricción de variables CNC" ;
    ns1:solucionaFallo ns1:Alarma_VariablesCNC ;
    ns1:textoExtracto "No se pueden borrar las variables predefinidas del CNC. Estos comandos sólo son aplicables a variables con prefijo P y S." .

ns1:Diagnostico_2354 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en parámetro TIPO de #LSFIT" ;
    ns1:identificador "2354" ;
    ns1:monitoreaParametro ns1:Parametro_TIPO_LSFIT ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido. SOLUCIÓN Revisar la programación." .

ns1:Diagnostico_3812 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error 3812" ;
    ns1:solucionaFallo ns1:Error_3812 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la captación conectada en la entrada de volante; niveles de señal, frecuencia, etc." .

ns1:Diagnostico_4300 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Falta de servidor de variables Sercos (4300)"@es ;
    ns1:identificador "4300" ;
    ns1:solucionaFallo ns1:ErrorBusSercos_4300 ;
    ns1:textoExtracto "'No hay registrado ningún servidor de variables Sercos'. DETECCIÓN En el osciloscopio. CAUSA En un canal del osciloscopio hay definida una variable Sercos, pero no hay ningún servidor de variables Sercos para responder a la petición."@es .

ns1:Diagnostico_604 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de niveles de señal Vpp en captación local del CNC"@es ;
