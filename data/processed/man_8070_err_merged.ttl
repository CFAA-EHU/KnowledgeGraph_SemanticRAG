    ns1:identificador "5015" ;
    ns1:textoExtracto "'La lectura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de un parámetro aritmético global o local que no existe." .

ns1:Alarma_5016 a ns1:Alarma ;
    rdfs:label "Alarma 5016: Valor de lectura fuera de rango" ;
    ns1:identificador "5016" ;
    ns1:textoExtracto "'Valor de lectura fuera de rango' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Dato leído fuera de rango." .

ns1:Alarma_5017 a ns1:Alarma ;
    rdfs:label "Alarma 5017: Bloque nulo de CNCEX" ;
    ns1:identificador "5017" ;
    ns1:textoExtracto "'Bloque nulo de CNCEX' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El bloque programado en la instrucción CNCEX es nulo o la canal programado no está disponible." .

ns1:Alarma_5018 a ns1:Alarma ;
    rdfs:label "Alarma 5018: Marca de comunicación activa" ;
    ns1:identificador "5018" ;
    ns1:textoExtracto "'No se ha ejecutado CNCEX por estar la marca de comunicación a \"1\"' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La marca programada en la instrucción CNCEX ya está activa al ejecutar la instrucción." .

ns1:Alarma_5019 a ns1:Alarma ;
    rdfs:label "Alarma 5019: Canal de ejecución no disponible" ;
    ns1:identificador "5019" ;
    ns1:textoExtracto "'CNCEX: Canal de ejecución no disponible' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no está disponible." .

ns1:Alarma_5020 a ns1:Alarma ;
    rdfs:label "Alarma 5020: Ejecución no finalizada",
        "CNCEX: Ejecución no finalizada" ;
    ns1:identificador "5020" ;
    ns1:textoExtracto "'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La instrucción CNCEX no puede ejecutar el bloque en el canal indicado.",
        "5020 'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La instrucción CNCEX no puede ejecutar el bloque en el canal indicado. SOLUCIÓN Comprobar el estado del canal programado en la instrucción CNCEX." .

ns1:Alarma_8128 a ns1:Alarma ;
    rdfs:label "Error 8128: Fallo en recuperación de datos FRAM"@es ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "No se han podido recuperar los datos de FRAM. [...] Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM."@es .

ns1:Alarma_8416 a ns1:Alarma ;
    rdfs:label "Programar el numerador antes que el denominador" ;
    ns1:identificador "8416" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." .

ns1:Alarma_9628 a ns1:Alarma ;
    rdfs:label "Alarma por frecuencia de contaje excesiva" ;
    ns1:identificador "9628" ;
    ns1:textoExtracto "9628 Captación: Frecuencia de contaje excesiva. [...] La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal." .

