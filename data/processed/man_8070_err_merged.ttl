ns1:Error_1017 a ns1:AvisoSeguridad ;
    rdfs:label "Límite de software negativo fuera de rango" ;
    ns1:identificador "1017" ;
    ns1:monitoreaParametro ns1:LimiteSoftwareNegativo ;
    ns1:textoExtracto "G198: límite de software negativo fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El límite negativo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Error_1018 a ns1:AvisoSeguridad ;
    rdfs:label "Límite de software positivo fuera de rango" ;
    ns1:identificador "1018" ;
    ns1:monitoreaParametro ns1:LimiteDeSoftwarePositivo ;
    ns1:textoExtracto "G199: límite de software positivo fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El límite positivo de software tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Error_1019 a ns1:AvisoSeguridad ;
    rdfs:label "Offset de medición no realizado" ;
    ns1:identificador "1019" ;
    ns1:textoExtracto "No se ha realizado medición en el eje(s) solicitado. DETECCIÓN Durante la ejecución. CAUSA La función G101 intenta incluir el offset de medición en un eje que no ha intervenido en la medición o el offset ha sido cancelado (G102). SOLUCIÓN Para incluir un offset de medición (G101), el eje debe haber realizado una medición." .

ns1:Error_1020 a ns1:AvisoSeguridad ;
    rdfs:label "Tiempo de rampa negativo" ;
    ns1:identificador "1020" ;
    ns1:monitoreaParametro ns1:TiempoDeRampa ;
    ns1:textoExtracto "Tiempo de rampa negativo. DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es negativo. SOLUCIÓN Programar un valor mayor o igual que cero." .

ns1:Error_1021 a ns1:AvisoSeguridad ;
    rdfs:label "Tiempo de rampa fuera de rango" ;
    ns1:identificador "1021" ;
    ns1:monitoreaParametro ns1:TiempoDeRampa ;
    ns1:textoExtracto "Tiempo de rampa fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El tiempo de rampa de la función G132 es demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Error_1022 a ns1:AvisoSeguridad ;
    rdfs:label "Porcentaje de Feed-Forward fuera de rango" ;
    ns1:identificador "1022" ;
    ns1:monitoreaParametro ns1:PorcentajeDeFeedForward ;
    ns1:textoExtracto "Porcentaje de Feed-Forward fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El porcentaje de feed forward (G134) o AC forward (G135) es demasiado alto. SOLUCIÓN El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." .

ns1:Error_1023 a ns1:AvisoSeguridad ;
    rdfs:label "Número de gama no válido" ;
    ns1:identificador "1023" ;
    ns1:monitoreaParametro ns1:NumeroDeGamaSet ;
    ns1:textoExtracto "Número de gama no válido. DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

ns1:Error_1031 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1031: 'Se espera #AXIS'",
        "Error 1031: 'Se espera #AXIS'"@es ;
    ns1:identificador "1031" ;
    ns1:monitoreaParametro ns1:FuncionG201_fb612d3e9a,
        ns1:Sentencia_AXIS ;
    ns1:textoExtracto "1031 'Se espera #AXIS' DETECCIÓN Durante la ejecución."@es .

ns1:Error_1032 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1032: 'Falta posición del cabezal para M19'" ;
    ns1:identificador "1032" ;
    ns1:monitoreaParametro ns1:FuncionM19_8014c11363 ;
    ns1:textoExtracto "'Falta posición del cabezal para M19' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la función M19 falta programar la posición del cabezal. SOLUCIÓN Revisar la programación." .

ns1:Error_1035 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1035: '#SLOPE: parámetro fuera de rango'" ;
    ns1:identificador "1035" ;
    ns1:monitoreaParametro ns1:ParametroSLOPE_cafcdecddc ;
    ns1:textoExtracto "'#SLOPE: parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto. SOLUCIÓN Programar valores menores." .

ns1:Error_1037 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1037: 'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas'" ;
    ns1:identificador "1037" ;
    ns1:textoExtracto "'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' DETECCIÓN Durante la ejecución." .

ns1:Error_1087 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1087: 'Se espera \"=\"'"@es ;
    ns1:identificador "1087" ;
    ns1:textoExtracto "1087 'Se espera \"=\"' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia o la función programada no es correcta. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1088 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1088: 'G159: número de offset no válido'"@es ;
    ns1:identificador "1088" ;
    ns1:textoExtracto "1088 'G159: número de offset no válido' DETECCIÓN Durante la ejecución. CAUSA En la función G159, el traslado de origen programado no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1089 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1089: Funciones M incompatibles (M3/M4/M5/M19, M8-M9, M41-M44)"@es ;
    ns1:identificador "1089" ;
    ns1:textoExtracto "1089 Funciones M incompatibles (M3/M4/M5/M19, M8-M9, M41-M44). DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones M incompatibles entre sí. SOLUCIÓN Programar las funciones M del mismo cabezal en bloques diferentes."@es .

ns1:Error_1156 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1156: Programa principal no encontrado" ;
    ns1:identificador "1156" ;
    ns1:solucionaFallo ns1:SolucionParaError1156 ;
    ns1:textoExtracto "'Programa principal no encontrado' DETECCIÓN Durante la ejecución. CAUSA El CNC no encuentra el programa principal." .

ns1:Error_1168 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1168: Índice de variable fuera de rango"@es ;
    ns1:identificador "1168" ;
    ns1:textoExtracto "1168 'Indice de variable fuera de rango' [...] DETECCIÓN Durante la ejecución. CAUSA Alguno de los índices definidos en la variable de array es incorrecto. SOLUCIÓN El índice mínimo admisible para una variable de array es 1 y el máximo depende de la variable de la que se trate. Hay algunos casos particulares en los que el índice 0 es admitido: G.GS, G.MS, G.LUP1 a G.LUP7, G.LUPACT y MTB.P."@es .

ns1:Error_1169 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1169: Logaritmo de número no válido"@es ;
    ns1:identificador "1169" ;
    ns1:textoExtracto "CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1189 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'"@es ;
    ns1:identificador "1189" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres parámetros. Cada uno de ellos representa el desplazamiento por impulso del volante en cada posición del conmutador."@es .

ns1:Error_1190 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1190: '#MPG: no se permiten resoluciones de volante negativas o cero'"@es ;
    ns1:identificador "1190" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #MPG intenta definir una resolución de volante negativa o nula. SOLUCIÓN El desplazamiento por impulso del volante debe ser un valor positivo y no nulo."@es .

ns1:Error_1191 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1191: '#INCJOG: no se permiten distancias de jog incremental negativas o cero'"@es ;
    ns1:identificador "1191" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir una distancia negativa o nula. SOLUCIÓN El desplazamiento incremental del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Error_1192 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1192: '#INCJOG: no se permiten velocidades de jog incremental negativas o cero'"@es ;
    ns1:identificador "1192" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Error_1193 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1193: '#CONTJOG/#INCJOG: avance programado fuera de rango'"@es ;
    ns1:identificador "1193" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El avance programado es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1194 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1194: '#INCJOG: demasiados parámetros'"@es ;
    ns1:identificador "1194" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #INCJOG admite un máximo de cinco grupos de parámetros. Cada uno de ellos representa el avance y el desplazamiento del eje para cada posición del conmutador en jog incremental."@es .

ns1:Error_1195 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1195: '#CONTJOG: demasiados parámetros'"@es ;
    ns1:identificador "1195" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución."@es .

ns1:Error_1196 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'"@es ;
    ns1:identificador "1196" ;
    ns1:monitoreaParametro ns1:ParametroDeAvanceEnJogContinuo_463bab80bb ;
    ns1:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo. [...] DETECCIÓN Durante la ejecución. CAUSA La sentencia #CONTJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en jog continuo debe ser un valor positivo y no nulo."@es .

ns1:Error_1197 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1197: '#SET OFFSET: offset inferior positivo'"@es ;
    ns1:identificador "1197" ;
    ns1:monitoreaParametro ns1:LimiteDeRecorridoInferiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido inferior del eje para el desplazamiento manual tiene un valor positivo. SOLUCIÓN El límite de recorrido inferior para el desplazamiento manual ser un valor negativo o cero."@es .

ns1:Error_1198 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1198: '#SET OFFSET: límite negativo fuera de rango'"@es ;
    ns1:identificador "1198" ;
    ns1:monitoreaParametro ns1:LimiteDeRecorridoInferiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido inferior es demasiado bajo. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1199 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1199: '#SET OFFSET: offset superior negativo'"@es ;
    ns1:identificador "1199" ;
    ns1:monitoreaParametro ns1:LimiteDeRecorridoSuperiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido superior del eje para el desplazamiento manual tiene un valor negativo. SOLUCIÓN El límite de recorrido superior para el desplazamiento manual ser un valor positivo o cero."@es .

ns1:Error_1200 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1200: '#SET OFFSET: límite positivo fuera de rango'"@es ;
