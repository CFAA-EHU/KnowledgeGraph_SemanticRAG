ns1:Alarma_3757 a ns1:Alarma ;
    rdfs:label "Alarma 3757: RPS, error en sincronización de placa sense" ;
    ns1:identificador "3757" ;
    ns1:textoExtracto "3757 RPS, error en la ejecución del comando de sincronización de la placa sense. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA No se detecta tensión en alguna de las ramas de la placa sense durante el comando de sincronización." .

ns1:Alarma_3758 a ns1:Alarma ;
    rdfs:label "Alarma 3758: RPS, regulador en error o estado incorrecto" ;
    ns1:identificador "3758" ;
