ns1:ErrorNodeModuleSinDefinir a ns1:AvisoSeguridad ;
    rdfs:label "Error Node Module sin definir" ;
    ns1:identificador "4616" ;
    ns1:textoExtracto "4616 Error Node Module sin definir. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de detección de nodos en el bus. SOLUCIÓN Corregir la configuración del bus simulado. Si no hay bus simulado, póngase en contacto con Fagor Automation." .

ns1:ErrorNombreTablaInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Nombre de tabla de parámetros máquina inválido" ;
    ns1:monitoreaParametro ns1:TablaParametrosMaquina ;
    ns1:textoExtracto "CAUSA El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo. SOLUCIÓN El nombre indicado en la variable debe ser una tabla válida." .

ns1:ErrorOperacionalBus_4605 a ns1:DiagnosticoFallo ;
