ns1:Error_1290 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1290: Programación de coordenadas I, J, K incorrecta" ;
    ns1:identificador "1290" ;
    ns1:textoExtracto "'Programación de coordenadas I, J, K incorrecta' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los valores programados para el centro de una interpolación circular, origen polar o centro de giro del sistema de coordenadas son demasiado altos. • Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos. SOLUCIÓN Revisar la programación." .

ns1:Error_1291 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1291: No se admiten más funciones S" ;
    ns1:identificador "1291" ;
    ns1:textoExtracto "'No se admiten más funciones S' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones S de las permitidas. SOLUCIÓN El máximo número de funciones S admitido en un mismo bloque es 4." .

ns1:Error_1292 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1292: Función M doblemente programada" ;
    ns1:identificador "1292" ;
    ns1:textoExtracto "'Función M doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función M está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." .

ns1:Error_1293 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1293: Función H doblemente programada" ;
    ns1:identificador "1293" ;
    ns1:textoExtracto "'Función H doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función H está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." .

ns1:Error_1301 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1301: Transformación de longitud de herramienta excede formato numérico" ;
    ns1:identificador "1301" ;
    ns1:textoExtracto "'La transformación de longitud de herramienta excede el formato numérico válido' DETECCIÓN Durante la ejecución. CAUSA La transformación de longitud de herramienta excede el formato numérico válido. SOLUCIÓN Modificar los valores de la transformación de longitud o los de la herramienta." .

ns1:Error_1302 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1302: Carácter no válido en el nombre" ;
    ns1:identificador "1302" ;
    ns1:textoExtracto "'Carácter no válido en el nombre' DETECCIÓN Durante la ejecución. CAUSA Carácter no válido en el nombre de una etiqueta, subrutina o variable. SOLUCIÓN Revisar la programación." .

ns1:Error_1303 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error 1303: Nombre de variable demasiado largo",
        "Error 1303: Nombre de variable demasiado largo"@es ;
    ns1:identificador "1303" ;
    ns1:textoExtracto "'Nombre de variable demasiado largo' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable. SOLUCIÓN El máximo número de caracteres permitido es 13.",
        "1303 'Nombre de variable demasiado largo' [...] SOLUCIÓN El máximo número de caracteres permitido es 13."@es .

ns1:Error_1304 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1304: Velocidad de cabezal no válida"@es ;
    ns1:identificador "1304" ;
    ns1:textoExtracto "1304 'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución."@es .

ns1:Error_1327 a ns1:AvisoSeguridad ;
    rdfs:label "Posición del cabezal doblemente programada (Error 1327)" ;
    ns1:identificador "1327" ;
    ns1:textoExtracto "1327 Posición del cabezal doblemente programada. DETECCIÓN Durante la ejecución. CAUSA La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque. SOLUCIÓN Revisar la programación. Programar la velocidad de posicionamiento una única vez en el bloque." .

ns1:Error_1328 a ns1:AvisoSeguridad ;
    rdfs:label "Sentencia $FOR sin $ENDFOR (Error 1328)" ;
    ns1:identificador "1328" ;
    ns1:textoExtracto "1328 'Sentencia $FOR sin $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA Hay programada una instrucción $FOR pero falta su $ENDFOR. SOLUCIÓN Revisar la programación." .

ns1:Error_1331 a ns1:AvisoSeguridad ;
    rdfs:label "#TANGFEED RMIN: radio negativo no permitido (Error 1331)" ;
    ns1:identificador "1331" ;
    ns1:textoExtracto "1331 '#TANGFEED RMIN: radio negativo no permitido' DETECCIÓN Durante la ejecución. CAUSA El radio programado es menor o igual que cero. SOLUCIÓN Revisar la programación." .

ns1:Error_1332 a ns1:AvisoSeguridad ;
    rdfs:label "#TOOL AX: orientación de herramienta no especificada (Error 1332)" ;
    ns1:identificador "1332" ;
    ns1:textoExtracto "1332 '#TOOL AX: se espera orientación +/- tras la designación del eje' DETECCIÓN Durante la ejecución. CAUSA Falta programar la orientación de la herramienta. SOLUCIÓN Revisar la programación." .

ns1:Error_1333 a ns1:AvisoSeguridad ;
    rdfs:label "Cambio de eje con compensación de radio activa (Error 1333)" ;
    ns1:identificador "1333" ;
    ns1:textoExtracto "1333 'Cambio del primer y/o segundo eje del plano con compensación de radio activa' DETECCIÓN Durante la ejecución. CAUSA Con la compensación de radio activa, el CNC ha intentado cambiar la configuración de ejes del canal y el cambio afecta a los dos primeros ejes del plano de trabajo. SOLUCIÓN Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo." .

ns1:Error_1334 a ns1:AvisoSeguridad ;
    rdfs:label "G200: movimiento no admitido en el mismo bloque (Error 1334)" ;
    ns1:identificador "1334" ;
    ns1:textoExtracto "1334 'G200: no admite movimiento en el mismo bloque' DETECCIÓN Durante la ejecución." .

ns1:Error_1369 a ns1:DiagnosticoFallo ;
    rdfs:label "#HSC: programación no permitida"@es ;
    ns1:activaAlarma ns1:Alarma_1369 ;
    ns1:identificador "1369" ;
    ns1:textoExtracto """\r
    '#HSC: programación no permitida'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: La sintaxis de la sentencia no es correcta.\r
    SOLUCIÓN: Revisar la programación."""@es .

ns1:Error_1370 a ns1:DiagnosticoFallo ;
    rdfs:label "#HSC: doble programación"@es ;
    ns1:activaAlarma ns1:Alarma_1370 ;
    ns1:identificador "1370" ;
    ns1:textoExtracto """\r
    '#HSC: doble programación'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: En un mismo bloque está programada la activación y desactivación del modo HSC.\r
    SOLUCIÓN: Revisar en el manual de"""@es .

ns1:Error_1394 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1394: 'No existe la subrutina asociada a la función G'"@es ;
    ns1:identificador "1394" ;
    ns1:textoExtracto "1394 'No existe la subrutina asociada a la función G' [...] CAUSA Hay programada una función G180 a G189 y no existe la subrutina asociada. Hay programada una función G74 sola en el bloque y no existe la subrutina asociada."@es .

ns1:Error_1395 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1395: 'La función G74 con subrutina asociada se programa sola en el bloque'"@es ;
    ns1:identificador "1395" ;
    ns1:textoExtracto "1395 'La función G74 con subrutina asociada se programa sola en el bloque' [...] CAUSA Si la función G74 tiene subrutina asociada, se debe programar sola en el bloque o junto a la etiqueta del bloque."@es .

ns1:Error_1396 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1396: 'Programación no permitida en MDI'"@es ;
    ns1:identificador "1396" ;
    ns1:textoExtracto "1396 'Programación no permitida en MDI' [...] CAUSA No se permite ejecutar esa orden en MDI."@es .

ns1:Error_1397 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1397: 'La posición programada para el eje Hirth es incorrecta'"@es ;
    ns1:identificador "1397" ;
    ns1:textoExtracto "1397 'La posición programada para el eje Hirth es incorrecta' [...] CAUSA La cota programada para el eje Hirth no se corresponde a un paso entero."@es .

ns1:Error_1398 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1398: 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO'"@es ;
    ns1:identificador "1398" ;
    ns1:solucionaFallo ns1:Parametro_HIRTH ;
    ns1:textoExtracto "1398 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO' [...] CAUSA El CNC ha intentado activar (G171) o desactivar (G170) como eje hirth un eje que no lo es (parámetro HIRTH)."@es .

ns1:Error_1399 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1399: 'No puede activarse el eje como Hirth'"@es ;
    ns1:identificador "1399" ;
    ns1:textoExtracto "1399 'No puede activarse el eje como Hirth' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Error_1452 a ns1:AvisoSeguridad ;
    rdfs:label "Variable inexistente para el tipo de regulador" ;
    ns1:identificador "1452" ;
    ns1:textoExtracto "Variable inexistente para el tipo de regulador. DETECCIÓN: Durante la ejecución. CAUSA: La variable no existe para el tipo de regulador programado (analógico, simulado o Sercos). SOLUCIÓN: Revisar la programación." .

ns1:Error_1453 a ns1:AvisoSeguridad ;
    rdfs:label "Nombre de eje demasiado largo" ;
    ns1:identificador "1453" ;
    ns1:textoExtracto "Nombre de eje demasiado largo. DETECCIÓN: Durante la ejecución. CAUSA: El nombre del eje supera la longitud máxima permitida de dos caracteres. SOLUCIÓN: El nombre del eje estará definido por 1 ó 2 caracteres. El primer carácter debe ser una de las letras X - Y - Z - U - V - W - A - B - C. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9." .

ns1:Error_1487 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1487: Programación incorrecta de #CLEAR"@es ;
    ns1:identificador "1487" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque."@es,
        "Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. 1487 'Programar: #CLEAR [señal, señal, señal, ...]'"@es .

ns1:Error_1489 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1489: Nombre de eje repetido"@es ;
    ns1:identificador "1489" ;
    ns1:textoExtracto "1489 'Nombre de eje repetido en el grupo resultante'"@es,
        "DETECCIÓN Durante la ejecución. CAUSA La sentencia #RENAME ha intentado renombrar más de un eje con el mismo nombre. SOLUCIÓN Renombrar los ejes de forma que en el canal no haya dos con el mismo nombre."@es .

ns1:Error_1490 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1490: G63 requiere M19 previo"@es ;
    ns1:identificador "1490" ;
    ns1:textoExtracto "1490 'G63 necesita programar previamente M19'"@es,
        "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer un roscado G63 con un cabezal Sercos sin posicionarlo previamente con M19. SOLUCIÓN Programar M19 antes de realizar el roscado."@es .

ns1:Error_1493 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1493: Conflicto de programación simultánea"@es ;
    ns1:identificador "1493" ;
    ns1:textoExtracto "1493 'Programación simultánea de #SPLINE ON, G41/G42 y G136 no permitida'"@es,
        "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado tener activas simultáneamente las funciones #SPLINE ON, G41, G42 y G136. SOLUCIÓN Desactivar alguna de estas funciones."@es .

ns1:Error_1495 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1495: '#PROBE1: eje no válido para ciclo de palpador'"@es ;
    ns1:identificador "1495" ;
    ns1:solucionaFallo ns1:Ciclo_PROBE1 ;
    ns1:textoExtracto "El ciclo PROBE1 da error porque los tres primeros ejes de la configuración actual no coinciden con los tres primeros ejes de la configuración inicial. SOLUCIÓN Restaurar la configuración inicial de los tres primeros ejes del canal."@es .

ns1:Error_1496 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1496: '#PROBE1: programación no permitida con #TOOL AX[-] activo'"@es ;
    ns1:identificador "1496" ;
    ns1:solucionaFallo ns1:Ciclo_PROBE1 ;
    ns1:textoExtracto "El CNC ha intentado ejecutar el ciclo PROBE1 teniendo la herramienta orientada en el sentido negativo del eje. SOLUCIÓN Programar #TOOL AX[+] antes de ejecutar el ciclo PROBE1 para orientar la herramienta en el sentido positivo del eje."@es .

ns1:Error_1497 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1497: 'Operador incorrecto para el tipo de variable'"@es ;
    ns1:identificador "1497" ;
    ns1:textoExtracto "El CNC ha intentado modificar mediante los operadores \"+=\", \"-=\", \"*=\" y \"/=\" alguna variable no numérica. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1499 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1499: 'Número de anidamientos de #RPT y subrutinas sobrepasado'"@es ;
    ns1:identificador "1499" ;
    ns1:solucionaFallo ns1:Sentencia_RPT ;
    ns1:textoExtracto "Se considera anidamiento cuando la sentencia #RPT se programa entre dos etiquetas que definen el radio de acción de otra sentencia #RPT. El CNC da error cuando sobrepasa el número de anidamientos de sentencias RPT y subrutinas, si las hay. SOLUCIÓN El máximo número de anidamientos permitido es 20."@es .

ns1:Error_1500 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1500: '#EXEC: no se puede ejecutar el programa en el canal indicado'"@es ;
    ns1:identificador "1500" ;
    ns1:solucionaFallo ns1:Sentencia_EXEC ;
    ns1:textoExtracto "Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático. SOLUCIÓN Esperar a que finalice el programa en el otro canal o hacerle un reset."@es .

ns1:Error_1508 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1508: 'No se admiten G201 y eje C activo en los ejes del plano principal'"@es ;
    ns1:identificador "1508" ;
    ns1:textoExtracto "1508 'No se admiten G201 y eje C activo en los ejes del plano principal' DETECCIÓN Durante la ejecución."@es .

ns1:Error_1525 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1525: 'No está permitido intercambiar el eje'"@es ;
    ns1:identificador "1525" ;
    ns1:textoExtracto "CAUSA: El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE) y el eje no tiene permiso de cambio (parámetro AXISEXCH). SOLUCIÓN: Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso. El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC."@es .

ns1:Error_1526 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1526: '#EXEC: el canal indicado no es de CNC'"@es ;
    ns1:identificador "1526" ;
    ns1:textoExtracto "CAUSA: Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que no es de CNC, sino de PLC. SOLUCIÓN: Revisar la programación."@es .

ns1:Error_1527 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1527: 'Identificador no válido tras %'"@es ;
    ns1:identificador "1527" ;
    ns1:textoExtracto "CAUSA: En la sentencia #MSG, #ERROR, #WARNING o #WARNINGSTOP hay programado un identificador no válido. SOLUCIÓN: Revisar la programación."@es .

ns1:Error_1529 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1529: 'Se espera lista de identificadores o \"]\" tras comillas finales'"@es ;
    ns1:identificador "1529" ;
    ns1:textoExtracto "CAUSA: En la sentencia #MSG, #ERROR, #WARNING o #WARNINGSTOP hay programado algún carácter no válido tras el mensaje a visualizar. SOLUCIÓN: Revisar la programación. Tras las comillas finales del mensaje a visualizar solo se permite la lista de variables o parámetros a incluir en el texto."@es .

ns1:Error_1530 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1530: 'No se permite programar G53 con coordenadas polares'"@es ;
    ns1:identificador "1530" ;
    ns1:textoExtracto "CAUSA: En la función G53, las cotas del punto final están definidas en coordenadas polares o cilíndricas."@es .

ns1:Error_1531 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1531: Sintaxis incorrecta en programación de bloque EXBLK"@es ;
    ns1:identificador "1531" ;
    ns1:textoExtracto "'Programar: #EXBLK [bloque, canal]' [...] SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error_1532 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1532: Sintaxis incorrecta en programación de cabezal MASTER"@es ;
    ns1:identificador "1532" ;
    ns1:textoExtracto "'Programar: #MASTER <nombre de cabezal>' [...] SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error_1533 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1533: Sintaxis incorrecta en programación de FREESP"@es ;
    ns1:identificador "1533" ;
    ns1:textoExtracto "'Programar: #FREESP [sp1, sp2, ..]' [...] SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error_1534 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1534: Sintaxis incorrecta en programación de CALLSP"@es ;
    ns1:identificador "1534" ;
    ns1:textoExtracto "'Programar: #CALLSP [sp1, sp2, ..]' [...] SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error_1535 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1535: Sintaxis incorrecta en programación de SETSP"@es ;
    ns1:identificador "1535" ;
    ns1:textoExtracto "'Programar: #SETSP [sp1, sp2, ..]' [...] SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error_1538 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1538: Imposibilidad de recuperar cabezal del canal"@es ;
    ns1:identificador "1538" ;
    ns1:textoExtracto "'No se puede recuperar algún cabezal del canal' [...] CAUSA Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es .

ns1:Error_1555 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1555: Sintaxis incorrecta en #MOVE" ;
    ns1:identificador "1555" ;
    ns1:textoExtracto "1555 'Programar #MOVE / #MOVE ABS/ADD/INF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #MOVE es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ABS/ADD/INF y a continuación los parámetros de llamada entre corchetes." .

ns1:Error_1556 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1556: Tipo de enlace incorrecto en #MOVE" ;
    ns1:identificador "1556" ;
    ns1:textoExtracto "1556 'Programar tipo de enlace: PRESENT, NEXT, NULL, WAITINPOS' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #MOVE, el tipo de enlace entre movimientos es incorrecto. SOLUCIÓN Revisar la programación." .

ns1:Error_1557 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1557: Sintaxis incorrecta en #CAM" ;
    ns1:identificador "1557" ;
    ns1:textoExtracto "1557 'Programar #CAM ON/OFF/SELECT/DESELECT[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #CAM es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON, OFF, SELECT o DESELECT y a continuación los parámetros de llamada entre corchetes." .

ns1:Error_1558 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1558: Número de leva incorrecto en #CAM" ;
    ns1:identificador "1558" ;
    ns1:textoExtracto "1558 'Número de leva incorrecto' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #CAM, el número de la leva es incorrecto. SOLUCIÓN El número de leva debe estar comprendido entre 1 y el parámetro NLEVAS." .

ns1:Error_1559 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1559: Tipo de leva incorrecto en #CAM" ;
    ns1:identificador "1559" ;
    ns1:textoExtracto "1559 'Programar tipo de leva: ONCE o CONT' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #CAM, el tipo de leva es incorrecto; el tipo de leva se define con los comandos ONCE (leva no periódica) y CONT (leva periódica). SOLUCIÓN Revisar la programación." .

ns1:Error_1560 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1560: Sintaxis incorrecta en #FOLLOW" ;
    ns1:identificador "1560" ;
    ns1:textoExtracto "1560 'Programar #FOLLOW ON/OFF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #FOLLOW es incorrecta. SOLUCIÓN Revisar la programación." .

ns1:Error_1759 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: P = 0"@es ;
    ns1:identificador "1759" ;
    ns1:monitoreaParametro ns1:Parametro_Profundidad_P ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error_1760 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: R = 0"@es ;
    ns1:identificador "1760" ;
    ns1:monitoreaParametro ns1:Parametro_Radio_R ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro R tiene valor 0. No hay radio programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error_1761 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1761" ;
    ns1:monitoreaParametro ns1:Parametro_PasoFresado_Delta ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Error_1762 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1762" ;
    ns1:monitoreaParametro ns1:Parametro_DemasiasParedes_delta ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Error_1763 a ns1:DiagnosticoFallo ;
    rdfs:label "PLANEADO: F = 0"@es ;
    ns1:identificador "1763" ;
    ns1:monitoreaParametro ns1:Parametro_Avance_F ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error_1764 a ns1:DiagnosticoFallo ;
    rdfs:label "PLANEADO: S = 0"@es ;
    ns1:identificador "1764" ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad_S ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error_1765 a ns1:DiagnosticoFallo ;
    rdfs:label "PLANEADO: T = 0"@es ;
    ns1:identificador "1765" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Error_1800 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1800: Ranurado - Diámetro de herramienta = 0"@es ;
    ns1:identificador "1800" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "radio de herramienta"@es ;
            ns1:textoExtracto "La herramienta de desbaste o acabado tiene radio 0."@es ;
            ns1:valor "0" ] ;
    ns1:textoExtracto "1800 'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Error_1802 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1802: Cajera circular - Beta/Theta fuera de rango"@es ;
    ns1:identificador "1802" ;
    ns1:solucionaFallo ns1:Error_1801 ;
    ns1:textoExtracto "1802 'CAJERA CIRCULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º."@es .

ns1:Error_1803 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1803: Cajera prevaciada - Beta/Theta fuera de rango"@es ;
    ns1:identificador "1803" ;
    ns1:solucionaFallo ns1:Error_1801 ;
    ns1:textoExtracto "1803 'CAJERA PREVACIADA: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º."@es .

ns1:Error_1804 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1804: Ciclo G87 - Profundidad = 0"@es ;
    ns1:identificador "1804" ;
    ns1:solucionaFallo [ a ns1:Parametro ;
            rdfs:label "profundidad de cajera (G87)"@es ;
            ns1:textoExtracto "La profundidad resultante de la cajera es cero."@es ;
            ns1:valor "0" ] ;
    ns1:textoExtracto "1804 'G87: Profundidad = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad resultante de la cajera es cero."@es .

ns1:Error_1806 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que L" ;
    ns1:identificador "1806" ;
    ns1:solucionaFallo ns1:Herramienta_G87_G88 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor." .

ns1:Error_1807 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta = 0" ;
    ns1:identificador "1807" ;
    ns1:solucionaFallo ns1:Herramienta_G87_G88 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Error_1808 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: No hay herramienta" ;
    ns1:identificador "1808" ;
    ns1:solucionaFallo ns1:Herramienta_G87_G88 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal." .

ns1:Error_1809 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que C" ;
    ns1:identificador "1809" ;
    ns1:solucionaFallo ns1:Herramienta_G87_G88 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:Error_1810 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Profundidad = 0" ;
    ns1:identificador "1810" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D. SOLUCIÓN Corregir la programación de los parámetros I Z D." .

ns1:Error_1811 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta mayor que cajera" ;
    ns1:identificador "1811" ;
    ns1:solucionaFallo ns1:Herramienta_G87_G88 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J). SOLUCIÓN Seleccionar una herramienta de diámetro menor." .

ns1:Error_1860 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1860: Programar K = 0/1/2"@es ;
    ns1:identificador "1860" ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 3. El parámetro K (eje de palpación) tiene un valor incorrecto. El parámetro K sólo admite los valores 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)."@es .

ns1:Error_1861 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1861: La distancia de seguridad B debe ser mayor que cero"@es ;
    ns1:identificador "1861" ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de palpador #PROBE. El parámetro B tiene valor negativo. Asignar al parámetro un valor positivo."@es .

ns1:Error_1862 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1862: #PROBE 1 no admitido con G20 activa"@es ;
    ns1:identificador "1862" ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ns1:Error_1863 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1863: Herramienta gastada por desgaste de radio"@es ;
    ns1:identificador "1863" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_CambioHerramienta ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. El ciclo ha detectado que la herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M). Cambiar de herramienta y volver a ejecutar el ciclo."@es .

ns1:Error_1864 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1864: Parámetros U, V, W deben ser mayores que X, Y, Z"@es ;
    ns1:identificador "1864" ;
    ns1:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. En el ciclo está mal definida la posición del palpador de sobremesa. Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W. Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas."@es .

ns1:Error_1881 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: F de semiacabado no válida" ;
    ns1:monitoreaParametro ns1:Parametro_F ;
    ns1:textoExtracto "1881 'Cajera con islas: F de semiacabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de semiacabado tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." .

ns1:Error_1882 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: S de semiacabado no válida" ;
    ns1:monitoreaParametro ns1:Parametro_S ;
    ns1:textoExtracto "1882 'Cajera con islas: S de semiacabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad para la operación de semiacabado tiene valor 0. SOLUCIÓN Definir una velocidad mayor que 0." .

ns1:Error_1883 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Cajera ya en ejecución" ;
    ns1:textoExtracto "1883 'Cajera con islas: Cajera ya en ejecución' DETECCIÓN Durante la ejecución del ciclo. CAUSA El CNC no puede simular o ejecutar la cajera porque ésta ya se encuentra en ejecución o simulación. SOLUCIÓN Esperar a que el CNC termine la simulación o ejecución." .

ns1:Error_1884 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Arco mal programado en perfil" ;
    ns1:textoExtracto "1884 'Cajera con islas: Arco mal programado en perfil' DETECCIÓN Durante la ejecución del ciclo. CAUSA En algún perfil de la cajera hay un arco mal definido o el perfil se ha modificado con otro programa diferente al editor de perfiles. SOLUCIÓN Corregir la geometría del perfil desde el editor de perfiles." .

ns1:Error_1885 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Geometría de la cajera no válida" ;
    ns1:textoExtracto "1885 'Cajera con islas: Geometría de la cajera no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA En algún perfil de la cajera hay un tramo mal definido (redondeos, chaflanes, etc). SOLUCIÓN Corregir la geometría del perfil desde el editor de perfiles." .

ns1:Error_1886 a ns1:AvisoSeguridad ;
    rdfs:label "Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido" ;
    ns1:monitoreaParametro ns1:Parametro_Angulo_Profundizacion ;
    ns1:textoExtracto "1886 'Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido' DETECCIÓN Durante la ejecución del ciclo." .

ns1:Error_2106_HSC a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno en modo HSC (2106)" ;
    ns1:identificador "2106" ;
    ns1:solucionaFallo ns1:ModoHSC ;
    ns1:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución. CAUSA Error en el cálculo de la trayectoria para trabajar en modo HSC. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ns1:Error_2108_HSC a ns1:DiagnosticoFallo ;
    rdfs:label "'HSC: Cambio de modo no permitido' (2108)" ;
    ns1:identificador "2108" ;
    ns1:solucionaFallo ns1:ModoHSC ;
    ns1:textoExtracto "2108 'HSC: Cambio de modo no permitido' DETECCIÓN Durante la ejecución. CAUSA No se puede cambiar el modo HSC sin desactivar el modo anterior. SOLUCIÓN Desactivar el modo HSC antes de programar otro." .

ns1:Error_2109_HSC a ns1:DiagnosticoFallo ;
    rdfs:label "'HSC: Error de contorno demasiado pequeño' (2109)" ;
    ns1:identificador "2109" ;
    ns1:solucionaFallo ns1:ModoHSC ;
    ns1:textoExtracto "2109 'HSC: Error de contorno demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado. SOLUCIÓN Programar la sentencia con un error de contorno superior a 20 micras." .

ns1:Error_2110_HSC a ns1:DiagnosticoFallo ;
    rdfs:label "'Límite software positivo sobrepasado en modo HSC' (2110)" ;
    ns1:identificador "2110" ;
    ns1:solucionaFallo ns1:ModoHSC ;
    ns1:textoExtracto "2110 'Límite software positivo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ns1:Error_2111_HSC a ns1:DiagnosticoFallo ;
    rdfs:label "'Límite software negativo sobrepasado en modo HSC' (2111)" ;
    ns1:identificador "2111" ;
    ns1:solucionaFallo ns1:ModoHSC ;
    ns1:textoExtracto "2111 'Límite software negativo sobrepasado en modo HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo HSC en el bloque o bloques que provocan el error." .

ns1:Error_2112_SPLINE a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE:Tangente inicial indeterminada (2112)" ;
    ns1:identificador "2112" ;
    ns1:textoExtracto "2112 SPLINE:Tangente inicial indeterminada. DETECCIÓN Durante la ejecución. CAUSA El punto inicial del spline coincide con el punto anterior y queda la tangente indeterminada o bien se ha programado sólo un eje de la tangente. SOLUCIÓN Programar un punto previo al punto de entrada al spline o ambos ejes de la tangente." .

ns1:Error_2113_SPLINE a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE:Tangente final indeterminada (2113)" ;
    ns1:identificador "2113" ;
    ns1:textoExtracto "2113 SPLINE:Tangente final indeterminada. DETECCIÓN Durante la ejecución." .

ns1:Error_2114 a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Activación no permitida" ;
    ns1:identificador "2114" ;
    ns1:solucionaFallo ns1:ModoSpline ;
    ns1:textoExtracto "2114 SPLINE:Activación no permitida. DETECCIÓN Durante la ejecución. CAUSA No se puede activar el modo spline sin terminar un spline previo. SOLUCIÓN Desactivar el modo spline activo antes de definir uno nuevo." .

ns1:Error_2115 a ns1:DiagnosticoFallo ;
