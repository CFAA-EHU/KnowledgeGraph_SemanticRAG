ns1:Fallo_9719 a ns1:DiagnosticoFallo ;
    rdfs:label "Warning en DrcLoop" ;
    ns1:identificador "9719" ;
    ns1:solucionaFallo ns1:CNCTIME_eff29762a8,
        ns1:POSLOOPTIME_a4bbc9acd6,
        ns1:SYSTEMTIME_0e55982614 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, validación de parámetros o cambio de ser en un eje o cabezal. CAUSA Error en el chequeo de coherencia de parámetros de tiempos de ciclo o error en la inicialización de los parámetros de un eje o cabezal. SOLUCIÓN Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Fallo_ParametrosConexion a ns1:DiagnosticoFallo ;
    rdfs:label "Conexión no existente en parámetro máquina"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC, la validación de parámetros máquina o tras un reset. CAUSA La conexión especificada en el parámetro no existe. SOLUCIÓN Revisar el apartado conexiones del CNC y comprobar que existen todas las conexiones que se van a utilizar."@es .

ns1:FaltaAlimentacionDeIOsLocales6036 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta alimentación de IOs locales (6036)" ;
    ns1:identificador "6036" ;
    ns1:textoExtracto "6036 'Falta alimentación de IOs locales' DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU). SOLUCIÓN Alimentar las I/Os locales con 24 V." .

ns1:FaltaParametroDONEnSentenciasFOLLOWONSYNC a ns1:DiagnosticoFallo ;
