    ns1:textoExtracto "Límites de software para ejes lineales analógicos y sercos."@es .

ns1:AvisoSeguridad_ManualCNC a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre uso correcto del CNC" ;
    ns1:documentadoEn ns1:Manual_FagorAutomation_CNC ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC si éste se utiliza de manera diferente a la explicada en la documentación relacionada." .

ns1:AvisoSeguridad_OverTemp a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sobretemperatura (OVERTEMP)" ;
    ns1:activaAlarma ns1:Alarma_OverTemp ;
    ns1:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo; si en tres muestras seguidas la temperatura supera los 60ºC (140ºF), el CNC muestra este aviso y activa la marca OVERTEMP. El warning muestra la temperatura actual." .

ns1:AvisoSeguridad_ProductosDobleUso a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Productos de doble uso (Reglamento UE 428/2009)" ;
    ns1:cumpleNormativa ns1:Directiva_UE_428_2009 ;
    ns1:textoExtracto "Los productos fabricados por FAGOR AUTOMATION [...] si el producto según el reglamento UE 428/2009 está incluido en la lista de productos de doble uso, incluye en la identificación de producto el texto -MDU y necesita licencia de exportación según destino." .

ns1:AvisoSeguridad_ProgramacionNR a ns1:AvisoSeguridad ;
    rdfs:label "Validación de programación NR"@es ;
    ns1:mitigaRiesgo ns1:AccionProhibida_NR_SinMovimiento ;
    ns1:textoExtracto "La repetición de otro tipo de bloques deberá hacerse mediante las instrucciones de control de flujo que ofrece"@es .

ns1:AvisoSeguridad_SincronizacionCabezales a ns1:AvisoSeguridad ;
    rdfs:label "Conflicto de sincronización de cabezales con eje C o función G63"@es ;
    ns1:textoExtracto "CAUSA El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa. [...] SOLUCIÓN Desactivar el eje C o la función G63 para sincronizar los cabezales. Para trabajar con el eje C o la función G63, cancelar la sincronización de cabezales."@es .

ns1:AvisoSeguridad_TestTendenciaEjes a ns1:AvisoSeguridad ;
    rdfs:label "Test de tendencia en los ejes analógicos"@es ;
    ns1:documentadoEn ns1:Manual_FagorAutomation ;
    ns1:mitigaRiesgo ns1:Sistema_SeguridadesCNC ;
    ns1:textoExtracto "Test de tendencia en los ejes analógicos."@es .

ns1:AvisoSeguridad_VirusInformaticos a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Virus informáticos en el sistema" ;
    ns1:mitigaRiesgo ns1:CNC_Generic ;
    ns1:textoExtracto "La presencia de virus informáticos en el CNC puede provocar su mal funcionamiento. [...] implica la pérdida de la garantía." .

ns1:AvisoSincronizacion a ns1:AvisoSeguridad ;
    rdfs:label "Validación de parámetros previa a sincronización de cabezales"@es ;
    ns1:mitigaRiesgo ns1:SistemaCNC ;
    ns1:textoExtracto "La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización de cabezales, o desincronizar los cabezales momentáneamente para llevar a cabo la acción deseada."@es .

ns1:Aviso_2005_CompensacionRadioLineal a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2005: El último bloque de compensación de radio debe ser lineal"@es ;
    ns1:identificador "2005" ;
    ns1:mitigaRiesgo ns1:Fallo_CompensacionRadio_G40 ;
    ns1:textoExtracto "2005 'El último bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución."@es .

ns1:Aviso_EmergenciaSETTMEM a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia SETTMEM activada por PLC"@es ;
    ns1:textoExtracto "Si el PLC ha activado la marca SETTMEM, corregir la causa por la que el PLC ha puesto la señal de emergencia."@es .

ns1:Aviso_ProgramacionPotenciaObjetivo a ns1:AvisoSeguridad ;
