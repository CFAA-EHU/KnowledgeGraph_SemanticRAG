    ns1:textoExtracto "6025 'Error de checksum en la COMPCI' DETECCIÓN Durante la ejecución. CAUSA Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es .

ns1:ErrorChecksumHiperface_4662 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum Hiperface"@es ;
    ns1:identificador "4662" ;
    ns1:textoExtracto "4662 Error de checksum Hiperface."@es .

ns1:ErrorCompensacionVolumetrica_23028 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ns1:identificador "23028" ;
    ns1:monitoreaParametro ns1:UnidadesDelFicheroDeVolumetria ;
    ns1:textoExtracto "23028 Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no..."@es .

ns1:ErrorComunicacionHiperface_4661 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicaciones con driver Hiperface"@es ;
    ns1:identificador "4661" ;
    ns1:solucionaFallo ns1:FagorAutomation ;
    ns1:textoExtracto "4661 Error de comunicaciones con driver Hiperface. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:ErrorConfiguracionEjes_43 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de validación: eje no asociado en lista de sistema"@es ;
    ns1:solucionaFallo ns1:ArranqueConConfiguracionDeUsuario,
        ns1:CorreccionDeParametrosMaquina ;
    ns1:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal. Por ejemplo, un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema."@es .

ns1:ErrorDeBusEnElDispositivoU a ns1:DiagnosticoFallo ;
    rdfs:label "Error de bus en el dispositivo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24618" ;
    ns1:textoExtracto "24618 Error de bus en el dispositivo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ErrorDeCargaDeSoftwareRIOR a ns1:Alarma ;
    rdfs:label "Error de carga de software RIOR" ;
    ns1:identificador "8050" ;
    ns1:textoExtracto "Error cargando software de RIOR. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga del software de los nodos RIOR. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ErrorDeComunicacionDeDatosDeESEnElModuloU a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación de datos de E/S en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24616" ;
    ns1:textoExtracto "24616 Error de comunicación de datos de E/S en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ErrorDeComunicacionDeDatosDeGestionEnElModuloU a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación de datos de gestión en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24617" ;
    ns1:textoExtracto "24617 Error de comunicación de datos de gestión en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ErrorDeComunicacionEnCaptacionCRCIncorrecto_007e73f933 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación (CRC incorrecto)"@es ;
    ns1:identificador "9629" ;
    ns1:textoExtracto "9629 Error de comunicación en captación. CRC incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Pérdida de la configuración del encóder o de la cabeza de la regla. El CRC de la regla absoluta FAGOR conectada no ha sido identificado por el regulador. SOLUCIÓN Las posibles soluciones son las siguientes: • Compruebe el cable y el conexionado con el captador. • Verifique la correcta parametrización del captador. • Si todo es correcto y sigue produciéndose el error, reemplazar el encóder o la cabeza de la regla."@es .

ns1:ErrorDeComunicacionEnCaptacionNoAcknowledge a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9630: Error de comunicación en captación"@es,
        "Error de comunicación en captación (No acknowledge)"@es ;
    ns1:identificador "9630" ;
    ns1:solucionaFallo ns1:ComprobacionDeCableYConexionadoConElCaptadorError9630 ;
    ns1:textoExtracto "9630 Error de comunicación en captación. No se recibió acknowledge."@es .

ns1:ErrorDeConfiguracionEnElModuloU a ns1:DiagnosticoFallo ;
    rdfs:label "Error de configuración en el módulo %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24619" ;
    ns1:textoExtracto "24619 Error de configuración en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ErrorDeHardwareEnElModuloU a ns1:DiagnosticoFallo ;
    rdfs:label "Error de hardware en el módulo %u"@es ;
