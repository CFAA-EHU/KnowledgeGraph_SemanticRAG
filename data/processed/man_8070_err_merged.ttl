    ns1:textoExtracto "1710 'TALADRADO 2: F = 0' [...] CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1711_Taladrado2 a ns1:AvisoSeguridad ;
