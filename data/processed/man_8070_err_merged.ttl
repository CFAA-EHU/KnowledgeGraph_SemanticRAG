    ns1:solucionaFallo ns1:Alimentacion_24V_15V ;
    ns1:textoExtracto "9641 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado alto. [...] Fallo en la alimentación del módulo." .

ns1:Error_9642 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9642: Captación digital Fagor - Error en pista absoluta" ;
    ns1:identificador "9642" ;
    ns1:textoExtracto "9642 Captación digital Fagor. Error en la pista absoluta. [...] Pérdida de contaje. La señal analógica < 0,20 Vpp." .

ns1:Error_9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parámetros en captación digital Fagor" ;
    ns1:identificador "9647" ;
    ns1:solucionaFallo ns1:CabezaRegla_CaptacionDigital_Fagor,
        ns1:Encoder_CaptacionDigital_Fagor ;
    ns1:textoExtracto "9647 Captación digital Fagor. Error de parámetros en captación. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Pérdida de la configuración del encóder o de la cabeza de la regla. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla." .

ns1:Error_9648 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la alimentación de las salidas analógicas" ;
    ns1:identificador "9648" ;
    ns1:textoExtracto "9648 Error en la alimentación de las salidas analógicas. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en la alimentación de las salidas analógicas del CNC. SOLUCIÓN Revisar el conexionado de salida analógica." .

ns1:Error_9649 a ns1:DiagnosticoFallo ;
    rdfs:label "Caída del bus de potencia en presencia de par" ;
    ns1:identificador "9649" ;
    ns1:textoExtracto "9649 Caída del bus de potencia en presencia de par. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Posible caída en alguna de las líneas trifásicas o fallo en algún regulador. SOLUCIÓN Comprobar que el estado de la líneas, los reguladores y revisar maniobra de potencia." .

ns1:Error_9650 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Señal analógica por debajo de 0,4 Vpp" ;
    ns1:identificador "9650" ;
    ns1:textoExtracto "9650 Captación digital Fagor: Señal analógica por debajo de 0,4 Vpp. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente. SOLUCIÓN Revisar los cables y la conexión de las entradas de captación." .

ns1:Error_9651 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Alimentación del encoder fuera de valores deseables" ;
    ns1:identificador "9651" ;
    ns1:solucionaFallo ns1:Encoder_CaptacionDigital_Fagor ;
    ns1:textoExtracto "9651 Captación digital Fagor: Alimentación del encoder fuera de valores deseables. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." .

ns1:Error_9652 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Velocidad excesiva en el eje",
        "Captación digital Fagor: Velocidad excesiva en el eje"@es ;
    ns1:identificador "9652" ;
