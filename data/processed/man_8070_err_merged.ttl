    ns1:identificador "3039" ;
    ns1:textoExtracto "3039 'No se ha encontrado bloque de parada en búsqueda de bloque' [...] SOLUCIÓN Cambiar el bloque de parada." .

ns1:Error3040 a ns1:AvisoSeguridad ;
