    ns1:identificador "1738" ;
    ns1:textoExtracto "1738 'CAJERA RECTANGULAR: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Error23013 a ns1:DiagnosticoFallo ;
