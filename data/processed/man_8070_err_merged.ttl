ns1:Error9340InconsistenciaEnCOUNTERIDSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9340: Inconsistencia en COUNTERID (Sercos)" ;
    ns1:solucionaFallo ns1:COUNTERIDSercos ;
