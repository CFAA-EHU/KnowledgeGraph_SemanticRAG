    ns1:textoExtracto "2143 'No se puede calcular la tangente al spline' DETECCIÓN Durante la ejecución. CAUSA No se puede calcular la tangente para deseleccionar el spline. SOLUCIÓN Deseleccionar el spline en otro punto o programar otra tangente." .

ns1:Error2144ErrorEnLaGeneracionDelSpline a ns1:AvisoSeguridad ;
    rdfs:label "Error 2144: Error en la generación del spline" ;
    ns1:identificador "2144" ;
    ns1:textoExtracto "2144 'Error en la generación del spline' DETECCIÓN Durante la ejecución. CAUSA No se ha programado el primer bloque para activar el spline. SOLUCIÓN Programar un movimiento antes de activar el spline." .

ns1:Error2145FinalDelProgramaSinDesactivarSplines a ns1:AvisoSeguridad ;
