    rdfs:label "Error en la transformación de RTCP"@es ;
    ns1:identificador "2129" ;
    ns1:textoExtracto "2129 'Error en la transformación de RTCP' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una transformación RTCP y no están en el canal todos los ejes necesarios. SOLUCIÓN Antes de activar la transformación RTCP, configurar el canal con los ejes necesarios."@es .

ns1:ErrorGenericoDeNodoEtherCAT a ns1:AvisoSeguridad ;
    rdfs:label "Error genérico de nodo EtherCAT" ;
    ns1:identificador "24651" ;
    ns1:textoExtracto "%u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:ErrorGenericoEtherCAT a ns1:AvisoSeguridad ;
    rdfs:label "Emergencia de nodo EtherCAT" ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:ErrorRecuperacionFRAM_8128 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8128: Fallo en recuperación de datos FRAM"@es ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "No se han podido recuperar los datos de FRAM. [...] Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM."@es .

