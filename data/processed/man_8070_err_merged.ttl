    ns1:textoExtracto "Revisar los niveles de la señal Vpp en la captación local del CNC."@es .

ns1:Diagnostico_9336 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de incompatibilidad de parámetros 9336" ;
    ns1:solucionaFallo ns1:Error_9336 ;
    ns1:textoExtracto "CAUSA: Hay activas dos prestaciones que son incompatibles entre sí. SOLUCIÓN: Anular uno de los dos."@es .

ns1:Diagnostico_BrazoCambiadorOcupado_1 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Brazo cambiador 2 ocupado"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:solucionaFallo ns1:Herramienta_CNC ;
    ns1:textoExtracto "' No se puede poner una herramienta en el cabezal si ya hay una en el brazo 2' [...] SOLUCIÓN Quitar la herramienta del brazo cambiador 2."@es .

ns1:Diagnostico_BrazoCambiadorOcupado_2 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Herramienta en brazo cambiador 1"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:solucionaFallo ns1:Herramienta_CNC ;
    ns1:textoExtracto "' No se puede poner en el cabezal la herramienta del brazo cambiador' [...] SOLUCIÓN Quitar la herramienta del brazo cambiador 1."@es .

ns1:Diagnostico_CCD a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para errores de captador CCD (E196-E496)"@es ;
    ns1:solucionaFallo ns1:Error_E196,
        ns1:Error_E296,
        ns1:Error_E396,
        ns1:Error_E496 ;
    ns1:textoExtracto "Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:Diagnostico_EncoderDanado a ns1:DiagnosticoFallo ;
    rdfs:label "Reemplazo de encóder o cabeza de regla"@es ;
    ns1:solucionaFallo ns1:Error_E494,
