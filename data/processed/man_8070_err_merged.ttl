    rdfs:label "Fallo 1213: Conflicto con función G63 activa"@es ;
    ns1:identificador "1213" ;
    ns1:textoExtracto "#CALL AX/#SET AX: no se admite con G63 activa. DETECCIÓN Durante la ejecución. CAUSA No se permite programar #CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ns1:Fallo_1257 a ns1:DiagnosticoFallo ;
    rdfs:label "Doble programación del paso de husillo"@es ;
    ns1:identificador "1257" ;
    ns1:textoExtracto "1257 'Doble programación del paso de husillo' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca está programado más de una vez. SOLUCIÓN Revisar la programación. Definir el paso de la rosca una sola vez en el bloque."@es .

ns1:Fallo_1258 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de husillo igual cero"@es ;
    ns1:identificador "1258" ;
    ns1:textoExtracto "1258 'Paso de husillo igual cero' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca tiene valor"@es .

ns1:Fallo_1319 a ns1:DiagnosticoFallo ;
    rdfs:label "Anidamiento de sentencias #CS ON/#ACS ON sobrepasado"@es ;
    ns1:identificador "1319" ;
    ns1:textoExtracto "1319 'Anidamiento de sentencias #CS ON/#ACS ON sobrepasado' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1325 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1325: Número de bloque definido varias veces" ;
    ns1:identificador "1325" ;
    ns1:textoExtracto "1325 'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" está repetido en el programa. SOLUCIÓN No repetir el número de bloque." .

ns1:Fallo_1339 a ns1:DiagnosticoFallo ;
    rdfs:label "La selección no tiene efecto" ;
    ns1:identificador "1339" ;
    ns1:textoExtracto "1339 'La selección no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA La sentencia programada no tiene efecto porque ya está activa, la misma sentencia con los mismos parámetros está programada en un bloque anterior. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1375 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1375: 'Se espera M17/M29/#RET'" ;
    ns1:identificador "1375" ;
    ns1:textoExtracto "1375 'Se espera M17/M29/#RET' [...] CAUSA Falta programar M17, M29 o #RET al final de la subrutina." .

ns1:Fallo_1377 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1377: 'Escritura de parámetro con índice no válido'" ;
    ns1:identificador "1377" ;
    ns1:textoExtracto "1377 'Escritura de parámetro con índice no válido' [...] CAUSA El parámetro aritmético no existe o está protegido contra escritura." .

ns1:Fallo_1433 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede modificar la configuración de un eje aparcado"@es ;
    ns1:identificador "1433" ;
    ns1:textoExtracto "1433 No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1470 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota incremental inválida en eje UNIDIR"@es,
        "Eje rotativo UNIDIR con programación incremental incorrecta"@es ;
    ns1:identificador "1470" ;
    ns1:monitoreaParametro ns1:UNIDIR_97891635a6 ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota incremental programada para el eje rotativo unidireccional (parámetro UNIDIR) no es válida."@es .

ns1:Fallo_1478 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1478: Cajera con ángulo de entrada de herramienta incorrecto" ;
    ns1:identificador "1478" ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente ángulo de entrada de herramienta'" .

ns1:Fallo_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1479: G74 - Falta asociación de subrutina" ;
    ns1:identificador "1479" ;
    ns1:textoExtracto "'G74: falta asociar subrutina'" .

ns1:Fallo_1694 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota fuera de rango en G174",
        "Cota fuera de rango en G174"@es ;
    ns1:identificador "1694" ;
    ns1:monitoreaParametro ns1:ParametroG174Cota_fbfafb36b7 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La cota programada en G174 está fuera de rango. SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647."@es .

ns1:Fallo_1695 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SWTOUT"@es ;
    ns1:identificador "1695" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1696 a ns1:DiagnosticoFallo ;
    rdfs:label "Borrado de subrutina *.fst en ejecución"@es ;
    ns1:identificador "1696" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una subrutina fst mientras está en ejecución. SOLUCIÓN Esperar a que finaliza la ejecución del programa."@es .

ns1:Fallo_1697 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en #CSROT"@es ;
    ns1:identificador "1697" ;
    ns1:textoExtracto "SOLUCIÓN Programar #CSROT [ON]/OFF. DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1784 a ns1:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta menor que DELTA" ;
    ns1:identificador "1784" ;
    ns1:requiereConsumible ns1:HerramientaDeRanuradoDiametroAdecuado ;
    ns1:solucionaFallo ns1:ParametroPasoDeFresado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." .

ns1:Fallo_1846 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio del arco nulo",
        "Radio del arco nulo"@es ;
    ns1:identificador "1846" ;
    ns1:textoExtracto "1846 'Radio del arco nulo' DETECCIÓN Durante la ejecución de un ciclo de mecanizado"@es .

ns1:Fallo_1849 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera" ;
    ns1:identificador "1849" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El tamaño de la cajera menos el diámetro de la herramienta es menor que las demasías de acabado laterales (dos veces el parámetro δ). SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1985 a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador no ha tocado la esfera" ;
    ns1:identificador "1985" ;
    ns1:textoExtracto "1985 'El palpador no ha tocado la esfera' DETECCIÓN Durante la ejecución. CAUSA Al ejecutar el ciclo de calibración de cinemáticas, el palpador no ha tocado la esfera. SOLUCIÓN Revisar la programación. Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente." .

ns1:Fallo_1986 a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador ha tocado la esfera cuando no se esperaba" ;
    ns1:identificador "1986" ;
    ns1:textoExtracto "1986 'El palpador ha tocado la esfera cuando no se esperaba' DETECCIÓN Durante la ejecución. CAUSA Al ejecutar el ciclo de calibración de cinemáticas, el palpador ha tocado la esfera cuando no debía hacerlo. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1988 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Tipo de palpador no válido (P6)"@es ;
    ns1:identificador "1988" ;
    ns1:textoExtracto "1988 'El tipo de palpador no es valido (P6)' DETECCIÓN Durante la ejecución. CAUSA El tipo de palpador seleccionado no es válido. SOLUCIÓN El parámetro P6 sólo admite valores 0 y 1."@es .

ns1:Fallo_1990 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Falta contacto con esfera de palpado"@es ;
    ns1:identificador "1990" ;
    ns1:textoExtracto "No ha llegado señal de palpado cuando se esperaba tocar la esfera. SOLUCIÓN Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es .

ns1:Fallo_1993 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Posición de reposo de ejes rotativos no es cero"@es ;
    ns1:identificador "1993" ;
    ns1:textoExtracto "1993 'La posición de reposo de los ejes rotativos de la cinemática tiene que ser cero' DETECCIÓN Durante la ejecución. CAUSA En los parámetros máquina de la cinemática la posición de reposo de los ejes tiene que ser 0. SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina."@es .

ns1:Fallo_1994 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Posición de ejes rotativos manuales no es cero"@es ;
    ns1:identificador "1994" ;
    ns1:textoExtracto "1994 La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es .

ns1:Fallo_2000 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta mayor que radio del arco"@es ;
    ns1:identificador "2000" ;
    ns1:textoExtracto "'Radio de herramienta mayor que radio del arco' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es mayor que el radio del arco que se intenta mecanizar. SOLUCIÓN Usar una herramienta de menor radio."@es .

ns1:Fallo_20008 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera superada en condición #WAIT FOR"@es ;
    ns1:identificador "20008" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El canal debe quedar libre cuando finaliza la ejecución. 20008 Esperando condición #WAIT FOR."@es .

ns1:Fallo_2001 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil dañado por compensación de radio"@es ;
    ns1:identificador "2001" ;
    ns1:textoExtracto "'Perfil dañado por compensación de radio' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el perfil programado; la herramienta daña el perfil. SOLUCIÓN Usar una herramienta de menor radio."@es .

ns1:Fallo_20015 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20015: G33/G34/G95 con cabezal parado"@es ;
    ns1:identificador "20015" ;
    ns1:textoExtracto "20015 G33/G34/G95 con cabezal %x parado. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal debe ponerse en marcha para ejecutar G33/G34/G95."@es .

ns1:Fallo_20016 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20016: Esperando finalizar petición de ejes"@es ;
    ns1:identificador "20016" ;
    ns1:textoExtracto "20016 Esperando finalizar petición de ejes. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El eje solicitado debe llegar al canal o ser liberado por otro."@es .

ns1:Fallo_20017 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20017: Esperando finalizar petición de cabezal"@es ;
    ns1:identificador "20017" ;
    ns1:textoExtracto "20017 Esperando finalizar petición de cabezal. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal solicitado debe llegar al canal o ser liberado por otro."@es .

ns1:Fallo_20018 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20018: Esperando finalizar forzar cota (G174)"@es ;
    ns1:identificador "20018" ;
    ns1:textoExtracto "20018 Esperando finalizar forzar cota (G174) del eje %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. La función G174 debe finalizar."@es .

ns1:Fallo_20019 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20019: Esperando señal XFERINH del PLC"@es ;
    ns1:identificador "20019" ;
    ns1:textoExtracto "20019 Esperando señal XFERINH del PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe activar la señal _XFERINH."@es .

ns1:Fallo_2002 a ns1:DiagnosticoFallo ;
    rdfs:label "Primer bloque de compensación de radio debe ser lineal"@es ;
    ns1:identificador "2002" ;
    ns1:textoExtracto "'El primer bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA Después de activar la compensación de radio (G41 o G42), el siguiente bloque de movimiento es un bloque circular. La compensación de radio no puede comenzar en un bloque circular. SOLUCIÓN La compensación de radio debe empezar en un bloque de movimiento lineal."@es .

ns1:Fallo_20020 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera de ejes en posición superada",
        "Fallo 20020: Esperando ejes en posición"@es ;
    ns1:identificador "20020" ;
    ns1:solucionaFallo ns1:PulsarRESETSinAnalisisPrevio ;
    ns1:textoExtracto "20020 Esperando ejes en posición. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:Fallo_20027 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera excedida en lazo abierto del cabezal"@es ;
    ns1:identificador "20027" ;
    ns1:textoExtracto "Esperando pasar a lazo abierto el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:Fallo_2003 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta demasiado grande en arcos consecutivos"@es ;
    ns1:identificador "2003" ;
    ns1:textoExtracto "'Radio de herramienta demasiado grande en arcos consecutivos' DETECCIÓN Durante la ejecución. CAUSA En el mecanizado de dos arcos consecutivos que forman un bucle (ambos arco se cortan), el radio de la herramienta es demasiado grande para poder mecanizar el interior del bucle. SOLUCIÓN Usar una herramienta de menor radio."@es .

ns1:Fallo_2005 a ns1:DiagnosticoFallo ;
    rdfs:label "Último bloque de compensación de radio debe ser lineal"@es ;
    ns1:identificador "2005" ;
    ns1:textoExtracto "'El último bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución. CAUSA Después de desactivar la compensación de radio (G40), el siguiente bloque de movimiento es un bloque circular. La compensación de radio no puede acabar en un bloque circular."@es .

ns1:Fallo_2303 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de cinemática con función #CSROT"@es ;
    ns1:identificador "2303" ;
    ns1:solucionaFallo ns1:ParametroDEFROTAngulo_5d69af661f ;
    ns1:textoExtracto "La función CSROT solo es aplicable a cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa. [...] CAUSA El tipo de cinemática no es compatible con la función #CSROT."@es .

ns1:Fallo_2309 a ns1:AccionProhibida ;
    rdfs:label "#VIRTAX: Programación no permitida con el eje virtual de la herramienta activo"@es ;
    ns1:identificador "2309" ;
    ns1:mitigaRiesgo ns1:EjeVirtualDeLaHerramientaVIRTAX ;
    ns1:textoExtracto "Programación no permitida con el eje virtual de la herramienta activo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una de las siguientes funciones mientras la transformación del eje virtual de la herramienta está activa. • Búsqueda de cero; G74. • Modificar los límites de software; G198 - G199. • Sentencia #OSC."@es .

ns1:Fallo_2312 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2312: Cinemática no definida en tabla NKIN" ;
    ns1:identificador "2312" ;
    ns1:solucionaFallo ns1:Tabla_Cinematicas ;
    ns1:textoExtracto "2312 '#KIN ID[]:Programar valores comprendidos entre 0 y el parámetro máquina NKIN' [...] SOLUCIÓN Revisar programación." .

ns1:Fallo_2356 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación #SELECT" ;
    ns1:identificador "2356" ;
    ns1:textoExtracto "'Programar #SELECT ORI [HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]' [...] CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ns1:Fallo_2357 a ns1:DiagnosticoFallo ;
    rdfs:label "Selección incorrecta de ejes rotativos" ;
    ns1:identificador "2357" ;
    ns1:textoExtracto "'Ejes rotativos seleccionados iguales o incorrectos' [...] Los valores posibles para seleccionar los ejes rotativos son HEAD1, HEAD2, TABLE1, TABLE2." .

ns1:Fallo_2358 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje no lineal en #DGWZ CYL" ;
    ns1:identificador "2358" ;
    ns1:textoExtracto "'#DGWZ CYL: El eje programado debe ser un eje lineal' [...] SOLUCIÓN Seleccionar como eje longitudinal un eje lineal." .

ns1:Fallo_2359 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje fuera de plano/triedro en #DGWZ CYL" ;
    ns1:identificador "2359" ;
    ns1:textoExtracto "'#DGWZ CYL: El eje programado debe pertenecer al plano o triedro' [...] SOLUCIÓN Seleccionar como eje longitudinal un eje del plano o del triedro." .

ns1:Fallo_2360 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de ejes no permitida" ;
    ns1:identificador "2360" ;
    ns1:textoExtracto "'La función o sentencia no permite programación de ejes' [...] SOLUCIÓN Revisar la programación." .

ns1:Fallo_2361 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje de rotación en DGWZ/DGWZ RECT no permitido" ;
    ns1:identificador "2361" ;
    ns1:textoExtracto "'#DGWZ <RECT>: No se permite programar eje de rotación.' [...] SOLUCIÓN Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT." .

ns1:Fallo_2362 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje de rotación no programado en DGWZ CYL",
        "Falta eje de rotación en DGWZ CYL" ;
    ns1:identificador "2362" ;
    ns1:textoExtracto "Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT. 2362 #DGWZ CYL: Eje de rotación no programado. DETECCIÓN Durante la ejecución. CAUSA En DGWZ CYL es obligatorio programar un eje de rotación y no se ha programado. SOLUCIÓN Programar eje de rotación para DGWZ CYL." .

ns1:Fallo_2442 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8754" ;
    ns1:identificador "2442" ;
    ns1:textoExtracto "Programación no permitida fuera de una macro G8754. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8753 programada fuera de una macro G8754." .

ns1:Fallo_3007 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha recibido señal del palpador antes del movimiento"@es ;
    ns1:identificador "3007" ;
    ns1:solucionaFallo ns1:ContactarConProveedorParaConfiguracionDePalpado ;
    ns1:textoExtracto "proceso de palpado. [...] 3007 'Se ha recibido señal del palpador antes del movimiento' DETECCIÓN Tras detectar la señal de palpador. CAUSA Proceso de palpado habilitado sin G100 programada. SOLUCIÓN Póngase en contacto con su proveedor."@es .

ns1:Fallo_3008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el proceso de palpador"@es ;
    ns1:identificador "3008" ;
    ns1:solucionaFallo ns1:VerificacionDeEjesProgramadosEnPalpado ;
    ns1:textoExtracto "3008 'Error en el proceso de palpador' DETECCIÓN Tras detectar la señal de palpador. CAUSA Es una seguridad de habilitación del proceso de palpado. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados."@es .

ns1:Fallo_3009 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha recibido señal del palpador"@es ;
    ns1:identificador "3009" ;
    ns1:solucionaFallo ns1:RevisionDeParametrizacionYSenalesFisicasDelPalpador ;
    ns1:textoExtracto "3009 No se ha recibido señal del palpador. DETECCIÓN Durante la ejecución. CAUSA No ha llegado la señal del palpador tras un movimiento de palpado. SOLUCIÓN Revisar la parametrización del palpador y señales físicas."@es .

ns1:Fallo_3063 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización pasa a lazo cerrado" ;
    ns1:identificador "3063" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una sincronización en lazo cerrado (CLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo abierto. SOLUCIÓN El CNC informa del cambio; no es necesaria ninguna acción." .

ns1:Fallo_3064 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal para roscar con G33/G34 debe de estar referenciado" ;
    ns1:identificador "3064" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado en el roscado G33/G34 no está referenciado. SOLUCIÓN Si el CNC utiliza el cabezal master del canal, siempre realiza una búsqueda de referencia antes de G33/G34." .

ns1:Fallo_3408 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota programada para eje independiente inferior al límite negativo"@es ;
    ns1:identificador "3408" ;
    ns1:textoExtracto "3408 'Cota programada para eje independiente inferior al límite negativo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los límites de software."@es .

ns1:Fallo_3604 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentido del posicionamiento de cabezal contrario al de parámetro máquina"@es ;
    ns1:identificador "3604" ;
    ns1:solucionaFallo ns1:MODLOWLIM_5a256ee4b3,
        ns1:MODUPLIM_bc11789e7d,
