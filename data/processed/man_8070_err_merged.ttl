    ns1:monitoreaParametro ns1:ParametroInstruccionENDSWITCH_2766596d53 ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma1126VariableContadorFORNoValida_809c96d754 a ns1:Alarma ;
    rdfs:label "Alarma 1126: Variable contador $FOR no válida"@es ;
    ns1:identificador "1126" ;
    ns1:monitoreaParametro ns1:ParametroVariableContadorFOR_92c6572be4 ;
    ns1:textoExtracto "'$FOR: variable contador no válida' DETECCIÓN Durante la ejecución. CAUSA El contador de la instrucción $FOR no es válido. SOLUCIÓN El contador de la instrucción $FOR podrá ser una variable o parámetro aritmético."@es .

ns1:Alarma1127SentenciaFORCondicionNoProgramadaSolaEnBloque_615e294081 a ns1:Alarma ;
    rdfs:label "Alarma 1127: Sentencia $FOR <condición> no programada sola en bloque"@es ;
