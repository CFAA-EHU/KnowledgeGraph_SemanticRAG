    ns1:textoExtracto "9640 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado bajo. [...] Fallo en la alimentación del módulo." .

ns1:Error_9641 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9641: INDUCTOSYN - Nivel de tensión 24 Vdc/15 Vdc alto" ;
