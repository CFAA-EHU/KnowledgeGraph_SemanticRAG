ns1:TablaPuntosError4000 a ns1:Tabla ;
    rdfs:label "Tabla de puntos de error en inicialización Sercos"@es ;
    ns1:documentadoEn ns1:Error4000_3 ;
    ns1:textoExtracto """\r
| Punto. | Significado. |\r
| --- | --- |\r
| 0 | Timeout. |\r
| 1 | Error en cambio a Fase 0. (Problema en la fibra óptica) |\r
| 2 | Error en cambio a Fase 1. (Un regulador no responde; fallo de hardware o selector de nodo mal puesto) |\r
| 3 | Error en cambio a Fase 2. |\r
| 4 | Error en lectura de la versión del fabricante. |\r
| 5 | Error en lectura de T1mim. |\r
