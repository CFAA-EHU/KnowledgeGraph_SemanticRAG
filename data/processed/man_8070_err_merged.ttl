    rdfs:label "Alarma 2487: Cinemática no válida para #FACE/#CYL"@es ;
    ns1:identificador "2487" ;
    ns1:mitigaRiesgo ns1:UsoDeCinematicaNoValidaEnFACECYL ;
    ns1:textoExtracto "El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado. SOLUCIÓN Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43."@es .

ns1:Alarma2501MovimientoDeEjeLinealRotativoNoPermitidoConRTCPSTATIC_23bfca97aa a ns1:Alarma ;
    rdfs:label "Alarma 2501: Movimiento de eje lineal/rotativo no permitido con RTCP STATIC"@es ;
    ns1:activaAlarma ns1:EjeLinealDeLaCinematica,
        ns1:EjeRotativoDeLaCinematica ;
    ns1:identificador "2501" ;
    ns1:textoExtracto "CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente."@es .

ns1:Alarma2502MovimientoDeEjeRotativoNoPermitidoEnInspeccionConRTCPSTATIC_bf20a5adfa a ns1:Alarma ;
    rdfs:label "Alarma 2502: Movimiento de eje rotativo no permitido en inspección con RTCP STATIC"@es ;
    ns1:activaAlarma ns1:EjeRotativoDeLaCinematica ;
    ns1:identificador "2502" ;
    ns1:mitigaRiesgo ns1:HerramientaDeInspeccion_53b9e58ffe ;
    ns1:textoExtracto "CAUSA Durante la inspección de herramienta, se ha intentado mover un eje rotativo de la cinemática RTCP STATIC activo. SOLUCIÓN Desactivar la funcionalidad de RTCP STATIC para poder mover el eje rotativo."@es .

ns1:Alarma2503RadioProgramadoIncorrectamenteEnG36373839_a05064526c a ns1:Alarma ;
    rdfs:label "Alarma 2503: Radio programado incorrectamente en G36/37/38/39"@es ;
    ns1:activaAlarma ns1:ParametroDeRadioParaG36G37G38G39_9f90cc5cf2 ;
    ns1:identificador "2503" ;
    ns1:textoExtracto "CAUSA Se ha programado incorrectamente el radio del redondeo (G36), chaflán (G39) o entrada/salida tangencial (G37/G38). SOLUCIÓN Revisar la programación. Programar el radio o chaflán con el comando \"I\"."@es .

ns1:Alarma3403NoSeAdmitenMasOperacionesConEjesIndependientesEnSincronizacion_d7c6fc8c31 a ns1:Alarma ;
    rdfs:label "Alarma 3403: No se admiten más operaciones con ejes independientes. En sincronización"@es ;
    ns1:identificador "3403" ;
    ns1:mitigaRiesgo ns1:ProgramarOperacionesDeEjeIndependienteConLevasActivasOSincronizacionesSeguidas ;
    ns1:textoExtracto "3403 'No se admiten mas operaciones con ejes independientes. En sincronización' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente pero existe una sincronización activa. SOLUCIÓN No programar operaciones de eje independiente con levas activas ni programar dos sincronizaciones seguidas. Desde el PLC abortar las sentencias pendientes (marca ABORT) o bien esperar a que finalice la sincronización."@es .

ns1:Alarma3404NoSeAdmiteFOLLOWOFFConOtraOperacionPendiente_760a3bba7c a ns1:Alarma ;
    rdfs:label "Alarma 3404: No se admite #FOLLOW OFF con otra operación pendiente"@es ;
    ns1:identificador "3404" ;
    ns1:mitigaRiesgo ns1:EjecutarFOLLOWOFFConOperacionesPendientes ;
    ns1:textoExtracto "3404 'No se admite #FOLLOW OFF con otra operación pendiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una sentencia #FOLLOW OFF pero existe una operación pendiente. SOLUCIÓN Desde el PLC abortar las sentencias pendientes (marca ABORT) o bien esperar a que haya espacio para almacenarla (marca FREE)."@es .

ns1:Alarma3405NoSeAdmiteMOVEINFParaUnEjeConLimites_31a2fbe638 a ns1:Alarma ;
    rdfs:label "Alarma 3405: No se admite #MOVE INF para un eje con límites"@es ;
    ns1:identificador "3405" ;
    ns1:mitigaRiesgo ns1:EjecutarMOVEINFEnEjesConLimitesDeSoftware ;
    ns1:textoExtracto "3405 'No se admite #MOVE INF para un eje con límites' DETECCIÓN Durante la ejecución. CAUSA El eje programado en la sentencia #MOVE INF tiene límites de recorrido definidos. SOLUCIÓN Eliminar los límites de software o interrumpir el movimiento antes de que el eje alcance el límite."@es .

ns1:Alarma3406LaVelocidadNecesariaParaSincronizarEsSuperiorALaMaxima_fd7cbafb73 a ns1:Alarma ;
    rdfs:label "Alarma 3406: La velocidad necesaria para sincronizar es superior a la máxima"@es ;
    ns1:identificador "3406" ;
    ns1:mitigaRiesgo ns1:SincronizarConVelocidadSuperiorAlAvanceMaximoDelEje ;
    ns1:textoExtracto "3406 'La velocidad necesaria para sincronizar es superior a la máxima' DETECCIÓN Durante la ejecución. CAUSA La sincronización programada implica superar el avance máximo del eje. SOLUCIÓN Programar la sincronización con el eje maestro moviéndose a un avance menor o programar un ratio de sincronización menor."@es .

ns1:Alarma3407CotaProgramadaParaEjeIndependienteSuperiorAlLimitePositivo_83c5f77d15 a ns1:Alarma ;
    rdfs:label "Alarma 3407: Cota programada para eje independiente superior al límite positivo"@es ;
    ns1:identificador "3407" ;
    ns1:mitigaRiesgo ns1:ProgramarCotasFueraDeLimitesDeSoftwareParaEjesIndependientes ;
    ns1:textoExtracto "3407 'Cota programada para eje independiente superior al límite positivo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los límites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:Alarma3408CotaProgramadaParaEjeIndependienteInferiorAlLimiteNegativo_b6df360d86 a ns1:Alarma ;
    rdfs:label "Alarma 3408: Cota programada para eje independiente inferior al límite negativo"@es ;
    ns1:identificador "3408" ;
    ns1:mitigaRiesgo ns1:ProgramarCotasInferioresAlLimiteNegativoParaEjesIndependientes ;
    ns1:textoExtracto "3408 'Cota programada para eje independiente inferior al límite negativo' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma3600VelocidadDeCabezalNula_9d52673274 a ns1:Alarma ;
    rdfs:label "Alarma 3600: Velocidad de cabezal nula" ;
    ns1:identificador "3600" ;
    ns1:textoExtracto "3600 'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA No existe una velocidad de posicionamiento de cabezal programada. SOLUCIÓN Revisar la programación y que los parámetros REFFEED2 y G00FEED de la gama activa del cabezal sean distintos de cero." .

ns1:Alarma3601VelocidadDeCabezalProgramadaSuperiorAlLimiteMaximo_c5078cda17 a ns1:Alarma ;
    rdfs:label "Alarma 3601: Velocidad de cabezal programada superior al límite máximo" ;
    ns1:identificador "3601" ;
    ns1:textoExtracto "3601 'Velocidad de cabezal programada superior al límite máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad programada para el cabezal supera la velocidad máxima definida en los parámetros máquina para la gama activa. SOLUCIÓN Revisar el parámetro G00FEED del cabezal." .

ns1:Alarma3602NoSePuedeMoverElCabezalEnModoVisualizador_519e989888 a ns1:Alarma ;
    rdfs:label "Alarma 3602: No se puede mover el cabezal en modo visualizador" ;
    ns1:identificador "3602" ;
    ns1:textoExtracto "3602 'No se puede mover el cabezal en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta controlar un cabezal que se encuentra en modo visualizador. SOLUCIÓN El CNC no puede controlar los cabezales activos en modo visualizador. Para desplazar el eje, desactivar el modo visualizador (marca DRO(axis) del PLC) y comprobar el estado de la marca SERVOON del cabezal." .

ns1:Alarma3603LaPosicionDelCabezalComandadaExcedeElRangoDeModulo_8c21cbdbc4 a ns1:Alarma ;
    rdfs:label "Alarma 3603: La posición del cabezal comandada excede el rango de módulo" ;
    ns1:identificador "3603" ;
    ns1:textoExtracto "3603 'La posición del cabezal comandada excede el rango de módulo' DETECCIÓN Durante la ejecución. CAUSA El CNC está intentando posicionar el cabezal en una cota que está fuera del rango permitido (parámetros MODUPLIM y MODLOWLIM). SOLUCIÓN Revisar los parámetros MODUPLIM y MODLOWLIM." .

ns1:Alarma3604SentidoDelPosicionamientoDeCabezalContrarioAlDeParametroMaquina_5f0b5c43bf a ns1:Alarma ;
    rdfs:label "Alarma 3604: Sentido del posicionamiento de cabezal contrario al de parámetro máquina" ;
    ns1:identificador "3604" ;
    ns1:textoExtracto "3604 'Sentido del posicionamiento de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución." .

ns1:Alarma3723NoSeAdmiteG174ParaEjeEnModoVisualizador_f6049081e8 a ns1:Alarma ;
    rdfs:label "Alarma 3723: No se admite G174 para eje en modo visualizador"@es ;
    ns1:identificador "3723" ;
    ns1:textoExtracto "3723 'No se admite G174 para eje en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca DRO). SOLUCIÓN Revisar la programación. Para forzar la cota de un eje (G174), éste no puede estar en modo visualizador; es decir, hay que desactivar su marca DRO(axis) y activar su marca SERVO(axis)ON."@es .

ns1:Alarma3724NoSePermiteG174SiElEjeNoEstaEnPosicion_beefe72319 a ns1:Alarma ;
    rdfs:label "Alarma 3724: No se permite G174 si el eje no está en posición"@es ;
    ns1:identificador "3724" ;
    ns1:textoExtracto "3724 'No se permite G174 si el eje no está en posición' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que no está en posición. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje esté en posición; es decir, que no esté en movimiento y que tenga su marca INPOS(axis) activa."@es .

ns1:Alarma3725NoSePermiteG174ParaUnEjeQueEstaSincronizado_51a9be8285 a ns1:Alarma ;
    rdfs:label "Alarma 3725: No se permite G174 para un eje que está sincronizado"@es ;
    ns1:identificador "3725" ;
    ns1:textoExtracto "3725 'No se permite G174 para un eje que está sincronizado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está sincronizado. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje no esté sincronizado con otro. Desincronizar eje antes de forzar cota o comprobar en el programa de PLC la lógica de la marca INSYNC del eje."@es .

ns1:Alarma3726FaltaDriveStatusReadyDRSTAFDRSTASDelEjeEsclavoDelTandem_2201ed9895 a ns1:Alarma ;
    rdfs:label "Alarma 3726: Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem"@es ;
    ns1:identificador "3726" ;
    ns1:textoExtracto "3726 'Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem' DETECCIÓN Al iniciar el movimiento de un eje tandem. CAUSA El CNC ha intentado mover el eje maestro del tandem sin esperar a que el eje esclavo esté habilitado. SOLUCIÓN En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados."@es .

ns1:Alarma3727NoSePermiteDesactivarUnEjeMultipleSinEntrarEnPosicion_55190cc2ad a ns1:Alarma ;
    rdfs:label "Alarma 3727: No se permite desactivar un eje múltiple sin entrar en posición"@es ;
    ns1:identificador "3727" ;
    ns1:textoExtracto "3727 'No se permite desactivar un eje múltiple sin entrar en posición' DETECCIÓN Al desactivar la marca SWITCH del eje."@es .

ns1:Alarma6058NodoCANopenNoOperacional_05c925a3fb a ns1:Alarma ;
    rdfs:label "Alarma 6058: Nodo CANopen no operacional" ;
    ns1:identificador "6058" ;
    ns1:solucionaFallo ns1:FalloEnNodosCANopenTrasReset ;
    ns1:textoExtracto "Algún nodo CANopen no se encuentra en fase operacional. DETECCIÓN Tras un reset del CNC. CAUSA En la reinicialización de CANopen que se hace durante el reset de CNC, alguno de los nodos no ha conseguido llegar a fase operacional." .

ns1:Alarma6059ErrorEnConfiguracionDeEntradaAnalogica_ba353c41ff a ns1:Alarma ;
    rdfs:label "Alarma 6059: Error en configuración de entrada analógica" ;
    ns1:identificador "6059" ;
    ns1:solucionaFallo ns1:ErrorDeParametrizacionEnEntradasAnalogicas ;
    ns1:textoExtracto "Error en la configuración de una entrada analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen, no se ha conseguido configurar correctamente alguna de las entradas parametrizadas en corriente." .

ns1:Alarma6060ErrorEnConfiguracionDeSalidaAnalogica_121d6f4d86 a ns1:Alarma ;
    rdfs:label "Alarma 6060: Error en configuración de salida analógica" ;
    ns1:identificador "6060" ;
    ns1:solucionaFallo ns1:ErrorDeParametrizacionEnSalidasAnalogicas ;
    ns1:textoExtracto "Error en la configuración de una salida analógica. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA En la inicialización del bus CANopen no se ha conseguido configurar correctamente alguna de las salidas parametrizadas en corriente." .

ns1:Alarma6061NodosCANopenNoFagorSinLicencia_d840c79723 a ns1:Alarma ;
    rdfs:label "Alarma 6061: Nodos CANopen no Fagor sin licencia" ;
    ns1:identificador "6061" ;
    ns1:solucionaFallo ns1:NodosNoFagorEnBusCANopen ;
    ns1:textoExtracto "Nodos CANopen no Fagor. Opción de software no permitida. DETECCIÓN En la inicialización del bus CANopen, durante el arranque del CNC o tras un reset. CAUSA Durante la inicialización del bus CANopen, se han detectado nodos de terceros sin disponer de la correspondiente opción de software." .

ns1:Alarma6062ReleDeEmergenciaAbiertoPorErrorDeBus_d662f2693c a ns1:Alarma ;
    rdfs:label "Alarma 6062: Relé de emergencia abierto por error de bus" ;
    ns1:identificador "6062" ;
    ns1:solucionaFallo ns1:ErrorEnRearmeDeBusCANSercos ;
    ns1:textoExtracto "Relé de emergencia abierto por error en reinicialización de bus. DETECCIÓN Tras un reset del CNC o durante la validación de parámetros máquina. CAUSA En reset o validación de parámetros máquina, no se ha conseguido finalizar correctamente la ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos." .

ns1:Alarma80017ParametroHNoPermitido_776f5c716b a ns1:Alarma ;
    rdfs:label "Alarma 80017: Parámetro H no permitido" ;
    ns1:identificador "80017" ;
    ns1:monitoreaParametro ns1:Parametro_H ;
    ns1:textoExtracto "80017 G%D H%D: Parámetro H no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro H. SOLUCIÓN Revisar la programación." .

ns1:Alarma80018ParametroINoPermitido_0e1d7f15f7 a ns1:Alarma ;
    rdfs:label "Alarma 80018: Parámetro I no permitido" ;
    ns1:identificador "80018" ;
    ns1:monitoreaParametro ns1:ParametroI_d8545c5396 ;
    ns1:textoExtracto "80018 G%D I%D: Parámetro I no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro I. SOLUCIÓN Revisar la programación." .

ns1:Alarma80019ParametroJNoPermitido_4e1cf15c77 a ns1:Alarma ;
