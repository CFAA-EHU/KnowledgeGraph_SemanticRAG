ns1:Error8832 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca fuera de rango permitido" ;
    ns1:identificador "8832" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La marca programada no es válida. SOLUCIÓN Las marcas deben estar dentro del rango M1 a M8192." .

ns1:Error8833 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro fuera de rango permitido" ;
    ns1:identificador "8833" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El registro programado no es válido. SOLUCIÓN Los registros deben estar dentro del rango R1 a R1024." .

ns1:Error8834 a ns1:DiagnosticoFallo ;
    rdfs:label "Temporizador fuera de rango permitido" ;
    ns1:identificador "8834" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El temporizador programado no es válido. SOLUCIÓN Los temporizador deben estar dentro del rango T1 a T512." .

ns1:Error8835 a ns1:DiagnosticoFallo ;
    rdfs:label "Contador fuera de rango permitido" ;
    ns1:identificador "8835" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El contador programado no es válido. SOLUCIÓN Los contador deben estar dentro del rango C1 a C256." .

ns1:Error8836 a ns1:DiagnosticoFallo ;
    rdfs:label "Reloj fuera de rango" ;
    ns1:identificador "8836" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El reloj programado no es válido. SOLUCIÓN Consultar en el manual de instalación los relojes válidos." .

ns1:Error8837 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer relojes" ;
    ns1:identificador "8837" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a relojes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error8838 a ns1:DiagnosticoFallo ;
    rdfs:label "Entrada de arranque fuera de rango permitido" ;
    ns1:identificador "8838" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Las entradas de arranque deben estar dentro del rango TG1 a TG4." .

ns1:Error8839 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas de arranque" ;
    ns1:identificador "8839" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas de arranque. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error8840 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ns1:identificador "8840" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. Suponemos TG1." .

ns1:Error8863 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta indefinida" ;
    ns1:identificador "8863" ;
    ns1:textoExtracto "8863 Etiqueta indefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida un salto a una etiquete pero ésta no existe (=JMP etiqueta). SOLUCIÓN Revisar el nombre de las etiquetas y los saltos a las etiquetas." .

ns1:Error8864 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta salto de línea tras fin de módulo" ;
    ns1:identificador "8864" ;
    ns1:textoExtracto "8864 Falta salto de linea tras fin de módulo. DETECCIÓN Durante la compilación",
        "Falta salto de linea tras fin de módulo. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida alguna instrucción en la mismo línea que un \"END\". SOLUCIÓN Programar un salto de línea tras la instrucción \"END\"." .

ns1:Error8865 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay memoria para símbolos nuevos" ;
    ns1:identificador "8865" ;
    ns1:textoExtracto "No hay memoria para símbolos nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA Se ha alcanzado el límite de símbolos del sistema. SOLUCIÓN No es posible definir más símbolos." .

ns1:Error8866 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede MOVer marcas de sistema" ;
    ns1:identificador "8866" ;
    ns1:textoExtracto "No se puede MOVer marcas de sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA Se ha intentado mover un recurso a una señal del PLC (marca). SOLUCIÓN Las señales de consulta no se pueden modificar. Modificar las señales modificables mediante instrucciones de acción." .

ns1:Error8867 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca obsoleta del sistema" ;
    ns1:identificador "8867" ;
    ns1:textoExtracto "Marca obsoleta del sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (marca) ya no es válida. SOLUCIÓN Es posible que la marca pertenezca a otra familia de CNCs o haya cambiado de nombre. No es posible utilizar esta marca." .

ns1:Error8868 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro obsoleto del sistema" ;
    ns1:identificador "8868" ;
    ns1:textoExtracto "Registro obsoleto del sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (registro) ya no es válida. SOLUCIÓN Es posible que el registro pertenezca a otra familia de CNCs o haya cambiado de nombre. No es posible utilizar este registro." .

ns1:Error8869 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca del sistema pendiente de ser implementada" ;
    ns1:identificador "8869" ;
    ns1:textoExtracto "Marca del sistema pendiente de ser implementada. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (marca) no es válida. SOLUCIÓN La marca pertenece a una prestación en desarrollo y no ha sido implementada todavía. No es posible utilizar esta marca. Consulte a Fagor Automation por la disponiblidad de esa marca o prestación." .

ns1:Error9014 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9014: Módulo duplicado o no permitido" ;
    ns1:identificador "9014" ;
    ns1:solucionaFallo ns1:ModuloCY1,
        ns1:ModuloPRG ;
    ns1:textoExtracto "9014 Error fatal. Módulo duplicado o no permitido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Los módulos CY1 y PRG están repetidos, o hay dos módulos periódicos con el mismo periodo. SOLUCIÓN Los módulos CY1 y PRG sólo se pueden programar una vez. Un proyecto puede tener varios módulos periódicos, pero con diferente periodo. Si dos módulos deben tener el mismo periodo, programarlos en un único módulo." .

ns1:Error9015 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9015: TG fuera del rango permitido" ;
    ns1:identificador "9015" ;
    ns1:solucionaFallo ns1:RangoTG ;
    ns1:textoExtracto "9015 TG fuera del rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4." .

ns1:Error9016 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9016: Recurso fuera del rango permitido" ;
    ns1:identificador "9016" ;
    ns1:solucionaFallo ns1:Error9016_soluciona_BitsRegistrosBR,
        ns1:Error9016_soluciona_ContadoresC,
        ns1:Error9016_soluciona_EntradasI,
        ns1:Error9016_soluciona_EntradasLocalesLI,
        ns1:Error9016_soluciona_ErroresERR,
        ns1:Error9016_soluciona_MarcasM,
        ns1:Error9016_soluciona_MensajesMSG,
        ns1:Error9016_soluciona_RegistrosR,
        ns1:Error9016_soluciona_RelojesCLK,
        ns1:Error9016_soluciona_SalidasLocalesLO,
        ns1:Error9016_soluciona_SalidasO,
        ns1:Error9016_soluciona_TemporizadoresT ;
    ns1:textoExtracto "9016 Recurso fuera del rango permitido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Algún recurso programado está fuera del rango permitido. SOLUCIÓN El rango válido para cada recurso es el siguiente. • Entradas (I1-I1024). • Salidas (O1-O1024). • Entradas locales (LI1-LI16). • Salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Bit de registros (B0-B31 R1-R1024). • Estado de los temporizadores (T1-T512). • Estado de los contadores (C1-C256)." .

ns1:Error9017 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9017: Número de bits fuera del rango permitido en MOV" ;
    ns1:identificador "9017" ;
    ns1:solucionaFallo ns1:InstruccionMOV ;
    ns1:textoExtracto "9017 Numero de bits fuera del rango permitido en MOV. DETECCIÓN Durante la compilación del programa PLC. CAUSA El número de bits programado en la instrucción MOV es erróneo. SOLUCIÓN El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32." .

ns1:Error9018 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9018: Demasiados DFUs en una única consulta" ;
    ns1:identificador "9018" ;
    ns1:solucionaFallo ns1:InstruccionDFU ;
    ns1:textoExtracto "9018 Demasiados DFUs en una única consulta. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas instrucciones DFU. SOLUCIÓN Analizar las instrucciones DFU en grupos, guardando el resultado en una marca." .

ns1:Error9020 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiadas acciones (Error 9020)" ;
    ns1:identificador "9020" ;
    ns1:textoExtracto "9020 Demasiadas acciones. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas acciones. SOLUCIÓN Duplicar la proposición ejecutable y distribuir las acciones." .

ns1:Error9026 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta fin de módulo o subrutina 'END' (Error 9026)" ;
    ns1:identificador "9026" ;
    ns1:textoExtracto "9026 Falta fin de módulo o de subrutina 'END'. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta la proposición directiva END al final de un módulo CY1, PRG o PE. SOLUCIÓN Finalizar todos los módulos con la proposición directiva END." .

ns1:Error9027 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción no soportada (Error 9027)" ;
    ns1:identificador "9027" ;
    ns1:textoExtracto "9027 Instrucción no soportada. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada no existe. SOLUCIÓN Revisar la sintaxis." .

ns1:Error9028 a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso o número esperado (Error 9028)" ;
    ns1:identificador "9028" ;
    ns1:textoExtracto "9028 Debe ser un recurso o un número. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada es incorrecta. SOLUCIÓN Programar un recurso o un número." .

ns1:Error9029 a ns1:DiagnosticoFallo ;
    rdfs:label "DEF incorrectamente construido (Error 9029)" ;
    ns1:identificador "9029" ;
    ns1:textoExtracto "9029 DEF incorrectamente construido. DETECCIÓN Durante la compilación del programa PLC. CAUSA DEF incorrectamente construido. SOLUCIÓN Revisar la programación." .

ns1:Error9030 a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de recurso desconocido (Error 9030)" ;
    ns1:identificador "9030" ;
    ns1:textoExtracto "9030 Tipo de recurso desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Tipo de recurso desconocido. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9031 a ns1:DiagnosticoFallo ;
    rdfs:label "Fin de fichero en comentario (Error 9031)" ;
    ns1:identificador "9031" ;
    ns1:textoExtracto "9031 Fin de fichero en comentario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Fin de fichero en comentario. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9032 a ns1:DiagnosticoFallo ;
    rdfs:label "Fichero de símbolos inaccesible (Error 9032)" ;
    ns1:identificador "9032" ;
    ns1:textoExtracto "9032 No se puede abrir el fichero de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA No se puede abrir el fichero de símbolos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9033 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente para lista de símbolos (Error 9033)" ;
    ns1:identificador "9033" ;
    ns1:textoExtracto "9033 No hay memoria para crear la lista de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9512 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión FPGA"@es ;
    ns1:identificador "9512" ;
    ns1:solucionaFallo ns1:Accion_ComprobarConexionado_9512 ;
    ns1:textoExtracto "9512 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS."@es .

ns1:Error9513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD"@es ;
    ns1:identificador "9513" ;
    ns1:textoExtracto "9513 Error en la actualización de versión CPLD. DETECCIÓN Durante el"@es .

ns1:Error9643 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9643 - Captación digital Fagor. Error en la CPU"@es ;
    ns1:identificador "9643" ;
    ns1:solucionaFallo ns1:Encoder_Regla_Danado ;
    ns1:textoExtracto "9643 Captación digital Fagor. Error en la CPU. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error9644 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9644 - Captación digital Fagor. Error de los potenciómetros de ajuste"@es ;
    ns1:identificador "9644" ;
    ns1:solucionaFallo ns1:Encoders_Potenciometros_Danados ;
    ns1:textoExtracto "9644 Captación digital Fagor. Error de los potenciómetros de ajuste. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es .

ns1:Error9645 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9645 - Captación digital Fagor. Error del captador de imagen (CCD)"@es ;
    ns1:identificador "9645" ;
    ns1:solucionaFallo ns1:Encoder_CCD_LED_Danado ;
    ns1:textoExtracto "9645 Captación digital Fagor. Error del captador de imagen (CCD). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)."@es .

ns1:Error9646 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9646 - Captación digital Fagor. Tensión de alimentación fuera de rango"@es ;
    ns1:identificador "9646" ;
    ns1:solucionaFallo ns1:TensionAlimentacion_FueraRango ;
    ns1:textoExtracto "9646 Captación digital Fagor. Tensión de alimentación fuera de rango. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es .

ns1:Error9720 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador"@es ;
    ns1:identificador "9720" ;
    ns1:textoExtracto "9720 Error en el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error9721 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor"@es ;
    ns1:identificador "9721" ;
    ns1:solucionaFallo ns1:Motor_9721 ;
    ns1:textoExtracto "9721 Sobrecarga en el motor. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor. SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al"@es .

ns1:ErrorBus_4612 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus mensaje no recibido en fase 0"@es ;
    ns1:identificador "4612" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisarCableadoBusSercos ;
    ns1:textoExtracto "4612 Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado."@es .

ns1:ErrorBus_4613 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus número de nodos detectados incorrectos"@es ;
    ns1:identificador "4613" ;
    ns1:textoExtracto "4613 Error bus número de nodos detectados incorrectos. DETECCIÓN Durante el arranque del CNC."@es .

ns1:ErrorCAM_FOLLOWOFF a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación: Comando CAM/FOLLOWOFF sin eje esclavo"@es ;
    ns1:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:ErrorCAN a ns1:AvisoSeguridad ;
    rdfs:label "Error de CAN"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError ;
