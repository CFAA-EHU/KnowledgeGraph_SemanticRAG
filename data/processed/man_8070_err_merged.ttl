ns1:Error0093InconsistenciaEnParametrosDRVIDTYPEMODE a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0093: Inconsistencia en parámetros DRV (ID/TYPE/MODE)"@es ;
    ns1:identificador "0093" ;
    ns1:solucionaFallo ns1:ParametroIDIdentificadorSercos_0a4725a067,
        ns1:ParametroMODEModoDeAcceso_40a349bd2d,
        ns1:ParametroTYPETipoDeAcceso_0c22b3356d ;
    ns1:textoExtracto "diferente ID, MODE o TYPE' [...] CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:Error0094TodosLosCanalesOcultosHIDDENCH a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0094: Todos los canales ocultos (HIDDENCH)"@es ;
    ns1:identificador "0094" ;
    ns1:solucionaFallo ns1:ParametroHIDDENCH_e5e463394d ;
    ns1:textoExtracto "0094 'Alguno de los canales debe tener el parámetro HIDDENCH = No' [...] CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)."@es .

ns1:Error0096ConfiguracionIncorrectaDeEjesTandemDRIVETYPEOPMODEP a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0096: Configuración incorrecta de ejes tándem (DRIVETYPE/OPMODEP)"@es ;
    ns1:identificador "0096" ;
    ns1:solucionaFallo ns1:ParametroDRIVETYPEParaEjesTandem_a9a571d0be,
        ns1:ParametroOPMODEPParaEjesTandem_e60899707c ;
    ns1:textoExtracto "0096 Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro. [...] CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)."@es .

ns1:Error0098DiferenciaEnParametroAXISEXCH a ns1:Alarma ;
    rdfs:label "Error 0098: Diferencia en parámetro AXISEXCH" ;
    ns1:identificador "0098" ;
    ns1:monitoreaParametro ns1:ParametroAXISEXCH_16de860e67 ;
    ns1:textoExtracto "El eje maestro y el esclavo tienen diferente parámetro AXISEXCH. DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen el parámetro AXISEXCH con diferente valor. SOLUCIÓN: Asignar el mismo valor al parámetro AXISEXCH de ambos ejes." .

ns1:Error0099PROBEFEEDDemasiadoAlto a ns1:Alarma ;
    rdfs:label "Error 0099: PROBEFEED demasiado alto" ;
    ns1:identificador "0099" ;
    ns1:monitoreaParametro ns1:DECEL_e8ec82f8e6,
        ns1:JERK_0a688b1e3d,
        ns1:PROBEFEED_bbad6b9ef4,
        ns1:PROBERANGE_df79814b26 ;
    ns1:textoExtracto "EL valor del PROBEFEED es demasiado alto para frenar respetando DECEL y JERK. DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: El avance máximo de palpado (parámetro PROBEFEED) es superior al avance necesario para frenar en el espacio definido en PROBERANGE, respetando los valores de aceleración y de jerk del eje. SOLUCIÓN: El valor de este parámetro debe ser inferior que el avance necesario para frenar en el espacio definido en PROBERANGE con los valores de aceleración y de jerk del eje." .

ns1:Error0100VariablesPendientesDeReporte a ns1:Alarma ;
    rdfs:label "Error 0100: Variables pendientes de reporte" ;
    ns1:identificador "0100" ;
    ns1:textoExtracto "Demasiadas variables esperando ser reportadas. DETECCIÓN: Durante la ejecución. CAUSA: El número de variables modificadas en el CNC y que hay que reportar hacia el interface supera el máximo permitido. SOLUCIÓN: Si el error persiste, póngase en contacto con su proveedor." .

ns1:Error0103TimeoutEnValidacionDeParametros a ns1:Alarma ;
    rdfs:label "Error 0103: Timeout en validación de parámetros" ;
    ns1:identificador "0103" ;
    ns1:textoExtracto "Validación de parámetros máquina no finalizada (timeout). DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: La parametrización ha producido un bloqueo en la validación de parámetros máquina. SOLUCIÓN: Revisar los parámetros máquina que han provocado el bloqueo (si se conocen) o reiniciar el CNC." .

ns1:Error0115IncoherenciaEnCodigoDeValidacionDeCPU a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0115: Incoherencia en código de validación de CPU"@es ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "Código de validación -tipo de CPU-, NO coherente con el"@es .

ns1:Error1024NumeroDeGamaFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1024: Número de gama fuera de rango"@es ;
    ns1:identificador "1024" ;
    ns1:solucionaFallo ns1:ParametroMaquinaNPARSETS_9931ecec66 ;
    ns1:textoExtracto "1024 'Número de gama fuera de rango' [...] SOLUCIÓN La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje"@es .

ns1:Error1025DistanciaProgramadaIgualACero a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1025: Distancia programada igual a cero"@es ;
    ns1:identificador "1025" ;
    ns1:textoExtracto "1025 'Distancia programada igual a cero' [...] SOLUCIÓN Revisar la programación"@es .

ns1:Error1026TrayectoriaCircularIncorrectaConElRadioProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1026: Trayectoria circular incorrecta con el radio programado"@es ;
    ns1:identificador "1026" ;
    ns1:textoExtracto "1026 'Trayectoria circular incorrecta con el radio programado' [...] SOLUCIÓN Revisar la programación"@es .

ns1:Error1027PuntoInicialYFinalDeTrayectoriaCircularIdenticos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1027: Punto inicial y final de trayectoria circular idénticos"@es ;
    ns1:identificador "1027" ;
    ns1:textoExtracto "1027 'Punto inicial y final de trayectoria circular idénticos (infinitas soluciones)' [...] SOLUCIÓN Revisar la programación"@es .

ns1:Error1028DiferenciaEntreElCentroProgramadoYElCalculadoDemasiadoGrande a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1028: Diferencia entre el centro programado y el calculado demasiado grande"@es ;
    ns1:identificador "1028" ;
    ns1:solucionaFallo ns1:ParametroMaquinaCIRINERR_23fa2a4fc0,
        ns1:ParametroMaquinaCIRINFACT_938b45e4dd ;
    ns1:textoExtracto "1028 'Diferencia entre el centro programado y el calculado demasiado grande' [...] SOLUCIÓN Revisar la programación"@es .

ns1:Error1029RadioNuloEnTrayectoriaCircular a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1029: Radio nulo en trayectoria circular"@es ;
    ns1:identificador "1029" ;
    ns1:textoExtracto "1029 'Radio nulo en trayectoria circular' [...] SOLUCIÓN El radio de una interpolación circular no puede ser nulo"@es .

ns1:Error1030AXISProgramadoSinG200201202 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1030: #AXIS programado sin G200/201/202"@es ;
    ns1:identificador "1030" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución"@es .

ns1:Error1030AXISProgramadoSinG200201202_dc12952ef4 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1030: '#AXIS programado sin G200/201/202'"@es ;
    ns1:identificador "1030" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la sentencia #AXIS falta programar G200, G201 o G202. SOLUCIÓN Revisar la programación."@es .

ns1:Error1050ExcesoDeRangoEnOffsetsDeHerramientas a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1050: Exceso de rango en offsets de herramientas" ;
    ns1:identificador "1050" ;
    ns1:textoExtracto "'Considerados los offsets de herramientas, se excede el rango de datos' [...] CAUSA Las dimensiones de la herramienta exceden los valores máximos. SOLUCIÓN Modificar las dimensiones de la herramienta." .

ns1:Error1051EjeNoExistenteONoDisponibleEnElCanal a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1051: Eje no existente o no disponible en el canal" ;
    ns1:identificador "1051" ;
    ns1:textoExtracto "'Eje no existente o no disponible en el canal' [...] CAUSA Las posibles causas son las siguientes: • El CNC ha intentado ejecutar un movimiento independiente en un cabezal. • El eje programado en una variable no está disponible. SOLUCIÓN Revisar la programación." .

ns1:Error1052ValoresDeMedicionFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1052: Valores de medición fuera de rango" ;
    ns1:identificador "1052" ;
    ns1:textoExtracto "'Valores resultado de la medición fuera de rango' [...] DETECCIÓN Durante la ejecución." .

ns1:Error1105SeEsperaOperadorDeAsignacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1105: 'Se espera operador de asignación'" ;
    ns1:textoExtracto "1105 'Se espera operador de asignación' DETECCIÓN Durante la ejecución. CAUSA Falta un operador de asignación tras la variable o parámetro. SOLUCIÓN Los operadores de asignación válidos son \"=\", \"+=\", \"-=\", \"*=\", \"/=\"." .

ns1:Error1106SeEspera a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1106: 'Se espera \"]\"'" ;
    ns1:textoExtracto "1106 'Se espera \"]\"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada falta el corchete de cierre \"]\". SOLUCIÓN Revisar la programación." .

ns1:Error1107EjeInexistenteONoDisponible a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1107: 'Eje inexistente o no disponible'" ;
    ns1:textoExtracto "1107 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje que no existe o que no está disponible en el sistema o en el canal. El eje programado en una sentencia o variable no existe en el sistema o en el canal. SOLUCIÓN Comprobar que el eje programado existe en el canal y que está disponible (que no está aparcado)." .

ns1:Error1108EjeDoblementeProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1108: 'Eje doblemente programado'" ;
    ns1:textoExtracto "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución." .

ns1:Error1132CondicionWHILEExcedeCaracteresPermitidos a ns1:AvisoSeguridad ;
    rdfs:label "Error 1132: Condición $WHILE excede caracteres permitidos" ;
    ns1:identificador "1132" ;
    ns1:textoExtracto "CAUSA La condición de la instrucción $WHILE supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 5000." ;
    ns1:valor "5000" .

ns1:Error1133NoSeEsperaENDWHILE a ns1:AvisoSeguridad ;
    rdfs:label "Error 1133: 'No se espera $ENDWHILE'" ;
    ns1:identificador "1133" ;
    ns1:textoExtracto "1133 'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDWHILE sin una instrucción $WHILE previa. SOLUCIÓN Revisar la programación." .

ns1:Error1134LaSentenciaENDWHILESeProgramaSolaEnElBloque a ns1:AvisoSeguridad ;
    rdfs:label "Error 1134: 'La sentencia $ENDWHILE se programa sola en el bloque'" ;
    ns1:identificador "1134" ;
    ns1:textoExtracto "1134 'La sentencia $ENDWHILE se programa sola en el bloque' DETECCIÓN Durante la" .

ns1:Error1162NoSeEsperaM17M29RET a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1162: 'No se espera M17/M29/#RET'" ;
    ns1:identificador "1162" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M17, M29 o #RET como final de programa. SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET." .

ns1:Error1163NoSeEsperaM30M02 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1163: 'No se espera M30/M02'" ;
    ns1:identificador "1163" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M02 o M30 como final de subrutina. SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET." .

ns1:Error1164TerminoDesconocidoEnExpresionMatematica a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1164: 'Término desconocido en expresión matemática'" ;
    ns1:identificador "1164" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La expresión matemática es incorrecta. SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc." .

ns1:Error1165VariableInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1165: 'Variable inexistente'" ;
    ns1:identificador "1165" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable pedida no existe. • Error sintáctico en el nombre de la variable. • La variable es un array y no se ha indicado índice de array. • Se ha pedido una variable general para un eje determinado o a la inversa. SOLUCIÓN Revisar la programación." .

ns1:Error1166RaizDeUnNumeroNegativo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1166: 'Raíz de un número negativo'" ;
    ns1:identificador "1166" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay una raíz cuadrada (SQRT) de un número negativo. SOLUCIÓN Revisar la programación." .

ns1:Error1167LogaritmoDeUnNumeroNegativoOCero a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1167: 'Logaritmo de un número negativo o cero'" ;
    ns1:identificador "1167" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación." .

ns1:Error1168IndiceDeVariableFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1168: 'Índice de variable fuera de rango'" ;
    ns1:identificador "1168" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

ns1:Error1187AXISNombreDeEjeRepetido a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1187: '#AXIS: nombre de eje repetido'" ;
    ns1:identificador "1187" ;
    ns1:textoExtracto "1187 '#AXIS: nombre de eje repetido' [...] DETECCIÓN Durante la ejecución. CAUSA El mismo eje se ha programado más de una vez en la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Error1188NoSeEspera a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1188: 'No se espera \"[\"'" ;
    ns1:identificador "1188" ;
    ns1:textoExtracto "1188 'No se espera \"[\"' [...] DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Error1189MPGDemasiadosParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'" ;
    ns1:identificador "1189" ;
    ns1:textoExtracto "1189 '#MPG: demasiados parámetros' [...] DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres" .

ns1:Error1195CONTJOGDemasiadosParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error 1195: '#CONTJOG: demasiados parámetros'"@es ;
    ns1:identificador "1195" ;
    ns1:mitigaRiesgo ns1:ParametroDeAvanceEnJogContinuo_d5b6e8cbe1 ;
    ns1:textoExtracto "1195 '#CONTJOG: demasiados parámetros' DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos."@es .

ns1:Error1196CONTJOGNoSePermitenVelocidadesDeJogContinuoNegativas a ns1:AvisoSeguridad ;
    rdfs:label "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas'"@es ;
    ns1:identificador "1196" ;
    ns1:mitigaRiesgo ns1:ParametroDeAvanceEnJogContinuo_d5b6e8cbe1 ;
    ns1:textoExtracto "1196 '#CONTJOG: no se permiten velocidades de jog continuo negativas o"@es .

ns1:Error1229AnidamientoDeSentenciasCondicionalesSobrepasado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1229: Anidamiento de sentencias condicionales sobrepasado"@es ;
    ns1:identificador "1229" ;
    ns1:textoExtracto "1229 Anidamiento de sentencias condicionales sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR, $WHILE y $DO. SOLUCIÓN Revisar la programación. El máximo número de anidamientos es 20."@es .

ns1:Error1233TrasladoProgramadoExcedeElRangoDeDatos a ns1:AvisoSeguridad ;
    rdfs:label "Error 1233: Traslado programado excede el rango de datos"@es ;
    ns1:identificador "1233" ;
    ns1:monitoreaParametro ns1:LONGAXIS_3b1e99e02b ;
    ns1:textoExtracto "1233 'El traslado programado excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA El traslado de origen definido supera al máximo permitido. SOLUCIÓN Revisar la programación."@es .

ns1:Error1236NombreDeMacroDemasiadoLargo a ns1:AvisoSeguridad ;
    rdfs:label "Error 1236: Nombre de macro demasiado largo"@es ;
    ns1:identificador "1236" ;
    ns1:textoExtracto "1236 'Nombre de macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la macro supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 30."@es .

ns1:Error1237FaltaEnTextoAsociadoAMacro a ns1:AvisoSeguridad ;
    rdfs:label "Error 1237: Falta '\\' en texto asociado a macro"@es ;
    ns1:identificador "1237" ;
    ns1:textoExtracto "1237 'Se espera \"\\\" en el texto asociado a la macro' DETECCIÓN Durante la ejecución. CAUSA En el texto de sustitución de una macro, se ha incluido una macro que no comienza por el carácter \"\\\". SOLUCIÓN El texto de sustitución de una macro debe ir entre comillas y puede incluir otras macros, las cuales deben estar delimitadas por los caracteres \\\"; por ejemplo \"macro\"=\"\\\"macro1\\\" \\\"macro2\\\"\""@es .

ns1:Error1238TextoDeSustitucionDeMacroDemasiadoLargo a ns1:AvisoSeguridad ;
    rdfs:label "Error 1238: Texto de sustitución de macro demasiado largo"@es ;
    ns1:identificador "1238" ;
    ns1:textoExtracto "1238 'Texto de sustitución de la macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El número de caracteres del texto de sustitución de la macro supera el máximo permitido. SOLUCIÓN El máximo número de caracteres permitidos es 140."@es .

ns1:Error1240MacroInexistente a ns1:AvisoSeguridad ;
    rdfs:label "Error 1240: Macro inexistente"@es ;
    ns1:identificador "1240" ;
    ns1:textoExtracto "1240 'Macro inexistente' DETECCIÓN Durante la ejecución. CAUSA La macro no está definida en el programa. SOLUCIÓN Definir la macro antes de utilizarla."@es .

ns1:Error1245NoHayEjeFrontalFACEAXISDefinidoEnElPlanoActivo a ns1:AvisoSeguridad ;
    rdfs:label "Error 1245: No hay eje frontal (FACEAXIS) definido en el plano activo" ;
    ns1:identificador "1245" ;
    ns1:solucionaFallo ns1:ParametroMPAFACEAXIS_8060b29a09 ;
    ns1:textoExtracto "'G96: no hay eje frontal (FACEAXIS) definido en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje frontal." .

ns1:Error1246NoSeAdmiteRoscadoConAvanceEnG95 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1246: No se admite roscado con avance en G95" ;
    ns1:identificador "1246" ;
    ns1:solucionaFallo ns1:AvanceEnFuncionDelTiempoG94 ;
    ns1:textoExtracto "'No se admite roscado con avance en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)." .

ns1:Error1247NoSeAdmiteRoscadoConG96Activa a ns1:AvisoSeguridad ;
    rdfs:label "Error 1247: No se admite roscado con G96 activa" ;
    ns1:identificador "1247" ;
    ns1:solucionaFallo ns1:AvanceEnFuncionDelTiempoG94 ;
    ns1:textoExtracto "'No se admite roscado con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante)." .

ns1:Error1422CSONACSONModoProgramadoNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1422: '#CS ON/#ACS ON: modo programado no válido'" ;
    ns1:identificador "1422" ;
    ns1:monitoreaParametro ns1:ParametroMODE ;
    ns1:textoExtracto "'#CS ON/#ACS ON: modo programado no válido' DETECCIÓN Durante la ejecución. CAUSA El parámetro MODE programado no es válido. SOLUCIÓN El valor del parámetro MODE debe ser estar comprendido entre 1 y 6." .

ns1:Error1423CSONACSONElParametroDeEjeAlineadoHaDeSer0O1 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1423: '#CS ON/#ACS ON: el parámetro de eje alineado ha de ser 0 o 1'" ;
    ns1:identificador "1423" ;
    ns1:monitoreaParametro ns1:ParametroDeEjeAlineado_82f30d2929 ;
    ns1:textoExtracto "'#CS ON/#ACS ON: el parámetro de eje alineado ha de ser 0 o 1' DETECCIÓN Durante la ejecución. CAUSA El valor programado como modo para alinear el plano no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error1424FuncionGNoPermitidaConMCSActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1424: 'Función G no permitida con MCS activo'" ;
    ns1:identificador "1424" ;
    ns1:monitoreaParametro ns1:ParametroDeFuncionG_60569ce7f9 ;
    ns1:textoExtracto "'Función G no permitida con MCS activo' DETECCIÓN Durante la ejecución. CAUSA No es posible ejecutar la función G programada con #MCS activo. SOLUCIÓN Revisar la programación." .

ns1:Error1425ElSaltoDeBloqueSoloSeAdmiteAlComienzoDeLaLinea a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1425: 'El salto de bloque sólo se admite al comienzo de la línea'" ;
    ns1:identificador "1425" ;
    ns1:monitoreaParametro ns1:ParametroDeSaltoDeBloque_60c7d25d81 ;
    ns1:textoExtracto "'El salto de bloque sólo se admite al comienzo de la línea' DETECCIÓN Durante la ejecución. CAUSA El carácter \"/\" solo se admite al comienzo de la línea de programa. SOLUCIÓN Revisar la programación." .

ns1:Error1426LaCajeraFueResueltaConDiferenteRadioDeHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1426: 'La cajera fue resuelta con diferente radio de herramienta'"@es ;
    ns1:identificador "1426" ;
    ns1:solucionaFallo ns1:HerramientaDeFresado_939c57511d ;
    ns1:textoExtracto "1426 'La cajera fue resuelta con diferente radio de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con un radio de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Error1427EjeMalProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1427: 'Eje mal programado'"@es ;
    ns1:identificador "1427" ;
    ns1:solucionaFallo ns1:ProgramaCNC ;
    ns1:textoExtracto "1427 'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está"@es .

ns1:Error1433ConfiguracionDeEjeAparcado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1433: Configuración de eje aparcado" ;
    ns1:identificador "1433" ;
    ns1:solucionaFallo ns1:ParametroUNPARKDesaparcarEje_bbe047760a ;
    ns1:textoExtracto "No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado. SOLUCIÓN Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)." .

ns1:Error1434InclusionDeEjeEsclavoAsociado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1434: Inclusión de eje esclavo asociado" ;
    ns1:identificador "1434" ;
    ns1:solucionaFallo ns1:ParametroUNLINKDesactivarAcoploActivo_4563447e55 ;
    ns1:textoExtracto "'No se ha podido incluir en la configuración un eje esclavo asociado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque no existe una posición libre para el eje esclavo distinta de las tres principales. SOLUCIÓN Para poder incluir únicamente el eje maestro hay que desactivar primero el acoplo activo (#UNLINK) o deshacer la pareja Gantry. Para poder incluir los ejes maestro y esclavo hay que eliminar del canal algún otro eje o bien aumentar el número de ejes del canal." .

ns1:Error1435NombreDeEjeEsclavoRepetido a ns1:AvisoSeguridad ;
    rdfs:label "Error 1435: Nombre de eje esclavo repetido" ;
    ns1:identificador "1435" ;
    ns1:textoExtracto "'No se ha podido asignar nombre a un eje esclavo asociado por estar repetido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal. SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración." .

ns1:Error1483NumeroDeCanalNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1483: Número de canal no válido"@es ;
    ns1:identificador "1483-Canal" ;
    ns1:solucionaFallo ns1:RangoValidoDeCanales14 ;
    ns1:textoExtracto "CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT. SOLUCIÓN El número de canal debe estar comprendido entre 1 y 4."@es .

ns1:Error1483SintaxisIncorrectaEnSentenciaWAITMEET a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1483: Sintaxis incorrecta en sentencia #WAIT/#MEET"@es ;
    ns1:identificador "1483" ;
    ns1:solucionaFallo ns1:ProgramarMultiplesSentenciasEnUnMismoBloque ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1484NumeroDeSenalFueraDeRango a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1484: Número de señal fuera de rango"@es ;
    ns1:identificador "1484" ;
    ns1:textoExtracto "CAUSA El número de señal programada en la sentencia #WAIT, #MEET o #SIGNAL no es correcto. SOLUCIÓN Revisar la programación."@es .

ns1:Error1485WAITMEETNoEfectivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1485: #WAIT/#MEET no efectivo"@es ;
    ns1:identificador "1485" ;
    ns1:solucionaFallo ns1:ProgramarMarcaDeSincronizacionEnElMismoCanalQueLaSentenciaWAITMEET ;
    ns1:textoExtracto "CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias."@es .

ns1:Error1487SintaxisIncorrectaEnProgramacionDeBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1487: Sintaxis incorrecta en programación de bloque" ;
    ns1:identificador "1487" ;
    ns1:solucionaFallo ns1:Sentencia_CLEAR ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. 1487 'Programar: #CLEAR [señal, señal, señal, ...]'" .

ns1:Error1489NombreDeEjeRepetidoEnGrupo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1489: Nombre de eje repetido en grupo" ;
    ns1:identificador "1489" ;
    ns1:solucionaFallo ns1:Sentencia_RENAME ;
    ns1:textoExtracto "1489 'Nombre de eje repetido en el grupo resultante'" .

ns1:Error1490SecuenciaIncorrectaDeProgramacionG63M19 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1490: Secuencia incorrecta de programación (G63/M19)" ;
    ns1:identificador "1490" ;
    ns1:solucionaFallo ns1:Sentencia_M19 ;
    ns1:textoExtracto "1490 'G63 necesita programar previamente M19'" .

ns1:Error1497OperadorIncorrectoParaElTipoDeVariable a ns1:AvisoSeguridad ;
    rdfs:label "Error 1497: Operador incorrecto para el tipo de variable" ;
    ns1:identificador "1497" ;
    ns1:textoExtracto "'Operador incorrecto para el tipo de variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar mediante los operadores \"+=\", \"-=\", \"*=\" y \"/=\" alguna variable no numérica. SOLUCIÓN Revisar la programación." .

ns1:Error1502_31cdcf1f11 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1502"@es ;
    ns1:identificador "1502" ;
    ns1:textoExtracto "1502"@es .

ns1:Error1513ErrorEnLaEscrituraDeLaVariable a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1513: Error en la escritura de la variable" ;
    ns1:identificador "1513" ;
    ns1:textoExtracto "1513 'Error en la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable no existe. • La variable es de eje pero el eje no existe. • La variable es de eje pero no existe para el tipo de eje (lineal o rotativo). • La variable es de eje pero no existe para el tipo de regulador del eje. • El operador compuesto (+= -= *= /=) no está permitido para esa variable. • El valor de la variable no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error1514NoEsPosibleEjecutarUnaCajera2D3DConG72Activo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1514: No es posible ejecutar una cajera 2D-3D con G72 activo" ;
    ns1:identificador "1514" ;
    ns1:solucionaFallo ns1:EjecutarCajera2D3DConG72Activo ;
    ns1:textoExtracto "1514 'No es posible ejecutar una cajera 2D-3D con G72 activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la cajera con un factor de escala activo. SOLUCIÓN Anular el factor de escala." .

ns1:Error1515UnoOVariosEjesDeLaConfiguracionOriginalNoEstanDisponibles a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1515: Uno o varios ejes de la configuración original no están disponibles" ;
    ns1:identificador "1515" ;
    ns1:textoExtracto "1515 'Uno o varios ejes de la configuración original no están disponibles' DETECCIÓN Durante la ejecución." .

ns1:Error1531ProgramarEXBLK a ns1:AvisoSeguridad ;
    rdfs:label "Error 1531: Programar #EXBLK"@es ;
    ns1:identificador "1531" ;
    ns1:textoExtracto "1531 'Programar: #EXBLK [bloque, canal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1532ProgramarMASTER a ns1:AvisoSeguridad ;
    rdfs:label "Error 1532: Programar #MASTER"@es ;
    ns1:identificador "1532" ;
    ns1:textoExtracto "1532 'Programar: #MASTER <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1533ProgramarFREESP a ns1:AvisoSeguridad ;
    rdfs:label "Error 1533: Programar #FREESP"@es ;
    ns1:identificador "1533" ;
    ns1:textoExtracto "1533 'Programar: #FREESP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1534ProgramarCALLSP a ns1:AvisoSeguridad ;
    rdfs:label "Error 1534: Programar #CALLSP"@es ;
    ns1:identificador "1534" ;
    ns1:textoExtracto "1534 'Programar: #CALLSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1535ProgramarSETSP a ns1:AvisoSeguridad ;
    rdfs:label "Error 1535: Programar #SETSP"@es ;
    ns1:identificador "1535" ;
    ns1:textoExtracto "1535 'Programar: #SETSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1575SentenciaInvalidaParaExtensionDePrograma a ns1:AvisoSeguridad ;
    rdfs:label "Error 1575: Sentencia inválida para extensión de programa"@es ;
    ns1:documentadoEn ns1:TablaDeErroresDeProgramacionCodigos15751578 ;
    ns1:identificador "1575" ;
    ns1:textoExtracto """\r
    1575 'Sentencia sólo válida en programas con extensión FBS'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: Programación de las sentencias #SPLINE o #BSPLINE.\r
    SOLUCIÓN: Estas sentencias sólo son válidas en programas con extensión fbs.\r
    """@es .

ns1:Error1576SintaxisIncorrectaFalta a ns1:AvisoSeguridad ;
    rdfs:label "Error 1576: Sintaxis incorrecta (falta ']')"@es ;
    ns1:documentadoEn ns1:TablaDeErroresDeProgramacionCodigos15751578 ;
    ns1:identificador "1576" ;
    ns1:textoExtracto """\r
    1576 'No se espera "]"\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: Error en la sintaxis de la sentencia.\r
    SOLUCIÓN: Revisar la programación.\r
    """@es .

ns1:Error1577TipoDeSincronizacionNoProgramado a ns1:AvisoSeguridad ;
    rdfs:label "Error 1577: Tipo de sincronización no programado"@es ;
    ns1:documentadoEn ns1:TablaDeErroresDeProgramacionCodigos15751578 ;
    ns1:identificador "1577" ;
    ns1:monitoreaParametro ns1:ParametroDeTipoDeSincronizacionFOLLOW_45d2799707 ;
    ns1:textoExtracto """\r
    1577 'Programar tipo de sincronización: VEL o POS'\r
    DETECCIÓN: Durante la ejecución.\r
    CAUSA: El parámetro que define el tipo de sincronización en la sentencia #FOLLOW es incorrecto.\r
    SOLUCIÓN: Revisar la programación. El parámetro puede tomar los valores VEL (velocidad) y POS (posición).\r
    """@es .

ns1:Error1578ConfiguracionIncorrectaDeEjeEsclavoLINK a ns1:AvisoSeguridad ;
    rdfs:label "Error 1578: Configuración incorrecta de eje esclavo (#LINK)"@es ;
    ns1:documentadoEn ns1:TablaDeErroresDeProgramacionCodigos15751578 ;
    ns1:identificador "1578" ;
    ns1:textoExtracto """\r
    1578 '#LINK: Un eje esclavo UNIDIR debe ser del mismo tipo que el maestro (UNIDIR)'\r
    DETECCIÓN: Durante la ejecución.\r
    """@es .

ns1:Error1594ElCabezalEsclavoYaEstaSincronizadoAOtroCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1594: 'El cabezal esclavo ya está sincronizado a otro cabezal'" ;
    ns1:identificador "1594" ;
    ns1:textoExtracto "1594 'El cabezal esclavo ya está sincronizado a otro cabezal' DETECCIÓN Durante la ejecución. CAUSA El cabezal esclavo ya está sincronizado a otro cabezal. SOLUCIÓN Un cabezal sólo puede ser esclavo de un maestro. Deshacer la sincronización anterior o sincronizar otro cabezal que esté disponible." .

ns1:Error1595UnCabezalNoPuedeSerALaVezMaestroYEsclavoDeUnaSincronizacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1595: 'Un cabezal no puede ser a la vez maestro y esclavo de una sincronización'" ;
    ns1:identificador "1595" ;
    ns1:textoExtracto "1595 'Un cabezal no puede ser a la vez maestro y esclavo de una sincronización' DETECCIÓN Durante la ejecución. CAUSA El cabezal esclavo de una sincronización es el cabezal maestro de otra. SOLUCIÓN Revisar la programación." .

ns1:Error1596ElCabezalNoEstaSincronizado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1596: 'El cabezal no está sincronizado'" ;
    ns1:identificador "1596" ;
    ns1:textoExtracto "1596 'El cabezal no está sincronizado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desincronizar un cabezal esclavo que no está actualmente sincronizado. SOLUCIÓN Revisar la programación." .

ns1:Error1597NoSePuedeSincronizarElMismoCabezalEsclavoADosMaestros a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1597: 'No se puede sincronizar el mismo cabezal esclavo a dos maestros'" ;
    ns1:identificador "1597" ;
    ns1:textoExtracto "1597 'No se puede sincronizar el mismo cabezal esclavo a dos maestros' DETECCIÓN Durante la ejecución. CAUSA No se puede sincronizar de forma simultánea un cabezal esclavo a dos maestros distintos. SOLUCIÓN Decidir qué sincronización de las dos es la que se quiere activar." .

ns1:Error1598NoSePermiteProgramarUnCabezalEsclavoDuranteLaSincronizacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1598: 'No se permite programar un cabezal esclavo durante la sincronización'" ;
    ns1:identificador "1598" ;
    ns1:textoExtracto "1598 'No se permite programar un cabezal esclavo durante la sincronización' DETECCIÓN Durante la ejecución. CAUSA Hay programada una velocidad S o una función M para el cabezal esclavo de una sincronización. SOLUCIÓN Eliminar esta programación o desincronizar el cabezal." .

ns1:Error1599NoSeAdmiteCambioDeGamaEnCabezalesSincronizados a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1599: 'No se admite cambio de gama en cabezales sincronizados'" ;
    ns1:identificador "1599" ;
    ns1:textoExtracto "1599 'No se admite cambio de gama en cabezales sincronizados' DETECCIÓN Durante la ejecución. CAUSA Durante la sincronización de dos cabezales, el CNC no permite el cambio de gama en ninguno de ellos. SOLUCIÓN Cancelar la sincronización para cambiar la gama del cabezal." .

ns1:Error1608VariableNoConsultable a ns1:AvisoSeguridad ;
    rdfs:label "Error 1608: Variable no consultable"@es ;
    ns1:identificador "1608" ;
    ns1:mitigaRiesgo ns1:ParametroAritmeticoLocalPn_e637bb4601 ;
    ns1:textoExtracto "'No se puede consultar esta variable. Asigne el valor de variable a Pn y consulte Pn' DETECCIÓN Durante la ejecución. CAUSA Determinados comandos e instrucciones de CNC no admiten leer variables que implican una sincronización entre la preparación y ejecución de bloques. SOLUCIÓN Para evitar este error, asignar el valor de la variable a un parámetro aritmético local y leer este parámetro cuando sea necesario."@es .

ns1:Error1609EjesInsuficientesParaCicloDeTorno a ns1:AvisoSeguridad ;
    rdfs:label "Error 1609: Ejes insuficientes para ciclo de torno"@es ;
    ns1:identificador "1609" ;
    ns1:textoExtracto "'Para ejecutar un ciclo de torno son necesarios dos ejes en el canal' DETECCIÓN Durante la ejecución."@es .

ns1:Error1636TransformadasFACEYCYLActivasSimultaneamente a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1636: Transformadas FACE y CYL activas simultáneamente" ;
    ns1:identificador "1636" ;
    ns1:monitoreaParametro ns1:ParametroNKINAXNumeroDeEjesEnTransformacionDeCoordenadas_96ef2c218a ;
    ns1:textoExtracto "'No se permiten tener activas las transformadas FACE y CYL al mismo tiempo' [...] DETECCIÓN Durante la ejecución. CAUSA El CNC intentado activar la sentencia #FACE o #CYL con una de ellas activa. SOLUCIÓN Desactivar una de ellas antes de activar la otra." .

ns1:Error1637SentidoDeGiroDelCabezalIncompatibleConLaHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1637: Sentido de giro del cabezal incompatible con la herramienta" ;
    ns1:identificador "1637" ;
    ns1:textoExtracto "'Sentido de giro del cabezal incompatible con la herramienta' [...] DETECCIÓN Durante la ejecución." .

ns1:Error1670SentenciaROTATEMZInvalidaParaAlmacenNoTorreta a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1670: Sentencia #ROTATEMZ inválida para almacén no torreta" ;
    ns1:identificador "1670" ;
    ns1:solucionaFallo ns1:FalloProgramacion1670 ;
    ns1:textoExtracto "1670 'El almacén indicado debe ser de tipo TORRETA' [...] SOLUCIÓN Revisar la programación. Comprobar que el almacén es de tipo torreta." .

ns1:Error1671ExcesoDeSubrutinasLocales a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1671: Exceso de subrutinas locales" ;
    ns1:identificador "1671" ;
    ns1:solucionaFallo ns1:FalloSubrutinas1671 ;
    ns1:textoExtracto "1671 Demasiadas subrutinas locales en el fichero. [...] SOLUCIÓN Reducir el número de subrutinas locales; agrupar varias subrutinas en una o utilizar subrutinas globales. El CNC permite 130 subrutinas locales por programa." .

ns1:Error1672CodigosG74G174NoAdmitidosParaCabezalesSincronizados a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1672: Códigos G74-G174 no admitidos para cabezales sincronizados" ;
    ns1:identificador "1672" ;
    ns1:solucionaFallo ns1:FalloCodigosG1672 ;
    ns1:textoExtracto "1672 'No se admite G74-G174 para cabezales sincronizados' DETECCIÓN Durante la ejecución." .

ns1:Error1681DemasiadosCanalesProgramadosEnSentencia a ns1:AvisoSeguridad ;
    rdfs:label "Error 1681: Demasiados canales programados en sentencia" ;
    ns1:identificador "1681" ;
    ns1:textoExtracto "1681 'Demasiados canales programados en sentencia' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #DGWZ hay programado más de un número de canal. SOLUCIÓN Programar un único número de canal C1-C4." .

ns1:Error1682SoloSePermiteProgramarUnNumeroDePieza a ns1:AvisoSeguridad ;
    rdfs:label "Error 1682: Solo se permite programar un número de pieza" ;
    ns1:identificador "1682" ;
    ns1:textoExtracto "1682 'Sólo se permite programar un número de pieza' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #DGWZ hay programado más de un número de pieza. SOLUCIÓN Programar un único número de pieza P1-P4." .

ns1:Error1683SentenciaREPOSSoloEnSubrutinasDeInterrupcion a ns1:AvisoSeguridad ;
    rdfs:label "Error 1683: Sentencia #REPOS solo en subrutinas de interrupción" ;
    ns1:identificador "1683" ;
    ns1:textoExtracto "1683 'La sentencia #REPOS solo se admite en subrutinas de interrupción' DETECCIÓN Durante la ejecución. CAUSA La instrucción #REPOS no está programada en una subrutina de interrupción. SOLUCIÓN Sólo se permite programar la sentencia #REPOS en las subrutinas de interrupción." .

ns1:Error1684SubrutinaLocalYMTOGConSubrutinaEnElMismoBloque a ns1:AvisoSeguridad ;
    rdfs:label "Error 1684: Subrutina local y M, T, o G con subrutina en el mismo bloque" ;
    ns1:identificador "1684" ;
    ns1:textoExtracto "1684 'Subrutina local y M, T, o G con subrutina en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA Un mismo bloque de programa está ejecutando una llamada a una subrutina local y una función M, T o G que tienen una subrutina asociada. SOLUCIÓN Programar la llamada a la subrutina local en otro bloque de programa." .

ns1:Error1685GOTONoPermitidoABloquesAnidados a ns1:AvisoSeguridad ;
    rdfs:label "Error 1685: $GOTO no permitido a bloques anidados" ;
    ns1:identificador "1685" ;
    ns1:textoExtracto "1685 '$GOTO:Salto a bloques anidados dentro de $IF, $FOR, $WHILE... no permitido' DETECCIÓN Durante la ejecución. CAUSA La instrucción $GOTO no está dentro de un bucle pero está saltando a una etiqueta definida dentro de un bucle $IF, $FOR, etc. SOLUCIÓN Revisar la programación. No se permite realizar saltos al interior de un bucle." .

ns1:Error1686PathDelFicheroDemasiadoLargo a ns1:AvisoSeguridad ;
    rdfs:label "Error 1686: Path del fichero demasiado largo" ;
    ns1:identificador "1686" ;
    ns1:textoExtracto "1686 El path del fichero es demasiado largo. DETECCIÓN Durante la ejecución. CAUSA El path definido es demasiado largo. SOLUCIÓN La longitud máxima permitida para el path es de 120 caracteres." .

ns1:Error1710TALADRADO2F0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1710: TALADRADO 2: F = 0"@es ;
    ns1:identificador "1710" ;
    ns1:textoExtracto "1710 'TALADRADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Error1819K0 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1819: 'K = 0'" ;
    ns1:identificador "1819" ;
    ns1:solucionaFallo ns1:ParametroKNumeroDeMecanizados_c4d34836ef ;
