ns1:ErrorCNC_1134 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1134: Sentencia $ENDWHILE mal programada"@es ;
    ns1:identificador "1134" ;
    ns1:textoExtracto "'La sentencia $ENDWHILE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:ErrorCNC_1135 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1135: Sentencia $DO mal programada"@es ;
    ns1:identificador "1135" ;
    ns1:textoExtracto "'La sentencia $DO se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:ErrorCNC_1136 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1136: Instrucción $ENDDO inesperada"@es ;
    ns1:identificador "1136" ;
    ns1:textoExtracto "'No se espera $ENDDO' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDDO sin una instrucción $DO previa. SOLUCIÓN Revisar la programación."@es .

ns1:ErrorCNC_1137 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1137: Sentencia $ENDDO mal programada"@es ;
    ns1:identificador "1137" ;
    ns1:textoExtracto "'La sentencia $ENDDO <expresión> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:ErrorCNC_1138 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1138: Sentencia $BREAK mal programada"@es ;
    ns1:identificador "1138" ;
    ns1:textoExtracto "'La sentencia $BREAK se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:ErrorCNC_1139 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1139: Instrucción $BREAK inesperada"@es ;
    ns1:identificador "1139" ;
    ns1:textoExtracto "'No se espera $BREAK' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $BREAK pero no hay ningún bucle de control abierto; $IF, $ELSE, $FOR, $WHILE, $DO o $CASE. SOLUCIÓN Revisar la programación. El CNC utiliza la instrucción $BREAK para finalizar un $CASE o para salir de un bucle $IF, $ELSE, $WHILE, $FOR o $DO antes de que finalice."@es .

ns1:ErrorCNC_1140 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1140: Instrucción $CONTINUE inesperada"@es ;
    ns1:identificador "1140" ;
    ns1:textoExtracto "'No se espera $CONTINUE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $CONTINUE pero no hay ningún bucle de control abierto; $FOR, $WHILE o $DO. SOLUCIÓN Revisar la programación. El CNC utiliza la instrucción $CONTINUE para volver al punto inicial de un bucle $FOR, $WHILE o $DO."@es .

ns1:ErrorCNC_1436 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1436: 'No se ha programado bloque de parada en búsqueda de bloque'"@es ;
    ns1:identificador "1436" ;
    ns1:textoExtracto "1436 'No se ha programado bloque de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque."@es .

ns1:ErrorCNC_5002 a ns1:DiagnosticoFallo ;
    rdfs:label "CNCRD: Variable no identificada" ;
    ns1:identificador "5002" ;
    ns1:textoExtracto "5002 'CNCRD: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe. Si el error se produce durante el arranque, es posible que el PLC esté intentando ejecutar una instrucción CNCRD antes de que la marca SERCOSRDY esté activa. SOLUCIÓN Verificar la sintaxis de la variable. Si el error se produce durante el arranque, condicionar la lectura de la variable a que la marca SERCOSRDY esté activa." .

ns1:ErrorCNC_5003 a ns1:DiagnosticoFallo ;
    rdfs:label "CNCWR: Variable no identificada" ;
    ns1:identificador "5003" ;
    ns1:textoExtracto "5003 'CNCWR: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA La variable no existe. SOLUCIÓN Verificar la sintaxis de la variable." .

ns1:ErrorCNC_EjeEsclavoDuplicado a ns1:AvisoSeguridad ;
    rdfs:label "Error: Nombre de eje esclavo duplicado en configuración de canal"@es ;
    ns1:textoExtracto "El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal. SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración."@es .

ns1:ErrorCNC_General a ns1:DiagnosticoFallo ;
