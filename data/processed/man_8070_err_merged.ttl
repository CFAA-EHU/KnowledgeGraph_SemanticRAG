ns1:Error2397GAPCTRLONActivo a ns1:AvisoSeguridad ;
    rdfs:label "Error 2397: #GAPCTRL ON activo" ;
    ns1:identificador "2397" ;
    ns1:mitigaRiesgo ns1:GAPCTRL_14f2c837cc ;
    ns1:textoExtracto "#GAPCTRL ON activo.#GAPCTRL OFF necesario para cambiar parámetros. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado modificar los parámetros de #GAPCTRL mientras está activo. SOLUCIÓN Desactivar #GAPCTRL antes de modificar sus parámetros." .

ns1:Error2398LEAPFaltaProgramacionDePOSLIMIT a ns1:AvisoSeguridad ;
    rdfs:label "Error 2398: #LEAP falta programación de POSLIMIT" ;
    ns1:identificador "2398" ;
    ns1:mitigaRiesgo ns1:POSLIMIT_6227c75e92 ;
    ns1:textoExtracto "#LEAP:falta programación de POSLIMIT. DETECCIÓN Durante la ejecución. CAUSA En el comando #LEAP falta programar el comando POSLIMIT. SOLUCIÓN La primera vez que se programa #LEAP es obligatorio programar el comando POSLIMIT." .

ns1:Error2399LEAPActivoNoSePuedeAlterarPOS a ns1:AvisoSeguridad ;
    rdfs:label "Error 2399: #LEAP activo. No se puede alterar POS" ;
    ns1:identificador "2399" ;
    ns1:mitigaRiesgo ns1:LEAPPOS ;
    ns1:textoExtracto "#LEAP activo. No se puede alterar POS, posición final del salto. DETECCIÓN Durante la ejecución. CAUSA Una vez programada la cota final del salto (#LEAP[POS]), no se permite cambiarla con #LEAP activo. SOLUCIÓN Revisar la programación." .

ns1:Error2400NumeroLogicoDeEjeFueraDeRango a ns1:AvisoSeguridad ;
    rdfs:label "Error 2400: Número lógico de eje fuera de rango" ;
    ns1:identificador "2400" ;
    ns1:textoExtracto "Número lógico de eje fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número lógico programado en la variable no es correcto." .

ns1:Error2436ProgramacionNoPermitidaFueraDeMacroG8777 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2436: Programación no permitida fuera de macro G8777"@es ;
    ns1:identificador "2436" ;
    ns1:mitigaRiesgo ns1:Macro_G8777 ;
    ns1:solucionaFallo ns1:FuncionG8701_52c4d2a158,
        ns1:FuncionG8702_2f02250cfa,
        ns1:FuncionG8778_bf2eae351e ;
    ns1:textoExtracto "2436 Programación no permitida fuera de una macro G8777. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777. SOLUCIÓN Revisar la programación. Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777."@es .

ns1:Error2437PerfilPoligonalEnMacroG8077 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2437: Perfil poligonal en macro G8077"@es ;
    ns1:identificador "2437" ;
    ns1:textoExtracto "2437 El perfil de la macro G8077 es poligonal. DETECCIÓN Durante la ejecución. CAUSA El perfil debe estar construido con tramos rectos. SOLUCIÓN Modificar el perfil."@es .

ns1:Error2450TransformacionActivaPARALAX a ns1:AvisoSeguridad ;
    rdfs:label "Error 2450: Transformación activa #PARALAX"@es ;
    ns1:identificador "2450" ;
    ns1:textoExtracto "ser Hirth. 2450 #PARALAX: Los ejes de la transformación activa, no pueden excluirse. DETECCIÓN Durante la ejecución. CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una transformación de ejes paralelos. SOLUCIÓN Desactivar la transformación antes de cambiar los ejes del canal."@es .

ns1:Error2451TransformacionDesactivadaPARALAX a ns1:AvisoSeguridad ;
    rdfs:label "Error 2451: Transformación desactivada #PARALAX"@es ;
    ns1:identificador "2451" ;
    ns1:textoExtracto "Se ha desactivado la transformación de ejes paralelos #PARALAX. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los ejes necesarios para la transformación no son adecuados. • Se ha intentando hacer una búsqueda de cero con la función #PARALAX activa. SOLUCIÓN Las posibles soluciones son las siguientes: • Los ejes de una transformación deben ser lineales, pertenecer al canal, no estar aparcados y no ser esclavos de un acoplo o eje gantry. • Desactivar la transformación antes de hacer una búsqueda de referencia."@es .

ns1:Error2452EjesNoLinealesEnPARALAX a ns1:AvisoSeguridad ;
    rdfs:label "Error 2452: Ejes no lineales en #PARALAX"@es ;
    ns1:identificador "2452" ;
    ns1:textoExtracto "Los ejes de la transformación paralela, #PARALAX, deben ser lineales. DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes programados es un eje rotativo. SOLUCIÓN Los ejes programados deben ser lineales."@es .

ns1:Error2453SintaxisDeVectorIncompleta a ns1:AvisoSeguridad ;
    rdfs:label "Error 2453: Sintaxis de vector incompleta"@es ;
    ns1:identificador "2453" ;
    ns1:textoExtracto "Se espera \"}\", programación de fin de vector. DETECCIÓN Durante la preparación de bloques. CAUSA Falta el carácter de cierre \"}\" en la programa de un vector. SOLUCIÓN Revisar la programación. Programar el vector de la forma V{i, j, k}."@es .

ns1:Error2454MemoriaInsuficienteParaCalibracion a ns1:AvisoSeguridad ;
    rdfs:label "Error 2454: Memoria insuficiente para calibración"@es ;
    ns1:identificador "2454" ;
    ns1:textoExtracto "No hay memoria para variables de usuario asociadas a la calibración de cinemáticas. DETECCIÓN Durante la preparación de bloques. CAUSA Las variables de usuario asociadas a la calibración de cinemáticas sólo existen si está activa la opción de software \"Calibración de cinemáticas\". SOLUCIÓN Contratar la correspondiente opción de software."@es .

ns1:Error2455GestionDeArbolDeVariables a ns1:AvisoSeguridad ;
    rdfs:label "Error 2455: Gestión de árbol de variables"@es ;
    ns1:identificador "2455" ;
    ns1:textoExtracto "Error en la gestión del árbol de variables. DETECCIÓN Durante la preparación de bloques. CAUSA Error al crear una nueva variable de usuario. SOLUCIÓN Contacte con Fagor Automation."@es .

ns1:Error24623_PerifericoResuelto a ns1:DiagnosticoFallo ;
    rdfs:label "Error periférico en el módulo %u se ha quitado"@es ;
    ns1:identificador "24623" ;
    ns1:textoExtracto "24623 Error periférico en el módulo %u se ha quitado. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es .

ns1:Error2470ProgramacionTABLECOROTNoPermitida a ns1:AvisoSeguridad ;
    rdfs:label "Error 2470: Programación TABLE/COROT no permitida" ;
    ns1:identificador "2470" ;
    ns1:mitigaRiesgo ns1:Sistema_CinematicaSinMesa ;
    ns1:textoExtracto "Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción TABLE o COROT para una cinemática sin mesa. SOLUCIÓN Revisar la programación." .

ns1:Error2471FicheroDeMaterialTablaObligatorio a ns1:AvisoSeguridad ;
    rdfs:label "Error 2471: Fichero de material/tabla obligatorio" ;
    ns1:documentadoEn ns1:Tabla_TechTable ;
    ns1:identificador "2471" ;
    ns1:textoExtracto "Es obligatorio programar el nombre del fichero de material y/o la tabla seleccionada. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material ni la tabla seleccionada. SOLUCIÓN Revisar la programación. Tanto el fichero de material como la tabla tecnológica son opcionales, pero hay que programar uno de ellos." .

ns1:Error2472FicheroDeMaterialInactivo a ns1:AvisoSeguridad ;
    rdfs:label "Error 2472: Fichero de material inactivo" ;
    ns1:identificador "2472" ;
    ns1:textoExtracto "No hay fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material, y no hay ninguno activo. SOLUCIÓN Activar un fichero de material. La programación del fichero de material sólo es opcional cuando hay uno activo." .

ns1:Error2473NumeroDeSetFueraDeRango a ns1:AvisoSeguridad ;
    rdfs:label "Error 2473: Número de set fuera de rango" ;
    ns1:identificador "2473" ;
    ns1:textoExtracto "Número de set fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número de set (grupo de parámetros) programado en la sentencia #TECHTABLE no es válido o no existe. SOLUCIÓN Revisar la programación. Comprobar que el grupo de parámetros programado existe en la tabla. El rango válido es 1..256." .

ns1:Error2474VariablePiercingSinMaterialValido a ns1:AvisoSeguridad ;
    rdfs:label "Error 2474: Variable Piercing sin material válido" ;
    ns1:identificador "2474" ;
    ns1:monitoreaParametro ns1:VariableTTPIRNameTablaPiercing ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Piercing. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTPIR.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Piercing. SOLUCIÓN Activar un fichero de material que tenga una tabla de Piercing." .

ns1:Error2475VariableCuttingSinMaterialValido a ns1:AvisoSeguridad ;
    rdfs:label "Error 2475: Variable Cutting sin material válido" ;
    ns1:identificador "2475" ;
    ns1:monitoreaParametro ns1:VariableTTCUTNameTablaCutting ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting." .

ns1:Error2492ComodinNoPermitidoFueraDeSubrutinaCAX a ns1:AvisoSeguridad ;
    rdfs:label "Error 2492: Comodín no permitido fuera de subrutina #CAX" ;
    ns1:monitoreaParametro ns1:ParametroMaquinaCAXSUB_92e3aaa506 ;
    ns1:textoExtracto "2492 Comodín no permitido fuera de la subrutina asociada a #CAX. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB). SOLUCIÓN Revisar la programación. No se permite el uso de estos comodines fuera de la subrutina asociada a #CAX." .

ns1:Error2493FaltaProgramacionDelOrigenDelEjeCEnFACECYL a ns1:AvisoSeguridad ;
    rdfs:label "Error 2493: Falta programación del origen del eje C en #FACECYL" ;
    ns1:monitoreaParametro ns1:OrigenDelEjeCGrados ;
    ns1:textoExtracto "2493 #FACE/CYL: se espera \"Q\", programación del origen del eje C, en grados. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el origen del eje C en la instrucción #FACECYL. SOLUCIÓN Revisar la programación." .

ns1:Error2512AnchuraDeRanuraInsuficienteORBIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2512: Anchura de ranura insuficiente (#ORBIT)"@es ;
    ns1:identificador "2512" ;
