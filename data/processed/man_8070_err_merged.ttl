ns1:ErrorSistema a ns1:AvisoSeguridad ;
    rdfs:label "Error de sistema"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Error de sistema."@es .

ns1:ErrorTablaIncorrecta a ns1:AvisoSeguridad ;
    rdfs:label "Error: 'Tipo de tabla seleccionada incorrecta'"@es ;
    ns1:textoExtracto "'Tipo de tabla seleccionada incorrecta' DETECCIÓN Al cargar la tabla de herramientas o almacén. CAUSA El fichero con los datos no corresponde a la tabla que se desea cargar o ha sido modificado externamente."@es .

ns1:Error_0010 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error en test de RAM con batería",
        "Error en test de RAM con batería"@es ;
    ns1:identificador "0010" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El test de arranque ha detectado un error de checksum en los datos de la NVRAM y por lo tanto un fallo en la misma. CONSECUENCIA Los datos guardados pueden no ser correctos (datos relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc). SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor.",
        "0010 'Error en test de RAM con batería' DETECCIÓN Durante el arranque del CNC. CAUSA El test de arranque ha detectado un error de"@es .

ns1:Error_0011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum en los datos de búsqueda de bloque" ;
    ns1:identificador "0011" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Error de cheksum de los datos necesarios para ejecutar una búsqueda de bloque automática. CONSECUENCIA No es posible ejecutar una búsqueda de bloque automática. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:Error_0012 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay tiempo de CPU para ejecutar todos los PREPFREQ" ;
    ns1:identificador "0012" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC necesita demasiado tiempo para analizar el programa. SOLUCIÓN Reducir el número de bloques a preparar por ciclo (parámetro PREPFREQ)." .

ns1:Error_0013 a ns1:DiagnosticoFallo ;
    rdfs:label "ASSERT DEL SISTEMA" ;
    ns1:identificador "0013" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha generado un error sin determinar. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0014 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado Watchdog en la última sesión" ;
    ns1:identificador "0014" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC se ha cerrado debido a un reset por watchdog. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0015 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio del equipo" ;
    ns1:identificador "0015" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0023 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0023: Parada de programa requerida para traza" ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:identificador "0023" ;
    ns1:textoExtracto "0023 'Es necesario parar el programa para iniciar la traza por primera vez' [...] SOLUCIÓN Parar el programa en ejecución." .

ns1:Error_0024 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0024: Fallo al iniciar traza en osciloscopio" ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:identificador "0024" ;
    ns1:textoExtracto "0024 'Error iniciando la traza' [...] SOLUCIÓN Comprobar las variables definidas en los canales del osciloscopio. El osciloscopio sólo puede acceder a dos variables Sercos de cada regulador." .

ns1:Error_0025 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0025: Fallo en registro de defines de PLC" ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:identificador "0025" ;
    ns1:textoExtracto "0025 'Error al registrar defines de PLC' [...] SOLUCIÓN Borrar el archivo plc_prg.sym y compilar el programa PLC para volver a crear este archivo." .

ns1:Error_0037 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta siguiente"@es ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:identificador "0037" ;
    ns1:mitigaRiesgo ns1:GestorHerramientas ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la herramienta siguiente. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta siguiente guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ns1:Error_0038 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de los correctores de herramienta"@es ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:identificador "0038" ;
    ns1:mitigaRiesgo ns1:GestorHerramientas ;
    ns1:textoExtracto "Inconsistencia en la recuperación de los correctores de herramienta. DETECCIÓN Durante el arranque del CNC. CAUSA La información de los correctores guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ns1:Error_0039 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal"@es ;
    ns1:identificador "0039" ;
    ns1:mitigaRiesgo ns1:GestorHerramientas ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la posición en el almacén de la herramienta en el cabezal. DETECCIÓN Durante el arranque del CNC. CAUSA La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es .

ns1:Error_0040 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0040: 'M Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque'"@es ;
    ns1:identificador "0040" ;
    ns1:solucionaFallo ns1:FuncionM_Duplicada ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después. SOLUCIÓN El CNC siempre ejecuta la subrutina asociada a una función M al finalizar el bloque en el que está programada la función. Definir la función M sin sincronización o bien con sincronización Después-Después."@es .

ns1:Error_0041 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0041: 'M duplicada en la tabla'"@es ;
    ns1:identificador "0041" ;
    ns1:solucionaFallo ns1:FuncionM_Duplicada ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. En la tabla de funciones M, hay una función repetida. SOLUCIÓN Corregir la definición de las funciones. En la tabla no puede haber dos funciones M con el mismo número."@es .

ns1:Error_0042 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0042: 'Valor de parámetro máquina no válido'"@es ;
    ns1:identificador "0042" ;
    ns1:solucionaFallo ns1:ParametroMaquina_0042 ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. El parámetro máquina tiene un valor no válido. En la ventana de error aparece cuál es el parámetro erróneo y el valor máximo y mínimo permitido. SOLUCIÓN Asignar al parámetro máquina un valor dentro de los límites permitidos."@es .

ns1:Error_0043 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0043: 'Para asumir nuevo valor es necesario rearrancar el CNC'"@es ;
    ns1:identificador "0043" ;
    ns1:solucionaFallo ns1:ParametroMaquina_0043 ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. El usuario ha modificado un parámetro máquina y es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor. SOLUCIÓN Reiniciar el CNC."@es .

ns1:Error_0044 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0044: 'Nombre de eje no válido o nombre de eje sin definir'"@es ;
    ns1:identificador "0044" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina."@es .

ns1:Error_0115 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0115: Código de validación de CPU no coherente" ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "Código de validación -tipo de CPU-, NO coherente con el"@es .

ns1:Error_0125 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0125: Valor leído de fichero no válido" ;
    ns1:identificador "0125" ;
    ns1:textoExtracto "0125 Valor leído de fichero no válido. DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado datos incorrectos en el archivo que está cargando; por ejemplo, al cargar los datos de calibración no-lineal del gap (#LOAD). SOLUCIÓN Definir los datos correctamente. Consultar en la ventana de error los valores máximo y mínimo." .

ns1:Error_0126 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0126: Lectura/escritura de variable no finalizada (timeout)" ;
    ns1:identificador "0126" ;
    ns1:textoExtracto "0126 Lectura/escritura de variable no finalizada (timeout). DETECCIÓN Durante la ejecución. CAUSA Se ha superado el tiempo mínimo de espera asignado al proceso de lectura/escritura de la variable. SOLUCIÓN Resetear el error. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:Error_0127 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0127: Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD" ;
    ns1:identificador "0127" ;
    ns1:textoExtracto "0127 Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC. CAUSA Alguno de los dispositivos SercosIII no es válido para esta versión de PLD. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_0128 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0128: Error en grabación PLD dispositivo S3, fichero de versión PLD no válido" ;
    ns1:identificador "0128" ;
    ns1:textoExtracto "0128 Error en grabación PLD dispositivo S3, fichero de versión PLD no válido. DETECCIÓN Durante el arranque del CNC. CAUSA La versión de PLD del CNC no es válida para el dispositivo SercosIII. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_0129 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0129: Dispositivo inválido" ;
    ns1:identificador "0129" ;
    ns1:textoExtracto "0129 Dispositivo inválido. DETECCIÓN Durante la ejecución. CAUSA El dispositivo asociado a la variable de regulador que se quiere leer o escribir no es válido. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0130 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0130: EtherCAT no disponible" ;
    ns1:identificador "0130" ;
    ns1:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_0130_EtherCAT_NoDisponible a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0130: EtherCAT no disponible"@es ;
    ns1:identificador "0130" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Contactar con Fagor Automation (error 0130)"@es ;
            ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es ] ;
    ns1:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo."@es .

ns1:Error_0131 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador" ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo ns1:Tabla_DRV ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0131_LecturaVariableRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
            rdfs:label "Contactar con Fagor Automation (error 0131)"@es ;
            ns1:textoExtracto "Póngase en contacto con Fagor Automation."@es ] ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución."@es .

ns1:Error_0132 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0132: Error en la escritura de variable de regulador" ;
    ns1:identificador "0132" ;
    ns1:solucionaFallo ns1:Tabla_DRV ;
    ns1:textoExtracto "0132 Error en la escritura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de escritura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la escritura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0150_HandleEnUso a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: Handle de fichero en uso" ;
    ns1:identificador "0150" ;
    ns1:textoExtracto "0150 #OPEN: handle de fichero en uso. DETECCIÓN Durante la ejecución. CAUSA El handle de fichero indicado en la sentencia #OPEN está siendo usado por el #OPEN de otro fichero. SOLUCIÓN Utilizar un handle de fichero diferente." .

ns1:Error_0150_MaxFicheros a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: Número máximo de ficheros abiertos sobrepasado" ;
    ns1:identificador "0150" ;
    ns1:textoExtracto "0150 'Número máximo de ficheros abiertos sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza con subrutinas globales. CAUSA El número de ficheros abiertos (programa principal más subrutinas externas) es superior a 20. SOLUCIÓN Reducir el número de subrutinas externas abiertas simultáneamente en el programa pieza." .

ns1:Error_0151 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Permiso de escritura denegado" ;
    ns1:textoExtracto "El CNC ha intentado escribir en un archivo que no tiene permiso de escritura. SOLUCIÓN Dar al fichero permiso de escritura." .

ns1:Error_0151_AccesoDenegado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Acceso de escritura denegado" ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "0151 'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura." .

ns1:Error_0151_FicheroNoEncontrado a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Texto o fichero cncWrite.txt no encontrado" ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "0151 #WRITE: texto o fichero cncWrite.txt no encontrado. DETECCIÓN Durante la ejecución. CAUSA No se encuentra el texto correspondiente al identificador programado. Es posible que no exista el archivo cncWrite.txt o que no esté definido el identificador. SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." .

ns1:Error_0153 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0153: Acceso de lectura denegado" ;
    ns1:identificador "0153" ;
    ns1:textoExtracto "0153 'Acceso de lectura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado leer un archivo que no tiene permiso de lectura. SOLUCIÓN Dar al fichero permiso de lectura." .

ns1:Error_0154 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0154: Programa o rutina protegida" ;
    ns1:identificador "0154" ;
    ns1:textoExtracto "0154 'Programa o rutina protegida' DETECCIÓN Durante al acceso a un archivo. CAUSA El CNC ha intentado leer un archivo encriptado, sin tener permiso de acceso. SOLUCIÓN Póngase en contacto con el fabricante de la máquina para obtener los códigos de encriptación del fichero." .

ns1:Error_0163 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0163: #OPEN - Archivo no existe" ;
    ns1:identificador "0163" ;
    ns1:textoExtracto "0163 #OPEN:El fichero o path indicado no existe. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha comprobado que el archivo no existe (comando \"R\"). SOLUCIÓN La sentencia #OPEN está programada para mostrar este error. Para continuar con la ejecución sin dar error, utilizar el comando \"MUTED\"." .

ns1:Error_0166 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0166: Límite de jerk sobrepasado" ;
    ns1:identificador "0166" ;
    ns1:textoExtracto "0166 'Límite de jerk sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza. CAUSA El eje está sobrepasando su límite de jerk permitido. SOLUCIÓN Analizar los casos en los que ocurre y póngase en contacto con el fabricante de la máquina." .

ns1:Error_0167 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0167: No RT IT" ;
    ns1:identificador "0167" ;
    ns1:textoExtracto "0167 'No RT IT' DETECCIÓN Durante el funcionamiento del CNC. CAUSA No entra la interrupción de tiempo real. SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con su proveedor." .

