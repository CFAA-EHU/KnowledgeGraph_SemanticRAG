    rdfs:label "Superado el número de variables permitidas en un telegrama Sercos" ;
    ns1:identificador "4009" ;
    ns1:textoExtracto "Superado el número de variables permitidas en un telegrama Sercos." .

ns1:DiagnosticoFallo_4010 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede escribir parámetro en el regulador'" ;
    ns1:identificador "4010" ;
    ns1:solucionaFallo ns1:Parametro_Regulador_4010 ;
    ns1:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Fallo genérico en la escritura del parámetro. SOLUCIÓN: Revisar el estado de la comunicación con el regulador, versión de software y opciones de parametrización permitidas." .

ns1:DiagnosticoFallo_4011 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede escribir parámetro en el regulador: No IDN'" ;
    ns1:identificador "4011" ;
    ns1:solucionaFallo ns1:Parametro_Regulador_4011 ;
    ns1:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: No existe el parámetro en el regulador. SOLUCIÓN: Actualizar versión de software del regulador." .

ns1:DiagnosticoFallo_4012 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede escribir parámetro en el regulador: Fuera de rango'" ;
    ns1:identificador "4012" ;
    ns1:solucionaFallo ns1:Parametro_Regulador_4012 ;
    ns1:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: El valor del parámetro máquina está fuera del rango permitido. SOLUCIÓN: Corregir el valor del parámetro en el CNC." .

ns1:DiagnosticoFallo_4013 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede escribir parámetro en el regulador: Protegido'" ;
    ns1:identificador "4013" ;
    ns1:solucionaFallo ns1:Parametro_Regulador_4013 ;
    ns1:textoExtracto "DETECCIÓN: Al escribir los parámetros del regulador durante la inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Parámetro protegido contra escritura. SOLUCIÓN: Revisar los permisos y el nivel de acceso en el regulador." .

ns1:DiagnosticoFallo_4014 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en la inicialización del SERCON'" ;
    ns1:identificador "4014" ;
    ns1:solucionaFallo ns1:Sistema_SERCON_4014 ;
    ns1:textoExtracto "DETECCIÓN: Al inicializar el chip de Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA: Número de ejes Sercos o tiempos de Sercos erróneos." .

ns1:DiagnosticoFallo_4015 a ns1:DiagnosticoFallo ;
    rdfs:label "TimeOut en la inicialización del anillo Sercos" ;
    ns1:identificador "4015" ;
    ns1:solucionaFallo ns1:Sistema_Sercos ;
    ns1:textoExtracto "4015 'TimeOut en la inicialización del anillo Sercos' DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. SOLUCIÓN Revisar la configuración y parametrización de Sercos." .

ns1:DiagnosticoFallo_4016 a ns1:DiagnosticoFallo ;
    rdfs:label "El Regulador no es Fagor. Opción de software no permitida" ;
    ns1:identificador "4016" ;
    ns1:solucionaFallo ns1:Sistema_Sercos ;
    ns1:textoExtracto "4016 'El Regulador no es Fagor. Opción de software no permitida' DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA El sistema ha detectado un regulador no Fagor, sin disponer de la opción de software correspondiente. SOLUCIÓN Es necesario activar en el CNC la opción de regulación digital no Fagor para poder conectar regulación Sercos de terceros." .

ns1:DiagnosticoFallo_4017 a ns1:DiagnosticoFallo ;
    rdfs:label "Recalcular valor del parámetro PP4 (HomingSwitchOffset) del regulador" ;
    ns1:identificador "4017" ;
    ns1:solucionaFallo ns1:Sistema_Sercos ;
    ns1:textoExtracto "4017 'Es necesario recalcular el valor del parámetro PP4(HomingSwitchOffset) del regulador' DETECCIÓN En el encendido del CNC. CAUSA El cálculo de módulo ha pasado del regulador al CNC, lo que supone que el valor de PP4 no es válido y es necesario recalcularlo. En el encendido del CNC, este comprueba si en los cabezales y ejes rotativos con módulo hay una relación de transmisión no entera y si el parámetro PP76(7)=1. En este caso, en lugar de escribir un 0 en dicho bit, el CNC muestra un mensaje indicando que hay una mala parametrización en el regulador y que es necesario volver a calcular el valor de PP4 con PP76(7)=0. SOLUCIÓN Desde el modo DDSsetup definir el parámetro PP76(7)=0, validarlo y ejecutar el comando GC6 para que el regulador recalcule el nuevo valor de PP4. Finalmente grabar parámetros en la flash del regulador." .

ns1:DiagnosticoFallo_4018 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación remota Sercos con FEEDBACKTYPE incoherente en diferentes gamas" ;
    ns1:identificador "4018" ;
    ns1:solucionaFallo ns1:Sistema_Sercos ;
    ns1:textoExtracto "4018 Captación remota Sercos con FEEDBACKTYPE incoherente en diferentes gamas. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset." .

ns1:DiagnosticoFallo_4033 a ns1:DiagnosticoFallo ;
    rdfs:label "Parametrizado Gap Control en un regulador que no lo soporta"@es ;
    ns1:identificador "4033" ;
    ns1:solucionaFallo ns1:Parametro_GAPANAINID ;
    ns1:textoExtracto "4033 Parametrizado Gap Control en un regulador que no lo soporta. DETECCIÓN Al inicializar el bus Sercos. CAUSA El parámetro GAPANAINID indica un regulador Fagor cuya versión no soporta control de gap o el regulador no es Fagor. SOLUCIÓN Utilizar un regulador Fagor con versión de software v9.03 o superior, o anular el control de gap interno del regulador."@es .

ns1:DiagnosticoFallo_4034 a ns1:DiagnosticoFallo ;
    rdfs:label "Para Gap Control, el regulador debe ser Sercos Posición"@es ;
    ns1:identificador "4034" ;
    ns1:textoExtracto "4034 Para Gap Control, el regulador debe ser Sercos Posición. DETECCIÓN Al inicializar el bus Sercos. CAUSA El regulador seleccionado para el control de gap no es Sercos posición. SOLUCIÓN Parametrizar correctamente el regulador que debe hacer el control de gap."@es .

ns1:DiagnosticoFallo_4035 a ns1:DiagnosticoFallo ;
    rdfs:label "Para Gap Control, el regulador debe tener REFMODE = Regulador"@es ;
    ns1:identificador "4035" ;
    ns1:solucionaFallo ns1:Parametro_REFMODE ;
    ns1:textoExtracto "4035 Para Gap Control, el regulador debe tener REFMODE = Regulador. DETECCIÓN Al inicializar el bus Sercos. CAUSA El eje seleccionado para el control de gap tiene su parámetro REFMODE definido como \"CNC\", no como \"Regulador\". SOLUCIÓN Definir el parámetro REFMODE del eje como \"Regulador\"."@es .

ns1:DiagnosticoFallo_4036 a ns1:DiagnosticoFallo ;
    rdfs:label "Para Gap Control, el regulador debe tener su captación externa libre"@es ;
    ns1:identificador "4036" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_TarjetaGap_X3 ;
    ns1:textoExtracto "4036 Para Gap Control, el regulador debe tener su captación externa libre. DETECCIÓN Al inicializar el bus Sercos. CAUSA El regulador seleccionado para el control de gap no tiene tarjeta de control de gap instalada (conector X3). SOLUCIÓN Instalar una tarjeta de control de gap en el regulador (conector X3)."@es .

ns1:DiagnosticoFallo_4037 a ns1:DiagnosticoFallo ;
    rdfs:label "El regulador no soporta la escritura síncrona de la variable DRV FFGAIN"@es ;
    ns1:identificador "4037" ;
    ns1:solucionaFallo ns1:Parametro_FFGAIN ;
    ns1:textoExtracto "4037 El regulador no soporta la escritura síncrona de la variable DRV FFGAIN. DETECCIÓN Al inicializar el bus Sercos. CAUSA En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona, y el regulador no es AXD o la versión de software es incompatible."@es .

ns1:DiagnosticoFallo_4506 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:FaltaPotenciaEsclavoMechatrolink_4506 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los"@es .

ns1:DiagnosticoFallo_4703 a ns1:DiagnosticoFallo ;
    rdfs:label "No se encuentra la referencia del eje"@es ;
    ns1:identificador "4703" ;
    ns1:solucionaFallo [ a ns1:AccionProhibida ;
