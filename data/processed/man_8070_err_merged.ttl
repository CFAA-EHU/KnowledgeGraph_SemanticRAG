ns1:AvisoSeguridad_1936 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1936: No se ha definido ningún eje como FACEAXIS en ciclo de eje C" ;
    ns1:identificador "1936" ;
    ns1:solucionaFallo ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "1936 'No se ha definido ningún eje como FACEAXIS en ciclo de eje C' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definido ningún eje frontal en el canal. SOLUCIÓN Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." .

ns1:AvisoSeguridad_1937 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1937: No hay definido ningún eje o cabezal para eje C" ;
    ns1:identificador "1937" ;
    ns1:solucionaFallo ns1:Parametro_CAXIS ;
    ns1:textoExtracto "1937 'No hay definido ningún eje o cabezal para eje C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje C, y no hay ningún eje C en el canal. SOLUCIÓN Definir algún eje o cabezal del canal como eje C (parámetro CAXIS)." .

ns1:AvisoSeguridad_1938 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1938: No hay definido ningún eje para eje Y" ;
    ns1:identificador "1938" ;
    ns1:solucionaFallo ns1:Parametro_GEOCONFIG ;
    ns1:textoExtracto "1938 'No hay definido ningún eje para eje Y' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje Y, y no hay ningún eje Y en el canal. SOLUCIÓN Definir una configuración de ejes tipo triedro en el canal (parámetro GEOCONFIG) con un eje Y." .

ns1:AvisoSeguridad_1950 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1950: No programada la cota Z de la superficie de la pieza" ;
    ns1:identificador "1950" ;
    ns1:solucionaFallo ns1:Parametro_Z ;
    ns1:textoExtracto "1950 'No programada la cota Z de la superficie de la pieza' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación." .

ns1:AvisoSeguridad_1951 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1951: No programada la cota Z de seguridad" ;
    ns1:identificador "1951" ;
    ns1:solucionaFallo ns1:Parametro_Zs ;
    ns1:textoExtracto "1951 'No programada la cota Z de seguridad' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el plano de seguridad (parámetro Zs)." .

ns1:AvisoSeguridad_20008 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando condición #WAIT FOR",
        "Espera superada en condición #WAIT FOR"@es ;
    ns1:identificador "20008" ;
    ns1:textoExtracto "20008 Esperando condición #WAIT FOR. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] o esperar a que se cumpla la condición.",
        "DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El canal debe quedar libre cuando finaliza la ejecución. 20008 Esperando condición #WAIT FOR."@es .

ns1:AvisoSeguridad_20009 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando señal INPOS del cabezal %x" ;
    ns1:identificador "20009" ;
    ns1:textoExtracto "20009 Esperando señal INPOS del cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:AvisoSeguridad_20010 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar proceso de sincronización de cabezales" ;
    ns1:identificador "20010" ;
    ns1:textoExtracto "20010 Esperando finalizar proceso de sincronización de cabezales. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:AvisoSeguridad_20011 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando respuesta del gestor de herramientas en el canal %c" ;
    ns1:identificador "20011" ;
    ns1:textoExtracto "20011 Esperando respuesta del gestor de herramientas en el canal %c. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Esperar a que la herramienta esté disponible, o pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:AvisoSeguridad_20012 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar paso a modo MANUAL del canal %c" ;
    ns1:identificador "20012" ;
    ns1:textoExtracto "20012 Esperando finalizar paso a modo MANUAL del canal %c. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:AvisoSeguridad_20013 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando confirmación de gama por el PLC" ;
    ns1:identificador "20013" ;
    ns1:textoExtracto "20013 Esperando confirmación de gama por el PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe confirmar la nueva gama." .

ns1:AvisoSeguridad_20014 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando final de búsqueda de cero del cabezal %x",
