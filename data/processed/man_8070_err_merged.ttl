ns1:Alarma0080EjeGantryAparcado_40955a7962 a ns1:Alarma ;
    rdfs:label "Alarma 0080: Eje gantry aparcado"@es ;
    ns1:identificador "0080" ;
    ns1:textoExtracto "'no puede estar aparcado' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. gantry está aparcado; la señal CAUSA El CNC ha detectado que el eje esclavo de una pareja PARKED del eje esclavo está activa."@es .

ns1:Alarma1008CoordenadasFueraDeRango_db4d34f600 a ns1:Alarma ;
    rdfs:label "Alarma 1008: Coordenadas fuera de rango" ;
    ns1:identificador "1008" ;
    ns1:mitigaRiesgo ns1:ProgramarCotasUOffsetsExcesivosEnEjes ;
    ns1:textoExtracto "1008 'Coordenadas fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La cota programada para el eje es demasiado grande. • La función G101 intenta incluir en el eje un offset demasiado grande. SOLUCIÓN Revisar la programación." .

ns1:Alarma1015CoordenadasDelCentroFueraDeRango_aa138a71e2 a ns1:Alarma ;
    rdfs:label "Alarma 1015: Coordenadas del centro fuera de rango" ;
    ns1:identificador "1015" ;
    ns1:textoExtracto "'Coordenadas del centro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas. SOLUCIÓN Programar un valor menor." .

ns1:Alarma1016NoSeAdmitenValoresNegativosEnLaProgramacionDeUnEjeEnDiametros_7782a94109 a ns1:Alarma ;
    rdfs:label "Alarma 1016: No se admiten valores negativos en la programación de un eje en diámetros" ;
    ns1:identificador "1016" ;
    ns1:textoExtracto "'No se admiten valores negativos en la programación de un eje en diámetros' DETECCIÓN Durante la ejecución. CAUSA No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros" .

ns1:Alarma1085FaltaEjeEnPlanoActivo_2a54e732e1 a ns1:Alarma ;
    rdfs:label "Alarma 1085: Falta eje en plano activo"@es ;
    ns1:activaAlarma ns1:Sistema_CNC ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "'No se admite G41/G42 si falta el primer o segundo eje del plano activo' DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal."@es .

ns1:Alarma1221LaSentenciaSETAXSeProgramaSolaEnElBloque_452d4eeb0a a ns1:Alarma ;
    rdfs:label "Alarma 1221: 'La sentencia #SET AX se programa sola en el bloque'"@es ;
    ns1:identificador "1221" ;
    ns1:textoExtracto "'La sentencia #SET AX se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la"@es .

ns1:Alarma1248NoSeAdmiteRoscadoYG192EnElMismoBloque_0ce1476c9a a ns1:Alarma ;
    rdfs:label "Alarma 1248: 'No se admite roscado y G192 en el mismo bloque'"@es ;
    ns1:identificador "1248" ;
    ns1:textoExtracto "1248 'No se admite roscado y G192 en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite programar las funciones G63 (roscado rígido) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

ns1:Alarma1262GrupoDeEjesInsuficienteParaTransformacion_ad5205a45a a ns1:Alarma ;
    rdfs:label "Alarma 1262: Grupo de ejes insuficiente para transformación" ;
    ns1:identificador "1262" ;
    ns1:textoExtracto "'El grupo de ejes es insuficiente para la transformación' [...] SOLUCIÓN Corregir la configuración de ejes del canal (sentencia #SET AX) para poder activar la cinemática." .

ns1:Alarma1263FaltaEjeSRotativoParaTransformacion_91253671df a ns1:Alarma ;
    rdfs:label "Alarma 1263: Falta eje(s) rotativo para transformación" ;
    ns1:identificador "1263" ;
    ns1:textoExtracto "'Falta eje(s) rotativo para la transformación' [...] SOLUCIÓN No programar la sentencia #TOOL ORI o activar una cinemática que permita colocar la herramienta perpendicular al plano inclinado." .

ns1:Alarma1271CinematicaActiva_79b31f4f55 a ns1:Alarma ;
    rdfs:label "Alarma 1271: Cinemática activa"@es ;
    ns1:identificador "1271" ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados'"@es .

ns1:Alarma1272EjesDeCinematicaActivaNoModificables_4eb0069e87 a ns1:Alarma ;
    rdfs:label "Alarma 1272: Ejes de cinemática activa no modificables"@es ;
    ns1:identificador "1272" ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar la configuración de ejes de una cinemática mientras ésta estaba activa. SOLUCIÓN Desactivar la cinemática para modificar la configuración de ejes del canal."@es .

ns1:Alarma1275PosicionCalculadaFueraDeRangoEnTransformacionCinematicaInversa_c5e03468d1 a ns1:Alarma ;
    rdfs:label "Alarma 1275: Posición calculada fuera de rango en transformación cinemática inversa"@es ;
    ns1:identificador "1275" ;
    ns1:textoExtracto "'Posición calculada por la transformada cinemática inversa fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer una transformación de coordenadas máquina a coordenadas pieza no resuelta. SOLUCIÓN Desactivar la transformación, cambiar la posición a la que se quiere acceder y volver a activar la transformación."@es .

ns1:Alarma1279SeEsperaComillas_d7e6d774c2 a ns1:Alarma ;
    rdfs:label "Alarma 1279: Se espera comillas" ;
    ns1:identificador "1279" ;
    ns1:textoExtracto "1279 'Se espera \"'\"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada faltan las comillas. SOLUCIÓN Revisar la programación." .

ns1:Alarma1336ConfiguracionErroneaDosEjesCAXIS_d1a750908f a ns1:Alarma ;
    rdfs:label "Alarma 1336: 'Configuración errónea: dos ejes CAXIS'" ;
    ns1:identificador "1336" ;
    ns1:textoExtracto "1336 'Configuración errónea: dos ejes CAXIS' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes" .

ns1:Alarma1340LaDeseleccionNoTieneEfecto_29dfa2bc4a a ns1:Alarma ;
    rdfs:label "Alarma 1340: 'La deselección no tiene efecto'"@es ;
    ns1:identificador "1340" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionCAXOFFSinEjeCActivo ;
    ns1:textoExtracto "1340 'La deselección no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #CAX OFF y no hay ningún cabezal trabajando como eje C."@es .

ns1:Alarma1342NoSeAdmiteCAXOFFSiAlgunaTransformacionEstaActiva_1140eb9255 a ns1:Alarma ;
    rdfs:label "Alarma 1342: 'No se admite #CAX OFF si alguna transformación está activa'"@es ;
    ns1:identificador "1342" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionCAXOFFConRTCPTLCActiva ;
    ns1:textoExtracto "1342 'No se admite #CAX OFF si alguna transformación esta activa' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite desactivar el eje C con la función RTCP o TLC activa."@es .

ns1:Alarma1343NoSeAdmiteFACEOFFConElTipoDeCinematicaActiva_8ce8971d08 a ns1:Alarma ;
    rdfs:label "Alarma 1343: 'No se admite #FACE OFF con el tipo de cinemática activa'"@es ;
    ns1:identificador "1343" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionFACEOFFSinMecanizadoFrontal ;
    ns1:textoExtracto "1343 'No se admite #FACE OFF con el tipo de cinemática activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #FACE OFF y no hay activo ningún mecanizado en la superficie frontal."@es .

ns1:Alarma1344CambioDePlanoNoAdmitidoDuranteMecanizadoLateral_3e51d8ddca a ns1:Alarma ;
    rdfs:label "Alarma 1344: 'No se admite cambio de plano durante el mecanizado en superficie lateral'"@es,
