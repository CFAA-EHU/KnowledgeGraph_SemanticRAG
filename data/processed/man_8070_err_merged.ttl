    ns1:monitoreaParametro ns1:ParametroMPAFACEAXIS_8060b29a09 ;
    ns1:textoExtracto "2137 No se ha definido FACEAXIS. DETECCIÓN Durante la ejecución. CAUSA No hay definido un eje frontal." .

ns1:Error_23024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en fichero de compensación volumétrica (eje 2, límite superior)"@es ;
    ns1:identificador "23024" ;
    ns1:solucionaFallo ns1:ParametroDeCompensacionVolumetricaEje2_8c27040cc4 ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del segundo eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ns1:Error_23025 a ns1:DiagnosticoFallo ;
