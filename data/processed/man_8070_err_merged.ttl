ns1:AvisoSeguridad_1771 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1771: PERFIL DE PUNTOS: P = 0"@es ;
    ns1:monitoreaParametro ns1:Parametro_Profundidad_Planeado_P ;
