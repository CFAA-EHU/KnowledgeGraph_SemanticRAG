ns1:Error_8856 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro de sistema redefinido" ;
    ns1:identificador "8856" ;
    ns1:textoExtracto "Registro de sistema redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (registros) con el mismo nombre. SOLUCIÓN Revisar el nombre de las registros." .

ns1:Error_8857 a ns1:DiagnosticoFallo ;
    rdfs:label "Múltiples módulos PRG" ;
    ns1:identificador "8857" ;
    ns1:textoExtracto "No puede haber mas de un módulo PRG. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programados dos módulos PRG. SOLUCIÓN Sólo puede haber un módulo PRG en el proyecto. Programar las instrucciones de ambos módulos en uno solo." .

ns1:Error_8858 a ns1:DiagnosticoFallo ;
    rdfs:label "Múltiples módulos CY1" ;
    ns1:identificador "8858" ;
    ns1:textoExtracto "No puede haber mas de un módulo CY1. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programados dos módulos CY1. SOLUCIÓN Sólo puede haber un módulo CY1 en el proyecto. Programar las instrucciones de ambos módulos en uno solo." .

ns1:Error_8859 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados módulos periódicos" ;
    ns1:identificador "8859" ;
    ns1:textoExtracto "Demasiados módulos periódicos. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay demasiados módulos periódicos en el programa. SOLUCIÓN Agrupar varios módulos periódicos en una solo." .

ns1:Error_8860 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo periódico redefinido" ;
    ns1:identificador "8860" ;
    ns1:textoExtracto "Módulo periódico redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos módulos periódicos con el mismo periodo. SOLUCIÓN Un proyecto puede tener varios módulos periódicos, pero con diferente periodo. Revisar el periodo de los módulos periódicos. Si dos módulos deben tener el mismo periodo, programarlos en un único módulo." .

ns1:Error_8861 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina redefinida" ;
    ns1:identificador "8861" ;
    ns1:textoExtracto "Subrutina redefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos subrutinas con el mismo nombre. SOLUCIÓN Revisar el nombre de las subrutinas." .

ns1:Error_8862 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiadas subrutinas" ;
    ns1:identificador "8862" ;
    ns1:textoExtracto "Demasiadas subrutinas. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay demasiadas subrutinas definidas en el programa. SOLUCIÓN Utilizar saltos a etiquetas en lugar de subrutinas, o agrupar varias subrutinas en una sola." .

ns1:Error_8863 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta indefinida" ;
    ns1:identificador "8863" ;
    ns1:textoExtracto "Etiqueta indefinida. DETECCIÓN Durante la compilación del programa PLC." .

ns1:Error_8870 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta sin salto en programa PLC"@es ;
    ns1:identificador "8870" ;
    ns1:textoExtracto "programa PLC. CAUSA Hay definida una etiqueta en el programa pero no hay ninguna instrucción de salto a ella (=JMP etiqueta). SOLUCIÓN Revisar las instrucciones de salto o borrar la etiqueta si no se usa."@es .

ns1:Error_8871 a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno: Línea demasiado larga"@es ;
    ns1:identificador "8871" ;
    ns1:textoExtracto "8871 Error interno: Linea demasiado larga. DETECCIÓN Durante la compilación del programa PLC. CAUSA La línea del programa es demasiado larga. SOLUCIÓN Dividir la línea en varias instrucciones."@es .

ns1:Error_8872 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta módulo PRG"@es ;
    ns1:identificador "8872" ;
    ns1:textoExtracto "8872 Falta módulo PRG. DETECCIÓN Durante la compilación del programa PLC. CAUSA No se ha programado el módulo PRG. SOLUCIÓN El módulo PRG debe existir en el programa."@es .

ns1:Error_8873 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer módulos periódicos"@es ;
    ns1:identificador "8873" ;
    ns1:textoExtracto "8873 Fallo del lexer al reconocer módulos periódicos. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a un módulo periódico. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:Error_8874 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina indefinida"@es ;
    ns1:identificador "8874" ;
    ns1:textoExtracto "8874 Subrutina indefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una llamada a una subrutina pero ésta no existe (=CAL subrutina). SOLUCIÓN Revisar el nombre de las subrutinas y las llamadas a subrutinas."@es .

ns1:Error_8875 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro no definido"@es ;
    ns1:identificador "8875" ;
    ns1:textoExtracto "8875 Registro no definido. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA No existe el símbolo programado. SOLUCIÓN Programar un símbolo válido, donde 'Símbolo' puede ser una variable del sistema o un símbolo definido con DEF/PDEF."@es .

ns1:Error_8876 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha podido abrir el fichero de ejes"@es ;
    ns1:identificador "8876" ;
    ns1:textoExtracto "8876 No se ha podido abrir el fichero de ejes. DETECCIÓN Durante la compilación del programa PLC. CAUSA Error abriendo el fichero 'MTB\\DATA\\axeslog.tab'. SOLUCIÓN Comprobar que el fichero existe y que se puede abrir con un editor habitual. Si está corrupto, póngase en contacto con Fagor Automation."@es .

ns1:Error_8877 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay eje físico equivalente al eje lógico"@es ;
    ns1:identificador "8877" ;
    ns1:textoExtracto "8877 No hay eje físico equivalente al eje lógico. DETECCIÓN Durante la compilación del programa PLC."@es .

ns1:Error_8878 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina definida pero no llamada" ;
    ns1:identificador "8878" ;
    ns1:textoExtracto "Subrutina definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una subrutina en el programa pero no hay ninguna instrucción de llamada a ella (=CAL subrutina). SOLUCIÓN Revisar las llamadas a subrutinas o borrar la subrutina si no se usa." .

ns1:Error_8879 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiadas etiquetas" ;
    ns1:identificador "8879" ;
    ns1:textoExtracto "Demasiadas etiquetas. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay demasiadas etiquetas definidas en el programa. SOLUCIÓN Utilizar subrutinas en lugar de saltos a etiquetas." .

ns1:Error_8880 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico. Se esperaba %" ;
    ns1:identificador "8880" ;
    ns1:textoExtracto "Error sintáctico. Se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_8881 a ns1:DiagnosticoFallo ;
    rdfs:label "% en lugar de %" ;
