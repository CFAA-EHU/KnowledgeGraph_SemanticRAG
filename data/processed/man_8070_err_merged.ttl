ns1:Error_8275 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de funciones M en un mismo bloque sobrepasado" ;
    ns1:identificador "8275" ;
    ns1:solucionaFallo ns1:BloqueProgramacion ;
    ns1:textoExtracto "8275 'Límite de funciones M en un mismo bloque sobrepasado' DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones M permitidas en un mismo bloque. SOLUCIÓN El número máximo de funciones M permitidas en un mismo bloque es 7." .

ns1:Error_8276 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de funciones H en un mismo bloque sobrepasado" ;
    ns1:identificador "8276" ;
    ns1:solucionaFallo ns1:BloqueProgramacion ;
    ns1:textoExtracto "8276 'Límite de funciones H en un mismo bloque sobrepasado' DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones H permitidas en un mismo bloque. SOLUCIÓN El número máximo de funciones H permitidas en un mismo bloque es 7." .

ns1:Error_8279 a ns1:DiagnosticoFallo ;
    rdfs:label "Imagen espejo repetida" ;
    ns1:identificador "8279" ;
    ns1:solucionaFallo ns1:FuncionesG10_G14 ;
    ns1:textoExtracto "8279 'Imagen espejo repetida' DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque. La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque." .

ns1:Error_8300 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8300: 'Se precisa al menos un eje para G170, G171 o G157'"@es ;
    ns1:identificador "8300" ;
    ns1:solucionaFallo ns1:Fallo_ProgramacionEjes ;
    ns1:textoExtracto "8300 'Se precisa al menos un eje para G170, G171 o G157' DETECCIÓN Durante la edición. CAUSA No se ha programado ningún eje con la función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157."@es .

ns1:Error_8302 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8302: 'La coordenada X mínima debe ser menor que la máxima'"@es ;
    ns1:identificador "8302" ;
    ns1:solucionaFallo ns1:Fallo_ParametrosCoordenadas ;
    ns1:textoExtracto "8302 'La coordenada X mínima debe ser menor que la máxima' DETECCIÓN Durante la"@es .

ns1:Error_8310 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8310: Parámetro obligatorio faltante" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8310" ;
    ns1:solucionaFallo ns1:ParametroACS_ae850f0b96,
        ns1:ParametroCS_df3908b77c,
        ns1:ParametroPOLY_50cfc12ae5,
        ns1:ParametroPROBE_a70534488a ;
    ns1:textoExtracto "'parámetro obligatorio' DETECCIÓN Durante la edición. CAUSA Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:Error_8311 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8311: Valor de parámetro no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8311" ;
    ns1:solucionaFallo ns1:ParametroACS_ae850f0b96,
        ns1:ParametroCS_df3908b77c,
        ns1:ParametroHSC_31deb152f2,
        ns1:ParametroPOLY_50cfc12ae5 ;
    ns1:textoExtracto "'Valor de parámetro no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido en algún argumento de la sentencia #CS, #ACS, #HSC o #POLY. Valor no válido para el índice de un parámetro aritmético. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias. El índice de un parámetro aritmético debe ser siempre positivo o nulo." .

ns1:Error_8312 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8312: #CS/#ACS modo no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8312" ;
    ns1:solucionaFallo ns1:ModoOperacion_CS_ACS ;
    ns1:textoExtracto "'#CS/#ACS: modo no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido para el comando MODE de la sentencia #CS o #ACS. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:Error_8313 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8313: '#CS/#ACS: número de sistema de coordenadas no válida'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8313" ;
    ns1:solucionaFallo ns1:SistemaCoordenadas ;
    ns1:textoExtracto "8313 '#CS/#ACS: número de sistema de coordenadas no válida' [...] CAUSA Valor no válido para el número de sistema en la sentencia #CS o #ACS. SOLUCIÓN El número de sistema debe tener un valor entre 1 y 5, ambos inclusive."@es .

ns1:Error_8314 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8314: 'Programación incorrecta G30/G73'"@es ;
    ns1:identificador "8314" ;
    ns1:solucionaFallo ns1:ParametroI_d8545c5396,
        ns1:ParametroJFuncionG30G73_6fb2658b72 ;
    ns1:textoExtracto "8314 'Programación incorrecta G30/G73' [...] CAUSA En la función G30/G73 se ha programado sólo uno de los parámetros I, J. SOLUCIÓN Programar ambos parámetros I, J o no programar ninguno."@es .

ns1:Error_8315 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8315: 'Número de ciclo de palpador no válido'"@es ;
    ns1:identificador "8315" ;
    ns1:solucionaFallo ns1:CicloPalpador ;
    ns1:textoExtracto "8315 'Número de ciclo de palpador no válido' [...] CAUSA El número de ciclo de palpador no es válido. SOLUCIÓN Consultar en la documentación los ciclos de palpador válidos."@es .

ns1:Error_8316 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8316: 'Parámetro no permitido'"@es ;
    ns1:identificador "8316" ;
    ns1:textoExtracto "8316 'Parámetro no permitido' [...] DETECCIÓN Durante la edición y ejecución en MDI."@es .

ns1:Error_8327 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8327: 'Falta algún paréntesis'"@es ;
    ns1:identificador "8327" ;
    ns1:textoExtracto "'Falta algún paréntesis' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre. SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre."@es .

ns1:Error_8329 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8329: 'Se esperaba V'"@es ;
    ns1:identificador "8329" ;
    ns1:textoExtracto "8329 'Se esperaba V' DETECCIÓN Durante la edición. CAUSA Se ha programado un nombre de variable que no comienza con el prefijo \"V.\". SOLUCIÓN Todo nombre de variable tanto en el programa pieza como por MDI debe comenzar con el prefijo \"V.\"."@es .

ns1:Error_8330 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8330: 'Se esperaba nombre o número de eje'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8330" ;
    ns1:textoExtracto "8330 'Se esperaba nombre o número de eje' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia o variable programada exige un nombre o número de eje. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable."@es .

ns1:Error_8331 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8331: 'No se esperaba nombre o número de eje'"@es ;
    ns1:identificador "8331" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8331 'No se esperaba nombre o número de eje' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia o variable programada no acepta un nombre o número de eje."@es .

