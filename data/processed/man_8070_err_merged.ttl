    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:solucionaFallo ns1:BaseDatosHerramientas_bd8070 ;
    ns1:textoExtracto "' Error renombrando la herramienta' [...] SOLUCIÓN La base de datos debe tener permiso de escritura."@es .

ns1:Diagnostico_FalloVentilador_64 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Fallo en ventilador de CPU"@es ;
    ns1:solucionaFallo ns1:Ventilador_CPU_64 ;
    ns1:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado."@es .

ns1:Diagnostico_HerramientaNoExistente a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Herramienta %1 no existe o no está cargada"@es ;
    ns1:documentadoEn ns1:TablaHerramientasAlmacen ;
    ns1:solucionaFallo ns1:Herramienta_CNC ;
    ns1:textoExtracto "' La herramienta %1 no existe o no está cargada en el almacén' [...] SOLUCIÓN Definir la herramienta y cargarla en el almacén."@es .

ns1:Diagnostico_NombreHerramientaDuplicado a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Nombre de herramienta duplicado en cabezal/almacén"@es ;
