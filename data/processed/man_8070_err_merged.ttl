ns1:Error_9709 a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento excesivo (9709)"@es ;
    ns1:identificador "9709" ;
    ns1:textoExtracto "9709 Error de seguimiento excesivo. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)."@es .

ns1:Error_9715 a ns1:AvisoSeguridad ;
    rdfs:label "Error en cálculo de I0s codificados" ;
    ns1:identificador "9715" ;
    ns1:textoExtracto "9715 Error en cálculo de I0s codificados. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los I0s latcheados no son coherentes. SOLUCIÓN Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." .

ns1:Error_9718 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo en la sincronización entre módulos" ;
    ns1:identificador "9718" ;
    ns1:textoExtracto "9718 Fallo en la sincronización entre módulos. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los reguladores no se sincronizan entre ellos. SOLUCIÓN Reducir la frecuencia de ejecución de los lazos." .

ns1:Error_9719 a ns1:AvisoSeguridad ;
    rdfs:label "Warning en DrcLoop" ;
    ns1:identificador "9719" ;
    ns1:textoExtracto "9719 Warning en DrcLoop. DETECCIÓN Durante el arranque del sistema, validación de parámetros o cambio de ser en un eje o cabezal. CAUSA Error en el chequeo de coherencia de parámetros de tiempos de ciclo o error en la inicialización de los parámetros de un eje o cabezal. SOLUCIÓN Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Error_9720 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el regulador" ;
    ns1:identificador "9720" ;
    ns1:textoExtracto "9720 Error en el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_9724 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9724: Error en el seguimiento de la rampa de emergencia en frenada" ;
