ns1:Error_Sintaxis a ns1:DiagnosticoFallo ;
    rdfs:label "Carácter programado incorrecto" ;
    ns1:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_SintaxisGeneral a ns1:AvisoSeguridad ;
    rdfs:label "Error de sintaxis: Falta carácter '#' o '$'" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Programada una sentencia sin el carácter \"#\" o una instrucción de control de flujo sin el carácter \"$\". SOLUCIÓN Toda sentencia debe comenzar por el carácter \"#\" y toda instrucción de control de flujo debe comenzar por el carácter \"$\"." .

ns1:Error_SintaxisParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error de sintaxis: Parámetros no programados entre corchetes"@es ;
    ns1:solucionaFallo ns1:Fallo_SintaxisParametros ;
    ns1:textoExtracto "CAUSA La sentencia programada exige que su lista de parámetros se programe entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_flotantes a ns1:AvisoSeguridad ;
