ns1:Error_1030 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1030: '#AXIS programado sin G200/201/202'"@es ;
    ns1:identificador "1030" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la sentencia #AXIS falta programar G200, G201 o G202. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1031 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1031: 'Se espera #AXIS'"@es ;
    ns1:identificador "1031" ;
    ns1:textoExtracto "1031 'Se espera #AXIS' DETECCIÓN Durante la ejecución."@es .

ns1:Error_1085_G41_G42 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1085: No se admite G41/G42 si falta eje del plano activo"@es ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "'No se admite G41/G42 si falta el primer o segundo eje del plano activo' DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal. SOLUCIÓN Definir el plano de trabajo. Si el canal ha cedido sus ejes a otro canales, recuperar el eje que falta"@es .

ns1:Error_1096 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1096: 'No se admite programar la velocidad con E'" ;
    ns1:identificador "1096" ;
    ns1:solucionaFallo ns1:Funcion_F ;
    ns1:textoExtracto "1096 'No se admite programar la velocidad con E' DETECCIÓN Durante la ejecución. CAUSA El avance se ha programado con la función E. SOLUCIÓN Programar el avance con la función F." .

ns1:Error_1097 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1097: 'Nombre de cabezal desconocido'" ;
    ns1:identificador "1097" ;
    ns1:solucionaFallo ns1:Cabezal_S ;
    ns1:textoExtracto "1097 'Nombre de cabezal desconocido' DETECCIÓN Durante la ejecución. CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal. SOLUCIÓN Los nombres válidos para el cabezal son S, S1, …, S9. El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal. Un canal sólo puede controlar sus cabezales." .

ns1:Error_1098 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1098: 'Velocidad S doblemente programada'" ;
    ns1:identificador "1098" ;
    ns1:solucionaFallo ns1:Funcion_S ;
    ns1:textoExtracto "1098 'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones S. SOLUCIÓN En un mismo bloque sólo puede haber una velocidad para cada cabezal." .

ns1:Error_1100 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1100: 'Índice de parámetro fuera de rango'" ;
    ns1:identificador "1100" ;
    ns1:monitoreaParametro ns1:ParametroMaquina ;
    ns1:textoExtracto "1100 'Indice de parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." .

ns1:Error_1108 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1108: 'Eje doblemente programado'"@es ;
    ns1:identificador "1108" ;
    ns1:mitigaRiesgo ns1:Funcion_CYL,
        ns1:Funcion_FACE,
        ns1:Funcion_G0,
        ns1:Funcion_G1,
        ns1:Funcion_G2,
        ns1:Funcion_G20,
        ns1:Funcion_G3,
        ns1:Funcion_G33,
        ns1:Funcion_G63,
        ns1:Funcion_G8,
        ns1:Funcion_G9 ;
    ns1:textoExtracto "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución. CAUSA En alguna de las siguientes funciones hay programado algún eje más de una vez. • Movimiento de ejes en G0, G1, G2, G3, G8 o G9. • Roscado G33 o G63. • Sentencias #FACE o #CYL. • Selección de plano, G20."@es .

ns1:Error_1168 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1168: Índice de variable fuera de rango"@es ;
    ns1:identificador "1168" ;
    ns1:textoExtracto "1168 'Indice de variable fuera de rango' [...] CAUSA Alguno de los índices definidos en la variable de array es incorrecto."@es .

ns1:Error_1169 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1169: Logaritmo de número no válido"@es ;
    ns1:identificador "1169" ;
    ns1:textoExtracto "CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero."@es .

ns1:Error_1181 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1181: Eje esclavo activo en G201" ;
    ns1:identificador "1181" ;
    ns1:textoExtracto "#LINK: no se puede definir como esclavo un eje activo en G201",
        "CAUSA El eje esclavo de un acoplo está activo en modo manual aditivo (G201). SOLUCIÓN Anular el modo manual aditivo para poder acoplar el eje." .

ns1:Error_1182 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1182: Exceso de acoplos programados" ;
    ns1:identificador "1182" ;
    ns1:textoExtracto "#LINK: demasiados acoplos programados",
        "CAUSA El número de acoplos que definidos supera el máximo permitido. SOLUCIÓN El máximo número de acoplos que pueden estar activos en un canal es igual al número de ejes del canal menos tres." .

ns1:Error_1183 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1183: Sentencia #LINK no programada sola" ;
    ns1:identificador "1183" ;
    ns1:textoExtracto "CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación.",
        "La sentencia #LINK se programa sola en el bloque" .

ns1:Error_1184 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1184: Ejes maestro/esclavo coincidentes" ;
    ns1:identificador "1184" ;
    ns1:textoExtracto "#LINK: el eje maestro y esclavo coinciden",
        "CAUSA Los ejes maestro y esclavo del acoplo son el mismo eje. SOLUCIÓN Los ejes maestro y esclavo han de ser diferentes." .

ns1:Error_1185 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1185: Eje esclavo con múltiples maestros" ;
    ns1:identificador "1185" ;
    ns1:textoExtracto "#LINK: un eje no puede ser esclavo de varios maestros",
        "CAUSA Un eje es esclavo de varios maestros. SOLUCIÓN Un eje sólo puede ser esclavo de un maestro." .

ns1:Error_1186 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1186: Eje maestro/esclavo en acoplos cruzados" ;
    ns1:identificador "1186" ;
    ns1:textoExtracto "#LINK: un eje maestro no puede ser esclavo en otro acoplo y viceversa",
        "CAUSA Un eje no puede ser esclavo en un acoplo y mestro en otro. SOLUCIÓN Un eje no puede ser maestro en un acoplo y esclavo en otro." .

ns1:Error_1187 a ns1:AvisoSeguridad,
        ns1:DiagnosticoFallo ;
    rdfs:label "Error 1187: Nombre de eje repetido",
        "Error 1187: '#AXIS: nombre de eje repetido'"@es ;
    ns1:identificador "1187" ;
    ns1:textoExtracto "#AXIS: nombre de eje repetido",
        "CAUSA El mismo eje se ha programado más de una vez en la sentencia.",
        "1187 '#AXIS: nombre de eje repetido' [...] CAUSA El mismo eje se ha programado más de una vez en la sentencia."@es .

ns1:Error_1188 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1188: 'No se espera [\"'"@es ;
    ns1:identificador "1188" ;
    ns1:textoExtracto "1188 'No se espera \"[\"' [...] CAUSA Error en la sintaxis de la sentencia."@es .

ns1:Error_1189 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'"@es ;
    ns1:identificador "1189" ;
    ns1:textoExtracto "1189 '#MPG: demasiados parámetros' [...] CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres"@es .

ns1:Error_1196 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'"@es ;
    ns1:identificador "1196" ;
    ns1:textoExtracto "1196 '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero' DETECCIÓN Durante la ejecución. CAUSA La sentencia #CONTJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en jog continuo debe ser un valor positivo y no nulo."@es .

ns1:Error_1197 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1197: '#SET OFFSET: offset inferior positivo'"@es ;
    ns1:identificador "1197" ;
    ns1:textoExtracto "1197 '#SET OFFSET: offset inferior positivo' DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido inferior del eje para el desplazamiento manual tiene un valor positivo. SOLUCIÓN El límite de recorrido inferior para el desplazamiento manual ser un valor negativo o cero."@es .

ns1:Error_1198 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1198: '#SET OFFSET: límite negativo fuera de rango'"@es ;
    ns1:identificador "1198" ;
    ns1:textoExtracto "1198 '#SET OFFSET: límite negativo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido inferior es demasiado bajo. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1199 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1199: '#SET OFFSET: offset superior negativo'"@es ;
    ns1:identificador "1199" ;
    ns1:textoExtracto "1199 '#SET OFFSET: offset superior negativo' DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido superior del eje para el desplazamiento manual tiene un valor negativo. SOLUCIÓN El límite de recorrido superior para el desplazamiento manual ser un valor positivo o cero."@es .

ns1:Error_1200 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1200: '#SET OFFSET: límite positivo fuera de rango'"@es ;
    ns1:identificador "1200" ;
    ns1:textoExtracto "1200 '#SET OFFSET: límite positivo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido superior es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1201 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1201: '#SET OFFSET: offset superior e inferior nulos'"@es ;
    ns1:identificador "1201" ;
    ns1:textoExtracto "1201 '#SET OFFSET: offset superior e inferior nulos' DETECCIÓN Durante la ejecución. CAUSA Los límites de recorrido del eje para el desplazamiento manual son nulos. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1213 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1213: '#CALL AX con la función G63 activa'"@es ;
    ns1:identificador "1213" ;
    ns1:textoExtracto "CAUSA No se permite programar #CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ns1:Error_1214 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1214: '#CALL AX/#SET AX: demasiados ejes requeridos'"@es ;
    ns1:identificador "1214" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Demasiados ejes programados; el número de ejes supera el número de ejes del sistema. SOLUCIÓN Repasar la configuración de ejes definida para el canal. El número de ejes de un canal no puede superar el número de ejes del sistema."@es .

ns1:Error_1215 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1215: 'La sentencia #CALL AX/#SET AX se programa sola en el bloque'"@es ;
    ns1:identificador "1215" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1216 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1216: '#CALL AX/#CAX: nombre de eje en uso'"@es ;
    ns1:identificador "1216" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El nombre de uno de los ejes está siendo utilizado por un eje C. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1217 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1217: '#CALL AX: índice en uso'"@es ;
    ns1:identificador "1217" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Una de las posiciones está ocupada por otro eje. SOLUCIÓN Repasar la configuración de ejes definida para el canal; dos ejes no pueden estar en la misma posición. Un eje puede utilizar cualquier posición libre comprendida entre 1 y un número igual al máximo de ejes más cabezales permitido por el sistema."@es .

ns1:Error_1218 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1218: 'La sentencia #FREE AX se programa sola en el bloque'"@es ;
    ns1:identificador "1218" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1219 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1219: 'Se espera \",\" o \"]\"'"@es ;
    ns1:identificador "1219" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1220 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1220: '#FREE AX: no se permite eliminar un eje activo en modo manual'"@es ;
    ns1:identificador "1220" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Un eje en modo manual aditivo (G201) no se puede eliminar del canal."@es .

ns1:Error_1229 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1229: Anidamiento de sentencias condicionales sobrepasado" ;
    ns1:identificador "1229" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR," .

ns1:Error_1279 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1279: Falta de comillas en programación" ;
    ns1:identificador "1279" ;
    ns1:textoExtracto "'Se espera \"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada faltan las comillas. SOLUCIÓN Revisar la programación." .

ns1:Error_1281 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1281: Inconsistencia entre parámetros y especificadores de formato",
        "Error 1281: Número de parámetros no coincide"@es ;
    ns1:identificador "1281" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Visualizacion ;
    ns1:textoExtracto "'No coincide el número de parámetros y de especificadores de formato' DETECCIÓN Durante la ejecución. CAUSA El número de identificadores de datos (%D ó %d) indicados en la sentencia #MSG, #ERROR ó #WARNING no coincide con el número de parámetros a visualizar. SOLUCIÓN Revisar la programación.",
        "El número de datos (%D ó %d) indicados en la sentencia #MSG, #ERROR ó #WARNING no coincide con el número de parámetros a visualizar. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1282 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1282: Mensaje demasiado largo",
        "Error 1282: Mensaje demasiado largo"@es ;
    ns1:identificador "1282" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Visualizacion ;
    ns1:textoExtracto "'Mensaje demasiado largo' DETECCIÓN",
        "En la sentencia #MSG, #ERROR o #WARNING, el texto del mensaje es demasiado largo. SOLUCIÓN El máximo número de caracteres permitidos es 69, incluidos los caracteres que sustituyen a los identificadores de datos."@es .

ns1:Error_1283 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1283: Límite de especificadores de formato sobrepasado"@es ;
    ns1:identificador "1283" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Visualizacion ;
    ns1:textoExtracto "En la sentencia #MSG, #ERROR o #WARNING, hay más de 5 identificadores de datos (%D ó %d). SOLUCIÓN Reducir el número de identificadores de datos."@es .

ns1:Error_1284 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1284: Se espera expresión aritmética"@es ;
    ns1:identificador "1284" ;
    ns1:solucionaFallo ns1:InterfazUsuario_Visualizacion ;
    ns1:textoExtracto "En la sentencia #MSG, #ERROR o #WARNING hay identificadores de datos programados (%D ó %d) pero faltan los parámetros a visualizar. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1285 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1285: Doble escritura del radio de herramienta"@es ;
    ns1:identificador "1285" ;
