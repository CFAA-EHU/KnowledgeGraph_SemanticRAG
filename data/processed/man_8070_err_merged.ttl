ns1:solucion_looptime a ns1:AccionProhibida ;
    rdfs:label "Ajuste del parámetro LOOPTIME"@es ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "SOLUCIÓN Ajustar el parámetro LOOPTIME."@es .

ns1:tabla_ejes_gantry_multieje a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry y multieje"@es ;
    ns1:textoExtracto "Corregir la tabla de ejes gantry y multieje."@es .

ns1:Alarma_0020 a ns1:Alarma ;
    rdfs:label "Acceso a variable incorrecto" ;
    ns1:identificador "0020" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_AccesoInvalido ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o al cambiar de página. CAUSA El CNC está accediendo a una variable de interfaz que no existe. SOLUCIÓN Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:Alarma_0078 a ns1:Alarma ;
    rdfs:label "Alarma 0078: Ejes Gantry de canales distintos"@es ;
    ns1:identificador "0078" ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben pertenecer al mismo canal' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún eje gantry está formado por ejes de canales distintos. SOLUCIÓN En un eje gantry, ambos ejes deben pertenecer al mismo canal."@es .

ns1:Alarma_0079 a ns1:Alarma ;
    rdfs:label "Alarma 0079: Eje esclavo Gantry aparcado"@es ;
    ns1:identificador "0079" ;
    ns1:textoExtracto "'Un eje esclavo Gantry no puede estar aparcado' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. gantry está aparcado; la señal CAUSA El CNC ha detectado que el eje esclavo de una pareja"@es .

ns1:Alarma_0098 a ns1:Alarma ;
    rdfs:label "Alarma 0098: Diferencia en parámetro AXISEXCH"@es ;
    ns1:identificador "0098" ;
    ns1:textoExtracto "El eje maestro y el esclavo tienen diferente parámetro AXISEXCH. DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen el parámetro AXISEXCH con diferente valor."@es .

ns1:Alarma_0104 a ns1:Alarma ;
    rdfs:label "Time out de comunicación",
        "Alarma 0104: Timeout de comunicación"@es ;
    ns1:identificador "0104" ;
    ns1:textoExtracto "0104 'Time out de comunicación' DETECCIÓN Durante la ejecución. CAUSA El CNC no finaliza con éxito la lectura o escritura de una variable externa.",
        "'Time out de comunicación'. DETECCIÓN: Durante la ejecución. CAUSA: El CNC no finaliza con éxito la lectura o escritura de una variable externa."@es .

ns1:Alarma_1141 a ns1:Alarma ;
    rdfs:label "Alarma 1141: Sentencia $CONTINUE mal programada"@es ;
    ns1:identificador "1141" ;
    ns1:textoExtracto "1141 'La sentencia $CONTINUE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1142 a ns1:Alarma ;
    rdfs:label "Alarma 1142: Sentencia #TIME mal programada"@es ;
    ns1:identificador "1142" ;
    ns1:textoExtracto "1142 'La sentencia #TIME se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está"@es .

ns1:Alarma_1162 a ns1:Alarma ;
    rdfs:label "No se espera M17/M29/#RET",
        "Alarma 1162: 'No se espera M17/M29/#RET'"@es ;
    ns1:identificador "1162" ;
    ns1:textoExtracto "1162 'No se espera M17/M29/#RET' DETECCIÓN Durante la ejecución. CAUSA El CNC ha",
        "1162 'No se espera M17/M29/#RET' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M17, M29 o #RET como final de programa. SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET."@es .

ns1:Alarma_1163 a ns1:Alarma ;
    rdfs:label "Alarma 1163: 'No se espera M30/M02'"@es ;
    ns1:identificador "1163" ;
    ns1:textoExtracto "1163 'No se espera M30/M02' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M02 o M30 como final de subrutina. SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET."@es .

ns1:Alarma_1164 a ns1:Alarma ;
    rdfs:label "Alarma 1164: 'Término desconocido en expresión matemática'"@es ;
    ns1:identificador "1164" ;
    ns1:textoExtracto "1164 'Término desconocido en expresión matemática' DETECCIÓN Durante la ejecución. CAUSA La expresión matemática es incorrecta. SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc."@es .

ns1:Alarma_1165 a ns1:Alarma ;
    rdfs:label "Alarma 1165: 'Variable inexistente'"@es ;
    ns1:identificador "1165" ;
    ns1:textoExtracto "1165 'Variable inexistente' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable pedida no existe. • Error sintáctico en el nombre de la variable. • La variable es un array y no se ha indicado índice de array. • Se ha pedido una variable general para un eje determinado o a la inversa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1166 a ns1:Alarma ;
    rdfs:label "Alarma 1166: 'Raíz de un número negativo'"@es ;
    ns1:identificador "1166" ;
    ns1:textoExtracto "1166 'Raíz de un número negativo' DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay una raíz cuadrada (SQRT) de un número negativo. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1167 a ns1:Alarma ;
    rdfs:label "Alarma 1167: 'Logaritmo de un número negativo o cero'"@es ;
    ns1:identificador "1167" ;
    ns1:textoExtracto "1167 'Logaritmo de un número negativo o cero' DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1175 a ns1:Alarma ;
    rdfs:label "Alarma 1175: '#LINK: no se ha definido acoplo'"@es ;
    ns1:identificador "1175" ;
    ns1:textoExtracto """\r
    1175 '#LINK: no se ha definido acoplo'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA No hay ningún acoplo de ejes definido en la sentencia #LINK.\r
    SOLUCIÓN Programar los ejes maestro y esclavo en la sentencia #LINK.\r
    """ .

ns1:Alarma_1176 a ns1:Alarma ;
    rdfs:label "Alarma 1176: '#LINK: el eje maestro no pertenece a la configuración de ejes actual'"@es ;
    ns1:identificador "1176" ;
    ns1:textoExtracto """\r
    1176 '#LINK: el eje maestro no pertenece a la configuración de ejes actual'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Las posibles causas son las siguientes:\r
    • El eje maestro del acoplo no existe o no está disponible en el canal.\r
    • El CNC ha intentado anular un acoplo cuyo eje maestro no existe o no está disponible en el canal.\r
    SOLUCIÓN Los ejes maestro y esclavo deben existir en el canal que ejecuta la sentencia.\r
    """ .

ns1:Alarma_1177 a ns1:Alarma ;
    rdfs:label "Alarma 1177: '#LINK: el eje esclavo no pertenece a la configuración de ejes actual'"@es ;
    ns1:identificador "1177" ;
    ns1:textoExtracto """\r
    1177 '#LINK: el eje esclavo no pertenece a la configuración de ejes actual'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Las posibles causas son las siguientes:\r
    • El eje esclavo del acoplo no existe o no está disponible en el canal.\r
    • El CNC ha intentado anular un acoplo cuyo eje esclavo no existe o no está disponible en el canal.\r
    SOLUCIÓN Los ejes maestro y esclavo deben existir en el canal que ejecuta la sentencia.\r
    """ .

ns1:Alarma_1178 a ns1:Alarma ;
    rdfs:label "Alarma 1178: '#LINK: el eje esclavo no puede ser un eje del plano principal'"@es ;
    ns1:identificador "1178" ;
    ns1:textoExtracto """\r
    1178 '#LINK: el eje esclavo no puede ser un eje del plano principal'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA El eje esclavo del acoplo es uno de los tres ejes principales.\r
    SOLUCIÓN Revisar la programación.\r
    """ .

ns1:Alarma_1179 a ns1:Alarma ;
    rdfs:label "Alarma 1179: '#LINK: los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)'"@es ;
    ns1:identificador "1179" ;
    ns1:textoExtracto """\r
    1179 '#LINK: los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)'\r
    DETECCIÓN Durante la ejecución.\r
    CAUSA Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo.\r
    SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE).\r
    """ .

ns1:Alarma_1258 a ns1:Alarma ;
    rdfs:label "Paso de husillo igual cero",
        "Alarma 1258: Paso de husillo igual cero"@es ;
    ns1:identificador "1258" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_PasoHusilloCero ;
    ns1:textoExtracto "1258 'Paso de husillo igual cero' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca tiene valor 0. SOLUCIÓN Revisar la programación. Programar el paso de la rosca con los parámetros I J K.",
        "1258 'Paso de husillo igual cero' [...] CAUSA En la función G33, el paso de la rosca tiene valor"@es .

ns1:Alarma_1264 a ns1:Alarma ;
    rdfs:label "Programación no permitida con CS/ACS activo",
        "Alarma 1264: Programación no permitida con CS/ACS activo"@es ;
    ns1:identificador "1264" ;
    ns1:textoExtracto "1264 'Programación no permitida con CS/ACS activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas.",
        "1264 'Programación no permitida con CS/ACS activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas. Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc. SOLUCIÓN Desactivar la transformación de coordenadas para poder ejecutar el resto de funciones."@es .

ns1:Alarma_1344 a ns1:Alarma ;
    rdfs:label "Alarma 1344: No se admite cambio de plano durante el mecanizado en superficie lateral"@es,
        "No se admite cambio de plano durante el mecanizado en superficie lateral"@es ;
    ns1:identificador "1344" ;
    ns1:textoExtracto "'No se admite cambio de plano durante el mecanizado en superficie lateral' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo (G17-G20) mientras está activo el mecanizado en la superficie lateral. SOLUCIÓN Revisar la programación."@es,
        "1344 'No se admite cambio de plano durante el mecanizado en superficie lateral' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo (G17-G20) mientras está activo el mecanizado en la superficie lateral. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1370 a ns1:Alarma ;
    rdfs:label "Alarma 1370: #HSC: doble programación",
        "Alarma 1370: Doble programación en modo HSC"@es ;
    ns1:identificador "1370" ;
    ns1:textoExtracto "1370 '#HSC: doble programación' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque está programada la activación y desactivación del modo HSC. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias.",
        "#HSC: doble programación"@es .

ns1:Alarma_1419 a ns1:Alarma ;
    rdfs:label "'No se permite aparcar ejes acoplados, Gantry o Tandem'" ;
    ns1:identificador "1419" ;
    ns1:textoExtracto "1419 'No se permite aparcar ejes acoplados, Gantry o Tandem' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado aparcar un eje que forma parte de una pareja gantry, tándem o de un acoplo activo (#LINK)." .

ns1:Alarma_1433 a ns1:Alarma ;
    rdfs:label "Alarma 1433: Configuración de eje aparcado",
        "Alarma 1433: Configuración de eje aparcado"@es ;
    ns1:identificador "1433" ;
    ns1:textoExtracto "No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución.",
        "1433 No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado. SOLUCIÓN Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)."@es .

ns1:Alarma_1439 a ns1:Alarma ;
    rdfs:label "Alarma 1439: Los ejes de la transformación activa no pueden ser Hirth" ;
    ns1:identificador "1439" ;
    ns1:textoExtracto "'Los ejes de la transformación activa no pueden ser Hirth' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación de coordenadas (#TLC, #RTCP, #TOOL ORI, #CS o #ACS) y uno de los ejes que intervienen en la transformación es Hirth. SOLUCIÓN Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)." .

ns1:Alarma_1439_parada_bloque a ns1:Alarma ;
    rdfs:label "Alarma: Falta definir el bloque de parada de la búsqueda de bloque" ;
    ns1:identificador "parada_bloque" ;
    ns1:textoExtracto "'de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque. SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en el menú de softkeys aparece la opción para seleccionar el bloque parada. Seleccionar el bloque en el que se desea finalizar la búsqueda de bloque." .

ns1:Alarma_1441 a ns1:Alarma ;
    rdfs:label "Alarma 1441: No se ha activado la cinemática" ;
    ns1:identificador "1441" ;
    ns1:textoExtracto "'No se ha activado la cinemática' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA La cinemática que aplica el CNC por defecto (parámetro KINID) es desconocida o los ejes necesarios para la cinemática no son los adecuados. SOLUCIÓN Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry." .

ns1:Alarma_1442 a ns1:Alarma ;
    rdfs:label "Alarma 1442: Se ha desactivado la cinemática",
        "Alarma 1442: 'Se ha desactivado la cinemática'"@es ;
    ns1:identificador "1442" ;
    ns1:textoExtracto "'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza.",
        "1442 'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza. CAUSA El CNC ha desactivado una cinemática, bien porque es una cinemática desconocida ó bien porque los ejes necesarios para esa cinemática no son los adecuados."@es .

ns1:Alarma_1447 a ns1:Alarma ;
    rdfs:label "Alarma 1447: Opción de software no permitida",
        "Alarma 1447: 'Opción de software no permitida'"@es ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "'Opción de software no permitida'",
        "1447 'Opción de software no permitida' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El CNC no dispone de la opción de software necesaria para ejecutar la orden programada. •"@es .

ns1:Alarma_1470 a ns1:Alarma ;
    rdfs:label "Eje rotativo UNIDIR con programación incremental incorrecta"@es ;
    ns1:identificador "1470" ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota incremental programada para el eje rotativo unidireccional (parámetro UNIDIR) no es válida."@es .

ns1:Alarma_1500 a ns1:Alarma ;
    rdfs:label "Error de ejecución en canal CNC"@es ;
    ns1:identificador "1500" ;
    ns1:textoExtracto "Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático."@es .

ns1:Alarma_1650 a ns1:Alarma ;
    rdfs:label "Función de transformación directa de usuario no encontrada" ;
    ns1:identificador "1650" ;
    ns1:textoExtracto "1650 'Función de transformación directa de usuario no encontrada' DETECCIÓN Durante la ejecución. CAUSA Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario." .

ns1:Alarma_2409 a ns1:Alarma ;
    rdfs:label "Alarma 2409: Conflicto en eje esclavo 'LASER FOLLOW AXIS'"@es ;
    ns1:identificador "2409" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_2409_Solucion ;
    ns1:textoExtracto "2409 No se puede programar el eje esclavo \"LASER FOLLOW AXIS\". DETECCIÓN Durante la preparación de bloques. CAUSA El nombre de eje esclavo en #FOLLOW ON [MASTER, eje esclavo] coincide con el parámetro máquina LASERFOLLOWAXIS."@es .

ns1:Alarma_2456 a ns1:Alarma ;
    rdfs:label "Alarma 2456: Conflicto con #GAPPOS y modificación de ejes" ;
    ns1:identificador "2456" ;
    ns1:textoExtracto "Con #GAPPOS activo no se permite cambiar los tres primeros ejes. DETECCIÓN Durante la preparación de bloques. CAUSA Se ha intentado modificar los tres primeros ejes del canal (#FREEAX o #SETAX) mientras la sentencia #GAPPOS está activa. SOLUCIÓN No modificar los tres primeros ejes del canal antes de la sentencia #GAPPOS o #GAPCTRL esté activa." .

ns1:Alarma_3104 a ns1:Alarma ;
    rdfs:label "Alarma 3104: Colisión detectada"@es,
        "Colisión detectada"@es ;
    ns1:identificador "3104" ;
    ns1:textoExtracto "3104 Se ha detectado una colisión."@es,
        "3104 Se ha detectado una colisión. DETECCIÓN Durante la ejecución o la simulación de un programa pieza. Durante la ejecución en MDI. CAUSA FCAS(Fagor Collision Avoidance System) ha detectado una colisión en alguno de los movimientos que va a ejecutar o simular. SOLUCIÓN Revisar la programación y modificar el programa pieza."@es .

ns1:Alarma_3511 a ns1:Alarma ;
    rdfs:label "Cancelada M3 o M4 de PLC en G96 sin S programada" ;
    ns1:identificador "3511" ;
    ns1:textoExtracto "3511 Cancelada M3 o M4 de PLC en G96 sin S programada. DETECCIÓN Durante la ejecución. CAUSA Se ha solicitado giro de cabezal M3/M4 en G96 sin S programada. El CNC ignora las funciones M3/M4. SOLUCIÓN Revisar programación de G96 y S." .

ns1:Alarma_3600 a ns1:Alarma ;
    rdfs:label "'Velocidad de cabezal nula'" ;
    ns1:identificador "3600" ;
    ns1:textoExtracto "3600 'Velocidad de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA No existe una velocidad de posicionamiento de cabezal programada. SOLUCIÓN Revisar la programación y que los parámetros REFFEED2 y G00FEED de la gama activa del cabezal sean distintos de cero." .

ns1:Alarma_3601 a ns1:Alarma ;
    rdfs:label "'Velocidad de cabezal programada superior al límite máximo'" ;
    ns1:identificador "3601" ;
    ns1:textoExtracto "3601 'Velocidad de cabezal programada superior al límite máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad programada para el cabezal supera la velocidad máxima definida en los parámetros máquina para la gama activa. SOLUCIÓN Revisar el parámetro G00FEED del cabezal." .

ns1:Alarma_3602 a ns1:Alarma ;
    rdfs:label "'No se puede mover el cabezal en modo visualizador'" ;
    ns1:identificador "3602" ;
    ns1:textoExtracto "3602 'No se puede mover el cabezal en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta controlar un cabezal que se encuentra en modo visualizador. SOLUCIÓN El CNC no puede controlar los cabezales activos en modo visualizador. Para desplazar el eje, desactivar el modo visualizador (marca DRO(axis) del PLC) y comprobar el estado de la marca SERVOON del cabezal." .

ns1:Alarma_3603 a ns1:Alarma ;
    rdfs:label "'La posición del cabezal comandada excede el rango de módulo'" ;
    ns1:identificador "3603" ;
    ns1:textoExtracto "3603 'La posición del cabezal comandada excede el rango de módulo' DETECCIÓN Durante la ejecución. CAUSA El CNC está intentando posicionar el cabezal en una cota que está fuera del rango permitido (parámetros MODUPLIM y MODLOWLIM). SOLUCIÓN Revisar los parámetros MODUPLIM y MODLOWLIM." .

ns1:Alarma_3604 a ns1:Alarma ;
    rdfs:label "'Sentido del posicionamiento de cabezal contrario al de parámetro máquina'" ;
    ns1:identificador "3604" ;
    ns1:textoExtracto "3604 'Sentido del posicionamiento de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución." .

ns1:Alarma_3715 a ns1:Alarma ;
    rdfs:label "Sobrepasamiento en la compensación de módulo" ;
    ns1:identificador "3715" ;
    ns1:textoExtracto "3715 'Sobrepasamiento en la compensación de módulo' DETECCIÓN Durante el movimiento de un eje rotativo o cabezal. CAUSA En los eje Sercos posición, el CNC mantiene la cuenta de la compensación de módulo de forma absoluta; si todos los movimientos del eje se realizan en el mismo sentido, el CNC va acumulando la compensación. SOLUCIÓN Realizar una búsqueda de referencia máquina." .

ns1:Alarma_3717 a ns1:Alarma ;
    rdfs:label "Superado umbral de contaje del encoder" ;
    ns1:identificador "3717" ;
    ns1:textoExtracto "3717 Superado umbral de contaje del encoder. Buscar cero para recuperar cota. DETECCIÓN Durante la ejecución. CAUSA El encóder del eje o cabezal ha superado la velocidad de giro máxima permitida. Al superar este límite, el eje o cabezal ha perdido el punto de referencia, por lo que las cotas leídas no son correctas." .

ns1:Alarma_3727 a ns1:Alarma ;
    rdfs:label "Alarma 3727: No se permite desactivar un eje múltiple sin entrar en posición"@es,
        "No se permite desactivar un eje múltiple sin entrar en posición"@es ;
    ns1:identificador "3727" ;
