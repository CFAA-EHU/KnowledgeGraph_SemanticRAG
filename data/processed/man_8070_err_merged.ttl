ns1:Error8815 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8815: entrada digital fuera de rango" ;
    ns1:identificador "8815" ;
    ns1:textoExtracto "Entrada fuera de rango permitido. [...] SOLUCIÓN Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16." .

ns1:Error8816 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8816: salida digital fuera de rango" ;
    ns1:identificador "8816" ;
