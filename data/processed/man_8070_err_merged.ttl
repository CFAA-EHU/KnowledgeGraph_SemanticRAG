ns1:Diagnostico_ParametroNoModificable a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro máquina sin permiso de escritura" ;
    ns1:monitoreaParametro ns1:Parametro_1587 ;
    ns1:textoExtracto "El parámetro máquina no tiene permiso de escritura desde el entorno de la puesta a punto" .

ns1:Diagnostico_PerdidaDatosCNC a ns1:DiagnosticoFallo ;
