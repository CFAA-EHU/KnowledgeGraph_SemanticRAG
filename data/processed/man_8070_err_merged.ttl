    ns1:monitoreaParametro ns1:Parametro_F_1735 ;
    ns1:textoExtracto "1735 'CAJERA RECTANGULAR: F = 0' [...] CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z." .

ns1:Alarma_1736 a ns1:Alarma ;
    rdfs:label "Alarma 1736: CAJERA RECTANGULAR - S = 0" ;
    ns1:monitoreaParametro ns1:Parametro_S_1736 ;
    ns1:textoExtracto "1736 'CAJERA RECTANGULAR: S = 0' [...] CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." .

