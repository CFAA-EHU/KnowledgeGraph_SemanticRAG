    ns1:solucionaFallo ns1:Alarma_Generica_PerdidaDatos ;
    ns1:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se han perdido. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor."@es .

ns1:Diagnostico_SenalAlta_Inductosyn a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Señal incremental demasiado alta en transductor Inductosyn/Resolver" ;
    ns1:solucionaFallo ns1:Cable_ABSIND_Transductor,
        ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto. Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Diagnostico_SenalBaja_Inductosyn a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Señal incremental demasiado baja en transductor Inductosyn/Resolver" ;
    ns1:solucionaFallo ns1:Cable_ABSIND_Transductor,
        ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo. Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Directiva_CAL a ns1:Parametro ;
    rdfs:label "Directiva CAL" ;
    ns1:identificador "CAL" ;
    ns1:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

