ns1:Error_9654 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Pérdida de sincronización"@es ;
    ns1:identificador "9654" ;
    ns1:solucionaFallo ns1:Encoder_9654 ;
    ns1:textoExtracto "9654 Captación digital Fagor: Pérdida de sincronización SOL. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error de comunicación del encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:Error_9655 a ns1:DiagnosticoFallo ;
    rdfs:label "Pulso de I0 no detectado"@es ;
    ns1:identificador "9655" ;
    ns1:solucionaFallo ns1:Encoder_9655 ;
    ns1:textoExtracto "9655 Pulso de I0 no detectado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador no ha recibido la señal de I0. SOLUCIÓN Revisar la parametrización y el conexionado del encoder."@es .

ns1:Error_9656 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta fase en la tarjeta sense"@es ;
    ns1:identificador "9656" ;
    ns1:solucionaFallo ns1:TarjetaSense_9656 ;
    ns1:textoExtracto "9656 Falta fase en la tarjeta sense. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Una fase de red no llega correctamente a la tarjeta sense. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:Error_9657 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 80%"@es ;
    ns1:identificador "9657" ;
    ns1:solucionaFallo ns1:TarjetaSense_9657 ;
    ns1:textoExtracto "9657 Nivel de tensión por debajo del 80%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:Error_9658 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 70%"@es ;
    ns1:identificador "9658" ;
    ns1:solucionaFallo ns1:TarjetaSense_9658 ;
