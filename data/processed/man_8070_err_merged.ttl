ns1:DiagnosticoFallo_4706 a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de nodo no permitido"@es ;
    ns1:identificador "4706" ;
    ns1:textoExtracto "Tipo de nodo no permitido. DETECCIÓN Durante la detección nodos bus. CAUSA El control no dispone de la opción de software necesaria para inicializar ese tipo de nodo. SOLUCIÓN En diagnosis se puede comprobar las opciones de software activas."@es .

ns1:DiagnosticoFallo_4707 a ns1:DiagnosticoFallo ;
    rdfs:label "Superado máximo número de nodos"@es ;
