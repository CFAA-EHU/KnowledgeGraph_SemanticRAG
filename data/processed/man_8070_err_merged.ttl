ns1:alarma_E411 a ns1:Alarma ;
    rdfs:label "E411 - Error de recepción de telegramas" ;
    ns1:activaAlarma ns1:modulo_RCS_S ;
    ns1:identificador "E411" ;
    ns1:textoExtracto "E411 Error de recepción de telegramas. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:alarma_E412 a ns1:Alarma ;
    rdfs:label "E412 - Mensaje de sincronismo retrasado" ;
    ns1:activaAlarma ns1:modulo_RCS_S ;
    ns1:identificador "E412" ;
    ns1:textoExtracto "E412 Mensaje de sincronismo retrasado. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:alarma_E413 a ns1:Alarma ;
    rdfs:label "E413 - Error de handshake en la contadora Sercos" ;
    ns1:activaAlarma ns1:modulo_RCS_S ;
    ns1:identificador "E413" ;
    ns1:textoExtracto "E413 Error de handshake en la contadora Sercos. El elemento master (CNC) envía un mensaje de sincronismo en cada ciclo (4ms, normalmente) que hace que los reguladores se sincronicen. Si en algún momento no pueden sincronizarse o pierden sincronización se origina este error. Posiblemente el CNC no ha enviado este mensaje o si lo ha hecho no ha sido en el momento exacto. Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión." .

ns1:anillo_fibra_optica a ns1:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica" ;
    ns1:textoExtracto "Problemas en la comunicación a través del **anillo de fibra óptica**. Verifíquense las conexiones en el anillo y la identificación de cada módulo." ;
    ns1:tieneComponente ns1:modulo_RCS_S .

ns1:aviso_seguridad_3093 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 3093"@es ;
    ns1:mitigaRiesgo ns1:alarma_3093 ;
    ns1:textoExtracto "SOLUCIÓN Mantener los ejes fuera de los límites de la zona de trabajo de no entrada. Si la herramienta está dentro de la zona prohibida, desactivar temporalmente dicha zona, mover el eje en el sentido adecuado mediante el"@es .

