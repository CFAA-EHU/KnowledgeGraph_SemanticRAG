ns1:Error_G264 a ns1:AvisoSeguridad ;
    rdfs:label "Error de programación: Radio nulo en interpolación circular (G264 activa)"@es ;
    ns1:identificador "G264" ;
    ns1:textoExtracto "Con la función G264 activa, ambas coordenadas del centro son cero. SOLUCIÓN El radio de una interpolación circular no puede ser nulo. Ambas coordenadas del centro de una interpolación circular no pueden ser nulas."@es .

ns1:Error_HerramientaDesconocida a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Herramienta y/o corrector no existe" ;
