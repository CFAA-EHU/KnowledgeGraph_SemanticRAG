ns1:LINKLosEjesMaestroYEsclavoDebenTenerLosMismosParametrosHIRTHYHPITCH a ns1:DiagnosticoFallo ;
    rdfs:label "#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH" ;
