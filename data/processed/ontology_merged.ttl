ns5:SistemaAireComprimidoExemplo a ns5:SistemaAireComprimido,
        owl:NamedIndividual ;
    ns5:tieneCaudal ns5:CaudalExemplo ;
    ns5:tieneFiltracion ns5:FiltracionExemplo ;
    ns5:tienePresion ns5:PresionExemplo ;
    ns5:tieneSecado ns5:SecadoExemplo .

ns5:tieneCaudal a owl:ObjectProperty ;
    rdfs:domain ns5:SistemaAireComprimido ;
    rdfs:range ns5:Caudal .

