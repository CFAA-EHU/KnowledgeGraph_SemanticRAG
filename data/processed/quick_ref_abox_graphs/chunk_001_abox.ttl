@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BACKKey a ns1:Parametro ;
    rdfs:label "BACK key" ;
    ns1:textoExtracto "BACK key. BACK On the horizontal softkey menu, it may be used to go from a softkey submenu up to the previous menu." ;
    ns1:valor "BACK" .

ns1:FOCUSKey a ns1:Parametro ;
    rdfs:label "FOCUS key" ;
    ns1:textoExtracto "FOCUS key. FOCUS It is used to switch between the different windows of the screen." ;
    ns1:valor "FOCUS" .

ns1:FunctionKeysF1ThroughF12 a ns1:Parametro ;
    rdfs:label "Function keys F1 through F12" ;
    ns1:textoExtracto "F1 Keys F1 through F12 select the options of the softkey menus." ;
    ns1:valor "F1-F12" .

ns1:HELPKey a ns1:Parametro ;
    rdfs:label "HELP key" ;
    ns1:textoExtracto "HELP key. HELP Display CNC help." ;
    ns1:valor "HELP" .

ns1:InterfazUsuarioTecladoMonitoreo a ns1:InterfazUsuario ;
    rdfs:label "Monitor & Keyboard" ;
    ns1:documentadoEn ns1:ManualDeProgramacion ;
    ns1:textoExtracto "HELP key. HELP Display CNC help."@en .

ns1:NEXTKey a ns1:Parametro ;
    rdfs:label "NEXT key" ;
    ns1:textoExtracto "NEXT key. NEXT OEM configurable table." ;
    ns1:valor "NEXT" .

