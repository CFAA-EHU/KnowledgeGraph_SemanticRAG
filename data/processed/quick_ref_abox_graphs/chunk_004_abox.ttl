@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_332c95891a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "The CNC assumes the machine reference zero point (home) as the new part zero." .

ns1:HomeSearchAutomatico a ns1:TareaMantenimiento ;
    rdfs:label "Home Search Automático" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Automatic home search (with subroutine)." .

ns1:HomeSearchManual a ns1:TareaMantenimiento ;
    rdfs:label "Home Search Manual" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Manual home search (one axis at a time)." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Técnico Autorizado" ;
    ns1:textoExtracto "Press [START] to go ahead with the home search or [ESC] to cancel the operation." .

