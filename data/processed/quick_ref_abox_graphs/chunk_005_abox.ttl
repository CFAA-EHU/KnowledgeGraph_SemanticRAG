@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_JogContinuo a ex:ModoOperacion ;
    rdfs:label "continuous jog" ;
    ex:textoExtracto "Movement in continuous jog. In continuous jog, the axes keep moving while the jog keyboard is acted upon." ;
    ex:valor "10 1 1 10 jog" .

ex:ModoOperacion_JogIncremental a ex:ModoOperacion ;
    rdfs:label "incremental jog" ;
    ex:textoExtracto "Movement in incremental jog. In incremental jog, the axis moves a specific distance every time the key is pressed." ;
    ex:valor "10 1 1 10 jog" .

ex:ModoOperacion_JogConManivelasGeneral a ex:ModoOperacion ;
    rdfs:label "General handwheel" ;
    ex:textoExtracto "General handwheel (it may be used to jog any axis of the machine)." ;
    ex:valor "10 1 1 10 jog" .

ex:ModoOperacion_JogConManivelasIndividual a ex:ModoOperacion ;
    rdfs:label "Individual handwheel" ;
    ex:textoExtracto "Individual handwheel (it is associated with a particular axis)." ;
    ex:valor "10 1 1 10 jog" .

ex:InterfazUsuario_PanelJOG a ex:InterfazUsuario ;
    rdfs:label "JOG panel (keypad)" ;
    ex:textoExtracto "Jog the desired axis using the JOG panel (keypad)." .

ex:InterfazUsuario_SelectorJOG a ex:InterfazUsuario ;
    rdfs:label "jog selector switch" ;
    ex:textoExtracto "Turn the jog selector switch to the continuous JOG position." , "Turn the jog selector switch to one of the incremental jog positions." , "Turn the jog selector switch to one of the handwheel positions." .

ex:InterfazUsuario_Manivelas a ex:InterfazUsuario ;
    rdfs:label "handwheel" ;
    ex:textoExtracto "Once the axis has been selected, the CNC will move it as the handwheel is turned depending on the setting of the selector switch and on the turning direction of the handwheel." , "The CNC moves each axis as its relevant handwheel is turned depending on the setting of the selector switch and on the turning direction of the handwheel." .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "The CNC will highlight the selected axes." , "The CNC moves each axis as its relevant handwheel is turned" .