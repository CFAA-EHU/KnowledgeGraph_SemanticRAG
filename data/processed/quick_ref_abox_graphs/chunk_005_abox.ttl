@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GeneralHandwheel a ns1:TareaMantenimiento ;
    rdfs:label "General handwheel" ;
    ns1:textoExtracto "General handwheel (it may be used to jog any axis of the machine)." .

ns1:IndividualHandwheel a ns1:TareaMantenimiento ;
    rdfs:label "Individual handwheel" ;
    ns1:textoExtracto "Individual handwheel (it is associated with a particular axis)." .

ns1:InterfazUsuarioPanelJog a ns1:InterfazUsuario ;
    rdfs:label "JOG panel (keypad)" ;
    ns1:textoExtracto "Jog the desired axis using the JOG panel (keypad)." .

ns1:MovementInContinuousJog a ns1:TareaMantenimiento ;
    rdfs:label "Movement in continuous jog" ;
    ns1:textoExtracto "In continuous jog, the axes keep moving while the jog keyboard is acted upon." .

ns1:MovementInIncrementalJog a ns1:TareaMantenimiento ;
    rdfs:label "Movement in incremental jog" ;
    ns1:textoExtracto "In incremental jog, the axis moves a specific distance every time the key is pressed." .

