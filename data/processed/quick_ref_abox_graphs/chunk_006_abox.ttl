@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_986af5d846 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CoordinatePreset ;
    ns1:textoExtracto "The CNC will highlight the coordinate of that axis." .

ns1:InterfazUsuarioSoftkeyMenu a ns1:InterfazUsuario ;
    rdfs:label "Softkey menu" ;
    ns1:textoExtracto "1 Press the softkey for presetting axes to show the list of axes of the channel and select an axis. The CNC will highlight the coordinate of that axis." .

ns1:InterfazUsuarioTeclado a ns1:InterfazUsuario ;
    rdfs:label "Keyboard" ;
    ns1:textoExtracto "1 Select the axis to be preset (on alphanumeric keyboard). The CNC will highlight the coordinate of that axis." .

ns1:CoordinatePreset a ns1:TareaMantenimiento ;
    rdfs:label "Coordinate Preset" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "The [ESC] key may be used to cancel the operation at any time." .

