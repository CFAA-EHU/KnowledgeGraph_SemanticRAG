@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_986af5d846 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "The CNC will highlight the coordinate of that axis." .

ns1:InterfazUsuarioTeclado a ns1:InterfazUsuario ;
    rdfs:label "Keyboard" ;
    ns1:textoExtracto "[ESC] key may be used to cancel the operation at any time. | Keyboard." .

ns1:MoveAnAxisToAParticularPosition a ns1:TareaMantenimiento ;
    rdfs:label "Move an Axis to a Particular Position" ;
    ns1:ejecutadoPor ns1:PersonalOperario ;
    ns1:textoExtracto "Select the axis to be moved, enter the target point coordinate and press [START] to make the move." .

ns1:PersonalOperario a ns1:Personal ;
    rdfs:label "Operator" ;
    ns1:textoExtracto "Enter the coordinate of the target point." .

