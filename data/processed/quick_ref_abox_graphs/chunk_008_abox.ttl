@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Feedrate a ex:Parametro ;
    rdfs:label "Feedrate"@en ;
    ex:textoExtracto "Feedrate. |  | F | 1 Press [F] at the alphanumeric keyboard. 2 Enter the new feedrate. |  | 3 Press [START] to assume the entered value or [ESC] to cancel the operation."@en .

ex:Speed a ex:Parametro ;
    rdfs:label "Speed"@en ;
    ex:textoExtracto "Speed. | S | 1 Press [S] at the alphanumeric keyboard until selecting the desired spindle. When pressing this key for the first time, the CNC will highlight the relevant data indicating that it is selected. 2 Enter the new spindle speed. |  | 3 Press [START] to assume the entered value or [ESC] to cancel the operation."@en .

ex:Tool a ex:Parametro ;
    rdfs:label "Tool"@en ;
    ex:textoExtracto "Tool. | T | 1 Press [T] on the alphanumeric keyboard. 2 Enter the tool to be selected. |  | 3 Press [START] to assume the entered value or [ESC] to cancel the operation."@en .

ex:JOG_keypad a ex:InterfazUsuario ;
    rdfs:label "JOG keypad"@en ;
    ex:textoExtracto "JOG keypad. Increases or decreases the percentage of spindle speed."@en .

ex:Switch a ex:InterfazUsuario ;
    rdfs:label "Switch"@en ;
    ex:textoExtracto "Switch. It sets the percentage of turning speed to be applied."@en .

ex:TablaVelocidades a ex:Tabla ;
    rdfs:label "Tabla de velocidades"@en ;
    ex:textoExtracto "70 80 90 100 110 60 120 50 130 40 140 30 150 20 160 10 170 4 180 2 0 200 190"@en .

ex:ParametroVelocidadOverride a ex:Parametro ;
    rdfs:label "Speed override"@en ;
    ex:textoExtracto "Vary the speed override from the operator panel. With the operator panel, it is possible to change the percentage of spindle speed using the jog keyboard or a switch (depending on model)."@en ;
    ex:valor "50% to 120% with a 5% step"@en .