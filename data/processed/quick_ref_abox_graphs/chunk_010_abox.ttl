@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualCalibracionHerramientas a ns1:DocumentoTecnico ;
    rdfs:label "TOOL CALIBRATION" ;
    ns1:textoExtracto "If there is no tabletop probe, only manual calibration is available. All types of calibration are available when using a table-top probe." .

