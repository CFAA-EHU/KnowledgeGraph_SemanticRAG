@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AutomaticCalibration a ns1:TareaMantenimiento ;
    rdfs:label "Automatic calibration" ;
    ns1:textoExtracto "Automatic calibration. The CNC executes all the movements using the calibration canned cycle #PROBE." .

ns1:CNC8070_a25ad6c46a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "The CNC executes all the movements using the calibration canned cycle #PROBE." .

ns1:CalibrationWithoutProbe a ns1:AccionProhibida ;
    rdfs:label "Calibration without probe" ;
    ns1:textoExtracto "Since there is no probe, a reference part is required to calibrate the tool." .

ns1:ManualCalibration a ns1:TareaMantenimiento ;
    rdfs:label "Manual calibration" ;
    ns1:textoExtracto "Manual calibration. In this mode, only the active tool can be calibrated. Since there is no probe, a reference part is required to calibrate the tool. All the movements are carried out manually." .

ns1:SemiAutomaticCalibration a ns1:TareaMantenimiento ;
    rdfs:label "Semi-automatic calibration" ;
    ns1:textoExtracto "Semi-automatic calibration. The positioning movements are carried out manually and the CNC executes the probing movements." .

