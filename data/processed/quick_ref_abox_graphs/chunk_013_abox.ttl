@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CalibracionHerramienta a ex:TareaMantenimiento ;
    rdfs:label "Tool calibration"@en ;
    ex:textoExtracto "calibration. Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle. The CNC moves the tool until touching the probe and validates the calibration on each axis. This mode may be used to calibrate any tool."@en .

ex:CicloFijoSondeo a ex:ModoOperacion ;
    rdfs:label "probing canned cycle"@en ;
    ex:textoExtracto "Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle."@en .

ex:SondaCalibracion a ex:Sensor ;
    rdfs:label "probe"@en ;
    ex:textoExtracto "The CNC moves the tool until touching the probe and validates the calibration on each axis."@en .

ex:MesaHerramientas a ex:Tabla ;
    rdfs:label "tool table"@en ;
    ex:textoExtracto "After the calibration It updates the tool table data."@en .

ex:PasoCalibracionHerramienta1 a ex:TareaMantenimiento ;
    rdfs:label "Select the tool and the offset to be calibrated"@en ;
    ex:textoExtracto "1 Select the tool and the offset to be calibrated."@en .

ex:PasoCalibracionHerramienta2 a ex:TareaMantenimiento ;
    rdfs:label "Define the data defining the calibration"@en ;
    ex:textoExtracto "2 Define the data defining the calibration."@en .

ex:PasoCalibracionHerramienta3 a ex:TareaMantenimiento ;
    rdfs:label "Press the [CYCLE START] key to start the calibration"@en ;
    ex:textoExtracto "3 Press the [CYCLE START] key to start the calibration. The CNC calibrates the tool making all the necessary movements; there is no need to manually approach the tool. If necessary, the CNC makes the tool change."@en .

ex:PasoCalibracionHerramienta4 a ex:TareaMantenimiento ;
    rdfs:label "After the calibration It updates the tool table data"@en ;
    ex:textoExtracto "4 After the calibration It updates the tool table data. Also, the CNC assumes the new values."@en .

ex:ModeloFresado a ex:ModoOperacion ;
    rdfs:label "Milling model"@en ;
    ex:textoExtracto "• Milling model. Calibrate the length, the radius or offsets of the endmills and the offsets of the lathe tools."@en .

ex:ModeloTornoPlano a ex:ModoOperacion ;
    rdfs:label "Lathe model (plane)"@en ;
    ex:textoExtracto "• Lathe model (plane). Calibrate the offset of any tool."@en .

ex:ModeloTornoTrihedron a ex:ModoOperacion ;
    rdfs:label "Lathe model (trihedron)"@en ;
    ex:textoExtracto "• Lathe model (trihedron). Calibrate the length, the radius or offsets of the endmills and the offsets of the lathe tools."@en .

ex:TeclaInicioCiclo a ex:InterfazUsuario ;
    rdfs:label "[CYCLE START] key"@en ;
    ex:textoExtracto "Press the [CYCLE START] key to start the calibration."@en .