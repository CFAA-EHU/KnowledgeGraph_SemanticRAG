    rdfs:label "Do not manually approach the tool" ;
    ns1:textoExtracto "there is no need to manually approach the tool." .

ns1:ToolCalibration a ns1:TareaMantenimiento ;
    rdfs:label "Tool Calibration" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "calibration. Calibration with a probe and a canned cycle." .

