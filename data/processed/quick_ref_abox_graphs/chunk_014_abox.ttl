@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MDI_MDA_Mode a ex:ModoOperacion ;
    ex:textoExtracto "Edit new blocks. • In MDI mode, the edit line is always visible. • In MDA mode, one must select the \"new block\" option from the softkey menu. Modify a block from the block history. • In MDI mode, use the [][] keys to pop-up the history and scroll it. The [ENTER] key restores from the history the block selected with the cursor and insert it in the edit line. • In MDA mode, use the [][] keys, select a block from the history and use the \"modify\" option from the softkey menu (or the [ENTER] key to copy it into the edit line. Execute blocks. • The [START] key executes the block currently displayed on the editing line. Once the block has been executed is saved in the block history. • The [STOP] key interrupts the execution of the block. Press [START] again to resume execution from where it was interrupted. While the execution is interrupted, the “CANCEL” softkey cancels the execution of the block while keeping the programmed machining conditions (it does not do a general reset of the CNC). • The [RESET] key cancels the execution of the block and resets the CNC to its initial conditions." ;
    rdfs:label "MDI/MDA Mode"@en .

ex:Softkey_Menu a ex:InterfazUsuario ;
    ex:textoExtracto "Softkey. | Description. | | --- | --- | |  | Select a program for execution. | |  | Begin tool inspection. Tool inspection is only available when program execution is interrupted. | |  | End simulated execution and start executing the program | |  | Select the program that is being edited." ;
    rdfs:label "Softkey Menu"@en .

ex:Softkey_SelectProgramExecution a ex:InterfazUsuario ;
    ex:textoExtracto "Select a program for execution." ;
    rdfs:label "Select a program for execution"@en .

ex:Softkey_BeginToolInspection a ex:InterfazUsuario ;
    ex:textoExtracto "Begin tool inspection. Tool inspection is only available when program execution is interrupted." ;
    rdfs:label "Begin tool inspection"@en .

ex:Softkey_EndSimulatedExecution a ex:InterfazUsuario ;
    ex:textoExtracto "End simulated execution and start executing the program" ;
    rdfs:label "End simulated execution and start executing the program"@en .

ex:Softkey_SelectProgramEdited a ex:InterfazUsuario ;
    ex:textoExtracto "Select the program that is being edited." ;
    rdfs:label "Select the program that is being edited"@en .

ex:Tecla_START a ex:InterfazUsuario ;
    ex:textoExtracto "The [START] key executes the block currently displayed on the editing line." ;
    rdfs:label "START key"@en .

ex:Tecla_STOP a ex:InterfazUsuario ;
    ex:textoExtracto "The [STOP] key interrupts the execution of the block." ;
    rdfs:label "STOP key"@en .

ex:Tecla_CANCEL a ex:InterfazUsuario ;
    ex:textoExtracto "the “CANCEL” softkey cancels the execution of the block while keeping the programmed machining conditions" ;
    rdfs:label "CANCEL key"@en .

ex:Tecla_RESET a ex:InterfazUsuario ;
    ex:textoExtracto "The [RESET] key cancels the execution of the block and resets the CNC to its initial conditions." ;
    rdfs:label "RESET key"@en .

ex:Tecla_ENTER a ex:InterfazUsuario ;
    ex:textoExtracto "The [ENTER] key restores from the history the block selected with the cursor and insert it in the edit line." ;
    rdfs:label "ENTER key"@en .

ex:Tecla_UP_DOWN a ex:InterfazUsuario ;
    ex:textoExtracto "use the [][] keys to pop-up the history and scroll it." ;
    rdfs:label "[][] keys"@en .

ex:BloquePrograma a ex:Componente ;
    ex:textoExtracto "Edit new blocks. • Modify a block from the block history. • The [START] key executes the block currently displayed on the editing line. Once the block has been executed is saved in the block history." ;
    rdfs:label "Program block"@en .

ex:HistorialBloques a ex:Componente ;
    ex:textoExtracto "Modify a block from the block history. • Once the block has been executed is saved in the block history." ;
    rdfs:label "Block history"@en .

ex:LineaEdicion a ex:InterfazUsuario ;
    ex:textoExtracto "In MDI mode, the edit line is always visible." ;
    rdfs:label "Edit line"@en .