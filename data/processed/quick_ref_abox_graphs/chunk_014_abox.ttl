@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_e090847e9e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Edit new blocks. In MDI mode, the edit line is always visible." .

ns1:EjecutarBloqueEnModoMDI a ns1:TareaMantenimiento ;
    rdfs:label "Ejecutar bloque en modo MDI" ;
    ns1:textoExtracto "The [START] key executes the block currently displayed on the editing line." .

ns1:InterrumpirEjecucionDeBloque a ns1:TareaMantenimiento ;
    rdfs:label "Interrumpir ejecución de bloque" ;
    ns1:textoExtracto "The [STOP] key interrupts the execution of the block." .

ns1:ModificarBloqueEnModoMDA a ns1:TareaMantenimiento ;
    rdfs:label "Modificar bloque en modo MDA" ;
    ns1:textoExtracto "In MDA mode, use the [][] keys, select a block from the history and use the 'modify' option from the softkey menu." .

ns1:ModificarBloqueEnModoMDI a ns1:TareaMantenimiento ;
    rdfs:label "Modificar bloque en modo MDI" ;
    ns1:textoExtracto "In MDI mode, use the [][] keys to pop-up the history and scroll it." .

ns1:ReiniciarCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar CNC" ;
    ns1:textoExtracto "The [RESET] key cancels the execution of the block and resets the CNC to its initial conditions." .

