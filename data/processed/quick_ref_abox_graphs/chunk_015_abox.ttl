@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ExecuteProgramTask a ns1:TareaMantenimiento ;
    rdfs:label "Execute Program Task" ;
    ns1:ejecutadoPor ns1:PersonalOperario ;
    ns1:textoExtracto "To start the execution of the program, press [START] on the Operator Panel." .

ns1:InterfazUsuarioProgramExecution a ns1:InterfazUsuario ;
    rdfs:label "Program Execution Interface" ;
    ns1:textoExtracto "Select a program. Each channel executes the program selected in it." .

ns1:InterruptProgramExecution a ns1:AccionProhibida ;
    rdfs:label "Interrupt Program Execution" ;
    ns1:textoExtracto "The [STOP] key interrupts the execution of the program." .

ns1:ModoOperacionEjecucionIndividual a ns1:ModoOperacion ;
    rdfs:label "Single-block Execution Mode" ;
    ns1:textoExtracto "Single-block execution mode. The program may be executed in –single block– or –automatic– mode;" .

ns1:ResetCNC a ns1:AccionProhibida ;
    rdfs:label "Reset CNC" ;
    ns1:textoExtracto "The [RESET] key cancels the execution of the program and resets the CNC to its initial conditions." .

