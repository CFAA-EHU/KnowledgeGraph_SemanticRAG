@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EXECUTEBLOCKSSEPARATELY a ns1:AccionProhibida ;
    rdfs:label "EXECUTE BLOCKS SEPARATELY" ;
    ns1:textoExtracto "Press the 'EXBLK' softkey of the horizontal menu. Being this option active, every time the [START] key is pressed, it only executes the block selected in the active program. Once that block is executed, another block may..."@en .

