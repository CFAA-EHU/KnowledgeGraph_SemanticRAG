ns1:CNC8070_6cffc16e3b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:AxisRepositioning_b75b6278e9,
        ns1:InterruptSimulation,
        ns1:SimulationOfProgram ;
    ns1:textoExtracto "Start the simulation of the program 1 On the horizontal softkey menu, select the desired type of simulation." .

ns1:AxisRepositioning_b75b6278e9 a ns1:TareaMantenimiento ;
    rdfs:label "Axis Repositioning" ;
    ns1:textoExtracto "The vertical softkey menu offers two options. • Repositioning the axes at the starting interruption point. point of the interrupted block." .

ns1:InterruptSimulation a ns1:AccionProhibida ;
    rdfs:label "Interrupt Simulation" ;
    ns1:textoExtracto "Press the [STOP] of the operator panel to interrupt the simulation." .

ns1:SimulationOfProgram a ns1:TareaMantenimiento ;
    rdfs:label "Simulation of Program" ;
    ns1:textoExtracto "With simulated execution, it is possible to simulate a program, interrupt it at a point and start execution from that point on." .

