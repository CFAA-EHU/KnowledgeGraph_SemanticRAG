@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SimulatedExecution ex:textoExtracto """With simulated execution, it is possible to simulate a program, interrupt it at a point and start execution from that point on. Depending on the type of simulation selected, it can involve movement of axes, spindle, etc.""" ;
    a ex:ModoOperacion ;
    ex:identificador "Simulated execution" .

ex:ProgramSimulation ex:textoExtracto """With simulated execution, it is possible to simulate a program, interrupt it at a point and start execution from that point on.""" ;
    a ex:TareaMantenimiento ;
    ex:identificador "Program simulation" .

ex:HorizontalSoftkeyMenu ex:textoExtracto """On the horizontal softkey menu, select the desired type of simulation.""" ;
    a ex:InterfazUsuario ;
    ex:identificador "Horizontal softkey menu" .

ex:STARTKey ex:textoExtracto """Press the [START] key to start the simulation.""" ;
    a ex:Actuador ;
    ex:identificador "START key" .

ex:STOPKey ex:textoExtracto """Press the [STOP] of the operator panel to interrupt the simulation.""" ;
    a ex:Actuador ;
    ex:identificador "STOP key" .

ex:OperatorPanel ex:textoExtracto """Press the [STOP] of the operator panel to interrupt the simulation.""" ;
    a ex:InterfazUsuario ;
    ex:identificador "Operator panel" .

ex:VerticalSoftkeyMenu ex:textoExtracto """the vertical softkey menu offers two options.""" ;
    a ex:InterfazUsuario ;
    ex:identificador "Vertical softkey menu" .

ex:SingleBlockMode ex:textoExtracto """The program may be simulated in "single block" or "continuous" mode; the mode may be selected even while simulating the program.""" ;
    a ex:ModoOperacion ;
    ex:identificador "Single block mode" .

ex:ContinuousMode ex:textoExtracto """The program may be simulated in "single block" or "continuous" mode; the mode may be selected even while simulating the program.""" ;
    a ex:ModoOperacion ;
    ex:identificador "Continuous mode" .

ex:ToolInspection ex:textoExtracto """When switching to execution mode (after pressing the softkey), the CNC goes into tool inspection to reposition the axes, modify program conditions, etc.""" ;
    a ex:TareaMantenimiento ;
    ex:identificador "Tool inspection" .

ex:CNC ex:textoExtracto """the CNC goes into tool inspection to reposition the axes, modify program conditions, etc.""" ;
    a ex:Maquina ;
    ex:identificador "CNC" .

ex:SpindleTurningDirection ex:textoExtracto """the spindle turning direction must be restored and the axes repositioned.""" ;
    a ex:Parametro ;
    ex:identificador "Spindle turning direction" .

ex:AxisRepositioning ex:textoExtracto """the spindle turning direction must be restored and the axes repositioned.""" ;
    a ex:TareaMantenimiento ;
    ex:identificador "Axis repositioning" .