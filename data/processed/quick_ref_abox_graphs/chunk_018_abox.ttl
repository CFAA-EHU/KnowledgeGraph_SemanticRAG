@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1869eec8f4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:BusquedaAutomaticaDeBloques,
        ns1:BusquedaManualDeBloques,
        ns1:ReposicionAutomaticaDeEjes ;
    ns1:textoExtracto "The CNC remembers the block where interruption was canceled, thus not being necessary to set the stop block." .

ns1:BusquedaAutomaticaDeBloques a ns1:TareaMantenimiento ;
    rdfs:label "Busqueda Automatica de Bloques" ;
    ns1:textoExtracto "The automatic block search may be used to recover the program history up to the block where the previous execution was canceled." .

ns1:BusquedaManualDeBloques a ns1:TareaMantenimiento ;
    rdfs:label "Busqueda Manual de Bloques" ;
    ns1:textoExtracto "The manual block search may be used to recover the program history up to a particular block of the program or of the subroutine, set by the operator." .

ns1:ReposicionAutomaticaDeEjes a ns1:AccionProhibida ;
    rdfs:label "Reposicion Automatica de Ejes" ;
    ns1:textoExtracto "Select the axes with the relevant softkey and press [START]." .

