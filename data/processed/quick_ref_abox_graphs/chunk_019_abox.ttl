@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RepositioningOfAxes a ns1:TareaMantenimiento ;
    rdfs:label "Repositioning of axes" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "repositioning of axes. Select the axes with the relevant softkey and press [START]. Repositioning may be interrupted (using the [STOP] key) to select other axes." .

ns1:ToolInspection_08faa4e674 a ns1:TareaMantenimiento ;
    rdfs:label "Tool inspection" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "In tool inspection, it is possible to change the feedrate and the spindle speed, execute blocks in MDI/MDA mode as well as activate M and H functions." .

ns1:PersonalTecnico a ns1:Personal ;
    rdfs:label "Technical Personnel" ;
    ns1:textoExtracto "Technical Personnel" .

