@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioPanelOperador a ns1:InterfazUsuario ;
    rdfs:label "Operator Panel" ;
    ns1:controla ns1:CNC8070_4b7c3c44b3 ;
    ns1:textoExtracto "act upon the master spindle of the channel from the operator panel" .

ns1:ToolInspection_4417fb418a a ns1:TareaMantenimiento ;
    rdfs:label "Tool Inspection" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Begin tool inspection. Tool inspection may be accessed from the vertical softkey menu only when the execution of the program has been interrupted ([STOP] key)." .

ns1:CNC8070_4b7c3c44b3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:textoExtracto "Refer to the operating manual." .

