@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8a77745be7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Change the channel being displayed for editing and simulation. It does not affect the active channel at the CNC." .

ns1:RESETSimulation_d2cf7201c9 a ns1:AccionProhibida ;
    rdfs:label "RESET (simulation)" ;
    ns1:textoExtracto "RESET (simulation). Cancel program simulation. If an error occurs during simulation, reset eliminates the error status and returns the simulation mode to its initial conditions." .

ns1:STARTSimulation a ns1:AccionProhibida ;
    rdfs:label "START (simulation)" ;
    ns1:textoExtracto "START (simulation). Starts program simulation or resume it if it was interrupted." .

ns1:STOPSimulation a ns1:AccionProhibida ;
    rdfs:label "STOP (simulation)" ;
    ns1:textoExtracto "STOP (simulation). Interrupt program simulation. Simulation will resume by pressing the START icon." .

