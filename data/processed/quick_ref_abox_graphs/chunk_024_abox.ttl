@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacionEDISIMU ex:textoExtracto """Activate or cancel tool radius compensation to simulate the program.""" ;
    rdfs:label "Tool radius compensation" ;
    a ex:ModoOperacion .

ex:ModoOperacionBlockSkip ex:textoExtracto """Option to simulate the external "block skip" switch. Being this option active, the CNC does not simulate the blocks containing the block-skip character "/".""" ;
    rdfs:label "Block skip" ;
    a ex:ModoOperacion .

ex:ModoOperacionSynchronizingSpindles ex:textoExtracto """There is an icon for each spindle where to indicate the spindle to synchronize with. The ·0· value cancels the synchronization.""" ;
    rdfs:label "Synchronizing spindles" ;
    a ex:ModoOperacion .

ex:ModoOperacionAssumeOrigins ex:textoExtracto """Assume the active origins for execution. When starting the simulation or pressing the simulation reset, the CNC applies to the simulation the origins set in the execution environment (for example, the part zero set in jog mode).""" ;
    rdfs:label "Assume the active origins for execution" ;
    a ex:ModoOperacion .

ex:ModoOperacionSoftwareLimits ex:textoExtracto """Activate or deactivate the software limits for program simulation.""" ;
    rdfs:label "Software limits" ;
    a ex:ModoOperacion .

ex:ModoOperacionConditionalStop ex:textoExtracto """Option to simulate the external "conditional stop" switch. Being this option active, the CNC interrupts the simulation in the blocks where the 'M01" function is programmed.""" ;
    rdfs:label "Conditional stop during simulation" ;
    a ex:ModoOperacion .

ex:ModoOperacionCancelChannelSync ex:textoExtracto """There is one icon per channel that cancels the wait for synchronism with the channel during simulation.""" ;
    rdfs:label "Cancel channel synchronization" ;
    a ex:ModoOperacion .