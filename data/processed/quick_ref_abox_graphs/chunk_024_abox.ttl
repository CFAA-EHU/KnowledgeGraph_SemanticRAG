@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AssumeTheActiveOriginsForExecution a ns1:Parametro ;
    rdfs:label "Assume the active origins for execution" ;
    ns1:textoExtracto "When starting the simulation or pressing the simulation reset, the CNC applies to the simulation the origins set in the execution environment (for example, the part zero set in jog mode)." .

ns1:BlockSkip a ns1:Parametro ;
    rdfs:label "Block skip" ;
    ns1:textoExtracto "Option to simulate the external \"block skip\" switch. Being this option active, the CNC does not simulate the blocks containing the block-skip character \"/\"."@en .

ns1:CancelChannelSynchronization a ns1:Parametro ;
    rdfs:label "Cancel channel synchronization" ;
    ns1:textoExtracto "There is one icon per channel that cancels the wait for synchronism with the channel during simulation." .

ns1:ConditionalStopDuringSimulation a ns1:Parametro ;
    rdfs:label "Conditional stop during simulation" ;
    ns1:textoExtracto "Option to simulate the external \"conditional stop\" switch. Being this option active, the CNC interrupts the simulation in the blocks where the 'M01' function is programmed."@en .

ns1:SoftwareLimits a ns1:Parametro ;
    rdfs:label "Software limits" ;
    ns1:textoExtracto "Activate or deactivate the software limits for program simulation." .

ns1:SynchronizingSpindles a ns1:Parametro ;
    rdfs:label "Synchronizing spindles" ;
    ns1:textoExtracto "There is an icon for each spindle where to indicate the spindle to synchronize with. The ·0· value cancels the synchronization." .

ns1:ToolRadiusCompensation a ns1:Parametro ;
    rdfs:label "Tool radius compensation" ;
    ns1:textoExtracto "Activate or cancel tool radius compensation to simulate the program." .

