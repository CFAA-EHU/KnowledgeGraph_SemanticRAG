@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EXBLKSoftkey a ns1:AccionProhibida ;
    rdfs:label "EXBLK softkey" ;
    ns1:textoExtracto "Press the 'EXBLK' softkey of the horizontal menu. Being this option active, every time the START icon key is pressed, it only simulates the block selected in the active program." .

