@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SoftkeyCambiarUnidades ex:textoExtracto "Change the units for data display (mm or inches). For programming, the CNC assumes the units defined with the active function G70 or G71, or, when not programmed, the units set by the machine manufacturer (INCHES parameter)." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Change the units for data display" .

ex:SoftkeyInicializarTabla ex:textoExtracto "Initialize the table. Reset all the table data to \"0\"." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Initialize the table" .

ex:SoftkeyBuscarTextoValor ex:textoExtracto "Search a text or a value in the table." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Search a text or a value in the table" .

ex:SoftkeyAccederTablasCanales ex:textoExtracto "Accessing the tables of other channels. With some tables, only the data of the active channel are displayed, this softkey is used to show the tables of the other channels. This softkey will only be available when using channels." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Accessing the tables of other channels" .

ex:SoftkeySeleccionarEjesMostrar ex:textoExtracto "Select the axes to be displayed in the tables. When using several channels, only those axes assigned to the active channel may be accessed." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Select the axes to be displayed in the tables" .

ex:SoftkeyGuardarValoresTabla ex:textoExtracto "Save the values of the table into a file." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Save the values of the table into a file" .

ex:SoftkeyRestaurarValoresTabla ex:textoExtracto "Restore the values of the table previously saved into a file." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Restore the values of the table previously saved into a file" .

ex:SoftkeyImprimirGuardarTabla ex:textoExtracto "Print the table in the pre-determined printer or save it as a file (prn format) at the CNC." ;
    a ex:InterfazUsuario ;
    rdfs:label "Softkey - Print the table in the pre-determined printer or save it as a file (prn format) at the CNC" .

ex:TablaInterfazUsuario ex:textoExtracto "Softkey. Description. Change the units for data display (mm or inches)... Print the table in the pre-determined printer or save it as a file (prn format) at the CNC." ;
    a ex:InterfazUsuario ;
    ex:compuestoPor ex:SoftkeyCambiarUnidades, ex:SoftkeyInicializarTabla, ex:SoftkeyBuscarTextoValor, ex:SoftkeyAccederTablasCanales, ex:SoftkeySeleccionarEjesMostrar, ex:SoftkeyGuardarValoresTabla, ex:SoftkeyRestaurarValoresTabla, ex:SoftkeyImprimirGuardarTabla ;
    rdfs:label "Tabla de softkeys para gestión de tablas CNC" .