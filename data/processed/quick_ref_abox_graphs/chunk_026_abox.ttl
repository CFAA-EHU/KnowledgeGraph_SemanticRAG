@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_03a1da753e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Change the units for data display (mm or inches). For programming, the CNC assumes the units defined with the active function G70 or G71, or, when not programmed, the units set by the machine manufacturer (INCHES parameter)." ;
    ns1:tieneComponente ns1:InterfazUsuarioTablaUsuarios .

ns1:RestoreTableValues a ns1:TareaMantenimiento ;
    rdfs:label "Restore Table Values" ;
    ns1:textoExtracto "Restore the values of the table previously saved into a file." .

ns1:SaveTableValues a ns1:TareaMantenimiento ;
    rdfs:label "Save Table Values" ;
    ns1:textoExtracto "Save the values of the table into a file." .

ns1:InterfazUsuarioTablaUsuarios a ns1:InterfazUsuario ;
    rdfs:label "User Tables" ;
    ns1:textoExtracto "Initialize the table. Reset all the table data to \"0\"." .

