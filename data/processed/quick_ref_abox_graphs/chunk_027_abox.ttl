@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla_27_1 a ex:Tabla ;
    rdfs:label "Zero offset tables" ;
    ex:textoExtracto "Zero offset tables. This table contains the absolute zero offsets and the PLC offset of all the axes and spindles that may be activated as C axis." ;
    ex:compuestoPor ex:OffsetCeroAbsoluto, ex:OffsetPLC .

ex:OffsetCeroAbsoluto a ex:Parametro ;
    rdfs:label "Absolute zero offset" ;
    ex:textoExtracto "The zero offsets are used to place the part zero at different positions of the machine." .

ex:OffsetPLC a ex:Parametro ;
    rdfs:label "PLC offset" ;
    ex:textoExtracto "The PLC offset may not be set directly in the table, its values are set from the PLC or via part-program using variables." .

ex:Tabla_27_2 a ex:Tabla ;
    rdfs:label "Fixture table" ;
    ex:textoExtracto "Fixture table. This table stores the clamp offsets for each axis." ;
    ex:compuestoPor ex:OffsetSujecion .

ex:OffsetSujecion a ex:Parametro ;
    rdfs:label "clamp offset" ;
    ex:textoExtracto "The clamp offsets are used to set the position of the clamping system of the machine." .

ex:Tabla_27_3 a ex:Tabla ;
    rdfs:label "Common parameters" ;
    ex:textoExtracto "Common parameters. The table is common to all the channels." .

ex:Tabla_27_4 a ex:Tabla ;
    rdfs:label "Global parameters" ;
    ex:textoExtracto "Global parameters. There is a table for each channel." .

ex:Tabla_27_5 a ex:Tabla ;
    rdfs:label "Local parameters" ;
    ex:textoExtracto "Local parameters. There are seven tables for each channel, one table per nesting level (7 levels)." .