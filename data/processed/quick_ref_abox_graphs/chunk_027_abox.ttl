@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AbsoluteZeroOffsets a ns1:Parametro ;
    rdfs:label "Absolute zero offsets" ;
    ns1:identificador "Absolute zero offsets" ;
    ns1:textoExtracto "The absolute zero offsets besides being set directly in the table may also be set from the PLC or via part-program using variables." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:ClampOffsets a ns1:Parametro ;
    rdfs:label "clamp offsets" ;
    ns1:identificador "clamp offsets" ;
    ns1:textoExtracto "The fixture offset besides being set directly in the table may also be set from the PLC or via part-program using variables." .

ns1:PLCOffset_46320ecc5b a ns1:Parametro ;
    rdfs:label "PLC offset" ;
    ns1:identificador "PLC offset" ;
    ns1:textoExtracto "The PLC offset may not be set directly in the table, its values are set from the PLC or via part-program using variables." .

ns1:PrintTheTableInThePreDeterminedPrinterOrSaveItAsAFilePrnFormatAtTheCNC a ns1:TareaMantenimiento ;
    rdfs:label "Print the table in the pre-determined printer or save it as a file (prn format) at the CNC" ;
    ns1:textoExtracto "Print the table in the pre-determined printer or save it as a file (prn format) at the CNC." .

ns1:RestoreTheValuesOfTheTablePreviouslySavedIntoAFile a ns1:TareaMantenimiento ;
    rdfs:label "Restore the values of the table previously saved into a file" ;
    ns1:textoExtracto "Restore the values of the table previously saved into a file." .

ns1:TablaFijacion a ns1:Tabla ;
    rdfs:label "Fixture table" ;
    ns1:textoExtracto "This table stores the clamp offsets for each axis." .

ns1:TablaParametrosArithmetic a ns1:Tabla ;
    rdfs:label "Arithmetic parameter tables" ;
    ns1:textoExtracto "There are the following arithmetic parameter tables:" .

ns1:TablaParametrosComunes a ns1:Tabla ;
    rdfs:label "Common parameters" ;
    ns1:textoExtracto "The table is common to all the channels." .

ns1:TablaParametrosGlobales a ns1:Tabla ;
    rdfs:label "Global parameters" ;
    ns1:textoExtracto "There is a table for each channel." .

ns1:TablaParametrosLocales a ns1:Tabla ;
    rdfs:label "Local parameters" ;
    ns1:textoExtracto "There are seven tables for each channel, one table per nesting level (7 levels)." .

ns1:TablaZeroOffsets a ns1:Tabla ;
    rdfs:label "Zero offset tables" ;
    ns1:textoExtracto "This table contains the absolute zero offsets and the PLC offset of all the axes and spindles that may be activated as C axis." .

