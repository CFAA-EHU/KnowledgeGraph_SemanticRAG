@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ChangeTheHiddenAttributeOfTheSelectedFiles a ns1:AccionProhibida ;
    rdfs:label "Change the 'hidden' attribute of the selected files" ;
    ns1:textoExtracto "Change the 'hidden' attribute of the selected files. The attributes column shows the letter -H- indicating that the program will be hidden (not visible). This attribute allows protecting the files so they are not displayed when selecting a program to be edited or executed." .

ns1:ChangeTheModifiableAttributeOfTheSelectedFiles a ns1:AccionProhibida ;
    rdfs:label "Change the 'modifiable' attribute of the selected files" ;
    ns1:textoExtracto "Change the 'modifiable' attribute of the selected files. The attributes column shows the letter -M- indicating that the program may be modified. This attribute is used to protect the files so they can't be modified from the EDISIMU mode." .

ns1:CopyTheSelectedFilesOntoTheClipboard a ns1:AccionProhibida ;
    rdfs:label "Copy the selected files onto the clipboard" ;
    ns1:textoExtracto "Copy the selected files onto the clipboard." .

ns1:CutTheSelectedFilesOntoTheClipboard a ns1:AccionProhibida ;
    rdfs:label "Cut the selected files onto the clipboard" ;
    ns1:textoExtracto "Cut the selected files onto the clipboard. With this option, when pasting the files to their new location, they are erased from the current folder." .

ns1:DeleteTheSelectedFolderOrFiles a ns1:AccionProhibida ;
    rdfs:label "Delete the selected folder or files" ;
    ns1:textoExtracto "Delete the selected folder or files. The folders can only be deleted if they are empty." .

ns1:EncryptFiles a ns1:AccionProhibida ;
    rdfs:label "Encrypt files" ;
    ns1:textoExtracto "Encrypt files. Encrypting may be used to protect any file (part-program, subroutine, etc.) making it illegible so it cannot be used by anyone else." .

ns1:PasteTheFilesFromTheClipboardIntoTheSelectedFolder a ns1:AccionProhibida ;
    rdfs:label "Paste the files from the clipboard into the selected folder" ;
    ns1:textoExtracto "Paste the files from the clipboard into the selected folder. If the files were placed using the 'Cut' option, they will be removed from their original location." .

ns1:RenameTheSelectedFolderOrFile a ns1:AccionProhibida ;
    rdfs:label "Rename the selected folder or file" ;
    ns1:textoExtracto "Rename the selected folder or file." .

