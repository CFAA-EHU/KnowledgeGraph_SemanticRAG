@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SoftkeyCut ex:textoExtracto """Cut the selected files onto the clipboard. With this option, when pasting the files to their new location, they are erased from the current folder.""" ;
    rdfs:label "Softkey Cut"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyCopy ex:textoExtracto """Copy the selected files onto the clipboard.""" ;
    rdfs:label "Softkey Copy"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyPaste ex:textoExtracto """Paste the files from the clipboard into the selected folder. If the files were placed using the "Cut" option, they will be removed from their original location.""" ;
    rdfs:label "Softkey Paste"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyRename ex:textoExtracto """Rename the selected folder or file.""" ;
    rdfs:label "Softkey Rename"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyChangeModifiableAttribute ex:textoExtracto """Change the "modifiable" attribute of the selected files. The attributes column shows the letter -M- indicating that the program may be modified. This attribute is used to protect the files so they can't be modified from the EDISIMU mode.""" ;
    rdfs:label "Softkey Change Modifiable Attribute"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyChangeHiddenAttribute ex:textoExtracto """Change the "hidden" attribute of the selected files. The attributes column shows the letter -H- indicating that the program will be hidden (not visible). This attribute allows protecting the files so they are not displayed when selecting a program to be edited or executed.""" ;
    rdfs:label "Softkey Change Hidden Attribute"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyEncrypt ex:textoExtracto """Encrypt files. Encrypting may be used to protect any file (part-program, subroutine, etc.) making it illegible so it cannot be used by anyone else.""" ;
    rdfs:label "Softkey Encrypt"@en ;
    a ex:InterfazUsuario .

ex:SoftkeyDelete ex:textoExtracto """Delete the selected folder or files. The folders can only be deleted if they are empty.""" ;
    rdfs:label "Softkey Delete"@en ;
    a ex:InterfazUsuario .