@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MachiningFeedrate_937455668f a ns1:Parametro ;
    rdfs:label "Machining feedrate" ;
    ns1:textoExtracto "The machining feedrate may be selected by programmed using the \"F\" code which remains active until another value is programmed." .

ns1:SpindleSpeed_287296db01 a ns1:Parametro ;
    rdfs:label "Spindle speed" ;
    ns1:textoExtracto "The spindle speed is selected by program using the spindle name followed by the desired speed." .

ns1:ToolNumber_972b96a447 a ns1:Parametro ;
    rdfs:label "Tool number" ;
    ns1:textoExtracto "The \"T\" code identifies the tool to be selected." .

ns1:ToolOffsetNumber a ns1:Parametro ;
    rdfs:label "Tool offset number" ;
    ns1:textoExtracto "The tool offset contains the tool dimensions. Each tool may have several offsets associated with it." .

