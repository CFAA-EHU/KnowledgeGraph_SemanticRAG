@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:G00 a ex:ModoOperacion ;
    ex:identificador "G00" ;
    ex:textoExtracto "G00 | * | ? | * | Rapid traverse." .

ex:G01 a ex:ModoOperacion ;
    ex:identificador "G01" ;
    ex:textoExtracto "G01 | * | ? | * | Linear interpolation." .

ex:G02 a ex:ModoOperacion ;
    ex:identificador "G02" ;
    ex:textoExtracto "G02 | * |  | * | Clockwise circular (helical) interpolation." .

ex:G03 a ex:ModoOperacion ;
    ex:identificador "G03" ;
    ex:textoExtracto "G03 | * |  | * | Counterclockwise circular (helical) interpolation." .

ex:G04 a ex:ModoOperacion ;
    ex:identificador "G04" ;
    ex:textoExtracto "G04 |  |  | * | Dwell." .

ex:G05 a ex:ModoOperacion ;
    ex:identificador "G05" ;
    ex:textoExtracto "G05 | * | ? | * | Controlled corner rounding (modal)." .

ex:G06 a ex:ModoOperacion ;
    ex:identificador "G06" ;
    ex:textoExtracto "G06 |  |  | * | Arc center in absolute coordinates (not modal)." .

ex:G07 a ex:ModoOperacion ;
    ex:identificador "G07" ;
    ex:textoExtracto "G07 | * | ? | * | Square corner (modal)." .

ex:G08 a ex:ModoOperacion ;
    ex:identificador "G08" ;
    ex:textoExtracto "G08 |  |  | * | Arc tangent to previous path." .

ex:G09 a ex:ModoOperacion ;
    ex:identificador "G09" ;
    ex:textoExtracto "G09 |  |  | * | Arc defined by three points." .

ex:G10 a ex:ModoOperacion ;
    ex:identificador "G10" ;
    ex:textoExtracto "G10 | * | * |  | Cancel mirror image on all the axes." .

ex:G11 a ex:ModoOperacion ;
    ex:identificador "G11" ;
    ex:textoExtracto "G11 | * |  | * | Mirror image on the abscissa axis." .

ex:G12 a ex:ModoOperacion ;
    ex:identificador "G12" ;
    ex:textoExtracto "G12 | * |  | * | Mirror image on the ordinate axis." .

ex:G13 a ex:ModoOperacion ;
    ex:identificador "G13" ;
    ex:textoExtracto "G13 | * |  | * | Mirror image on the axis perpendicular to the plane." .

ex:G14 a ex:ModoOperacion ;
    ex:identificador "G14" ;
    ex:textoExtracto "G14 | * |  | * | Activate or cancel mirror image on a axis." .

ex:G17 a ex:ModoOperacion ;
    ex:identificador "G17" ;
    ex:textoExtracto "G17 | * | ? | * | Main plane formed by the first axis (abscissa), second (ordinate) and third axis (perpendicular) of the channel." .