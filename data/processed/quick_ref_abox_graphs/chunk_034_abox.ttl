@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgrammingInInches a ns1:Parametro ;
    rdfs:label "Programming in inches" ;
    ns1:identificador "G70" ;
    ns1:textoExtracto "G70 | * | ? | * | Programming in inches." .

ns1:ProgrammingInMillimeters a ns1:Parametro ;
    rdfs:label "Programming in millimeters" ;
    ns1:identificador "G71" ;
    ns1:textoExtracto "G71 | * | ? |  | Programming in millimeters." .

ns1:RigidTapping a ns1:Parametro ;
    rdfs:label "Rigid tapping" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "G63 | * |  | * | Rigid tapping." .

ns1:ZeroOffsetAbsoluteZeroOffset6 a ns1:Parametro ;
    rdfs:label "Zero offset. Absolute zero offset 6" ;
    ns1:identificador "G59" ;
    ns1:textoExtracto "G59 | ! |  | * | Zero offset. Absolute zero offset 6." .

