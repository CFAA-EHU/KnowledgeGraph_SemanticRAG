@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CoordinateSystemRotation a ns1:Parametro ;
    rdfs:label "Coordinate system rotation" ;
    ns1:identificador "G73" ;
    ns1:textoExtracto "G73 | * |  | * | Coordinate system rotation." .

ns1:HomeSearch a ns1:Parametro ;
    rdfs:label "Home search" ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "G74 |  |  | * | Home search." .

ns1:MModelCancelTheCannedCycle a ns1:Parametro ;
    rdfs:label "(·M· model). Cancel the canned cycle" ;
    ns1:identificador "G80" ;
    ns1:textoExtracto "G80 | * | * |  | (·M· model). Cancel the canned cycle." .

ns1:MModelDrillingCannedCycle a ns1:Parametro ;
    rdfs:label "(·M· model). Drilling canned cycle",
        "(·T· model). Turning canned cycle with straight sections" ;
    ns1:identificador "G81" ;
    ns1:textoExtracto "G81 |  |  | * | (·T· model). Turning canned cycle with straight sections.",
        "G81 | * |  | * | (·M· model). Drilling canned cycle." .

ns1:MModelDrillingCannedCycleWithAVariablePeck a ns1:Parametro ;
    rdfs:label "(·M· model). Drilling canned cycle with a variable peck",
        "(·T· model). Facing canned cycle with straight sections" ;
    ns1:identificador "G82" ;
    ns1:textoExtracto "G82 |  |  | * | (·T· model). Facing canned cycle with straight sections.",
        "G82 | * |  | * | (·M· model). Drilling canned cycle with a variable peck." .

ns1:MModelTappingCannedCycle a ns1:Parametro ;
    rdfs:label "(·M· model). Tapping canned cycle" ;
    ns1:identificador "G84" ;
    ns1:textoExtracto "G84 | * |  | * | (·M· model). Tapping canned cycle." .

ns1:ProgrammingInMillimeters a ns1:Parametro ;
    rdfs:label "Programming in millimeters" ;
    ns1:identificador "G71" ;
    ns1:textoExtracto "G71 | * | ? |  | Programming in millimeters." .

ns1:ScalingFactor a ns1:Parametro ;
    rdfs:label "Scaling factor" ;
    ns1:identificador "G72" ;
    ns1:textoExtracto "G72 | * |  | * | Scaling factor." .

ns1:TModelDrillingTappingCannedCycle a ns1:Parametro ;
    rdfs:label "(·M· model). Deep-hole drilling canned cycle with constant peck",
        "(·T· model). Drilling / tapping canned cycle" ;
    ns1:identificador "G83" ;
    ns1:textoExtracto "G83 |  |  | * | (·T· model). Drilling / tapping canned cycle.",
        "G83 | * |  | * | (·M· model). Deep-hole drilling canned cycle with constant peck." .

