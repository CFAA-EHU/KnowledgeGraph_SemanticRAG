@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G84 a ex:ModoOperacion ;
    rdfs:label "G84" ;
    ex:identificador "G84" ;
    ex:textoExtracto "Turning canned cycle with arcs."@en .

