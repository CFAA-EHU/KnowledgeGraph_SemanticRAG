@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BlendTheFeedrateAtTheBeginningOfTheBlock a ns1:Parametro ;
    rdfs:label "Blend the feedrate at the beginning of the block" ;
    ns1:identificador "G108" ;
    ns1:textoExtracto "G108 | * | Blend the feedrate at the beginning of the block." .

ns1:BlendTheFeedrateAtTheEndOfTheBlock a ns1:Parametro ;
    rdfs:label "Blend the feedrate at the end of the block" ;
    ns1:identificador "G109" ;
    ns1:textoExtracto "G109 | * | Blend the feedrate at the end of the block." .

ns1:ChangingOfParameterRangeOfAnAxis a ns1:Parametro ;
    rdfs:label "Changing of parameter range of an axis" ;
    ns1:identificador "G112" ;
    ns1:textoExtracto "G112 | * | Changing of parameter range of an axis." .

ns1:ExcludeProbeOffset a ns1:Parametro ;
