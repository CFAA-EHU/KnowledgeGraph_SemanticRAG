ex:ParametroP7 a ex:Parametro ;
    ex:identificador "P7" ;
    ex:textoExtracto "programming \"P7\" means that no machining operation takes place at point 7." .

ex:ParametroQ10_013 a ex:Parametro ;
    ex:identificador "Q10.013" ;
    ex:textoExtracto "Programming \"Q10.013\" means that no machining takes place at points 10, 11, 12 and 13." .

ex:AccionProhibidaNoMaquinadoP7 a ex:AccionProhibida ;
    ex:textoExtracto "programming \"P7\" means that no machining operation takes place at point 7." .

ex:AccionProhibidaNoMaquinadoQ10_013 a ex:AccionProhibida ;
