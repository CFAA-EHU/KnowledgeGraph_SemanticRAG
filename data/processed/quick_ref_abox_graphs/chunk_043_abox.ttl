@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ParametroP a ex:Parametro ;
    ex:identificador "P" ;
    ex:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning." .

