    ns1:textoExtracto "#CALL SP Add a spindle to the configuration of the channel." .

ns1:AdditiveManualInterventionOnAxis a ns1:AccionProhibida ;
    rdfs:label "Additive Manual Intervention on Axis" ;
    ns1:textoExtracto "#AXIS Axis upon which the additive manual intervention is applied." .

