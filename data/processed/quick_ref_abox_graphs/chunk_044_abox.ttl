    rdfs:label "Activate Collision Detection" ;
    ns1:textoExtracto "#CD ON Activating collision detection." .

ns1:ActivateElectronicCam a ns1:AccionProhibida ;
    rdfs:label "Activate Electronic Cam" ;
    ns1:textoExtracto "#CAM ON Activate the electronic cam (real coordinates)." .

ns1:ActivateSpindleAsCAxis a ns1:AccionProhibida ;
