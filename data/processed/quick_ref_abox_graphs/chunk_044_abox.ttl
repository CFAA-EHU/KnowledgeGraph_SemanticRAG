@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AbortExecutionOfProgram a ns1:AccionProhibida ;
    rdfs:label "Abort Execution of Program" ;
    ns1:textoExtracto "#ABORT Abort the execution of the program and resume it in another block or program." .

