@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_45_1 a ex:ModoOperacion ;
    rdfs:label "#CD ON" ;
    ex:textoExtracto "Activating collision detection." .

ex:ModoOperacion_45_2 a ex:ModoOperacion ;
    rdfs:label "#CLEAR" ;
    ex:textoExtracto "Channels. It clears the synchronism marks of the channel." .

ex:ModoOperacion_45_3 a ex:ModoOperacion ;
    rdfs:label "#CONTJOG" ;
    ex:textoExtracto "Manual intervention. Feedrate in continuous jog." .

ex:ModoOperacion_45_4 a ex:ModoOperacion ;
    rdfs:label "#COMMENT BEGIN" ;
    ex:textoExtracto "Beginning of comment." .

ex:ModoOperacion_45_5 a ex:ModoOperacion ;
    rdfs:label "#COMMENT END" ;
    ex:textoExtracto "End of comment." .

ex:ModoOperacion_45_6 a ex:ModoOperacion ;
    rdfs:label "#CS" ;
    ex:textoExtracto "Machining coordinate system." .

ex:ModoOperacion_45_7 a ex:ModoOperacion ;
    rdfs:label "#CSROT ON" ;
    ex:textoExtracto "Activate tool orientation in the part coordinate system." .

ex:ModoOperacion_45_8 a ex:ModoOperacion ;
    rdfs:label "#CSROT OFF" ;
    ex:textoExtracto "Cancel tool orientation in the part coordinate system." .