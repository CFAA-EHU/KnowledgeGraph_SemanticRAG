@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivateToolOrientationInThePartCoordinateSystem a ns1:Parametro ;
    rdfs:label "Activate tool orientation in the part coordinate system" ;
    ns1:identificador "#CSROT ON" ;
    ns1:textoExtracto "Activate tool orientation in the part coordinate system." .

ns1:ActivatingCollisionDetection a ns1:Parametro ;
    rdfs:label "Activating collision detection" ;
    ns1:identificador "#CD ON" ;
    ns1:textoExtracto "Activating collision detection." .

ns1:BeginningOfComment a ns1:Parametro ;
    rdfs:label "Beginning of comment" ;
    ns1:identificador "#COMMENT BEGIN" ;
    ns1:textoExtracto "Beginning of comment." .

ns1:CancelToolOrientationInThePartCoordinateSystem a ns1:Parametro ;
    rdfs:label "Cancel tool orientation in the part coordinate system" ;
    ns1:identificador "#CSROT OFF" ;
    ns1:textoExtracto "Cancel tool orientation in the part coordinate system." .

ns1:ChannelsItClearsTheSynchronismMarksOfTheChannel a ns1:Parametro ;
    rdfs:label "Channels. It clears the synchronism marks of the channel" ;
    ns1:identificador "#CLEAR" ;
    ns1:textoExtracto "Channels. It clears the synchronism marks of the channel." .

ns1:EndOfComment a ns1:Parametro ;
    rdfs:label "End of comment" ;
    ns1:identificador "#COMMENT END" ;
    ns1:textoExtracto "End of comment." .

ns1:MachiningCoordinateSystem a ns1:Parametro ;
    rdfs:label "Machining coordinate system" ;
    ns1:identificador "#CS" ;
    ns1:textoExtracto "Machining coordinate system." .

ns1:ManualInterventionFeedrateInContinuousJog a ns1:Parametro ;
    rdfs:label "Manual intervention. Feedrate in continuous jog" ;
    ns1:identificador "#CONTJOG" ;
    ns1:textoExtracto "Manual intervention. Feedrate in continuous jog." .

