@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivateToolOrientationInThePartCoordinateSystem a ns1:Parametro ;
    rdfs:label "Activate tool orientation in the part coordinate system" ;
    ns1:identificador "#CSROT ON" ;
    ns1:textoExtracto "\"#CSROT ON | Activate tool orientation in the part coordinate system.\"" .

ns1:CAxisMachiningOfTheTurningSideOfThePart a ns1:Parametro ;
    rdfs:label "C axis. Machining of the turning side of the part" ;
    ns1:identificador "#CYL" ;
    ns1:textoExtracto "\"#CYL | \\\"C\\\" axis. Machining of the turning side of the part.\"" .

ns1:CancelToolOrientationInThePartCoordinateSystem a ns1:Parametro ;
    rdfs:label "Cancel tool orientation in the part coordinate system" ;
    ns1:identificador "#CSROT OFF" ;
    ns1:textoExtracto "\"#CSROT OFF | Cancel tool orientation in the part coordinate system.\"" .

ns1:MachiningCoordinateSystem a ns1:Parametro ;
    rdfs:label "Machining coordinate system" ;
    ns1:identificador "#CS" ;
    ns1:textoExtracto "\"#CS | Machining coordinate system.\"" .

ns1:MacrosDefineAMacro a ns1:Parametro ;
    rdfs:label "Macros. Define a macro" ;
    ns1:identificador "#DEF" ;
    ns1:textoExtracto "\"#DEF | Macros. Define a macro.\"" .

