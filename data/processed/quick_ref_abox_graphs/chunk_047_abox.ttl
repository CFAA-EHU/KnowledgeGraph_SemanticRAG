@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LINK a ex:AccionProhibida ;
    ex:textoExtracto "Activate the electronic coupling (slaving) of axes." ;
    rdfs:label "#LINK".

ex:HSC_ON a ex:ModoOperacion ;
    ex:textoExtracto "Activate the HSC mode. Optimizing the contouring error." ;
    rdfs:label "#HSC ON".

ex:HSC_ON_FAST a ex:ModoOperacion ;
    ex:textoExtracto "Activate the HSC mode. Optimizing the machining speed." ;
    rdfs:label "#HSC ON [FAST]".

ex:FOLLOW_ON a ex:ModoOperacion ;
    ex:textoExtracto "Independent axis. Begin the synchronization movement (real coordinates)." ;
    rdfs:label "#FOLLOW ON".

ex:FOLLOW_OFF a ex:ModoOperacion ;
    ex:textoExtracto "Independent axis. End the synchronization movement." ;
    rdfs:label "#FOLLOW OFF".

ex:MASTER a ex:ModoOperacion ;
    ex:textoExtracto "Selecting the master spindle of the channel." ;
    rdfs:label "#MASTER".

ex:KIN_ID a ex:ModoOperacion ;
    ex:textoExtracto "Select a kinematics." ;
    rdfs:label "#KIN ID".

ex:KINORG a ex:AccionProhibida ;
    ex:textoExtracto "Transform the current part zero considering the position of the table kinematics." ;
    rdfs:label "#KINORG".

ex:ESTOP a ex:ModoOperacion ;
    ex:textoExtracto "Enable the cycle stop signal." ;
    rdfs:label "#ESTOP".

ex:ESBLK a ex:ModoOperacion ;
    ex:textoExtracto "Activate the single-block treatment." ;
    rdfs:label "#ESBLK".

ex:DSTOP a ex:ModoOperacion ;
    ex:textoExtracto "Disable the cycle stop signal." ;
    rdfs:label "#DSTOP".

ex:DSBLK a ex:ModoOperacion ;
    ex:textoExtracto "Cancel the single-block treatment." ;
    rdfs:label "#DSBLK".

ex:EFHOLD a ex:ModoOperacion ;
    ex:textoExtracto "Disable the feed-hold signal." ;
    rdfs:label "#EFHOLD".

ex:DFHOLD a ex:ModoOperacion ;
    ex:textoExtracto "Disable the feed-hold signal." ;
    rdfs:label "#DFHOLD".