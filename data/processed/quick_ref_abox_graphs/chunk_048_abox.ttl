@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_MCS ex:textoExtracto "Program a movement referred to machine zero." ;
    rdfs:label "#MCS" ;
    a ex:ModoOperacion .

ex:ModoOperacion_MCS_OFF ex:textoExtracto "Cancel the machine coordinate system." ;
    rdfs:label "#MCS OFF" ;
    a ex:ModoOperacion .

ex:ModoOperacion_MCS_ON ex:textoExtracto "Activate the machine coordinate system." ;
    rdfs:label "#MCS ON" ;
    a ex:ModoOperacion .

ex:ModoOperacion_MDOFF ex:textoExtracto "Turning the subroutine into non-modal." ;
    rdfs:label "#MDOFF" ;
    a ex:ModoOperacion .

ex:ModoOperacion_MEET ex:textoExtracto "Channels. Activate the mark in the indicated channel." ;
    rdfs:label "#MEET" ;
    a ex:ModoOperacion .