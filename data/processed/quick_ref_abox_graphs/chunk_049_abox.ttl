@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MSG a ex:AccionProhibida ;
    ex:textoExtracto "Display a message on the screen." ;
    rdfs:label "MSG" .

ex:PROBE1 a ex:Sensor ;
    ex:textoExtracto "(·M· model). Tool calibration (dimensions and wear). (·T· model). Tool calibration." ;
    rdfs:label "PROBE 1" .

ex:PCALL a ex:AccionProhibida ;
    ex:textoExtracto "Call to a global or local subroutine initializing parameters." ;
    rdfs:label "PCALL" .