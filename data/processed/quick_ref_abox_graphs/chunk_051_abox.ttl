@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccelerationControl a ns1:Parametro ;
    rdfs:label "Acceleration control" ;
    ns1:identificador "SLOPE" ;
    ns1:textoExtracto "#SLOPE | Acceleration control." .

ns1:ActivateSynchronizedSwitching a ns1:Parametro ;
    rdfs:label "Activate synchronized switching" ;
    ns1:identificador "SWTOUT ON" ;
    ns1:textoExtracto "#SWTOUT ON | Activate synchronized switching." .

ns1:ActivateTheOpenLoopMode a ns1:Parametro ;
    rdfs:label "Activate the open loop mode" ;
    ns1:identificador "SERVO OFF" ;
    ns1:textoExtracto "#SERVO OFF | Activate the open loop mode." .

ns1:AkimaSplinesActivateSplineAdaptation a ns1:Parametro ;
    rdfs:label "Akima splines. Activate spline adaptation" ;
    ns1:identificador "SPLINE ON" ;
    ns1:textoExtracto "#SPLINE ON | Akima splines. Activate spline adaptation." .

ns1:AkimaSplinesCancelsSplineAdaptation a ns1:Parametro ;
    rdfs:label "Akima splines. Cancels spline adaptation" ;
    ns1:identificador "SPLINE OFF" ;
    ns1:textoExtracto "#SPLINE OFF | Akima splines. Cancels spline adaptation." .

ns1:CancelSynchronizedSwitching a ns1:Parametro ;
    rdfs:label "Cancel synchronized switching" ;
    ns1:identificador "SWTOUT OFF" ;
    ns1:textoExtracto "#SWTOUT OFF | Cancel synchronized switching." .

ns1:ChannelsActivateTheMarkInItsOwnChannel a ns1:Parametro ;
    rdfs:label "Channels. Activate the mark in its own channel" ;
    ns1:identificador "SIGNAL" ;
    ns1:textoExtracto "#SIGNAL | Channels. Activate the mark in its own channel." .

ns1:ManualInterventionMovingLimits a ns1:Parametro ;
    rdfs:label "Manual intervention. Moving limits" ;
    ns1:identificador "SET OFFSET" ;
    ns1:textoExtracto "#SET OFFSET | Manual intervention. Moving limits." .

ns1:SetANewAxesConfiguration a ns1:Parametro ;
    rdfs:label "Set a new axes configuration" ;
    ns1:identificador "SET AX" ;
    ns1:textoExtracto "#SET AX | Set a new axes configuration." .

ns1:SetANewSpindleConfiguration a ns1:Parametro ;
    rdfs:label "Set a new spindle configuration" ;
    ns1:identificador "SET SP" ;
    ns1:textoExtracto "#SET SP | Set a new spindle configuration." .

