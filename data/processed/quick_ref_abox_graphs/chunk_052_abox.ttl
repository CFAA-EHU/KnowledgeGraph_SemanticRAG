@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivateSynchronizedSwitching a ns1:Parametro ;
    rdfs:label "Activate synchronized switching."@en ;
    ns1:identificador "SWTOUT ON" ;
    ns1:textoExtracto "#SWTOUT ON | Activate synchronized switching." .

ns1:ActivateTangentialControl a ns1:Parametro ;
    rdfs:label "Activate tangential control."@en ;
    ns1:identificador "TANGCTRL ON" ;
    ns1:textoExtracto "#TANGCTRL ON | Activate tangential control." .

ns1:AkimaSplinesActivateSplineAdaptation a ns1:Parametro ;
    rdfs:label "Akima splines. Activate spline adaptation."@en ;
    ns1:identificador "SPLINE ON" ;
    ns1:textoExtracto "#SPLINE ON | Akima splines. Activate spline adaptation." .

ns1:CancelSynchronizedSwitching a ns1:Parametro ;
    rdfs:label "Cancel synchronized switching."@en ;
    ns1:identificador "SWTOUT OFF" ;
    ns1:textoExtracto "#SWTOUT OFF | Cancel synchronized switching." .

ns1:CancelTangentialControl a ns1:Parametro ;
    rdfs:label "Cancel tangential control."@en ;
    ns1:identificador "TANGCTRL OFF" ;
    ns1:textoExtracto "#TANGCTRL OFF | Cancel tangential control." .

ns1:FreezeTangentialControl_c59bc54a66 a ns1:Parametro ;
    rdfs:label "Freeze tangential control."@en ;
    ns1:identificador "TANGCTRL SUSP" ;
    ns1:textoExtracto "#TANGCTRL SUSP | Freeze tangential control." .

ns1:ManualInterventionCoordinateSynchronization a ns1:Parametro ;
    rdfs:label "Manual intervention. Coordinate synchronization."@en ;
    ns1:identificador "SYNC POS" ;
    ns1:textoExtracto "#SYNC POS | Manual intervention. Coordinate synchronization." .

ns1:SpindleSynchronizationBasedOnTheRealActualCoordinate a ns1:Parametro ;
    rdfs:label "Spindle synchronization based on the real (actual) coordinate."@en ;
    ns1:identificador "SYNC" ;
    ns1:textoExtracto "#SYNC | Spindle synchronization based on the real (actual) coordinate." .

