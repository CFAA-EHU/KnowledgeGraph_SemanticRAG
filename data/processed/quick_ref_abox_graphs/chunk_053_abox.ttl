@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivateTheElectronicCamTheoreticalCoordinates a ns1:Parametro ;
    rdfs:label "Activate the electronic cam (theoretical coordinates)" ;
    ns1:identificador "TCAM" ;
    ns1:textoExtracto "#TCAM ON | Activate the electronic cam (theoretical coordinates)." .

ns1:ActivateTheVirtualToolAxis a ns1:Parametro ;
    rdfs:label "Activate the virtual tool axis" ;
    ns1:identificador "VIRTAX ON" ;
    ns1:textoExtracto "#VIRTAX ON | Activate the virtual tool axis." .

ns1:CancelTheElectronicCouplingSlavingOfAxes a ns1:Parametro ;
    rdfs:label "Cancel the electronic coupling (slaving) of axes" ;
    ns1:identificador "UNLINK" ;
    ns1:textoExtracto "#UNLINK | Cancel the electronic coupling (slaving) of axes." .

ns1:CancelTheSpindleSynchronization a ns1:Parametro ;
    rdfs:label "Cancel the spindle synchronization" ;
    ns1:identificador "UNSYNC" ;
    ns1:textoExtracto "#UNSYNC | Cancel the spindle synchronization." .

ns1:ChannelsItWaitsForAMarkToBeActivatedInTheIndicatedChannel a ns1:Parametro ;
    rdfs:label "Channels. It waits for a mark to be activated in the indicated channel" ;
    ns1:identificador "WAIT" ;
    ns1:textoExtracto "#WAIT | Channels. It waits for a mark to be activated in the indicated channel." .

ns1:CorrectTheImplicitToolLengthCompensationOfTheProgram a ns1:Parametro ;
    rdfs:label "Correct the implicit tool length compensation of the program" ;
    ns1:identificador "TLC" ;
    ns1:textoExtracto "#TLC | Correct the implicit tool length compensation of the program." .

ns1:DisplayAWarningOnTheScreen a ns1:Parametro ;
    rdfs:label "Display a warning on the screen" ;
    ns1:identificador "WARNING" ;
    ns1:textoExtracto "#WARNING | Display a warning on the screen." .

ns1:DisplayAWarningOnTheScreenAndInterruptTheProgram a ns1:Parametro ;
    rdfs:label "Display a warning on the screen and interrupt the program" ;
    ns1:identificador "WARNINGSTOP" ;
    ns1:textoExtracto "#WARNINGSTOP | Display a warning on the screen and interrupt the program." .

ns1:IndependentAxisBeginTheSynchronizationMovementTheoreticalCoordinates a ns1:Parametro ;
    rdfs:label "Independent axis. Begin the synchronization movement (theoretical coordinates)" ;
    ns1:identificador "TFOLLOW" ;
    ns1:textoExtracto "#TFOLLOW ON | Independent axis. Begin the synchronization movement (theoretical coordinates)." .

ns1:MinimumRadiusForApplyingConstantTangentialFeedrate a ns1:Parametro ;
    rdfs:label "Minimum radius for applying constant tangential feedrate" ;
    ns1:identificador "TANGFEED" ;
    ns1:textoExtracto "#TANGFEED RMIN | Minimum radius for applying constant tangential feedrate." .

ns1:SelectTheLongitudinalAxisOfTheTool a ns1:Parametro ;
    rdfs:label "Select the longitudinal axis of the tool" ;
    ns1:identificador "TOOL AX" ;
    ns1:textoExtracto "#TOOL AX | Select the longitudinal axis of the tool." .

ns1:SpindleSynchronizationBasedOnTheTheoreticalCoordinate a ns1:Parametro ;
    rdfs:label "Spindle synchronization based on the theoretical coordinate" ;
    ns1:identificador "TSYNC" ;
    ns1:textoExtracto "#TSYNC | Spindle synchronization based on the theoretical coordinate." .

ns1:ToolPerpendicularToTheInclinedPlane a ns1:Parametro ;
    rdfs:label "Tool perpendicular to the inclined plane" ;
    ns1:identificador "TOOL ORI" ;
    ns1:textoExtracto "#TOOL ORI | Tool perpendicular to the inclined plane." .

ns1:UnparkAnAxisOrSpindle a ns1:Parametro ;
    rdfs:label "Unpark an axis or spindle" ;
    ns1:identificador "UNPARK" ;
    ns1:textoExtracto "#UNPARK | Unpark an axis or spindle." .

ns1:WaitForAnEventBeforeResumingExecution a ns1:Parametro ;
    rdfs:label "Wait for an event before resuming execution" ;
    ns1:identificador "WAIT FOR" ;
    ns1:textoExtracto "#WAIT FOR | Wait for an event before resuming execution." .

