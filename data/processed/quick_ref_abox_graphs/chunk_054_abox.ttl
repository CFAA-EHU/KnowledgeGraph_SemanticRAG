@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:TablaConstantesBooleanas a ns1:Tabla ;
    ns1:textoExtracto "Boolean constants. | TRUE True | FALSE Not true" .

ns1:TablaFuncionesMatematicas a ns1:Tabla ;
    ns1:textoExtracto "Mathematical functions. | ABS[...] Absolute value | SQR[...] Square function | SQRT[...] Square root | LOG[...] Decimal logarithm | LN[...] Neperian logarithm | EXP[...] \"e\" function | DEXP[...] Decimal exponent" .

ns1:TablaFuncionesTrigonometricas a ns1:Tabla ;
    ns1:textoExtracto "Trigonometric functions. | SIN[...] Sine | COS[...] Cosine | TAN[...] Tangent | ASIN[...] Arc-sine | ACOS[...] Arc-cosine | ATAN[...] Arc-tangent (within ±90º). | ARG[...] Arc-tangent (within 0-360º)." .

ns1:TablaOperadoresAritmeticos a ns1:Tabla ;
    ns1:textoExtracto "Arithmetic operators. | + Add | - Subtract / change sign | * Multiply | / Divide | += Compounded addition | -= Compounded subtraction | *= Compounded multiplication | /= Compounded division | MOD Remainder of the division | ** Exponent" .

ns1:TablaOperadoresBinarios a ns1:Tabla ;
    ns1:textoExtracto "Binary operators. | & Binary AND | | Binary OR | ^ Exclusive OR (XOR) | INV[...] Inverse" .

ns1:TablaOperadoresLogicos a ns1:Tabla ;
    ns1:textoExtracto "Logic operators. | * Logic AND | + Logic OR" .

ns1:TablaOperadoresRelacionales a ns1:Tabla ;
    ns1:textoExtracto "Relational operators. | == Equal to | != Different | > Greater than | < Smaller than | >= Greater than or equal to | <= Smaller than or equal to" .

