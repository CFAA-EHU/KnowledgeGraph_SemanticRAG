@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioCNC a ns1:InterfazUsuario ;
    rdfs:label "Vista general de la interfaz del CNC" ;
    ns1:ilustradoEn ns1:CNC8070_500a76dd52 ;
    ns1:textoExtracto "Vista general de la interfaz del CNC con un mockup de pantalla etiquetado por letras A–H. Se distinguen: barra de estado superior (icono de fabricante, estado del programa, número de bloque, canales y modo activo), área central para el modo de trabajo, y menús de softkeys vertical y horizontal." .

ns1:CNC8070_500a76dd52 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Vista general de la interfaz del CNC con un mockup de pantalla etiquetado por letras A–H. Se distinguen: barra de estado superior (icono de fabricante, estado del programa, número de bloque, canales y modo activo), área central para el modo de trabajo, y menús de softkeys vertical y horizontal." .

