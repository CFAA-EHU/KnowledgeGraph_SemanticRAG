@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaBusquedaReferenciaAutomatica a ns1:Figura ;
    rdfs:label "Diagrama de búsqueda de referencia automática (subrutina)" ;
    ns1:textoExtracto "Cada diagrama presenta secuencia numerada 1–3 con teclas involucradas (ZERO, START, ESC) y un recuadro que lista ejes del canal." .

ns1:DiagramaBusquedaReferenciaManual a ns1:Figura ;
    rdfs:label "Diagrama de búsqueda de referencia manual por eje" ;
    ns1:textoExtracto "Cada diagrama presenta secuencia numerada 1–3 con teclas involucradas (ZERO, START, ESC) y un recuadro que lista ejes del canal." .

ns1:InterfazUsuarioJogPanel a ns1:InterfazUsuario ;
    rdfs:label "Panel de operador con diagramas circulares tipo selector" ;
    ns1:ilustradoEn ns1:TablaSoftkeys ;
    ns1:textoExtracto "Panel de operador con diagramas circulares tipo selector: uno para modo de jog (continuo/incremental/volantes con factores ×1/×10/×100) y otro para override de avance (0–200%)." .

ns1:InterfazUsuarioKeyboardShortcuts a ns1:InterfazUsuario ;
    rdfs:label "Mosaico de atajos con etiquetas de teclas" ;
    ns1:ilustradoEn ns1:TablaSoftkeys ;
    ns1:textoExtracto "Mosaico de atajos con etiquetas de teclas (CTRL/ALT/Fx) y mini-iconos de los mismos pictogramas de modos (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES)." .

ns1:TablaSoftkeys a ns1:Tabla ;
    rdfs:label "Tabla visual de softkeys" ;
    ns1:textoExtracto "Tabla visual de softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado) y, debajo, dos diagramas de búsqueda de referencia (home)." .

