@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalibracionDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de Herramienta" ;
    ns1:textoExtracto "panel comparativo de calibración de herramienta para fresado y torno con tarjetas que distinguen manual, semi-automática y automática (con sonda)." .

ns1:Componente_604f2991aa a ns1:Componente ;
    rdfs:label "Tecla" ;
    ns1:textoExtracto "Las flechas de flujo y los símbolos numéricos refuerzan el orden de operación." .

ns1:InterfazUsuarioJogContinuo a ns1:InterfazUsuario ;
    rdfs:label "Jog Continuo" ;
    ns1:textoExtracto "jog continuo, jog incremental (pasos visibles en el dial) y volantes (general/individual) con su factor de multiplicación." .

ns1:InterfazUsuarioJogIncremental a ns1:InterfazUsuario ;
    rdfs:label "Jog Incremental" ;
    ns1:textoExtracto "jog continuo, jog incremental (pasos visibles en el dial) y volantes (general/individual) con su factor de multiplicación." .

ns1:InterfazUsuarioVolante a ns1:InterfazUsuario ;
    rdfs:label "Volante" ;
    ns1:textoExtracto "jog continuo, jog incremental (pasos visibles en el dial) y volantes (general/individual) con su factor de multiplicación." .

ns1:PosicionDelEje_73635e4264 a ns1:Parametro ;
    rdfs:label "Posición del Eje" ;
    ns1:textoExtracto "introducción del valor y validación con ENTER/START." .

ns1:SistemaControlHusillo a ns1:Sistema ;
    rdfs:label "Sistema Control Husillo" ;
    ns1:textoExtracto "botonera del husillo maestro con iconos de giro horario/antihorario, parada, orientación y override de velocidad (teclas +/– y selector 0–200%)." .

