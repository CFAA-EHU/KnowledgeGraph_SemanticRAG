@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_730cac8680 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Esquema procedimental con pasos numerados para la calibración automática (selección de herramienta/offset, datos de calibración, START, actualización de tabla)." ;
    ns1:tieneComponente ns1:CalibracionAutomatica .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico" ;
    ns1:textoExtracto "Diagrama de inspección de herramienta con bloques para: acceso tras STOP, ejecución MDI/MDA durante la inspección, reposición de ejes (al punto de interrupción o al inicio del bloque) y restauración del estado del husillo (M3/M4/M5/M19)." ;
    ns1:tieneComponente ns1:InspeccionDeHerramienta_c5b350b03d .

ns1:CalibracionAutomatica a ns1:TareaMantenimiento ;
    rdfs:label "Calibración Automática" ;
    ns1:textoExtracto "Esquema procedimental con pasos numerados para la calibración automática (selección de herramienta/offset, datos de calibración, START, actualización de tabla)." .

ns1:InspeccionDeHerramienta_c5b350b03d a ns1:TareaMantenimiento ;
    rdfs:label "Inspección de Herramienta" ;
    ns1:textoExtracto "Diagrama de inspección de herramienta con bloques para: acceso tras STOP, ejecución MDI/MDA durante la inspección, reposición de ejes (al punto de interrupción o al inicio del bloque) y restauración del estado del husillo (M3/M4/M5/M19)." .

