@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CannedCycleG81 a ns1:Sistema ;
    rdfs:label "Canned Cycle G81" ;
    ns1:documentadoEn ns1:InterfazUsuarioOperacionesArchivos ;
    ns1:textoExtracto "Corte seccional del taladro con broca descendiendo desde un plano de referencia 'Z'" .

ns1:CannedCycleG82 a ns1:Sistema ;
    rdfs:label "Canned Cycle G82" ;
    ns1:documentadoEn ns1:InterfazUsuarioOperacionesArchivos ;
    ns1:textoExtracto "Dos esquemas de taladrado a pecks con pasos 'B/H', plano de referencia 'Z' y retorno rápido (G0)." .

ns1:InterfazUsuarioHojaReferencia a ns1:InterfazUsuario ;
    rdfs:label "Hoja de referencia con iconos de acciones sobre tablas" ;
    ns1:ilustradoEn ns1:SistemaPLC ;
    ns1:textoExtracto "Hoja de referencia con iconos de acciones sobre tablas de orígenes y utillajes: cambio de unidades, inicializar, buscar, ver otros canales, filtrar ejes, guardar/restaurar y imprimir." .

ns1:Parametro_1da298590b a ns1:Parametro ;
    rdfs:label "Parámetro L" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "el texto lateral ancla parámetros (R, L, J)" .

ns1:Parametro_ee0a746269 a ns1:Parametro ;
    rdfs:label "Parámetro R" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "el texto lateral ancla parámetros (R, L, J)" .

ns1:Parametro_ff5a113b44 a ns1:Parametro ;
    rdfs:label "Parámetro J" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "el texto lateral ancla parámetros (R, L, J)" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Los bloques explican el significado de PLC offset vs absolute zero offsets" .

ns1:InterfazUsuarioOperacionesArchivos a ns1:InterfazUsuario ;
    rdfs:label "Cuadro de operaciones de archivos con iconos" ;
    ns1:textoExtracto "Cuadro de operaciones de archivos con iconos (Cut, Copy, Paste, Rename, atributos -M- y -H-, Encrypt, Delete)." .

