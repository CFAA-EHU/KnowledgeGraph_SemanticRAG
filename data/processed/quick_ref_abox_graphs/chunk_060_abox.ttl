@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G83 a ex:ModoOperacion ;
    ex:textoExtracto "Deep-hole drilling canned cycle with constant peck. — G90/G91" ;
    rdfs:label "G83" .

ex:G84 a ex:ModoOperacion ;
    ex:textoExtracto "Tapping canned cycle. — G90/G91" ;
    rdfs:label "G84" .

ex:G85 a ex:ModoOperacion ;
    ex:textoExtracto "Reaming canned cycle. — G90/G91" ;
    rdfs:label "G85" .

ex:G86 a ex:ModoOperacion ;
    ex:textoExtracto "Boring canned cycle. — G90/G91" ;
    rdfs:label "G86" .

ex:G87 a ex:ModoOperacion ;
    ex:textoExtracto "Rectangular pocket canned cycle." ;
    rdfs:label "G87" .

ex:EsquemaCiclosCanned a ex:Esquema ;
    ex:textoExtracto "Flechas segmentadas representan pecks sucesivos; el texto lateral ancla parámetros (R, L, J) y la geometría ilustra la retirada periódica para evacuar viruta. Vista seccional del taladro profundo con pecks constantes “I” y retiradas “B” tras cada paso. Dos viñetas muestran programación absoluta/incremental; las flechas y cotas marcan fondo, peck y permanencia “K”. Esquema del roscado con macho, con plano “Z”, profundidad “I” y pausa “K”. La simbología de sentido y el bloque de texto asocian tipo de roscado (R0 normal/R1 rígido) y factor de retirada “J”. Representación de escariado con herramienta cilíndrica; líneas de guía indican avance hasta “I” y permanencia “K”. Se mantiene la lectura por plano de referencia “Z” y retorno. Dos viñetas de mandrinado con parámetros de retirada “R” y separación de pared mediante orientación “Q” y desplazamientos laterales “D/E”. Flechas curvas y rectas señalan salida del útil para evitar roce." ;
    ex:tieneComponente ex:G83, ex:G84, ex:G85, ex:G86, ex:G87 .