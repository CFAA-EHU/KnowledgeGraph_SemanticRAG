ns1:BoringCannedCycle_ece8cb62b2 a ns1:Parametro ;
    rdfs:label "Boring canned cycle" ;
    ns1:detalladoEnEsquema ns1:EsquemaCiclosPredefinidos ;
    ns1:identificador "G86" ;
    ns1:textoExtracto "Dos viñetas de mandrinado con parámetros de retirada 'R' y separación de pared mediante orientación 'Q' y desplazamientos laterales 'D/E'." .

ns1:DeepHoleDrillingCannedCycleWithConstantPeck a ns1:Parametro ;
    rdfs:label "Deep-hole drilling canned cycle with constant peck" ;
    ns1:detalladoEnEsquema ns1:EsquemaCiclosPredefinidos ;
    ns1:identificador "G83" ;
    ns1:textoExtracto "Vista seccional del taladro profundo con pecks constantes 'I' y retiradas 'B' tras cada paso." .

ns1:ReamingCannedCycle_1732d639fe a ns1:Parametro ;
    rdfs:label "Reaming canned cycle" ;
    ns1:detalladoEnEsquema ns1:EsquemaCiclosPredefinidos ;
    ns1:identificador "G85" ;
    ns1:textoExtracto "Representación de escariado con herramienta cilíndrica; líneas de guía indican avance hasta 'I' y permanencia 'K'." .

ns1:RectangularPocketCannedCycle_db53213e3b a ns1:Parametro ;
    rdfs:label "Rectangular pocket canned cycle" ;
    ns1:detalladoEnEsquema ns1:EsquemaCiclosPredefinidos ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "Dos viñetas de mandrinado con parámetros de retirada 'R' y separación de pared mediante orientación 'Q' y desplazamientos laterales 'D/E'." .

ns1:TappingCannedCycle a ns1:Parametro ;
    rdfs:label "Tapping canned cycle" ;
    ns1:detalladoEnEsquema ns1:EsquemaCiclosPredefinidos ;
    ns1:identificador "G84" ;
