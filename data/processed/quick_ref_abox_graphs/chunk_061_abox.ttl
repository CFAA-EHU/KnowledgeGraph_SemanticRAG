@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CircularPocketCannedCycle_4ba117cbbf a ns1:Parametro ;
    rdfs:label "Circular pocket canned cycle" ;
    ns1:textoExtracto "Esquema de bolsillo circular con radio 'J' y pasadas radiales 'B/C'; se anotan profundidad 'I', plano 'Z' y acabado 'L/H'. La sección de pieza clarifica penetración 'V'." .

ns1:MultipleMachiningInGridPattern a ns1:Parametro ;
    rdfs:label "Multiple machining in grid pattern" ;
    ns1:textoExtracto "Retícula ortogonal con distribución regular de puntos; se identifican longitudes 'X/Y' y pasos 'I/J'. La malla enfatiza la generación de matrices de taladros." .

ns1:MultipleMachiningInRectangularPattern a ns1:Parametro ;
    rdfs:label "Multiple machining in rectangular pattern" ;
    ns1:textoExtracto "Paralelepípedo/paralelogramo con dos direcciones de maquinado (ángulos A y B). Se visualizan pasos 'I/J' en X/Y y totales 'K/D'; la cuadricula ligera ordena las posiciones." .

ns1:MultipleMachiningInStraightLine a ns1:Parametro ;
    rdfs:label "Multiple machining in straight line" ;
    ns1:textoExtracto "Patrón lineal con puntos numerados y flechas de avance; ángulo 'A' define la dirección, longitud 'X', paso 'I' y número de operaciones 'K'. La línea punteada marca el trazado de centros." .

ns1:RectangularPocketCannedCycle_7703cd79e7 a ns1:Parametro ;
    rdfs:label "Rectangular pocket canned cycle" ;
    ns1:textoExtracto "Vista superior de un cajetín rectangular con ángulo 'A' respecto a X, semiejes 'J/K', tipo de esquina 'M' (viva/redondeada/chaflán) y radios 'Q'. Flechas muestran pasadas 'B/C' y pasada de acabado 'L/H'." .

