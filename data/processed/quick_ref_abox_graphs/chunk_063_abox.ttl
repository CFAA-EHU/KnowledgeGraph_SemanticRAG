@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G69 a ex:ModoOperacion ;
    rdfs:label "G69. Stock removal canned cycle along Z axis" ;
    ex:textoExtracto "Desbaste análogo al anterior pero a lo largo de Z; diagramación con franjas de material y retracciones controladas." ;
    ex:identificador "G69" .

ex:G81 a ex:ModoOperacion ;
    rdfs:label "G81. Turning canned cycle with straight sections" ;
    ex:textoExtracto "Perfil con tramos rectos (cilindrado/planeado) entre puntos (X,Z)–(Q,R). Capas de desbaste “C” y retiradas “D” con stocks “L/M”." ;
    ex:identificador "G81" .

ex:G82 a ex:ModoOperacion ;
    rdfs:label "G82. Facing canned cycle with straight sections" ;
    ex:textoExtracto "Planeado en Z con franjas de pasada; mismo código visual de stocks y avances que G81, pero orientado al frente." ;
    ex:identificador "G82" .

ex:G83 a ex:ModoOperacion ;
    rdfs:label "G83. Axial drilling and tapping canned cycle" ;
    ex:textoExtracto "Taladrado/roscado axial en torno: dos bloques (drilling/tapping). Se muestran seguridad “D”, pecks “H/C/R” y profundidad “I”." ;
    ex:identificador "G83" .

ex:G84 a ex:ModoOperacion ;
    rdfs:label "G84. Turning canned cycle with arcs" ;
    ex:textoExtracto "Perfil con transición por arco; vectores “I/K” desde el origen al centro del arco y franjas de desbaste." ;
    ex:identificador "G84" .

ex:G85 a ex:ModoOperacion ;
    rdfs:label "G85. Facing canned cycle with arcs" ;
    ex:textoExtracto "Variante de planeado con arco de unión; misma simbología de stocks y retirada." ;
    ex:identificador "G85" .

ex:G86 a ex:ModoOperacion ;
    rdfs:label "G86. Longitudinal threading or thread repair canned cycle" ;
    ex:textoExtracto "Rosca longitudinal con penetraciones escalonadas “B/E” y ángulo de penetración “A”. Se marcan inicio/fin (Q/R) y posición angular “W”." ;
    ex:identificador "G86" .