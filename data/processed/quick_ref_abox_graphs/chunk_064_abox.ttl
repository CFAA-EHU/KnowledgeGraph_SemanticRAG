@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloEmbotelladoDeRanuradoAxial a ns1:Parametro ;
    rdfs:label "Ciclo embotellado de ranurado axial" ;
    ns1:identificador "G88" ;
    ns1:textoExtracto "Ranurado axial con varias penetraciones \"C\", seguridad \"D\" y demora \"K\"; el esquema muestra los escalones en X con fin en (Q,R)."@es .

ns1:CicloEmbotelladoDeRanuradoFrontal a ns1:Parametro ;
    rdfs:label "Ciclo embotellado de ranurado frontal" ;
    ns1:identificador "G89" ;
    ns1:textoExtracto "Ranurado frontal con penetraciones en Z; idéntica representación de pasadas y retirada." .

ns1:CicloEmbotelladoDeRoscaFrontalEnCara a ns1:Parametro ;
    rdfs:label "Ciclo embotellado de rosca frontal (en cara)" ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "Rosca frontal (en cara): análogo al anterior pero referenciado a coordenadas en X; retirada \"J\" y tolerancias de penetración."@es .

ns1:FresadoRanuraLateral a ns1:Parametro ;
    rdfs:label "Fresado ranura lateral" ;
    ns1:identificador "G162" ;
    ns1:textoExtracto "Fresado ranura lateral: longitud \"L\", profundidad \"I\" y reparto angular (Q/A/J)."@es .

ns1:Herramienta_0408789aa3 a ns1:Herramienta ;
    rdfs:label "Herramienta motorizada para fresado ranura lateral" ;
    ns1:textoExtracto "se ilustra herramienta motorizada y sentido." .

ns1:Herramienta_8b96c9014e a ns1:Herramienta ;
    rdfs:label "Herramienta motorizada (S/N)" ;
    ns1:textoExtracto "Iconografía de herramienta motorizada (S/N) y seguridad \"D/H/C/R\"."@es .

ns1:TaladradoFresadoEnCaraDelCilindro a ns1:Parametro ;
    rdfs:label "Taladrado/fresado en cara del cilindro" ;
    ns1:identificador "G160" ;
    ns1:textoExtracto "Cilindro en cara con múltiples taladros repartidos angularmente (Q/A/J)." .

ns1:TaladradoFresadoEnLateralDelCilindro a ns1:Parametro ;
    rdfs:label "Taladrado/fresado en lateral del cilindro" ;
    ns1:identificador "G161" ;
    ns1:textoExtracto "Taladrado radial en el lateral del cilindro; distribución angular y parámetros análogos con seguridad a lo largo de X." .

