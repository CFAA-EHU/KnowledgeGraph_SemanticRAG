@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalibracionDeSondaDeMesa a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda de mesa" ;
    ns1:textoExtracto "Tabletop probe calibration. --- Calibración de sonda de mesa: esquema de palpado radial con posiciones teóricas X..W y secuencias de avance H/F, incluyendo tipo de calibración 'I'." .

ns1:DistanciaDeSeguridad a ns1:Parametro ;
    rdfs:label "Distancia de seguridad" ;
    ns1:identificador "B" ;
    ns1:textoExtracto "Palpado en torno con sonda de mesa; se resaltan lados activos 'K', distancia de seguridad 'B' y velocidades de palpado." .

ns1:LadosActivos a ns1:Parametro ;
    rdfs:label "Lados activos" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "Palpado en torno con sonda de mesa; se resaltan lados activos 'K', distancia de seguridad 'B' y velocidades de palpado." .

ns1:MedicionSobreCaraCilindrica a ns1:TareaMantenimiento ;
    rdfs:label "Medición sobre cara cilíndrica" ;
    ns1:textoExtracto "Part measuring along the ordinate axis. --- Medición sobre cara cilíndrica con vector de palpado en Y y referencia en Z; incluye tolerancia 'L' y corrección de desgaste T/D." .

ns1:PalpadoEnTornoConSondaDeMesa a ns1:TareaMantenimiento ;
    rdfs:label "Palpado en torno con sonda de mesa" ;
    ns1:textoExtracto "Tool calibration. --- Palpado en torno con sonda de mesa; se resaltan lados activos 'K', distancia de seguridad 'B' y velocidades de palpado." .

ns1:Parametro_1da298590b a ns1:Parametro ;
    rdfs:label "Tolerancia" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "Medición sobre cara cilíndrica con vector de palpado en Y y referencia en Z; incluye tolerancia 'L' y corrección de desgaste T/D." .

ns1:TipoDeCalibracion a ns1:Parametro ;
    rdfs:label "Tipo de calibración" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "Calibración de sonda de mesa: esquema de palpado radial con posiciones teóricas X..W y secuencias de avance H/F, incluyendo tipo de calibración 'I'." .

