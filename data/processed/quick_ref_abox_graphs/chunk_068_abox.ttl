@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MedicionEquivalenteALaAnteriorPeroConVectorDePalpadoEnX a ns1:AccionProhibida ;
    rdfs:label "Medición equivalente a la anterior pero con vector de palpado en X" ;
    ns1:textoExtracto "Part measuring along the abscissa axis. --- Medición equivalente a la anterior pero con vector de palpado en X; se mantienen B, F, L y referencias a T/D." .

