    ns1:textoExtracto "Mathematical functions. ABS[...] Absolute value SQR[...] Square function SQRT[...] Square root LOG[...] Decimal logarithm LN[...] Neperian logarithm EXP[...] \"e\" function DEXP[...] Decimal exponent" .

ns1:FuncionTrigonometrica a ns1:Tabla ;
