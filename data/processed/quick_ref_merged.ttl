ns1:G83 a ns1:ModoOperacion ;
    rdfs:label "G83",
        "G83. Axial drilling and tapping canned cycle" ;
    ns1:identificador "G83" ;
    ns1:textoExtracto "(·M· model). Deep-hole drilling canned cycle with constant peck.",
        "Deep-hole drilling canned cycle with constant peck. — G90/G91",
        "Taladrado/roscado axial en torno: dos bloques (drilling/tapping). Se muestran seguridad “D”, pecks “H/C/R” y profundidad “I”." ;
    ns1:valor "(·M· model). Deep-hole drilling canned cycle with constant peck." .

ns1:G84 a ns1:ModoOperacion ;
    rdfs:label "G84",
        "G84. Turning canned cycle with arcs" ;
    ns1:identificador "G84" ;
    ns1:textoExtracto "(·M· model). Tapping canned cycle.",
        "Perfil con transición por arco; vectores “I/K” desde el origen al centro del arco y franjas de desbaste.",
        "Tapping canned cycle. — G90/G91",
        "Turning canned cycle with arcs."@en ;
    ns1:valor "(·M· model). Tapping canned cycle." .

ns1:G85 a ns1:ModoOperacion ;
    rdfs:label "G85",
        "G85. Facing canned cycle with arcs" ;
    ns1:identificador "G85" ;
    ns1:textoExtracto "Reaming canned cycle. — G90/G91",
        "Variante de planeado con arco de unión; misma simbología de stocks y retirada.",
        "(·M· model). Reaming canned cycle."@en,
        "(·T· model). Facing canned cycle with arcs."@en .

ns1:G86 a ns1:ModoOperacion ;
    rdfs:label "G86",
        "G86. Longitudinal threading or thread repair canned cycle" ;
    ns1:identificador "G86" ;
    ns1:textoExtracto "Boring canned cycle. — G90/G91",
        "Rosca longitudinal con penetraciones escalonadas “B/E” y ángulo de penetración “A”. Se marcan inicio/fin (Q/R) y posición angular “W”.",
        "(·M· model). Boring canned cycle."@en,
        "(·T· model). Longitudinal threading canned cycle."@en .

ns1:G87 a ns1:Esquema,
        ns1:ModoOperacion ;
    rdfs:label "G87" ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "Rectangular pocket canned cycle.",
        "Rosca longitudinal con penetraciones escalonadas “B/E” y ángulo de penetración “A”. Se marcan inicio/fin (Q/R) y posición angular “W”.",
        "Vista superior de un cajetín rectangular con ángulo “A” respecto a X, semiejes “J/K”, tipo de esquina “M” (viva/redondeada/chaflán) y radios “Q”. Flechas muestran pasadas “B/C” y pasada de acabado “L/H”.",
        "(·M· model). Rectangular pocket canned cycle."@en,
        "(·T· model). Face threading canned cycle."@en ;
    ns1:tieneComponente ns1:CajetinRectangular,
        ns1:FlechaCurva,
        ns1:FlechaRecta .

