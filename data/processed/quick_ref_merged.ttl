    ns1:textoExtracto "#TANGFEED RMIN | Minimum radius for applying constant tangential feedrate. [...] #WARNINGSTOP | Display a warning on the screen and interrupt the program." .

ns1:Tabla_FuncionesG a ns1:Tabla ;
    rdfs:label "Tabla de funciones G (modelos M y T)"@es,
        "Tabla de funciones G para control de máquina"@es ;
    ns1:documentadoEn ns1:Manual_Tecnologico,
