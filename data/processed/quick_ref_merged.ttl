    ns1:textoExtracto "Reposition the axes to the point to resume execution." .

ns1:EjeLongitudinal a ns1:ComponenteMecanico ;
    rdfs:label "Eje longitudinal" ;
    ns1:textoExtracto "Select the longitudinal axis of the tool." .

ns1:EjeSeleccionado a ns1:Parametro ;
    rdfs:label "axis"@en ;
    ns1:textoExtracto "Select the axis and the probing direction on the softkey menu"@en .

ns1:EjeVirtual a ns1:ComponenteMecanico ;
    rdfs:label "Eje virtual" ;
    ns1:textoExtracto "Activate the virtual tool axis." .

ns1:EsquemaCalibracion a ns1:Esquema ;
    rdfs:label "Esquema de calibración" ;
    ns1:ilustradoEn ns1:FresadoEnCara ;
    ns1:textoExtracto "esquema con pieza en vista frontal." .

ns1:EsquemaCiclosCanned a ns1:Esquema ;
    ns1:textoExtracto "Flechas segmentadas representan pecks sucesivos; el texto lateral ancla parámetros (R, L, J) y la geometría ilustra la retirada periódica para evacuar viruta. Vista seccional del taladro profundo con pecks constantes “I” y retiradas “B” tras cada paso. Dos viñetas muestran programación absoluta/incremental; las flechas y cotas marcan fondo, peck y permanencia “K”. Esquema del roscado con macho, con plano “Z”, profundidad “I” y pausa “K”. La simbología de sentido y el bloque de texto asocian tipo de roscado (R0 normal/R1 rígido) y factor de retirada “J”. Representación de escariado con herramienta cilíndrica; líneas de guía indican avance hasta “I” y permanencia “K”. Se mantiene la lectura por plano de referencia “Z” y retorno. Dos viñetas de mandrinado con parámetros de retirada “R” y separación de pared mediante orientación “Q” y desplazamientos laterales “D/E”. Flechas curvas y rectas señalan salida del útil para evitar roce." ;
    ns1:tieneComponente ns1:G83,
        ns1:G84,
        ns1:G85,
        ns1:G86,
        ns1:G87 .

ns1:EsquemaMedicion a ns1:Esquema ;
    rdfs:label "Esquema de medición" ;
    ns1:ilustradoEn ns1:CalibracionHerramienta ;
    ns1:textoExtracto "flechas muestran la trayectoria de la sonda respecto a herramienta y mesa." .

ns1:Esquema_59_1 a ns1:Esquema ;
    ns1:textoExtracto "Corte seccional del taladro con broca descendiendo desde un plano de referencia “Z”, mostrando dos viñetas (G90/G91) con flechas verticales que indican profundidad “I” y permanencia “K” al fondo. El sombreado de la pieza y las cotas ayudan a entender el avance y el retorno del husillo según sistema absoluto o incremental." .

ns1:Esquema_59_2 a ns1:Esquema ;
    ns1:textoExtracto "Dos esquemas de taladrado a pecks con pasos “B/H”, plano de referencia “Z” y retorno rápido (G0). Flechas segmentadas representan pecks sucesivos; el texto lateral ancla parámetros (R, L, J) y la geometría ilustra la retirada periódica para evacuar viruta." .

ns1:Execution_time_estimate a ns1:InterfazUsuario ;
    rdfs:label "Execution time estimate" ;
    ns1:textoExtracto "Offer an estimate of the total execution time at 100% of the programmed feedrate. The result will appear at the statistics window." .

ns1:FOLLOW_OFF a ns1:ModoOperacion ;
    rdfs:label "#FOLLOW OFF" ;
    ns1:textoExtracto "Independent axis. End the synchronization movement." .

ns1:FOLLOW_ON a ns1:ModoOperacion ;
    rdfs:label "#FOLLOW ON" ;
    ns1:textoExtracto "Independent axis. Begin the synchronization movement (real coordinates)." .

ns1:FeedSelector a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Feed selectors. jog 1 1 10 10 100 100 1000 10000 Sector for the type of jog; continuous / incremental jog or handwheels. • In handwheel mode, it selects the multiplying for the handwheel pulses (x1, x10 o x100). • In incremental mode, it selects the incremental value of the axis movements." .

ns1:Feedrate a ns1:Parametro ;
    rdfs:label "Feedrate"@en ;
    ns1:textoExtracto "Feedrate. |  | F | 1 Press [F] at the alphanumeric keyboard. 2 Enter the new feedrate. |  | 3 Press [START] to assume the entered value or [ESC] to cancel the operation."@en .

ns1:FresadoRanuraLateral a ns1:TareaMantenimiento ;
    rdfs:label "Fresado ranura lateral" ;
    ns1:textoExtracto "Slot milling along the side of the part. --- Fresado ranura lateral: longitud “L”, profundidad “I” y reparto angular (Q/A/J); se ilustra herramienta motorizada y sentido." ;
    ns1:tieneComponente ns1:HerramientaMotorizada .

