ns1:InterfazUsuario_ModoMDI_MDA a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de calibración automática (MDI/MDA)"@es ;
    ns1:identificador "MDI/MDA MODE - Automatic calibration" ;
    ns1:textoExtracto "Esquema procedimental con pasos numerados para la calibración automática (selección de herramienta/offset, datos de calibración, START, actualización de tabla). La maquetación por bloques y uso de teclas representadas (START/RESET) ofrecen una direccionalidad clara sin gráficos de ejes; funciona como diagrama textual de la rutina de sondeo."@es ;
    ns1:tieneComponente ns1:Boton_RESET_MDI,
        ns1:Boton_START_MDI,
        ns1:Tabla_DatosCalibracion .

ns1:InterfazUsuario_OrigenesActivos a ns1:InterfazUsuario ;
    rdfs:label "Assume the active origins for execution" ;
    ns1:textoExtracto "Assume the active origins for execution. When starting the simulation or pressing the simulation reset, the CNC applies to the simulation the origins set in the execution environment (for example, the part zero set in jog mode)." .

ns1:InterfazUsuario_PanelJog a ns1:InterfazUsuario ;
