ns1:AbsoluteZeroOffset a ns1:Parametro ;
    rdfs:label "Absolute zero offset"@en ;
    ns1:documentadoEn ns1:Tabla_ZeroOffsets ;
    ns1:textoExtracto "Absolute zero offsets besides being set directly in the table may also be set from the PLC or via part-program using variables. The zero offsets are used to place the part zero at different positions of the machine."@en ;
    ns1:valor "Set directly in table, from PLC, or via part-program"@en .

