ns1:Tabla_InstruccionesHLL a ns1:Tabla ;
    rdfs:label "High-Level Language (HLL) Instruction Table"@en ;
    ns1:textoExtracto """\r
| Instruction. | Meaning. |\r
| --- | --- |\r
| $GOTO | Block skip. |\r
| $IF $ENDIF $ELSEIF $ELSE | Conditional execution. |\r
| $SWITCH $CASE $ENDSWITCH $BREAK $DEFAULT | Conditional execution. |\r
| $FOR $ENDFOR $BREAK $CONTINUE | Block repetition. |\r
| $WHILE $ENDWHILE $BREAK $CONTINUE | Conditional block repetition. |\r
| $DO $ENDDO $BREAK $CONTINUE | Conditional block repetition. |\r
| L | Call to a global subroutine. |\r
| LL | Call to a local subroutine. |\r
| #ABORT | Abort the execution of the program and resume it in another block or program. |\r
| #ACS | Fixture coordinate system. |\r
| #ANGAX OFF/ON/SUSP | Turn angular transformation off/on/freeze. |\r
| #ASPLINE ENDTANG/STARTTANG/MODE | Akima splines. Tangent type selection. |\r
| #AXIS | Axis for additive manual intervention. |\r
| #CALL | Call to a global or local subroutine. |\r
| #CALL AX/SP | Add axis/spindle to channel configuration. |\r
| #CAM ON/OFF | Activate/cancel electronic cam. |\r
| #CAX | Activate spindle as "C" axis. |\r
| #CD ON/OFF | Activate/cancel collision detection. |\r
| #CLEAR | Clear synchronism marks of the channel. |\r
| #CONTJOG | Feedrate in continuous jog. |\r
| #COMMENT BEGIN/END | Comment delimiters.""" .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
