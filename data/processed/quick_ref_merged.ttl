    ns1:monitoreaParametro ns1:AutomaticHomeSearchWithSubroutine,
        ns1:ManualHomeSearchOneAxisAtATime ;
    ns1:textoExtracto "The CNC will highlight the coordinate of that axis."@en .

ns1:BlockExecutionMode a ns1:ModoOperacion ;
    rdfs:label "Execute Blocks Separately mode" ;
    ns1:habilitadoPor ns1:EXBLK_Softkey ;
    ns1:textoExtracto "Being this option active, every time the [START] key is pressed, it only executes the block selected in the active program." .

ns1:BusquedaAutomaticaBloques a ns1:ModoOperacion ;
    rdfs:label "Automatic Block Search"@en ;
    ns1:habilitadoPor ns1:BlockSearch ;
    ns1:textoExtracto "The automatic block search may be used to recover the program history up to the block where the previous execution was canceled. The CNC remembers the block where interruption was canceled, thus not being necessary to set the stop block."@en .

ns1:BusquedaManualBloques a ns1:ModoOperacion ;
    rdfs:label "Manual Block Search"@en ;
    ns1:habilitadoPor ns1:BlockSearch ;
    ns1:textoExtracto "The manual block search may be used to recover the program history up to a particular block of the program or of the subroutine, set by the operator."@en .

