ns1:InterfazUsuario_4_Keyboard a ns1:InterfazUsuario ;
    rdfs:label "Keyboard interface for home search"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:textoExtracto "Select the axis to be homed (on alphanumeric keyboard). The CNC will highlight the coordinate of that axis. [...] Press the homing key [ZERO]. The CNC will display the symbol '1' in the numeric area."@en .

ns1:InterfazUsuario_4_SoftkeyMenu a ns1:InterfazUsuario ;
    rdfs:label "Softkey menu for home search"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:textoExtracto "Press the home search softkey to show the list of axes of the channel. [...] Select the axis to be homed on the softkey menu."@en .

ns1:InterfazUsuario_ReposicionamientoEjes a ns1:InterfazUsuario ;
    rdfs:label "Repositioning interface for axes and spindle"@en ;
    ns1:textoExtracto "The CNC allows repositioning the axes either one by one or in groups. Use the vertical softkeys to select the axes to be repositioned and press [START]. The CNC will reposition the axes at the selected point (according to the softkey selected earlier) at the feedrate set by the machine manufacturer. Once one axis has reached its position, it will no longer be available. Repositioning the master spindle. If the status of the master spindle has changed during the inspection, the softkeys will show the M3, M4, M5 or M19 function to restore."@en .

ns1:JogTypeSector_5 a ns1:InterfazUsuario ;
    rdfs:label "Jog type sector"@en ;
    ns1:textoExtracto "Sector for the type of jog; continuous / incremental jog or handwheels. • In handwheel mode, it selects the multiplying for the handwheel pulses (x1, x10 o x100). • In incremental mode, it selects the incremental value of the axis movements."@en .

ns1:Key_SINGLE a ns1:Componente ;
    rdfs:label "SINGLE Key"@en ;
    ns1:textoExtracto "Single-block execution mode. The program may be executed in –single block– or –automatic– mode; the mode may be selected even while executing the program."@en .

ns1:ManualHomeSearchOneAxisAtATime a ns1:TareaMantenimiento ;
