ns1:CalibracionDeHerramientaEnTornoPROBE1T a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de herramienta en torno (PROBE 1 ·T·)" ;
    ns1:identificador "PROBE 1 (T·MODEL)" ;
    ns1:monitoreaParametro ns1:DistanciaDeSeguridadB,
        ns1:OrdenDePalpadoK ;
    ns1:textoExtracto "Palpado en torno con sonda de mesa; se resaltan lados activos 'K', distancia de seguridad 'B' y velocidades de palpado." .

ns1:CalibracionDeSondaDeMesaPROBE2T a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda de mesa (PROBE 2 ·T·)" ;
    ns1:identificador "PROBE 2 (T·MODEL)" ;
    ns1:textoExtracto "Esquema de calibración con selección de lados de palpado y posiciones X..W; códigos idénticos a #PROBE 1." .

ns1:CalibracionDeSondaDeMesaTabletopProbeCalibration a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda de mesa (Tabletop probe calibration)" ;
    ns1:identificador "Tabletop probe calibration" ;
    ns1:monitoreaParametro ns1:SecuenciaDeAvanceF,
        ns1:SecuenciaDeAvanceH,
        ns1:TipoDeCalibracionI ;
    ns1:textoExtracto "Calibración de sonda de mesa: esquema de palpado radial con posiciones teóricas X..W y secuencias de avance H/F, incluyendo tipo de calibración 'I'." .

ns1:CalibracionHerramienta_Automatica a ns1:TareaMantenimiento ;
    rdfs:label "Automatic tool calibration"@en ;
    ns1:ejecutadoPor ns1:InterfazCNC_ProcesoCalibracion ;
    ns1:textoExtracto "Automatic calibration. Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle. The CNC moves the tool until touching the probe and validates the calibration on each"@en .

ns1:CalibracionHerramienta_SemiAutomatica a ns1:TareaMantenimiento ;
    rdfs:label "Semi-automatic tool calibration"@en ;
    ns1:ejecutadoPor ns1:InterfazCNC_ProcesoCalibracion ;
    ns1:requiereMantenimiento ns1:EndmillTool,
        ns1:LatheTool_b3607770ec ;
    ns1:textoExtracto "Semi-automatic calibration. Calibration with a probe. The positioning movements are carried out manually and the CNC executes the probing movements. The CNC will move the tool on the selected axis until it touches the probe and validates the calibration only on that axis."@en .

