@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_19_1 a ns1:AccionProhibida ;
    ns1:textoExtracto "activate M and H functions" .

ns1:AutomaticCalibrationMode a ns1:ModoOperacion ;
    rdfs:label "Automatic calibration mode" ;
    ns1:textoExtracto "Automatic calibration. The CNC executes all the movements using the calibration (Calibration with probe). canned cycle #PROBE." .

ns1:AxisRepositioning a ns1:TareaMantenimiento ;
    ns1:identificador "Axis repositioning" ;
    ns1:textoExtracto "the spindle turning direction must be restored and the axes repositioned." .

ns1:BlockSelection a ns1:InterfazUsuario ;
    rdfs:label "Block selection interface" ;
    ns1:textoExtracto "it only executes the block selected in the active program" .

ns1:BloqueBusqueda a ns1:ModoOperacion ;
    ns1:identificador "block search" ;
    ns1:textoExtracto "With block search, it is possible to recover the program history up to a particular block in such way that if program execution is resumed at that block, it will do so with the same conditions as if it were executed from the beginning." .

ns1:BloquePrograma a ns1:Componente ;
    rdfs:label "Program block"@en ;
    ns1:textoExtracto "Edit new blocks. • Modify a block from the block history. • The [START] key executes the block currently displayed on the editing line. Once the block has been executed is saved in the block history." .

ns1:BotonSTART a ns1:InterfazUsuario ;
    rdfs:label "[START]"@en ;
    ns1:textoExtracto "press [START]"@en .

ns1:BusquedaBloque a ns1:TareaMantenimiento ;
    ns1:identificador "Executing block search" ;
    ns1:textoExtracto "Executing block search. 1 Selecting the type of search: automatic or manual. 2 Selecting the stop block. In the automatic block search, there is no need to select the stop block; by default, the CNC runs the search up to the block where the program was interrupted. 3 Selecting the starting block for the search. If the first block is not selected, the block search starts at the beginning of the program. 4 Press the [CYCLE START] key to start the block search. 5 Depending on how the treatment of functions M, H, F, S is configured, it may be necessary to decide which ones are sent out to the PLC. 6 Reposition the axes to the point to resume execution. 7 Tool inspection may be accessed to change the machining conditions. 8 Press [START] to execute the program." .

ns1:BusquedaBloqueAutomatica a ns1:ModoOperacion ;
    ns1:identificador "automatic block search" ;
    ns1:textoExtracto "The automatic block search may be used to recover the program history up to the block where the previous execution was canceled. The CNC remembers the block where interruption was canceled, thus not being necessary to set the stop block." .

ns1:BusquedaBloqueManual a ns1:ModoOperacion ;
    ns1:identificador "manual block search" ;
    ns1:textoExtracto "The manual block search may be used to recover the program history up to a particular block of the program or of the subroutine, set by the operator." .

ns1:CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:identificador "CNC" ;
    ns1:textoExtracto "The CNC executes all the movements",
        "the CNC goes into tool inspection to reposition the axes, modify program conditions, etc." .

ns1:CS a ns1:ModoOperacion ;
    rdfs:label "#CS" ;
    ns1:textoExtracto "Machining coordinate system." .

ns1:CSROT_OFF a ns1:ModoOperacion ;
    rdfs:label "#CSROT OFF" ;
    ns1:textoExtracto "Cancel tool orientation in the part coordinate system." .

ns1:CSROT_ON a ns1:ModoOperacion ;
    rdfs:label "#CSROT ON" ;
    ns1:textoExtracto "Activate tool orientation in the part coordinate system." .

ns1:CYL a ns1:ModoOperacion ;
    rdfs:label "#CYL" ;
    ns1:textoExtracto "\"C\" axis. Machining of the turning side of the part." .

ns1:CalibracionConSondaDeMesa a ns1:TareaMantenimiento ;
    rdfs:label "table-top probe calibration"@en ;
    ns1:textoExtracto "All types of calibration are available when using a table-top probe."@en .

ns1:CalibracionManual a ns1:TareaMantenimiento ;
    rdfs:label "manual calibration"@en ;
    ns1:textoExtracto "If there is no tabletop probe, only manual calibration is available."@en .

ns1:CalibracionSonda a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda" ;
    ns1:textoExtracto "Probe calibration. --- Palpado de un orificio patrón: plano XY con centro (X,Y), profundidad Z y retirada “E”; se ven dos velocidades de palpado y distancias de seguridad." .

ns1:CalibrationValidationStep a ns1:TareaMantenimiento ;
    rdfs:label "Calibration validation step" ;
    ns1:textoExtracto "validate the calibration using the softkey menu" .

ns1:Change_channel a ns1:InterfazUsuario ;
    rdfs:label "Change channel" ;
    ns1:textoExtracto "Change the channel being displayed for editing and simulation. It does not affect the active channel at the CNC. ( This icon will only be available when the CNC has channels)." .

ns1:CicloFijoSondeo a ns1:ModoOperacion ;
    rdfs:label "probing canned cycle"@en ;
    ns1:textoExtracto "Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle."@en .

ns1:CircularPartCentering a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Circular part centering. --- Centrado de pieza circular con diámetros “J”, orden de palpado “K” y medición opcional “L”; trayectorias y retiradas B/D/E." .

