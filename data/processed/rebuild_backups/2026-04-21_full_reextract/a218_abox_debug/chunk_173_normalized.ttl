@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Esquema_SoportePinonDCH
    a ex:Esquema ;
    rdfs:label "Soporte piñón DCH (A21811030_DCH)" ;
    ex:identificador "A21811030_DCH" ;
    ex:textoExtracto "El isométrico facilita la lectura del posicionamiento respecto a la estructura del carro. --- Vistas ortogonales y sección A-A a escala 1:2 mostrando eje estriado, chaveteros y alojamiento de rodamientos. Se indican radios, chaflanes y referencias de cadena de rodillos; globos vinculan piezas clave." ;
    ex:ilustradoEn ex:Pagina_95 .

ex:Esquema_SoportePinonIZQ
    a ex:Esquema ;
    rdfs:label "Soporte piñón IZQ (A21811030_IZQ)" ;
    ex:identificador "A21811030_IZQ" ;
    ex:textoExtracto "Misma estructura que el derecho: vistas y sección A-A. Se aprecian cotas de alojamiento, roscas y posición del racor; el isométrico evidencia la geometría diferenciada por lateralidad." ;
    ex:ilustradoEn ex:Pagina_96 .

ex:Esquema_PinonMacizoDoble
    a ex:Esquema ;
    rdfs:label "Piñón macizo doble (ISO 1\") (A21811035)" ;
    ex:identificador "A21811035" ;
    ex:textoExtracto "Vistas de alzado, perfil y sección A-A con dentado para cadena de 1\". Se detallan ajuste del cubo (K7), chaveteros, taladros roscados y radio de transición; un detalle A (2:1) muestra el flanco de diente." ;
    ex:ilustradoEn ex:Pagina_98 .

ex:Esquema_FuelleCarroPortaPiezas
    a ex:Esquema ;
    rdfs:label "Fuelle carro porta-piezas (A21811069)" ;
    ex:identificador "A21811069" ;
    ex:textoExtracto "Conjunto de fuelles plegados con secciones A-A y B-B. Se representan radios de pliegue, pasos y ángulos; leyenda 'Virutas a proteger de INCONEL' contextualiza la función de barrera." ;
    ex:ilustradoEn ex:Pagina_98 .

