### Esquemas y relaciones
ex:Esquema_External_IO_Entradas1_8
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico: External I/O (entradas 1–8 + lubricación)" ;
    ex:textoExtracto "Cableado de IN1–IN8 (conectores X01–X04) y el bloque de estado lubricación (515U1 → 515.03)." ;
    ex:detalladoEnEsquema ex:Conector_X01, ex:Conector_X02, ex:Conector_X03, ex:Conector_X04, ex:Componente_515U1, ex:UnidadLubricacion_WA800_WE700 .

ex:Esquema_External_IO_Entradas9_16
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico: External I/O (entradas 9–16 + presiones/frenos)" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710, BP711, BP714." ;
    ex:detalladoEnEsquema ex:Conector_X05, ex:Conector_X06, ex:Conector_X07, ex:Conector_X08, ex:Sensor_BP710, ex:Sensor_BP711, ex:Sensor_BP714 .

ex:Esquema_Modulo_70U1
    a ex:Esquema ;
    rdfs:label "Esquema: Módulo 70U1 (AXL E EC DI8 DO4 2A M12 6P)" ;
    ex:textoExtracto "Vista del módulo descentralizado con su silueta centrada y columnas laterales que listan conectores M12 (X01–X08), BUS IN/OUT (X21/X22)." ;
    ex:detalladoEnEsquema ex:Modulo_70U1, ex:Conector_X01, ex:Conector_X02, ex:Conector_X03, ex:Conector_X04, ex:Conector_X05, ex:Conector_X06, ex:Conector_X07, ex:Conector_X08, ex:Conector_X21, ex:Conector_X22 .

### Relaciones funcionales
ex:Modulo_70U1
    ex:tieneComponente ex:Conector_X01, ex:Conector_X02, ex:Conector_X03, ex:Conector_X04, ex:Conector_X05, ex:Conector_X06, ex:Conector_X07, ex:Conector_X08, ex:Conector_X21, ex:Conector_X22 .

ex:UnidadLubricacion_WA800_WE700
    ex:tieneComponente ex:Componente_515U1 .