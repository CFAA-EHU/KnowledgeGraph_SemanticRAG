@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PuertasMaquina_2_2_1
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Puertas de la máquina"@es ;
    ex:textoExtracto      "NO SE DEBEN ABRIR LAS PUERTAS DE LA MÁQUINA DURANTE EL SERVICIO AUTOMÁTICO."@es ;
    ex:tieneComponente    ex:InterruptorSeguridad_2_2_1 .

ex:InterruptorSeguridad_2_2_1
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Interruptor de seguridad"@es ;
    ex:textoExtracto      "Puertas controladas con interruptor de seguridad [...] LA APERTURA DE LOS INTERRUPTORES PROVOCA LA DESCONEXIÓN DE LOS DISTINTOS SISTEMAS Y DE LOS SERVOMOTORES Y LA PARADA DE LA MÁQUINA."@es ;
    ex:controla           ex:SistemasMaquina_2_2_1 ;
    ex:activaAlarma       ex:AvisoSeguridad_Puertas_2_2_1 .

ex:SistemasMaquina_2_2_1
    a                     ex:Sistema ;
    rdfs:label            "Sistemas y servomotores de la máquina"@es ;
    ex:textoExtracto      "LA APERTURA DE LOS INTERRUPTORES PROVOCA LA DESCONEXIÓN DE LOS DISTINTOS SISTEMAS Y DE LOS SERVOMOTORES Y LA PARADA DE LA MÁQUINA."@es .

ex:AvisoSeguridad_Puertas_2_2_1
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Advertencia: Puertas durante servicio automático"@es ;
    ex:textoExtracto      "NO SE DEBEN ABRIR LAS PUERTAS DE LA MÁQUINA DURANTE EL SERVICIO AUTOMÁTICO."@es ;
    ex:mitigaRiesgo        ex:InterruptorSeguridad_2_2_1 .