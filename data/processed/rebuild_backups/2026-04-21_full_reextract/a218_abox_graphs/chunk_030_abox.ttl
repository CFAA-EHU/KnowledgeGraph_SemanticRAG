@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EPI_GafasSeguridad
    a ex:EPI ;
    rdfs:label "Gafas de seguridad" ;
    ex:textoExtracto "Para todo tipo de trabajo con herramienta en el que exista proyección de partículas. [...] De no usarse correctamente pueden producirse serias lesiones oculares, e incluso la pérdida de la visión." ;
    ex:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .

ex:EPI_Guantes
    a ex:EPI ;
    rdfs:label "Guantes" ;
    ex:textoExtracto "Deben ser adecuados para cada tipo de trabajo, tales como: Para trabajos con materiales abrasivos o a altas temperaturas. Para trabajos con elementos de aristas cortantes. No usar guantes cuando haya peligro de enganchones." ;
    ex:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .

ex:EPI_CalzadoSeguridad
    a ex:EPI ;
    rdfs:label "Calzado de seguridad" ;
    ex:textoExtracto "Debe ser calzado de seguridad y con puntera reforzada. De no usarse correctamente pueden producirse aplastamientos de los pies." .

ex:EPI_Auriculares
    a ex:EPI ;
    rdfs:label "Auriculares" ;
    ex:textoExtracto "Para los trabajos con ruidos superiores a los 78 dB. Se pueden utilizar tapones en lugar de los auriculares. De no usarse correctamente pueden producirse lesiones auditivas." .

ex:EPI_Tapones
    a ex:EPI ;
    rdfs:label "Tapones" ;
    ex:textoExtracto "Se pueden utilizar tapones en lugar de los auriculares." .

ex:EPI_CascoSeguridad
    a ex:EPI ;
    rdfs:label "Casco de seguridad" ;
    ex:textoExtracto "Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa." .

ex:EPI_PantallaProtectora
    a ex:EPI ;
    rdfs:label "Pantalla protectora" ;
    ex:textoExtracto "Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .

ex:EPI_Mandil
    a ex:EPI ;
    rdfs:label "Mandil" ;
    ex:textoExtracto "Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .

ex:TareaMantenimiento_General
    a ex:TareaMantenimiento ;
    rdfs:label "Trabajos de mantenimiento general" ;
    ex:textoExtracto "Para realizar los trabajos de mantenimiento conservando la seguridad personal, se debe emplear la indumentaria que a continuación se describe y la que el personal de mantenimiento considere adecuada en cada tipo de trabajo a realizar." ;
    ex:requiereEPI ex:EPI_GafasSeguridad, ex:EPI_Guantes, ex:EPI_CalzadoSeguridad .

ex:TareaMantenimiento_Soldadura
    a ex:TareaMantenimiento ;
    rdfs:label "Trabajos de soldadura" ;
    ex:textoExtracto "Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." ;
    ex:requiereEPI ex:EPI_PantallaProtectora, ex:EPI_Mandil, ex:EPI_Guantes .

ex:TareaMantenimiento_Ruidoso
    a ex:TareaMantenimiento ;
    rdfs:label "Trabajos con ruido superior a 78 dB" ;
    ex:textoExtracto "Para los trabajos con ruidos superiores a los 78 dB." ;
    ex:requiereEPI ex:EPI_Auriculares, ex:EPI_Tapones .

ex:TareaMantenimiento_MovimientoPesado
    a ex:TareaMantenimiento ;
    rdfs:label "Movimiento de elementos pesados" ;
    ex:textoExtracto "En toda acción de movimiento de elementos pesados mediante una grúa." ;
    ex:requiereEPI ex:EPI_CascoSeguridad .