@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_32
    a               ex:Maquina ;
    rdfs:label      "Máquina"@es ;
    ex:textoExtracto "SEGURIDAD CON MATERIALES UTILIZADOS LOS ACEITES, GRASAS, FLUIDOS Y DEMÁS SUSTANCIAS QUÍMICAS UTILIZADAS EN LA MÁQUINA..."@es ;
    ex:requiereConsumible ex:Consumible_32_1 ;
    ex:requiereMantenimiento ex:TareaMantenimiento_32_1 .

ex:Consumible_32_1
    a               ex:Consumible ;
    rdfs:label      "Aceites, grasas y fluidos"@es ;
    ex:textoExtracto "LOS ACEITES, GRASAS, FLUIDOS Y DEMÁS SUSTANCIAS QUÍMICAS UTILIZADAS EN LA MÁQUINA DEBEN CUMPLIR LAS NORMATIVAS VIGENTES PARA LA PROTECCIÓN DEL MEDIOAMBIENTE"@es ;
    ex:cumpleNormativa ex:Directiva_32_1 .

ex:Directiva_32_1
    a               ex:Directiva ;
    rdfs:label      "Normativas vigentes de protección medioambiental"@es ;
    ex:textoExtracto "DEBEN CUMPLIR LAS NORMATIVAS VIGENTES PARA LA PROTECCIÓN DEL MEDIOAMBIENTE"@es .

ex:TareaMantenimiento_32_1
    a               ex:TareaMantenimiento ;
    rdfs:label      "Gestión de residuos de consumibles"@es ;
    ex:textoExtracto "Los residuos que se forman pueden dar lugar a problemas medio ambientales y para su almacenamiento y deshecho debe recurrirse a la legislación vigente en el país de utilización de la máquina"@es ;
    ex:cumpleNormativa ex:Directiva_32_1 .

ex:PiezaRecambio_32_1
    a               ex:PiezaRecambio ;
    rdfs:label      "Piezas de recambio"@es ;
    ex:textoExtracto "TODAS LAS PIEZAS DE RECAMBIO SEAN ELIMINADOS DE MANERA SEGURA Y RESPETUOSA CON EL MEDIO AMBIENTE"@es .