@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:BrochadoraExteriores_43
    a                     ex:Maquina ;
    rdfs:label            "Brochadora de exteriores de único puesto"@es ;
    ex:textoExtracto      "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija)"@es ;
    ex:tieneComponente    ex:SistemaPinonCremallera_43 ;
    ex:tieneComponente    ex:Servomotor_43 .

ex:SistemaPinonCremallera_43
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Sistema piñón-cremallera"@es ;
    ex:textoExtracto      "movimiento de carro porta-piezas accionado por un sistema piñón cremallera"@es ;
    ex:tieneComponente    ex:Servomotor_43 .

ex:Servomotor_43
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Servomotor del sistema piñón-cremallera"@es ;
    ex:textoExtracto      "servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min"@es ;
    ex:valor              "70 kNw ; 40 m/min" .