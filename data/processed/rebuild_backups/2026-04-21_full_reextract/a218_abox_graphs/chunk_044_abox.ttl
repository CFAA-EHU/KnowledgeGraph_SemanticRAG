    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Carro porta-piezas" .

ex:PlatoDivisor_44
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Plato divisor" .

ex:CarroPortaBrochas_44
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Carro porta-brochas" .

