ex:Maquina_44
    a               ex:Maquina ;
    rdfs:label      "Máquina (p. 33)" ;
    ex:textoExtracto "La máquina se compone de: Zócalo, Columna, Carro porta-piezas, Plato divisor, Carro porta-brochas, Sistema de limpieza de brocha, Sistema neumático, Sistema de engrase, Sistema hidráulico, Sistema de refrigeración, Carenado, Armario eléctrico." ;
    ex:tieneComponente
        ex:Zocalo_44 ,
        ex:Columna_44 ,
        ex:CarroPortaPiezas_44 ,
        ex:PlatoDivisor_44 ,
        ex:CarroPortaBrochas_44 ,
        ex:SistemaLimpiezaBrocha_44 ,
        ex:SistemaNeumatico_44 ,
        ex:SistemaEngrase_44 ,
        ex:SistemaHidraulico_44 ,
        ex:SistemaRefrigeracion_44 ,
        ex:Carenado_44 ,
        ex:ArmarioElectrico_44 .

ex:Zocalo_44
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Zócalo" .

ex:Columna_44
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Columna" .

