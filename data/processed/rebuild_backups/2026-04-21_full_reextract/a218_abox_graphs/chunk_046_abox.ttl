@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Columna_4_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Columna con guías lineales y sistema de tracción"@es ;
    ex:textoExtracto
        "Sobre el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro porta-piezas, siendo el recorrido máximo de 3000 mm. [...] Columna"@es ;
    ex:tieneComponente
        ex:GuiasLineales_Columna_4_2 ,
        ex:ReglasLineales_Columna_4_2 ,
        ex:SistemaPinonCremallera_4_2 ,
        ex:Servomotores_CarroPortaPiezas_4_2 ,
        ex:CarroPortaPiezas_4_2 ;
    ex:ilustradoEn  ex:Figura_4_2 .

ex:GuiasLineales_Columna_4_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Guías lineales de la columna"@es ;
    ex:textoExtracto
        "dos guías lineales por las que se desplaza el carro porta-piezas"@es .

ex:ReglasLineales_Columna_4_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Reglas lineales de control de posición"@es ;
    ex:textoExtracto
        "La posición del carro se controla a través de dos reglas lineales colocadas en el lateral de la columna"@es ;
    ex:monitoreaParametro  ex:Parametro_PosicionCarro_4_2 .

ex:SistemaPinonCremallera_4_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Sistema piñón/cremallera (WITTENSTEIN)"@es ;
    ex:identificador "WITTENSTEIN" ;
    ex:textoExtracto
        "juegos de sistemas piñón/cremallera (WITTENSTEIN) accionados por dos servomotores"@es .

ex:Servomotores_CarroPortaPiezas_4_2
    a               ex:ComponenteElectrico ;
    rdfs:label      "Servomotores del carro porta-piezas"@es ;
    ex:textoExtracto
        "accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento"@es ;
    ex:controla     ex:CarroPortaPiezas_4_2 .

ex:CarroPortaPiezas_4_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro porta-piezas"@es ;
    ex:textoExtracto
        "carro porta-piezas [...] siendo el recorrido máximo de 3000 mm"@es ,
        "velocidad máxima de 40 m/min de avance y 40 m/min de retroceso. La fuerza máxima desarrollada en este movimiento es de 70 kNw"@es .

ex:Parametro_PosicionCarro_4_2
    a               ex:Parametro ;
    rdfs:label      "Posición del carro porta-piezas"@es ;
    ex:textoExtracto
        "La posición del carro se controla a través de dos reglas lineales"@es ;
    ex:valor         "0..3000"^^xsd:string .  # Rango de recorrido en mm

ex:Parametro_VelocidadAvance_4_2
    a               ex:Parametro ;
    rdfs:label      "Velocidad de avance/retroceso"@es ;
    ex:textoExtracto
        "velocidad máxima de 40 m/min de avance y 40 m/min de retroceso"@es ;
    ex:valor         "40"^^xsd:string ;  # m/min
    ex:monitoreaParametro  ex:CarroPortaPiezas_4_2 .

ex:Parametro_FuerzaMaxima_4_2
    a               ex:Parametro ;
    rdfs:label      "Fuerza máxima del movimiento"@es ;
    ex:textoExtracto
        "La fuerza máxima desarrollada en este movimiento es de 70 kNw"@es ;
    ex:valor         "70"^^xsd:string ;  # kNw
    ex:monitoreaParametro  ex:CarroPortaPiezas_4_2 .

ex:Figura_4_2
    a               ex:Figura ;
    rdfs:label      "Conjunto de tracción (Figura 4-2)"@es ;
    ex:identificador "4-2" ;
    ex:textoExtracto
        "Columna [...] Figura 4-2. Conjunto tracción"@es .