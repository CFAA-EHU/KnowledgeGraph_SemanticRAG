@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:plato_divisor_maquina_4_2_4
    a               ex:ComponenteMecanico ;
    rdfs:label      "Plato divisor" ;
    ex:textoExtracto "El plato divisor de la máquina va colocado sobre el carro porta-piezas y dispone de un dentado Hirth con capacidad para hacer divisiones de 1º." ;
    ex:tieneComponente ex:dentado_hirth_4_2_4 ;
    ex:tieneComponente ex:servomotor_plato_divisor_4_2_4 ;
    ex:tieneComponente ex:cilindro_hidraulico_plato_divisor_4_2_4 ;
    ex:tieneComponente ex:torreta_micros_4_2_4 ;
    ex:tieneComponente ex:base_plana_0grados_4_2_4 ;
    ex:tieneComponente ex:base_inclinada_15grados_4_2_4 ;
    ex:ilustradoEn   ex:figura_4_4 ;
    ex:ilustradoEn   ex:figura_4_5 .

ex:dentado_hirth_4_2_4
    a               ex:ComponenteMecanico ;
    rdfs:label      "Dentado Hirth" ;
    ex:textoExtracto "dispone de un dentado Hirth con capacidad para hacer divisiones de 1º." ;
    ex:identificador "DENTADO HIRTH" .

ex:servomotor_plato_divisor_4_2_4
    a               ex:ComponenteElectrico ;
    rdfs:label      "Servomotor del plato divisor" ;
    ex:textoExtracto "Para que el movimiento del plato divisor pueda llevarse a cabo interviene un servomotor." ;
    ex:controla     ex:plato_divisor_maquina_4_2_4 .

ex:cilindro_hidraulico_plato_divisor_4_2_4
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Cilindro hidráulico del plato divisor" ;
    ex:textoExtracto "el cilindro hidráulico permite que el engranaje superior del 'DENTADO HIRTH' se mueva verticalmente, liberando los dientes del engranaje inferior." ;
    ex:controla     ex:dentado_hirth_4_2_4 .

ex:torreta_micros_4_2_4
    a               ex:ComponenteElectrico ;
    rdfs:label      "Torreta de micros" ;
    ex:textoExtracto "dispone de una torreta de micros que al girar se activan por medio de unas levas dando las siguientes señales: SQ46: MESA ABAJO (BLOQUEADO), SQ47: MESA ARRIBA (DESBLOQUEADO)." ;
    ex:activaAlarma  ex:senal_sq46_bloqueado ;
    ex:activaAlarma  ex:senal_sq47_desbloqueado .

ex:senal_sq46_bloqueado
    a               ex:AvisoSeguridad ;
    rdfs:label      "SQ46: MESA ABAJO (BLOQUEADO)" ;
    ex:textoExtracto "SQ46: MESA ABAJO (BLOQUEADO)" ;
    ex:identificador "SQ46" .

ex:senal_sq47_desbloqueado
    a               ex:AvisoSeguridad ;
    rdfs:label      "SQ47: MESA ARRIBA (DESBLOQUEADO)" ;
    ex:textoExtracto "SQ47: MESA ARRIBA (DESBLOQUEADO)" ;
    ex:identificador "SQ47" .

ex:base_plana_0grados_4_2_4
    a               ex:ComponenteMecanico ;
    rdfs:label      "Base plana (0°)" ;
    ex:textoExtracto "El plato divisor dispone de dos bases, una plana para brochar a 0°" ;
    ex:identificador "Base 0°" .

ex:base_inclinada_15grados_4_2_4
    a               ex:ComponenteMecanico ;
    rdfs:label      "Base inclinada (15°)" ;
    ex:textoExtracto "otra inclinada para brochar a 15°" ;
    ex:identificador "Base 15°" .

ex:figura_4_4
    a               ex:Figura ;
    rdfs:label      "Figura 4-4. Plato divisor" ;
    ex:textoExtracto "Figura 4-4. Plato divisor" ;
    ex:identificador "Figura 4-4" .

ex:figura_4_5
    a               ex:Figura ;
    rdfs:label      "Figura 4-5. Bases del plato divisor (0° y 15°)" ;
    ex:textoExtracto "Figura 4-5. Bases del plato divisor (0° y 15°)" ;
    ex:identificador "Figura 4-5" .