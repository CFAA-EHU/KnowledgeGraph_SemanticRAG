@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcedimientoCambioBase_4_2_4_1
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Procedimiento cambio de base (0º - 15º / 15º - 0º)"@es ;
    ex:textoExtracto       "Para realizar el cambio de base seguir los siguientes pasos: 1. Consignar la máquina para realizar la operación. 2. Desconectar los cables del motor y de la torreta de micros; soltar los tubos hidráulicos y el neumático..."@es ;
    ex:requiereMantenimiento ex:MaquinaBrochadora ;
    ex:ilustradoEn         ex:Figura_4_6, ex:Figura_4_7, ex:Figura_4_8, ex:Figura_4_9, ex:Figura_4_10 ;
    ex:requiereEPI         ex:Eslingas, ex:Cancamos_M12 ;
    ex:requiereConsumible  ex:TornillosAjustePlato, ex:TornillosFijacionBase, ex:TornillosFijacionCarro .

ex:MaquinaBrochadora
    a               ex:Maquina ;
    ex:textoExtracto "Consignar la máquina para realizar la operación"@es ;
    ex:tieneComponente ex:MotorPrincipal, ex:TorretaMicros, ex:SistemaHidraulico, ex:SistemaNeumatico, ex:PlatoDivisor, ex:CarroPortaPiezas, ex:PlataformaInterior .

ex:MotorPrincipal
    a               ex:ComponenteElectrico ;
    ex:textoExtracto "Desconectar los cables del motor"@es .

ex:TorretaMicros
    a               ex:ComponenteElectrico ;
    ex:textoExtracto "Desconectar los cables de la torreta de micros"@es .

ex:SistemaHidraulico
    a               ex:ComponenteHidraulico ;
    ex:textoExtracto "soltar los tubos hidráulicos"@es .

ex:SistemaNeumatico
    a               ex:ComponenteHidraulico ;
    ex:textoExtracto "soltar el neumático"@es .

ex:PlatoDivisor
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "sacar el plato divisor hacia arriba", "Colocar el plato en la base plana"@es ;
    ex:compuestoPor  ex:BasePlatoDivisor, ex:PiezasAjustePlato .

ex:BasePlatoDivisor
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Soltar la base para realizar el cambio", "Colocar el plato en la base plana"@es .

ex:PiezasAjustePlato
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Soltar los tres tornillos que fijan las piezas de ajuste del plato", "Amarrar los tres tornillos que fijan las piezas de ajuste del plato"@es .

ex:CarroPortaPiezas
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "fijan la base del plato divisor al carro porta-piezas", "apoyarlo en el carro porta-piezas"@es .

ex:PlataformaInterior
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "Abrir la plataforma interior"@es .

ex:Figura_4_6
    a               ex:Figura ;
    ex:identificador "Figura 4-6" ;
    ex:textoExtracto "Cambio de base (1)"@es ;
    ex:ilustradoEn    ex:Pagina_38 .

ex:Figura_4_7
    a               ex:Figura ;
    ex:identificador "Figura 4-7" ;
    ex:textoExtracto "Cambio de base (2)"@es ;
    ex:ilustradoEn    ex:Pagina_39 .

ex:Figura_4_8
    a               ex:Figura ;
    ex:identificador "Figura 4-8" ;
    ex:textoExtracto "Cambio de base (3)"@es ;
    ex:ilustradoEn    ex:Pagina_40 .

ex:Figura_4_9
    a               ex:Figura ;
    ex:identificador "Figura 4-9" ;
    ex:textoExtracto "Cambio de base (4)"@es ;
    ex:ilustradoEn    ex:Pagina_40 .

ex:Figura_4_10
    a               ex:Figura ;
    ex:identificador "Figura 4-10" ;
    ex:textoExtracto "Cambio de base (5)"@es ;
    ex:ilustradoEn    ex:Pagina_41 .

ex:Cancamos_M12
    a               ex:EPI ;
    ex:identificador "M12" ;
    ex:textoExtracto "Colocar dos cáncamos en los agujeros roscados (M12) de la cara superior del disco"@es .

ex:Eslingas
    a               ex:EPI ;
    ex:textoExtracto "Colocar unas eslingas en los cáncamos y por medio de una grúa sacar el plato divisor hacia arriba"@es .

ex:TornillosFijacionCarro
    a               ex:Consumible ;
    ex:textoExtracto "Amarrar los siete tornillos que fijan el plato al carro porta-piezas"@es ;
    ex:identificador "7 unidades (fijación carro)" .

ex:TornillosAjustePlato
    a               ex:Consumible ;
    ex:textoExtracto "Soltar los tres tornillos que fijan las piezas de ajuste del plato", "Amarrar los tres tornillos que fijan las piezas de ajuste del plato"@es ;
    ex:identificador "3 unidades (ajuste plato)" .

ex:TornillosFijacionBase
    a               ex:Consumible ;
    ex:textoExtracto "Soltar los cuatro tornillos que fijan el plato a la base"@es ;
    ex:identificador "4 unidades (fijación base)" .