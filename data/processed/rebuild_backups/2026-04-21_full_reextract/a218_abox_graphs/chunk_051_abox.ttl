ex:CarroPortaBrochas_42
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro porta-brochas"@es ;
    ex:textoExtracto "Sobre el carro porta-brochas van amarradas las herramientas y está fijado a la columna. Permanece quieto durante el proceso de mecanizado, ya que el desplazamiento lo realiza el carro porta-piezas."@es ;
    ex:ilustradoEn  ex:Figura_4_11 .

ex:Figura_4_11
    a               ex:Figura ;
    rdfs:label      "Figura 4-11. Porta-brochas"@es ;
    ex:identificador "4-11" ;
    ex:textoExtracto "Porta-brochas"@es .