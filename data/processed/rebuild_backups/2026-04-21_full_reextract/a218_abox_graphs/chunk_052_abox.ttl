@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_PlataformasLaterales
    a                     ex:Maquina ;
    rdfs:label            "Máquina con plataformas laterales" ;
    ex:textoExtracto      "La máquina dispone de dos plataformas a distintas alturas, una en cada lateral de la máquina, con una puerta para acceder al interior de la máquina y realizar el cambio de herramienta." ;
    ex:tieneComponente    ex:PlataformaDerecha, ex:PlataformaIzquierda, ex:PuertaPlataformaDerecha, ex:PuertaPlataformaIzquierda, ex:PortonFrontal, ex:PortaCremalleras ;
    ex:ilustradoEn        ex:Figura4_12, ex:Figura4_13 .

ex:PlataformaDerecha
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Plataforma lateral derecha" ;
    ex:textoExtracto      "plataforma derecha" ;
    ex:tieneComponente    ex:PuertaPlataformaDerecha .

ex:PlataformaIzquierda
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Plataforma lateral izquierda" ;
    ex:textoExtracto      "plataforma izquierda" ;
    ex:tieneComponente    ex:PuertaPlataformaIzquierda .

ex:PuertaPlataformaDerecha
    a                     ex:ElementoSeguridad ;
    rdfs:label            "Puerta de acceso de plataforma derecha" ;
    ex:textoExtracto      "puerta de la plataforma derecha" .

ex:PuertaPlataformaIzquierda
    a                     ex:ElementoSeguridad ;
    rdfs:label            "Puerta de acceso de plataforma izquierda" ;
    ex:textoExtracto      "puerta de la plataforma izquierda" .

ex:PortonFrontal
    a                     ex:ElementoSeguridad ;
    rdfs:label            "Portón frontal de acceso para grúa" ;
    ex:textoExtracto      "portón principal", "portón frontal para el acceso de la grúa" .

ex:PortaCremalleras
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Porta-cremalleras" ;
    ex:textoExtracto      "porta-cremalleras", "tornillos del porta-cremalleras", "tornillos superiores (ROJOS)", "tornillos restantes (AZULES)" ;
    ex:tieneComponente    ex:TornillosRojos, ex:TornillosAzules, ex:CancamosLaterales .

ex:TornillosRojos
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Tornillos superiores (ROJOS) del porta-cremalleras" ;
    ex:textoExtracto      "tornillos del porta-cremalleras y de las referencias laterales de la parte superior (ROJOS)" .

ex:TornillosAzules
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Tornillos frontales y laterales (AZULES) del porta-cremalleras" ;
    ex:textoExtracto      "tornillos restantes (AZULES), tanto frontales como laterales" .

ex:CancamosLaterales
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Cáncamos laterales del porta-cremalleras" ;
    ex:textoExtracto      "cáncamos laterales" .

ex:Figura4_12
    a                     ex:Figura ;
    rdfs:label            "Figura 4-12. Plataformas laterales" ;
    ex:identificador      "4-12" ;
    ex:textoExtracto      "Figura 4-12. Plataformas laterales" .

ex:Figura4_13
    a                     ex:Figura ;
    rdfs:label            "Figura 4-13. Plataformas laterales" ;
    ex:identificador      "4-13" ;
    ex:textoExtracto      "Figura 4-13. Plataformas laterales" .

ex:TareaMantenimiento_CambioPortaCremalleras
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Procedimiento de cambio de porta-cremalleras" ;
    ex:textoExtracto      "Procedimiento cambio porta-cremalleras", "Para volver a colocar el porta-cremalleras seguir las instrucciones en orden inverso." ;
    ex:requiereMantenimiento ex:PortaCremalleras ;
    ex:ejecutadoPor       ex:Personal_Operario ;
    ex:requiereEPI        ex:EPI_Eslingas ;
    ex:ilustradoEn        ex:Figura4_12, ex:Figura4_13 .

ex:Personal_Operario
    a                     ex:Personal ;
    rdfs:label            "Operario de mantenimiento" ;
    ex:textoExtracto      "El operario sube por la plataforma derecha", "El operario suelta los tornillos", "El operario sale del interior de la máquina", "El operario procede a soltar los tornillos restantes" .

ex:EPI_Eslingas
    a                     ex:EPI ;
    rdfs:label            "Eslingas para izado del porta-cremalleras" ;
    ex:textoExtracto      "ata el porta-cremalleras por los cáncamos laterales y tensa las eslingas" .