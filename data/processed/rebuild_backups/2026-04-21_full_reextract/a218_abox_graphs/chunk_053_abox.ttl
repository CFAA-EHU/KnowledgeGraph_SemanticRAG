@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:sistemaLimpiezaBrochas_53
    a                   ex:Sistema ;
    rdfs:label          "Sistema de limpieza de brochas"@es ;
    ex:textoExtracto    "La máquina dispone de un sistema de limpieza de brochas situado en la parte superior del carro porta-piezas compuesto por un cilindro neumático guiado y unos cepillos."@es ;
    ex:compuestoPor     ex:cilindroNeumatico_53, ex:cepillos_53 ;
    ex:ilustradoEn      ex:figura4_14_53 .

ex:cilindroNeumatico_53
    a                   ex:ComponenteHidraulico ;
    rdfs:label          "Cilindro neumático guiado"@es ;
    ex:textoExtracto    "compuesto por un cilindro neumático guiado [...] el vástago del cilindro avanza y los cepillos limpian la brocha mientras el carro porta-piezas desciende."@es .

ex:cepillos_53
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Cepillos de limpieza"@es ;
    ex:textoExtracto    "compuesto por [...] unos cepillos. [...] los cepillos limpian la brocha mientras el carro porta-piezas desciende."@es .

ex:figura4_14_53
    a                   ex:Figura ;
    rdfs:label          "Figura 4-14. Sistema de limpieza"@es ;
    ex:identificador    "4-14" ;
    ex:textoExtracto    "Cilindro Cepillos Figura 4-14. Sistema de limpieza"@es .

ex:senalBQ740_53
    a                   ex:InterfazUsuario ;
    rdfs:label          "Señal BQ740: CEPILLO AVANZADO"@es ;
    ex:identificador    "BQ740" ;
    ex:textoExtracto    "BQ740: CEPILLO AVANZADO"@es ;
    ex:monitoreaParametro ex:parametroAvanceCepillos_53 .

ex:senalBQ741_53
    a                   ex:InterfazUsuario ;
    rdfs:label          "Señal BQ741: CEPILLO RETROCEDIDO"@es ;
    ex:identificador    "BQ741" ;
    ex:textoExtracto    "BQ741: CEPILLO RETROCEDIDO"@es ;
    ex:monitoreaParametro ex:parametroRetrocesoCepillos_53 .

ex:parametroAvanceCepillos_53
    a                   ex:Parametro ;
    rdfs:label          "Posición avanzada de cepillos"@es ;
    ex:textoExtracto    "BQ740: CEPILLO AVANZADO"@es .

ex:parametroRetrocesoCepillos_53
    a                   ex:Parametro ;
    rdfs:label          "Posición retrocedida de cepillos"@es ;
    ex:textoExtracto    "BQ741: CEPILLO RETROCEDIDO"@es .