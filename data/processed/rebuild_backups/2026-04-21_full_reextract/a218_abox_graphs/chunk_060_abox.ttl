@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EslingaHomologada_60
    a               ex:ElementoSeguridad ;
    rdfs:label      "Eslingas homologadas con declaración CE de conformidad"@es ;
    ex:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS."@es ;
    ex:mitigaRiesgo ex:RiesgoRoturaEslinga_60 .

ex:RiesgoRoturaEslinga_60
    a               ex:AvisoSeguridad ;
    rdfs:label      "Riesgo por rotura de eslingas defectuosas"@es ;
    ex:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS."@es .

ex:ProteccionContacto_60
    a               ex:ElementoSeguridad ;
    rdfs:label      "Tablones o trapos para protección en puntos de contacto"@es ;
    ex:textoExtracto "DEBEN COLOCARSE TABLONES O TRAPOS EN TODOS LOS PUNTOS DE CONTACTO ENTRE ESLINGAS Y MÁQUINA, PARA EVITAR EVENTUALES DAÑOS EN LA MISMA."@es ;
    ex:mitigaRiesgo ex:RiesgoDanioMaquina_60 .

ex:RiesgoDanioMaquina_60
    a               ex:AvisoSeguridad ;
    rdfs:label      "Riesgo de daño en máquina por presión de eslingas"@es ;
    ex:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES."@es .

ex:ZonaDeformable_60
    a               ex:ComponenteMecanico ;
    rdfs:label      "Zonas deformables (husillos, guías, cajas de cables)"@es ;
    ex:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES."@es .

ex:DepositoAceite_60
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Depósitos de aceite"@es ;
    ex:textoExtracto "ES MUY RECOMENDABLE QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS."@es .

ex:TaponesCierre_60
    a               ex:ComponenteMecanico ;
    rdfs:label      "Tapones de cierre de depósitos"@es ;
    ex:textoExtracto "EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN"@es .