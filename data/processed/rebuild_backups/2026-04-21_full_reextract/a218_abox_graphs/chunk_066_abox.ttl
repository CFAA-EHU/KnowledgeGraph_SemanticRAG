@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VelocidadMecanizado
    a ex:Parametro ;
    rdfs:label "Velocidad de mecanizado"@es ;
    ex:textoExtracto "Regulación de la velocidad de mecanizado. [...] hasta un límite de 40m/min."@es ;
    ex:valor "40" ;
    ex:monitoreaParametro ex:Interfaz_PanelOperador .

ex:Parametro_VelocidadRetroceso
    a ex:Parametro ;
    rdfs:label "Velocidad de retroceso"@es ;
    ex:textoExtracto "Regulación de la velocidad de retroceso. [...] hasta un límite de 40m/min."@es ;
    ex:valor "40" ;
    ex:monitoreaParametro ex:Interfaz_PanelOperador .

ex:Interfaz_PanelOperador
    a ex:InterfazUsuario ;
    rdfs:label "Panel operador"@es ;
    ex:textoExtracto "Desde el panel operador se puede ajustar la velocidad de brochado [...]"@es .