@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_PanelOperador
    a ex:InterfazUsuario ;
    rdfs:label "Panel operador"@es ;
    ex:textoExtracto "Pantalla principal o Movimientos manuales o Movimientos máquina"@es ;
    ex:tieneComponente ex:ModoOperacion_MovimientosManuales ;
    ex:tieneComponente ex:ModoOperacion_MovimientosMaquina ;
    ex:tieneComponente ex:ModoOperacion_CicloCambioBrocha ;
    ex:tieneComponente ex:ModoOperacion_CondicionesMaquina ;
    ex:tieneComponente ex:ModoOperacion_CicloBrochado ;
    ex:tieneComponente ex:ModoOperacion_Inspeccion .

ex:ModoOperacion_MovimientosManuales
    a ex:ModoOperacion ;
    rdfs:label "Movimientos manuales"@es ;
    ex:textoExtracto "Movimientos manuales"@es .

ex:ModoOperacion_MovimientosMaquina
    a ex:ModoOperacion ;
    rdfs:label "Movimientos máquina"@es ;
    ex:textoExtracto "Movimientos máquina"@es .

ex:ModoOperacion_ArranqueMotores
    a ex:ModoOperacion ;
    rdfs:label "Arranque motores"@es ;
    ex:textoExtracto "Arranque motores"@es .

ex:ModoOperacion_CicloCambioBrocha
    a ex:ModoOperacion ;
    rdfs:label "Ciclo cambio de brocha"@es ;
    ex:textoExtracto "Ciclo cambio de brocha"@es .

ex:ModoOperacion_CondicionesMaquina
    a ex:ModoOperacion ;
    rdfs:label "Condiciones máquina"@es ;
    ex:textoExtracto "Condiciones máquina"@es .

ex:ModoOperacion_CicloBrochado
    a ex:ModoOperacion ;
    rdfs:label "Ciclos de brochado"@es ;
    ex:textoExtracto "Ciclos de brochado"@es ;
    ex:tieneComponente ex:ModoOperacion_CicloAnillaDesbaste ;
    ex:tieneComponente ex:ModoOperacion_CicloAnillaAcabado ;
    ex:tieneComponente ex:ModoOperacion_CicloPlanaDesbaste ;
    ex:tieneComponente ex:ModoOperacion_CicloPlanaAcabado .

ex:ModoOperacion_CicloAnillaDesbaste
    a ex:ModoOperacion ;
    rdfs:label "Ciclo anilla desbaste"@es ;
    ex:textoExtracto "Ciclo anilla desbaste"@es .

ex:ModoOperacion_CicloAnillaAcabado
    a ex:ModoOperacion ;
    rdfs:label "Ciclo anilla acabado"@es ;
    ex:textoExtracto "Ciclo anilla acabado"@es .

ex:ModoOperacion_CicloPlanaDesbaste
    a ex:ModoOperacion ;
    rdfs:label "Ciclo plana desbaste"@es ;
    ex:textoExtracto "Ciclo plana desbaste"@es .

ex:ModoOperacion_CicloPlanaAcabado
    a ex:ModoOperacion ;
    rdfs:label "Ciclo plana acabado"@es ;
    ex:textoExtracto "Ciclo plana acabado"@es .

ex:ModoOperacion_Inspeccion
    a ex:ModoOperacion ;
    rdfs:label "Inspección"@es ;
    ex:textoExtracto "Inspección"@es .