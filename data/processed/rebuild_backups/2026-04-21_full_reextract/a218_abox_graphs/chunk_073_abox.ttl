@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senalizador_6242
    a               ex:InterfazUsuario ;
    rdfs:label      "Señalizador"@es ;
    ex:textoExtracto
                    "Siempre van acompañados de un texto o de un botón al cual están asociados y cambian de color dependiendo del estado del sensor de un actuador o del estado de un sinóptico. Negro = Desactivado Verde = Activado Botones Señalizadores"@es ;
    ex:monitoreaParametro
                    ex:EstadoActuador_6242 ;
    ex:monitoreaParametro
                    ex:EstadoSinoptico_6242 .

ex:EstadoActuador_6242
    a               ex:Parametro ;
    rdfs:label      "Estado del sensor de un actuador"@es ;
    ex:textoExtracto
                    "estado del sensor de un actuador"@es .

ex:EstadoSinoptico_6242
    a               ex:Parametro ;
    rdfs:label      "Estado de un sinóptico"@es ;
    ex:textoExtracto
                    "estado de un sinóptico"@es .

ex:IndicacionVisual_6242_Desactivado
    a               ex:AvisoSeguridad ;
    rdfs:label      "Indicación visual 'Desactivado'"@es ;
    ex:textoExtracto
                    "Negro = Desactivado"@es ;
    ex:mitigaRiesgo ex:Senalizador_6242 .

ex:IndicacionVisual_6242_Activado
    a               ex:AvisoSeguridad ;
    rdfs:label      "Indicación visual 'Activado'"@es ;
    ex:textoExtracto
                    "Verde = Activado"@es ;
    ex:mitigaRiesgo ex:Senalizador_6242 .