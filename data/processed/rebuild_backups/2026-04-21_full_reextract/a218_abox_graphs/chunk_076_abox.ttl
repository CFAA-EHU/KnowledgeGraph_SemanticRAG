@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Pantalla_MovimientosMaquina
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla Movimientos máquina" ;
    ex:textoExtracto "Esta pantalla permite controlar los movimientos de la máquina. El carro de tracción se puede llevar a tres posiciones (superior, intermedio e inferior), mientras que la mesa giratoria se puede subir/bajar y girar." ;
    ex:monitoreaParametro ex:Parametro_TemperaturaMotores ;
    ex:monitoreaParametro ex:Parametro_PosicionEjeZ ;
    ex:monitoreaParametro ex:Parametro_PosicionEjeZ1 ;
    ex:monitoreaParametro ex:Parametro_PosicionEjeC ;
    ex:controla ex:ComponenteMecanico_CarroTracion ;
    ex:controla ex:ComponenteMecanico_MesaGiratoria .

ex:Pantalla_ArranqueMotores
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla Arranque motores" ;
    ex:textoExtracto "Esta pantalla muestra el estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR, TRASVASE REFRIGERANTE, GRUPO HIDRÁULICO, EXTRACTOR DE VIRUTAS y MOTOR ENGRASE) y dispone de cuatro columnas (MARCHA, MOTOR, DISYUNTOR y SEÑALES)." ;
    ex:monitoreaParametro ex:Parametro_EstadoMotorRefrigeranteBrocha ;
    ex:monitoreaParametro ex:Parametro_EstadoMotorExtractorVirutas ;
    ex:monitoreaParametro ex:Parametro_EstadoMotorGrupoHidraulico ;
    ex:monitoreaParametro ex:Parametro_EstadoMotorEngrase ;
    ex:monitoreaParametro ex:Parametro_EstadoDisyuntorRefrigerante ;
    ex:monitoreaParametro ex:Parametro_EstadoDisyuntorExtractorVirutas ;
    ex:monitoreaParametro ex:Parametro_NivelMinimoRefrigerante ;
    ex:monitoreaParametro ex:Parametro_NivelMinimoGrupoHidraulico ;
    ex:controla ex:ComponenteElectrico_MotorRefrigeranteBrocha ;
    ex:controla ex:ComponenteElectrico_MotorExtractorVirutas ;
    ex:controla ex:ComponenteHidraulico_GrupoHidraulico ;
    ex:controla ex:ComponenteElectrico_MotorEngrase .

ex:Pantalla_CicloCambioBrocha
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla Ciclo cambio de brocha" ;
    ex:textoExtracto "Ciclo cambio de brocha"@es .

ex:Pantalla_CondicionesMaquina
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla Condiciones máquina" ;
    ex:textoExtracto "Condiciones máquina"@es .

ex:Pantalla_MovimientosManuales
    a ex:InterfazUsuario ;
    rdfs:label "Pantallas de movimientos manuales" ;
    ex:textoExtracto "Hay cuatro pantallas de movimientos manuales (Movimientos máquina, Arranque motores, Ciclo cambio de brocha y Condiciones máquina)." ;
    ex:tieneComponente ex:Pantalla_MovimientosMaquina ;
    ex:tieneComponente ex:Pantalla_ArranqueMotores ;
    ex:tieneComponente ex:Pantalla_CicloCambioBrocha ;
    ex:tieneComponente ex:Pantalla_CondicionesMaquina .

ex:Parametro_TemperaturaMotores
    a ex:Parametro ;
    rdfs:label "Temperatura de los motores" ;
    ex:textoExtracto "muestra la temperatura de los motores" .

ex:Parametro_PosicionEjeZ
    a ex:Parametro ;
    rdfs:label "Posición eje Z" ;
    ex:textoExtracto "las posiciones de los ejes Z" .

ex:Parametro_PosicionEjeZ1
    a ex:Parametro ;
    rdfs:label "Posición eje Z1" ;
    ex:textoExtracto "las posiciones de los ejes Z, Z1" .

ex:Parametro_PosicionEjeC
    a ex:Parametro ;
    rdfs:label "Posición eje C" ;
    ex:textoExtracto "las posiciones de los ejes [...] C" .

ex:Parametro_EstadoMotorRefrigeranteBrocha
    a ex:Parametro ;
    rdfs:label "Estado motor refrigerante a brocha/bastidor" ;
    ex:textoExtracto "estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR [...])." .

ex:Parametro_EstadoMotorExtractorVirutas
    a ex:Parametro ;
    rdfs:label "Estado motor extractor de virutas" ;
    ex:textoExtracto "estado de todos los motores de la máquina ([...] EXTRACTOR DE VIRUTAS [...])." .

ex:Parametro_EstadoMotorGrupoHidraulico
    a ex:Parametro ;
    rdfs:label "Estado motor grupo hidráulico" ;
    ex:textoExtracto "estado de todos los motores de la máquina ([...] GRUPO HIDRÁULICO [...])." .

ex:Parametro_EstadoMotorEngrase
    a ex:Parametro ;
    rdfs:label "Estado motor engrase" ;
    ex:textoExtracto "estado de todos los motores de la máquina ([...] MOTOR ENGRASE)." .

ex:Parametro_EstadoDisyuntorRefrigerante
    a ex:Parametro ;
    rdfs:label "Estado disyuntor refrigerante" ;
    ex:textoExtracto "La columna 'DISYUNTOR' permite visualizar el estado de la protección eléctrica de los motores." .

ex:Parametro_EstadoDisyuntorExtractorVirutas
    a ex:Parametro ;
    rdfs:label "Estado disyuntor extractor de virutas" ;
    ex:textoExtracto "La columna 'DISYUNTOR' permite visualizar el estado de la protección eléctrica de los motores." .

ex:Parametro_NivelMinimoRefrigerante
    a ex:Parametro ;
    rdfs:label "Nivel mínimo de refrigerante" ;
    ex:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante" .

ex:Parametro_NivelMinimoGrupoHidraulico
    a ex:Parametro ;
    rdfs:label "Nivel mínimo grupo hidráulico" ;
    ex:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; [...] otro para el grupo hidráulico." .

ex:ComponenteMecanico_CarroTracion
    a ex:ComponenteMecanico ;
    rdfs:label "Carro de tracción" ;
    ex:textoExtracto "El carro de tracción se puede llevar a tres posiciones (superior, intermedio e inferior)" .

ex:ComponenteMecanico_MesaGiratoria
    a ex:ComponenteMecanico ;
    rdfs:label "Mesa giratoria" ;
    ex:textoExtracto "la mesa giratoria se puede subir/bajar y girar." .

ex:ComponenteElectrico_MotorRefrigeranteBrocha
    a ex:ComponenteElectrico ;
    rdfs:label "Motor refrigerante a brocha/bastidor" ;
    ex:textoExtracto "motor de 'REFRIGERANTE A BROCHA/BASTIDOR'" .

ex:ComponenteElectrico_MotorExtractorVirutas
    a ex:ComponenteElectrico ;
    rdfs:label "Motor extractor de virutas" ;
    ex:textoExtracto "motor de 'EXTRACTOR DE VIRUTAS'" .

ex:ComponenteHidraulico_GrupoHidraulico
    a ex:ComponenteHidraulico ;
    rdfs:label "Grupo hidráulico" ;
    ex:textoExtracto "motor de 'GRUPO HIDRÁULICO'" .

ex:ComponenteElectrico_MotorEngrase
    a ex:ComponenteElectrico ;
    rdfs:label "Motor engrase" ;
    ex:textoExtracto "motor de 'MOTOR ENGRASE'" .