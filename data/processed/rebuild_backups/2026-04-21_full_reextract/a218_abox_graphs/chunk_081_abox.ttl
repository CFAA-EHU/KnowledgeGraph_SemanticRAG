ex:Tarea_BorrarPrograma_81
    a               ex:TareaMantenimiento ;
    rdfs:label      "Borrar programa guardado"@es ;
    ex:textoExtracto "Para borrar un programa ya guardado, acceder al navegador de carpetas, para ello: Pulsar Utilities • Acceder a la carpeta C:\\FAGORCNC\\Users\\PRG • Seleccionar programa que se desea borrar • Pulsar Eliminar"@es ;
    ex:ejecutadoPor ex:InterfazUsuario_NavegadorCarpetas_81 .

ex:InterfazUsuario_NavegadorCarpetas_81
    a               ex:InterfazUsuario ;
    rdfs:label      "Navegador de carpetas (Utilities → C:\\FAGORCNC\\Users\\PRG)"@es ;
    ex:textoExtracto "acceder al navegador de carpetas, para ello: Pulsar Utilities • Acceder a la carpeta C:\\FAGORCNC\\Users\\PRG"@es .