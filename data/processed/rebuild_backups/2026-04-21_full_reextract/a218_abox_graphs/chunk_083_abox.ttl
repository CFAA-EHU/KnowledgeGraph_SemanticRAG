@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:pantallaParametrosBrochado
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de parámetros de brochado"@es ;
    ex:textoExtracto "Estando en la pantalla de parámetros de brochado y teniendo los parámetros deseados"@es .

ex:ventanaEmergenteReemplazoCiclo
    a ex:InterfazUsuario ;
    rdfs:label "Ventana emergente '¿Reemplazar el antiguo ciclo o insertar nuevo?'"@es ;
    ex:textoExtracto "Aparece ventana emergente '¿Reemplazar el antiguo ciclo o insertar nuevo?'"@es .

ex:parametrosBrochadoModificados
    a ex:Parametro ;
    rdfs:label "Parámetros de brochado reemplazados"@es ;
    ex:textoExtracto "Los parámetros quedan reemplazados"@es ;
    ex:documentadoEn ex:pantallaParametrosBrochado .

ex:cicloTrabajoSeleccionado
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de trabajo seleccionado"@es ;
    ex:textoExtracto "para que surtan efecto los cambios si se tiene seleccionado el mismo ciclo de trabajo se tendrá que volver a seleccionar de nuevo el ciclo"@es .

ex:softkeyEjecutarPrograma
    a ex:InterfazUsuario ;
    rdfs:label "Softkey 'Ejecutar programa'"@es ;
    ex:textoExtracto "Pulsar softkey 'Ejecutar programa'"@es ;
    ex:ilustradoEn ex:pantallaParametrosBrochado .

ex:programaActualizado
    a ex:ModoOperacion ;
    rdfs:label "Programa con parámetros actualizados"@es ;
    ex:textoExtracto "se vuelve a seleccionar el mismo programa pero con los parámetros actualizados"@es ;
    ex:controla ex:parametrosBrochadoModificados .