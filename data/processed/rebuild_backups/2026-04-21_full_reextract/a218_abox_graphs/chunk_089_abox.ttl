@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoManual_6_4_2
    a               ex:ModoOperacion ;
    rdfs:label      "Modo manual (Sección 6.4.2)"@es ;
    ex:textoExtracto "Para seleccionar el modo de trabajo manual: [...] A partir de este momento se pueden realizar todos los movimientos manuales de la máquina y el cambio de herramienta."@es ;
    ex:identificador "6.4.2" .

ex:TareaCambioHerramienta_Manual
    a               ex:TareaMantenimiento ;
    rdfs:label      "Cambio de herramienta en modo manual"@es ;
    ex:textoExtracto "A partir de este momento [...] el cambio de herramienta."@es ;
    ex:requiereMantenimiento ex:ModoManual_6_4_2 ;
    ex:ejecutadoPor ex:Personal_Operador .

ex:Personal_Operador
    a               ex:Personal ;
    rdfs:label      "Operador de máquina"@es ;
    ex:textoExtracto "Seleccionar el modo manual."@es .

ex:SistemaEnclavamientoPuertas
    a               ex:ElementoSeguridad ;
    rdfs:label      "Enclavamiento de seguridad de puertas"@es ;
    ex:textoExtracto "Puertas con enclavamiento de seguridad cerradas y bloqueadas."@es ;
    ex:mitigaRiesgo ex:ModoManual_6_4_2 .