@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_91_cicloAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático (ciclo)"@es ;
    ex:textoExtracto "Siempre volviendo a 0º para la bajada del carro. Se podrá seleccionar si se desea con ciclo inspección o no."@es ;
    ex:identificador "6.4.3" .

ex:ModoOperacion_91_cicloAnilloAcabado
    a ex:ModoOperacion ;
    rdfs:label "Ciclo anillo acabado"@es ;
    ex:textoExtracto "El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente. Se pueden abrir las puertas para verificar visualmente que el primer diente concuerda. Después el carro baja para posicionar el plato"@es .

ex:ComponenteMecanico_91_carro
    a ex:ComponenteMecanico ;
    rdfs:label "carro"@es ;
    ex:textoExtracto "Siempre volviendo a 0º para la bajada del carro"@es ;
    ex:textoExtracto "el carro posicionándose en la cota de inspección"@es ;
    ex:textoExtracto "el carro baja para posicionar el plato"@es .

ex:ComponenteMecanico_91_plato
    a ex:ComponenteMecanico ;
    rdfs:label "plato"@es ;
    ex:textoExtracto "el plato girado en el primer diente"@es ;
    ex:textoExtracto "para verificar visualmente que el primer diente concuerda"@es ;
    ex:textoExtracto "el carro baja para posicionar el plato"@es .

ex:Parametro_91_cotaInspeccion
    a ex:Parametro ;
    rdfs:label "cota de inspección"@es ;
    ex:textoExtracto "el carro posicionándose en la cota de inspección"@es .

ex:Parametro_91_posicionCero
    a ex:Parametro ;
    rdfs:label "posición 0°"@es ;
    ex:textoExtracto "Siempre volviendo a 0º para la bajada del carro"@es .

ex:ModoOperacion_91_cicloInspeccion
    a ex:ModoOperacion ;
    rdfs:label "ciclo inspección"@es ;
    ex:textoExtracto "Se podrá seleccionar si se desea con ciclo inspección o no"@es .

ex:ElementoSeguridad_91_puertas
    a ex:ElementoSeguridad ;
    rdfs:label "puertas"@es ;
    ex:textoExtracto "Se pueden abrir las puertas para verificar visualmente que el primer diente concuerda"@es .