@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:BrochadoraElectromecanica_A218_RASHEM_7x3000x500
    a ex:Maquina ;
    rdfs:label "Brochadora electromecánica de exteriores A218/RASHEM 7x3000x500" ;
    ex:identificador "A218/RASHEM 7x3000x500" ;
    ex:textoExtracto "BROCHADORA ELECTROMECÁNICA DE EXTERIORES | A218/ RASHEM 7x3000x500" ;
    ex:requiereMantenimiento ex:TareasMantenimientoSemanales_50h .

ex:TareasMantenimientoSemanales_50h
    a ex:TareaMantenimiento ;
    rdfs:label "Tareas semanales de mantenimiento (cada 50 h)" ;
    ex:textoExtracto "Trabajos semanales de mantenimiento | Cada 50 h" ;
    ex:tieneFrecuencia ex:Frecuencia_50h ;
    ex:ejecutadoPor ex:Personal_Operario ,
                     ex:Personal_Mantenimiento .

ex:Frecuencia_50h
    a ex:Frecuencia ;
    rdfs:label "Cada 50 horas de operación" ;
    ex:valor "50" ;
    ex:textoExtracto "Cada 50 h" .

ex:Personal_Operario
    a ex:Personal ;
    rdfs:label "Operario" ;
    ex:textoExtracto "OPERARIO" .

ex:Personal_Mantenimiento
    a ex:Personal ;
    rdfs:label "Personal de mantenimiento" ;
    ex:textoExtracto "MANTENIMIENTO" .

ex:Tarea_LimpiezaExteriorMaquina
    a ex:TareaMantenimiento ;
    rdfs:label "Limpieza del exterior de la máquina" ;
    ex:textoExtracto "Limpieza del exterior de la máquina" ;
    ex:tieneFrecuencia ex:Frecuencia_50h ;
    ex:ejecutadoPor ex:Personal_Operario ,
                     ex:Personal_Mantenimiento .

ex:Tarea_ComprobarEstanqueidadTuberias
    a ex:TareaMantenimiento ;
    rdfs:label "Comprobar estanqueidad de tuberías" ;
    ex:textoExtracto "Comprobar la estanqueidad de las tuberías" ;
    ex:tieneFrecuencia ex:Frecuencia_50h ;
    ex:ejecutadoPor ex:Personal_Operario .

ex:Tarea_ComprobarAprieteRacores
