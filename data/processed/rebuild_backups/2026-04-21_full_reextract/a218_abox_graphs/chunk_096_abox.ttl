    ex:textoExtracto "Comprobar el buen apriete de racores" ;
    ex:tieneFrecuencia ex:Frecuencia_50h ;
    ex:ejecutadoPor ex:Personal_Operario .

ex:Tarea_ComprobarTemperaturaGrupoHidraulico
    a ex:TareaMantenimiento ;
    rdfs:label "Comprobar temperatura del grupo hidráulico (máx. 65°C)" ;
    ex:textoExtracto "Comprobar la temperatura de trabajo del grupo hidráulico (65ºC Max.)" ;
    ex:tieneFrecuencia ex:Frecuencia_50h ;
    ex:ejecutadoPor ex:Personal_Operario ;
    ex:monitoreaParametro ex:Parametro_TemperaturaGrupoHidraulico .

ex:Parametro_TemperaturaGrupoHidraulico
    a ex:Parametro ;
    rdfs:label "Temperatura máxima del grupo hidráulico" ;
    ex:valor "65" ;
    ex:textoExtracto "65ºC Max." .

ex:Tarea_ComprobarFugasAceite
    a ex:TareaMantenimiento ;
