@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TareaMantenimiento_ComprobacionFinalesCarreraDetectoresProximidad
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Comprobación de funcionamiento de finales de carrera y detectores de proximidad"@es ;
    ex:textoExtracto      "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad. En caso necesario, reemplazarlos."@es ;
    ex:requiereMantenimiento
        ex:ComponenteElectrico_FinalesCarrera ,
        ex:ComponenteElectrico_DetectoresProximidad .

ex:ComponenteElectrico_FinalesCarrera
    a               ex:ComponenteElectrico ;
    rdfs:label      "Finales de carrera"@es ;
    ex:textoExtracto "finales de carrera"@es .

ex:ComponenteElectrico_DetectoresProximidad
    a               ex:ComponenteElectrico ;
    rdfs:label      "Detectores de proximidad"@es ;
    ex:textoExtracto "detectores de proximidad"@es .