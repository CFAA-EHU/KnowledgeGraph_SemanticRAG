@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DepositoHidraulico_120L
    a ex:ComponenteHidraulico ;
    rdfs:label "Depósito hidráulico"@es ;
    ex:textoExtracto "La capacidad del depósito hidráulico es de 120 litros."@es ;
    ex:valor "120 litros" .

ex:FluidoHidraulico_HM46
    a ex:Consumible ;
    rdfs:label "Aceite ISO 3498 - HM46"@es ;
    ex:textoExtracto "El fluido a emplear debe ser Aceite ISO 3498 - HM46."@es ;
    ex:identificador "ISO 3498 - HM46" .