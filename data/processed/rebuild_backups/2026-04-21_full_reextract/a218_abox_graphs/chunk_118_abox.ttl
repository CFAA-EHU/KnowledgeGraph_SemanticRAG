@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DepositoLubricacion_Manual_9_2_1
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Depósito de lubricación (capacidad: 5 litros)" ;
    ex:textoExtracto "La capacidad del depósito es de 5 litros." ;
    ex:identificador "5L" .

ex:AceiteISO3498_G220
    a               ex:Consumible ;
    rdfs:label      "Aceite ISO 3498 G220" ;
    ex:textoExtracto "El fluido a emplear debe ser Aceite ISO 3498 G220, de viscosidad 220 cSt a 40 C°." ;
    ex:identificador "ISO 3498 G220" ;
    ex:valor         "220 cSt a 40°C" .

ex:DepositoLubricacion_Manual_9_2_1
    ex:requiereConsumible ex:AceiteISO3498_G220 .