@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PresionAireComprimido
    a               ex:Parametro ;
    ex:valor        "6 bar" ;
    ex:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    rdfs:label      "Presión de aire comprimido"@es .

ex:Parametro_CaudalAireComprimido
    a               ex:Parametro ;
    ex:valor        "225 L/min" ;
    ex:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    rdfs:label      "Caudal de aire comprimido"@es .