    rdfs:label "Esquema eléctrico - Guardamotores y bloques de contactos auxiliares"@es ;
    ex:textoExtracto "10.3 – ESQUEMAS ELECTRICOS [...] INTERRUPTOR AUT. BORNES TORNILLO [...] GUARDAMOTOR [...]"@es ;
    ex:identificador "10.3" .

