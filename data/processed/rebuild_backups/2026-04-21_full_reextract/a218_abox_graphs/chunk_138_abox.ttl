@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaEmergenciaPanelOperador
    a ex:Sistema ;
    rdfs:label "Sistema de Emergencia del Panel de Operador" ;
    ex:textoExtracto "EMERGENCIA PANEL OPERADOR" ;
    ex:identificador "SistemaEmergenciaPanelOperador" ;
    ex:compuestoPor ex:PulsadorEmergencia40mmRojo ;
    ex:compuestoPor ex:PlacaNotHaltGelba ;
    ex:compuestoPor ex:SoportePulsador26SB1 ;
    ex:compuestoPor ex:ModuloContacto1NC_26SB1_1 ;
    ex:compuestoPor ex:ModuloContacto1NC_26SB1_2 .

ex:PulsadorEmergencia40mmRojo
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador de Emergencia 40mm Rojo" ;
    ex:textoExtracto "40MM, ROJO | EMERGENCIA PANEL OPERADOR | SIEMENS AG | 3SU1050-1HB20-0AA0" ;
    ex:identificador "3SU1050-1HB20-0AA0" .

ex:PlacaNotHaltGelba
    a ex:ComponenteMecanico ;
    rdfs:label "Placa NOT-HALT (amarilla) para pulsador 26SB1" ;
    ex:textoExtracto "NOT-HALT-UNTERLEGSCHILD, GELB | EMERGENCIA PANEL OPERADOR | SIEMENS AG | 3SU1900-0BC31-0DA0" ;
    ex:identificador "3SU1900-0BC31-0DA0" .

ex:SoportePulsador26SB1
    a ex:ComponenteMecanico ;
    rdfs:label "Soporte para pulsador 26SB1" ;
    ex:textoExtracto "SOPORTE | EMERGENCIA PANEL OPERADOR | SIEMENS | 3SU1550-0AA10-0AA0" ;
    ex:identificador "3SU1550-0AA10-0AA0" .

ex:ModuloContacto1NC_26SB1_1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de contacto 1NC (26SB1, unidad 1)" ;
    ex:textoExtracto "CONTACT MODULE 1NC | EMERGENCIA PANEL OPERADOR | SIEMENS | 3SU1400-1AA10-3CA0" ;
    ex:identificador "3SU1400-1AA10-3CA0_1" .

ex:ModuloContacto1NC_26SB1_2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de contacto 1NC (26SB1, unidad 2)" ;
    ex:textoExtracto "CONTACT MODULE 1NC | EMERGENCIA PANEL OPERADOR | SIEMENS | 3SU1400-1AA10-3CA0" ;
    ex:identificador "3SU1400-1AA10-3CA0_2" .