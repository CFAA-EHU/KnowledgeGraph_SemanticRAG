ex:Esquema_10.3_ComponentesEmergencia
    a ex:Esquema ;
    rdfs:label "Esquema de componentes eléctricos de emergencia (Anexos 10.3)"@es ;
    ex:textoExtracto "10.3 – ESQUEMAS ELECTRICOS [...] 26SB1 | SOPORTE | EMERGENCIA PANEL OPERADOR [...] 26SB2 | PULSADOR SETA PARO EMERG., 40MM, ROJO | EMERGENCIA ARMARIO"@es ;
    ex:tieneComponente ex:_26SB1_SoportePanel, ex:_26SB1_ModuloContacto1NC_1, ex:_26SB1_ModuloContacto1NC_2,
                        ex:_26SB2_PulsadorEmergencia, ex:_26SB2_PlacaNotHalt, ex:_26SB2_SoporteArmario,
                        ex:_26SB2_ModuloContacto1NC_1, ex:_26SB2_ModuloContacto1NC_2 .

