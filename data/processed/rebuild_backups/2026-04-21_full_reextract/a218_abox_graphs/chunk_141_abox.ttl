@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquema de seguridad (ancla para componentes)
ex:Esquema_Seguridad_PuertasEscotillas
    a ex:Esquema ;
    rdfs:label "Esquema de seguridad de puertas y escotillas (sensores y actuadores)"@es ;
    ex:textoExtracto "24SQ1, 24SQ2, 25SQ1 (sensores/actuadores EUCHNER); Conexión Cabeza Lectora (20 metros); CTP-L1-AP-M-HA-AZ-SA; Straight actuator for Transponder-coded safety switch"@es .

### Sensores y actuadores (puertas/escotillas)
ex:_24SQ1_SensorPuertaIzquierda
    a ex:Sensor ;
    rdfs:label "Sensor 24SQ1 (Cabeza Lectora, Puerta Izquierda, EUCHNER 100179)"@es ;
    ex:identificador "24SQ1" ;
    ex:textoExtracto "Conexion Cabeza Lectora (20 metros)(Sensor sin Contacto) | PUERTA IZQUIERDA | EUCHNER | 100179"@es ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

ex:_24SQ2_SensorPuertaDerecha
    a ex:Sensor ;
    rdfs:label "Sensor 24SQ2 (CTP-L1-AP-M-HA-AZ-SA, Puerta Derecha, EUCHNER)"@es ;
    ex:identificador "24SQ2" ;
    ex:textoExtracto "CTP-L1-AP-M-HA-AZ-SA | PUERTA DERECHA | EUCHNER | CTP-L1-AP-M-HA-AZ-SA"@es ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

ex:_24SQ2_ActuadorPuertaDerecha
    a ex:Actuador ;
    rdfs:label "Actuador 24SQ2 (Straight actuator for Transponder-coded safety switch CTP, Puerta Derecha, EUCHNER A-C-H-G-SST-122666)"@en ;
    ex:identificador "24SQ2" ;
    ex:textoExtracto "Straight actuator for Transponder-coded safety switch CTP | PUERTA DERECHA | EUCHNER | A-C-H-G-SST-122666"@en ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

ex:_25SQ1_SensorEscotillaInterior
    a ex:Sensor ;
    rdfs:label "Sensor 25SQ1 (CTP-L1-AP-M-HA-AZ-SA, Escotilla Interior, EUCHNER)"@es ;
    ex:identificador "25SQ1" ;
    ex:textoExtracto "CTP-L1-AP-M-HA-AZ-SA | ESCOTILLA INTERIOR | EUCHNER | CTP-L1-AP-M-HA-AZ-SA"@es ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

ex:_25SQ1_ActuadorEscotillaInterior
    a ex:Actuador ;
    rdfs:label "Actuador 25SQ1 (Straight actuator for Transponder-coded safety switch CTP, Escotilla Interior, EUCHNER A-C-H-G-SST-122666)"@en ;
    ex:identificador "25SQ1" ;
    ex:textoExtracto "Straight actuator for Transponder-coded safety switch CTP | ESCOTILLA INTERIOR | EUCHNER | A-C-H-G-SST-122666"@en ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

### Componentes eléctricos (fuente y transformador)
ex:_12T1_FuenteAlimentacion
    a ex:ComponenteElectrico ;
    rdfs:label "Fuente de alimentación SITOP PSU300S (SIEMENS 6EP1437-2BA20)"@es ;
    ex:identificador "12T1" ;
    ex:textoExtracto "SITOP PSU300S | SIEMENS AG | 6EP1437-2BA20"@es ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

ex:_11TR1_Transformador
    a ex:ComponenteElectrico ;
    rdfs:label "Transformador 11TR1 (Prim. 400 VAC +/-5%)"@es ;
    ex:identificador "11TR1" ;
    ex:textoExtracto "Transformador Prim. 400 VAC +/-5%. Sec."@es ;
    ex:detalladoEnEsquema ex:Esquema_Seguridad_PuertasEscotillas .

### Relaciones funcionales (solo las seguras)
ex:_24SQ2_SensorPuertaDerecha ex:controla ex:_24SQ2_ActuadorPuertaDerecha .
ex:_25SQ1_SensorEscotillaInterior ex:controla ex:_25SQ1_ActuadorEscotillaInterior .