@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EsquemaElectrico_10_3
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico - Sistema de gestión de emergencias y señalización" ;
    ex:textoExtracto "400 VAC +/-5%. Sec. 230 VAC - 1000VA [...] SEÑALIZACION DEL ESTADO DE LA MAQUINA (COLUMNA LUMINOSA)" .

### Sistema de gestión de emergencias (PNOZmulti)
ex:SistemaGestionEmergencias_26U
    a ex:Sistema ;
    rdfs:label "Sistema de gestión de emergencias PNOZmulti" ;
    ex:identificador "26U" ;
    ex:textoExtracto "PNOZmulti 2 base unit | RELE GESTION EMERGENCIAS" ;
    ex:detalladoEnEsquema ex:EsquemaElectrico_10_3 ;
    ex:compuestoPor ex:ComponenteElectrico_26U1_UnidadBase ,
                     ex:ComponenteElectrico_26U1_Terminales ,
                     ex:ComponenteElectrico_26U1_ChipCard ,
                     ex:ComponenteElectrico_26U2_ModuloEntrada ,
                     ex:ComponenteElectrico_26U2_Bornas .

ex:ComponenteElectrico_26U1_UnidadBase
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad base PNOZmulti 2" ;
    ex:identificador "PNOZ m B0 772100" ;
    ex:textoExtracto "PNOZmulti 2 base unit | PILZ | PNOZ m B0 772100" .

ex:ComponenteElectrico_26U1_Terminales
    a ex:ComponenteElectrico ;
    rdfs:label "Terminales de resorte para PNOZmulti" ;
    ex:identificador "PNOZ s Set1 spring loaded terminals" ;
    ex:textoExtracto "1 set of spring-loaded terminals | PILZ | PNOZ s Set1 spring loaded terminals" .

ex:ComponenteElectrico_26U1_ChipCard
    a ex:ComponenteElectrico ;
    rdfs:label "ChipCard para PNOZ-mm01p" ;
    ex:identificador "779201" ;
    ex:textoExtracto "ChipCard para PNOZ-mm01p | PILZ | 779201" .

ex:ComponenteElectrico_26U2_ModuloEntrada
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de entrada PNOZmulti 2 (16DI)" ;
    ex:identificador "PNOZ m EF 16DI 772140" ;
    ex:textoExtracto "PNOZmulti 2 Input module | PILZ | PNOZ m EF 16DI 772140" .

ex:ComponenteElectrico_26U2_Bornas
    a ex:ComponenteElectrico ;
    rdfs:label "Bornas de resorte PNOZ (4 pines)" ;
    ex:identificador "751004" ;
    ex:textoExtracto "PILZ Bornas de resorte PNOZ 4pines | PILZ | 751004" .

### Sistema de señalización (Columna luminosa)
ex:SistemaSenalizacion_40U1
    a ex:Sistema ;
    rdfs:label "Sistema de señalización del estado de la máquina (columna luminosa)" ;
    ex:identificador "40U1" ;
    ex:textoExtracto "SEÑALIZACION DEL ESTADO DE LA MAQUINA (COLUMNA LUMINOSA)" ;
    ex:detalladoEnEsquema ex:EsquemaElectrico_10_3 ;
    ex:compuestoPor ex:ComponenteElectrico_40U1_Rojo ,
                     ex:ComponenteElectrico_40U1_Verde ,
                     ex:ComponenteElectrico_40U1_Naranja .

ex:ComponenteElectrico_40U1_Rojo
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad iluminada roja (70mm, 24V LED, IP65)" ;
    ex:identificador "XVBC2B4" ;
    ex:textoExtracto "Ø 70 mm unidad iluminada - estable - rojo - IP65 - 24 V-LED | Schneider Electric | XVBC2B4" .

ex:ComponenteElectrico_40U1_Verde
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad iluminada verde (70mm, 24V LED, IP65)" ;
    ex:identificador "XVBC2B3" ;
    ex:textoExtracto "Ø 70 mm unidad iluminada - estable - Verde - IP65 - 24 V-LED | Schneider Electric | XVBC2B3" .

ex:ComponenteElectrico_40U1_Naranja
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad iluminada naranja (70mm, 24V LED, IP65)" ;
    ex:identificador "XVBC2B5" ;
    ex:textoExtracto "Ø 70 mm unidad iluminada - constante - naranja - IP65 - 24 V-LED | Schneider Electric | XVBC2B5" .