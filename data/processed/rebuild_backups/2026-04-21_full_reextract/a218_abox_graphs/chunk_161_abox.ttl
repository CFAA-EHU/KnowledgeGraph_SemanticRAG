@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_0_1_1
    a ex:Figura ;
    rdfs:label "Figura 0-1-1. Información mostrada en páginas"@es ;
    ex:textoExtracto "Diagrama con flechas y rótulos que identifican, en cabecera y pie, fabricante, número y nombre de capítulo, modelo de máquina, nombre de fichero, contenido y paginación; establece la jerarquía visual de metadatos del documento."@es ;
    ex:ilustradoEn ex:Manual_Principal .

ex:Figura_2_1
    a ex:Figura ;
    rdfs:label "Figura 2-1. Elementos de seguridad de la máquina"@es ;
    ex:textoExtracto "Lámina con varias vistas de la máquina; marcadores y colores señalan la ubicación de interruptor general, paradas de emergencia, paneles fijos/desmontables y puertas, ofreciendo un mapa visual de zonas seguras."@es ;
    ex:ilustradoEn ex:Manual_Principal .

ex:Figura_2_2
    a ex:Figura ;
    rdfs:label "Figura 2-2"@es ;
    ex:textoExtracto "Puertas con ventanas, columna alta y zócalo con apoyos antivibratorios; paleta en blanco/gris con acentos azules corporativos."@es ;
    ex:ilustradoEn ex:Manual_Principal .

ex:AvisoSeguridad_2_1_1
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad general"@es ;
    ex:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad (placas, enclavamientos, manipulación segura, uso de medios de elevación). Diseño en bloques rojos con texto blanco para resaltar severidad."@es ;
    ex:documentadoEn ex:Manual_Principal .

ex:AvisoSeguridad_2_1_2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para uso de máquina"@es ;
    ex:textoExtracto "Conjunto de recuadros 'STOP' que enfatizan aplicación prevista, cumplimiento del manual, cierre de armarios eléctricos, no sobrepasar capacidad y verificación de interior; iconografía y color refuerzan las advertencias."@es ;
    ex:documentadoEn ex:Manual_Principal .

ex:Manual_Principal
    a ex:Manual ;
    rdfs:label "Manual de la máquina"@es ;
    ex:textoExtracto "Sección 0.2 USO DEL MANUAL, 2.1.1 Instrucciones generales de seguridad, 2.1.2 Instrucciones de seguridad para el uso de la máquina, 2.2 Elementos de protección y seguridad de la máquina."@es .

ex:InterfazUsuario_Visual
    a ex:InterfazUsuario ;
    rdfs:label "Jerarquía visual de metadatos del manual"@es ;
    ex:textoExtracto "Diagrama con flechas y rótulos que identifican, en cabecera y pie, fabricante, número y nombre de capítulo, modelo de máquina, nombre de fichero, contenido y paginación."@es ;
    ex:detalladoEnEsquema ex:Figura_0_1_1 .

ex:Sistema_SeguridadMaquina
    a ex:Sistema ;
    rdfs:label "Sistema de seguridad de la máquina"@es ;
    ex:textoExtracto "Elementos de protección y seguridad: interruptor general, paradas de emergencia, paneles fijos/desmontables y puertas."@es ;
    ex:compuestoPor ex:ComponenteElectrico_InterruptorGeneral ;
    ex:compuestoPor ex:ComponenteMecanico_Puertas ;
    ex:compuestoPor ex:ComponenteMecanico_Paneles ;
    ex:ilustradoEn ex:Figura_2_1 .

ex:ComponenteElectrico_InterruptorGeneral
    a ex:ComponenteElectrico ;
    rdfs:label "Interruptor general"@es ;
    ex:textoExtracto "Marcadores y colores señalan la ubicación de interruptor general en la máquina."@es .

ex:ComponenteMecanico_Puertas
    a ex:ComponenteMecanico ;
    rdfs:label "Puertas con ventanas"@es ;
    ex:textoExtracto "Puertas con ventanas, columna alta y zócalo con apoyos antivibratorios."@es .

ex:ComponenteMecanico_Paneles
    a ex:ComponenteMecanico ;
    rdfs:label "Paneles fijos/desmontables"@es ;
    ex:textoExtracto "Marcadores y colores señalan la ubicación de paneles fijos/desmontables en la máquina."@es .