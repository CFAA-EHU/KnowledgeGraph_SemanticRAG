@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PlatoDivisor_SQ46_SQ47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Plato divisor (SQ46/SQ47)" ;
    ex:textoExtracto       "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)."@es ;
    ex:identificador       "SQ46/SQ47" ;
    ex:compuestoPor        ex:AnilloDentadoHirth_SQ46_SQ47 ;
    ex:compuestoPor        ex:Servomotor_PlatoDivisor ;
    ex:compuestoPor        ex:TorretaMicros_PlatoDivisor ;
    ex:ilustradoEn         ex:Figura4_5_BasesPlatoDivisor ;
    ex:ilustradoEn         ex:Figura4_6_CambioBase1 ;
    ex:ilustradoEn         ex:Figura4_7_CambioBase2 ;
    ex:ilustradoEn         ex:Figura4_8_CambioBase3 .

ex:AnilloDentadoHirth_SQ46_SQ47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Anillo dentado Hirth" ;
    ex:textoExtracto       "Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico."@es .

ex:Servomotor_PlatoDivisor
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Servomotor del plato divisor" ;
    ex:textoExtracto       "Fotografías de detalle con recuadros y flechas hacia cables del motor."@es .

ex:TorretaMicros_PlatoDivisor
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Torreta de micros" ;
    ex:textoExtracto       "Fotografías de detalle con recuadros y flechas hacia cable torreta de micros."@es .

ex:SistemaHidraulico_PlatoDivisor
    a                     ex:Sistema ;
    rdfs:label            "Sistema hidráulico del plato divisor" ;
    ex:textoExtracto       "flechas sugieren el giro tras el desbloqueo hidráulico; tubos hidráulicos y tubo neumático a desconectar."@es ;
    ex:tieneComponente     ex:TuboHidraulico_PlatoDivisor ;
    ex:tieneComponente     ex:TuboNeumatico_PlatoDivisor .

ex:TuboHidraulico_PlatoDivisor
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Tubo hidráulico del plato divisor" ;
    ex:textoExtracto       "tubos hidráulicos a desconectar."@es .

ex:TuboNeumatico_PlatoDivisor
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Tubo neumático del plato divisor" ;
    ex:textoExtracto       "tubo neumático a desconectar."@es .

ex:SistemaMecanicoFijacion_PlatoDivisor
    a                     ex:Sistema ;
    rdfs:label            "Sistema de fijación mecánica del plato divisor" ;
    ex:textoExtracto       "Vista superior del disco con agujeros roscados M12 para cáncamos y llamadas a tornillos de fijación y tornillos de ajuste."@es ;
    ex:tieneComponente     ex:TornillosFijacion_PlatoDivisor ;
    ex:tieneComponente     ex:TornillosAjuste_PlatoDivisor .

ex:TornillosFijacion_PlatoDivisor
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Tornillos de fijación del plato divisor (M12)" ;
    ex:textoExtracto       "agujeros roscados M12 para cáncamos y llamadas a tornillos de fijación."@es .

ex:TornillosAjuste_PlatoDivisor
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Tornillos de ajuste del plato divisor" ;
    ex:textoExtracto       "llamadas a tornillos de ajuste."@es .

ex:Figura4_5_BasesPlatoDivisor
    a                     ex:Figura ;
    rdfs:label            "Figura 4-5. Bases del plato divisor (0º y 15º)" ;
    ex:identificador       "4-5" ;
    ex:textoExtracto       "Dos vistas comparativas con rótulos Base 0º y Base 15º. La codificación cromática diferencia ambas configuraciones, evidenciando el ajuste angular disponible para el brochado."@es .

ex:Figura4_6_CambioBase1
    a                     ex:Figura ;
    rdfs:label            "Figura 4-6. Cambio de base (1)" ;
    ex:identificador       "4-6" ;
    ex:textoExtracto       "Fotografías de detalle con recuadros y flechas hacia cables del motor, cable torreta de micros, tubos hidráulicos y tubo neumático a desconectar."@es .

ex:Figura4_7_CambioBase2
    a                     ex:Figura ;
    rdfs:label            "Figura 4-7. Cambio de base (2)" ;
    ex:identificador       "4-7" ;
    ex:textoExtracto       "Fotografías de detalle con recuadros y flechas hacia cables del motor, cable torreta de micros, tubos hidráulicos y tubo neumático a desconectar."@es .

ex:Figura4_8_CambioBase3
    a                     ex:Figura ;
    rdfs:label            "Figura 4-8. Cambio de base (3)" ;
    ex:identificador       "4-8" ;
    ex:textoExtracto       "Vista superior del disco con agujeros roscados M12 para cáncamos y llamadas a tornillos de fijación y tornillos de ajuste."@es .