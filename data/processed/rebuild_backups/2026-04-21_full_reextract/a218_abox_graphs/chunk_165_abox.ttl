@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_4_9
    a ex:Figura ;
    rdfs:label "Figura 4-9. Cambio de base" ;
    ex:textoExtracto "Perspectiva del plato fuera de máquina; rótulos repetidos a tornillos del plato refuerzan la extracción de la base. La repetición visual ayuda a ver la simetría del amarre." ;
    ex:ilustradoEn ex:ProcedimientoCambioBase_4.2.4.1 .

ex:Figura_4_10
    a ex:Figura ;
    rdfs:label "Figura 4-10. Cambio de base" ;
    ex:textoExtracto "Colocación del plato en base plana. Recuadros señalan los tornillos de amarre en ambos laterales; vista limpia para verificar apoyos." ;
    ex:ilustradoEn ex:ProcedimientoCambioBase_4.2.4.1 .

ex:Figura_4_11
    a ex:Figura ;
    rdfs:label "Figura 4-11. Porta-brochas" ;
    ex:textoExtracto "Inserción del conjunto con grúa a través de la plataforma; círculos marcan los siete tornillos del plato y tres de ajuste a reapretar. Flechas orientan la secuencia final." ;
    ex:ilustradoEn ex:ProcedimientoCarroPortaBrochas_4.2.5 .

ex:Figura_4_12
    a ex:Figura ;
    rdfs:label "Figura 4-12. Plataformas laterales" ;
    ex:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado. Se muestra fijo, alineado con el eje vertical, frente al movimiento del carro porta-piezas." ;
    ex:ilustradoEn ex:ProcedimientoCambioPortaCremalleras_4.2.5.1 .

ex:Figura_4_13
    a ex:Figura ;
    rdfs:label "Figura 4-13. Plataformas laterales" ;
    ex:textoExtracto "Vista frontal del equipo con dos plataformas (marcas 1 y 2) a distinta altura. Líneas horizontales rojas indican posiciones de trabajo y puerta de acceso a interior." ;
    ex:ilustradoEn ex:ProcedimientoCambioPortaCremalleras_4.2.5.1 .

ex:ProcedimientoCambioBase_4.2.4.1
    a ex:TareaMantenimiento ;
    rdfs:label "Procedimiento cambio de base (0º–15º / 15º–0º)" ;
    ex:identificador "4.2.4.1" ;
    ex:textoExtracto "Procedimiento cambio de base (0º–15º / 15º–0º)" ;
    ex:documentadoEn ex:Capitulo_10_Anexos .

ex:ProcedimientoCarroPortaBrochas_4.2.5
    a ex:TareaMantenimiento ;
    rdfs:label "Carro porta-brochas" ;
    ex:identificador "4.2.5" ;
    ex:textoExtracto "Carro porta-brochas" ;
    ex:documentadoEn ex:Capitulo_10_Anexos .

ex:ProcedimientoCambioPortaCremalleras_4.2.5.1
    a ex:TareaMantenimiento ;
    rdfs:label "Procedimiento cambio porta-cremalleras" ;
    ex:identificador "4.2.5.1" ;
    ex:textoExtracto "Procedimiento cambio porta-cremalleras" ;
    ex:documentadoEn ex:Capitulo_10_Anexos .

ex:Capitulo_10_Anexos
    a ex:Capitulo ;
    rdfs:label "CAPÍTULO 10 - ANEXOS" ;
    ex:identificador "10" ;
    ex:textoExtracto "CAPÍTULO 10 - ANEXOS - 10.1 – PLANOS MECANICOS - 10.2 – ESQUEMAS DE FLUIDOS - 10.3 – ESQUEMAS ELECTRICOS" .

ex:PlatoMecanico
    a ex:ComponenteMecanico ;
    rdfs:label "Plato mecánico" ;
    ex:textoExtracto "Perspectiva del plato fuera de máquina; rótulos repetidos a tornillos del plato refuerzan la extracción de la base." ;
    ex:ilustradoEn ex:Figura_4_9 ;
    ex:compuestoPor ex:TornillosAmarrePlato .

ex:TornillosAmarrePlato
    a ex:ComponenteMecanico ;
    rdfs:label "Tornillos de amarre del plato" ;
    ex:textoExtracto "Recuadros señalan los tornillos de amarre en ambos laterales; vista limpia para verificar apoyos." ;
    ex:ilustradoEn ex:Figura_4_10 ;
    ex:compuestoPor ex:TornillosAjusteReapriete .

ex:TornillosAjusteReapriete
    a ex:ComponenteMecanico ;
    rdfs:label "Tornillos de ajuste a reapretar" ;
    ex:textoExtracto "Círculos marcan los siete tornillos del plato y tres de ajuste a reapretar." ;
    ex:ilustradoEn ex:Figura_4_11 .

ex:PortaBrochas
    a ex:ComponenteMecanico ;
    rdfs:label "Porta-brochas" ;
    ex:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado. Se muestra fijo, alineado con el eje vertical." ;
    ex:ilustradoEn ex:Figura_4_12 .

ex:PlataformasLaterales
    a ex:ComponenteMecanico ;
    rdfs:label "Plataformas laterales" ;
    ex:textoExtracto "Vista frontal del equipo con dos plataformas (marcas 1 y 2) a distinta altura." ;
    ex:ilustradoEn ex:Figura_4_13 .

ex:TornilleriaSuperior
    a ex:ComponenteMecanico ;
    rdfs:label "Tornillería superior (codificación ROJO)" ;
    ex:textoExtracto "Sección frontal con codificación ROJO (tornillería superior a retirar)." ;
    ex:ilustradoEn ex:Figura_4_13 .

ex:TornilleriaRestante
    a ex:ComponenteMecanico ;
    rdfs:label "Tornillería restante (codificación AZUL)" ;
    ex:textoExtracto "Sección frontal con codificación AZUL (resto de tornillería)." ;
    ex:ilustradoEn ex:Figura_4_13 .