    a               ex:ComponenteHidraulico ;
    rdfs:label      "Actuador YP802 (mesa arriba)" ;
    ex:identificador "YP802" ;
    ex:textoExtracto "YP802/YP803 (mesa arriba/abajo)" .

ex:ComponenteHidraulico_YP803
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Actuador YP803 (mesa abajo)" ;
    ex:identificador "YP803" ;
    ex:textoExtracto "YP802/YP803 (mesa arriba/abajo)" .

ex:ComponenteHidraulico_YP900
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Freno hidráulico YP900" ;
