### Sistemas y Componentes Hidráulicos
ex:SistemaHidraulico_Refrigeracion
    a               ex:Sistema ;
    rdfs:label      "Sistema hidráulico de refrigeración" ;
    ex:textoExtracto "Conjunto sobre bancada con M6 (motor), BL726 (nivel), YP802/YP803 (mesa arriba/abajo), YP900 (freno), BP714/BP727 (presión). Flechas rojas y rótulos guían funciones y puntos de medida." ;
    ex:ilustradoEn  ex:Figura_4_18 ;
    ex:tieneComponente
        ex:ComponenteHidraulico_M6,
        ex:ComponenteHidraulico_BL726,
        ex:ComponenteHidraulico_YP802,
        ex:ComponenteHidraulico_YP803,
        ex:ComponenteHidraulico_YP900,
        ex:ComponenteHidraulico_BP714,
        ex:ComponenteHidraulico_BP727 .

ex:ComponenteHidraulico_M6
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Motor hidráulico M6" ;
    ex:identificador "M6" ;
    ex:textoExtracto "M6 (motor)" .

