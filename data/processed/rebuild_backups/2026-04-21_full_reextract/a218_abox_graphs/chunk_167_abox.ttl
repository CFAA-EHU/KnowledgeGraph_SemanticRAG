ex:Figura_5_1
    a               ex:Figura ;
    rdfs:label      "Figura 5-1. Cáncamos transporte" ;
    ex:identificador "5-1" ;
    ex:textoExtracto "Panel infográfico de advertencias con iconografía (STOP, triángulos de peligro) y bloques de texto en rojo que jerarquizan riesgos y condiciones de elevación/transporte." ;
    ex:documentadoEn ex:Pagina_53 ;
    ex:ilustradoEn  ex:AvisoSeguridad_Transporte .

ex:AvisoSeguridad_Transporte
    a               ex:AvisoSeguridad ;
    rdfs:label      "Advertencias de manipulación y transporte" ;
    ex:textoExtracto "Panel infográfico de advertencias con iconografía (STOP, triángulos de peligro) y bloques de texto en rojo que jerarquizan riesgos y condiciones de elevación/transporte." ;
    ex:ilustradoEn  ex:Figura_5_1 .

ex:Figura_5_2
    a               ex:Figura ;
    rdfs:label      "Figura 5-2. Volteo máquina" ;
    ex:identificador "5-2" ;
    ex:textoExtracto "Secuencia 1–2–3 con flechas verticales y curva que ilustran el volteo desde vertical a horizontal con dos grúas; vistas frontal y lateral para claridad espacial." ;
    ex:documentadoEn ex:Pagina_54 .

