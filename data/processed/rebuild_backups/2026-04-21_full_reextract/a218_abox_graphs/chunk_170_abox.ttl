@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Interfaces de Usuario y Modos de Operación
ex:InterfazOperacionBrochado
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de ciclos de brochado"@es ;
    ex:textoExtracto "Selector con iconos conmutables de pieza (ANILLO/PLANA), operación (DESBASTE/ACABADO) y refrigeración (CON/SIN); gráfico circular contextualiza trayectorias. Botonería con softkeys para ejecutar/simular/memorizar."@es ;
    ex:ilustradoEn ex:EsquemaModosOperacion .

ex:InterfazModosFuncionamiento
    a ex:InterfazUsuario ;
    rdfs:label "Panel de modos de funcionamiento (Reset/Auto/Manual)"@es ;
    ex:textoExtracto "Fragmento de teclado con Reset / Auto / Manual enfatizados por color (rojo/amarillo/verde). Flechas rojas subrayan la secuencia de puesta en servicio y cambio de modo."@es .

ex:ModoAuto
    a ex:ModoOperacion ;
    rdfs:label "Modo Automático"@es ;
    ex:textoExtracto "Auto"@es ;
    ex:habilitadoPor ex:InterfazModosFuncionamiento .

ex:ModoManual
    a ex:ModoOperacion ;
    rdfs:label "Modo Manual"@es ;
    ex:textoExtracto "Manual"@es ;
    ex:habilitadoPor ex:InterfazModosFuncionamiento .

ex:PanelAdvertenciasSeguridad
    a ex:InterfazUsuario ;
    rdfs:label "Panel de advertencias de seguridad"@es ;
    ex:textoExtracto "Panel infográfico de advertencias con pictogramas STOP y triángulos de peligro; bloques rojos con texto blanco destacan consignación, prohibición de aire a presión y uso de mástil anticaídas."@es .

### Esquemas y Figuras
ex:EsquemaModosOperacion
    a ex:Esquema ;
    rdfs:label "Esquema de modos de operación"@es ;
    ex:textoExtracto "Selector con iconos conmutables [...] Botonería con softkeys para ejecutar/simular/memorizar."@es .

ex:FiguraColumnaCarro
    a ex:Figura ;
    rdfs:label "Figura 8-1: Elementos de columna y carro porta-piezas"@es ;
    ex:identificador "Figura 8-1"@es ;
    ex:textoExtracto "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores."@es .

ex:FiguraPlatoDivisor
    a ex:Figura ;
    rdfs:label "Figura 8-2: Elementos del plato divisor"@es ;
    ex:identificador "Figura 8-2"@es ;
    ex:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)."@es .

### Componentes Mecánicos (de Figura 8-1 y 8-2)
ex:ColumnaMecanica
    a ex:ComponenteMecanico ;
    rdfs:label "Columna mecánica"@es ;
    ex:textoExtracto "Vista 3D a color de la columna [...] con globos numerados y recuadros en rojo"@es ;
    ex:ilustradoEn ex:FiguraColumnaCarro ;
    ex:tieneComponente ex:CremalleraColumna, ex:ServomotorColumna, ex:GuiaColumna, ex:FrenoColumna, ex:FuelleColumna, ex:SensorColumna .

ex:CarroPortaPiezas
    a ex:ComponenteMecanico ;
    rdfs:label "Carro porta-piezas"@es ;
    ex:textoExtracto "Vista 3D a color de [...] el carro con globos numerados"@es ;
    ex:ilustradoEn ex:FiguraColumnaCarro .

ex:PlatoDivisor
    a ex:ComponenteMecanico ;
    rdfs:label "Plato divisor"@es ;
    ex:identificador "1"@es ;  # Referencia en Figura 8-2
    ex:textoExtracto "resaltado del plato (1)"@es ;
    ex:ilustradoEn ex:FiguraPlatoDivisor .

ex:ServomotorPlato
    a ex:ComponenteMecanico ;
    rdfs:label "Servomotor del plato divisor"@es ;
    ex:identificador "2"@es ;  # Referencia en Figura 8-2
    ex:textoExtracto "servomotor (2)"@es ;
    ex:ilustradoEn ex:FiguraPlatoDivisor .

### Componentes Genéricos (de Figura 8-1)
ex:CremalleraColumna
    a ex:ComponenteMecanico ;
    rdfs:label "Cremallera de columna"@es ;
    ex:textoExtracto "identifica cremalleras"@es .

ex:ServomotorColumna
    a ex:ComponenteMecanico ;
    rdfs:label "Servomotor de columna"@es ;
    ex:textoExtracto "identifica [...] servomotores"@es .

ex:GuiaColumna
    a ex:ComponenteMecanico ;
    rdfs:label "Guía de columna"@es ;
    ex:textoExtracto "identifica [...] guías"@es .

ex:FrenoColumna
    a ex:ComponenteMecanico ;
    rdfs:label "Freno de columna"@es ;
    ex:textoExtracto "identifica [...] frenos"@es .

ex:FuelleColumna
    a ex:ComponenteMecanico ;
    rdfs:label "Fuelle de protección de columna"@es ;
    ex:textoExtracto "identifica [...] fuelles"@es .

ex:SensorColumna
    a ex:Sensor ;
    rdfs:label "Sensor de columna"@es ;
    ex:textoExtracto "identifica [...] sensores"@es .