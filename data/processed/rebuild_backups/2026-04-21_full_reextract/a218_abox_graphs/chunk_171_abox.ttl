@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Figura_8_3
    a ex:Figura ;
    rdfs:label "Figura 8-3. Elementos comerciales y de desgaste del sistema limpieza brocha"@es ;
    ex:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2). Paleta de colores separa elementos y facilita la correspondencia con referencias comerciales."@es ;
    ex:ilustradoEn ex:SistemaLimpiezaBrocha ;
    ex:identificador "Figura 8-3" .

ex:SistemaLimpiezaBrocha
    a ex:Sistema ;
    rdfs:label "Sistema de limpieza de brocha"@es ;
    ex:textoExtracto "Módulo longitudinal con cilindro neumático y cepillos señalados (1–2). Círculo de detalle sobre el peine de cerdas; disposición evidencia el área activa de limpieza."@es ;
    ex:compuestoPor ex:CilindroNeumatico_LimpiezaBrocha ;
    ex:compuestoPor ex:Cepillos_LimpiezaBrocha ;
    ex:compuestoPor ex:PlatoDivisor_1 ;
    ex:compuestoPor ex:Servomotor_2 .

ex:CilindroNeumatico_LimpiezaBrocha
    a ex:ComponenteHidraulico ;
    rdfs:label "Cilindro neumático (sistema limpieza brocha)"@es ;
    ex:textoExtracto "Módulo longitudinal con cilindro neumático y cepillos señalados (1–2)."@es .

ex:Cepillos_LimpiezaBrocha
    a ex:Consumible ;
    rdfs:label "Cepillos de limpieza (1–2)"@es ;
    ex:textoExtracto "Módulo longitudinal con cilindro neumático y cepillos señalados (1–2). Círculo de detalle sobre el peine de cerdas; disposición evidencia el área activa de limpieza."@es .

ex:PlatoDivisor_1
    a ex:ComponenteMecanico ;
    rdfs:label "Plato divisor (1)"@es ;
    ex:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)."@es ;
    ex:ilustradoEn ex:Figura_8_3 .

ex:Servomotor_2
    a ex:ComponenteElectrico ;
    rdfs:label "Servomotor (2)"@es ;
    ex:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)."@es ;
    ex:ilustradoEn ex:Figura_8_3 .

ex:Figura_8_4
    a ex:Figura ;
    rdfs:label "Figura 8-4. Elementos comerciales y de desgaste del carenado"@es ;
    ex:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización). Globos numerados y recuadros localizan componentes de sustitución frecuente."@es ;
    ex:ilustradoEn ex:Carenado_Sistema ;
    ex:identificador "Figura 8-4" .

ex:Carenado_Sistema
    a ex:Sistema ;
    rdfs:label "Carenado (sistema)"@es ;
    ex:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización)."@es ;
    ex:compuestoPor ex:Lamparas_EUCHNER ;
    ex:compuestoPor ex:Interruptores_EUCHNER .

ex:Lamparas_EUCHNER
    a ex:ComponenteElectrico ;
    rdfs:label "Lámparas EUCHNER (transponder y monitorización)"@es ;
    ex:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización)."@es .

ex:Interruptores_EUCHNER
    a ex:ComponenteElectrico ;
    rdfs:label "Interruptores EUCHNER"@es ;
    ex:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización)."@es .

ex:Plano_A21811000
    a ex:Esquema ;
    rdfs:label "Conjunto Carro Porta-piezas (Nº A21811000)"@es ;
    ex:textoExtracto "Lámina con vistas frontal, lateral, planta e isométrica explotada. Globos de referencia señalan subconjuntos y puntos de fijación; rejilla alfanumérica y cartela técnica estructuran la localización. Se aprecian guías lineales, bastidor y apoyos."@es ;
    ex:detalladoEnEsquema ex:CarroPortaPiezas_A21811000 ;
    ex:identificador "A21811000" .

ex:CarroPortaPiezas_A21811000
    a ex:ComponenteMecanico ;
    rdfs:label "Carro porta-piezas (Nº A21811000)"@es ;
    ex:textoExtracto "Lámina con vistas frontal, lateral, planta e isométrica explotada. Globos de referencia señalan subconjuntos y puntos de fijación; rejilla alfanumérica y cartela técnica estructuran la localización."@es ;
    ex:tieneComponente ex:GuiasLineales_Carro ;
    ex:tieneComponente ex:Bastidor_Carro ;
    ex:tieneComponente ex:Apoyos_Carro ;
    ex:documentadoEn ex:Plano_A21811000 .

ex:GuiasLineales_Carro
    a ex:ComponenteMecanico ;
    rdfs:label "Guías lineales (Carro porta-piezas)"@es ;
    ex:textoExtracto "Se aprecian guías lineales, bastidor y apoyos."@es .

ex:Bastidor_Carro
    a ex:ComponenteMecanico ;
    rdfs:label "Bastidor (Carro porta-piezas)"@es ;
    ex:textoExtracto "Se aprecian guías lineales, bastidor y apoyos."@es .

ex:Apoyos_Carro
    a ex:ComponenteMecanico ;
    rdfs:label "Apoyos (Carro porta-piezas)"@es ;
    ex:textoExtracto "Se aprecian guías lineales, bastidor y apoyos."@es .

ex:Plano_A21811000_I
    a ex:Esquema ;
    rdfs:label "Carro Porta-piezas (Subconjunto I - Nº A21811000_I)"@es ;
    ex:textoExtracto "Conjunto detallado con múltiples llamadas numeradas y tres detalles ampliados (A, B, C). Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes."@es ;
    ex:detalladoEnEsquema ex:SubconjuntoI_CarroPortaPiezas ;
    ex:identificador "A21811000_I" .

ex:SubconjuntoI_CarroPortaPiezas
    a ex:ComponenteMecanico ;
    rdfs:label "Subconjunto I (Carro porta-piezas)"@es ;
    ex:textoExtracto "Conjunto detallado con múltiples llamadas numeradas y tres detalles ampliados (A, B, C). Se distinguen columnas con guías, patines y cableado de sensores."@es ;
    ex:tieneComponente ex:ColumnasGuias_SubconjuntoI ;
    ex:tieneComponente ex:Patines_SubconjuntoI ;
    ex:tieneComponente ex:CableadoSensores_SubconjuntoI ;
    ex:documentadoEn ex:Plano_A21811000_I .

ex:ColumnasGuias_SubconjuntoI
    a ex:ComponenteMecanico ;
    rdfs:label "Columnas con guías (Subconjunto I)"@es ;
    ex:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores."@es .

ex:Patines_SubconjuntoI
    a ex:ComponenteMecanico ;
    rdfs:label "Patines (Subconjunto I)"@es ;
    ex:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores."@es .

ex:CableadoSensores_SubconjuntoI
    a ex:ComponenteElectrico ;
    rdfs:label "Cableado de sensores (Subconjunto I)"@es ;
    ex:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores."@es .