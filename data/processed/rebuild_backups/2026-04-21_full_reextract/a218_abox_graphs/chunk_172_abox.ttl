@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas Mecánicos (Planos)
ex:Esquema_CarroPortaPiezas_SubconjuntoII
    a ex:Esquema ;
    rdfs:label "Carro Porta-piezas (Subconjunto II)"@es ;
    ex:identificador "A21811000_II" ;
    ex:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes."@es ;
    ex:ilustradoEn ex:Pagina_91 .

ex:Esquema_GuiaCarroPortaPiezaDerecha
    a ex:Esquema ;
    rdfs:label "Guías carro porta-pieza derecha"@es ;
    ex:identificador "A21811005" ;
    ex:textoExtracto "Vista general a longitud completa con sección lateral del perfil guía. Se indican posiciones de deslizaderas y patrón de taladros a paso regular; notas de precisión (clase P, rascador estándar) y cotas críticas en mm."@es ;
    ex:ilustradoEn ex:Pagina_93 .

ex:Esquema_GuiaCarroPortaPiezaIzquierda
    a ex:Esquema ;
    rdfs:label "Guías carro porta-pieza izquierda"@es ;
    ex:identificador "A21811006" ;
    ex:textoExtracto "Lámina simétrica a la anterior: vista longitudinal con esquema de tres patines y sección de anclaje. Se señalan tolerancias de rectitud/planitud y cotas de referencia para montaje."@es ;
    ex:ilustradoEn ex:Pagina_94 .

ex:Esquema_PinonesContrapeso
    a ex:Esquema ;
    rdfs:label "Piñones contrapeso — Conjunto"@es ;
    ex:identificador "A21811030" ;
    ex:textoExtracto "Vistas múltiples del soporte de piñón con cotas de referencia (distancias entre ejes y alturas). El isométrico facilita la lectura del posicionamiento respecto a la estructura del carro."@es ;
    ex:ilustradoEn ex:Pagina_94 .

### Componentes Mecánicos (Extraídos de Esquemas)
ex:Componente_ColumnasConGuias
    a ex:ComponenteMecanico ;
    rdfs:label "Columnas con guías (Carro Porta-piezas)"@es ;
    ex:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores"@es ;
    ex:detalladoEnEsquema ex:Esquema_CarroPortaPiezas_SubconjuntoII .

ex:Componente_PatinesCarro
    a ex:ComponenteMecanico ;
    rdfs:label "Patines del carro porta-piezas"@es ;
    ex:textoExtracto "Lámina simétrica [...] con esquema de tres patines y sección de anclaje"@es ;
    ex:detalladoEnEsquema ex:Esquema_GuiaCarroPortaPiezaIzquierda .

ex:Componente_DeslizaderasGuiaDerecha
    a ex:ComponenteMecanico ;
    rdfs:label "Deslizaderas (Guía derecha)"@es ;
    ex:textoExtracto "Se indican posiciones de deslizaderas y patrón de taladros a paso regular"@es ;
    ex:detalladoEnEsquema ex:Esquema_GuiaCarroPortaPiezaDerecha .

ex:Componente_PinonesContrapeso
    a ex:ComponenteMecanico ;
    rdfs:label "Piñones de contrapeso"@es ;
    ex:textoExtracto "Vistas múltiples del soporte de piñón con cotas de referencia"@es ;
    ex:detalladoEnEsquema ex:Esquema_PinonesContrapeso .

