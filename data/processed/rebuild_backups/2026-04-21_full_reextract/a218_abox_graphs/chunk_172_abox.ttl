    ex:identificador "116-117 (Anexo 10.1)" ;
    ex:textoExtracto "Anexos — Planos mecánicos (Carro porta-piezas)"@es ;
    ex:documentadoEn ex:Capitulo_10 .

ex:Pagina_93
    a ex:Pagina ;
    ex:identificador "170-171 (Anexo 10.1)" ;
    ex:textoExtracto "Anexos — Planos mecánicos (Guías)"@es ;
    ex:documentadoEn ex:Capitulo_10 .

ex:Pagina_94
    a ex:Pagina ;
    ex:identificador "172 (Anexo 10.1)" ;
    ex:textoExtracto "Anexos — Planos mecánicos (Contrapeso)"@es ;
    ex:documentadoEn ex:Capitulo_10 .

### Estructura Jerárquica (Capítulo)
ex:Capitulo_10
    a ex:Capitulo ;
    rdfs:label "CAPÍTULO 10 - ANEXOS"@es ;
    ex:textoExtracto "10.1 – PLANOS MECANICOS | 10.2 – ESQUEMAS DE FLUIDOS | 10.3 – ESQUEMAS ELECTRICOS"@es .