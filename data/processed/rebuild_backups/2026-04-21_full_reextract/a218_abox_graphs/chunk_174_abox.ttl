@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

### Esquemas y Planos
ex:Esquema_Contrapeso_A21811090
    a ex:Esquema ;
    rdfs:label "Conjunto contrapeso (Nº A21811090)" ;
    ex:identificador "A21811090" ;
    ex:textoExtracto "Isométricos y alzados del bloque doble con guías laterales; detalle A (1:5) y detalle B (1:1) enseñan fijaciones y paso de cableado. La sección A-A muestra el apilamiento y anclaje de los deslizadores." .

ex:Esquema_PlatoDivisor_0_A21813100
    a ex:Esquema ;
    rdfs:label "Plato divisor 0° (Nº A21813100)" ;
    ex:identificador "A21813100" ;
    ex:textoExtracto "Vistas lateral, frontal y planta del divisor con corona dentada exterior y alojamiento central taladrado. Se aprecia el acoplamiento al servomotor y el patrón circular de fijación en la mesa." .

ex:Esquema_PlatoDivisor_15_A21813115
    a ex:Esquema ;
    rdfs:label "Plato divisor 15° (Nº A21813115)" ;
    ex:identificador "A21813115" ;
    ex:textoExtracto "Misma familia de vistas con inclinación de 15°. Trazas y ejes indican la basculación; se mantiene el dentado perimetral y el patrón de agujeros para el amarre de utillajes." .

ex:Esquema_ModuloLimpieza_A21816000
    a ex:Esquema ;
    rdfs:label "Conjunto cepillos (Nº A21816000)" ;
    ex:identificador "A21816000" ;
    ex:textoExtracto "Conjunto con secciones A-A y B-B de un módulo de limpieza: cuerpo, cilindro neumático y cartucho de cepillos. Los isométricos y vistas planas muestran guías, tornillería y pasos de aire; cotas 'REF' sitúan longitudes clave." .

ex:Esquema_Hidraulico_Grupo
    a ex:Esquema ;
    rdfs:label "Esquema hidráulico del grupo" ;
    ex:textoExtracto "Esquema hidráulico del grupo: depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque." .

### Componentes Mecánicos
ex:Contrapeso_BloqueDoble
    a ex:ComponenteMecanico ;
    rdfs:label "Bloque doble con guías laterales" ;
    ex:textoExtracto "Isométricos y alzados del bloque doble con guías laterales; detalle A (1:5) y detalle B (1:1) enseñan fijaciones y paso de cableado." ;
    ex:detalladoEnEsquema ex:Esquema_Contrapeso_A21811090 .

ex:PlatoDivisor_0
    a ex:ComponenteMecanico ;
    rdfs:label "Plato divisor 0°" ;
    ex:textoExtracto "Vistas lateral, frontal y planta del divisor con corona dentada exterior y alojamiento central taladrado." ;
    ex:detalladoEnEsquema ex:Esquema_PlatoDivisor_0_A21813100 .

ex:PlatoDivisor_15
    a ex:ComponenteMecanico ;
    rdfs:label "Plato divisor 15°" ;
    ex:textoExtracto "Misma familia de vistas con inclinación de 15°. Trazas y ejes indican la basculación; se mantiene el dentado perimetral y el patrón de agujeros para el amarre de utillajes." ;
    ex:detalladoEnEsquema ex:Esquema_PlatoDivisor_15_A21813115 .

ex:ModuloLimpieza_Cepillos
    a ex:ComponenteMecanico ;
    rdfs:label "Módulo de limpieza con cepillos" ;
    ex:textoExtracto "Conjunto con secciones A-A y B-B de un módulo de limpieza: cuerpo, cilindro neumático y cartucho de cepillos." ;
    ex:detalladoEnEsquema ex:Esquema_ModuloLimpieza_A21816000 .

### Componentes Hidráulicos
ex:Deposito_Hidraulico_130L
    a ex:ComponenteHidraulico ;
    rdfs:label "Depósito hidráulico 130 L" ;
    ex:valor "130" ;
    ex:textoExtracto "depósito 130 L con sensor de nivel (BL726)" ;
    ex:detalladoEnEsquema ex:Esquema_Hidraulico_Grupo .

ex:SensorNivel_BL726
    a ex:Sensor ;
    rdfs:label "Sensor de nivel BL726" ;
    ex:identificador "BL726" ;
    ex:textoExtracto "depósito 130 L con sensor de nivel (BL726)" ;
    ex:detalladoEnEsquema ex:Esquema_Hidraulico_Grupo .

ex:MotorHidraulico_M6
    a ex:ComponenteHidraulico ;
    rdfs:label "Motor del grupo M6" ;
    ex:identificador "M6" ;
    ex:textoExtracto "M6 motor del grupo, bomba y retorno al tanque." ;
    ex:detalladoEnEsquema ex:Esquema_Hidraulico_Grupo .

### Relaciones entre esquemas y componentes
ex:Esquema_Hidraulico_Grupo
    ex:tieneComponente ex:Deposito_Hidraulico_130L , ex:SensorNivel_BL726 , ex:MotorHidraulico_M6 .