@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas y sistemas principales
ex:esquema_hidraulico_grupo
    a ex:Esquema ;
    rdfs:label "Esquema hidráulico del grupo"@es ;
    ex:textoExtracto "Esquema hidráulico del grupo: depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque. Líneas rojas/azules identifican presión (2P) y retorno (2T); se muestran longitudes de latiguillos, secciones y elementos de sensórica."@es ;
    ex:detalladoEnEsquema ex:sistema_hidraulico_grupo .

ex:sistema_hidraulico_grupo
    a ex:Sistema ;
    rdfs:label "Sistema hidráulico del grupo"@es ;
    ex:textoExtracto "depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque"@es ;
    ex:tieneComponente ex:deposito_130L, ex:sensor_nivel_BL726, ex:motor_M6, ex:bomba_hidraulica_grupo ;
    ex:compuestoPor ex:latiguillos_hidraulicos_2P, ex:latiguillos_hidraulicos_2T .

ex:esquema_hidraulico_mesa_freno
    a ex:Esquema ;
    rdfs:label "Esquema hidráulico de mesa rotatoria y freno"@es ;
    ex:textoExtracto "Diagrama funcional de mesa rotatoria subir/bajar (válvulas YP802/YP803, TN10) y desbloqueo freno MAYR del carro (YP900). Incluye presostatos (BP714, BP727), detectores (SQ46/SQ47) y válvulas con referencias (BQ715/717/720/721/723/724)."@es ;
    ex:detalladoEnEsquema ex:sistema_hidraulico_mesa_freno .

ex:sistema_hidraulico_mesa_freno
    a ex:Sistema ;
    rdfs:label "Sistema hidráulico de mesa rotatoria y freno MAYR"@es ;
    ex:textoExtracto "mesa rotatoria subir/bajar (válvulas YP802/YP803, TN10) y desbloqueo freno MAYR del carro (YP900)"@es ;
    ex:tieneComponente ex:valvula_YP802, ex:valvula_YP803, ex:valvula_TN10, ex:valvula_YP900, ex:presostato_BP714, ex:presostato_BP727, ex:sensor_SQ46, ex:sensor_SQ47 .

ex:esquema_neumatico_cepillo_refrigerante
    a ex:Esquema ;
    rdfs:label "Esquema neumático de cepillo de limpieza y refrigerante"@es ;
    ex:textoExtracto "Esquema neumático con unidad FRL (AW40, manómetros BP710/BP711), regulación de presiones y circuitos para cepillo de limpieza (cilindro MGPM25-175Z; válvulas YP901/YP902) y refrigerante limpieza bastidor (YP903)."@es ;
    ex:detalladoEnEsquema ex:sistema_neumatico_limpieza .

ex:sistema_neumatico_limpieza
    a ex:Sistema ;
    rdfs:label "Sistema neumático de cepillo de limpieza y refrigerante"@es ;
    ex:textoExtracto "circuitos para cepillo de limpieza (cilindro MGPM25-175Z; válvulas YP901/YP902) y refrigerante limpieza bastidor (YP903)"@es ;
    ex:tieneComponente ex:unidad_FRL_AW40, ex:manometro_BP710, ex:manometro_BP711, ex:cilindro_MGPM25_175Z, ex:valvula_YP901, ex:valvula_YP902, ex:valvula_YP903 .

ex:esquema_refrigeracion
    a ex:Esquema ;
    rdfs:label "Esquema de refrigeración"@es ;
    ex:textoExtracto "Circuito de refrigeración con capacidad 200 L. Motores: M3 (refrigerante máquina), M4 (trasvase), M5 (extractor de viruta) y grupo de filtro de papel (SQ40). Sensores de nivel (BN41/BN42) y caudal BC44."@es ;
    ex:detalladoEnEsquema ex:sistema_refrigeracion .

ex:sistema_refrigeracion
    a ex:Sistema ;
    rdfs:label "Sistema de refrigeración (200 L)"@es ;
    ex:textoExtracto "Circuito de refrigeración con capacidad 200 L. Motores: M3 (refrigerante máquina), M4 (trasvase), M5 (extractor de viruta) y grupo de filtro de papel (SQ40). Sensores de nivel (BN41/BN42) y caudal BC44."@es ;
    ex:tieneComponente ex:motor_M3, ex:motor_M4, ex:motor_M5, ex:filtro_SQ40, ex:sensor_nivel_BN41, ex:sensor_nivel_BN42, ex:sensor_caudal_BC44 .

### Componentes hidráulicos
ex:deposito_130L
    a ex:ComponenteHidraulico ;
    rdfs:label "Depósito hidráulico 130 L"@es ;
    ex:identificador "130 L" ;
    ex:textoExtracto "depósito 130 L"@es .

ex:sensor_nivel_BL726
    a ex:Sensor ;
    rdfs:label "Sensor de nivel BL726"@es ;
    ex:identificador "BL726" ;
    ex:textoExtracto "sensor de nivel (BL726)"@es ;
    ex:monitoreaParametro ex:parametro_nivel_deposito .

ex:parametro_nivel_deposito
    a ex:Parametro ;
    rdfs:label "Nivel del depósito hidráulico"@es ;
    ex:textoExtracto "nivel"@es .

ex:motor_M6
    a ex:ComponenteHidraulico ;
    rdfs:label "Motor del grupo M6"@es ;
    ex:identificador "M6" ;
    ex:textoExtracto "M6 motor del grupo"@es .

ex:bomba_hidraulica_grupo
    a ex:ComponenteHidraulico ;
    rdfs:label "Bomba hidráulica del grupo"@es ;
    ex:textoExtracto "bomba"@es .

ex:latiguillos_hidraulicos_2P
    a ex:ComponenteHidraulico ;
    rdfs:label "Latiguillos de presión (2P)"@es ;
    ex:identificador "2P" ;
    ex:textoExtracto "Líneas rojas [...] presión (2P)"@es .

ex:latiguillos_hidraulicos_2T
    a ex:ComponenteHidraulico ;
    rdfs:label "Latiguillos de retorno (2T)"@es ;
    ex:identificador "2T" ;
    ex:textoExtracto "Líneas azules [...] retorno (2T)"@es .

