@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas eléctricos (I/O Máquina y módulos)
ex:Esquema_IOMaquinaVista
    a ex:Esquema ;
    rdfs:label "Esquema I/O Máquina (vista)"@es ;
    ex:textoExtracto "Conexión común a 0SAFE; simbología de contactos y bobinas uniformada. --- Páginas: 134 | Sección: Esquemas eléctricos — I/O de máquina (vista) | Título: I/O Maquina vista ---"@es ;
    ex:identificador "I/O_Maquina_vista" .

ex:Esquema_PowerModule
    a ex:Esquema ;
    rdfs:label "Esquema Power Module (19A1 IL EC BK-PAC)"@es ;
    ex:textoExtracto "Diagrama del módulo de potencia y alimentación de bus para 19A1 IL EC BK-PAC. Se muestran barras superiores de 24S/0S/PE y derivaciones a través de bornes XT1/XT2/XTP1, con rótulos de señales cruzadas (p. ej., 12.21/24API, 0API/90.03)."@es ;
    ex:identificador "PowerModule_19A1" .

ex:Esquema_BorneEntradaDigital
    a ex:Esquema ;
    rdfs:label "Esquema borne de entrada digital (19A2 E00–E07)"@es ;
    ex:textoExtracto "Entradas E00–E07 (módulo 19A2) rotuladas con estados de seguridad: Fallo climatizador armario, Puesta en servicio, Puertas cerradas (frontal/izq./dcha.), Discordancia relés de seguridad, PILZ OK."@es ;
    ex:identificador "BorneEntradaDigital_19A2" .

### Módulos y componentes eléctricos
ex:Modulo_IL_EC_BK_PAC
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo IL EC BK-PAC (bus)"@es ;
    ex:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus)"@es ;
    ex:identificador "19A1_IL_EC_BK-PAC" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule ;
    ex:detalladoEnEsquema ex:Esquema_IOMaquinaVista .

ex:Modulo_DI_8_HD_ECO
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo DI 8/HD-ECO (entrada digital)"@es ;
    ex:textoExtracto "varias DI 8/HD-ECO"@es ;
    ex:identificador "DI_8_HD-ECO" ;
    ex:detalladoEnEsquema ex:Esquema_IOMaquinaVista .

ex:Modulo_DO_8_HD_ECO
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo DO 8/HD-ECO (salida digital)"@es ;
    ex:textoExtracto "DO 8/HD-ECO"@es ;
    ex:identificador "DO_8_HD-ECO" ;
    ex:detalladoEnEsquema ex:Esquema_IOMaquinaVista .

ex:Modulo_AI_4_U_PAC
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo AI 4/U-PAC (entrada analógica)"@es ;
    ex:textoExtracto "AI 4/U-PAC"@es ;
    ex:identificador "AI_4_U-PAC" ;
    ex:detalladoEnEsquema ex:Esquema_IOMaquinaVista .

ex:Modulo_19A2_EntradasDigitales
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 19A2 (entradas digitales E00–E07)"@es ;
    ex:textoExtracto "Entradas E00–E07 (módulo 19A2) rotuladas con estados de seguridad"@es ;
    ex:identificador "19A2_E00-E07" ;
    ex:detalladoEnEsquema ex:Esquema_BorneEntradaDigital .

### Bornes y conexiones críticas
ex:Borne_XT1
    a ex:ComponenteElectrico ;
    rdfs:label "Borne XT1 (derivación 24S/0S/PE)"@es ;
    ex:textoExtracto "derivaciones a través de bornes XT1/XT2/XTP1"@es ;
    ex:identificador "XT1" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule .

ex:Borne_XT2
    a ex:ComponenteElectrico ;
    rdfs:label "Borne XT2 (derivación 24S/0S/PE)"@es ;
    ex:textoExtracto "derivaciones a través de bornes XT1/XT2/XTP1"@es ;
    ex:identificador "XT2" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule .

ex:Borne_XTP1
    a ex:ComponenteElectrico ;
    rdfs:label "Borne XTP1 (señales cruzadas: 12.21/24API, 0API/90.03)"@es ;
    ex:textoExtracto "rótulos de señales cruzadas (p. ej., 12.21/24API, 0API/90.03)"@es ;
    ex:identificador "XTP1" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule .

ex:Conector_RJ45_X1
    a ex:ComponenteElectrico ;
    rdfs:label "Conector RJ45 X1 (bus EC)"@es ;
    ex:textoExtracto "El bloque del bus EC (RJ45 X1/X2) aparece con sus pines y referencias"@es ;
    ex:identificador "RJ45_X1" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule .

ex:Conector_RJ45_X2
    a ex:ComponenteElectrico ;
    rdfs:label "Conector RJ45 X2 (bus EC)"@es ;
    ex:textoExtracto "El bloque del bus EC (RJ45 X1/X2) aparece con sus pines y referencias"@es ;
    ex:identificador "RJ45_X2" ;
    ex:detalladoEnEsquema ex:Esquema_PowerModule .

### Señales de seguridad (entradas digitales)
ex:Entrada_E00_FalloClimatizador
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada E00 (Fallo climatizador armario)"@es ;
    ex:textoExtracto "E00: Fallo climatizador armario"@es ;
    ex:identificador "E00" ;
    ex:detalladoEnEsquema ex:Esquema_BorneEntradaDigital ;
    ex:tieneComponente ex:Modulo_19A2_EntradasDigitales .

ex:Entrada_E01_PuestaServicio
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada E01 (Puesta en servicio)"@es ;
    ex:textoExtracto "E01: Puesta en servicio"@es ;
    ex:identificador "E01" ;
