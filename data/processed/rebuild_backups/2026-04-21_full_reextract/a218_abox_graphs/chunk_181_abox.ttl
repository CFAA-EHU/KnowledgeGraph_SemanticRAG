ex:Entrada_E04_PILZ_OK
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada E04 (PILZ OK)"@es ;
    ex:textoExtracto "E04: PILZ OK"@es ;
    ex:identificador "E04" ;
    ex:detalladoEnEsquema ex:Esquema_BorneEntradaDigital ;
    ex:tieneComponente ex:Modulo_19A2_EntradasDigitales .

### Relaciones de composición
ex:Modulo_IL_EC_BK_PAC
    ex:tieneComponente ex:Conector_RJ45_X1 ;
    ex:tieneComponente ex:Conector_RJ45_X2 ;
    ex:tieneComponente ex:Borne_XT1 ;
    ex:tieneComponente ex:Borne_XT2 ;
    ex:tieneComponente ex:Borne_XTP1 .

ex:Modulo_19A2_EntradasDigitales
    ex:tieneComponente ex:Entrada_E00_FalloClimatizador ;
    ex:tieneComponente ex:Entrada_E01_PuestaServicio ;
    ex:tieneComponente ex:Entrada_E02_PuertasCerradas ;
    ex:tieneComponente ex:Entrada_E03_DiscordanciaReles ;
    ex:tieneComponente ex:Entrada_E04_PILZ_OK .