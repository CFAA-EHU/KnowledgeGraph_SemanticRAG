@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Interfaz de Usuario (HMI)
ex:PanelOperador_VistaExterior
    a ex:InterfazUsuario ;
    rdfs:label "Panel Operador (Vista Exterior)" ;
    ex:textoExtracto "Alzado del HMI con cotas (558×350 mm, separación de 79 mm entre elementos) y rotulado de teclas: Puesta en servicio, Paro servicio, Marcha ciclo, Setup, Enable puertas, Apertura puertas." ;
    ex:ilustradoEn ex:Esquema_ExternalIO_60U1 .

### Componentes Eléctricos (Módulo y Conectores)
ex:Modulo_60U1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo DI16 M12 (60U1)" ;
    ex:identificador "60U1" ;
    ex:textoExtracto "Lámina de asignación de conectores M12 del módulo 60U1. En el centro se dibuja el dispositivo con pines X01–X08 y, a ambos lados, columnas con Us/GND/FE/IN1…IN16 y referencias cruzadas (62.xx/63.xx/61.xx)." ;
    ex:detalladoEnEsquema ex:Esquema_ExternalIO_60U1 ;
    ex:tieneComponente ex:Conector_XT1 .

ex:Conector_XT1
    a ex:ComponenteElectrico ;
    rdfs:label "Bornes XT1" ;
    ex:identificador "XT1" ;
    ex:textoExtracto "Canales reservados (etiqueta RESERVA) con polaridad indicada y referencias a bornes XT1; se representa la asignación +U/–U por canal." ;
    ex:documentadoEn ex:Esquema_ExternalIO_60U1 .

ex:Latiguillo_61WAL1
    a ex:ComponenteElectrico ;
    rdfs:label "Latiguillo 61WAL1" ;
    ex:identificador "61WAL1" ;
    ex:valor "7,5 m" ;
    ex:textoExtracto "BUS IN (X21) y BUS OUT (X22) con latiguillo 61WAL1 (7,5 m); referencias a WCAT2/WCAT3 enlazan el tramo de red." ;
    ex:documentadoEn ex:Esquema_ExternalIO_60U1 .

### Esquemas de Documentación
ex:Esquema_ExternalIO_60U1
    a ex:Esquema ;
    rdfs:label "Esquema External I/O — AXL E EC DI16 M12 6P (60U1)" ;
    ex:identificador "AXL E EC DI16 M12 6P" ;
    ex:textoExtracto "Esquema de alimentación y comunicaciones del 60U1: entradas 24VAN/0VAN/24EBC/0EBC, BUS IN (X21) y BUS OUT (X22). Se muestran bloques X31/X32 con US/UA/GND." ;
    ex:ilustradoEn ex:Pagina_152_153 .

### Pulsadores y Señales Asociadas
ex:Pulsador_26SBL1
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador 26SBL1" ;
    ex:identificador "26SBL1" ;
    ex:textoExtracto "flechas y recuadros asocian cada pulsador con su señal (p. ej., 26SBL1, 34SBL2, SA36, SBL37)." ;
    ex:documentadoEn ex:PanelOperador_VistaExterior .

ex:Pulsador_34SBL2
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador 34SBL2" ;
    ex:identificador "34SBL2" ;
    ex:textoExtracto "flechas y recuadros asocian cada pulsador con su señal (p. ej., 26SBL1, 34SBL2, SA36, SBL37)." ;
    ex:documentadoEn ex:PanelOperador_VistaExterior .

ex:Selector_51XS1
    a ex:ComponenteElectrico ;
    rdfs:label "Selector 51XS1" ;
    ex:identificador "51XS1" ;
    ex:textoExtracto "A la derecha, vista del selector 51XS1." ;
    ex:documentadoEn ex:PanelOperador_VistaExterior .