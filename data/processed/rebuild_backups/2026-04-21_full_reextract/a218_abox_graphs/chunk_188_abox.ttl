@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas y módulos principales
ex:Esquema_75U1_ExternalIO a ex:Esquema ;
    rdfs:label "Esquema de E/S externas (75U1)"@es ;
    ex:textoExtracto "Lámina gemela de la anterior para el módulo 75U1: tabla gráfica de pines IN/OUT, BUS y alimentación. La leyenda lateral identifica conectores (X01–X08, X21/X22, X31/X32) y muestra correspondencias con actuadores YP90x."@es ;
    ex:identificador "AXL E EC DI8 DO4 2A M12 6P — 75U1" .

ex:Esquema_75U1_AlimentacionBus a ex:Esquema ;
    rdfs:label "Esquema de alimentación y bus (75U1)"@es ;
    ex:textoExtracto "Entradas de 24VAN/0VAN y 24EBC/0EBC desde XT1 a US/UA del 75U1, con representación de relés 27KA3–27KA6. Un latiguillo (76WAL1) enlaza comunicaciones."@es .

ex:Esquema_75U1_EntradasDI a ex:Esquema ;
    rdfs:label "Esquema de entradas digitales (75U1 IN1–IN8)"@es ;
    ex:textoExtracto "Asignación de entradas para el 'cepillo' (avanzado/retrocedido) y reservas. Dos sensores se representan con bloques BQ/WE y lazo de alimentación +24 V/0 V. Los conectores M12 X01–X04 agrupan señales, cada una con su pin (IN1–IN8), masa y FE."@es .

### Componentes eléctricos (conectores, latiguillos, relés)
ex:Conector_X01 a ex:ComponenteElectrico ;
    rdfs:label "Conector X01 (M12, IN1–IN8)"@es ;
    ex:textoExtracto "Los conectores M12 X01–X04 agrupan señales, cada una con su pin (IN1–IN8), masa y FE."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_EntradasDI .

ex:Conector_X05 a ex:ComponenteElectrico ;
    rdfs:label "Conector X05 (OUT1/3/5/7, FE/GND)"@es ;
    ex:textoExtracto "Cada conector (X05–X08) etiqueta OUT1/3/5/7 y FE/GND."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_ExternalIO .

ex:Latiguillo_76WAL1 a ex:ComponenteElectrico ;
    rdfs:label "Latiguillo 76WAL1 (comunicaciones)"@es ;
    ex:textoExtracto "Un latiguillo (76WAL1) enlaza comunicaciones."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_AlimentacionBus .

ex:Rel_27KA3 a ex:ComponenteElectrico ;
    rdfs:label "Relé 27KA3"@es ;
    ex:textoExtracto "Representación de relés 27KA3–27KA6."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_AlimentacionBus .

### Actuadores y sensores
ex:Actuador_YP801 a ex:Actuador ;
    rdfs:label "Actuador YP801"@es ;
    ex:textoExtracto "símbolos YP80x y bloques WA80x representan actuadores, con trazado simple de bobinas y retorno a masa."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_ExternalIO .

ex:Sensor_CepilloAvance a ex:Sensor ;
    rdfs:label "Sensor de cepillo (avance)"@es ;
    ex:textoExtracto "Asignación de entradas para el 'cepillo' (avanzado/retrocedido). Dos sensores se representan con bloques BQ/WE y lazo de alimentación +24 V/0 V."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_EntradasDI .

ex:Sensor_CepilloRetroceso a ex:Sensor ;
    rdfs:label "Sensor de cepillo (retroceso)"@es ;
    ex:textoExtracto "Asignación de entradas para el 'cepillo' (avanzado/retrocedido). Dos sensores se representan con bloques BQ/WE y lazo de alimentación +24 V/0 V."@es ;
    ex:detalladoEnEsquema ex:Esquema_75U1_EntradasDI .

### Relaciones de composición
ex:Esquema_75U1_ExternalIO ex:tieneComponente ex:Conector_X05 .
ex:Esquema_75U1_ExternalIO ex:tieneComponente ex:Actuador_YP801 .
ex:Esquema_75U1_AlimentacionBus ex:tieneComponente ex:Latiguillo_76WAL1 .
ex:Esquema_75U1_AlimentacionBus ex:tieneComponente ex:Rel_27KA3 .
ex:Esquema_75U1_EntradasDI ex:tieneComponente ex:Conector_X01 .
ex:Esquema_75U1_EntradasDI ex:tieneComponente ex:Sensor_CepilloAvance .
ex:Esquema_75U1_EntradasDI ex:tieneComponente ex:Sensor_CepilloRetroceso .