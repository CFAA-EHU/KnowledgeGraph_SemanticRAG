### Red y comunicaciones (Pág. 165)
ex:Esquema_TopologiaRed
    a ex:Esquema ;
    rdfs:label "Topología de comunicaciones de máquina (Pág. 165)"@es ;
    ex:identificador "FL SWITCH SFNB 5TX" ;
    ex:textoExtracto "Diagrama de red con router Wi-Fi industrial, switch Ethernet (puertos X1–X5), pasamuros RJ45 (X34) y alimentación 24 V DC."@es .

ex:Switch_Ethernet_SFNB5TX
    a ex:ComponenteElectrico ;
    rdfs:label "Switch Ethernet SFNB 5TX (puertos X1–X5)"@es ;
    ex:identificador "SFNB 5TX" ;
    ex:textoExtracto "switch Ethernet (puertos X1–X5)"@es ;
    ex:detalladoEnEsquema ex:Esquema_TopologiaRed .

ex:Router_WiFiIndustrial
    a ex:ComponenteElectrico ;
    rdfs:label "Router Wi-Fi industrial (24V DC)"@es ;
    ex:textoExtracto "Diagrama de red con router Wi-Fi industrial"@es ;
    ex:detalladoEnEsquema ex:Esquema_TopologiaRed .

ex:Pasamuros_RJ45_X34
