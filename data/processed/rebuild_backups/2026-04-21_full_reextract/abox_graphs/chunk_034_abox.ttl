@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SistemaAlumbradoMaquina a ex:Sistema ;
    rdfs:label "Sistema de alumbrado de máquina" ;
    ex:textoExtracto "La máquina esta provista de un sistema de alumbrado, compuesto por cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)." ;
    ex:compuestoPor ex:LamparaAlumbrado1, ex:LamparaAlumbrado2, ex:LamparaAlumbrado3, ex:LamparaAlumbrado4 .

ex:LamparaAlumbrado1 a ex:ComponenteElectrico ;
    rdfs:label "Lámpara de alumbrado 1" ;
    ex:textoExtracto "cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)" ;
    ex:identificador "19.5 W" ;
    ex:valor "19.5" .

ex:LamparaAlumbrado2 a ex:ComponenteElectrico ;
    rdfs:label "Lámpara de alumbrado 2" ;
    ex:textoExtracto "cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)" ;
    ex:identificador "19.5 W" ;
    ex:valor "19.5" .

ex:LamparaAlumbrado3 a ex:ComponenteElectrico ;
    rdfs:label "Lámpara de alumbrado 3" ;
    ex:textoExtracto "cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)" ;
    ex:identificador "19.5 W" ;
    ex:valor "19.5" .

ex:LamparaAlumbrado4 a ex:ComponenteElectrico ;
    rdfs:label "Lámpara de alumbrado 4" ;
    ex:textoExtracto "cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)" ;
    ex:identificador "19.5 W" ;
    ex:valor "19.5" .