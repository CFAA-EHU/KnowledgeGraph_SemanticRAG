@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Maquina_44_33 a ex:Maquina ;
    ex:textoExtracto "La máquina se compone de: Zócalo, Columna, Carro porta-piezas, Plato divisor, Carro porta-brochas, Sistema de limpieza de brocha, Sistema neumático, Sistema de engrase, Sistema hidráulico, Sistema de refrigeración, Carenado, Armario eléctrico" ;
    ex:compuestoPor ex:Zocalo_44_33, ex:Columna_44_33, ex:CarroPortapiezas_44_33, ex:PlatoDivisor_44_33, ex:CarroPortabrochas_44_33, ex:SistemaLimpiezaBrocha_44_33, ex:SistemaNeumatico_44_33, ex:SistemaEngrase_44_33, ex:SistemaHidraulico_44_33, ex:SistemaRefrigeracion_44_33, ex:Carenado_44_33, ex:ArmarioElectrico_44_33 .

