@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Columna_46 a ex:ComponenteMecanico ;
    ex:textoExtracto "Sobe el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro porta-piezas" ;
    ex:tieneComponente ex:GuiaLineal_46_1, ex:GuiaLineal_46_2, ex:CarroPortaPiezas_46 .

ex:GuiaLineal_46_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "dos guías lineales por las que se desplaza el carro porta-piezas" .

ex:GuiaLineal_46_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "dos guías lineales por las que se desplaza el carro porta-piezas" .

ex:CarroPortaPiezas_46 a ex:ComponenteMecanico ;
    ex:textoExtracto "el carro porta-piezas" ;
    ex:tieneComponente ex:SistemaPinonCremallera_46, ex:Servomotor_46_1, ex:Servomotor_46_2 ;
    ex:controla ex:ReglaLineal_46_1, ex:ReglaLineal_46_2 .

ex:ReglaLineal_46_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "dos reglas lineales colocadas en el lateral de la columna" .

ex:ReglaLineal_46_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "dos reglas lineales colocadas en el lateral de la columna" .

ex:SistemaPinonCremallera_46 a ex:ComponenteMecanico ;
    ex:textoExtracto "juegos de sistemas piñón/cremallera (WITTENSTEIN)" ;
    ex:identificador "WITTENSTEIN" .

ex:Servomotor_46_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "dos servomotores colocados sobre el carro porta-piezas" .

ex:Servomotor_46_2 a ex:ComponenteElectrico ;
    ex:textoExtracto "dos servomotores colocados sobre el carro porta-piezas" .