@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PanelOperador_66 a ex:InterfazUsuario ;
    ex:textoExtracto "Desde el panel operador se puede ajustar la velocidad de brochado hasta un límite de 40m/min." .

ex:ModoOperacion_VelocidadBrochado_40m_min_66 a ex:ModoOperacion ;
    ex:identificador "40m/min" ;
    ex:textoExtracto "velocidad de brochado hasta un límite de 40m/min" .

ex:PanelOperador_66 ex:controla ex:ModoOperacion_VelocidadBrochado_40m_min_66 .