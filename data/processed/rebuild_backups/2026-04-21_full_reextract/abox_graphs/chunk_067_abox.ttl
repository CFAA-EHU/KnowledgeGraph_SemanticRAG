@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterruptorGeneral a ex:Actuador ;
    rdfs:label "Interruptor general"@es ;
    ex:textoExtracto "colocando en ON la posición del interruptor general que se encuentra en la parte derecha del armario eléctrico visto de frente"@es ;
    ex:identificador "Figura 6-1" .

ex:ArmarioElectrico a ex:ComponenteElectrico ;
    rdfs:label "Armario eléctrico"@es ;
    ex:textoExtracto "en la parte derecha del armario eléctrico visto de frente"@es .

ex:TomaCorrienteInterior a ex:ComponenteElectrico ;
    rdfs:label "Toma de corriente interior"@es ;
    ex:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO"@es ;
    ex:valor "220VAC" .

ex:TomaCorrienteExterior a ex:ComponenteElectrico ;
    rdfs:label "Toma de corriente exterior"@es ;
    ex:textoExtracto "OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL"@es ;
    ex:valor "220VAC" .

ex:IluminacionArmario a ex:ComponenteElectrico ;
    rdfs:label "Iluminación del armario"@es ;
    ex:textoExtracto "LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC"@es ;
    ex:valor "220VAC" .

ex:Figura6_1 a ex:Figura ;
    rdfs:label "Figura 6-1"@es ;
    ex:textoExtracto "ON Figura 6-1. Interruptor general del armario eléctrico."@es ;
    ex:ilustradoEn ex:InterruptorGeneral .