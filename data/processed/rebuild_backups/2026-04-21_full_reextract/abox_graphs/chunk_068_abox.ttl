@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PulsadorParadaEmergencia_68 a ex:ComponenteElectrico ;
    rdfs:label "Pulsador de parada de emergencia" ;
    ex:textoExtracto "Pulsadores de parada de emergencia" .

ex:PulsadorSimple_68 a ex:ComponenteElectrico ;
    rdfs:label "Pulsador simple" ;
    ex:textoExtracto "Pulsadores simples" .

ex:PulsadorLuminoso_68 a ex:ComponenteElectrico ;
    rdfs:label "Pulsador luminoso" ;
    ex:textoExtracto "Pulsadores luminosos" .

ex:Selector_68 a ex:ComponenteElectrico ;
    rdfs:label "Selector" ;
    ex:textoExtracto "Selectores" .

ex:PanelOperadorPC21_68 a ex:InterfazUsuario ;
    rdfs:label "Panel operador PC-21” Panorámico 16Gb" ;
    ex:textoExtracto "Panel operador PC-21” Panorámico 16Gb" .

ex:ElementosMando_68 a ex:Sistema ;
    rdfs:label "Elementos de mando" ;
    ex:compuestoPor ex:PulsadorParadaEmergencia_68, ex:PulsadorSimple_68, ex:PulsadorLuminoso_68, ex:Selector_68, ex:PanelOperadorPC21_68 ;
    ex:textoExtracto "La máquina está compuesta por los siguientes elementos de mando:  Pulsadores de parada de emergencia  Pulsadores simples  Pulsadores luminosos  Selectores  Panel operador PC-21” Panorámico 16Gb" .