@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterruptorGeneral a ex:ComponenteElectrico ;
    rdfs:label "INTERRUPTOR GENERAL" ;
    ex:textoExtracto "INTERRUPTOR GENERAL" .

ex:PulsadorEmergencia a ex:ComponenteElectrico ;
    rdfs:label "PULSADOR EMERGENCIA" ;
    ex:textoExtracto "PULSADOR EMERGENCIA" .

ex:PilotoLuminosoTension a ex:ComponenteElectrico ;
    rdfs:label "PILOTO LUMINOSO TENSIÓN" ;
    ex:textoExtracto "PILOTO LUMINOSO TENSIÓN" .