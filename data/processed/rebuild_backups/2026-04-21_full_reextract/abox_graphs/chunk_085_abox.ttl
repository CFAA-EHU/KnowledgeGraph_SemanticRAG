@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PortonDobleCorrederoFrontal a ex:ComponenteMecanico ;
    rdfs:label "portón doble corredero" ;
    ex:textoExtracto "un portón doble corredero en la parte frontal" .

ex:PuertaCorrederaLateral a ex:ComponenteMecanico ;
    rdfs:label "puerta corredera" ;
    ex:textoExtracto "una puerta corredera en cada lateral" .

ex:PanelDesmontableLateral a ex:ComponenteMecanico ;
    rdfs:label "panel desmontable" ;
    ex:textoExtracto "dos paneles desmontables en cada lateral" .

ex:PanelDesmontableTrasero a ex:ComponenteMecanico ;
    rdfs:label "panel desmontable" ;
    ex:textoExtracto "dos paneles desmontables en la parte trasera" .