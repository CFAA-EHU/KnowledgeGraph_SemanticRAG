@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:VentanaAvisos a ex:AvisoSeguridad ;
    ex:textoExtracto "Siempre atendiendo las indicaciones de la ventana de avisos" .

ex:BotonReset a ex:InterfazUsuario ;
    ex:textoExtracto "Pulsar botón “RESET”" .

ex:BotonPuestaServicio a ex:InterfazUsuario ;
    ex:textoExtracto "Pulsar el botón “PUESTA SERVICIO”" .

ex:ModoOperacionBrochadora a ex:ModoOperacion ;
    ex:identificador "Brochadora en servicio" ;
    ex:textoExtracto "Brochadora en servicio" .

ex:ModoOperacionReset a ex:ModoOperacion ;
    ex:identificador "Reset Auto Manual" ;
    ex:textoExtracto "Reset Auto Manual" .