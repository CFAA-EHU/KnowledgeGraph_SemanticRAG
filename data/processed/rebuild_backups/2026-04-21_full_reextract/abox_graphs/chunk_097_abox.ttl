@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_97 a ex:Tabla ;
    ex:textoExtracto "OPERACION | PERIODO | RESPONSABLE | Comprobar y, si procede, cambiar el filtro del refrigerador del armario | Cada 200 h | OPERARIO / MANTENIMIENTO | Comprobar visualmente el estado de los cepillos del sistema de limpieza brocha | Cada 200 h | OPERARIO | Comprobar la instalación de refrigerante | Cada 200 h | OPERARIO | Comprobar las presiones de trabajo | Cada 200 h | OPERARIO |" .

ex:TareaMantenimiento_97_1 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar y, si procede, cambiar el filtro del refrigerador del armario" ;
    ex:tieneFrecuencia ex:Frecuencia_97_1 .

ex:Frecuencia_97_1 a ex:Frecuencia ;
    ex:valor "Cada 200 h" ;
    ex:textoExtracto "Cada 200 h" .

ex:TareaMantenimiento_97_2 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar visualmente el estado de los cepillos del sistema de limpieza brocha" ;
    ex:tieneFrecuencia ex:Frecuencia_97_2 .

ex:Frecuencia_97_2 a ex:Frecuencia ;
    ex:valor "Cada 200 h" ;
    ex:textoExtracto "Cada 200 h" .

ex:TareaMantenimiento_97_3 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar la instalación de refrigerante" ;
    ex:tieneFrecuencia ex:Frecuencia_97_3 .

ex:Frecuencia_97_3 a ex:Frecuencia ;
    ex:valor "Cada 200 h" ;
    ex:textoExtracto "Cada 200 h" .

ex:TareaMantenimiento_97_4 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar las presiones de trabajo" ;
    ex:tieneFrecuencia ex:Frecuencia_97_4 .

ex:Frecuencia_97_4 a ex:Frecuencia ;
    ex:valor "Cada 200 h" ;
    ex:textoExtracto "Cada 200 h" .

ex:Tabla_97 ex:tieneComponente ex:TareaMantenimiento_97_1, ex:TareaMantenimiento_97_2, ex:TareaMantenimiento_97_3, ex:TareaMantenimiento_97_4 .