@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TareaComprobacionApriete a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar si se han soltado los tornillos, tuercas, etc. En el caso de que así fuera, apretarlos." .

ex:Tornillo a ex:ComponenteMecanico ;
    ex:textoExtracto "tornillos" .

ex:Tuerca a ex:ComponenteMecanico ;
    ex:textoExtracto "tuercas" .