@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroPresion a ex:Parametro ;
    rdfs:label "6 bar" ;
    ex:valor "6" ;
    ex:textoExtracto "A una presión de 6 bar" .

ex:ParametroCaudal a ex:Parametro ;
    rdfs:label "225 L/min" ;
    ex:valor "225" ;
    ex:textoExtracto "un caudal de 225 L/min" .

ex:ParametroFiltracion a ex:Parametro ;
    ex:textoExtracto "filtrado y secado" .