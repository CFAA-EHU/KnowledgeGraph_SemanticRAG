@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaHidraulicoConBancada a ex:Sistema ;
    ex:compuestoPor ex:MotorM6, ex:NivelBL726, ex:ActuadorYP802, ex:ActuadorYP803, ex:ActuadorYP900, ex:SensorBP714, ex:SensorBP727 ;
    ex:textoExtracto "Conjunto sobre bancada con M6 (motor), BL726 (nivel), YP802/YP803 (mesa arriba/abajo), YP900 (freno), BP714/BP727 (presión)." .

ex:MotorM6 a ex:ComponenteMecanico ;
    ex:identificador "M6" ;
    ex:textoExtracto "M6 (motor)" .

ex:NivelBL726 a ex:Sensor ;
    ex:identificador "BL726" ;
    ex:textoExtracto "BL726 (nivel)" .

ex:ActuadorYP802 a ex:ComponenteHidraulico ;
    ex:identificador "YP802" ;
    ex:textoExtracto "YP802 (mesa arriba/abajo)" .

ex:ActuadorYP803 a ex:ComponenteHidraulico ;
    ex:identificador "YP803" ;
    ex:textoExtracto "YP803 (mesa arriba/abajo)" .

ex:ActuadorYP900 a ex:ComponenteHidraulico ;
    ex:identificador "YP900" ;
    ex:textoExtracto "YP900 (freno)" .

ex:SensorBP714 a ex:Sensor ;
    ex:identificador "BP714" ;
    ex:textoExtracto "BP714/BP727 (presión)" .

ex:SensorBP727 a ex:Sensor ;
    ex:identificador "BP727" ;
    ex:textoExtracto "BP714/BP727 (presión)" .

ex:SistemaRefrigeracion a ex:Sistema ;
    ex:tieneComponente ex:MotorM1, ex:MotorM3, ex:MotorM4, ex:MotorM5, ex:NivelBN41, ex:NivelBN42, ex:SensorSQ40, ex:SensorBC44 ;
    ex:textoExtracto "Dos fotos con recuadros a M1/M3/M4/M5 (motores), BN41/BN42 (niveles), SQ40 (papel) y BC44 (caudal)." .

ex:MotorM1 a ex:ComponenteMecanico ;
    ex:identificador "M1" ;
    ex:textoExtracto "M1/M3/M4/M5 (motores)" .

ex:MotorM3 a ex:ComponenteMecanico ;
    ex:identificador "M3" ;
    ex:textoExtracto "M1/M3/M4/M5 (motores)" .

ex:MotorM4 a ex:ComponenteMecanico ;
    ex:identificador "M4" ;
    ex:textoExtracto "M1/M3/M4/M5 (motores)" .

ex:MotorM5 a ex:ComponenteMecanico ;
    ex:identificador "M5" ;
    ex:textoExtracto "M1/M3/M4/M5 (motores)" .

ex:NivelBN41 a ex:Sensor ;
    ex:identificador "BN41" ;
    ex:textoExtracto "BN41/BN42 (niveles)" .

ex:NivelBN42 a ex:Sensor ;
