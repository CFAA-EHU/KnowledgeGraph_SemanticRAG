    ex:textoExtracto "BN41/BN42 (niveles)" .

ex:SensorSQ40 a ex:Sensor ;
    ex:identificador "SQ40" ;
    ex:textoExtracto "SQ40 (papel)" .

ex:SensorBC44 a ex:Sensor ;
