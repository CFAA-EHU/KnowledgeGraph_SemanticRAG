@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ServomotorDERECHAAXD2 a ex:ComponenteElectrico ;
    rdfs:label "Servomotor DERECHA AXD2" ;
    ex:textoExtracto "Esquema gemelo del anterior para el servo derecho: mismas funciones y cableados (19W1–W3, 1910). Se detallan saltos a buses y señales de safety." ;
    ex:compuestoPor ex:Relé27KAx, ex:BusSERCOS, ex:EnlaceBornesXT1 ;
    ex:detalladoEnEsquema ex:EsquemaEléctricoEjeTracciónDCHA .

ex:ServomotorMESAAXD1 a ex:ComponenteElectrico ;
    rdfs:label "Servomotor MESA AXD1" ;
    ex:textoExtracto "Drive AXD1 de mesa: potencia U/V/W, DC BUS, habilitaciones por 27KA1/2/5/6, retorno de encoder y enlaces 24CNC/0CNC. Representación modular idéntica para consistencia visual." ;
    ex:compuestoPor ex:Relé27KA1, ex:Relé27KA2, ex:Relé27KA5, ex:Relé27KA6, ex:Bus24CNC, ex:Bus0CNC ;
    ex:detalladoEnEsquema ex:EsquemaEléctricoEjeMesaGiratoria .

ex:SensorEUCHNERSSTP a ex:Sensor ;
    rdfs:label "Sensor EUCHNER STP" ;
    ex:textoExtracto "Sensor EUCHNER STP para puerta frontal con contactos etiquetados (21/22, 41/42, 11/12, 33/34) y líneas a 0S/24SAFE." ;
    ex:identificador "STP" ;
    ex:compuestoPor ex:Contacto21_22, ex:Contacto41_42, ex:Contacto11_12, ex:Contacto33_34 ;
    ex:detalladoEnEsquema ex:EsquemaEléctricoSeguridadPuertaFrontal .

ex:BloqueCTP_L1_AP_M_HA_AZ_SA a ex:ComponenteElectrico ;
    rdfs:label "Bloque CTP-L1-AP-M-HA-AZ-SA" ;
    ex:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs." ;
    ex:identificador "CTP-L1-AP-M-HA-AZ-SA" ;
    ex:detalladoEnEsquema ex:EsquemaEléctricoSeguridadPuertasLaterales .

