@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CTP_L1_AP_M_HA_AZ_SA_izquierda_derecha a ex:ComponenteElectrico ;
    rdfs:label "CTP-L1-AP-M-HA-AZ-SA" ;
    ex:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs." .

ex:CTP_25SQ1 a ex:ComponenteElectrico ;
    rdfs:label "CTP para escotilla interior (25SQ1)" ;
    ex:textoExtracto "Bloque único CTP para escotilla interior (25SQ1) con salidas de seguridad y diagnóstico; enlaces a 24SAFE/0S y rótulo Puerta cerrada." .

ex:PNOZ_m_B0_EF_16DI a ex:ComponenteElectrico ;
    rdfs:label "PNOZ m B0 + EF 16DI" ;
    ex:textoExtracto "Arquitectura PNOZ m B0 + EF 16DI: entradas/salidas, paradas de emergencia (pupitre y armario), puesta/paro de servicio, PLC OK, y salidas a relés 27KA1–8." .

ex:Relé_27KA1_8 a ex:ComponenteElectrico ;
    rdfs:label "27KA1–8" ;
    ex:textoExtracto "Banco de relés de potencia 27KA1–8 asignados a EMERGENCIA CH1/CH2, EMERGENCIA RETARDADA CH1/CH2, PUERTAS CH1/CH2, FRENO CH1/CH2." .

ex:Sistema_Puertas_Seguridad a ex:Sistema ;
    ex:tieneComponente ex:CTP_L1_AP_M_HA_AZ_SA_izquierda_derecha, ex:CTP_25SQ1 ;
    ex:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) ... Bloque único CTP para escotilla interior (25SQ1) ... con salidas de seguridad y diagnóstico; enlaces a 24SAFE/0S y rótulo Puerta cerrada." .

ex:Sistema_PLC_Seguridad a ex:Sistema ;
    ex:tieneComponente ex:PNOZ_m_B0_EF_16DI, ex:Relé_27KA1_8 ;
    ex:textoExtracto "Arquitectura PNOZ m B0 + EF 16DI ... y salidas a relés 27KA1–8." .

ex:Sistema_Salidas_Seguras a ex:Sistema ;
    ex:tieneComponente ex:Relé_27KA1_8 ;
    ex:textoExtracto "Banco de relés de potencia 27KA1–8 asignados a EMERGENCIA CH1/CH2, EMERGENCIA RETARDADA CH1/CH2, PUERTAS CH1/CH2, FRENO CH1/CH2." .