ex:X31_X32 a ex:ComponenteElectrico ;
    rdfs:label "X31/X32" ;
    ex:textoExtracto "Se muestran bloques X31/X32 con US/UA/GND." .

ex:X01_X04 a ex:ComponenteElectrico ;
    rdfs:label "X01–X04" ;
    ex:textoExtracto "Cableado de IN1–IN8 (conectores X01–X04) y el bloque de estado lubricación (515U1 → 515.03)." .

ex:IN1_IN8 a ex:Sensor ;
    rdfs:label "IN1–IN8" ;
    ex:textoExtracto "Cableado de IN1–IN8 (conectores X01–X04) y el bloque de estado lubricación (515U1 → 515.03)." .

ex:515U1 a ex:Sensor ;
    rdfs:label "515U1" ;
    ex:textoExtracto "Cableado de IN1–IN8 (conectores X01–X04) y el bloque de estado lubricación (515U1 → 515.03)." .

ex:WA800_WE700 a ex:Sistema ;
    rdfs:label "WA800/WE700" ;
    ex:textoExtracto "Se representa la unidad de lubricación (WA800/WE700) con su E/S (24 V, OUT, 0 V) y derivaciones a 62U1; líneas rojas/azules/verde identifican alimentación, señal y retorno." .

ex:62U1 a ex:ComponenteElectrico ;
    rdfs:label "62U1" ;
    ex:textoExtracto "Se representa la unidad de lubricación (WA800/WE700) con su E/S (24 V, OUT, 0 V) y derivaciones a 62U1; líneas rojas/azules/verde identifican alimentación, señal y retorno." .

ex:X05_X08 a ex:ComponenteElectrico ;
    rdfs:label "X05–X08" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

ex:IN9_IN16 a ex:Sensor ;
    rdfs:label "IN9–IN16" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

ex:BP710 a ex:Sensor ;
    rdfs:label "BP710" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

ex:BP711 a ex:Sensor ;
    rdfs:label "BP711" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

ex:BP714 a ex:Sensor ;
    rdfs:label "BP714" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

ex:63U1 a ex:ComponenteElectrico ;
    rdfs:label "63U1" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada. Se incluyen longitudes de latiguillos 1,5 m 5×0,34 y colores (WH/BL), más referencias a bloques 63U1/63U3/63U4." .

ex:63U3 a ex:ComponenteElectrico ;
    rdfs:label "63U3" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada. Se incluyen longitudes de latiguillos 1,5 m 5×0,34 y colores (WH/BL), más referencias a bloques 63U1/63U3/63U4." .

ex:63U4 a ex:ComponenteElectrico ;
    rdfs:label "63U4" ;
    ex:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada. Se incluyen longitudes de latiguillos 1,5 m 5×0,34 y colores (WH/BL), más referencias a bloques 63U1/63U3/63U4." .

ex:70U1 a ex:Sistema ;
    rdfs:label "70U1" ;
    ex:textoExtracto "Vista del módulo descentralizado con su silueta centrada y columnas laterales que listan conectores M12 (X01–X08), BUS IN/OUT (X21/X22) y bornes de alimentación/masa (US/UA/GND/FE). Cada puerto muestra pines (IN1–IN8, OUT1–OUT7) con referencias cruzadas y códigos de cableado; la jerarquía visual separa claramente alimentación, señales y tierra." .

ex:X21_X22 a ex:ComponenteElectrico ;
    rdfs:label "X21/X22" ;
    ex:textoExtracto "Vista del módulo descentralizado con su silueta centrada y columnas laterales que listan conectores M12 (X01–X08), BUS IN/OUT (X21/X22) y bornes de alimentación/masa (US/UA/GND/FE)." .

ex:OUT1_OUT7 a ex:Sensor ;
    rdfs:label "OUT1–OUT7" ;
    ex:textoExtracto "Vista del módulo descentralizado con su silueta centrada y columnas laterales que listan conectores M12 (X01–X08), BUS IN/OUT (X21/X22) y bornes de alimentación/masa (US/UA/GND/FE). Cada puerto muestra pines (IN1–IN8, OUT1–OUT7) con referencias cruzadas y códigos de cableado; la jerarquía visual separa claramente alimentación, señales y tierra." .