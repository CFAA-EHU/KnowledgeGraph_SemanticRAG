    ex:textoExtracto "ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros)" .

ex:ArmarioElectrico_190_168 a ex:ComponenteElectrico ;
    rdfs:label "Armario eléctrico" ;
    ex:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables. Líneas de cota (mm) y rótulos de referencia (p. ej., 19A1…19A9, 27KAx) dan jerarquía y ubicación precisa." ;
    ex:tieneComponente ex:Seccionador_190_168, ex:Contactor_190_168, ex:FuenteSITOP_190_168, ex:ModuloPhoenix_190_168, ex:Relé_190_168, ex:Climatizador_190_168_2, ex:Pasacables_190_168 .

