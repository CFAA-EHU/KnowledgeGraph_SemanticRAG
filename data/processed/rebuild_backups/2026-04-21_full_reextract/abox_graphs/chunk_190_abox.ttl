ex:PlacaCaracteristicas_190_168 a ex:Tabla ;
    rdfs:label "Placa de características" ;
    ex:textoExtracto "Placa ilustrada con logotipo y campos: potencia instalada (80 kVA), alimentación (3×380 V 50 Hz), control (220 V/24 V =), año, protección (125 A, 10 kA) y datos del fabricante. Diseño con recuadros y tipografía clara a modo de etiqueta industrial." ;
    ex:valor "potencia instalada (80 kVA), alimentación (3×380 V 50 Hz), control (220 V/24 V =), protección (125 A, 10 kA)" .

ex:Broachadora_190_169 a ex:Maquina ;
    rdfs:label "Broachadora" ;
    ex:textoExtracto "Diagrama de etapas/acciones numeradas (0–15) para la broachadora: origen, subir/girar/bajar mesa giratoria, movimiento del carro de tracción, avance/retroceso de cepillos y fin de ciclo." ;
    ex:tieneComponente ex:MesaGiratoria_190_169, ex:CarroTraccion_190_169, ex:Cepillos_190_169 .

ex:MesaGiratoria_190_169 a ex:ComponenteMecanico ;
