@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ArmarioElectrico_190_166 a ex:ComponenteElectrico ;
    rdfs:label "Armario eléctrico" ;
    ex:textoExtracto "Líneas gruesas conectan cada equipo al switch; iconografía de cada dispositivo facilita identificar su rol en la red." ;
    ex:tieneComponente ex:Switch_190_166 .

ex:Switch_190_166 a ex:ComponenteElectrico ;
    rdfs:label "Switch" ;
    ex:textoExtracto "Líneas gruesas conectan cada equipo al switch" .

ex:ArmarioElectrico_190_167 a ex:ComponenteElectrico ;
    rdfs:label "Armario eléctrico" ;
    ex:identificador "A218" ;
    ex:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.) y ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros). Cotas y símbolos de seguridad se representan con flechas y etiquetas." ;
    ex:valor "alto 1800 mm, ancho 1200 mm, fondo 500 mm" ;
    ex:tieneComponente ex:Selector_190_167, ex:SetaEmergencia_190_167, ex:Climatizador_190_167, ex:Pasamuros_190_167 .

ex:Selector_190_167 a ex:ComponenteElectrico ;
    rdfs:label "Selector" ;
    ex:textoExtracto "ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros)" .

ex:SetaEmergencia_190_167 a ex:ElementoSeguridad ;
    rdfs:label "Seta de emergencia" ;
    ex:textoExtracto "ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros)" .

ex:Climatizador_190_167 a ex:ComponenteElectrico ;
