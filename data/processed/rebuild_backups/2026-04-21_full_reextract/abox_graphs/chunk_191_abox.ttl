@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:XT1M a ex:InterfazUsuario ;
    ex:textoExtracto "Diagrama matricial del bloque XT1M con filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico) y climatizador." ;
    ex:tieneComponente ex:MotorRefrigerante, ex:MotorTrasvase, ex:MotorExtractor, ex:GrupoHidraulico, ex:Climatizador .

ex:MotorRefrigerante a ex:ComponenteElectrico ;
    ex:textoExtracto "filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico)" .

ex:MotorTrasvase a ex:ComponenteElectrico ;
    ex:textoExtracto "filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico)" .

ex:MotorExtractor a ex:ComponenteElectrico ;
    ex:textoExtracto "filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico)" .

ex:GrupoHidraulico a ex:ComponenteHidraulico ;
    ex:textoExtracto "filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico)" .

ex:Climatizador a ex:ComponenteElectrico ;
    ex:textoExtracto "filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico) y climatizador." .

ex:XT1 a ex:InterfazUsuario ;
    ex:textoExtracto "Vista de bornes XT1 con asignaciones a 0V/24V de distintos sistemas (API, CNC, PNL, S, SAFE) y señales de puertas, columna luminosa y motores." ;
    ex:tieneComponente ex:ColumnaLuminosa, ex:Motor, ex:Puerta ;
    ex:compuestoPor ex:Borne0V, ex:Borne24V .

ex:ColumnaLuminosa a ex:ComponenteElectrico ;
    ex:textoExtracto "señales de ... columna luminosa" .

ex:Motor a ex:ComponenteElectrico ;
    ex:textoExtracto "señales de ... motores" .

ex:Puerta a ex:ElementoSeguridad ;
    ex:textoExtracto "señales de ... puertas" .

ex:Borne0V a ex:ComponenteElectrico ;
    ex:textoExtracto "asignaciones a 0V/24V de distintos sistemas" .

ex:Borne24V a ex:ComponenteElectrico ;
    ex:textoExtracto "asignaciones a 0V/24V de distintos sistemas" .

ex:XT1_3_4 a ex:InterfazUsuario ;
    ex:textoExtracto "Continuación de XT1 con líneas dedicadas a alimentaciones (24API/24CNC/24E/24EBC/24PNL/24S/24SAFE) y vínculos a servomotores (mesa e izquierda). Se resaltan bornes de 'ALIMENTACIÓN ENTRADAS/SALIDAS/Safety' y referencias cruzadas a páginas funcionales." ;
    ex:tieneComponente ex:ServomotorMesa, ex:ServomotorIzquierda, ex:BorneAlimentacionEntradas, ex:BorneAlimentacionSalidas, ex:BorneAlimentacionSafety .

ex:ServomotorMesa a ex:ComponenteElectrico ;
    ex:textoExtracto "vínculos a servomotores (mesa e izquierda)" .

ex:ServomotorIzquierda a ex:ComponenteElectrico ;
    ex:textoExtracto "vínculos a servomotores (mesa e izquierda)" .

ex:BorneAlimentacionEntradas a ex:ComponenteElectrico ;
    ex:textoExtracto "Se resaltan bornes de 'ALIMENTACIÓN ENTRADAS/SALIDAS/Safety'" .

ex:BorneAlimentacionSalidas a ex:ComponenteElectrico ;
    ex:textoExtracto "Se resaltan bornes de 'ALIMENTACIÓN ENTRADAS/SALIDAS/Safety'" .

ex:BorneAlimentacionSafety a ex:ComponenteElectrico ;
    ex:textoExtracto "Se resaltan bornes de 'ALIMENTACIÓN ENTRADAS/SALIDAS/Safety'" .

ex:XT1_4_4 a ex:InterfazUsuario ;
    ex:textoExtracto "Asignaciones a I/O de máquina (tomas, iluminación, climatización), alimentaciones de panel y señales SAFE (puertas/escotilla). El diagrama ordena por grupos funcionales y muestra numeración correlativa (1104, 1117, 1204, etc.) para localizar físicamente cada borne." ;
    ex:tieneComponente ex:Toma, ex:Iluminacion, ex:Climatizacion, ex:BorneSAFE ;
    ex:identificador "1104", "1117", "1204" .

ex:Toma a ex:ComponenteElectrico ;
    ex:textoExtracto "Asignaciones a I/O de máquina (tomas, iluminación, climatización)" .

ex:Iluminacion a ex:ComponenteElectrico ;
    ex:textoExtracto "Asignaciones a I/O de máquina (tomas, iluminación, climatización)" .

ex:Climatizacion a ex:ComponenteElectrico ;
    ex:textoExtracto "Asignaciones a I/O de máquina (tomas, iluminación, climatización)" .

ex:BorneSAFE a ex:ComponenteElectrico ;
    ex:textoExtracto "señales SAFE (puertas/escotilla)" .