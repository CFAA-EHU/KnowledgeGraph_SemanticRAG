@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SetupHelp_Vxx_xx ex:textoExtracto """SetupHelp_Vxx.xx.exe (donde Vxx_xx es el nombre de la versión), disponible en la zona de descargas del sitio web corporativo de Fagor Automation.""" ;
    a ex:Herramienta ;
    ex:identificador "SetupHelp_Vxx.xx.exe" ;
    rdfs:label "SetupHelp_Vxx.xx.exe" .

ex:FagorAutomationWebsite ex:textoExtracto """disponible en la zona de descargas del sitio web corporativo de Fagor Automation. - http://www.fagorautomation.com/en/downloads/""" ;
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:identificador "http://www.fagorautomation.com/en/downloads/" .

ex:CNCHelpLanguageChanger ex:textoExtracto """Archivo: CNC Help Language Changer. Tipo de fichero: Software.""" ;
    a ex:Herramienta ;
    rdfs:label "CNC Help Language Changer" .

ex:CNC ex:textoExtracto """Fagor entrega el CNC con los archivos de ayuda instalados en inglés.""" ;
    a ex:Maquina ;
    rdfs:label "CNC" .

ex:CNC_Help_Files ex:textoExtracto """Los archivos de ayuda instalados por Fagor se encuentran en la carpeta ..\Fagor\Mmc\Help. El programa SetupHelp_Vxx.xx.exe instala la ayuda en la carpeta ..\Users\Help. Cuando el CNC debe mostrar la ayuda, primero la busca en ..\Users\Help, y si no la encuentra, en ..\Fagor\Mmc\Help.""" ;
    a ex:Software ;
    rdfs:label "CNC Help Files" .