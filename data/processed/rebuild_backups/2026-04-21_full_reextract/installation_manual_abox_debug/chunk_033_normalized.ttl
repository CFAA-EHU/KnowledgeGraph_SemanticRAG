@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SistemaSoftwareCNC8070 a ex:Sistema ;
    ex:textoExtracto "Los ficheros necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\CNC8070, y sus correspondientes subcarpetas." ;
    rdfs:label "Sistema de software CNC8070" .

ex:CarpetaCNC8070 a ex:Esquema ;
    ex:textoExtracto "carpeta C:\CNC8070" ;
    rdfs:label "Carpeta C:\\CNC8070" .