@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:REFI ex:Parametro ;
    rdfs:label "REFI" ;
    ex:textoExtracto "El parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." ;
    ex:valor "REFI" .

ex:NPULSES ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" ;
    ex:valor "NPULSES" .

ex:NPULSES2 ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:textoExtracto "los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" ;
    ex:valor "NPULSES2" .

ex:CNC ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC hace una búsqueda de referencia del cabezal" ;
    ex:textoExtracto "el CNC realizará una nueva búsqueda de referencia del cabezal" .

ex:cabezal ex:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "búsqueda de referencia del cabezal" ;
    ex:textoExtracto "el cabezal está referenciado" ;
    ex:textoExtracto "el cabezal supera el límite de contaje" .

ex:M19 ex:ModoOperacion ;
    rdfs:label "M19" ;
    ex:textoExtracto "las paradas orientadas del cabezal en M19" .

ex:G74 ex:TareaMantenimiento ;
    rdfs:label "G74" ;
    ex:textoExtracto "programa una nueva búsqueda de referencia con la función G74" ;
    ex:textoExtracto "programa una búsqueda de cero de varios ejes analógicos en paralelo, es decir, con el mismo índice (por ejemplo \"G74 X1 Y1 Z1\")" .

ex:anilloSercos ex:ComponenteElectrico ;
    rdfs:label "anillo de Sercos" ;
    ex:textoExtracto "después de caer el anillo de Sercos" .

ex:encoder ex:ComponenteElectrico ;
    rdfs:label "encoder" ;
    ex:textoExtracto "con cambio de encoder" .

ex:sistemaTandem ex:Sistema ;
    rdfs:label "sistema tándem" ;
    ex:textoExtracto "En un sistema tándem, sólo se referencia el eje maestro" .

ex:ejeMaestro ex:ComponenteMecanico ;
    rdfs:label "eje maestro" ;
    ex:textoExtracto "sólo se referencia el eje maestro" .

ex:ejeEsclavo ex:ComponenteMecanico ;
    rdfs:label "eje esclavo" ;
    ex:textoExtracto "la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro" .

ex:REFFEED1 ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "cada uno a su avance REFFEED1" .

ex:REFFEED2 ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "al avance REFFEED2" .

ex:micro ex:Sensor ;
    rdfs:label "micro" ;
    ex:textoExtracto "hasta encontrar cada uno su micro" ;
    ex:textoExtracto "llegar a sus micros" .

ex:ejeAnalogicoX ex:ComponenteMecanico ;
    rdfs:label "eje analógico X" ;
    ex:textoExtracto "G74 X1 Y1 Z1" .

ex:ejeAnalogicoY ex:ComponenteMecanico ;
    rdfs:label "eje analógico Y" ;
    ex:textoExtracto "G74 X1 Y1 Z1" .

ex:ejeAnalogicoZ ex:ComponenteMecanico ;
    rdfs:label "eje analógico Z" ;
    ex:textoExtracto "G74 X1 Y1 Z1" .

ex:I0 ex:Parametro ;
    rdfs:label "I0" ;
    ex:textoExtracto "buscará su I0 al avance REFFEED2" .