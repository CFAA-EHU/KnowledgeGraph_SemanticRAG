@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sub_Probe_Tool_Begin ex:textoExtracto "Nombre y ubicación de la subrutina. El nombre de las subrutinas es Sub_Probe_Tool_Begin.fst y Sub_Probe_Tool_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\Mtb\Sub. Todos los canales utilizan las mismas subrutinas. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." ;
    a ex:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" .

ex:Sub_Probe_Tool_End ex:textoExtracto "Nombre y ubicación de la subrutina. El nombre de las subrutinas es Sub_Probe_Tool_Begin.fst y Sub_Probe_Tool_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\Mtb\Sub. Todos los canales utilizan las mismas subrutinas. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." ;
    a ex:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Tool_End.fst" .