@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPROGNAME ex:textoExtracto """Nombre de subrutina asociada a la función M.""" ;
    rdfs:label "MPROGNAME" ;
    a ex:Parametro .

ex:FUNM ex:textoExtracto """Parámetro máquina; tabla de funciones "M". Nombre y ubicación de la subrutina.""" ;
    rdfs:label "FUNM" ;
    a ex:Parametro .

ex:TablaFuncionesM a ex:Tabla ;
    ex:textoExtracto """tabla de funciones "M".""" ;
    rdfs:label "tabla de funciones M" ;
    a ex:Tabla .

ex:SubrutinaM ex:textoExtracto """Estas subrutinas deben estar definidas en la tabla de funciones "M", en el campo MPROGNAME, y estarán guardadas en la carpeta ..\Mtb\Sub.""" ;
    rdfs:label "subrutina M" ;
    a ex:TareaMantenimiento .

ex:MPROGNAME ex:tieneComponente ex:SubrutinaM .

ex:TablaFuncionesM a ex:Tabla ;
    ex:compuestoPor ex:MPROGNAME .