@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:KEYDIS1 a ex:KEYDIS3 a ex:Parametro ;
    ex:identificador "KEYDIS1 a KEYDIS3" ;
    ex:textoExtracto "Estos registros inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente." .

ex:KEYDIS1_1 a ex:KEYDIS3_8 a ex:Parametro ;
    ex:identificador "KEYDIS1_1 a KEYDIS3_8" ;
    ex:textoExtracto "Estos registros inhiben (bit=1) las teclas y los conmutadores en cada panel de mando." .

ex:KEYLED1 a ex:KEYLED2 a ex:Parametro ;
    ex:identificador "KEYLED1 / KEYLED2" ;
    ex:textoExtracto "Estos registros controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ex:KEYLED1_1 a ex:KEYLED2_8 a ex:Parametro ;
    ex:identificador "KEYLED1_1 / KEYLED2_1 ... KEYLED1_8 / KEYLED2_8" ;
    ex:textoExtracto "Estos registros controlan los led (lámparas) de las teclas de cada panel de mando." .