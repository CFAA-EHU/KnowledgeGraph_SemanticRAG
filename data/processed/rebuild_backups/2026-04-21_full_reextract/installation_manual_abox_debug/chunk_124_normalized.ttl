@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MNEMONIC a rdfs:Class ;
    rdfs:label "MNEMONIC" ;
    ex:textoExtracto "MNEMONIC | Mnemónico del bloque lógico." .

ex:NODE a rdfs:Class ;
    rdfs:label "NODE" ;
    ex:textoExtracto "NODE | Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os." .

ex:BLOCK a rdfs:Class ;
    rdfs:label "BLOCK" ;
    ex:textoExtracto "BLOCK | Número de bloque lógico." .

ex:ADDRESS a rdfs:Class ;
    rdfs:label "ADDRESS" ;
    ex:textoExtracto "ADDRESS | Dirección base del bloque lógico." .

ex:NDI a rdfs:Class ;
    rdfs:label "NDI" ;
    ex:textoExtracto "NDI | Número de entradas digitales del módulo." .