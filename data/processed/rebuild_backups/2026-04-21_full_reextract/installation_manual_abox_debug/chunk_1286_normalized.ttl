@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SensorGapControl ex:textoExtracto "Esta distancia la calcula un sensor conectado al CNC" ;
    a ex:Sensor ;
    ex:tieneComponente ex:CNC_Laser ;
    ex:monitoreaParametro ex:GapDistancia .

ex:GapDistancia ex:textoExtracto "distancia fija entre la boquilla del láser y la superficie de la chapa" ;
    a ex:Parametro ;
    ex:valor "distancia programada" ;
    ex:unidad "Milímetros o pulgadas" .

ex:CNC_Laser ex:textoExtracto "un sensor conectado al CNC" ;
    a ex:Sistema ;
    ex:identificador "#GAPCTRL" ;
    ex:identificador "CNC" .

ex:OpcionSoftwareGAPControl ex:textoExtracto "disponer de la opción de software \"GAP CONTROL\"" ;
    a ex:Parametro ;
    ex:identificador "GAP CONTROL" .

ex:ComandoCNCex ex:textoExtracto "ejecutando con el comando CNCEX el bloque de CNC correspondiente" ;
    a ex:Parametro ;
    ex:identificador "CNCEX" .

ex:SentenciaGAPCTRL_ON ex:textoExtracto "#GAPCTRL ON permite activar el control del gap" ;
    a ex:Parametro ;
    ex:identificador "#GAPCTRL ON" .

ex:SentenciaGAPCTRL_OFF ex:textoExtracto "#GAPCTRL OFF desactiva el control del gap" ;
    a ex:Parametro ;
    ex:identificador "#GAPCTRL OFF" .