@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaControlNumeracionSalidasDigitales a ex:Sistema ;
    ex:textoExtracto "La configuración debe cumplir los siguientes requisitos. Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las salidas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus. • Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir. • Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar. • El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales. • El número de I/Os de un bloque lógico no puede ser cero, y debe ser un múltiplo de 8 • Los valores del índice base deben cumplir con la fórmula \"8n + 1" (es decir, 1, 9, 17, 25 ...). • Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024). El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ex:ParametroMaximoBloquesLogicos a ex:Parametro ;
    ex:identificador \"64" ;
    ex:textoExtracto "El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales." ;
    ex:valor "64"^^xsd:integer .

ex:ParametroRangoRecursosPLC a ex:Parametro ;
    ex:identificador "1...1024" ;
    ex:textoExtracto "Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024)." ;
    ex:valor "1024"^^xsd:integer .

ex:ParametroFormulaIndiceBase a ex:Parametro ;
    ex:identificador "8n + 1" ;
    ex:textoExtracto "Los valores del índice base deben cumplir con la fórmula \"8n + 1\" (es decir, 1, 9, 17, 25 ...)." ;
    ex:valor "8n + 1" .

ex:ParametroMultiplo8 a ex:Parametro ;
    ex:identificador "múltiplo de 8" ;
    ex:textoExtracto "El número de I/Os de un bloque lógico no puede ser cero, y debe ser un múltiplo de 8" ;
    ex:valor "8"^^xsd:integer .

ex:ParametroNumeracionSecuencial a ex:Parametro ;
    ex:identificador "numeración secuencial" ;
    ex:textoExtracto "Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las salidas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus." .

ex:ParametroNodosSinDefinir a ex:Parametro ;
    ex:identificador "nodos sin definir" ;
    ex:textoExtracto "Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir." .

ex:ParametroIOsSinNumerar a ex:Parametro ;
    ex:identificador "I/Os sin numerar" ;
    ex:textoExtracto "Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar." .

ex:ParametroNoSolapamiento a ex:Parametro ;
    ex:identificador "no solapamiento entre bloques" ;
    ex:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ex:ParametroNumeroNodo a ex:Parametro ;
    ex:identificador "NODE" ;
    ex:textoExtracto "NODE Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os. Valores posibles: De 1 a 125. Valor por defecto: 0. Variable asociada: (V.)MPG.DOMODNODE[nb] Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os. Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir." .

ex:ParametroNumeroBloque a ex:Parametro ;
    ex:identificador "BLOCK" ;
    ex:textoExtracto "BLOCK Número de bloque lógico. Valores posibles: De 1 a 64. Valor por defecto: 0. Variable asociada: (V.)MPG.DOMODBLOCK[nb] Número de bloque lógico. El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales." .

ex:ParametroDireccionBase a ex:Parametro ;
    ex:identificador "ADDRESS" ;
    ex:textoExtracto "ADDRESS Dirección base del bloque lógico. Valores posibles: De 1 a 1017. Valor por defecto: El primer valor válido." .