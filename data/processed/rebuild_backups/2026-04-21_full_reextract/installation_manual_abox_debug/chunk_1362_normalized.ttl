@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ExportarConfiguracion ex:textoExtracto """Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción "Export" y "Export Master Configuration ETG Standard". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC. NOTA: En modo Online, para exportar la configuración hay que desaclopar el máster del bus (opción "Detach master").""" .

ex:MaestroTopologia ex:textoExtracto """colocar el ratón sobre el máster de la topología (ventana izquierda)""" ;
    rdfs:label "máster de la topología" ;
    a ex:ComponenteElectrico .

ex:ExportMasterConfigurationETGStandard ex:textoExtracto """seleccionar la opción "Export" y "Export Master Configuration ETG Standard""" ;
    rdfs:label "Export Master Configuration ETG Standard" ;
    a ex:InterfazUsuario .

ex:ArchivoConfiguracion ex:textoExtracto """El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC.""" ;
    rdfs:label "archivo de configuración" ;
    a ex:Sistema .

ex:ModoOnline ex:textoExtracto """En modo Online, para exportar la configuración hay que desaclopar el máster del bus (opción "Detach master").""" ;
    rdfs:label "modo Online" ;
    a ex:ModoOperacion .

ex:DetachMaster ex:textoExtracto """opción "Detach master""" ;
    rdfs:label "Detach master" ;
    a ex:InterfazUsuario .