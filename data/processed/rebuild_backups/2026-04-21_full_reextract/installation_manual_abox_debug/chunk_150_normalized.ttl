@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GAPANAINID
    a ex:Parametro ;
    rdfs:label "GAPANAINID" ;
    ex:identificador "MPG.GAPANAINID" ;
    ex:textoExtracto "GAPANAINID Número de entrada analógica conectada al sensor. Valores posibles (1): Si GAPANAINTYPE=Remoto CAN, de 1 a 60. Valores posibles (2): Si GAPANAINTYPE=Regulador, de 101 a 132 o de 201 a 232. Valores posibles (3): Si GAPANAINTYPE=Captación, número de nodo del regulador. Valores posibles (4): Si GAPANAINTYPE=EtherCAT, de 1 a 1024. Valor por defecto: Ninguna (no hay control del gap). Variable asociada: (V.)MPG.GAPANAINID" ;
    ex:valor "Ninguna"^^xsd:string .

ex:Sensor_ControlGap
    a ex:Sensor ;
    rdfs:label "Sensor de control del gap" ;
    ex:textoExtracto "El sensor puede estar conectado a una salida analógica de los módulos remotos CAN o de un regulador Sercos. En ambos casos, este parámetro identifica la salida analógica que se está usando." ;
    ex:monitoreaParametro ex:Parametro_GAPANAINID .

ex:Sistema_ModulosRemotosCAN
    a ex:Sistema ;
    rdfs:label "Módulos remotos CAN" ;
    ex:textoExtracto "Entrada analógica de los módulos remotos CAN. En este caso, este parámetro indica el número de la salida analógica que se utiliza para la consigna." .

ex:Sistema_ReguladoresSercos
    a ex:Sistema ;
    rdfs:label "Reguladores Sercos" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos. En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar." ;
    ex:tieneComponente ex:Sensor_ControlGap .

ex:InterfazUsuario_ParametrizacionGap
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de parametrización del gap" ;
    ex:textoExtracto "El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." ;
    ex:controla ex:Parametro_GAPANAINID .