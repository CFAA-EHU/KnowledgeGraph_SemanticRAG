@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CompensacionHusillo a Parametro ;
    rdfs:label "Compensación de husillo" ;
    ex:identificador "(V.)[ch].MPA.REFNEED.xn" ;
    ex:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP. Este parámetro indica si es necesario referenciar el eje para empezar a aplicar la compensación." ;
    ex:valor "Sí / No" .

ex:Tabla_LSCRWCOMP a Tabla ;
    rdfs:label "LSCRWCOMP" ;
    ex:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP." ;
    ex:tieneComponente ex:Parametro_CompensacionHusillo .

ex:Parametro_CompensacionHusilloDatos a Parametro ;
    rdfs:label "Compensación de husillo en cada punto" ;
    ex:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando está definido" .