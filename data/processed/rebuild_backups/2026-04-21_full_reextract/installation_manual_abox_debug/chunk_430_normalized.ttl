@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MAXDIFREF a ex:Parametro ;
    ex:identificador "MAXDIFREF" ;
    ex:textoExtracto "que MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753." ;
    ex:valor "0" ;
    ex:valor "Entre ±99999.9999 mm" ;
    ex:valor "Entre ±3937.00787 inch" ;
    ex:valor "Entre ±99999.9999 grados" .

ex:error_3753 a ex:AvisoSeguridad ;
    ex:identificador "3753" ;
    ex:textoExtracto "mostrará el error 3753. Con este error, el usuario decide la validez de la cota." .

ex:REFPOIN a ex:Marca ;
    ex:identificador "REFPOIN" ;
    ex:textoExtracto "Si tras un error o una caída del anillo Sercos, la diferencia es mayor que MAXDIFREF, el CNC pone la marca de PLC REFPOIN(axis)=0. Si la diferencia es menor que MAXDIFREF, el CNC no pone la marca de PLC REFPOIN(axis)=1." .

ex:ABSFEEDBACK a ex:Parametro ;
    ex:identificador "ABSFEEDBACK" ;
    ex:textoExtracto "Captación incremental (parámetro ABSFEEDBACK=No)." ;
    ex:valor "No" .

ex:ABSOFF a ex:Parametro ;
    ex:identificador "ABSOFF" ;
    ex:textoExtracto "ABSOFF Offset respecto al I0 codificado. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "Entre ±99999.9999 mm" ;
    ex:valor "Entre ±3937.00787 inch" ;
    ex:valor "Entre ±99999.9999 grados" ;
    ex:valor "0" .

ex:I0TYPE a ex:Parametro ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE=Codificado" ;
    ex:valor "Codificado" .

ex:I0 a ex:Parametro ;
    ex:identificador "I0" ;
    ex:textoExtracto "Offset respecto al I0 codificado" .

ex:SistemaCNC a ex:Sistema ;
    ex:identificador "CNC" ;
    ex:textoExtracto "el CNC arrancará con la posición guardada por el CNC en el apagado" ;
    ex:textoExtracto "el CNC pone la marca de PLC REFPOIN(axis)=0" ;
    ex:textoExtracto "el CNC no pone la marca de PLC REFPOIN(axis)=1" ;
    ex:textoExtracto "el CNC siempre desactiva la marca REFPOIN(axis)" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE=Codificado" .

ex:ReguladorSercos a ex:ComponenteElectrico ;
    ex:identificador "Sercos" ;
    ex:textoExtracto "caída del anillo Sercos" ;
    ex:textoExtracto "regulador analógico, Sercos y simulado" .

ex:ModuloRCS_S a ex:ComponenteElectrico ;
    ex:identificador "RCS-S" ;
    ex:textoExtracto "cuando la captación absoluta está en un módulo RCS-S" .