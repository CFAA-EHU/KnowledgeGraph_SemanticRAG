@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:CLK32 a ex:Frecuencia ;
    ex:identificador "CLK32" ;
    ex:valor "32 ms" ;
    ex:textoExtracto "CLK32 | 32 ms" .

ex:CLK3200 a ex:Frecuencia ;
    ex:identificador "CLK3200" ;
    ex:valor "3.2 s" ;
    ex:textoExtracto "CLK3200 | 3.2 s" .

ex:CLK32000 a ex:Frecuencia ;
    ex:identificador "CLK32000" ;
    ex:valor "32 s" ;
    ex:textoExtracto "CLK32000 | 32 s" .

ex:CLK64 a ex:Frecuencia ;
    ex:identificador "CLK64" ;
    ex:valor "64 ms" ;
    ex:textoExtracto "CLK64 | 64 ms" .

ex:CLK6400 a ex:Frecuencia ;
    ex:identificador "CLK6400" ;
    ex:valor "6.4 s" ;
    ex:textoExtracto "CLK6400 | 6.4 s" .

ex:CLK64000 a ex:Frecuencia ;
    ex:identificador "CLK64000" ;
    ex:valor "64 s" ;
    ex:textoExtracto "CLK64000 | 64 s" .

ex:CLK128 a ex:Frecuencia ;
    ex:identificador "CLK128" ;
    ex:valor "128 ms" ;
