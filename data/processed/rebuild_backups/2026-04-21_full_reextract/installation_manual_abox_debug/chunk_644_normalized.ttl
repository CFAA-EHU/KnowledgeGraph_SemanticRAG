@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:plc_pdef_h a ex:Archivo ;
    ex:textoExtracto "El archivo se guarda en la carpeta ..\\MTB\\PLC\\Project. PDEF COOL I12 PDEF CONSTANT $FFFF3 DEF DATA_D1 372893 DEF DATA_D3 -437289 DEF /FAN I23" .

ex:directiva_PDEF a ex:Directiva ;
    ex:textoExtracto "PDEF COOL I12 PDEF CONSTANT $FFFF3 DEF DATA_D1 372893 DEF DATA_D3 -437289 DEF /FAN I23" .

ex:directiva_NOMONIT a ex:Directiva ;
    ex:textoExtracto "NOMONIT No monitorización. Es decir, que no se dispone de monitorización del programa. Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ex:variable_PLC_symbol a ex:Parametro ;
    ex:textoExtracto "V.PLC.symbol Acceso desde programa pieza o MDI. PLC.symbol Acceso desde una aplicación externa." ;
    rdfs:label "V.PLC.symbol / PLC.symbol" .

ex:simbolo_PDEF a ex:Parametro ;
    ex:textoExtracto "Los símbolos estarán formados por una secuencia de hasta 20 caracteres, formada por letras mayúsculas (A..Z) y dígitos (0..9). Los símbolos pueden comenzar con el carácter \"/" en cuyo caso el siguiente carácter debe ser una letra. El carácter "_" puede estar contenido en el nombre pero no puede ser el primer carácter del mismo." ;
    rdfs:label \"símbolo PDEF" .