@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sincronizacion ex:textoExtracto """| synctype | Tipo de sincronización. Se programa mediante los parámetros "POS" (sincronización en posición) o "VEL" (sincronización en velocidad). |""" .

ex:Parametro_POS ex:textoExtracto """"POS" (sincronización en posición)""" .
ex:Parametro_POS rdfs:label "POS"@es .

ex:Parametro_VEL ex:textoExtracto """"VEL" (sincronización en velocidad)""" .
ex:Parametro_VEL rdfs:label "VEL"@es .

ex:SistemaPLC ex:textoExtracto """Las unidades de programación serán las estándar del PLC.""" .

ex:SincronizacionVelocidad ex:textoExtracto """Sincronización en velocidad.""" .
ex:SincronizacionVelocidad rdfs:label "Sincronización en velocidad"@es .

ex:Variable_V_ASYNCVELOFF_xn ex:textoExtracto """Se define con la variable V.A.SYNCVELOFF.xn.""" .
ex:Variable_V_ASYNCVELOFF_xn rdfs:label "V.A.SYNCVELOFF.xn"@es .

ex:RatioTransmision ex:textoExtracto """Ratio de transmisión. Cociente (Nslave/Nmaster) entre el número de rotaciones del eje esclavo (Nslave) y el número de rotaciones del eje maestro (Nmaster).""" .
ex:RatioTransmision rdfs:label "Ratio de transmisión"@es .

ex:SincronizacionPosicion ex:textoExtracto """Sincronización en posición (en fase).""" .
ex:SincronizacionPosicion rdfs:label "Sincronización en posición"@es .

ex:Variable_V_ASYNCPOSOFF_xn ex:textoExtracto """Se define con la variable V.A.SYNCPOSOFF.xn.""" .
ex:Variable_V_ASYNCPOSOFF_xn rdfs:label "V.A.SYNCPOSOFF.xn"@es .

ex:Variable_GEARADJ ex:textoExtracto """El ajuste fino del ratio se define con la variable GEARADJ.""" .
ex:Variable_GEARADJ rdfs:label "GEARADJ"@es .

ex:SistemaSincronizacion ex:textoExtracto """FOLLOW ON (A1, Z, N3, D1, VEL)
TFOLLOW ON (A1, Z, VEL)
FOLLOW OFF (Z)""" .
ex:SistemaSincronizacion rdfs:label "Sistema de sincronización"@es .