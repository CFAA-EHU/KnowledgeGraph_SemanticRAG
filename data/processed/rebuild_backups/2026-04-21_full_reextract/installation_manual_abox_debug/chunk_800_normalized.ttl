@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC activa la marca RESETIN." .

ex:RESETIN a ex:Parametro ;
    rdfs:label "RESETIN" ;
    ex:textoExtracto "El PLC activa la marca RESETIN." .

ex:RESETOUT a ex:Parametro ;
    rdfs:label "RESETOUT" ;
    ex:textoExtracto "El canal activa la marca RESETOUT. Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW. Fin del reset. El canal desactiva la marca RESETOUT." .

ex:MINAENDW a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ex:PROGRAM_RESET a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET" ;
    ex:textoExtracto "El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET)." .

ex:LATCHM a ex:Parametro ;
    rdfs:label "LATCHM" ;
    ex:textoExtracto "LATCHM Esta marca permite seleccionar el tipo de funcionamiento de las teclas de JOG en el modo manual." .

ex:BLKSKIP1 a ex:Parametro ;
    rdfs:label "BLKSKIP1" ;
    ex:textoExtracto "BLKSKIP1 BLKSKIP9 Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos para BLKSKIP1; para el resto de las marcas es igual. BLKSKIP1C1 (también se puede programar como BLKSKIP1) BLKSKIP1C2 BLKSKIP1C3 BLKSKIP1C4 El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque \"/" se cumple, por lo que no se ejecutarán los bloques que tengan esta condición." .

ex:BLKSKIP1C1 a ex:Parametro ;
    rdfs:label \"BLKSKIP1C1" ;
    ex:textoExtracto "BLKSKIP1C1 (también se puede programar como BLKSKIP1)" .

ex:BLKSKIP1C2 a ex:Parametro ;
    rdfs:label "BLKSKIP1C2" ;
    ex:textoExtracto "BLKSKIP1C2" .

ex:BLKSKIP1C3 a ex:Parametro ;
    rdfs:label "BLKSKIP1C3" ;
    ex:textoExtracto "BLKSKIP1C3" .

ex:BLKSKIP1C4 a ex:Parametro ;
    rdfs:label "BLKSKIP1C4" ;
    ex:textoExtracto "BLKSKIP1C4" .

ex:M01STOP a ex:Parametro ;
    rdfs:label "M01STOP" ;
    ex:textoExtracto "M01STOP Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. M01STOPC1 (también se puede programar como M01STOP) M01STOPC2 M01STOPC3 M01STOPC4 El PLC pone esta marca a (=1) para indicar al canal del CNC que tenga en cuenta las paradas condicionales (M01)." .

ex:M01STOPC1 a ex:Parametro ;
    rdfs:label "M01STOPC1" ;
    ex:textoExtracto "M01STOPC1 (también se puede programar como M01STOP)" .

ex:M01STOPC2 a ex:Parametro ;
    rdfs:label "M01STOPC2" ;
    ex:textoExtracto "M01STOPC2" .

ex:M01STOPC3 a ex:Parametro ;
    rdfs:label "M01STOPC3" ;
    ex:textoExtracto "M01STOPC3" .

ex:AUXEND a ex:Parametro ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "AUXEND Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes." .