@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaValidacionCNC8070
    a               ex:Sistema ;
    rdfs:label      "Sistema de validación por código del CNC8070" ;
    ex:textoExtracto
        "del código de validación, el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB. [...] Si cambiamos el código de validación, el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc); a continuación, el CNC moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB." ;
    ex:identificador "CNC8070" .

ex:CarpetaMTB
    a               ex:InterfazUsuario ;
    rdfs:label      "Carpeta MTB (configuración activa)" ;
    ex:textoExtracto
        "el sistema moverá la carpeta correspondiente [...] y la renombrará como MTB. [...] Si el fabricante ha creado la carpeta MTB manualmente, por ejemplo copiándola de algún backup, el sistema no hará ningún cambio en el arranque ni al modificar el código de validación." ;
    ex:identificador "MTB" .

ex:CarpetaConfiguracion
    a               ex:InterfazUsuario ;
    rdfs:label      "Carpeta ..\\CONFIGURATION (almacén de configuraciones)" ;
    ex:textoExtracto
        "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 [...] Si cambiamos el código de validación, el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION" ;
    ex:identificador "..\\CONFIGURATION" .

ex:SistemaValidacionCNC8070
    ex:tieneComponente ex:CarpetaMTB , ex:CarpetaConfiguracion .