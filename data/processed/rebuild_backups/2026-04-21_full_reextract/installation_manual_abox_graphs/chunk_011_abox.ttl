@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CarpetaMTB
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta MTB"@es ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB. [...] la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es ;
    ex:identificador "MTB" .

ex:CarpetaMTB_M
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta MTB_M"@es ;
    ex:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es ;
    ex:identificador "MTB_M" .

ex:CarpetaMTB_T
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta MTB_T"@es ;
    ex:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es ;
    ex:identificador "MTB_T" .

ex:SistemaCNC8070
    a ex:Sistema ;
    rdfs:label "Sistema CNC8070"@es ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB"@es ;
    ex:tieneComponente ex:CarpetaMTB .

ex:CodigoValidacion
    a ex:Parametro ;
    rdfs:label "Código de validación"@es ;
    ex:textoExtracto "En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente"@es .

ex:ProgramaPLC
    a ex:Parametro ;
    rdfs:label "Programa PLC"@es ;
    ex:textoExtracto "por ejemplo, el programa PLC, los parámetros máquina, etc."@es .

ex:ParametrosMaquina
    a ex:Parametro ;
    rdfs:label "Parámetros máquina"@es ;
    ex:textoExtracto "por ejemplo, el programa PLC, los parámetros máquina, etc."@es .