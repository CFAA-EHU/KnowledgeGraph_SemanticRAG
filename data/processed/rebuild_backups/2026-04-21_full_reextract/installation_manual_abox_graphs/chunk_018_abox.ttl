@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SoporteUnicode_CNC
    a ex:Sistema ;
    rdfs:label "Soporte Unicode en editor CNC"@es ;
    ex:textoExtracto "El editor del CNC admite caracteres Unicode. Los programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.0."@es ;
    ex:identificador "V4.0" .

ex:VersionSoftware_V4.0
    a ex:Parametro ;
    rdfs:label "Versión mínima para soporte Unicode"@es ;
    ex:valor "V4.0" ;
    ex:textoExtracto "versión V4.0"@es ;
    ex:monitoreaParametro ex:SoporteUnicode_CNC .