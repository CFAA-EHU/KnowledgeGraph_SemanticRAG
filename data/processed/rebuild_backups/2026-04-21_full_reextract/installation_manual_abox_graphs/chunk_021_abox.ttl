@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MANRAPID
    a ex:Parametro ;
    rdfs:label "MANRAPID (marca PLC por canal)" ;
    ex:textoExtracto "La marca MANRAPID del PLC pasa de ser una marca general a ser una marca por canal. La marca MANRAPID que en versiones anteriores afectaba a todos los ejes del sistema, ahora sólo afectará a los ejes del primer canal." ;
    ex:identificador "MANRAPID" .

ex:MANRAPIDC1
    a ex:Parametro ;
    rdfs:label "MANRAPIDC1 (marca PLC para canal 1)" ;
    ex:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." ;
    ex:identificador "MANRAPIDC1" .

ex:MANRAPIDC4
    a ex:Parametro ;
    rdfs:label "MANRAPIDC4 (marca PLC para canal 4)" ;
    ex:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." ;
    ex:identificador "MANRAPIDC4" .

ex:PANELOFF
    a ex:Parametro ;
    rdfs:label "PANELOFF (deshabilitación panel de jog)" ;
    ex:textoExtracto "En versiones anteriores, la marca PANELOFF del PLC deshabilitaba tanto la parte de jog como la parte alfanumérica (módulo OP-PANEL-H/E). A partir de esta versión, la nueva marca QWERTYOFF deshabilita la parte alfanumérica y la marca PANELOFF sólo deshabilita el panel de jog." ;
    ex:identificador "PANELOFF" .

ex:QWERTYOFF
    a ex:Parametro ;
    rdfs:label "QWERTYOFF (deshabilitación teclado alfanumérico)" ;
    ex:textoExtracto "A partir de esta versión, la nueva marca QWERTYOFF deshabilita la parte alfanumérica y la marca PANELOFF sólo deshabilita el panel de jog." ;
    ex:identificador "QWERTYOFF" .

ex:FTIMELIM
    a ex:Parametro ;
    rdfs:label "FTIMELIM (parámetro máquina para mecanizado HSC)" ;
    ex:textoExtracto "Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC. En versiones previas el parámetro FTIMELIM se programaba en milisegundos. A partir de este versión, este parámetro se define en porcentaje." ;
    ex:identificador "FTIMELIM" ;
    ex:valor "porcentaje" .

ex:G00COMP
    a ex:Parametro ;
    rdfs:label "G00COMP (compensación de radio en G00)" ;
    ex:textoExtracto "En esta versión, los movimientos en G00 no aplican la compensación de radio. Ésto se corrige en versiones posteriores mediante el parámetro G00COMP." ;
    ex:identificador "G00COMP" .

ex:ModoAdministrador
    a ex:ModoOperacion ;
    rdfs:label "Modo administrador (para actualización permanente)" ;
    ex:textoExtracto "La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías." .

ex:ModoSetup
    a ex:ModoOperacion ;
    rdfs:label "Modo setup (para actualización temporal)" ;
    ex:textoExtracto "Si la instalación se hace en modo setup, el registro sólo tiene carácter temporal hasta que se apague el equipo." .

ex:OP_PANEL_H_E
    a ex:InterfazUsuario ;
    rdfs:label "Módulo OP-PANEL-H/E (panel de control)" ;
    ex:textoExtracto "En versiones anteriores, la marca PANELOFF del PLC deshabilitaba tanto la parte de jog como la parte alfanumérica (módulo OP-PANEL-H/E)." ;
    ex:identificador "OP-PANEL-H/E" .

ex:Software_V4.10
    a ex:Sistema ;
    rdfs:label "Versión de software V4.10" ;
    ex:textoExtracto "Versión V4.10. Actualizar la versión de software." ;
    ex:identificador "V4.10" .

ex:Software_V4.20
    a ex:Sistema ;
    rdfs:label "Versión de software V4.20" ;
    ex:textoExtracto "Versión V4.20. Actualizar la versión de software." ;
    ex:identificador "V4.20" .

ex:Software_V4.25
    a ex:Sistema ;
    rdfs:label "Versión de software V4.25" ;
    ex:textoExtracto "Versión V4.25. Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC." ;
    ex:identificador "V4.25" .

ex:Software_V5.31.01
    a ex:Sistema ;
    rdfs:label "Versión de software V5.31.01" ;
    ex:textoExtracto "Versión V5.31.01. Aplicar o no compensación de radio en G00." ;
    ex:identificador "V5.31.01" .

ex:Software_V5.40
    a ex:Sistema ;
    rdfs:label "Versión de software V5.40" ;
    ex:textoExtracto "Versión V5.40. Nueva opción de software 'CANopen de terceros'." ;
    ex:identificador "V5.40" .

ex:CANopenTerceros
    a ex:Sistema ;
    rdfs:label "Opción CANopen de terceros" ;
    ex:textoExtracto "Nueva opción de software 'CANopen de terceros'." .