@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G00COMP
    a ex:Parametro ;
    rdfs:label "G00COMP" ;
    ex:textoExtracto "los movimientos en G00 no aplican la compensación de radio. Ésto se corrige en versiones posteriores mediante el parámetro G00COMP." ;
    ex:identificador "G00COMP" .

ex:VersionSoftware_V5.40
    a ex:Sistema ;
    rdfs:label "Versión V5.40" ;
    ex:textoExtracto "Versión V5.40. Nueva opción de software 'CANopen de terceros'." ;
    ex:identificador "V5.40" ;
    ex:tieneComponente ex:Modulo_CANopenTerceros .

ex:Modulo_CANopenTerceros
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo CANopen de terceros" ;
    ex:textoExtracto "si una máquina estuviera usando algún módulo CANopen no Fagor" .