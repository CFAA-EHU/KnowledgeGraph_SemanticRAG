@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ActualizacionSoftware_V2
    a ex:Sistema ;
    rdfs:label "Actualización de software a VERSION_2"@es ;
    ex:textoExtracto "Incluir: <GeometryObject name=\"VERSION_2\"> </GeometryObject>"@es ;
    ex:identificador "VERSION_2" .

ex:Herramienta_SYS_Tool1
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta SYS-Tool1 (Husillo S1)"@es ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool1\"/> Por: <ToolVice name=\"SYS-Tool1\" spindle=\"S1\"/>"@es ;
    ex:identificador "SYS-Tool1" .

ex:Herramienta_SYS_Tool2
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta SYS-Tool2 (Husillo S2)"@es ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool2\"/> Por: <ToolVice name=\"SYS-Tool2\" spindle=\"S2\"/>"@es ;
    ex:identificador "SYS-Tool2" .

ex:Herramienta_SYS_Tool3
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta SYS-Tool3 (Husillo S3)"@es ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool3\"/> Por: <ToolVice name=\"SYS-Tool3\" spindle=\"S3\"/>"@es ;
    ex:identificador "SYS-Tool3" .

ex:Herramienta_SYS_Tool4
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta SYS-Tool4 (Husillo S4)"@es ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool4\"/> Por: <ToolVice name=\"SYS-Tool4\" spindle=\"S4\"/>"@es ;
    ex:identificador "SYS-Tool4" .

ex:Conexion_SYS_Tool1_C1
    a ex:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C1 (rotación: 0 1 0 -90)"@es ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C1\" rotation=\"0 1 0 -90\"/>"@es ;
    ex:compuestoPor ex:Herramienta_SYS_Tool1 .

ex:Conexion_SYS_Tool1_C2
    a ex:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C2 (rotación: 0 1 0 -90)"@es ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S2\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C2\" rotation=\"0 1 0 -90\"/>"@es ;
    ex:compuestoPor ex:Herramienta_SYS_Tool1 .

ex:Conexion_SYS_Tool1_C3
    a ex:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 → C3 (rotación: 0 1 0 -90)"@es ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S3\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C3\" rotation=\"0 1 0 -90\"/>"@es ;
    ex:compuestoPor ex:Herramienta_SYS_Tool1 .

ex:ActualizacionSoftware_V2
    ex:tieneComponente ex:Herramienta_SYS_Tool1 , ex:Herramienta_SYS_Tool2 , ex:Herramienta_SYS_Tool3 , ex:Herramienta_SYS_Tool4 ;
    ex:tieneComponente ex:Conexion_SYS_Tool1_C1 , ex:Conexion_SYS_Tool1_C2 , ex:Conexion_SYS_Tool1_C3 .