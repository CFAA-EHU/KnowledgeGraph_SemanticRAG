@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Carpeta_DATA
    a ex:Sistema ;
    rdfs:label "Carpeta DATA" ;
    ex:textoExtracto "Esta carpeta contiene los siguientes archivos o subcarpetas. • Las bases de datos de los parámetros máquina, tablas, etc y las copias de seguridad (en ASCII) de esas tablas. • Los archivos relacionados con los datos de los ciclos del editor (archivos dat). • Los datos que debe mantener el CNC tras el apagado (cotas, orígenes, etc)." ;
    ex:identificador "DATA" .

ex:Carpeta_DRIVE
    a ex:Sistema ;
    rdfs:label "Carpeta DRIVE" ;
    ex:textoExtracto "Esta carpeta contiene la información referente al modo DDSSETUP." ;
    ex:identificador "DRIVE" .

ex:Carpeta_GRAFDATA
    a ex:Sistema ;
    rdfs:label "Carpeta GRAFDATA" ;
    ex:textoExtracto "Esta carpeta contiene la información referente a los gráficos." ;
    ex:identificador "GRAFDATA" .

ex:Carpeta_KINEMATIC
    a ex:Sistema ;
    rdfs:label "Carpeta KINEMATIC" ;
    ex:textoExtracto "Esta carpeta contiene la información referente a las cinemáticas OEM." ;
    ex:identificador "KINEMATIC" .

ex:Carpeta_MMC
    a ex:Sistema ;
    rdfs:label "Carpeta MMC" ;
    ex:textoExtracto "Esta carpeta contiene la personalización del CNC realizada por el fabricante. • La subcarpeta ..\\CONFIG contiene los archivos de configuración (archivos ini) y los archivos modificados mediante la herramienta de personalización de pantallas (Fguim). • La subcarpeta ..\\IMAGES contiene las imágenes, iconos, videos, etc que el fabricante utiliza para personalizar el CNC." ;
    ex:identificador "MMC" .

ex:Carpeta_PLC
    a ex:Sistema ;
    rdfs:label "Carpeta PLC" ;
    ex:textoExtracto "Esta carpeta contiene la información referente al PLC." ;
    ex:identificador "PLC" .

ex:Archivo_cncError_txt
    a ex:InterfazUsuario ;
    rdfs:label "cncError.txt" ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\LANG está el archivo cncError.txt que contiene los mensajes y errores del fabricante en los distintos idiomas." ;
    ex:identificador "cncError.txt" .

ex:Archivo_scripts_MMC
    a ex:InterfazUsuario ;
    rdfs:label "Archivo de textos de scripts MMC" ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\LANG está el archivo que contiene los textos utilizados por los scripts." .

ex:Archivo_mensajes_PLC
    a ex:InterfazUsuario ;
    rdfs:label "Archivo de mensajes y errores del PLC" ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas." .

ex:Modo_DDSSETUP
    a ex:ModoOperacion ;
    rdfs:label "Modo DDSSETUP" ;
    ex:textoExtracto "Esta carpeta contiene la información referente al modo DDSSETUP." ;
    ex:documentadoEn ex:Carpeta_DRIVE .