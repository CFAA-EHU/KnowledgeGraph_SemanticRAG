@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:carpeta_MTB
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)" ;
    ex:textoExtracto "Cuando cambia el lenguaje del CNC, éste reemplaza este archivo por el del lenguaje correspondiente." ;
    ex:tieneComponente ex:subcarpeta_PLC .

ex:subcarpeta_PLC
    a ex:InterfazUsuario ;
    rdfs:label "Subcarpeta PLC" ;
    ex:textoExtracto "Esta carpeta contiene la información referente al PLC." ;
    ex:tieneComponente ex:subcarpeta_LANG, ex:subcarpeta_PROJECT, ex:subcarpeta_WATCH .

ex:subcarpeta_LANG
    a ex:InterfazUsuario ;
    rdfs:label "Subcarpeta LANG (PLC)" ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas." .

ex:subcarpeta_PROJECT
    a ex:InterfazUsuario ;
    rdfs:label "Subcarpeta PROJECT (PLC)" ;
    ex:textoExtracto "La subcarpeta ..\\PROJECT contiene los archivos que forman el proyecto PLC y el fichero objeto." .

ex:subcarpeta_WATCH
    a ex:InterfazUsuario ;
    rdfs:label "Subcarpeta WATCH (PLC)" ;
    ex:textoExtracto "La subcarpeta ..\\WATCH contiene los datos guardados desde los" .