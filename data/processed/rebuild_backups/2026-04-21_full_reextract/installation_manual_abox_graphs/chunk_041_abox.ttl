@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Capitulo_ParametrosMaquina
    a ex:Capitulo ;
    rdfs:label "Capítulo de Parámetros Máquina"@es ;
    ex:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC."@es ;
    ex:identificador "2.2" ;
    ex:documentadoEn ex:Manual_CNC .

ex:ParametrosMaquina_CNC
    a ex:Parametro ;
    rdfs:label "Parámetros máquina del CNC"@es ;
    ex:textoExtracto "Los parámetros máquina del CNC están agrupados [...] datos específicos de la máquina. Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc."@es ;
    ex:documentadoEn ex:Capitulo_ParametrosMaquina .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "El CNC muestra los parámetros apropiados en función del modelo y las opciones de software activas."@es ;
    ex:monitoreaParametro ex:ParametrosMaquina_CNC ;
    ex:controla ex:MaquinaHerramienta .

ex:MaquinaHerramienta
    a ex:Maquina ;
    rdfs:label "Máquina-herramienta"@es ;
    ex:textoExtracto "Para que la máquina-herramienta pueda ejecutar correctamente las instrucciones programadas, así como interpretar los elementos que tiene interconectados, el CNC debe conocer los datos específicos de la máquina."@es .