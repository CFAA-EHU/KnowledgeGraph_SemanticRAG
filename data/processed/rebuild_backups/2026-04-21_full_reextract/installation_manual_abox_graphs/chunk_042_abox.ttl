@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametrosGeneralesMaquina
    a ex:Parametro ;
    rdfs:label "Parámetros generales"@es ;
    ex:textoExtracto "Estos parámetros definen el nombre de los ejes y cabezales, condiciones tras el encendido, rutinas asociadas a determinadas funciones, etc. Algunos de estos parámetros hay que definirlos en primer lugar porque configuran las tablas de parámetros de ejes. Por ejemplo, el número y denominación de los ejes y cabezales, etc."@es .

ex:ParametrosEjesCabezales
    a ex:Parametro ;
    rdfs:label "Parámetros de ejes y cabezales"@es ;
    ex:textoExtracto "Estos parámetros indican las propiedades de los ejes y cabezales, límites de recorrido, condiciones de desplazamiento, volantes asociados, trabajo con palpador, compensaciones, etc. Cada eje o cabezal puede disponer de hasta 4 sets de trabajo. En cada uno de ellos hay que definir el ajuste de los avances y ganancias, búsquedas de referencia, aceleraciones, etc."@es .

ex:ParametrosModoManual
    a ex:Parametro ;
    rdfs:label "Parámetros del modo manual"@es ;
    ex:textoExtracto "Estos parámetros permiten personalizar los volantes y las teclas de JOG."@es .

ex:ParametrosTablaFuncionesM
    a ex:Parametro ;
    rdfs:label "Parámetros de la tabla de funciones M"@es ;
    ex:textoExtracto "Estos parámetros permiten definir nuevas funciones M y personalizar el tipo de sincronización y la rutina asociada a cada una de las funciones M del sistema."@es .

ex:ParametrosTablaCinematicas
    a ex:Parametro ;
    rdfs:label "Parámetros de la tabla de cinemáticas"@es ;
    ex:textoExtracto "Estos parámetros indican el tipo y características de cada una de las cinemáticas."@es .

ex:ParametrosAlmacenes
    a ex:Parametro ;
    rdfs:label "Parámetros de los almacenes"@es ;
    ex:textoExtracto "Estos parámetros indican el número de almacenes, tipo, número de posiciones, etc."@es .

ex:ParametrosHMI
    a ex:Parametro ;
    rdfs:label "Parámetros HMI"@es ;
    ex:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC."@es .

ex:ParametrosOEM
    a ex:Parametro ;
    rdfs:label "Parámetros OEM"@es ;
    ex:textoExtracto "Estos parámetros permiten configurar la lectura/escritura de variables del regulador, editar levas, definir un grupo de parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina, etc."@es .

ex:TablaParametrosMaquina a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros máquina"@es ;
    ex:textoExtracto "Parámetros máquina. | Significado."@es ;
    ex:documentadoEn ex:Pagina49_50 ;
    ex:tieneComponente ex:ParametrosGeneralesMaquina ,
                      ex:ParametrosEjesCabezales ,
                      ex:ParametrosModoManual ,
                      ex:ParametrosTablaFuncionesM ,
                      ex:ParametrosTablaCinematicas ,
                      ex:ParametrosAlmacenes ,
                      ex:ParametrosHMI ,
                      ex:ParametrosOEM .