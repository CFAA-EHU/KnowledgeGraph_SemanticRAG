@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_IconosParametrosMaquina a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de iconos de parámetros máquina"@es ;
    ex:textoExtracto """
| Icono. | Significado. |
| --- | --- |
|  | El parámetro posee una lista de opciones. |
|  | Accede a una tabla de datos. |
|  | Accede a un grupo de parámetros. |
|  | El parámetro hace referencia a un archivo.
"""@es .

ex:ParametrosSimuladorCNC
    a ex:Parametro ;
    rdfs:label "Parámetros por defecto en modo simulador"@es ;
    ex:textoExtracto """
Valor por defecto de los parámetros en un simulador. Cuando el CNC se instala como simulador en un PC, el valor por defecto de algunos parámetros máquina puede ser diferente a los aquí mencionados. Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk. También se modifican los datos del palpador para poder disponer, en el modo manual, de los ciclos de centrado de pieza y calibración de herramienta.
"""@es ;
    ex:documentadoEn ex:Tabla_IconosParametrosMaquina .

ex:ParametrosAvancesEjes
    a ex:Parametro ;
    rdfs:label "Avances máximos de ejes (simulador)"@es ;
    ex:textoExtracto "avances máximos de ejes"@es ;
    ex:documentadoEn ex:Tabla_IconosParametrosMaquina .

ex:ParametrosAceleraciones
    a ex:Parametro ;
    rdfs:label "Aceleraciones (simulador)"@es ;
    ex:textoExtracto "aceleraciones"@es ;
    ex:documentadoEn ex:Tabla_IconosParametrosMaquina .

ex:ParametrosJerk
    a ex:Parametro ;
    rdfs:label "Jerk (simulador)"@es ;
    ex:textoExtracto "jerk"@es ;
    ex:documentadoEn ex:Tabla_IconosParametrosMaquina .

ex:ParametrosPalpador
    a ex:Parametro ;
    rdfs:label "Datos del palpador (simulador)"@es ;
    ex:textoExtracto """
datos del palpador para poder disponer, en el modo manual, de los ciclos de centrado de pieza y calibración de herramienta
"""@es ;
    ex:documentadoEn ex:Tabla_IconosParametrosMaquina .