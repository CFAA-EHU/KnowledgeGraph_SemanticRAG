@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosCNC_47 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de homogeneización CNC-regulador (pág. 51-52)"@es ;
    ex:textoExtracto """
| FBACKDIFF | PP5 | Posición. | Externa. |
| FBMIXTIME | PP16 | Posición. | Externa. |
| AXISCH/LOOPCH | PP115 (bit 3) | Posición. | Externa. | B3=0; Signo del contaje AXISCH==LOOPCH. B3=1; Signo del contaje AXISCH<>LOOPCH.
"""@es .

ex:Parametro_FBACKDIFF
    a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:identificador "PP5" ;
    ex:valor "Externa" ;
    ex:textoExtracto "FBACKDIFF | PP5 | Posición. | Externa."@es ;
    ex:documentadoEn ex:TablaParametrosCNC_47 .

ex:Parametro_FBMIXTIME
    a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:identificador "PP16" ;
    ex:valor "Externa" ;
    ex:textoExtracto "FBMIXTIME | PP16 | Posición. | Externa."@es ;
    ex:documentadoEn ex:TablaParametrosCNC_47 .

ex:Parametro_AXISCH_LOOPCH
    a ex:Parametro ;
    rdfs:label "AXISCH/LOOPCH" ;
    ex:identificador "PP115 (bit 3)" ;
    ex:valor "B3=0; Signo del contaje AXISCH==LOOPCH. B3=1; Signo del contaje AXISCH<>LOOPCH."@es ;
    ex:textoExtracto "AXISCH/LOOPCH | PP115 (bit 3) | Posición. | Externa. | B3=0; Signo del contaje AXISCH==LOOPCH. B3=1; Signo del contaje AXISCH<>LOOPCH."@es ;
    ex:documentadoEn ex:TablaParametrosCNC_47 .