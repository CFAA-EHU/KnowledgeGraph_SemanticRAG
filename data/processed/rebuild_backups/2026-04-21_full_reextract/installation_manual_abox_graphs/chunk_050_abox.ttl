@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXFLWE
    a ex:Parametro ;
    rdfs:label "MAXFLWE" ;
    ex:identificador "PP159" ;
    ex:textoExtracto "MAXFLWE | PP159 |  |  | Sólo si está activa la monitorización del error de seguimiento." ;
    ex:monitoreaParametro ex:Sistema_MonitorizacionErrorSeguimiento .

ex:Sistema_MonitorizacionErrorSeguimiento
    a ex:Sistema ;
    ex:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

ex:Parametro_CalculoModuloCota
    a ex:Parametro ;
    rdfs:label "Cálculo del módulo de la cota" ;
    ex:identificador "PP76 (bit 7)" ;
    ex:textoExtracto "B7=0; En los ejes rotativos o cabezales trabajando en Sercos velocidad, el cálculo del módulo de la cota lo realiza el CNC." ;
    ex:valor "B7=0" .

ex:Sistema_CNC
    a ex:Sistema ;
    ex:textoExtracto "el cálculo del módulo de la cota lo realiza el CNC." ;
    ex:controla ex:Parametro_CalculoModuloCota .