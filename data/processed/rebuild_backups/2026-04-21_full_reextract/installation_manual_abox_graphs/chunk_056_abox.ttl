@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NCHANNEL
    a ex:Parametro ;
    rdfs:label "NCHANNEL" ;
    ex:textoExtracto "NCHANNEL Número de canales del CNC. Valores posibles: De 1 a 4. Valor por defecto: 1." ;
    ex:valor "1-4" ;
    ex:identificador "MPG.NCHANNEL" ;
    ex:monitoreaParametro ex:SistemaCNC_Multicanal .

ex:SistemaCNC_Multicanal
    a ex:Sistema ;
    rdfs:label "Sistema CNC multicanal" ;
    ex:textoExtracto "El CNC puede disponer de un único canal de ejecución (sistema monocanal) o de varios (sistema multicanal). Cada canal constituye un entorno de trabajo diferente que puede actuar sobre una parte o sobre la totalidad del sistema CNC." ;
    ex:tieneComponente ex:CanalCNC_Generico .

ex:CanalCNC_Generico
    a ex:Componente ;
    rdfs:label "Canal CNC" ;
    ex:textoExtracto "Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales. También es posible configurar un canal sin asignarle ejes ni cabezales inicialmente." ;
    ex:controla ex:EjeCNC_Generico ;
    ex:controla ex:CabezalCNC_Generico .

ex:EjeCNC_Generico
    a ex:ComponenteMecanico ;
    rdfs:label "Eje CNC" ;
    ex:textoExtracto "Los ejes y cabezales de un canal. Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales." .

ex:CabezalCNC_Generico
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal CNC" ;
    ex:textoExtracto "Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales." .