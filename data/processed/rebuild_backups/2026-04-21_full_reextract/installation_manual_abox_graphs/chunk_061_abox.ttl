@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosTandem_61 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros para configuración de sistema tándem"@es ;
    ex:textoExtracto "Este parámetro muestra la tabla de parámetros para definir las parejas tándem del sistema. Cada pareja tándem dispone de los siguientes parámetros máquina para su configuración."@es ;
    ex:documentadoEn ex:Pagina_57_60 .

ex:Parametro_MASTERAXIS_61
    a ex:Parametro ;
    rdfs:label "MASTERAXIS" ;
    ex:identificador "MASTERAXIS" ;
    ex:textoExtracto "Pareja tándem. Eje/cabezal maestro o principal."@es ;
    ex:documentadoEn ex:Tabla_ParametrosTandem_61 .

ex:Parametro_SLAVEAXIS_61
    a ex:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ex:identificador "SLAVEAXIS" ;
    ex:textoExtracto "Pareja tándem. Eje/cabezal esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosTandem_61 .

ex:Parametro_TORQDIST_61
    a ex:Parametro ;
    rdfs:label "TORQDIST" ;
    ex:identificador "TORQDIST" ;
    ex:textoExtracto "Pareja tándem. Distribución del par."@es ;
    ex:documentadoEn ex:Tabla_ParametrosTandem_61 .

ex:SistemaTandem_61
    a ex:Sistema ;
    rdfs:label "Sistema tándem"@es ;
    ex:textoExtracto "Configuración de un sistema tándem"@es ;
    ex:detalladoEnEsquema ex:Tabla_ParametrosTandem_61 .