@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Kp_Tandem
    a ex:Parametro ;
    rdfs:label "Ganancia proporcional (Kp) para el tándem"@es ;
    ex:textoExtracto "Ganancia proporcional (Kp) para el tándem. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional)."@es ;
    ex:identificador "MPG.TPROGAIN[nb]" ;
    ex:valor "0"^^xsd:float .

ex:Tabla_Tandem a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla TANDEM"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM."@es ;
    ex:documentadoEn ex:Manual_Broaching .

ex:Sistema_Tandem
    a ex:Sistema ;
    rdfs:label "Sistema tándem"@es ;
    ex:textoExtracto "Configuración de un sistema tándem."@es ;
    ex:tieneComponente ex:Parametro_Kp_Tandem ;
    ex:detalladoEnEsquema ex:Tabla_Tandem .

ex:Parametro_S_max
    a ex:Parametro ;
    rdfs:label "Velocidad máxima (S.max)"@es ;
    ex:textoExtracto "S.max Velocidad máxima."@es .

ex:Parametro_T_nom
    a ex:Parametro ;
    rdfs:label "Par nominal (T.nom)"@es ;
    ex:textoExtracto "T.nom Par nominal."@es .

ex:Parametro_T_err
    a ex:Parametro ;
    rdfs:label "Error de par entre motores (T.err)"@es ;
    ex:textoExtracto "T.err Error de par entre motores. T.err = (–T.mst+T.slv+PRELOAD)"@es .