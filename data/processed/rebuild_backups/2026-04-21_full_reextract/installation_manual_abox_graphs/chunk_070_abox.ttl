@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DECINPUT
    a ex:Parametro ;
    rdfs:label "Micro de referencia (DECINPUT)" ;
    ex:textoExtracto "micro de referencia (parámetro DECINPUT)" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia (REFFEED1)" ;
    ex:textoExtracto "velocidad rápida [...] de búsqueda de referencia máquina (parámetros REFFEED1)" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "Velocidad lenta de búsqueda de referencia (REFFEED2)" ;
    ex:textoExtracto "velocidad [...] lenta de búsqueda de referencia máquina (parámetros [...] REFFEED2)" .

ex:Parametro_GANTRY
    a ex:Parametro ;
    rdfs:label "Configuración de ejes gantry (GANTRY)" ;
    ex:textoExtracto "GANTRY n Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema" ;
    ex:identificador "GANTRY" .

ex:Tabla_ParametrosGantry a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de ejes gantry" ;
    ex:textoExtracto "muestra la tabla de parámetros para definir los ejes gantry del sistema" ;
    ex:detalladoEnEsquema ex:Parametro_GANTRY .