@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjesGantry_71
    a               ex:Parametro ;
    rdfs:label      "Configuración de los ejes gantry"@es ;
    ex:textoExtracto
                    "Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema."@es ;
    ex:identificador "GANTRY" .

ex:TablaParametrosGantry_71 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros de ejes gantry"@es ;
    ex:textoExtracto
                    "muestra la tabla de parámetros para definir los ejes gantry del sistema. Cada uno de los ejes gantry dispone de los siguientes parámetros máquina para su configuración."@es ;
    ex:documentadoEn ex:ConfiguracionEjesGantry_71 .