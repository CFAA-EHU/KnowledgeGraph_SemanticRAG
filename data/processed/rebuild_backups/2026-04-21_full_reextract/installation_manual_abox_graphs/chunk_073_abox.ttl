@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GANTRY_MAXCOUPE
    a ex:Parametro ;
    rdfs:label "MAXCOUPE" ;
    ex:textoExtracto "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." ;
    ex:valor "Diferencia entre el error de seguimiento de ambos ejes" .

ex:Parametro_GANTRY_DIFFCOMP
    a ex:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ex:textoExtracto "Compensar la diferencia de cota entre ambos ejes tras G74." ;
    ex:valor "Compensación de diferencia de cota entre ejes" .

ex:Parametro_GANTRY_MAXDIFF
    a ex:Parametro ;
    rdfs:label "MAXDIFF" ;
    ex:textoExtracto "Máxima diferencia de cota permitida entre ambos ejes para poder compensarla." ;
    ex:valor "Máxima diferencia de cota permitida" .

ex:Tabla_ConfiguracionGantry a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de parámetros GANTRY" ;
    ex:textoExtracto "| GANTRY |  | MAXCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning. | DIFFCOMP | Compensar la diferencia de cota entre ambos ejes tras G74. | MAXDIFF | Máxima diferencia de cota permitida entre ambos ejes para poder compensarla. |" ;
    ex:tieneComponente ex:Parametro_GANTRY_MAXCOUPE ;
    ex:tieneComponente ex:Parametro_GANTRY_DIFFCOMP ;
    ex:tieneComponente ex:Parametro_GANTRY_MAXDIFF .