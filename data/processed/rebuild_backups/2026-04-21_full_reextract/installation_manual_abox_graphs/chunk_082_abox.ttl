@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MULNAXIS
    a ex:Parametro ;
    rdfs:label "MULNAXIS" ;
    ex:textoExtracto "Número de ejes y/o cabezales que forman el grupo multieje. Valores posibles: De 2 a 8. Valor por defecto: 2." ;
    ex:valor "2-8" ;
    ex:identificador "MPG.MULNAXIS[nb]" ;
    ex:documentadoEn ex:Tabla_MULTIAXIS .

ex:Parametro_MULNAXISNAME
    a ex:Parametro ;
    rdfs:label "MULNAXISNAME" ;
    ex:textoExtracto "Nombre de los ejes y/o cabezales del grupo. Valores posibles: Cualquier eje Sercos del sistema, excepto ejes tándem o gantry." ;
    ex:identificador "MPG.MULAXISNAMExn[nb]" ;
    ex:documentadoEn ex:Tabla_MULTIAXIS .

ex:Parametro_KEEPPOS
    a ex:Parametro ;
    rdfs:label "KEEPPOS" ;
    ex:textoExtracto "El eje desactivado mantiene su cota independientemente del eje activo." ;
    ex:documentadoEn ex:Tabla_MULTIAXIS .

ex:Tabla_MULTIAXIS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MULTIAXIS // GROUP n" ;
    ex:textoExtracto "Tabla que incluye parámetros de configuración de grupos multieje (MULNAXIS, MULNAXISNAME, KEEPPOS)." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Sistema CNC con regulador que gestiona hasta 8 sets de parámetros repartidos entre ejes y/o cabezales del grupo multieje." ;
    ex:tieneComponente ex:Parametro_MULNAXIS ;
    ex:tieneComponente ex:Parametro_MULNAXISNAME ;
    ex:tieneComponente ex:Parametro_KEEPPOS .