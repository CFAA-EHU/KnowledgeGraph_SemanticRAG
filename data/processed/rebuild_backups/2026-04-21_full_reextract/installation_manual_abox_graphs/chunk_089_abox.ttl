@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación" ;
    ex:monitoreaParametro ex:BusCAN .

ex:Parametro_PRGFREQ
    a ex:Parametro ;
    rdfs:label "PRGFREQ" ;
    ex:identificador "MPG.PRGFREQ" ;
    ex:textoExtracto "Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." ;
    ex:valor "2" ;
    ex:monitoreaParametro ex:ModuloPRG_PLC .

ex:BusCAN
    a ex:Sistema ;
    rdfs:label "Bus CAN" ;
    ex:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. Desde el punto de vista del bus CAN, el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema" ;
    ex:tieneComponente ex:ModuloPRG_PLC .

ex:ModuloPRG_PLC
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo PRG del PLC" ;
    ex:textoExtracto "Periodicidad del módulo PRG del PLC (PRGFREQ)" .

ex:HerramientaAnalisisCAN
    a ex:Herramienta ;
    rdfs:label "Herramienta comercial de análisis lógico del bus CAN" ;
    ex:textoExtracto "recurrir a una herramienta comercial de análisis lógico del bus CAN. Con esta herramienta se puede fijar el parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación" .

ex:Aviso_InsuficienteLOOPTIME_CANopen
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de LOOPTIME insuficiente (CANopen)" ;
    ex:textoExtracto "En el arranque del CNC se realiza adicionalmente una estimación del tiempo necesario, mostrando el correspondiente aviso en caso de ser insuficiente" .