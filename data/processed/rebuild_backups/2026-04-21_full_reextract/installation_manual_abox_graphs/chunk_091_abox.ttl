@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SERBRATE
    a ex:Parametro ;
    rdfs:label "SERBRATE (Velocidad de transmisión de Sercos)" ;
    ex:textoExtracto "SERBRATE Velocidad de transmisión de Sercos. Valores posibles: 2/4/8/16 Mbps (megabits por segundo). Valor por defecto: 4 Mbps." ;
    ex:valor "4 Mbps" ;
    ex:identificador "V.MPG.SERBRATE" .

ex:Parametro_SERPOWSE
    a ex:Parametro ;
    rdfs:label "SERPOWSE (Potencia óptica de Sercos)" ;
    ex:textoExtracto "SERPOWSE Potencia óptica de Sercos. Valores posibles: De 1 a 6 (placa Sercos I) / de 1 a 8 (placa Sercos II). Valor por defecto: 4 (placa Sercos I) / 2 (placa Sercos II)." ;
    ex:valor "4 (placa Sercos I) / 2 (placa Sercos II)" ;
    ex:identificador "V.MPG.SERPOWSE" .

ex:Tabla_RecomendacionesSERPOWSE_PlacaI a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Valores recomendados para SERPOWSE (placa Sercos I)" ;
    ex:textoExtracto "| SERPOWSE | Longitud del cable. | --- | --- | 2 | Menor de 7 metros. | 4 | Entre 7 y 15 metros. | 6 | Mayor de 15 metros." .

ex:Tabla_RecomendacionesSERPOWSE_PlacaII a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Valores recomendados para SERPOWSE (placa Sercos II)" ;
    ex:textoExtracto "| SERPOWSE | Longitud del cable. | Tipo de cable recomendado. | --- | --- | --- | 1 a 4 | Menor de 15 metros." .