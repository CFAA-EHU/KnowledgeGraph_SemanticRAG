@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionBusSercos_92 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración del bus Sercos (placa Sercos II)" ;
    ex:textoExtracto "Valores recomendados (placa Sercos II). | SERPOWSE | Longitud del cable. | Tipo de cable recomendado. | --- | --- | --- | 1 a 4 | Menor de 15 metros. | SFO / SFO-FLEX | 5 a 6 | Entre 15 y 30 metros. | SFO-FLEX | 7 | Entre 30 y 40 metros. | SFO-FLEX | 8 | Mayor de 40 metros. | SFO-V-FLEX" ;
    ex:identificador "Tabla 2.3.8 (pág. 69)" .

ex:Parametro_SERPOWSE_92
    a ex:Parametro ;
    rdfs:label "SERPOWSE (configuración bus Sercos)" ;
    ex:textoExtracto "SERPOWSE | Longitud del cable. | Tipo de cable recomendado." ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusSercos_92 ;
    ex:valor "1-8" .

ex:ComponenteElectrico_CableSFO_92
    a ex:ComponenteElectrico ;
    rdfs:label "Cable SFO / SFO-FLEX" ;
    ex:textoExtracto "Tipo de cable recomendado: SFO / SFO-FLEX" ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusSercos_92 .

ex:ComponenteElectrico_CableSFOV_FLEX_92
    a ex:ComponenteElectrico ;
    rdfs:label "Cable SFO-V-FLEX" ;
    ex:textoExtracto "Tipo de cable recomendado: SFO-V-FLEX" ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusSercos_92 .