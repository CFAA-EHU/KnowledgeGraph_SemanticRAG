@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INCHES
    a ex:Parametro ;
    rdfs:label "Unidades de trabajo (INCHES)" ;
    ex:identificador "V.MPG.INCHES" ;
    ex:valor "Milímetros" ;
    ex:textoExtracto "INCHES Unidades de trabajo (milímetros, inch) por defecto. Valores posibles: Milímetros / inches. Valor por defecto: Milímetros. Variable asociada: (V.)MPG.INCHES Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset." .

ex:Parametro_PRESSURE
    a ex:Parametro ;
    rdfs:label "Unidades de presión" ;
    ex:identificador "V.MPG.PRESSURE" ;
    ex:valor "Bar" ;
    ex:textoExtracto "PRESSURE Unidades de presión por defecto. Valores posibles: Bar / Psi. Valor por defecto: Bar. Variable asociada: (V.)MPG.PRESSURE Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset." .