@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Cambio de herramienta)"@es ;
    ex:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta. [...] LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es ;
    ex:identificador "M06" .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador"@es ;
    ex:textoExtracto "Retirar el brazo cambiador. [...] Llevar el brazo cambiador al punto de cambio."@es .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1"@es ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. [...] LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal."@es .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] LL SUB_CH1_TO_SPD ; Llevar la herramienta [...] al cabezal."@es .

ex:PuntoCambioAutomatico a ex:InterfazUsuario ;
    rdfs:label "Punto de cambio automático"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es .

ex:PuntoCambioManual a ex:InterfazUsuario ;
    rdfs:label "Punto de cambio manual"@es ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es .

ex:MarcaTCHANGEOK a ex:Parametro ;
    rdfs:label "TCHANGEOK"@es ;
    ex:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución."@es ;
    ex:identificador "M[1100]" ;
    ex:valor "1" .

ex:RutinaM06 ex:controla ex:BrazoCambiador .
ex:RutinaM06 ex:controla ex:Pinza1 .
ex:RutinaM06 ex:controla ex:Cabezal .
ex:RutinaM06 ex:monitoreaParametro ex:MarcaTCHANGEOK .