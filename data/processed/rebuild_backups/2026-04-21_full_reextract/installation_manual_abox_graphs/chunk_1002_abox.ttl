@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionT a ex:ModoOperacion ;
    rdfs:label "Función T (TMOPERATION=11)" ;
    ex:textoExtracto "Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11 para coger la próxima herramienta en el brazo y acercarla al cabezal durante el mecanizado." ;
    ex:identificador "TMOPERATION=11" ;
    ex:controla ex:Pinza1 .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "Coger con la pinza 1 la herramienta que ocupa la posición de almacén que indica TAKEPOS." .

ex:MarcadorCH1TOMZ a ex:Parametro ;
    rdfs:label "Marca CH1TOMZ" ;
    ex:textoExtracto "Activar la marca CH1TOMZ para indicar que se ha dejado la herramienta en la posición del almacén." ;
    ex:identificador "CH1TOMZ" .

ex:MarcadorMZTOCH1 a ex:Parametro ;
    rdfs:label "Marca MZTOCH1" ;
    ex:textoExtracto "Activar la marca MZTOCH1 para indicar al gestor que se ha cogido la herramienta." ;
    ex:identificador "MZTOCH1" .

ex:FuncionM06 a ex:ModoOperacion ;
    rdfs:label "Función M06" ;
    ex:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." ;
    ex:identificador "M06" ;
    ex:controla ex:Pinza1, ex:Pinza2, ex:Cabezal .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2" ;
    ex:textoExtracto "La herramienta se ha llevado del cabezal a la pinza 2." .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ex:textoExtracto "La herramienta se ha llevado de la pinza 1 al cabezal." .

ex:MarcadorTCHANGEOK a ex:Parametro ;
    rdfs:label "Marca TCHANGEOK" ;
    ex:textoExtracto "DFU M1100 = SET TCHANGEOK [...] Se puede continuar con la ejecución del programa." ;
    ex:identificador "TCHANGEOK" .

ex:MarcadorCH1TOSPDL a ex:Parametro ;
    rdfs:label "Marca CH1TOSPDL" ;
    ex:textoExtracto "La herramienta se ha llevado de la pinza 1 al cabezal." ;
    ex:identificador "CH1TOSPDL" .

ex:MarcadorSPDLTOCH2 a ex:Parametro ;
    rdfs:label "Marca SPDLTOCH2" ;
    ex:textoExtracto "La herramienta se ha llevado del cabezal a la pinza 2." ;
    ex:identificador "SPDLTOCH2" .

ex:MarcadorSPDLTOGR a ex:Parametro ;
    rdfs:label "Marca SPDLTOGR" ;
    ex:textoExtracto "La herramienta se ha llevado del cabezal a tierra." ;
    ex:identificador "SPDLTOGR" .

ex:MarcadorGRTOSPDL a ex:Parametro ;
    rdfs:label "Marca GRTOSPDL" ;
    ex:textoExtracto "La herramienta se ha llevado de tierra al cabezal." ;
    ex:identificador "GRTOSPDL" .

ex:FuncionM101 a ex:ModoOperacion ;
    rdfs:label "Función M101" ;
    ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." ;
    ex:identificador "M101" ;
    ex:controla ex:Pinza1 .