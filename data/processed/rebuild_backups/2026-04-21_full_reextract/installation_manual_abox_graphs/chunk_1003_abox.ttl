@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06" ;
    ex:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." ;
    ex:tieneComponente ex:FuncionM101, ex:FuncionM102, ex:FuncionM104, ex:FuncionM106, ex:FuncionM121, ex:FuncionM122, ex:FuncionM123 .

ex:FuncionM101 a ex:AccionProhibida ;
    rdfs:label "M101" ;
    ex:identificador "M101" ;
    ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:FuncionM102 a ex:AccionProhibida ;
    rdfs:label "M102" ;
    ex:identificador "M102" ;
    ex:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ex:FuncionM104 a ex:AccionProhibida ;
    rdfs:label "M104" ;
    ex:identificador "M104" ;
    ex:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .

ex:FuncionM106 a ex:AccionProhibida ;
    rdfs:label "M106" ;
    ex:identificador "M106" ;
    ex:textoExtracto "M106 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2." .

ex:FuncionM121 a ex:AccionProhibida ;
    rdfs:label "M121" ;
    ex:identificador "M121" ;
    ex:textoExtracto "M121 Llevar el brazo cambiador al punto de cambio." .

ex:FuncionM122 a ex:AccionProhibida ;
    rdfs:label "M122" ;
    ex:identificador "M122" ;
    ex:textoExtracto "M122 Llevar el brazo cambiador al almacén." .

ex:FuncionM123 a ex:AccionProhibida ;
    rdfs:label "M123" ;
    ex:identificador "M123" ;
    ex:textoExtracto "M123 Retirar el brazo cambiador. Su programación depende del tipo de máquina." .