@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_CodigosTecla
    a                       ex:InterfazUsuario ;
    rdfs:label              "Códigos de tecla (scan codes) del CNC"@es ;
    ex:textoExtracto        "Los códigos de tecla (scan codes) permiten conocer cuál ha sido la última tecla aceptada por el CNC y también permiten simular el teclado desde el PLC. A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla."@es ;
    ex:documentadoEn        ex:Pagina_543 .

ex:Pagina_543
    a                       ex:Pagina ;
    ex:identificador        "543" ;
    ex:textoExtracto        "Sección 8.2: Códigos de tecla. Descripción de scan codes y simulación de teclado desde PLC."@es ;
    ex:ilustradoEn          ex:Manual_CNC .

ex:Pagina_547
    a                       ex:Pagina ;
    ex:identificador        "547" ;
    ex:textoExtracto        "8.5.1 Scan codes. Distribución de teclado 'Español (España)'."@es .

ex:Pagina_548
    a                       ex:Pagina ;
    ex:identificador        "548" ;
    ex:textoExtracto        "8.5.2 Scan codes. Distribución de teclado 'Inglés (Estados Unidos)'."@es .

ex:Sistema_TeclasCNC
    a                       ex:Sistema ;
    rdfs:label              "Teclas propias del CNC"@es ;
    ex:textoExtracto        "Las teclas propias del CNC no tienen asociado ningún código de tecla. Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente."@es ;
    ex:compuestoPor         ex:Tecla_START , ex:Tecla_STOP , ex:Tecla_RESET , ex:Tecla_LogoFagor ;
    ex:controla             ex:InterfazUsuario_CodigosTecla .

ex:Tecla_START
    a                       ex:Componente ;
    rdfs:label              "Tecla [START]"@es ;
    ex:identificador        "START" ;
    ex:textoExtracto        "Tecla [START] accionable desde el PLC mediante la marca CYSTART."@es .

ex:Tecla_STOP
    a                       ex:Componente ;
    rdfs:label              "Tecla [STOP]"@es ;
    ex:identificador        "_STOP" ;
    ex:textoExtracto        "Tecla [STOP] accionable desde el PLC mediante la marca _STOP."@es .

ex:Tecla_RESET
    a                       ex:Componente ;
    rdfs:label              "Tecla [RESET]"@es ;
    ex:identificador        "RESETIN" ;
    ex:textoExtracto        "Tecla [RESET] accionable desde el PLC mediante la marca RESETIN."@es .

ex:Tecla_LogoFagor
    a                       ex:Componente ;
    rdfs:label              "Tecla con logo Fagor"@es ;
    ex:textoExtracto        "La tecla con el logo Fagor no se puede simular. Esta tecla no está disponible en todos los teclados."@es .

ex:VentanaTareas_Hotkeys
    a                       ex:InterfazUsuario ;
    rdfs:label              "Ventana de tareas ([CTRL]+[A])"@es ;
    ex:textoExtracto        "La ventana de tareas ([CTRL]+[A]) muestra la lista de hotkeys disponibles en el CNC."@es ;
    ex:documentadoEn        ex:Pagina_543 .