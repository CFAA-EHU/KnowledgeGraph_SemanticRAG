@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_CNC_8_2_1
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC (atajos de teclado)"@es ;
    ex:textoExtracto "8.2.1 Atajos de teclado. Teclas propias del CNC."@es ;
    ex:tieneComponente ex:AtajoTeclado_CTRLO,
                       ex:AtajoTeclado_CTRLW,
                       ex:AtajoTeclado_ALTF4,
                       ex:AtajoTeclado_ALTS,
                       ex:AtajoTeclado_ALTW .

ex:AtajoTeclado_CTRLO
    a ex:Componente ;
    rdfs:label "[CTRL]+[O]"@es ;
    ex:textoExtracto "Minimizar/Maximizar el CNC."@es ;
    ex:identificador "CTRL+O" .

ex:AtajoTeclado_CTRLW
    a ex:Componente ;
    rdfs:label "[CTRL]+[W]"@es ;
    ex:textoExtracto "Apagar el CNC."@es ;
    ex:identificador "CTRL+W" .

ex:AtajoTeclado_ALTF4
    a ex:Componente ;
    rdfs:label "[ALT]+[F4]"@es ;
    ex:textoExtracto "Apagar el CNC."@es ;
    ex:identificador "ALT+F4" .

ex:AtajoTeclado_ALTS
    a ex:Componente ;
    rdfs:label "[ALT]+[S]"@es ;
    ex:textoExtracto "Ventana de sincronización de canales."@es ;
    ex:identificador "ALT+S" .

ex:AtajoTeclado_ALTW
    a ex:Componente ;
    rdfs:label "[ALT]+[W]"@es ;
    ex:textoExtracto "Mostrar / ocultar la ventana de errores y warnings."@es ;
    ex:identificador "ALT+W" .