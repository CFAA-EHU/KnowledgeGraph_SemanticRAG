@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tecla_CTRL
    a ex:Componente ;
    rdfs:label "Tecla CTRL" ;
    ex:textoExtracto "Pulsar la tecla [CTRL] (...) Soltar la tecla [CTRL]"@es ;
    ex:identificador "$1D (pulsar), $9D (soltar)" .

ex:Tecla_F1
    a ex:Componente ;
    rdfs:label "Tecla F1" ;
    ex:textoExtracto "Pulsar la tecla [F1] (...) Soltar la tecla [F1]"@es ;
    ex:identificador "$3B (pulsar), $BB (soltar)" .

ex:CombinacionTeclas_B0KEYBD1
    a ex:InterfazUsuario ;
    rdfs:label "Combinación de teclas B0KEYBD1" ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía la combinación [CTRL]+[F1]"@es ;
    ex:identificador "B0KEYBD1" ;
    ex:compuestoPor ex:Tecla_CTRL ;
    ex:compuestoPor ex:Tecla_F1 .

ex:Registro_R204
    a ex:Parametro ;
    rdfs:label "Registro R204 (pulsar CTRL)" ;
    ex:textoExtracto "MOV $1D R204 ; Pulsar la tecla [CTRL]"@es ;
    ex:valor "$1D" ;
    ex:identificador "R204" .

ex:Registro_R205
    a ex:Parametro ;
    rdfs:label "Registro R205 (soltar CTRL)" ;
    ex:textoExtracto "MOV $9D R205 ; Soltar la tecla [CTRL]"@es ;
    ex:valor "$9D" ;
    ex:identificador "R205" .

ex:Registro_R206
    a ex:Parametro ;
    rdfs:label "Registro R206 (pulsar F1)" ;
    ex:textoExtracto "MOV $3B R206 ; Pulsar la tecla [F1]"@es ;
    ex:valor "$3B" ;
    ex:identificador "R206" .

ex:Registro_R207
    a ex:Parametro ;
    rdfs:label "Registro R207 (soltar F1)" ;
    ex:textoExtracto "MOV $BB R207 ; Soltar la tecla [F1]"@es ;
    ex:valor "$BB" ;
    ex:identificador "R207" .

ex:Tarea_SimulacionTecladoPLC
    a ex:ModoOperacion ;
    rdfs:label "Simulación de teclado desde PLC" ;
    ex:textoExtracto "8.4 Simular el teclado desde el PLC (...) Enviar el código asociado a soltar la primera tecla (por ejemplo, tecla [CTRL]). Enviar el código asociado a soltar la segunda tecla (por ejemplo, tecla [F1])."@es ;
    ex:documentadoEn ex:CombinacionTeclas_B0KEYBD1 .