@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ScanCodes_InglesUS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de scan codes para distribución de teclado Inglés (Estados Unidos)"@es ;
    ex:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT]."@es ;
    ex:ilustradoEn ex:InterfazUsuario_Teclado .

ex:InterfazUsuario_Teclado
    a ex:InterfazUsuario ;
    rdfs:label "Teclado (distribución Inglés - Estados Unidos)"@es ;
    ex:textoExtracto "Scan codes. Distribución de teclado \"Inglés (Estados Unidos)\""@es ;
    ex:tieneComponente ex:Tecla_BloquearMayusculas ,
                       ex:Tecla_Shift ,
                       ex:Tecla_Ctrl ,
                       ex:Tecla_Alt ,
                       ex:Tecla_AltGr ,
                       ex:Tecla_BarraEspaciadora ,
                       ex:Tecla_Backspace ,
                       ex:Tecla_ImprPantalla ,
                       ex:Tecla_AvPag ,
                       ex:Tecla_RePag ,
                       ex:Tecla_Inicio ,
                       ex:Tecla_Fin ,
                       ex:Tecla_FlechaArriba ,
                       ex:Tecla_FlechaAbajo ,
                       ex:Tecla_FlechaDerecha ,
                       ex:Tecla_FlechaIzquierda .

ex:Tecla_BloquearMayusculas
    a ex:Componente ;
    rdfs:label "Tecla Bloquear Mayúsculas"@es ;
    ex:identificador "$3A (pulsar) / $BA (soltar)" ;
    ex:textoExtracto "Bloquear mayúsculas. | $3A | $BA"@es .

ex:Tecla_Shift
    a ex:Componente ;
    rdfs:label "Tecla Mayúsculas (SHIFT)"@es ;
    ex:identificador "$2A / $36 (pulsar) / $AA / $B6 (soltar)" ;
    ex:textoExtracto "Mayúsculas (SHIFT). | $2A/ $36 | $AA / $B6"@es .

ex:Tecla_Ctrl
    a ex:Componente ;
    rdfs:label "Tecla Control (CTRL)"@es ;
    ex:identificador "$1D (pulsar) / $9D (soltar)" ;
    ex:textoExtracto "Control (CTRL). | $1D | $9D"@es .

ex:Tecla_Alt
    a ex:Componente ;
    rdfs:label "Tecla Alternativo (ALT)"@es ;
    ex:identificador "$38 (pulsar) / $B8 (soltar)" ;
    ex:textoExtracto "Alternativo (ALT). | $38 | $B8"@es .

ex:Tecla_AltGr
    a ex:Componente ;
    rdfs:label "Tecla Alternativo Gráfico (ALT GR)"@es ;
    ex:identificador "$E0$38 (pulsar) / $E0$B8 (soltar)" ;
    ex:textoExtracto "Alternativo gráfico (ALT GR). | $E0$38 | $E0$B8"@es .

ex:Tecla_BarraEspaciadora
    a ex:Componente ;
    rdfs:label "Tecla Barra Espaciadora"@es ;
    ex:identificador "$39 (pulsar) / $B9 (soltar)" ;
    ex:textoExtracto "Barra espaciadora. | $39 | $B9"@es .

ex:Tecla_Backspace
    a ex:Componente ;
    rdfs:label "Tecla Retroceso (Backspace)"@es ;
    ex:identificador "$0E (pulsar) / $8E (soltar)" ;
    ex:textoExtracto "Retroceso (Backspace). | $0E | $8E"@es .

ex:Tecla_ImprPantalla
    a ex:Componente ;
    rdfs:label "Tecla Imprimir Pantalla"@es ;
    ex:identificador "$E0$37 (pulsar) / $E0$B7 (soltar)" ;
    ex:textoExtracto "Imprimir pantalla. | $E0$37 | $E0$B7"@es .

ex:Tecla_AvPag
    a ex:Componente ;
    rdfs:label "Tecla Avanzar Página"@es ;
    ex:identificador "$E0$51 (pulsar) / $E0$D1 (soltar)" ;
    ex:textoExtracto "Avanzar página. | $E0$51 | $E0$D1"@es .

ex:Tecla_RePag
    a ex:Componente ;
    rdfs:label "Tecla Retroceder Página"@es ;
    ex:identificador "$E0$49 (pulsar) / $E0$C9 (soltar)" ;
    ex:textoExtracto "Retroceder página. | $E0$49 | $E0$C9"@es .

ex:Tecla_Inicio
    a ex:Componente ;
    rdfs:label "Tecla Inicio"@es ;
    ex:identificador "$E0$47 (pulsar) / $E0$C7 (soltar)" ;
    ex:textoExtracto "Inicio. | $E0$47 | $E0$C7"@es .

ex:Tecla_Fin
    a ex:Componente ;
    rdfs:label "Tecla Fin"@es ;
    ex:identificador "$E0$4F (pulsar) / $E0$CF (soltar)" ;
    ex:textoExtracto "Fin. | $E0$4F | $E0$CF"@es .

ex:Tecla_FlechaArriba
    a ex:Componente ;
    rdfs:label "Tecla Flecha Arriba"@es ;
    ex:identificador "$E0$48 (pulsar) / $E0$C8 (soltar)" ;
    ex:textoExtracto "Flecha arriba. | $E0$48 | $E0$C8"@es .

ex:Tecla_FlechaAbajo
    a ex:Componente ;
    rdfs:label "Tecla Flecha Abajo"@es ;
    ex:identificador "$E0$50 (pulsar) / $E0$D0 (soltar)" ;
    ex:textoExtracto "Flecha abajo. | $E0$50 | $E0$D0"@es .

ex:Tecla_FlechaDerecha
    a ex:Componente ;
    rdfs:label "Tecla Flecha Derecha"@es ;
    ex:identificador "$E0$4D (pulsar) / $E0$CD (soltar)" ;
    ex:textoExtracto "Flecha derecha. | $E0$4D | $E0$CD"@es .

ex:Tecla_FlechaIzquierda
    a ex:Componente ;
    rdfs:label "Tecla Flecha Izquierda"@es ;
    ex:identificador "$E0$4B (pulsar) / $E0$CB (soltar)" ;
    ex:textoExtracto "Flecha izquierda. | $E0$4B | $E0$CB"@es .