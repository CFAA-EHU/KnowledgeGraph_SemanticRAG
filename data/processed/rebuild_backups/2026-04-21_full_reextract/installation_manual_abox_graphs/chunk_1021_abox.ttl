@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Norma_DIN66217
    a ex:Directiva ;
    rdfs:label "Norma DIN 66217 para denominación de ejes"@es ;
    ex:identificador "DIN66217" ;
    ex:textoExtracto "La norma DIN 66217 denomina los diferentes tipos de ejes de la siguiente manera."@es .

ex:Tabla_DenominacionEjes a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de denominación de ejes según DIN 66217"@es ;
    ex:textoExtracto "Nombre. | Tipo de eje según la norma DIN 66217."@es ;
    ex:documentadoEn ex:Norma_DIN66217 .

ex:Eje_Xn
    a ex:ComponenteMecanico ;
    rdfs:label "Eje principal Xn (según DIN 66217)"@es ;
    ex:identificador "Xn" ;
    ex:textoExtracto "Xn | Ejes principales. Dos ejes forman el plano de trabajo y el tercer eje corresponde al eje perpendicular al plano."@es ;
    ex:cumpleNormativa ex:Norma_DIN66217 ;
    ex:detalladoEnEsquema ex:Tabla_DenominacionEjes .

