@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionEjesCabezales_1023 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (SPDLNAME/AXISNAME)"@es ;
    ex:textoExtracto """
| AXISNAME | Orden lógico. | Índice en el sistema. |
| --- | --- | --- |
| AXISNAME 1 | Número lógico ꞏ1ꞏ. |  |
| AXISNAME 2 | Número lógico ꞏ2ꞏ. |  |
| AXISNAME 3 | Número lógico ꞏ3ꞏ. |  |
| SPDLNAME 1 | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ. |
| SPDLNAME 2 | Número lógico ꞏ5ꞏ. | Cabezal con índice ꞏ2ꞏ.
""" ;
    ex:documentadoEn ex:Pagina_556 .

ex:Parametro_SPDLNAME
    a ex:Parametro ;
    rdfs:label "Parámetro máquina SPDLNAME"@es ;
    ex:textoExtracto "El índice de un cabezal en el sistema viene establecido por el orden en el que está definido en el parámetro máquina SPDLNAME."@es ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCabezales_1023 ;
    ex:identificador "SPDLNAME" .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "Parámetro AXISNAME"@es ;
    ex:textoExtracto "Orden lógico de ejes (AXISNAME 1, AXISNAME 2, AXISNAME 3)."@es ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCabezales_1023 ;
    ex:identificador "AXISNAME" .

ex:Cabezal_Indice1
    a ex:Componente ;
    rdfs:label "Cabezal con índice 1 (SPDLNAME 1)"@es ;
    ex:textoExtracto "SPDLNAME 1 [...] Cabezal con índice ꞏ1ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCabezales_1023 ;
    ex:identificador "1" .

