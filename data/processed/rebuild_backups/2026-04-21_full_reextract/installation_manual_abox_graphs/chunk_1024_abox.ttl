@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CHNAXIS
    a ex:Parametro ;
    rdfs:label "CHNAXIS" ;
    ex:textoExtracto "Número de ejes del canal." ;
    ex:identificador "CHNAXIS" .

ex:Parametro_CHAXISNAME
    a ex:Parametro ;
    rdfs:label "CHAXISNAME" ;
    ex:textoExtracto "Lista de ejes del canal. [...] El orden en el que se definen los ejes y cabezales en los parámetros CHAXISNAME y CHSPDLNAME determina su índice en el canal." ;
    ex:identificador "CHAXISNAME" .

ex:Parametro_CHNSPDL
    a ex:Parametro ;
    rdfs:label "CHNSPDL" ;
    ex:textoExtracto "Número de cabezales del canal." ;
    ex:identificador "CHNSPDL" .

ex:Parametro_CHSPDLNAME
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME" ;
    ex:textoExtracto "Lista de cabezales del canal. [...] El orden en el que se definen los ejes y cabezales en los parámetros CHAXISNAME y CHSPDLNAME determina su índice en el canal." ;
    ex:identificador "CHSPDLNAME" .

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:textoExtracto "Número de ejes del sistema." ;
    ex:identificador "NAXIS" .

ex:Tabla_AsignacionEjesCabezales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Asignación de ejes y cabezales por canal" ;
    ex:textoExtracto "CHAXISNAME | CHSPDLNAME | Índice en el canal." ;
    ex:detalladoEnEsquema ex:Parametro_CHAXISNAME ;
    ex:detalladoEnEsquema ex:Parametro_CHSPDLNAME .