@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionTorno_3Canales_6Ejes_2Cabezales
    a ex:Sistema ;
    rdfs:label "Torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ex:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales. Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano. Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano. Canal 3: 2 ejes y ningún cabezal."@es ;
    ex:identificador "Configuración 567" ;
    ex:compuestoPor ex:Canal1_2Ejes_1Cabezal_Plano, ex:Canal2_2Ejes_1Cabezal_Plano, ex:Canal3_2Ejes_0Cabezales .

ex:Canal1_2Ejes_1Cabezal_Plano
    a ex:ComponenteMecanico ;
    rdfs:label "Canal 1: 2 ejes y 1 cabezal (configuración tipo plano)"@es ;
    ex:textoExtracto "Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es ;
    ex:identificador "Canal 1" .

ex:Canal2_2Ejes_1Cabezal_Plano
    a ex:ComponenteMecanico ;
    rdfs:label "Canal 2: 2 ejes y 1 cabezal (configuración tipo plano)"@es ;
    ex:textoExtracto "Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es ;
    ex:identificador "Canal 2" .

ex:Canal3_2Ejes_0Cabezales
    a ex:ComponenteMecanico ;
    rdfs:label "Canal 3: 2 ejes y ningún cabezal"@es ;
    ex:textoExtracto "Canal 3: 2 ejes y ningún cabezal."@es ;
    ex:identificador "Canal 3" .