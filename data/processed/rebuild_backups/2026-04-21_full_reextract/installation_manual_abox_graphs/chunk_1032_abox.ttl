@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fresadora_3Canales_9Ejes_2Cabezales
    a               ex:Maquina ;
    rdfs:label      "Fresadora con 3 canales, 9 ejes y 2 cabezales"@es ;
    ex:textoExtracto "Supongamos una máquina con tres canales dónde los dos primeros canales disponen de ejes y cabezales para mecanizar y el tercer canal es un sistema de carga y descarga controlado por dos ejes."@es ;
    ex:tieneComponente ex:Canal_1, ex:Canal_2, ex:Canal_3 .

ex:Canal_1
    a               ex:Sistema ;
    rdfs:label      "Canal 1"@es ;
    ex:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)."@es ;
    ex:tieneComponente ex:Eje_X_Canal1, ex:Eje_Y_Canal1, ex:Eje_Z_Canal1, ex:Cabezal_S1 ;
    ex:identificador "1" .

ex:Canal_2
    a               ex:Sistema ;
    rdfs:label      "Canal 2"@es ;
    ex:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)."@es ;
    ex:tieneComponente ex:Eje_X1_Canal2, ex:Eje_Y1_Canal2, ex:Eje_Z1_Canal2, ex:Eje_W_Canal2, ex:Cabezal_S2 ;
    ex:identificador "2" .

ex:Canal_3
    a               ex:Sistema ;
    rdfs:label      "Canal 3 (Sistema de carga/descarga)"@es ;
    ex:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales. [...] el tercer canal es un sistema de carga y descarga controlado por dos ejes."@es ;
    ex:tieneComponente ex:Eje_U_Canal3, ex:Eje_U1_Canal3 ;
    ex:identificador "3" .

ex:Cabezal_S1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal S1"@es ;
    ex:textoExtracto "1 cabezal (S1)"@es ;
    ex:identificador "S1" .

ex:Cabezal_S2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal S2"@es ;
    ex:textoExtracto "1 cabezal (S2)"@es ;
    ex:identificador "S2" .

ex:Eje_X_Canal1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje X (Canal 1)"@es ;
    ex:textoExtracto "3 ejes (X Y Z)"@es ;
    ex:identificador "X" .

ex:Eje_Y_Canal1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje Y (Canal 1)"@es ;
    ex:textoExtracto "3 ejes (X Y Z)"@es ;
    ex:identificador "Y" .

ex:Eje_Z_Canal1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje Z (Canal 1)"@es ;
    ex:textoExtracto "3 ejes (X Y Z)"@es ;
    ex:identificador "Z" .

ex:Eje_X1_Canal2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje X1 (Canal 2)"@es ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)"@es ;
    ex:identificador "X1" .

ex:Eje_Y1_Canal2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje Y1 (Canal 2)"@es ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)"@es ;
    ex:identificador "Y1" .

ex:Eje_Z1_Canal2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje Z1 (Canal 2)"@es ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)"@es ;
    ex:identificador "Z1" .

ex:Eje_W_Canal2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje W (Canal 2)"@es ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)"@es ;
    ex:identificador "W" .

ex:Eje_U_Canal3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje U (Canal 3)"@es ;
    ex:textoExtracto "2 ejes (U U1)"@es ;
    ex:identificador "U" .

ex:Eje_U1_Canal3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje U1 (Canal 3)"@es ;
    ex:textoExtracto "2 ejes (U U1)"@es ;
    ex:identificador "U1" .