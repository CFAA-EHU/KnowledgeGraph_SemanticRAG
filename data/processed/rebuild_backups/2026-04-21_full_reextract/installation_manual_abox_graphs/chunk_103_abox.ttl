@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CROSSCOMP
    a ex:Parametro ;
    rdfs:label "CROSSCOMP" ;
    ex:textoExtracto "CROSSCOMP Tablas de compensación cruzada. Este parámetro muestra las tablas de compensación cruzada." ;
    ex:monitoreaParametro ex:Tabla_CompensacionCruzada .

ex:Parametro_DISCROSS
    a ex:Parametro ;
    rdfs:label "DISCROSS" ;
    ex:textoExtracto "el PLC dispone de una marca para cada tabla; la marca DISCROSS1 es para la tabla 1, DISCROSS2 para la tabla 2 y así sucesivamente." ;
    ex:identificador "DISCROSS1, DISCROSS2, ..." .

ex:Tabla_CompensacionCruzada a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tablas de compensación cruzada" ;
    ex:textoExtracto "Este parámetro muestra las tablas de compensación cruzada. La compensación cruzada se utiliza cuando dependiendo del desplazamiento de un eje, otro eje sufre variaciones de posición." ;
    ex:documentadoEn ex:Manual_Operacion .

ex:Manual_Operacion
    a ex:Manual ;
    rdfs:label "Manual de operación" ;
    ex:textoExtracto "Para obtener más información sobre cómo importar las tablas de compensación cruzada, consultar en el manual de operación." .

ex:Parametro_COMPAXIS
    a ex:Parametro ;
    rdfs:label "COMPAXIS" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" ;
    ex:monitoreaParametro ex:Tabla_CompensacionCruzada .

ex:Parametro_MOVAXIS
    a ex:Parametro ;
    rdfs:label "MOVAXIS" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" ;
    ex:monitoreaParametro ex:Tabla_CompensacionCruzada .

ex:Parametro_POSERROR
    a ex:Parametro ;
    rdfs:label "POSERROR" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" ;
    ex:monitoreaParametro ex:Tabla_CompensacionCruzada .

ex:Parametro_POSITION
    a ex:Parametro ;
    rdfs:label "POSITION" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" ;
    ex:monitoreaParametro ex:Tabla_CompensacionCruzada .