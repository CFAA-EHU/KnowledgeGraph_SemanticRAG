@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sistema_Torno_1Canal_3Ejes_1Cabezal
    a ex:Sistema ;
    rdfs:label "Sistema de torno con 1 canal, 3 ejes y 1 cabezal (configuración triedro)"@es ;
    ex:textoExtracto "Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S). Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | NCHANNEL = 1 | GEOCONFIG = Triedro | NAXIS = 3 | CHNAXIS = 3 | NSPDL = 1 | CHNSPDL = 1"@es ;
    ex:identificador "GEOCONFIG = Triedro ; NCHANNEL = 1 ; NAXIS = 3 ; NSPDL = 1" ;
    ex:compuestoPor ex:Eje_X_Torno_Canal1 ,
                    ex:Eje_Y_Torno_Canal1 ,
                    ex:Eje_Z_Torno_Canal1 ,
                    ex:Cabezal_S_Torno_Canal1 .

ex:Canal_1_Torno
    a ex:Sistema ;
    rdfs:label "Canal 1 del torno (3 ejes X/Y/Z, 1 cabezal S)"@es ;
    ex:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ1ꞏ. | CHAXISNAME | Valor | Índice en el canal. | Orden lógico. | CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ. | CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ. | CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ."@es ;
    ex:identificador "Canal-1" ;
    ex:compuestoPor ex:Eje_X_Torno_Canal1 ,
                    ex:Eje_Y_Torno_Canal1 ,
                    ex:Eje_Z_Torno_Canal1 ,
                    ex:Cabezal_S_Torno_Canal1 ;
    ex:detalladoEnEsquema ex:Sistema_Torno_1Canal_3Ejes_1Cabezal .

ex:Eje_X_Torno_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Torno, Canal 1, Índice 1, Orden lógico 1)"@es ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ. | CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ."@es ;
    ex:identificador "AXISNAME-1 ; CHAXISNAME-1 ; X" ;
    ex:valor "Índice en sistema: 1 ; Índice en canal: 1 ; Orden lógico: 1" .

ex:Eje_Y_Torno_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Y (Torno, Canal 1, Índice 2, Orden lógico 2)"@es ;
    ex:textoExtracto "AXISNAME 2 | Y | Número lógico ꞏ2ꞏ. | CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ."@es ;
    ex:identificador "AXISNAME-2 ; CHAXISNAME-2 ; Y" ;
    ex:valor "Índice en sistema: 2 ; Índice en canal: 2 ; Orden lógico: 2" .

ex:Eje_Z_Torno_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Torno, Canal 1, Índice 3, Orden lógico 3)"@es ;
    ex:textoExtracto "AXISNAME 3 | Z | Número lógico ꞏ3ꞏ. | CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ3ꞏ."@es ;
    ex:identificador "AXISNAME-3 ; CHAXISNAME-3 ; Z" ;
    ex:valor "Índice en sistema: 3 ; Índice en canal: 3 ; Orden lógico: 3" .

ex:Cabezal_S_Torno_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S (Torno, Canal 1, Índice 1, Orden lógico 4)"@es ;
    ex:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ."@es ;
    ex:identificador "SPDLNAME-1 ; S" ;
    ex:valor "Índice en sistema: 4 ; Índice en canal: 1 ; Orden lógico: 4" .