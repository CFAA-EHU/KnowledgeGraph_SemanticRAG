@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjes_1043 a ex:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo plano (G18)"@es ;
    ex:textoExtracto "Con una configuración de ejes tipo plano, siempre está activo el plano G18; en este caso el plano ZX. Las funciones G17 y G19 no son válidas."@es ;
    ex:identificador "G18" .

ex:Cabezal_1043 a ex:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es ;
    ex:textoExtracto "CHSPDLNAME 1 • S • Cabezal con índice •1•. Número lógico •4•. Selección de planos en el canal •1•."@es ;
    ex:identificador "1" .

ex:Parametro_G18 a ex:Parametro ;
    rdfs:label "Función G18 (plano ZX)"@es ;
    ex:textoExtracto "G18 • Plano ZX. Eje Z para la compensación longitudinal."@es ;
    ex:identificador "G18" ;
    ex:monitoreaParametro ex:ConfiguracionEjes_1043 .

ex:Parametro_G17 a ex:Parametro ;
    rdfs:label "Función G17 (no válida en esta configuración)"@es ;
    ex:textoExtracto "Las funciones G17 [...] no son válidas."@es ;
    ex:identificador "G17" .

ex:Parametro_G19 a ex:Parametro ;
    rdfs:label "Función G19 (no válida en esta configuración)"@es ;
    ex:textoExtracto "Las funciones [...] G19 no son válidas."@es ;
    ex:identificador "G19" .

ex:Tabla_Planos_1043 a ex:Tabla ;
    rdfs:label "Tabla de selección de planos (G17/G18/G19)"@es ;
    ex:textoExtracto "Orden lógico. • CHSPDLNAME 1 • S • Cabezal con índice •1•. Número lógico •4•. Selección de planos en el canal •1•."@es ;
    ex:documentadoEn ex:Pagina_565 ;
    ex:ilustradoEn ex:ConfiguracionEjes_1043 .

ex:Pagina_565 a ex:Pagina ;
    rdfs:label "Página 565 (Sección 10.2.6)"@es ;
    ex:identificador "565" ;
    ex:textoExtracto "Torno con 1 canal, 3 ejes (1 libre) y 1 cabezal. Configuración de ejes tipo."@es .