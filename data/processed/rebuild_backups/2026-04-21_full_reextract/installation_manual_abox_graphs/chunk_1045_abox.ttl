@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionEjesCanal1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes (Canal 1)"@es ;
    ex:textoExtracto """
| Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ. |
| CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.
""" .

ex:Tabla_ConfiguracionCabezalesCanal1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de cabezales (Canal 1)"@es ;
    ex:textoExtracto """
| CHSPDLNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ5ꞏ.
""" .

ex:Tabla_ConfiguracionEjesCanal2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes (Canal 2)"@es ;
    ex:textoExtracto """
| CHAXISNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X1 | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ. |
| CHAXISNAME 2 | Z1 | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ4ꞏ.
""" .

ex:ComponenteMecanico_EjeX_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Canal 1)"@es ;
    ex:identificador "X" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ1ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCanal1 .

ex:ComponenteMecanico_EjeZ_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Canal 1)"@es ;
    ex:identificador "Z" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ2ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCanal1 .

ex:ComponenteMecanico_CabezalS_Canal1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S (Canal 1)"@es ;
    ex:identificador "S" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ5ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionCabezalesCanal1 .

ex:ComponenteMecanico_EjeX1_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X1 (Canal 2)"@es ;
    ex:identificador "X1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ3ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCanal2 .

ex:ComponenteMecanico_EjeZ1_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z1 (Canal 2)"@es ;
    ex:identificador "Z1" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ4ꞏ."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCanal2 .

ex:Sistema_Torno2Canales4Ejes2Cabezales
    a ex:Sistema ;
    rdfs:label "Configuración de torno con 2 canales, 4 ejes y 2 cabezales"@es ;
    ex:textoExtracto "Torno con 2 canales, 4 ejes y 2 cabezales. Configuración de ejes tipo"@es ;
    ex:tieneComponente ex:ComponenteMecanico_EjeX_Canal1 ;
    ex:tieneComponente ex:ComponenteMecanico_EjeZ_Canal1 ;
    ex:tieneComponente ex:ComponenteMecanico_CabezalS_Canal1 ;
    ex:tieneComponente ex:ComponenteMecanico_EjeX1_Canal2 ;
    ex:tieneComponente ex:ComponenteMecanico_EjeZ1_Canal2 ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCanal1 ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionCabezalesCanal1 ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCanal2 .