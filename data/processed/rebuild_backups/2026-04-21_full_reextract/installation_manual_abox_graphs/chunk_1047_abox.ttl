@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Torno_3Canales_6Ejes_2Cabezales
    a ex:Maquina ;
    rdfs:label "Torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ex:textoExtracto "plano. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S). Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1). Canal ꞏ3ꞏ. 2 ejes (U V)"@es ;
    ex:compuestoPor ex:Canal_1, ex:Canal_2, ex:Canal_3 ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z, ex:Eje_X1, ex:Eje_Z1, ex:Eje_U, ex:Eje_V ;
    ex:tieneComponente ex:Cabezal_S, ex:Cabezal_S1 ;
    ex:documentadoEn ex:Tabla_ConfiguracionCanales .

ex:Canal_1
    a ex:Sistema ;
    rdfs:label "Canal 1"@es ;
    ex:identificador "Canal ꞏ1ꞏ" ;
    ex:textoExtracto "Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S)"@es ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z ;
    ex:tieneComponente ex:Cabezal_S ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionCanales .

ex:Canal_2
    a ex:Sistema ;
    rdfs:label "Canal 2"@es ;
    ex:identificador "Canal ꞏ2ꞏ" ;
    ex:textoExtracto "Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1)"@es ;
    ex:tieneComponente ex:Eje_X1, ex:Eje_Z1 ;
    ex:tieneComponente ex:Cabezal_S1 ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionCanales .

ex:Canal_3
    a ex:Sistema ;
    rdfs:label "Canal 3"@es ;
    ex:identificador "Canal ꞏ3ꞏ" ;
    ex:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U V)"@es ;
    ex:tieneComponente ex:Eje_U, ex:Eje_V ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionCanales .

ex:Eje_X
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Canal 1)"@es ;
    ex:identificador "X" ;
    ex:textoExtracto "2 ejes (X Z)"@es .

ex:Eje_Z
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Canal 1)"@es ;
    ex:identificador "Z" ;
    ex:textoExtracto "2 ejes (X Z)"@es .

ex:Eje_X1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X1 (Canal 2)"@es ;
    ex:identificador "X1" ;
    ex:textoExtracto "2 ejes (X1 Z1)"@es .

ex:Eje_Z1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z1 (Canal 2)"@es ;
    ex:identificador "Z1" ;
    ex:textoExtracto "2 ejes (X1 Z1)"@es .

ex:Eje_U
    a ex:ComponenteMecanico ;
    rdfs:label "Eje U (Canal 3)"@es ;
    ex:identificador "U" ;
    ex:textoExtracto "2 ejes (U V)"@es .

ex:Eje_V
    a ex:ComponenteMecanico ;
    rdfs:label "Eje V (Canal 3)"@es ;
    ex:identificador "V" ;
    ex:textoExtracto "2 ejes (U V)"@es .

ex:Cabezal_S
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S (Canal 1)"@es ;
    ex:identificador "S" ;
    ex:textoExtracto "1 cabezal (S)"@es .

ex:Cabezal_S1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S1 (Canal 2)"@es ;
    ex:identificador "S1" ;
    ex:textoExtracto "1 cabezal (S1)"@es .

ex:Tabla_ConfiguracionCanales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de canales, ejes y cabezales"@es ;
    ex:textoExtracto "Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | Canal ꞏ2ꞏ | Canal ꞏ3ꞏ | --- | --- | --- | --- | NCHANNEL = 3 | GEOCONFIG = Plano | GEOCONFIG = Plano |  | NAXIS = 6 | CHNAXIS = 2 | CHNAXIS = 2 | CHNAXIS = 2 | NSPDL = 2 | CHNSPDL = 1 | CHNSPDL = 1 | CHNSPDL = 0 |  | IPLANE = G18 | IPLANE = G18 |  |"@es .