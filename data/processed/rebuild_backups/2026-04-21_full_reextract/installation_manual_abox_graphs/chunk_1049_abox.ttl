@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Torno_3Canales_6Ejes_2Cabezales_ConfiguracionCanal3
    a               ex:Sistema ;
    rdfs:label      "Configuración de ejes y cabezales del canal 3 (torno 3 canales, 6 ejes, 2 cabezales)"@es ;
    ex:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ3ꞏ."@es ;
    ex:identificador "Canal 3"@es ;
    ex:tieneComponente
        ex:Eje_X1_Canal3 ,
        ex:Eje_Z1_Canal3 ,
        ex:Cabezal_S1_Canal3 .

ex:Eje_X1_Canal3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje X1 (canal 3)"@es ;
    ex:identificador "X1"@es , "3"@es ;
    ex:textoExtracto "CHAXISNAME 1 | X1 | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ."@es .

ex:Eje_Z1_Canal3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje Z1 (canal 3)"@es ;
    ex:identificador "Z1"@es , "4"@es ;
    ex:textoExtracto "CHAXISNAME 2 | Z1 | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ4ꞏ."@es .

ex:Cabezal_S1_Canal3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal S1 (canal 3)"@es ;
    ex:identificador "S1"@es , "8"@es ;
    ex:textoExtracto "CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ8ꞏ."@es .