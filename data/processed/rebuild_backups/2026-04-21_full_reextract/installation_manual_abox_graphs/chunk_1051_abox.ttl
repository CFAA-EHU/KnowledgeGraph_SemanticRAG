@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AXISTYPE
    a ex:Parametro ;
    rdfs:label "AXISTYPE" ;
    ex:textoExtracto "Parámetro: AXISTYPE | Valor: Rotativo." ;
    ex:valor "Rotativo" .

ex:Parametro_AXISMODE_Linearlike
    a ex:Parametro ;
    rdfs:label "AXISMODE (Linearlike)" ;
    ex:textoExtracto "AXISMODE | Linearlike." ;
    ex:valor "Linearlike" .

ex:Parametro_UNIDIR_SinFuncion
    a ex:Parametro ;
    rdfs:label "UNIDIR (Sin función para eje linearlike)" ;
    ex:textoExtracto "UNIDIR | Sin función." ;
    ex:valor "Sin función" .

ex:Parametro_SHORTESTWAY_SinFuncion
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY (Sin función para eje linearlike)" ;
    ex:textoExtracto "SHORTESTWAY | Sin función." ;
    ex:valor "Sin función" .

ex:Parametro_LIMIT_Positive
    a ex:Parametro ;
    rdfs:label "LIMIT+" ;
    ex:textoExtracto "LIMIT+ | Límites de recorrido." ;
    ex:valor "Límite superior de recorrido (grados)" .

ex:Parametro_LIMIT_Negative
    a ex:Parametro ;
    rdfs:label "LIMIT-" ;
    ex:textoExtracto "LIMIT- | Límites de recorrido." ;
    ex:valor "Límite inferior de recorrido (grados)" .

ex:Parametro_MODUPLIM_SinFuncion
    a ex:Parametro ;
    rdfs:label "MODUPLIM (Sin función para eje linearlike)" ;
    ex:textoExtracto "MODUPLIM | Sin función." ;
    ex:valor "Sin función" .

ex:Parametro_MODLOWLIM_SinFuncion
    a ex:Parametro ;
    rdfs:label "MODLOWLIM (Sin función para eje linearlike)" ;
    ex:textoExtracto "MODLOWLIM | Sin función." ;
    ex:valor "Sin función" .

ex:ModoOperacion_G90
    a ex:ModoOperacion ;
    rdfs:label "G90 (Posicionamiento absoluto)" ;
    ex:textoExtracto "Movimientos en G90: El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica la posición final." .

ex:ModoOperacion_G91
    a ex:ModoOperacion ;
    rdfs:label "G91 (Posicionamiento incremental)" ;
    ex:textoExtracto "Movimientos en G91: Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición." .

ex:Sistema_ConfiguracionEjeRotativo
    a ex:Sistema ;
    rdfs:label "Configuración de eje rotativo en CNC" ;
    ex:textoExtracto "El CNC admite diferentes formas de configurar un eje rotativo, en función de como va a realizar los desplazamientos. Así el CNC puede tener ejes rotativos con límites de recorrido, por ejemplo entre 0º y 180º (eje rotativo linearlike); ejes que siempre se desplacen en el mismo sentido (eje rotativo unidireccional); ejes que elijan el camino más corto (eje rotativo de posicionamiento)." ;
    ex:tieneComponente ex:Parametro_AXISTYPE, ex:Parametro_AXISMODE_Linearlike, ex:Parametro_UNIDIR_SinFuncion, ex:Parametro_SHORTESTWAY_SinFuncion, ex:Parametro_LIMIT_Positive, ex:Parametro_LIMIT_Negative, ex:Parametro_MODUPLIM_SinFuncion, ex:Parametro_MODLOWLIM_SinFuncion ;
    ex:monitoreaParametro ex:Parametro_AXISTYPE, ex:Parametro_LIMIT_Positive, ex:Parametro_LIMIT_Negative .

ex:Tabla_ComportamientoG90_G91 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Comportamiento de cotas en modos G90 y G91 para ejes rotativos" ;
    ex:textoExtracto "| Movimientos en G90 | Movimientos en G91 | --- | --- | El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica la posición final. | Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición." ;
    ex:documentadoEn ex:Sistema_ConfiguracionEjeRotativo ;
    ex:ilustradoEn ex:ModoOperacion_G90, ex:ModoOperacion_G91 .