@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes" ;
    ex:valor "igual" .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes" ;
    ex:valor "igual" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes" ;
    ex:valor "igual" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes" ;
    ex:valor "igual" .

ex:ModoOperacion_Tandem
    a ex:ModoOperacion ;
    rdfs:label "Configuración de eje tándem" ;
    ex:textoExtracto "Configurar dos ejes como un eje tándem" ;
    ex:monitoreaParametro ex:Parametro_AXISMODE ;
    ex:monitoreaParametro ex:Parametro_SHORTESTWAY ;
    ex:monitoreaParametro ex:Parametro_REFFEED1 ;
    ex:monitoreaParametro ex:Parametro_REFFEED2 .