@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CROSSCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación cruzada (CROSSCOMP)"@es ;
    ex:textoExtracto "MOVAXIS [...] Parámetro incluido en la tabla CROSSCOMP. [...] REFNEED [...] Parámetro incluido en la tabla CROSSCOMP."@es ;
    ex:tieneComponente
        ex:Parametro_MOVAXIS,
        ex:Parametro_COMPAXIS,
        ex:Parametro_NPCROSS,
        ex:Parametro_TYPCROSS,
        ex:Parametro_BIDIR,
        ex:Parametro_REFNEED .

ex:Parametro_MOVAXIS
    a ex:Parametro ;
    rdfs:label "MOVAXIS"@es ;
    ex:identificador "MPG.MOVAXIS[tbl]" ;
    ex:textoExtracto "MOVAXIS Eje que al moverse genera variaciones (maestro). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.MOVAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece cuál es el eje maestro en la compensación cruzada."@es .

ex:Parametro_COMPAXIS
    a ex:Parametro ;
    rdfs:label "COMPAXIS"@es ;
    ex:identificador "MPG.COMPAXIS[tbl]" ;
    ex:textoExtracto "COMPAXIS Eje que sufre variaciones (compensado). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.COMPAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece cuál es el eje compensado en la compensación cruzada."@es .

ex:Parametro_NPCROSS
    a ex:Parametro ;
    rdfs:label "NPCROSS"@es ;
    ex:identificador "MPG.NPCROSS[tbl]" ;
    ex:valor "0"^^<http://www.w3.org/2001/XMLSchema#integer> ;
    ex:textoExtracto "NPCROSS Número de puntos de la tabla. Valores posibles: De 0 a 1000. Valor por defecto: 0 (no hay tabla). Variable asociada: (V.)MPG.NPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP. Cada tabla de compensación cruzada puede disponer de hasta 1000 puntos."@es .

ex:Parametro_TYPCROSS
    a ex:Parametro ;
    rdfs:label "TYPCROSS"@es ;
    ex:identificador "MPG.TYPCROSS[tbl]" ;
    ex:valor "Real"@es ;
    ex:textoExtracto "TYPCROSS Método de compensación (tipo de cotas). Valores posibles: Real / Teórica. Valor por defecto: Real. Variable asociada: (V.)MPG.TYPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece si la compensación cruzada se realiza con las cotas teóricas o con las cotas reales."@es .

ex:Parametro_BIDIR
    a ex:Parametro ;
    rdfs:label "BIDIR"@es ;
    ex:identificador "MPG.BIDIR[tbl]" ;
    ex:valor "No"@es ;
    ex:textoExtracto "BIDIR Compensación bidireccional. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.BIDIR[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si la compensación es bidireccional; es decir, si hay distinta compensación en cada sentido."@es .

ex:Parametro_REFNEED
    a ex:Parametro ;
    rdfs:label "REFNEED"@es ;
    ex:identificador "MPG.REFNEED[tbl]" ;
    ex:valor "No"@es ;
    ex:textoExtracto "REFNEED Búsqueda de referencia necesaria para compensar. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación."@es .