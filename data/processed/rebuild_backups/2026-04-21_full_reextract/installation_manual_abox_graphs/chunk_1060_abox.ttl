@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosTandem_1060 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del eje tándem"@es ;
    ex:textoExtracto "Tabla de ejes o cabezales tándem."@es ;
    ex:tieneComponente
        ex:Param_TANDEM_1060, ex:Param_MASTERAXIS_1060, ex:Param_SLAVEAXIS_1060,
        ex:Param_TORQDIST_1060, ex:Param_PRELOAD_1060, ex:Param_PRELFITI_1060,
        ex:Param_TPROGAIN_1060, ex:Param_TINTIME_1060, ex:Param_TCOMPLIM_1060 .

ex:Param_TANDEM_1060
    a ex:Parametro ;
    rdfs:label "TANDEM" ;
    ex:identificador "TANDEM" ;
    ex:textoExtracto "Tabla de ejes o cabezales tándem."@es .

ex:Param_MASTERAXIS_1060
    a ex:Parametro ;
    rdfs:label "MASTERAXIS" ;
    ex:identificador "MASTERAXIS" ;
    ex:textoExtracto "Eje/cabezal maestro o principal."@es .

ex:Param_SLAVEAXIS_1060
    a ex:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ex:identificador "SLAVEAXIS" ;
    ex:textoExtracto "Eje/cabezal esclavo."@es .

ex:Param_TORQDIST_1060
    a ex:Parametro ;
    rdfs:label "TORQDIST" ;
    ex:identificador "TORQDIST" ;
    ex:textoExtracto "Distribución del par."@es .

ex:Param_PRELOAD_1060
    a ex:Parametro ;
    rdfs:label "PRELOAD" ;
    ex:identificador "PRELOAD" ;
    ex:textoExtracto "Precarga entre ambos motores."@es .

ex:Param_PRELFITI_1060
    a ex:Parametro ;
    rdfs:label "PRELFITI" ;
    ex:identificador "PRELFITI" ;
    ex:textoExtracto "Tiempo del filtro para aplicar la precarga."@es .

ex:Param_TPROGAIN_1060
    a ex:Parametro ;
    rdfs:label "TPROGAIN" ;
    ex:identificador "TPROGAIN" ;
    ex:textoExtracto "Ganancia proporcional (Kp) para el tándem."@es .

ex:Param_TINTIME_1060
    a ex:Parametro ;
    rdfs:label "TINTIME" ;
    ex:identificador "TINTIME" ;
    ex:textoExtracto "Ganancia integral (Ki) para el tándem."@es .

ex:Param_TCOMPLIM_1060
    a ex:Parametro ;
    rdfs:label "TCOMPLIM" ;
    ex:identificador "TCOMPLIM" ;
    ex:textoExtracto "Límite de la compensación."@es .