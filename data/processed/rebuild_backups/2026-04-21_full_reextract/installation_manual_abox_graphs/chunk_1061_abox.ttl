@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaTandem_1061
    a                     ex:Sistema ;
    rdfs:label            "Sistema tándem de ejes/cabezales"@es ;
    ex:textoExtracto       "Un sistema tándem podrá estar formado por una pareja de ejes lineales, de ejes rotativos o de cabezales. La pareja de ejes o cabezales que forman el sistema tándem se definen en los parámetros máquina MASTERAXIS y SLAVEAXIS, dentro de la tabla TANDEM."@es ;
    ex:tieneComponente     ex:MotorMaestro_1061, ex:MotorEsclavo_1061 ;
    ex:monitoreaParametro  ex:Parametro_MASTERAXIS_1061, ex:Parametro_SLAVEAXIS_1061, ex:Parametro_AXISNAME_1061, ex:Parametro_SPDLNAME_1061 ;
    ex:documentadoEn       ex:Tabla_TANDEM_1061 .

ex:MotorMaestro_1061
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Motor maestro del tándem"@es ;
    ex:textoExtracto       "El motor maestro del tándem, además de generar par, es el responsable del posicionamiento. El CNC cierra el lazo de posición únicamente con la posición del eje maestro del tándem."@es ;
    ex:controla            ex:MotorEsclavo_1061 ;
    ex:monitoreaParametro  ex:Parametro_ConsignaVelocidad_1061 .

ex:MotorEsclavo_1061
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Motor esclavo del tándem"@es ;
    ex:textoExtracto       "El motor esclavo únicamente suministra par. La consigna de velocidad del eje/cabezal maestro del tándem se envía también al eje/cabezal esclavo del tándem cerrando el lazo de velocidad."@es .

ex:Parametro_MASTERAXIS_1061
    a                     ex:Parametro ;
    rdfs:label            "MASTERAXIS"@es ;
    ex:identificador       "MASTERAXIS" ;
    ex:textoExtracto       "parámetro máquina MASTERAXIS [...] dentro de la tabla TANDEM"@es ;
    ex:documentadoEn       ex:Tabla_TANDEM_1061 .

ex:Parametro_SLAVEAXIS_1061
    a                     ex:Parametro ;
    rdfs:label            "SLAVEAXIS"@es ;
    ex:identificador       "SLAVEAXIS" ;
    ex:textoExtracto       "parámetro máquina [...] SLAVEAXIS, dentro de la tabla TANDEM"@es ;
    ex:documentadoEn       ex:Tabla_TANDEM_1061 .

ex:Parametro_AXISNAME_1061
    a                     ex:Parametro ;
    rdfs:label            "AXISNAME"@es ;
    ex:identificador       "AXISNAME" ;
    ex:textoExtracto       "Los ejes deberán estar previamente definidos en el parámetro AXISNAME"@es .

ex:Parametro_SPDLNAME_1061
    a                     ex:Parametro ;
    rdfs:label            "SPDLNAME"@es ;
    ex:identificador       "SPDLNAME" ;
    ex:textoExtracto       "los cabezales en el parámetro SPDLNAME"@es .

ex:Parametro_ConsignaVelocidad_1061
    a                     ex:Parametro ;
    rdfs:label            "Consigna de velocidad del tándem"@es ;
    ex:textoExtracto       "La consigna de velocidad del eje/cabezal maestro del tándem se envía también al eje/cabezal esclavo del tándem"@es ;
    ex:valor               "Sercos velocidad"@es .

ex:Tabla_TANDEM_1061 a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla TANDEM"@es ;
    ex:identificador       "TANDEM" ;
    ex:textoExtracto       "Los parámetros máquina MASTERAXIS y SLAVEAXIS [...] dentro de la tabla TANDEM"@es ;
    ex:documentadoEn       ex:Pagina_573_574 .