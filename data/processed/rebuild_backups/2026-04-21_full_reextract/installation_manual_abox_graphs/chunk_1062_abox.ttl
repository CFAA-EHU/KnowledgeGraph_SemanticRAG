@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionTandem_1062 a ex:Sistema ;
    rdfs:label "Configuración del eje tándem"@es ;
    ex:textoExtracto "Consideraciones para cabezales tándem. [...] La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem."@es ;
    ex:tieneComponente ex:MotorMaestro_1062, ex:MotorEsclavo_1062 ;
    ex:tieneComponente ex:Parametro_SPENA_1062, ex:Parametro_DRENA_1062 ;
    ex:tieneComponente ex:Parametro_PLCCNTL_1062, ex:Parametro_SPDLEREV_1062, ex:Parametro_SANALOG_1062 ;
    ex:controla ex:Parametro_DistribucionPar_1062 .

ex:MotorMaestro_1062 a ex:ComponenteElectrico ;
    rdfs:label "Motor maestro (cabezal tándem)"@es ;
    ex:textoExtracto "cabezal maestro"@es ;
    ex:monitoreaParametro ex:Parametro_DistribucionPar_1062 .

ex:MotorEsclavo_1062 a ex:ComponenteElectrico ;
    rdfs:label "Motor esclavo (cabezal tándem)"@es ;
    ex:textoExtracto "cabezal esclavo"@es ;
    ex:monitoreaParametro ex:Parametro_DistribucionPar_1062 .

ex:Parametro_SPENA_1062 a ex:Parametro ;
    rdfs:label "SPENA(axis)"@es ;
    ex:identificador "SPENA(axis)" ;
    ex:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) [...] de los cabezales maestro y esclavo simultáneamente."@es .

ex:Parametro_DRENA_1062 a ex:Parametro ;
    rdfs:label "DRENA(axis)"@es ;
    ex:identificador "DRENA(axis)" ;
    ex:textoExtracto "El PLC deba habilitar y deshabilitar las señales [...] DRENA(axis) de los cabezales maestro y esclavo simultáneamente."@es .

ex:Parametro_PLCCNTL_1062 a ex:Parametro ;
    rdfs:label "PLCCNTL" ;
    ex:identificador "PLCCNTL" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro."@es .

ex:Parametro_SPDLEREV_1062 a ex:Parametro ;
    rdfs:label "SPDLEREV" ;
    ex:identificador "SPDLEREV" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro."@es .

ex:Parametro_SANALOG_1062 a ex:Parametro ;
    rdfs:label "SANALOG" ;
    ex:identificador "SANALOG" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro."@es .

ex:Parametro_DistribucionPar_1062 a ex:Parametro ;
    rdfs:label "Distribución del par en tándem"@es ;
    ex:textoExtracto "La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem."@es ;
    ex:valor "porcentaje"@es .