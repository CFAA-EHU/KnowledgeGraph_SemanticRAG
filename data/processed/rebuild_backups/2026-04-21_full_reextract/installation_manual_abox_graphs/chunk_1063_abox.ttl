@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TORQDIST
    a ex:Parametro ;
    rdfs:label "TORQDIST" ;
    ex:textoExtracto "La distribución del par en el tándem se define con el parámetro TORQDIST, el cual indica qué porcentaje debe dar el motor maestro." ;
    ex:valor "50%"^^xsd:string .

ex:Parametro_PRELOAD
    a ex:Parametro ;
    rdfs:label "PRELOAD" ;
    ex:textoExtracto "La precarga se define con el parámetro PRELOAD, el cual indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." .

ex:Parametro_PRELFITI
    a ex:Parametro ;
    rdfs:label "PRELFITI" ;
    ex:textoExtracto "Para aplicar la precarga de una forma gradual [...] se puede definir el parámetro PRELFITI. Este parámetro habilita un filtro de primer orden que establece el tiempo que tarda el CNC en aplicar la precarga de forma progresiva." .

ex:Parametro_TPROGAIN
    a ex:Parametro ;
    rdfs:label "TPROGAIN" ;
    ex:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN." .

ex:Sistema_Tandem
    a ex:Sistema ;
    rdfs:label "Sistema de eje tándem" ;
    ex:textoExtracto "Distribución del par en el tándem. [...] La aplicación del valor de precarga implica necesariamente la unión mecánica entre los motores maestro y esclavo que forman el tándem." ;
    ex:tieneComponente ex:Motor_Maestro, ex:Motor_Esclavo ;
    ex:monitoreaParametro ex:Parametro_TORQDIST, ex:Parametro_PRELOAD, ex:Parametro_PRELFITI, ex:Parametro_TPROGAIN .

ex:Motor_Maestro
    a ex:ComponenteMecanico ;
    rdfs:label "Motor maestro del tándem" ;
    ex:textoExtracto "el parámetro TORQDIST [...] indica qué porcentaje debe dar el motor maestro. [...] PRELOAD [...] indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." .

ex:Motor_Esclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Motor esclavo del tándem" ;
    ex:textoExtracto "La diferencia entre el valor de este parámetro [TORQDIST] y el 100% es el porcentaje que se aplicará al motor esclavo." .