@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TPROGAIN
    a               ex:Parametro ;
    rdfs:label      "Ganancia proporcional (Kp) para el eje tándem"@es ;
    ex:identificador "TPROGAIN" ;
    ex:textoExtracto "Ganancia proporcional (Kp) para el tándem. [...] La ganancia proporcional se puede definir con el parámetro TPROGAIN."@es ;
    ex:valor         "Kp"@es .

ex:Parametro_KiTandem
    a               ex:Parametro ;
    rdfs:label      "Ganancia integral (Ki) para el eje tándem"@es ;
    ex:textoExtracto "Ganancia integral (Ki) para el tándem."@es ;
    ex:valor         "Ki"@es .

ex:Sistema_ControlTandem
    a               ex:Sistema ;
    rdfs:label      "Sistema de control del eje tándem"@es ;
    ex:textoExtracto "El controlador proporcional genera una salida proporcional al error en par entre los dos motores."@es ;
    ex:monitoreaParametro ex:Parametro_TPROGAIN ;
    ex:monitoreaParametro ex:Parametro_KiTandem .