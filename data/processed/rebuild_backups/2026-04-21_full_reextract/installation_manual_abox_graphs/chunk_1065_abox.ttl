@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TPROGAIN
    a ex:Parametro ;
    rdfs:label "Ganancia proporcional del eje tándem (TPROGAIN)"@es ;
    ex:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN."@es ;
    ex:identificador "TPROGAIN" .

ex:Parametro_TINTTIME
    a ex:Parametro ;
    rdfs:label "Ganancia integral del eje tándem (TINTTIME)"@es ;
    ex:textoExtracto "La ganancia integral se puede definir con el parámetro TINTTIME."@es ;
    ex:identificador "TINTTIME" .

ex:Sistema_ControlTandem
    a ex:Sistema ;
    rdfs:label "Sistema de control del eje tándem"@es ;
    ex:textoExtracto "genera una salida proporcional al error en par entre los dos motores. [...] El controlador integral genera una salida proporcional a la integral del error en par entre los dos motores."@es ;
    ex:monitoreaParametro ex:Parametro_TPROGAIN ;
    ex:monitoreaParametro ex:Parametro_TINTTIME .