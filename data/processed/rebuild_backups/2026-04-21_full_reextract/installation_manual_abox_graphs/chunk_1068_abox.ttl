@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjeTandem_1068
    a ex:Sistema ;
    rdfs:label "Configuración del eje tándem"@es ;
    ex:textoExtracto "Distribución de par. Ganancia de normalización de los pares generados por los motores cuyo fin es establecer un reparto de pares que no siga una relación 1:1. Precarga. Par previo aplicado a ambos ejes del tándem en sentidos opuestos. De esta manera se establece una tracción entre ellos con el fin de eliminar la holgura piñón-cremallera cuando se encuentra en reposo. Se determina como la diferencia de par que suministra cada uno de los ejes."@es ;
    ex:tieneComponente ex:MotorTandemIzquierdo_1068, ex:MotorTandemDerecho_1068 ;
    ex:tieneComponente ex:PinonCremalleraTandem_1068 .

ex:MotorTandemIzquierdo_1068
    a ex:ComponenteMecanico ;
    rdfs:label "Motor del eje tándem (izquierdo)"@es ;
    ex:textoExtracto "pares generados por los motores cuyo fin es establecer un reparto de pares"@es .

ex:MotorTandemDerecho_1068
    a ex:ComponenteMecanico ;
    rdfs:label "Motor del eje tándem (derecho)"@es ;
    ex:textoExtracto "pares generados por los motores cuyo fin es establecer un reparto de pares"@es .

ex:PinonCremalleraTandem_1068
    a ex:ComponenteMecanico ;
    rdfs:label "Sistema piñón-cremallera del eje tándem"@es ;
    ex:textoExtracto "eliminar la holgura piñón-cremallera cuando se encuentra en reposo"@es .