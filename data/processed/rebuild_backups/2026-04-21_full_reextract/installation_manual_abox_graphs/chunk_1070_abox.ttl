@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_1070_VariablesTandem a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables asociadas al tándem (pág. 579)"@es ;
    ex:textoExtracto """
Variables asociadas a los parámetros máquina generales. Estas variables son de lectura síncrona y se evalúan durante la preparación de bloques. Las denominaciones de las variables son genéricas. Sustituir el carácter 'nb' por números, conservando los corchetes.
| Variable | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)MPG.TMASTERAXIS[nb] - Tándem [nb]. Número lógico del eje maestro | R | R | R |
| (V.)MPG.TSLAVEAXIS[nb] - Tándem [nb]. Número lógico del eje esclavo | R | R | R |
| (V.)MPG.TORQDIST[nb] - Tándem [nb]. Distribución del par | R | R | R |
| (V.)MPG.PRELOAD[nb] - Tándem [nb]. Precarga | R | R | R |
| (V.)MPG.PRELFITI[nb] - Tándem [nb]. Tiempo para aplicar la precarga | R | R | R |
| (V.)MPG.TPROGAIN[nb] - Tándem [nb]. Ganancia proporcional | R | R | R |
| (V.)MPG.TINTIME[nb] - Tándem [nb]. Ganancia integral | R | R | R |
| (V.)MPG.TCOMPLIM[nb] - Tándem [nb]. Limitación de la compensación | R | R | R |
""" .

ex:Parametro_TMASTERAXIS
    a ex:Parametro ;
    rdfs:label "MPG.TMASTERAXIS[nb]" ;
    ex:identificador "MPG.TMASTERAXIS[nb]" ;
    ex:textoExtracto "(V.)MPG.TMASTERAXIS[nb] - Tándem [nb]. Número lógico del eje maestro"@es ;
    ex:documentadoEn ex:Tabla_1070_VariablesTandem .

