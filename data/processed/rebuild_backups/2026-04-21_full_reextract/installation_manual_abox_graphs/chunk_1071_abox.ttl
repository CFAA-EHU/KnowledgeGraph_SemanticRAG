@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_11.2.4_VariablesTandem
    a                       ex:Tabla ;
    rdfs:label              "Tabla de variables asociadas al tándem (11.2.4)" ;
    ex:textoExtracto        "Los mnemónicos de las variables son genéricos. • Sustituir el carácter \"xn\" por el nombre o número lógico del eje. • Sustituir el carácter \"ch\" por el número de canal, conservando los corchetes. |  | PRG | PLC | INT | --- | --- | --- | --- | (V.)[ch].A.TPIIN.xn | Entrada del PI del eje maestro del tándem (en rpm) | R | R | R | (V.)[ch].A.TPIOUT.xn | Salida del PI del eje maestro del tándem (en rpm) | R | R | R | (V.)[ch].A.TFILTOUT.xn | Salida del filtro de precarga | R | R | R | (V.)[ch].A.PRELOAD.xn | Precarga | R/W | R/W | R/W | (V.)[ch].A.FTEO.xn | Consigna de velocidad para Sercos | R | R | R | (V.)[ch].A.TORQUE.xn | Par de corriente en Sercos | R | R | R | (V.)A.TPIOUT.[Xn] (V.)A.TPIIN.[Xn] El eje debe ser un eje maestro tándem válido, en caso contrario devuelve valor cero. (V.)A.TORQUE La lectura desde el PLC de esta variable vendrá expresada en décimas (x10)." .

ex:Parametro_TPIIN
    a                       ex:Parametro ;
    rdfs:label              "Entrada del PI del eje maestro del tándem (TPIIN)" ;
    ex:identificador        "(V.)[ch].A.TPIIN.xn" ;
    ex:valor                 "rpm" ;
    ex:textoExtracto        "(V.)[ch].A.TPIIN.xn | Entrada del PI del eje maestro del tándem (en rpm)" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .

ex:Parametro_TPIOUT
    a                       ex:Parametro ;
    rdfs:label              "Salida del PI del eje maestro del tándem (TPIOUT)" ;
    ex:identificador        "(V.)[ch].A.TPIOUT.xn" ;
    ex:valor                 "rpm" ;
    ex:textoExtracto        "(V.)[ch].A.TPIOUT.xn | Salida del PI del eje maestro del tándem (en rpm)" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .

ex:Parametro_TFILTOUT
    a                       ex:Parametro ;
    rdfs:label              "Salida del filtro de precarga (TFILTOUT)" ;
    ex:identificador        "(V.)[ch].A.TFILTOUT.xn" ;
    ex:textoExtracto        "(V.)[ch].A.TFILTOUT.xn | Salida del filtro de precarga" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .

ex:Parametro_PRELOAD
    a                       ex:Parametro ;
    rdfs:label              "Precarga (PRELOAD)" ;
    ex:identificador        "(V.)[ch].A.PRELOAD.xn" ;
    ex:textoExtracto        "(V.)[ch].A.PRELOAD.xn | Precarga | R/W | R/W | R/W" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .

ex:Parametro_FTEO
    a                       ex:Parametro ;
    rdfs:label              "Consigna de velocidad para Sercos (FTEO)" ;
    ex:identificador        "(V.)[ch].A.FTEO.xn" ;
    ex:textoExtracto        "(V.)[ch].A.FTEO.xn | Consigna de velocidad para Sercos" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .

ex:Parametro_TORQUE
    a                       ex:Parametro ;
    rdfs:label              "Par de corriente en Sercos (TORQUE)" ;
    ex:identificador        "(V.)[ch].A.TORQUE.xn" ;
    ex:valor                 "décimas (x10)" ;
    ex:textoExtracto        "(V.)[ch].A.TORQUE.xn | Par de corriente en Sercos | (V.)A.TORQUE La lectura desde el PLC de esta variable vendrá expresada en décimas (x10)" ;
    ex:documentadoEn        ex:Tabla_11.2.4_VariablesTandem .