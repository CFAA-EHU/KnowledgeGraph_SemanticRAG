@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ANAOUTID
    a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Número de la salida analógica asociada al eje. // 1 - 16" ;
    ex:valor "1-16" .

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "Tipo de entrada de captación del eje." .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "Número de la entrada de captación del eje." .

ex:Sistema_ModulosRemotosCANfagor
    a ex:Sistema ;
    rdfs:label "Módulos remotos CANfagor" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los módulos remotos CANfagor." ;
    ex:tieneComponente ex:Parametro_ANAOUTID .

ex:Sistema_ReguladoresSercos
    a ex:Sistema ;
    rdfs:label "Reguladores Sercos" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos." ;
    ex:tieneComponente ex:Parametro_ANAOUTID .

ex:Tabla_ConfiguracionEjesAnalogicos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Configuración de parámetros para ejes analógicos" ;
    ex:textoExtracto "Cada eje dispone de los siguientes parámetros máquina para su configuración." ;
    ex:documentadoEn ex:Pagina_581_582 ;
    ex:tieneComponente ex:Parametro_ANAOUTID , ex:Parametro_COUNTERTYPE , ex:Parametro_COUNTERID .

ex:Pagina_581_582
    a ex:Pagina ;
    rdfs:label "Páginas 581-582" ;
    ex:identificador "581-582" ;
    ex:textoExtracto "11.3 Ejes analógicos. - 11.3.1 Configurar el número de salida analógica y de la entrada de captación." .