@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjesCompartidos_1077
    a                     ex:Sistema ;
    rdfs:label            "Configuración de 2 ejes con misma entrada captación y salida analógica"@es ;
    ex:textoExtracto      "Hay máquinas donde existen 2 ejes que nunca están de forma simultánea en la misma configuración, ya que uno de ellos está siempre aparcado; por ejemplo, en el caso de cambio de cabezales con motor interior para mover su articulación. En estos casos, ambos motores están controlados por el mismo regulador y para el CNC sólo hay una entrada de captación y una salida analógica."@es ;
    ex:tieneComponente    ex:MotorEje1_1077, ex:MotorEje2_1077 ;
    ex:controla          ex:Parametro_COUNTERTYPE_1077, ex:Parametro_COUNTERID_1077, ex:Parametro_ANAOUTID_1077 ;
    ex:detalladoEnEsquema ex:TablaParametrosEjes_1077 .

ex:MotorEje1_1077
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor del eje 1 (cabezal aparcado)"@es ;
    ex:textoExtracto "ambos motores están controlados por el mismo regulador... aunque los motores son iguales, los ejes son totalmente distintos"@es .

ex:MotorEje2_1077
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor del eje 2 (cabezal activo)"@es ;
    ex:textoExtracto "ambos motores están controlados por el mismo regulador... aunque los motores son iguales, los ejes son totalmente distintos"@es .

ex:Parametro_COUNTERTYPE_1077
    a               ex:Parametro ;
    rdfs:label      "COUNTERTYPE" ;
    ex:identificador "COUNTERTYPE" ;
    ex:textoExtracto "los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales"@es ;
    ex:valor         "igual para ambos ejes"@es .

ex:Parametro_COUNTERID_1077
    a               ex:Parametro ;
    rdfs:label      "COUNTERID" ;
    ex:identificador "COUNTERID" ;
    ex:textoExtracto "los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales"@es ;
    ex:valor         "igual para ambos ejes"@es .

ex:Parametro_ANAOUTID_1077
    a               ex:Parametro ;
    rdfs:label      "ANAOUTID" ;
    ex:identificador "ANAOUTID" ;
    ex:textoExtracto "el parámetro ANAOUTID de ambos ejes también debe ser igual"@es ;
    ex:valor         "igual para ambos ejes"@es .

ex:TablaParametrosEjes_1077 a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Parámetros máquina para ejes compartidos"@es ;
    ex:textoExtracto      "| Parámetro | Significado | --- | --- | ABSFEEDBACK | Tipo de captación. | SINMAGNI | Factor multiplicador de la señal sinusoidal. | I0TYPE | Tipo de I0. | REFPULSE | Flanco de la señal de I0. | ABSOFF | Offset del captador respecto a I0. | EXTMULT | Factor multiplicador externo. | I0CODDI1 | Paso entre señales de I0 fijas. | I0CODDI2 | Paso entre señales de I0 variables."@es ;
    ex:documentadoEn      ex:ConfiguracionEjesCompartidos_1077 .

ex:Parametro_ABSFEEDBACK_1077
    a               ex:Parametro ;
    rdfs:label      "ABSFEEDBACK" ;
    ex:identificador "ABSFEEDBACK" ;
    ex:textoExtracto "Tipo de captación"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_SINMAGNI_1077
    a               ex:Parametro ;
    rdfs:label      "SINMAGNI" ;
    ex:identificador "SINMAGNI" ;
    ex:textoExtracto "Factor multiplicador de la señal sinusoidal"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_I0TYPE_1077
    a               ex:Parametro ;
    rdfs:label      "I0TYPE" ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "Tipo de I0"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_REFPULSE_1077
    a               ex:Parametro ;
    rdfs:label      "REFPULSE" ;
    ex:identificador "REFPULSE" ;
    ex:textoExtracto "Flanco de la señal de I0"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_ABSOFF_1077
    a               ex:Parametro ;
    rdfs:label      "ABSOFF" ;
    ex:identificador "ABSOFF" ;
    ex:textoExtracto "Offset del captador respecto a I0"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_EXTMULT_1077
    a               ex:Parametro ;
    rdfs:label      "EXTMULT" ;
    ex:identificador "EXTMULT" ;
    ex:textoExtracto "Factor multiplicador externo"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_I0CODDI1_1077
    a               ex:Parametro ;
    rdfs:label      "I0CODDI1" ;
    ex:identificador "I0CODDI1" ;
    ex:textoExtracto "Paso entre señales de I0 fijas"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .

ex:Parametro_I0CODDI2_1077
    a               ex:Parametro ;
    rdfs:label      "I0CODDI2" ;
    ex:identificador "I0CODDI2" ;
    ex:textoExtracto "Paso entre señales de I0 variables"@es ;
    ex:valor         "debe ser igual en ambos ejes"@es .