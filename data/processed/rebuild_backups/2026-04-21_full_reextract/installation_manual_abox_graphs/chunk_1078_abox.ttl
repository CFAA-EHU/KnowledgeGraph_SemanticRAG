@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:GrupoMultieje_1078
    a               ex:Sistema ;
    rdfs:label      "Grupo multieje (A1 + A2)"@es ;
    ex:textoExtracto "Un grupo multieje consiste en varios ejes o cabezales Sercos controlados por un único regulador, aunque no de forma simultánea. [...] Grupo multieje compuesto por dos ejes, cada uno controlado por un motor."@es ;
    ex:tieneComponente ex:Eje_A1_1078, ex:Eje_A2_1078 ;
    ex:compuestoPor ex:Motor_A1_1078, ex:Motor_A2_1078 .

ex:Eje_A1_1078
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje A1"@es ;
    ex:identificador "A1" ;
    ex:textoExtracto "Axis A1"@en ;
    ex:controla ex:Motor_A1_1078 .

ex:Eje_A2_1078
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje A2"@es ;
    ex:identificador "A2" ;
    ex:textoExtracto "Axis A2"@en ;
    ex:controla ex:Motor_A2_1078 .

ex:Motor_A1_1078
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor del eje A1"@es ;
    ex:textoExtracto "cada uno controlado por un motor"@es .

ex:Motor_A2_1078
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor del eje A2"@es ;
    ex:textoExtracto "cada uno controlado por un motor"@es .