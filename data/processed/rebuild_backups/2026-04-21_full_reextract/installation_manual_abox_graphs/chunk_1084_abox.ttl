@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MULTIAXIS
    a ex:Parametro ;
    rdfs:label "MULTIAXIS" ;
    ex:textoExtracto "Tabla de grupos multieje." ;
    ex:valor "Tabla de definición de grupos multieje" .

ex:Parametro_MULNGROUP
    a ex:Parametro ;
    rdfs:label "MULNGROUP" ;
    ex:textoExtracto "Número de grupos multieje en el sistema." ;
    ex:valor "Número de grupos multieje" .

ex:Parametro_GROUP_n
    a ex:Parametro ;
    rdfs:label "GROUP_n" ;
    ex:textoExtracto "Grupos multieje." ;
    ex:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje." .

ex:Parametro_MULNAXIS
    a ex:Parametro ;
    rdfs:label "MULNAXIS" ;
    ex:textoExtracto "Número de ejes y/o cabezales que forman el grupo multieje." ;
    ex:valor "Número de ejes/cabezales por grupo" .

ex:Parametro_MULAXISNAME_n
    a ex:Parametro ;
    rdfs:label "MULAXISNAME_n" ;
    ex:textoExtracto "Nombre de los ejes y/o cabezales del grupo." ;
    ex:textoExtracto "La tabla muestra un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje." .

ex:Tabla_ConfiguracionMultieje a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de grupos multieje" ;
    ex:textoExtracto "El parámetro MULTIAXIS muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo." ;
    ex:detalladoEnEsquema ex:Parametro_MULTIAXIS ;
    ex:tieneComponente ex:Parametro_MULNGROUP, ex:Parametro_GROUP_n, ex:Parametro_MULNAXIS, ex:Parametro_MULAXISNAME_n .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Los grupos multieje se configuran desde los parámetros máquina." ;
    ex:tieneComponente ex:Tabla_ConfiguracionMultieje ;
    ex:monitoreaParametro ex:Parametro_MULTIAXIS, ex:Parametro_MULNGROUP, ex:Parametro_GROUP_n, ex:Parametro_MULNAXIS, ex:Parametro_MULAXISNAME_n .