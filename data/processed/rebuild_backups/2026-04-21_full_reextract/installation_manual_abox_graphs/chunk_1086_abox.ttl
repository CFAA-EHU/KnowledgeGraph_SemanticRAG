@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DRIVESET
    a ex:Parametro ;
    rdfs:label "DRIVESET" ;
    ex:textoExtracto "Set del regulador a utilizar. En los ejes que pertenecen a un grupo multieje, el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC (G112 y M41 a M44)." ;
    ex:identificador "DRIVESET" .

ex:Parametro_FFGAIN
    a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:textoExtracto "feed forward (parámetro FFGAIN)" ;
    ex:identificador "FFGAIN" .

ex:Parametro_ACFGAIN
    a ex:Parametro ;
    rdfs:label "ACFGAIN" ;
    ex:textoExtracto "AC forward (parámetro ACFGAIN)" ;
    ex:identificador "ACFGAIN" .

ex:Tabla_ParametrosMultieje a ex:Tabla ;
     a ex:Tabla ;
    ex:documentadoEn ex:Pagina_586 ;
    ex:textoExtracto "Tabla de parámetros para configuración de grupo multieje: DRIVESET, FFGAIN, ACFGAIN." ;
    ex:tieneComponente ex:Parametro_DRIVESET ;
    ex:tieneComponente ex:Parametro_FFGAIN ;
    ex:tieneComponente ex:Parametro_ACFGAIN .

ex:Pagina_586
    a ex:Pagina ;
    ex:identificador "586" ;
    ex:textoExtracto "Sección 11.4.1 Configuración de un grupo multieje. Los parámetros máquina." .