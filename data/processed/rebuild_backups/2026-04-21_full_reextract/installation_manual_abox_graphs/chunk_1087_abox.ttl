@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "Tipo de entrada de captación del eje; regulador, local o remota." ;
    ex:identificador "COUNTERTYPE" .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "Número de la entrada de captación del eje." ;
    ex:identificador "COUNTERID" .

ex:Parametro_PP5
    a ex:Parametro ;
    rdfs:label "PP5" ;
    ex:textoExtracto "Cuando la captación interna (motor) y la captación externa (directa) de un eje estén en reguladores diferentes, en el regulador que recibe la captación externa parametrizar el parámetro PP5=-0,0001." ;
    ex:identificador "PP5" ;
    ex:valor "-0.0001" .

ex:Tabla_ParametrosCaptacionEje a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de captación del eje" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | COUNTERTYPE | Tipo de entrada de captación del eje; regulador, local o remota. | COUNTERID | Número de la entrada de captación del eje." ;
    ex:documentadoEn ex:Pagina_586 .

ex:Sistema_CaptacionEje
    a ex:Sistema ;
    rdfs:label "Sistema de captación de eje" ;
    ex:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador. [...] Cuando el eje utiliza la segunda entrada de captación de otro regulador, el CNC no permite realizar su búsqueda de referencia, por lo que el eje debe disponer de captación absoluta." ;
    ex:tieneComponente ex:ComponenteElectrico_EntradaCaptacionInterna ;
    ex:tieneComponente ex:ComponenteElectrico_EntradaCaptacionExterna ;
    ex:detalladoEnEsquema ex:Tabla_ParametrosCaptacionEje .

ex:ComponenteElectrico_EntradaCaptacionInterna
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada de captación interna (motor)" ;
    ex:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador." ;
    ex:monitoreaParametro ex:Parametro_COUNTERTYPE .

ex:ComponenteElectrico_EntradaCaptacionExterna
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada de captación externa (directa)" ;
    ex:textoExtracto "El parámetro COUNTERTYPE indica dónde está ubicada la entrada para la captación externa (directa) del eje; en los módulos remotos (4 entradas por módulo, TTL diferencial y senoidal 1 Vpp), en la captación libre de un regulador Sercos o en las entradas de captación locales de la unidad central." ;
    ex:monitoreaParametro ex:Parametro_COUNTERID .

ex:Esquema_ELUDOM_EVIRD
    a ex:Esquema ;
    rdfs:label "Esquema de conexión ELUDOM EVIRD" ;
    ex:textoExtracto "POWER SUPPLY COUNTER DIGITAL INPUT ELUDOM EVIRD 4 X X X 1 2 3 DIGITAL G G N N N NI IIIIII . . 1 111111 C CI IIIIIII ID D6 012345 O 8 1234567 9 . . UTP X X U 1 2 T SS SS C C C C HH HH A AG G II IIA A EE EE N N N N N N LL LL H H DD DDD D L L X X 3 2 X X 4 5 + + G G 2OOOOOOO 2 4N N O OOOOOOO O111111 4 1 V V D D 012345 8 1234567 9 6" ;
    ex:ilustradoEn ex:Pagina_588 .