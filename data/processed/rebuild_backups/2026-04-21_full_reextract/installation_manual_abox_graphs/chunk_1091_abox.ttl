@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DriveSet
    a ex:Parametro ;
    rdfs:label "DRIVESET" ;
    ex:textoExtracto "El regulador activa la gama definida en el parámetro DRIVESET del set programado." .

ex:Parametro_CaxSet
    a ex:Parametro ;
    rdfs:label "CAXSET" ;
    ex:textoExtracto "El CNC activa el set definido en el parámetro CAXSET. [...] El regulador activa la gama definida en el parámetro CAXSET." .

ex:Funcion_G112 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "G112" ;
    ex:identificador "G112" ;
    ex:textoExtracto "G112 (solo ejes) | El CNC activa el set programado. | El regulador activa la gama definida en el parámetro DRIVESET del set programado." ;
    ex:controla ex:Parametro_DriveSet .

ex:Funcion_M41_M44 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "M41-M44" ;
    ex:identificador "M41-M44" ;
    ex:textoExtracto "M41-M44 (solo cabezales) | El CNC activa el set programado. | El regulador activa la gama definida en el parámetro DRIVESET del set programado." ;
    ex:controla ex:Parametro_DriveSet .

ex:Funcion_V_A_SETGE_xn a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "A.SETGE.xn" ;
    ex:identificador "A.SETGE.xn" ;
    ex:textoExtracto "(V.)A.SETGE.xn | Sin función [en CNC]. | El regulador activa el set y/o la gama programada." .

ex:Funcion_CAX_ON a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "#CAX ON" ;
    ex:identificador "CAX ON" ;
    ex:textoExtracto "#CAX ON | El CNC activa el set definido en el parámetro CAXSET. | El regulador activa la gama definida en el parámetro CAXSET." ;
    ex:controla ex:Parametro_CaxSet .

ex:Funcion_CAX_OFF a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "#CAX OFF" ;
    ex:identificador "CAX OFF" ;
    ex:textoExtracto "#CAX OFF | El CNC recupera el set que se encontraba activo antes de habilitar el cabezal como eje C. | El regulador recupera la gama que se encontraba activa antes de habilitar el cabezal como eje C." .

ex:Tabla_11_4_3_FuncionesSetGama a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Funciones para cambio de set/gama en CNC y regulador" ;
    ex:textoExtracto "Tabla de funciones G112, M41-M44, A.SETGE.xn, #CAX ON/OFF y su comportamiento en CNC/regulador." ;
    ex:documentadoEn ex:Pagina_590 ;
    ex:ilustradoEn [
        a ex:ModoOperacion ;
        ex:tieneComponente ex:Funcion_G112, ex:Funcion_M41_M44, ex:Funcion_V_A_SETGE_xn, ex:Funcion_CAX_ON, ex:Funcion_CAX_OFF
    ] .

ex:Pagina_590
    a ex:Pagina ;
    rdfs:label "Página 590 (Sección 11.4.3)" ;
    ex:identificador "590" ;
    ex:textoExtracto "Sección 11.4.3: Cómo cambiar el set y la gama en el CNC y el regulador." ;
    ex:documentadoEn ex:Manual_Broaching .