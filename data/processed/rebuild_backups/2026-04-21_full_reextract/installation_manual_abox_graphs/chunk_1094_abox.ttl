@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionGrupoMultieje_1094
    a ex:Sistema ;
    rdfs:label "Configuración del grupo multieje (GROUP_1)" ;
    ex:textoExtracto "Configuración del grupo multieje. | MULTIAXIS | GROUP_1 |" ;
    ex:identificador "GROUP_1" ;
    ex:tieneComponente ex:Eje_A1_1094, ex:Eje_A2_1094 ;
    ex:compuestoPor ex:Parametro_MULNGROUP_1094, ex:Parametro_MULNAXIS_1094 .

ex:Eje_A1_1094
    a ex:ComponenteMecanico ;
    rdfs:label "Eje A1" ;
    ex:textoExtracto "Eje A1 | 1 | Velocidad | Externa Remoto | 1" ;
    ex:identificador "A1" ;
    ex:monitoreaParametro ex:Parametro_DRIVEID_A1_1094, ex:Parametro_OPMODEP_A1_1094, ex:Parametro_FBACKSRC_A1_1094, ex:Parametro_COUNTERID_A1_1094 .

ex:Eje_A2_1094
    a ex:ComponenteMecanico ;
    rdfs:label "Eje A2" ;
    ex:textoExtracto "Eje A2 | 1 | Velocidad | Externa Remoto | 2" ;
    ex:identificador "A2" ;
    ex:monitoreaParametro ex:Parametro_DRIVEID_A2_1094, ex:Parametro_OPMODEP_A2_1094, ex:Parametro_FBACKSRC_A2_1094, ex:Parametro_COUNTERID_A2_1094 .

ex:Parametro_MULNGROUP_1094
    a ex:Parametro ;
    rdfs:label "MULNGROUP" ;
    ex:textoExtracto "MULNGROUP = 1" ;
    ex:identificador "MULNGROUP" ;
    ex:valor "1" .

ex:Parametro_MULNAXIS_1094
    a ex:Parametro ;
    rdfs:label "MULNAXIS" ;
    ex:textoExtracto "MULNAXIS | MULAXI | 2 = A1 = A2" ;
    ex:identificador "MULNAXIS" ;
    ex:valor "A1, A2" .

ex:Parametro_DRIVEID_A1_1094
    a ex:Parametro ;
    rdfs:label "DRIVEID (Eje A1)" ;
    ex:textoExtracto "DRIVEID | 1" ;
    ex:identificador "DRIVEID_A1" ;
    ex:valor "1" .

ex:Parametro_OPMODEP_A1_1094
    a ex:Parametro ;
    rdfs:label "OPMODEP (Eje A1)" ;
    ex:textoExtracto "OPMODEP | Velocidad" ;
    ex:identificador "OPMODEP_A1" ;
    ex:valor "Velocidad" .

ex:Parametro_FBACKSRC_A1_1094
    a ex:Parametro ;
    rdfs:label "FBACKSRC (Eje A1)" ;
    ex:textoExtracto "FBACKSRC | Externa Remoto" ;
    ex:identificador "FBACKSRC_A1" ;
    ex:valor "Externa Remoto" .

ex:Parametro_COUNTERID_A1_1094
    a ex:Parametro ;
    rdfs:label "COUNTERID (Eje A1)" ;
    ex:textoExtracto "COUNTERID | 1" ;
    ex:identificador "COUNTERID_A1" ;
    ex:valor "1" .

ex:Parametro_DRIVEID_A2_1094
    a ex:Parametro ;
    rdfs:label "DRIVEID (Eje A2)" ;
    ex:textoExtracto "DRIVEID | 1" ;
    ex:identificador "DRIVEID_A2" ;
    ex:valor "1" .

ex:Parametro_OPMODEP_A2_1094
    a ex:Parametro ;
    rdfs:label "OPMODEP (Eje A2)" ;
    ex:textoExtracto "OPMODEP | Velocidad" ;
    ex:identificador "OPMODEP_A2" ;
    ex:valor "Velocidad" .

ex:Parametro_FBACKSRC_A2_1094
    a ex:Parametro ;
    rdfs:label "FBACKSRC (Eje A2)" ;
    ex:textoExtracto "FBACKSRC | Externa Remoto" ;
    ex:identificador "FBACKSRC_A2" ;
    ex:valor "Externa Remoto" .

ex:Parametro_COUNTERID_A2_1094
    a ex:Parametro ;
    rdfs:label "COUNTERID (Eje A2)" ;
    ex:textoExtracto "COUNTERID | 2" ;
    ex:identificador "COUNTERID_A2" ;
    ex:valor "2" .