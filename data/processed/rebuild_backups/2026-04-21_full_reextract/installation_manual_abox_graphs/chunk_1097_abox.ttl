@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaBusquedaReferencia_1097
    a                   ex:Sistema ;
    rdfs:label          "Sistema de búsqueda de referencia máquina (ejes y cabezales)"@es ;
    ex:textoExtracto    "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados... El fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina."@es ;
    ex:tieneComponente   ex:MicroReferencia_1097 ;
    ex:monitoreaParametro
        ex:Parametro_I0TYPE_1097 ,
        ex:Parametro_DECINPUT_1097 ,
        ex:Parametro_REFDIREC_1097 ,
        ex:Parametro_REFFEED1_1097 ,
        ex:Parametro_REFFEED2_1097 .

ex:MicroReferencia_1097
    a               ex:Sensor ;
    rdfs:label      "Micro de referencia máquina"@es ;
    ex:textoExtracto
        "El fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina. Al iniciar la búsqueda, el eje se desplaza... hasta que pulsa el micro de referencia máquina."@es .

ex:Parametro_I0TYPE_1097
    a               ex:Parametro ;
    rdfs:label      "I0TYPE" ;
    ex:identificador "I0TYPE" ;
    ex:valor         "No codificado"@es ;
    ex:textoExtracto "I0TYPE | No codificado."@es .

ex:Parametro_DECINPUT_1097
    a               ex:Parametro ;
    rdfs:label      "DECINPUT" ;
    ex:identificador "DECINPUT" ;
    ex:valor         "El eje dispone de micro para la búsqueda de referencia."@es ;
    ex:textoExtracto "DECINPUT | El eje dispone de micro para la búsqueda de referencia."@es .

ex:Parametro_REFDIREC_1097
    a               ex:Parametro ;
    rdfs:label      "REFDIREC" ;
    ex:identificador "REFDIREC" ;
    ex:textoExtracto
        "REFDIREC | Sentido del movimiento para la búsqueda de referencia."@es ,
        "El eje se desplaza en el sentido indicado por el parámetro REFDIREC..."@es .

ex:Parametro_REFFEED1_1097
    a               ex:Parametro ;
    rdfs:label      "REFFEED1" ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto
        "REFFEED1 | Velocidad rápida de búsqueda de referencia."@es ,
        "el eje se desplaza... al avance indicado en el parámetro REFFEED1 hasta que pulsa el micro de referencia máquina."@es .

ex:Parametro_REFFEED2_1097
    a               ex:Parametro ;
    rdfs:label      "REFFEED2" ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto
        "REFFEED2 | Velocidad lenta de búsqueda de referencia."@es ,
        "invierte el sentido y se desplaza al avance indicado en el parámetro REFFEED2."@es .