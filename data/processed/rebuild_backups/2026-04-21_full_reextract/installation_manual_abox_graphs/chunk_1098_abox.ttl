@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "I0TYPE" ;
    ex:textoExtracto "I0TYPE | Codificado creciente. Codificado decreciente." ;
    ex:valor "Codificado creciente; Codificado decreciente" .

ex:Parametro_REFDIREC
    a ex:Parametro ;
    rdfs:label "REFDIREC" ;
    ex:textoExtracto "REFDIREC | Sentido del movimiento para la búsqueda de referencia." ;
    ex:valor "Sentido del movimiento para la búsqueda de referencia" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "REFFEED2 | Velocidad lenta de búsqueda de referencia." ;
    ex:valor "Velocidad lenta de búsqueda de referencia" .

ex:Tabla_ParametrosBusquedaReferencia a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros para búsqueda de referencia (ejes y cabezales)" ;
    ex:textoExtracto "| Parámetro. | Valor. | --- | --- | I0TYPE | Codificado creciente. Codificado decreciente. | REFDIREC | Sentido del movimiento para la búsqueda de referencia. | REFFEED2 | Velocidad lenta de búsqueda de referencia." ;
    ex:tieneComponente ex:Parametro_I0TYPE ;
    ex:tieneComponente ex:Parametro_REFDIREC ;
    ex:tieneComponente ex:Parametro_REFFEED2 .

ex:Sensor_I0
    a ex:Sensor ;
    rdfs:label "Sensor I0 (sistema de captación codificado)" ;
    ex:textoExtracto "Cuando el sistema de captación dispone de I0 codificado, la búsqueda de referencia se puede efectuar en cualquier punto de la máquina; [...] hasta que el CNC recibe un impulso de I0 del sistema de captación." ;
    ex:monitoreaParametro ex:Parametro_I0TYPE .

ex:Componente_MicroReferencia
    a ex:ComponenteElectrico ;
    rdfs:label "Micro de referencia máquina" ;
    ex:textoExtracto "No es necesario disponer de micro de referencia. [...] Si antes de recibir la señal del I0 el eje pulsa el micro de referencia máquina, este invierte el sentido y continúa con el proceso, alejándose del micro, [...]." .

ex:SistemaBusquedaReferencia
    a ex:Sistema ;
    rdfs:label "Sistema de búsqueda de referencia (ejes y cabezales)" ;
    ex:textoExtracto "El eje se desplaza la menor distancia posible, menos de 200 mm, en el sentido indicado por el parámetro REFDIREC y al avance indicado en el parámetro REFFEED2 hasta que el CNC recibe un impulso de I0 del sistema de captación." ;
    ex:compuestoPor ex:Sensor_I0 ;
    ex:compuestoPor ex:Componente_MicroReferencia ;
    ex:tieneComponente ex:Parametro_REFDIREC ;
    ex:tieneComponente ex:Parametro_REFFEED2 ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferencia .