@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosBusquedaReferenciaGantry a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros para búsqueda de referencia (ejes gantry)"@es ;
    ex:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| I0TYPE | Tipo de I0. No codificado en ambos ejes. A definir en los ejes maestro y esclavo. |
| DECINPUT | El eje dispone de micro para la búsqueda de referencia. A definir en los ejes maestro y esclavo. |
| REFDIREC | Sentido del movimiento para la búsqueda de referencia. A definir en el eje maestro. |
| REFFEED1 | Velocidad rápida de búsqueda de referencia. A definir en el eje maestro. |
| REFFEED2 | Velocidad lenta de búsqueda de referencia. A definir en el eje maestro. |
| REFVALUE | Posición del punto de referencia. A definir en los ejes maestro y esclavo. |
| REFSHIFT | Offset del punto de referencia. A definir en los ejes maestro y esclavo. """@es .

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "I0TYPE" ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "Tipo de I0. No codificado en ambos ejes. A definir en los ejes maestro y esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_DECINPUT
    a ex:Parametro ;
    rdfs:label "DECINPUT" ;
    ex:identificador "DECINPUT" ;
    ex:textoExtracto "El eje dispone de micro para la búsqueda de referencia. A definir en los ejes maestro y esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_REFDIREC
    a ex:Parametro ;
    rdfs:label "REFDIREC" ;
    ex:identificador "REFDIREC" ;
    ex:textoExtracto "Sentido del movimiento para la búsqueda de referencia. A definir en el eje maestro."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "Velocidad rápida de búsqueda de referencia. A definir en el eje maestro."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto "Velocidad lenta de búsqueda de referencia. A definir en el eje maestro."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_REFVALUE
    a ex:Parametro ;
    rdfs:label "REFVALUE" ;
    ex:identificador "REFVALUE" ;
    ex:textoExtracto "Posición del punto de referencia. A definir en los ejes maestro y esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .

ex:Parametro_REFSHIFT
    a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:identificador "REFSHIFT" ;
    ex:textoExtracto "Offset del punto de referencia. A definir en los ejes maestro y esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferenciaGantry .