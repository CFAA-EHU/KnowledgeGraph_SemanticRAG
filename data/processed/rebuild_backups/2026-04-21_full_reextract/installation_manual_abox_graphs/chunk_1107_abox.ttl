@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REFDIREC
    a ex:Parametro ;
    rdfs:label "REFDIREC" ;
    ex:textoExtracto "parámetro REFDIREC del eje maestro" ;
    ex:identificador "REFDIREC" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "parámetro REFFEED1 del eje maestro" ;
    ex:identificador "REFFEED1" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "avance REFFEED2 del eje maestro" ;
    ex:identificador "REFFEED2" .

ex:Parametro_REFVALUE
    a ex:Parametro ;
    rdfs:label "REFVALUE" ;
    ex:textoExtracto "parámetro REFVALUE" ;
    ex:identificador "REFVALUE" .

ex:Parametro_REFSHIFT
    a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:textoExtracto "parámetro REFSHIFT" ;
    ex:identificador "REFSHIFT" .

ex:Sensor_MicroEjeMaestro
    a ex:Sensor ;
    rdfs:label "Micro del eje maestro" ;
    ex:textoExtracto "pulse su micro" .

ex:Sensor_I0EjeEsclavo
    a ex:Sensor ;
    rdfs:label "I0 del eje esclavo" ;
    ex:textoExtracto "el eje esclavo encuentre el I0" .

ex:EjeMaestro
    a ex:ComponenteMecanico ;
    rdfs:label "Eje maestro (gantry)" ;
    ex:textoExtracto "eje maestro" ;
    ex:tieneComponente ex:Sensor_MicroEjeMaestro ;
    ex:monitoreaParametro ex:Parametro_REFDIREC, ex:Parametro_REFFEED1, ex:Parametro_REFFEED2 .

ex:EjeEsclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Eje esclavo (gantry)" ;
    ex:textoExtracto "eje esclavo" ;
    ex:tieneComponente ex:Sensor_I0EjeEsclavo ;
    ex:monitoreaParametro ex:Parametro_REFVALUE, ex:Parametro_REFSHIFT .