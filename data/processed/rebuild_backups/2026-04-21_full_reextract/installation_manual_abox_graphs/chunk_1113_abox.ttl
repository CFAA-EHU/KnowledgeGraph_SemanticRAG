@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_LimitesSoftwareEjes a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de límites de software de ejes (pág. 600-601)"@es ;
    ex:textoExtracto "Variable | Significado --- (V.)[ch].G.SOFTLIMIT | Límites de software alcanzados. El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo. Marca de PLC | Significado --- LIMITPOS(axis) | El eje ha alcanzado el límite superior de software. LIMITNEG(axis) | El eje ha alcanzado el límite inferior de software."@es ;
    ex:documentadoEn ex:Pagina_600_601 .

ex:Pagina_600_601
    a ex:Pagina ;
    ex:identificador "600-601" ;
    ex:textoExtracto "11.6 Límites de software de los ejes"@es .

ex:Parametro_SOFTLIMIT
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.SOFTLIMIT" ;
    ex:textoExtracto "Límites de software alcanzados. El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo."@es ;
    ex:documentadoEn ex:Tabla_LimitesSoftwareEjes .

ex:Parametro_LIMITPOS
    a ex:Parametro ;
    rdfs:label "LIMITPOS(axis)" ;
    ex:textoExtracto "El eje ha alcanzado el límite superior de software."@es ;
    ex:documentadoEn ex:Tabla_LimitesSoftwareEjes .

ex:Parametro_LIMITNEG
    a ex:Parametro ;
    rdfs:label "LIMITNEG(axis)" ;
    ex:textoExtracto "El eje ha alcanzado el límite inferior de software."@es ;
    ex:documentadoEn ex:Tabla_LimitesSoftwareEjes .

ex:Sistema_ControlEjes
    a ex:Sistema ;
    rdfs:label "Sistema de control de límites de software de ejes"@es ;
    ex:textoExtracto "El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo."@es ;
    ex:monitoreaParametro ex:Parametro_SOFTLIMIT ;
    ex:monitoreaParametro ex:Parametro_LIMITPOS ;
    ex:monitoreaParametro ex:Parametro_LIMITNEG ;
    ex:detalladoEnEsquema ex:Tabla_LimitesSoftwareEjes .