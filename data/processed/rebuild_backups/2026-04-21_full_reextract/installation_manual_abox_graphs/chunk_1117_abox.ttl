@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SWLIMITTOL
    a ex:Parametro ;
    rdfs:label "SWLIMITTOL" ;
    ex:identificador "SWLIMITTOL" ;
    ex:textoExtracto "SWLIMITTOL | Tolerancia de los límites de software." ;
    ex:valor "Tolerancia de los límites de software" .

ex:Parametro_SWLIMITTOL_Descripcion
    a ex:Parametro ;
    rdfs:label "Descripción del parámetro SWLIMITTOL" ;
    ex:textoExtracto "La tolerancia indica la máxima variación u oscilación permitida a la cota real de un eje respecto de los límites de software, antes de dar error de límites sobrepasados. El movimiento teórico programado del eje sólo se permite hasta el límite exacto, pero a la cota real del eje se le permite este margen antes de dar error." .