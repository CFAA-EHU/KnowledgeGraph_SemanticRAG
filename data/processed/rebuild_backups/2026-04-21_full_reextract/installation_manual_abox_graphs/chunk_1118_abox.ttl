@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CompensacionVolumetrica_Basica
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica básica" ;
    ex:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." ;
    ex:identificador "Compensación volumétrica básica" .

ex:CompensacionVolumetrica_Media
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica media" ;
    ex:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." ;
    ex:identificador "Compensación volumétrica media" .

ex:CompensacionVolumetrica_Grande
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica grande" ;
    ex:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." ;
    ex:identificador "Compensación volumétrica grande" .

ex:ArchivoCompensacionCSV
    a ex:Tabla ;
    rdfs:label "Archivo de compensación volumétrica (CSV)" ;
    ex:textoExtracto "Si el CNC tiene activa la compensación volumétrica media o grande (opción de software), también permitirá definir una compensación volumétrica básica si el fichero tiene extensión csv." ;
    ex:identificador "fichero CSV de compensación" .

ex:ParametrosMaquina_CompensacionVolumetrica
    a ex:Parametro ;
    rdfs:label "Parámetros máquina para compensación volumétrica" ;
    ex:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." ;
    ex:identificador "VOLCOMP1-VOLCOMP4" .

ex:SistemaCompensacionVolumetrica
    a ex:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ex:textoExtracto "La compensación volumétrica corrige en gran medida estos errores geométricos, mejorando así la precisión de los posicionamientos." ;
    ex:compuestoPor ex:ParametrosMaquina_CompensacionVolumetrica ;
    ex:documentadoEn ex:ArchivoCompensacionCSV ;
    ex:tieneComponente ex:CompensacionVolumetrica_Basica ,
                        ex:CompensacionVolumetrica_Media ,
                        ex:CompensacionVolumetrica_Grande .