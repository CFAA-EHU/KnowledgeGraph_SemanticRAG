@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosCompensacionVolumetrica_1123 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros de compensación volumétrica (Pág. 607)"@es ;
    ex:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| VOLCOMP MPG |  | Este parámetro muestra las tablas de compensación volumétrica. |
| VMOVAXIS1 MPG, VMOVAXIS2, VMOVAXIS3 |  | Ejes que al moverse generan variaciones... definen el volumen a compensar. |
| NPOINTSAX1 MPG, NPOINTSAX2, NPOINTSAX3 |  | Número de puntos que definen el volumen a compensar en cada eje... |
| INIPOSAX1 MPG, INIPOSAX2, INIPOSAX3 |  | Posición inicial de la compensación volumétrica básica para el MOVAXIS. |
| INCREAX1 MPG, INCREAX2, INCREAX3 |  | Intervalo entre puntos para el eje MOVAXIS... |
| VCOMPAXIS1 MPG, VCOMPAXIS2, VCOMPAXIS3 |  | Estos parámetros definen los ejes a compensar mediante la compensación volumétrica... """ .

ex:Parametro_VOLCOMP_MPG
    a               ex:Parametro ;
    rdfs:label      "VOLCOMP MPG" ;
    ex:identificador "VOLCOMP MPG" ;
    ex:textoExtracto "Este parámetro muestra las tablas de compensación volumétrica."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1123 .

ex:Parametro_VMOVAXIS1_MPG
    a               ex:Parametro ;
    rdfs:label      "VMOVAXIS1 MPG" ;
    ex:identificador "VMOVAXIS1 MPG" ;
    ex:textoExtracto "Ejes que al moverse generan variaciones. Hay que definir al menos un eje. Estos ejes, que podrán ser lineales o rotativos, definen el volumen a compensar."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1123 .

ex:Parametro_VMOVAXIS2
    a               ex:Parametro ;
    rdfs:label      "VMOVAXIS2" ;
    ex:identificador "VMOVAXIS2" ;
    ex:textoExtracto "Ejes que al moverse generan variaciones. Hay que definir al menos un eje. Estos ejes, que podrán ser lineales o rotativos, definen el volumen a compensar."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1123 .

ex:Parametro_VMOVAXIS3
    a               ex:Parametro ;
    rdfs:label      "VMOVAXIS3" ;
    ex:identificador "VMOVAXIS3" ;
    ex:textoExtracto "Ejes que al moverse generan variaciones. Hay que definir al menos un eje. Estos ejes, que podrán ser lineales o rotativos, definen el volumen a compensar."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1123 .

ex:Parametro_NPOINTSAX1_MPG
    a               ex:Parametro ;
    rdfs:label      "NPOINTSAX1 MPG" ;
    ex:identificador "NPOINTSAX1 MPG" ;
    ex:textoExtracto "Número de puntos que definen el volumen a compensar en cada eje. El número total de puntos del volumen está limitado a 15.625, y se calcula de la forma NPOINTSAX1×NPOINTSAX2×NPOINTSAX3."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1123 .

ex:Parametro_NPOINTSAX2
    a               ex:Parametro ;
    rdfs:label      "NPOINTSAX2" ;
