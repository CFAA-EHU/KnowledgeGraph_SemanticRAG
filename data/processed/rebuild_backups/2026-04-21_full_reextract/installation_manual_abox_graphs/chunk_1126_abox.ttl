ex:Tabla_CompensacionVolumetrica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación volumétrica básica" ;
    ex:textoExtracto "archivo de texto está formado por tres columnas de datos y tantas filas como puntos a compensar" ;
    ex:documentadoEn ex:Pagina_608 .

ex:Pagina_608
    a ex:Pagina ;
    rdfs:label "Página 608 - Compensación volumétrica" ;
    ex:identificador "608" ;
    ex:textoExtracto "12.1.3 Archivo con los datos para la compensación volumétrica básica" .