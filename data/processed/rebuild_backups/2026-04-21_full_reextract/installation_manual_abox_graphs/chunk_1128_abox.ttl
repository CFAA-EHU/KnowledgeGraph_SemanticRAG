@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_1128_INIPOSAX a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de coordenadas INIPOSAX"@es ;
    ex:textoExtracto """
| X (INIPOSAX1)
Y (INIPOSAX2) |
| --- |
| Z (INIPOSAX3) |
""" ;
    ex:identificador "INIPOSAX" .

ex:Parametro_INIPOSAX1
    a               ex:Parametro ;
    rdfs:label      "INIPOSAX1 (coordenada X)"@es ;
    ex:textoExtracto "X (INIPOSAX1)" ;
    ex:identificador "INIPOSAX1" ;
    ex:valor         "-0.1861, 0.0993, -2.230" ;
    ex:documentadoEn ex:Tabla_1128_INIPOSAX .

ex:Parametro_INIPOSAX2
    a               ex:Parametro ;
    rdfs:label      "INIPOSAX2 (coordenada Y)"@es ;
    ex:textoExtracto "Y (INIPOSAX2)" ;
    ex:identificador "INIPOSAX2" ;
    ex:documentadoEn ex:Tabla_1128_INIPOSAX .

ex:Parametro_INIPOSAX3
    a               ex:Parametro ;
    rdfs:label      "INIPOSAX3 (coordenada Z)"@es ;
    ex:textoExtracto "Z (INIPOSAX3)" ;
    ex:identificador "INIPOSAX3" ;
    ex:documentadoEn ex:Tabla_1128_INIPOSAX .