@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CompensacionVolumetrica_Basica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de compensación volumétrica básica"@es ;
    ex:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| VMOVAXIS1, VMOVAXIS2, VMOVAXIS3 | En la compensación volumétrica básica, nombre del eje que al moverse genera variaciones. |
| NPOINTSAX1, NPOINTSAX2, NPOINTSAX3 | Número de puntos de la compensación volumétrica básica en cada eje. |
| INIPOSAX1, INIPOSAX2, INIPOSAX3 | Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS. |
| INCREAX1, INCREAX2, INCREAX3 | Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. |
| VCOMPAXIS1, VCOMPAXIS2, VCOMPAXIS3 | Nombre del primer, segundo y tercer eje a compensar. |
| VCOMPFILE | Archivo con los datos de la compensación volumétrica."""@es ;
    ex:tieneComponente
        ex:Param_VMOVAXIS1, ex:Param_VMOVAXIS2, ex:Param_VMOVAXIS3,
        ex:Param_NPOINTSAX1, ex:Param_NPOINTSAX2, ex:Param_NPOINTSAX3,
        ex:Param_INIPOSAX1, ex:Param_INIPOSAX2, ex:Param_INIPOSAX3,
        ex:Param_INCREAX1, ex:Param_INCREAX2, ex:Param_INCREAX3,
        ex:Param_VCOMPAXIS1, ex:Param_VCOMPAXIS2, ex:Param_VCOMPAXIS3,
        ex:Param_VCOMPFILE .

ex:Param_VMOVAXIS1
    a ex:Parametro ;
    ex:identificador "VMOVAXIS1" ;
    ex:textoExtracto "nombre del eje que al moverse genera variaciones"@es .

ex:Param_VMOVAXIS2
    a ex:Parametro ;
    ex:identificador "VMOVAXIS2" ;
    ex:textoExtracto "nombre del eje que al moverse genera variaciones"@es .

ex:Param_VMOVAXIS3
    a ex:Parametro ;
    ex:identificador "VMOVAXIS3" ;
    ex:textoExtracto "nombre del eje que al moverse genera variaciones"@es .

ex:Param_NPOINTSAX1
    a ex:Parametro ;
    ex:identificador "NPOINTSAX1" ;
    ex:textoExtracto "Número de puntos de la compensación volumétrica básica en cada eje"@es .

ex:Param_NPOINTSAX2
    a ex:Parametro ;
    ex:identificador "NPOINTSAX2" ;
    ex:textoExtracto "Número de puntos de la compensación volumétrica básica en cada eje"@es .

ex:Param_NPOINTSAX3
    a ex:Parametro ;
    ex:identificador "NPOINTSAX3" ;
    ex:textoExtracto "Número de puntos de la compensación volumétrica básica en cada eje"@es .

ex:Param_INIPOSAX1
    a ex:Parametro ;
    ex:identificador "INIPOSAX1" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS"@es .

ex:Param_INIPOSAX2
    a ex:Parametro ;
    ex:identificador "INIPOSAX2" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS"@es .

ex:Param_INIPOSAX3
    a ex:Parametro ;
    ex:identificador "INIPOSAX3" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS"@es .

ex:Param_INCREAX1
    a ex:Parametro ;
    ex:identificador "INCREAX1" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica"@es .

ex:Param_INCREAX2
    a ex:Parametro ;
    ex:identificador "INCREAX2" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica"@es .

ex:Param_INCREAX3
    a ex:Parametro ;
    ex:identificador "INCREAX3" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica"@es .

ex:Param_VCOMPAXIS1
    a ex:Parametro ;
    ex:identificador "VCOMPAXIS1" ;
    ex:textoExtracto "Nombre del primer eje a compensar"@es .

ex:Param_VCOMPAXIS2
    a ex:Parametro ;
    ex:identificador "VCOMPAXIS2" ;
    ex:textoExtracto "Nombre del segundo eje a compensar"@es .

ex:Param_VCOMPAXIS3
    a ex:Parametro ;
    ex:identificador "VCOMPAXIS3" ;
    ex:textoExtracto "Nombre del tercer eje a compensar"@es .

ex:Param_VCOMPFILE
    a ex:Parametro ;
    ex:identificador "VCOMPFILE" ;
    ex:textoExtracto "Archivo con los datos de la compensación volumétrica"@es .