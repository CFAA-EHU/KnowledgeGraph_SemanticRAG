@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CompensacionVolumetrica_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Primera tabla de compensación volumétrica"@es ;
    ex:textoExtracto "V.MPG.VMOVAXIS2[1] | Nombre del segundo eje de la primera tabla de compensación volumétrica."@es ;
    ex:identificador "tbl=1" .

ex:Parametro_VMOVAXIS2_1
    a ex:Parametro ;
    rdfs:label "Segundo eje (tabla 1 de compensación volumétrica)"@es ;
    ex:textoExtracto "V.MPG.VMOVAXIS2[1] | Nombre del segundo eje de la primera tabla de compensación volumétrica."@es ;
    ex:identificador "V.MPG.VMOVAXIS2[1]" ;
    ex:documentadoEn ex:Tabla_CompensacionVolumetrica_1 .

ex:Tabla_CompensacionVolumetrica_2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Segunda tabla de compensación volumétrica"@es ;
    ex:textoExtracto "V.MPG.NPOINTAX2[2] | Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es ;
    ex:identificador "tbl=2" .

ex:Parametro_NPOINTAX2_2
    a ex:Parametro ;
    rdfs:label "Número de puntos del segundo eje (tabla 2)"@es ;
    ex:textoExtracto "V.MPG.NPOINTAX2[2] | Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es ;
    ex:identificador "V.MPG.NPOINTAX2[2]" ;
    ex:documentadoEn ex:Tabla_CompensacionVolumetrica_2 .

ex:Archivo_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "Archivo de compensación volumétrica (VCOMPFILE)"@es ;
    ex:textoExtracto "Archivo con los datos de la compensación volumétrica. Unidades: -. | R(*) | R | R |"@es ;
    ex:identificador "VCOMPFILE[tbl]" .