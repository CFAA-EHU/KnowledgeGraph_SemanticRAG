@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_1135_VariablesVolumetricas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables de compensación volumétrica (PRG/PLC/INT)"@es ;
    ex:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)PLC.VOLCOMP1
(V.)PLC.VOLCOMP2
(V.)PLC.VOLCOMP3
(V.)PLC.VOLCOMP4
Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). Unidades: -.
| V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ.
| (V.)[ch].A.VOLCOMP.xn | Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero). Unidades: Milímetros, pulgadas o grados.
| V.A.VOLCOMP.Z | Eje Z.
| V.A.VOLCOMP.3 | Eje con número lógico ꞏ3ꞏ.
| V.[2].A.VOLCOMP.3 | Eje con índice ꞏ3ꞏ en el canal ꞏ2ꞏ.""" .

ex:Parametro_VOLCOMP1
    a ex:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ex:identificador "V.PLC.VOLCOMP1" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 [...] Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)."@es .

ex:Parametro_VOLCOMP2
    a ex:Parametro ;
    rdfs:label "VOLCOMP2" ;
    ex:identificador "V.PLC.VOLCOMP2" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC."@es .

ex:Parametro_VOLCOMP3
    a ex:Parametro ;
    rdfs:label "VOLCOMP3" ;
    ex:identificador "V.PLC.VOLCOMP3" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC."@es .

ex:Parametro_VOLCOMP4
    a ex:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ex:identificador "V.PLC.VOLCOMP4" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC."@es .

ex:Parametro_VOLCOMP_EjeZ
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica del eje Z" ;
    ex:identificador "V.A.VOLCOMP.Z" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:valor "Milímetros, pulgadas o grados"@es ;
    ex:textoExtracto "Valor que está añadiendo la compensación volumétrica al eje. [...] | V.A.VOLCOMP.Z | Eje Z."@es .

ex:Parametro_VOLCOMP_EjeLogico3
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica del eje lógico 3" ;
    ex:identificador "V.A.VOLCOMP.3" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:valor "Milímetros, pulgadas o grados"@es ;
    ex:textoExtracto "| V.A.VOLCOMP.3 | Eje con número lógico ꞏ3ꞏ."@es .

ex:Parametro_VOLCOMP_Canal2_Eje3
    a ex:Parametro ;
    rdfs:label "Compensación volumétrica del eje 3 en canal 2" ;
    ex:identificador "V.[2].A.VOLCOMP.3" ;
    ex:monitoreaParametro ex:Tabla_1135_VariablesVolumetricas ;
    ex:valor "Milímetros, pulgadas o grados"@es ;
    ex:textoExtracto "| V.[2].A.VOLCOMP.3 | Eje con índice ꞏ3ꞏ en el canal ꞏ2ꞏ."@es .