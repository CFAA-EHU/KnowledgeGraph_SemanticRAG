@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_VOLCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación volumétrica (VOLCOMP)"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP. Ejes que al moverse generan variaciones. [...] El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE."@es ;
    ex:identificador "VOLCOMP" .

ex:Parametro_VMOVAXIS1
    a ex:Parametro ;
    rdfs:label "VMOVAXIS1" ;
    ex:textoExtracto "VMOVAXIS1 [...] Nombre del eje que al moverse genera variaciones. Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.VMOVAXIS1[tbl]."@es ;
    ex:identificador "VMOVAXIS1" ;
    ex:valor "(V.)MPG.VMOVAXIS1[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VMOVAXIS2
    a ex:Parametro ;
    rdfs:label "VMOVAXIS2" ;
    ex:textoExtracto "VMOVAXIS2 [...] Nombre del eje que al moverse genera variaciones. Variable asociada: (V.)MPG.VMOVAXIS2[tbl]."@es ;
    ex:identificador "VMOVAXIS2" ;
    ex:valor "(V.)MPG.VMOVAXIS2[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VMOVAXIS3
    a ex:Parametro ;
    rdfs:label "VMOVAXIS3" ;
    ex:textoExtracto "VMOVAXIS3 [...] Nombre del eje que al moverse genera variaciones. Variable asociada: (V.)MPG.VMOVAXIS3[tbl]."@es ;
    ex:identificador "VMOVAXIS3" ;
    ex:valor "(V.)MPG.VMOVAXIS3[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_NPOINTSAX1
    a ex:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ex:textoExtracto "NPOINTSAX1 [...] Número de puntos de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: De 2 a 1000 puntos. Variable asociada: (V.)MPG.NPOINTSAX1[tbl]."@es ;
    ex:identificador "NPOINTSAX1" ;
    ex:valor "(V.)MPG.NPOINTSAX1[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_NPOINTSAX2
    a ex:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ex:textoExtracto "NPOINTSAX2 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX2[tbl]."@es ;
    ex:identificador "NPOINTSAX2" ;
    ex:valor "(V.)MPG.NPOINTSAX2[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_NPOINTSAX3
    a ex:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ex:textoExtracto "NPOINTSAX3 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX3[tbl]."@es ;
    ex:identificador "NPOINTSAX3" ;
    ex:valor "(V.)MPG.NPOINTSAX3[tbl]" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .