@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23102 a ex:AvisoSeguridad ;
    ex:identificador "23102" ;
    rdfs:label "Error del sistema de compensación volumétrica"@es ;
    ex:textoExtracto "23102 'Error del sistema de compensación volumétrica;"@es ;
    ex:solucionaFallo ex:FalloCompensacionVolumetrica .

ex:FalloCompensacionVolumetrica a ex:DiagnosticoFallo ;
    ex:textoExtracto "El fichero definido en VCOMPFILE no tiene definidos todos los puntos. [...] Compensación volumétrica media y grande: • El formato del fichero definido en VCOMPFILE no es correcto."@es ;
    ex:mitigaRiesgo [
        a ex:TareaMantenimiento ;
        ex:textoExtracto "Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos."@es
    ] .

ex:ParametroNPOINTSAX1 a ex:Parametro ;
    ex:identificador "NPOINTSAX1" ;
    ex:textoExtracto "NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ex:ParametroNPOINTSAX2 a ex:Parametro ;
    ex:identificador "NPOINTSAX2" ;
    ex:textoExtracto "NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ex:ParametroNPOINTSAX3 a ex:Parametro ;
    ex:identificador "NPOINTSAX3" ;
    ex:textoExtracto "NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es .

ex:SistemaCompensacionVolumetrica a ex:Sistema ;
    ex:textoExtracto "sistema de compensación volumétrica"@es ;
    ex:activaAlarma ex:Error23102 ;
    ex:monitoreaParametro ex:ParametroNPOINTSAX1, ex:ParametroNPOINTSAX2, ex:ParametroNPOINTSAX3 .