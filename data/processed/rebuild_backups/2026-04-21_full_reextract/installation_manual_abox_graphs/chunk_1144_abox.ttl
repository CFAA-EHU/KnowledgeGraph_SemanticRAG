@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_HSC a ex:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ex:textoExtracto "La orden para ejecutar programas formados por muchos bloques pequeños, típicos del mecanizado a alta velocidad, se realiza mediante una única instrucción, #HSC."@es ;
    ex:identificador "#HSC" .

ex:ModoOperacion_SURFACE a ex:ModoOperacion ;
    rdfs:label "Modo SURFACE"@es ;
    ex:textoExtracto "optimizando el acabado superficial (modo SURFACE)"@es ;
    ex:textoExtracto "Los algoritmos más sofisticados del modo SURFACE hacen que los mecanizados sean más precisos."@es .

ex:ModoOperacion_CONTERROR a ex:ModoOperacion ;
    rdfs:label "Modo CONTERROR"@es ;
    ex:textoExtracto "optimizando el error de contorno (modo CONTERROR)"@es .

ex:ModoOperacion_FAST a ex:ModoOperacion ;
    rdfs:label "Modo FAST"@es ;
    ex:textoExtracto "optimizando la velocidad de mecanizado (modo FAST)"@es .

ex:Parametro_HSCDEFAULTMODE a ex:Parametro ;
    rdfs:label "Parámetro HSCDEFAULTMODE"@es ;
    ex:identificador "HSCDEFAULTMODE" ;
    ex:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE, donde Fagor ofrece el modo SURFACE como modo por defecto."@es ;
    ex:valor "SURFACE" .

ex:ModoOperacion_HSC ex:tieneFrecuencia ex:ModoOperacion_SURFACE .
ex:ModoOperacion_HSC ex:tieneFrecuencia ex:ModoOperacion_CONTERROR .
ex:ModoOperacion_HSC ex:tieneFrecuencia ex:ModoOperacion_FAST .