@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FILTER
    a ex:Parametro ;
    rdfs:label "FILTER" ;
    ex:textoExtracto "filtros definidos mediante el parámetro FILTER" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Parametro_HSCFILTFREQ
    a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" ;
    ex:monitoreaParametro ex:ModoOperacion_CONTERROR .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ex:textoExtracto "modo HSC; Mecanizado HSC optimizando el avance (modo FAST)" .

ex:ModoOperacion_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ex:textoExtracto "modo CONTERROR" .

ex:ModoOperacion_FAST
    a ex:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ex:textoExtracto "modo FAST" .