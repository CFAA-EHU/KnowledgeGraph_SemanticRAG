@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoHSCFAST
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC FAST" ;
    ex:textoExtracto "modo HSC FAST mejora la calidad del mecanizado", "modo HSC FAST activo" .

ex:Parametro_FASTFACTOR_MPG
    a ex:Parametro ;
    rdfs:label "FASTFACTOR MPG" ;
    ex:identificador "FASTFACTOR MPG" ;
    ex:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de avance que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST." ;
    ex:monitoreaParametro ex:ModoHSCFAST ;
    ex:valor "valor por defecto (modificable desde programa pieza)" .

ex:Parametro_FTIMELIM_MPG
    a ex:Parametro ;
    rdfs:label "FTIMELIM MPG" ;
    ex:identificador "FTIMELIM MPG" ;
    ex:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo. Si se programa con valor 0, el CNC no realiza la interpolación del avance y por tanto la ejecución es más rápida." ;
    ex:monitoreaParametro ex:ModoHSCFAST ;
    ex:valor "0 (sin interpolación) o porcentaje (ej. 200%, 300%)" .

ex:Parametro_MINCORFEED_MPG
    a ex:Parametro ;
    rdfs:label "MINCORFEED MPG" ;
    ex:identificador "MINCORFEED MPG" ;
    ex:textoExtracto "Velocidad mínima en las esquinas. No se recomienda modificar este valor, porque se puede sobrepasar la dinámica de los ejes." ;
    ex:monitoreaParametro ex:ModoHSCFAST .

ex:Parametro_FSMOOTHFREQ_MPG
    a ex:Parametro ;
    rdfs:label "FSMOOTHFREQ MPG" ;
    ex:identificador "FSMOOTHFREQ MPG" ;
    ex:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para el modo HSC FAST. Evita acelerar y decelerar por encima de una determinada frecuencia." ;
    ex:monitoreaParametro ex:ModoHSCFAST .