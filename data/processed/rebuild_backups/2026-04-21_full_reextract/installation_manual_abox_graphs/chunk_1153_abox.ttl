@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosHSC_1153 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (pág. 621-622)"@es ;
    ex:textoExtracto """
| Parámetro. |  | Significado. |
| FASTFILTFREQ MPG |  | Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST...
| FREQRES MPG |  | Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna...
| SOFTFREQ MPG |  | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal...
| HSCROUND MPG |  | Valor por defecto del error máximo de la trayectoria en HSC...
| SURFFILFREQ MPG |  | Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE..."""@es ;
    ex:documentadoEn ex:Manual_ConfiguracionHSC .

ex:Parametro_FASTFILTFREQ_MPG
    a ex:Parametro ;
    rdfs:label "FASTFILTFREQ MPG" ;
    ex:identificador "FASTFILTFREQ MPG" ;
    ex:textoExtracto "Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas. Este parámetro introduce un desfase constante, independiente de las frecuencias."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1153 .

ex:Parametro_FREQRES_MPG
    a ex:Parametro ;
    rdfs:label "FREQRES MPG" ;
    ex:identificador "FREQRES MPG" ;
    ex:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1153 .

ex:Parametro_SOFTFREQ_MPG
    a ex:Parametro ;
    rdfs:label "SOFTFREQ MPG" ;
    ex:identificador "SOFTFREQ MPG" ;
    ex:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado. Este parámetro se debe ajustar con ayuda de la aplicación FineTune."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1153 .

ex:Parametro_HSCROUND_MPG
    a ex:Parametro ;
    rdfs:label "HSCROUND MPG" ;
    ex:identificador "HSCROUND MPG" ;
    ex:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1153 .

ex:Parametro_SURFFILFREQ_MPG
    a ex:Parametro ;
    rdfs:label "SURFFILFREQ MPG" ;
    ex:identificador "SURFFILFREQ MPG" ;
    ex:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1153 .

ex:ModoOperacion_HSC_FAST
    a ex:ModoOperacion ;
    rdfs:label "HSC FAST" ;
    ex:textoExtracto "modo HSC FAST"@es .

ex:ModoOperacion_HSC_SURFACE
    a ex:ModoOperacion ;
    rdfs:label "HSC SURFACE" ;
    ex:textoExtracto "modo HSC SURFACE"@es .

ex:ModoOperacion_HSC_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "HSC CONTERROR" ;
    ex:textoExtracto "modo HSC CONTERROR"@es .

ex:Parametro_FASTFILTFREQ_MPG
    ex:monitoreaParametro ex:ModoOperacion_HSC_FAST .

ex:Parametro_SURFFILFREQ_MPG
    ex:monitoreaParametro ex:ModoOperacion_HSC_SURFACE .

ex:Parametro_FREQRES_MPG
    ex:monitoreaParametro ex:ModoOperacion_HSC_CONTERROR .