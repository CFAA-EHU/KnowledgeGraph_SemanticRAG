@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosEje_1154 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de eje (MPA)"@es ;
    ex:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| CORNERACC MPA |  | Este parámetro define la aceleración máxima que se va a permitir al eje en la transición de bloques. [...] [MPA].......Parámetro máquina; ejes.
""" ;
    ex:tieneComponente
        ex:Param_CORNERACC_MPA_1154 ,
        ex:Param_CURVACC_MPA_1154 ,
        ex:Param_CORNERJERK_MPA_1154 ,
        ex:Param_CURVJERK_MPA_1154 ,
        ex:Param_FASTACC_MPA_1154 ,
        ex:Param_MAXERROR_MPA_1154 .

ex:Param_CORNERACC_MPA_1154
    a ex:Parametro ;
    rdfs:label "CORNERACC MPA" ;
    ex:identificador "CORNERACC" ;
    ex:textoExtracto "Este parámetro define la aceleración máxima que se va a permitir al eje en la transición de bloques. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .

ex:Param_CURVACC_MPA_1154
    a ex:Parametro ;
    rdfs:label "CURVACC MPA" ;
    ex:identificador "CURVACC" ;
    ex:textoExtracto "Aceleración máxima permitida en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .

ex:Param_CORNERJERK_MPA_1154
    a ex:Parametro ;
    rdfs:label "CORNERJERK MPA" ;
    ex:identificador "CORNERJERK" ;
    ex:textoExtracto "Jerk máximo permitido en las esquinas. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .

ex:Param_CURVJERK_MPA_1154
    a ex:Parametro ;
    rdfs:label "CURVJERK MPA" ;
    ex:identificador "CURVJERK" ;
    ex:textoExtracto "Jerk máximo permitido en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .

ex:Param_FASTACC_MPA_1154
    a ex:Parametro ;
    rdfs:label "FASTACC MPA" ;
    ex:identificador "FASTACC" ;
    ex:textoExtracto "Aceleración máxima permitida (modo FAST). Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .

ex:Param_MAXERROR_MPA_1154
    a ex:Parametro ;
    rdfs:label "MAXERROR MPA" ;
    ex:identificador "MAXERROR" ;
    ex:textoExtracto "Error de posición. Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosEje_1154 .