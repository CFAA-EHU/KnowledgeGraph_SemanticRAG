@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_VOLCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación volumétrica (VOLCOMP)" ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP." ;
    ex:identificador "VOLCOMP" .

ex:Parametro_INIPOSAX1
    a ex:Parametro ;
    rdfs:label "Posición inicial de compensación volumétrica básica (MOVAXIS - Eje 1)" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica para el MOVAXIS. Variable asociada: (V.)MPG.INIPOSAX1[tbl]" ;
    ex:identificador "MPG.INIPOSAX1" ;
    ex:valor "0"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_INIPOSAX2
    a ex:Parametro ;
    rdfs:label "Posición inicial de compensación volumétrica básica (MOVAXIS - Eje 2)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.INIPOSAX2[tbl]" ;
    ex:identificador "MPG.INIPOSAX2" ;
    ex:valor "0"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_INIPOSAX3
    a ex:Parametro ;
    rdfs:label "Posición inicial de compensación volumétrica básica (MOVAXIS - Eje 3)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.INIPOSAX3[tbl]" ;
    ex:identificador "MPG.INIPOSAX3" ;
    ex:valor "0"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_INCREAX1
    a ex:Parametro ;
    rdfs:label "Intervalo entre puntos (MOVAXIS - Eje 1)" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. Variable asociada: (V.)MPG.INCREAX1[tbl]" ;
    ex:identificador "MPG.INCREAX1" ;
    ex:valor "10 mm / 0.3937 inch"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_INCREAX2
    a ex:Parametro ;
    rdfs:label "Intervalo entre puntos (MOVAXIS - Eje 2)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.INCREAX2[tbl]" ;
    ex:identificador "MPG.INCREAX2" ;
    ex:valor "10 mm / 0.3937 inch"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_INCREAX3
    a ex:Parametro ;
    rdfs:label "Intervalo entre puntos (MOVAXIS - Eje 3)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.INCREAX3[tbl]" ;
    ex:identificador "MPG.INCREAX3" ;
    ex:valor "10 mm / 0.3937 inch"^^xsd:string ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VCOMPAXIS1
    a ex:Parametro ;
    rdfs:label "Eje a compensar (MOVAXIS - Configuración 1)" ;
    ex:textoExtracto "Nombre del eje a compensar. Variable asociada: (V.)MPG.VCOMPAXIS1[tbl]" ;
    ex:identificador "MPG.VCOMPAXIS1" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VCOMPAXIS2
    a ex:Parametro ;
    rdfs:label "Eje a compensar (MOVAXIS - Configuración 2)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS2[tbl]" ;
    ex:identificador "MPG.VCOMPAXIS2" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VCOMPAXIS3
    a ex:Parametro ;
    rdfs:label "Eje a compensar (MOVAXIS - Configuración 3)" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS3[tbl]" ;
    ex:identificador "MPG.VCOMPAXIS3" ;
    ex:documentadoEn ex:Tabla_VOLCOMP .

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "Archivo de compensación volumétrica (CSV)" ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:identificador "VCOMPFILE" ;
    ex:valor "*.csv"^^xsd:string .