@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Variable_G_LIMERROR
    a ex:Parametro ;
    rdfs:label "Variable (V.)[ch].G.LIMERROR" ;
    ex:identificador "G.LIMERROR" ;
    ex:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR). Esta variable permite valorar si el programa está generado con más error del que pedimos al modo HSC." ;
    ex:valor "-1" , "#" ;
    ex:textoExtracto "[-1] El perfil generado no supera el error programado. El error programado no limita el avance máximo del eje. [#] Valor del error que desactiva las splines. Unidades: Milímetros o pulgadas." .