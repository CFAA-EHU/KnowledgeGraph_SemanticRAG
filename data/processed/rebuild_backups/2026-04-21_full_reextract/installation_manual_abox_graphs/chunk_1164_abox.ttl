@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_13_3_6_VariablesCotasLazo a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla 13.3.6: Variables asociadas a las cotas en el lazo"@es ;
    ex:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.IPOPOS.xn
(V.)[ch].A.IPOPOS.sn
(V.)[ch].SP.IPOPOS.sn
Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza. Unidades: Milímetros, pulgadas o grados.
...
(V.)[ch].A.LOOPPOS.sn
Cota real a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados."""@es .

ex:Parametro_IPOPOS
    a ex:Parametro ;
    rdfs:label "Cota teórica a la salida del interpolador (IPOPOS)"@es ;
    ex:identificador "(V.)[ch].A.IPOPOS.xn / (V.)[ch].A.IPOPOS.sn / (V.)[ch].SP.IPOPOS.sn" ;
    ex:valor "Milímetros, pulgadas o grados"@es ;
    ex:textoExtracto "Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza. Unidades: Milímetros, pulgadas o grados."@es ;
    ex:documentadoEn ex:Tabla_13_3_6_VariablesCotasLazo .

