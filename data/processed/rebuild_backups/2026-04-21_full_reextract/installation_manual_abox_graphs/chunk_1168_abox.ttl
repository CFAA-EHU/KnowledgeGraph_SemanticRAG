@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_HSC
    a               ex:ModoOperacion ;
    rdfs:label      "Modo HSC" ;
    ex:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

ex:Parametro_G00FEED
    a               ex:Parametro ;
    rdfs:label      "G00FEED" ;
    ex:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Parametro_ACCEL
    a               ex:Parametro ;
    rdfs:label      "ACCEL" ;
    ex:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Parametro_LACC1
    a               ex:Parametro ;
    rdfs:label      "LACC1" ;
    ex:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Parametro_LACC2
    a               ex:Parametro ;
    rdfs:label      "LACC2" ;
    ex:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Parametro_ACCJERK
    a               ex:Parametro ;
    rdfs:label      "ACCJERK" ;
    ex:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:Herramienta_Osciloscopio
    a               ex:Herramienta ;
    rdfs:label      "Osciloscopio" ;
    ex:textoExtracto "El osciloscopio servirá como herramienta análisis para ver la evolución del HSC durante el mecanizado." .

ex:TareaMantenimiento_AjusteHSC
    a               ex:TareaMantenimiento ;
    rdfs:label      "Ajuste del modo HSC" ;
    ex:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." ;
    ex:requiereMantenimiento ex:ModoOperacion_HSC .