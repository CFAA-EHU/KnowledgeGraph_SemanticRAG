@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VMPG_VCOMPAXIS1
    a               ex:Parametro ;
    rdfs:label      "Variable (V.)MPG.VCOMPAXIS1[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS1[tbl]" ;
    ex:identificador "VMPG.VCOMPAXIS1" .

ex:Parametro_VMPG_VCOMPAXIS2
    a               ex:Parametro ;
    rdfs:label      "Variable (V.)MPG.VCOMPAXIS2[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS2[tbl]" ;
    ex:identificador "VMPG.VCOMPAXIS2" .

ex:Parametro_VMPG_VCOMPAXIS3
    a               ex:Parametro ;
    rdfs:label      "Variable (V.)MPG.VCOMPAXIS3[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS3[tbl]" ;
    ex:identificador "VMPG.VCOMPAXIS3" .

ex:Tabla_VOLCOMP a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de compensación volumétrica VOLCOMP" ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP. Estos parámetros definen los ejes a compensar mediante la compensación volumétrica." ;
    ex:identificador "VOLCOMP" ;
    ex:tieneComponente ex:Parametro_VMPG_VCOMPAXIS1 ;
    ex:tieneComponente ex:Parametro_VMPG_VCOMPAXIS2 ;
    ex:tieneComponente ex:Parametro_VMPG_VCOMPAXIS3 .