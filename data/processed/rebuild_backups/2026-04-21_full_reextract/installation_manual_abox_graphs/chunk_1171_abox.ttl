@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_13_4_ParametrosHSC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros para análisis del modo HSC (pág. 630-632)" ;
    ex:textoExtracto """
| Variable. | Significado. |
| --- | --- |
| V.G.PARLIMF | Causa que limita el avance en el bloque en ejecución. |
| V.G.AXLIMF | Número lógico del eje que limita el avance, en el bloque en ejecución. |
| V.G.PARLIMC | Causa que limita el avance en la esquina, en el bloque actual. |
| V.G.AXLIMC | Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución. |
| V.G.LIMERROR | Valor del error que desactiva las splines (modo CONTERROR). |
| V.G.PATHFEED | Avance teórico sobre la trayectoria. |
| V.G.FREAL | Avance real sobre la trayectoria.""" .

ex:Parametro_V_G_PARLIMF
    a ex:Parametro ;
    rdfs:label "V.G.PARLIMF" ;
    ex:identificador "V.G.PARLIMF" ;
    ex:textoExtracto "Causa que limita el avance en el bloque en ejecución." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

ex:Parametro_V_G_AXLIMF
    a ex:Parametro ;
    rdfs:label "V.G.AXLIMF" ;
    ex:identificador "V.G.AXLIMF" ;
    ex:textoExtracto "Número lógico del eje que limita el avance, en el bloque en ejecución." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

ex:Parametro_V_G_PARLIMC
    a ex:Parametro ;
    rdfs:label "V.G.PARLIMC" ;
    ex:identificador "V.G.PARLIMC" ;
    ex:textoExtracto "Causa que limita el avance en la esquina, en el bloque actual." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

ex:Parametro_V_G_AXLIMC
    a ex:Parametro ;
    rdfs:label "V.G.AXLIMC" ;
    ex:identificador "V.G.AXLIMC" ;
    ex:textoExtracto "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

ex:Parametro_V_G_LIMERROR
    a ex:Parametro ;
    rdfs:label "V.G.LIMERROR" ;
    ex:identificador "V.G.LIMERROR" ;
    ex:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR)." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

