    a ex:Parametro ;
    rdfs:label "V.G.PATHFEED" ;
    ex:identificador "V.G.PATHFEED" ;
    ex:textoExtracto "Avance teórico sobre la trayectoria." ;
    ex:documentadoEn ex:Tabla_13_4_ParametrosHSC .

