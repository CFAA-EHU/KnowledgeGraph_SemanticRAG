ex:ModoOperacion_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "CONTERROR" ;
    ex:identificador "CONTERROR" ;
    ex:textoExtracto "modo CONTERROR (desactivación de splines por error)." .