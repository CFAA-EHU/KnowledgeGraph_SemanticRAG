@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosErrorHSC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de error y parámetros HSC"@es ;
    ex:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| 1 | El avance máximo del eje. |
| 2 | La aceleración debida a la curvatura (parámetro CURVACC). |
| 3 | El jerk debido a la curvatura (parámetro CURVJERK). |
| 6 | El error que comete el spline. |
| 7 | Espacio insuficiente por bloques muy pequeños y/o buffer lleno. |
| 10 | Máximo avance del eje en transformaciones. |
| 11 | Máxima aceleración del eje en transformaciones.
---
| Valor. | Significado. |
| --- | --- |
| 1 | El avance máximo del eje. |
| 4 | La aceleración en la esquina (parámetro CORNERACC). |
| 5 | El jerk en la esquina (parámetro CORNERJERK). |
| 8 | El error cordal en la esquina (modo CONTERROR). |
| 9 | Geometría de la esquina (modo FAST)."""@es .

ex:Parametro_CURVACC
    a ex:Parametro ;
    rdfs:label "CURVACC"@es ;
    ex:identificador "CURVACC" ;
    ex:textoExtracto "parámetro CURVACC (aceleración debida a la curvatura)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Parametro_CURVJERK
    a ex:Parametro ;
    rdfs:label "CURVJERK"@es ;
    ex:identificador "CURVJERK" ;
    ex:textoExtracto "parámetro CURVJERK (jerk debido a la curvatura)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Parametro_CORNERACC
    a ex:Parametro ;
    rdfs:label "CORNERACC"@es ;
    ex:identificador "CORNERACC" ;
    ex:textoExtracto "parámetro CORNERACC (aceleración en la esquina)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Parametro_CORNERJERK
    a ex:Parametro ;
    rdfs:label "CORNERJERK"@es ;
    ex:identificador "CORNERJERK" ;
    ex:textoExtracto "parámetro CORNERJERK (jerk en la esquina)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Variable_VGLIMERROR
    a ex:Parametro ;
    rdfs:label "V.G.LIMERROR"@es ;
    ex:identificador "V.G.LIMERROR" ;
    ex:textoExtracto "Variable V.G.LIMERROR (error que comete el spline y valor que desactiva los splines)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Variable_VGAXLIMC
    a ex:Parametro ;
    rdfs:label "V.G.AXLIMC"@es ;
    ex:identificador "V.G.AXLIMC" ;
    ex:textoExtracto "Variable V.G.AXLIMC (eje que limita el avance en esquinas)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:Variable_VGPARLIMC
    a ex:Parametro ;
    rdfs:label "V.G.PARLIMC"@es ;
    ex:identificador "V.G.PARLIMC" ;
    ex:textoExtracto "Variable V.G.PARLIMC (causa por la que el eje limita el avance en esquinas)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:ModoOperacion_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "CONTERROR"@es ;
    ex:identificador "CONTERROR" ;
    ex:textoExtracto "modo CONTERROR (error cordal en la esquina)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .

ex:ModoOperacion_FAST
    a ex:ModoOperacion ;
    rdfs:label "FAST"@es ;
    ex:identificador "FAST" ;
    ex:textoExtracto "modo FAST (geometría de la esquina)"@es ;
    ex:documentadoEn ex:Tabla_CodigosErrorHSC .