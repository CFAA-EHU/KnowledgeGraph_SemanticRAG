@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionSubrutinas_14_2_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de subrutinas por canal (Sección 14.2.1)"@es ;
    ex:textoExtracto """
    | Nombre. | Canal. |
    | --- | --- |
    | PROGRAM_START / PROGRAM_START_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START. |
    | PROGRAM_START_C2 | Canal 2. |
    | PROGRAM_START_C3 | Canal 3. |
    | PROGRAM_START_C4 | Canal 4. |
    """@es .

ex:Subrutina_PROGRAM_START
    a ex:Componente ;
    rdfs:label "Subrutina PROGRAM_START (canal predeterminado)"@es ;
    ex:identificador "PROGRAM_START" ;
    ex:textoExtracto "El nombre de la subrutina debe ser PROGRAM_START (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub. Si hay varios canales, puede haber una subrutina diferente para cada canal, cuyo nombre deberá ser PROGRAM_START_Cn donde n es el número de canal (entre 1 y 4)."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionSubrutinas_14_2_1 .

ex:Subrutina_PROGRAM_START_C1
    a ex:Componente ;
    rdfs:label "Subrutina PROGRAM_START_C1 (Canal 1)"@es ;
    ex:identificador "PROGRAM_START_C1" ;
    ex:textoExtracto "El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionSubrutinas_14_2_1 .

ex:Subrutina_PROGRAM_START_C2
    a ex:Componente ;
    rdfs:label "Subrutina PROGRAM_START_C2 (Canal 2)"@es ;
    ex:identificador "PROGRAM_START_C2" ;
    ex:textoExtracto "PROGRAM_START_C2 | Canal 2."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionSubrutinas_14_2_1 .

ex:Subrutina_PROGRAM_START_C3
    a ex:Componente ;
    rdfs:label "Subrutina PROGRAM_START_C3 (Canal 3)"@es ;
    ex:identificador "PROGRAM_START_C3" ;
    ex:textoExtracto "PROGRAM_START_C3 | Canal 3."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionSubrutinas_14_2_1 .

ex:Subrutina_PROGRAM_START_C4
    a ex:Componente ;
    rdfs:label "Subrutina PROGRAM_START_C4 (Canal 4)"@es ;
    ex:identificador "PROGRAM_START_C4" ;
    ex:textoExtracto "PROGRAM_START_C4 | Canal 4."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionSubrutinas_14_2_1 .