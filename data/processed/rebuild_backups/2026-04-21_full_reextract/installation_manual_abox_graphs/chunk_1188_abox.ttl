@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_PROGRAM_RESET
    a ex:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ex:textoExtracto "El nombre de la subrutina debe ser PROGRAM_RESET (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." ;
    ex:identificador "PROGRAM_RESET" .

ex:Subrutina_PROGRAM_RESET_C1
    a ex:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET_C1" ;
    ex:textoExtracto "PROGRAM_RESET_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_RESET." ;
    ex:identificador "PROGRAM_RESET_C1" .

ex:Subrutina_PROGRAM_RESET_C2
    a ex:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET_C2" ;
    ex:textoExtracto "PROGRAM_RESET_C2 | Canal 2." ;
    ex:identificador "PROGRAM_RESET_C2" .

ex:Subrutina_PROGRAM_RESET_C3
    a ex:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET_C3" ;
    ex:textoExtracto "PROGRAM_RESET_C3 | Canal 3." ;
    ex:identificador "PROGRAM_RESET_C3" .

ex:Subrutina_PROGRAM_RESET_C4
    a ex:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET_C4" ;
    ex:textoExtracto "PROGRAM_RESET_C4 | Canal 4." ;
    ex:identificador "PROGRAM_RESET_C4" .

ex:Parametro_MINAENDW
    a ex:Parametro ;
    rdfs:label "Parámetro MINAENDW" ;
    ex:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." ;
    ex:identificador "MINAENDW" .

ex:InterfazUsuario_TeclaRESET
    a ex:InterfazUsuario ;
    rdfs:label "Tecla RESET" ;
    ex:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" ;
    ex:identificador "RESET" .

ex:Sistema_ProcesoReset
    a ex:Sistema ;
    rdfs:label "Proceso de reset del CNC" ;
    ex:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN (RESETIN=1). 2 El canal asume las condiciones iniciales (las definidas en los parámetros máquina). 3 El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. 4 El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." .

ex:Parametro_RESETIN
    a ex:Parametro ;
    rdfs:label "Marca RESETIN" ;
    ex:textoExtracto "El PLC activa la marca RESETIN (RESETIN=1)." ;
    ex:identificador "RESETIN" ;
    ex:valor "1" .

ex:Parametro_RESETOUT
    a ex:Parametro ;
    rdfs:label "Marca RESETOUT" ;
    ex:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." ;
    ex:identificador "RESETOUT" ;
    ex:valor "1" .

ex:Sistema_ProcesoReset
    ex:tieneComponente ex:InterfazUsuario_TeclaRESET ;
    ex:tieneComponente ex:Parametro_RESETIN ;
    ex:tieneComponente ex:Parametro_RESETOUT ;
    ex:tieneComponente ex:Parametro_MINAENDW ;
    ex:tieneComponente ex:Subrutina_PROGRAM_RESET ;
    ex:tieneComponente ex:Subrutina_PROGRAM_RESET_C1 ;
    ex:tieneComponente ex:Subrutina_PROGRAM_RESET_C2 ;
    ex:tieneComponente ex:Subrutina_PROGRAM_RESET_C3 ;
    ex:tieneComponente ex:Subrutina_PROGRAM_RESET_C4 .