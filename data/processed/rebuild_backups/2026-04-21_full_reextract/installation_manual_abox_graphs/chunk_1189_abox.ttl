@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Subrutina_9998
    a               ex:Sistema ;
    rdfs:label      "Subrutina 9998" ;
    ex:identificador "9998" ;
    ex:textoExtracto "Rutina que ejecutará el CNC al principio de cada programa del 8055-MC y 8055-TC." .

ex:Subrutina_9999
    a               ex:Sistema ;
    rdfs:label      "Subrutina 9999" ;
    ex:identificador "9999" ;
    ex:textoExtracto "Rutina que ejecutará el CNC al final de cada programa del 8055-MC y 8055-TC." .

ex:Programa_8055_MC
    a               ex:ModoOperacion ;
    rdfs:label      "Programa 8055-MC" ;
    ex:identificador "8055-MC" ;
    ex:textoExtracto "programa del 8055-MC" .

ex:Programa_8055_TC
    a               ex:ModoOperacion ;
    rdfs:label      "Programa 8055-TC" ;
    ex:identificador "8055-TC" ;
    ex:textoExtracto "programa del 8055-TC" .

ex:Subrutina_9998
    ex:habilitadoPor ex:Programa_8055_MC ;
    ex:habilitadoPor ex:Programa_8055_TC .

ex:Subrutina_9999
    ex:habilitadoPor ex:Programa_8055_MC ;
    ex:habilitadoPor ex:Programa_8055_TC .