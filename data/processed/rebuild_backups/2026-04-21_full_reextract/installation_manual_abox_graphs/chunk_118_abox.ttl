@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:MINAENDW
    a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:identificador "MINAENDW" ;
    ex:valor "10"^^xsd:integer ;
    ex:textoExtracto "MINAENDW Duración mínima de la señal AUXEND. Valores posibles: De 0 a 65535 ms. Valor por defecto: 10 ms." ;
    ex:textoExtracto "Este parámetro define el tiempo que mínimamente debe permanecer activa la señal AUXEND para que el CNC la interprete como señal válida." ;
    ex:textoExtracto "Para las funciones –M– que no necesitan sincronización, este parámetro indica la duración de la señal MSTROBE. Para las funciones –H– (que no necesitan sincronización) este parámetro indica la duración de la señal HSTROBE." .

ex:REFTIME
    a ex:Parametro ;
    rdfs:label "REFTIME" ;
    ex:identificador "REFTIME" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "REFTIME Tiempo estimado para la búsqueda de cero. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ex:textoExtracto "Consultar el parámetro máquina general TTIME." .

ex:HTIME
    a ex:Parametro ;
    rdfs:label "HTIME" ;
    ex:identificador "HTIME" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "HTIME Tiempo estimado para una función H. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ex:textoExtracto "Consultar el parámetro máquina general TTIME." .

ex:DTIME
    a ex:Parametro ;
    rdfs:label "DTIME" ;
    ex:identificador "DTIME" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "DTIME Tiempo estimado para una función D. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ex:textoExtracto "Consultar el parámetro máquina general TTIME." .

ex:TTIME
    a ex:Parametro ;
    rdfs:label "TTIME" ;
    ex:identificador "TTIME" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "TTIME Tiempo estimado para una función T. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." ;
    ex:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ex:se_al_AUXEND
    a ex:Parametro ;
    rdfs:label "AUXEND" ;
    ex:identificador "AUXEND" ;
    ex:textoExtracto "Se denomina AUXEND a la señal de sincronización que el PLC envía al CNC indicando que ha terminado la ejecución de las funciones auxiliares –M–, –S–, –T–." .

ex:se_al_MSTROBE
    a ex:Parametro ;
    rdfs:label "MSTROBE" ;
    ex:identificador "MSTROBE" ;
    ex:textoExtracto "Para las funciones –M– que no necesitan sincronización, este parámetro [MINAENDW] indica la duración de la señal MSTROBE." .

ex:se_al_HSTROBE
    a ex:Parametro ;
    rdfs:label "HSTROBE" ;
    ex:identificador "HSTROBE" ;
    ex:textoExtracto "Para las funciones –H– (que no necesitan sincronización) este parámetro [MINAENDW] indica la duración de la señal HSTROBE." .

ex:modo_edicion_simulacion
    a ex:ModoOperacion ;
    rdfs:label "Edición-Simulación" ;
    ex:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .