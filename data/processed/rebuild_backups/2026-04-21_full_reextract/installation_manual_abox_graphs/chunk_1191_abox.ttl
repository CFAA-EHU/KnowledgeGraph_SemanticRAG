@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:KinCal_Begin_nc
    a ex:TareaMantenimiento ;
    rdfs:label "KinCal_Begin.nc" ;
    ex:identificador "KinCal_Begin.nc" ;
    ex:textoExtracto "Subrutina asociada al inicio del ciclo de calibración de cinemática." ;
    ex:ejecutadoPor ex:Maquina_CNC .

ex:KinCal_End_nc
    a ex:TareaMantenimiento ;
    rdfs:label "KinCal_End.nc" ;
    ex:identificador "KinCal_End.nc" ;
    ex:textoExtracto "Subrutina asociada al final del ciclo de calibración de cinemática." ;
    ex:ejecutadoPor ex:Maquina_CNC .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El ciclo de calibración de cinemática tiene asociadas dos subrutinas (KinCal_Begin.nc y KinCal_End.nc) que el CNC ejecuta antes y después del ciclo." .