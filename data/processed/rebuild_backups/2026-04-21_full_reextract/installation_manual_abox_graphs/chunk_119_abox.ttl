@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TiempoEjecucion_MPG_TTIME
    a               ex:Parametro ;
    rdfs:label      "Tiempo de ejecución (MPG.TTIME)"@es ;
    ex:identificador "MPG.TTIME" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.TTIME [...] Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez."@es ;
    ex:valor         "0" ;
    ex:monitoreaParametro ex:ModoOperacion_EdicionSimulacion .

ex:ModoOperacion_EdicionSimulacion
    a               ex:ModoOperacion ;
    rdfs:label      "Modo edición-simulación"@es ;
    ex:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa."@es .