@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TOOLSUB_CHN
    a ex:Parametro ;
    rdfs:label "TOOLSUB CHN" ;
    ex:textoExtracto "TOOLSUB CHN | Subrutina asociada a la función T."@es ;
    ex:identificador "TOOLSUB CHN" ;
    ex:valor "Nombre y ubicación de la subrutina. Esta subrutina debe estar definida en el parámetro general TOOLSUB y estará guardada en la carpeta ..\\Mtb\\Sub."@es .

ex:Parametro_Canal
    a ex:Parametro ;
    rdfs:label "[CHN]" ;
    ex:textoExtracto "[CHN].......Parámetro máquina; general del canal."@es ;
    ex:identificador "[CHN]" ;
    ex:valor "Parámetro máquina; general del canal."@es .