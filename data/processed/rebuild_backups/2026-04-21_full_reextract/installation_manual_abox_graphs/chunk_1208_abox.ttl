@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPROGNAME_FUNM
    a ex:Parametro ;
    rdfs:label "MPROGNAME FUNM" ;
    ex:identificador "MPROGNAME FUNM" ;
    ex:textoExtracto "MPROGNAME FUNM | Nombre de subrutina asociada a la función M." ;
    ex:valor "Nombre de subrutina asociada a la función M" .

ex:Tabla_Funciones_M a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones \"M\"" ;
    ex:textoExtracto "[FUNM]....Parámetro máquina; tabla de funciones \"M\". Nombre y ubicación de la subrutina. Estas subrutinas deben estar definidas en la tabla de funciones \"M\", en el campo MPROGNAME" ;
    ex:tieneComponente ex:Parametro_MPROGNAME_FUNM .