PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_11_2_Variables a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables accesibles (PRG, PLC, INT)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:documentadoEn ex:Pagina_650 .

ex:Variable_MPM_MPROGNAME
    a ex:Parametro ;
    rdfs:label "MPM.MPROGNAME[pos]" ;
    ex:identificador "MPM.MPROGNAME[pos]" ;
    ex:textoExtracto "Nombre de subrutina asociada a la función M. Unidades: Texto."@es ;
    ex:valor "Texto (nombre de subrutina)"@es ;
    ex:documentadoEn ex:Tabla_14_11_2_Variables ;
    ex:ilustradoEn ex:Pagina_650 .

ex:Sintaxis_MPM_MPROGNAME
    a ex:InterfazUsuario ;
    rdfs:label "Sintaxis de MPM.MPROGNAME[pos]"@es ;
    ex:textoExtracto "Sintaxis. ꞏposꞏ Posición dentro de la tabla de funciones \"M\". | MPM.MPROGNAME[12] | Posición ꞏ12ꞏ de la tabla de funciones M."@es ;
    ex:documentadoEn ex:Tabla_14_11_2_Variables .