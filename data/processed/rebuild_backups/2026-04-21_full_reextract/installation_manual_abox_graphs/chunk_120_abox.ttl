@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SPDLTIME
    a ex:Parametro ;
    rdfs:label "SPDLTIME" ;
    ex:textoExtracto "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S." ;
    ex:valor "tiempo estimado para función S" .

ex:Parametro_MTIME
    a ex:Parametro ;
    rdfs:label "MTIME" ;
    ex:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M." ;
    ex:valor "tiempo estimado para función M" .

ex:Tabla_TiemposEjecucion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tiempos de ejecución de funciones (H, D, T, S, M)" ;
    ex:textoExtracto "el tiempo estimado para el proceso de determinadas funciones. Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez." ;
    ex:documentadoEn ex:Pagina_83 .