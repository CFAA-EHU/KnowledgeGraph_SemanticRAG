@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_OEMSUB_G180_G189
    a               ex:Parametro ;
    rdfs:label      "OEMSUB (G180-G189)" ;
    ex:textoExtracto "OEMSUB (G180) CHN [...] OEMSUB (G189) | Subrutinas asociadas a las funciones G180 a G189."@es ;
    ex:identificador "OEMSUB (G180-G189)" .

ex:Parametro_OEMSUB_G380_G399
    a               ex:Parametro ;
    rdfs:label      "OEMSUB (G380-G399)" ;
    ex:textoExtracto "OEMSUB (G380) CHN [...] OEMSUB (G399) | Subrutinas asociadas a las funciones G380 a G399."@es ;
    ex:identificador "OEMSUB (G380-G399)" .

ex:Parametro_CarpetaSubrutinas
    a               ex:Parametro ;
    rdfs:label      "Parámetro de carpeta de subrutinas" ;
    ex:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales OEMSUB y estarán guardadas en la carpeta ..\\Mtb\\Sub."@es ;
    ex:identificador "..\\Mtb\\Sub" ;
    ex:valor         "..\\Mtb\\Sub" .

ex:Parametro_ExtensionFST
    a               ex:Parametro ;
    rdfs:label      "Extensión de archivo de subrutinas en RAM" ;
    ex:textoExtracto "Estas subrutinas se pueden cargar en la memoria RAM (extensión fst)."@es ;
    ex:identificador "fst" ;
    ex:valor         "fst" .