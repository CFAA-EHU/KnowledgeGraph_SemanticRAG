PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_12_2_Variables a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables accesibles (PRG, PLC, INT) - Sección 14.12.2"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "14.12.2" .

ex:Parametro_OEMSUB1_a_OEMSUB10
    a ex:Parametro ;
    rdfs:label "Variables (V.)[ch].MPG.OEMSUB1 a (V.)[ch].MPG.OEMSUB10"@es ;
    ex:textoExtracto "(V.)[ch].MPG.OEMSUB1 ꞏꞏ (V.)[ch].MPG.OEMSUB10 - Subrutinas OEM asociadas a las funciones G180 a G189."@es ;
    ex:valor "R (solo lectura desde INT)" ;
    ex:documentadoEn ex:Tabla_14_12_2_Variables .

ex:Parametro_OEMSUB11_a_OEMSUB30
    a ex:Parametro ;
    rdfs:label "Variables (V.)[ch].MPG.OEMSUB11 a (V.)[ch].MPG.OEMSUB30"@es ;
    ex:textoExtracto "(V.)[ch].MPG.OEMSUB11 ꞏꞏ (V.)[ch].MPG.OEMSUB30 - Subrutinas OEM asociadas a las funciones G380 a G399."@es ;
    ex:valor "R (solo lectura desde INT)" ;
    ex:documentadoEn ex:Tabla_14_12_2_Variables .