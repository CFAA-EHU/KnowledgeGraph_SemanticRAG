ex:Sintaxis_AccesoVariables
    a ex:InterfazUsuario ;
    rdfs:label "Sintaxis de acceso a variables por canal"@es ;
    ex:textoExtracto "Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.INT1SUB | Canal ꞏ2ꞏ."@es ;
