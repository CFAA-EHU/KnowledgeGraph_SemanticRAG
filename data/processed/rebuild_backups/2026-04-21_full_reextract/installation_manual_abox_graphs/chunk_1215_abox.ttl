ex:Tabla_14_13_2_Variables a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables accesibles (PRG, MDI/MDA, PLC, INT)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "14.13.2" .

ex:Variable_MPG_INT1SUB
    a ex:Parametro ;
    rdfs:label "Subrutina de interrupción MPG.INT1SUB"@es ;
    ex:textoExtracto "(V.)[ch].MPG.INT1SUB — Subrutinas de interrupción. Unidades: Texto."@es ;
    ex:valor "Texto" ;
    ex:documentadoEn ex:Tabla_14_13_2_Variables .

