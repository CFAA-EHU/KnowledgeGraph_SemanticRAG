@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_INITIALSUB
    a ex:InterfazUsuario ;
    rdfs:label "Comando #INITIALSUB" ;
    ex:identificador "#INITIALSUB" ;
    ex:textoExtracto "El comando #INITIALSUB tiene una subrutina asociada, que el CNC ejecuta junto al comando." .

ex:SubrutinaInicializacionLaser
    a ex:ModoOperacion ;
    rdfs:label "Subrutina asociada al comando #INITIALSUB" ;
    ex:textoExtracto "Subrutina orientada al modelo láser. [...] debe realizar las operaciones iniciales del láser." ;
    ex:ejecutadoPor ex:Comando_INITIALSUB .

ex:MaquinaLaser
    a ex:Maquina ;
    rdfs:label "Máquina láser" ;
    ex:textoExtracto "Este comando está orientado a máquina láser, donde esta subrutina debe realizar las operaciones iniciales del láser." ;
    ex:tieneComponente ex:SubrutinaInicializacionLaser .