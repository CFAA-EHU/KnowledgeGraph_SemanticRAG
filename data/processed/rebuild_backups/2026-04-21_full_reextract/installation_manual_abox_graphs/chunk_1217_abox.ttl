@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INITIALSUB_CHN
    a ex:Parametro ;
    rdfs:label "INITIALSUB CHN" ;
    ex:textoExtracto "INITIALSUB CHN | Subrutina asociada al comando #INITIALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:identificador "INITIALSUB CHN" ;
    ex:valor "Subrutina asociada al comando #INITIALSUB" .

ex:Subrutina_Initialsub_fst
    a ex:Componente ;
    rdfs:label "Initialsub.fst" ;
    ex:textoExtracto "Esta subrutina debe estar definida en el parámetro general INITIALSUB (por defecto Initialsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub." ;
    ex:identificador "Initialsub.fst" .

ex:Parametro_INITIALSUB_CHN
    ex:monitoreaParametro ex:Subrutina_Initialsub_fst .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "el CNC actúa de la siguiente manera. [...] el CNC carga esta subrutina en la memoria RAM del CNC." ;
    ex:tieneComponente ex:Subrutina_Initialsub_fst .