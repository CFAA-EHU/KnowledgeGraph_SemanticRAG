@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_15_2_Variables a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables accesibles (PRG, MDI/MDA, PLC, INT)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "14.15.2" .

ex:Variable_MPG_PIERCING
    a ex:Parametro ;
    rdfs:label "V.[ch].MPG.PIERCING" ;
    ex:textoExtracto "Subrutina asociada al comando #PIERCING. Unidades: Texto."@es ;
    ex:valor "Subrutina asociada al comando #PIERCING"@es ;
    ex:documentadoEn ex:Tabla_14_15_2_Variables ;
    ex:identificador "[ch].MPG.PIERCING" .

ex:InterfazProgramacion
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación (PRG, MDI/MDA, PLC, INT)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa."@es ;
    ex:ilustradoEn ex:Tabla_14_15_2_Variables .