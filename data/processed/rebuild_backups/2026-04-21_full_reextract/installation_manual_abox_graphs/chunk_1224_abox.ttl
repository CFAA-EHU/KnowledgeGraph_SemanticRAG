@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_16_2_Variables a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables accesibles desde PRG, MDI/MDA, PLC e INT (Sección 14.16.2)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "14.16.2" .

ex:Parametro_CUTTINGON_Channel2
    a ex:Parametro ;
    rdfs:label "Variable [2].MPG.CUTTINGON (Canal 2)"@es ;
    ex:textoExtracto "(V.)[ch].MPG.CUTTINGON - Subrutina asociada al comando #CUTTING ON. Unidades: Texto."@es ;
    ex:identificador "[2].MPG.CUTTINGON" ;
    ex:valor "Canal 2"@es ;
    ex:documentadoEn ex:Tabla_14_16_2_Variables .

ex:Parametro_CUTTINGOFF_Channel2
    a ex:Parametro ;
    rdfs:label "Variable [2].MPG.CUTTINGOFF (Canal 2)"@es ;
    ex:textoExtracto "(V.)[ch].MPG.CUTTINGOFF - Subrutina asociada al comando #CUTTINGOFF. Unidades: Texto."@es ;
    ex:identificador "[2].MPG.CUTTINGOFF" ;
    ex:valor "Canal 2"@es ;
    ex:documentadoEn ex:Tabla_14_16_2_Variables .