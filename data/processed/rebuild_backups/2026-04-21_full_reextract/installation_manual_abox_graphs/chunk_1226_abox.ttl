@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FINALSUB_CHN
    a ex:Parametro ;
    rdfs:label "FINALSUB CHN" ;
    ex:textoExtracto "FINALSUB CHN | Subrutina asociada al comando #FINALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:identificador "FINALSUB CHN" ;
    ex:valor "Finalsub.fst" .

ex:Subrutina_Finalsub_fst
    a ex:Componente ;
    rdfs:label "Subrutina Finalsub.fst" ;
    ex:textoExtracto "Esta subrutina debe estar definida en el parámetro general FINALSUB (por defecto Finalsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." ;
    ex:identificador "Finalsub.fst" .

ex:Parametro_FINALSUB_CHN
    ex:monitoreaParametro ex:Subrutina_Finalsub_fst .