@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_17_2_Variables a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de variables accesibles (PRG, PLC, INT)"@es ;
    ex:textoExtracto """
    Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W).
    | Variable. | PRG | PLC | INT |
    | --- | --- | --- | --- |
    | (V.)[ch].MPG.FINALSUB | - | - | R |
    """^^rdf:XMLLiteral .

ex:Variable_MPG_FINALSUB
    a               ex:Parametro ;
    rdfs:label      "V.[ch].MPG.FINALSUB"@es ;
    ex:identificador "V.[ch].MPG.FINALSUB" ;
    ex:textoExtracto """
    (V.)[ch].MPG.FINALSUB
    Subrutina asociada al comando #FINALSUB. Unidades: Texto.
    """^^rdf:XMLLiteral ;
    ex:documentadoEn ex:Tabla_14_17_2_Variables ;
    ex:valor         "Texto" .

ex:ModoOperacion_PRG
    a               ex:ModoOperacion ;
    rdfs:label      "Modo PRG (programa pieza)"@es ;
    ex:textoExtracto "accesibles desde; (PRG) el programa pieza"^^rdf:XMLLiteral .

ex:ModoOperacion_PLC
    a               ex:ModoOperacion ;
    rdfs:label      "Modo PLC"@es ;
    ex:textoExtracto "accesibles desde [...] PLC"^^rdf:XMLLiteral .

ex:ModoOperacion_INT
    a               ex:ModoOperacion ;
    rdfs:label      "Modo INT (aplicación externa)"@es ;
    ex:textoExtracto "accesibles desde [...] (INT) una aplicación externa"^^rdf:XMLLiteral .