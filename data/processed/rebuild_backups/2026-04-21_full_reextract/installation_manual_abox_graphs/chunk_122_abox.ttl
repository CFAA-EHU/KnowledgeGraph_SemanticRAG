@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NDOMOD
    a ex:Parametro ;
    rdfs:label "NDOMOD" ;
    ex:textoExtracto "NDOMOD Número total de módulos de salidas digitales. Valores posibles: De 0 a 64. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDOMOD Este parámetro indica la cantidad de módulos de salidas digitales conectados en el bus CAN." ;
    ex:valor "0" ;
    ex:identificador "(V.)MPG.NDOMOD" .

ex:Parametro_DOMOD
    a ex:Parametro ;
    rdfs:label "DOMOD" ;
    ex:textoExtracto "DOMOD n Índice base de los módulos de salidas digitales. Valores posibles: De 0 a 1009. Valor por defecto: El primer valor válido. Variable asociada: (V.)MPG.DOMODADDR[nb]." ;
    ex:identificador "(V.)MPG.DOMODADDR[nb]" .

ex:Tabla_DOMODADDR a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "DOMODADDR" ;
    ex:textoExtracto "DOMODADDR Tabla de módulos de salidas digitales. Este parámetro muestra la lista de módulos de salidas digitales conectados en el mismo bus CAN." ;
    ex:identificador "DOMODADDR" .

ex:Sistema_BusCAN
    a ex:Sistema ;
    rdfs:label "Bus CAN" ;
    ex:textoExtracto "bus CAN" ;
    ex:tieneComponente ex:Tabla_DOMODADDR ;
    ex:monitoreaParametro ex:Parametro_NDOMOD ;
    ex:monitoreaParametro ex:Parametro_DOMOD .