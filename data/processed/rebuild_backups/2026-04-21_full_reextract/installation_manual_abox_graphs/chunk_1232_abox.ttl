ex:SubrutinaGlobal_MCALL
    a ex:ModoOperacion ;
    rdfs:label "Subrutina global llamada mediante #MCALL"@es ;
    ex:identificador "#MCALL" ;
    ex:textoExtracto "subrutina global llamada mediante #MCALL ó #PCALL se les puede asociar ficheros de ayuda que se mostrarán durante la edición."@es ;
    ex:documentadoEn ex:FicheroAyudaTextoSubrutina ;
    ex:ilustradoEn ex:FicheroAyudaDibujoSubrutina .

