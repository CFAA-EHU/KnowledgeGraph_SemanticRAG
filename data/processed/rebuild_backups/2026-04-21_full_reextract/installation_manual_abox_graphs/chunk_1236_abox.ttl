@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ListaSubrutinas_pcall
    a ex:InterfazUsuario ;
    rdfs:label "Lista pcall.txt" ;
    ex:textoExtracto "la lista pcall.txt mostrará los nombres de subrutinas contenidos en ambos" ;
    ex:identificador "pcall.txt" .

ex:DirectivaVersionCNC_8060
    a ex:Directiva ;
    rdfs:label "Versión V1.60 (8060)" ;
    ex:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas" ;
    ex:identificador "V1.60 (8060)" .

ex:DirectivaVersionCNC_8065
    a ex:Directiva ;
    rdfs:label "Versión V5.60 (8065)" ;
    ex:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas" ;
    ex:identificador "V5.60 (8065)" .