@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_ConfiguracionPrestacion
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de prestación (CNC)"@es ;
    ex:textoExtracto "C . N . C . N . C . N . C . IIIIIII 1234567 IIIIIII 1234567 [...] ERRORREWRAEONDERYTR .1111111 . .1111111 [...] ADDRESSRESET [...] DIGITAL OUTPUT [...] LIANDED MERSMB01"@es ;
    ex:identificador "CNC_ConfigPanel_15.1.1" ;
    ex:ilustradoEn ex:Esquema_ConfiguracionPrestacion_1239 .

ex:Esquema_ConfiguracionPrestacion_1239
    a ex:Esquema ;
    rdfs:label "Esquema de conexionado para configuración (Págs. 665-669)"@es ;
    ex:textoExtracto "X1 X1 X1 X1 [...] OVE R V OS5OV VYL EST RTAE GM5U E [...] + 24V [...] GND [...] DIGITAL OUTPUT [...] LIANDED MERSMB01 [...] SSCCHHAAGIIEENNNLL DDHDL"@es ;
    ex:identificador "Fig15.1.1_ConfigPrestacion" .

ex:ComponenteElectrico_X1_Configuracion
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X1 (Entrada/Salida principal)"@es ;
    ex:textoExtracto "X1 X1 X1 X1 [...] 1234567 [...] +5 +C [...] GND"@es ;
    ex:identificador "X1_CNC_Config" ;
    ex:detalladoEnEsquema ex:Esquema_ConfiguracionPrestacion_1239 .

ex:ComponenteElectrico_X2_Configuracion
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X2 (Reset/Address)"@es ;
    ex:textoExtracto "X2 X2 X2 X2 [...] ADDRESS RESET [...] GND"@es ;
    ex:identificador "X2_CNC_Config" ;
    ex:detalladoEnEsquema ex:Esquema_ConfiguracionPrestacion_1239 .

ex:ComponenteElectrico_DigitalOutput
    a ex:ComponenteElectrico ;
    rdfs:label "Salida digital (24V)"@es ;
    ex:textoExtracto "DIGITAL OUTPUT [...] + 24 V + 24 V + 24 V"@es ;
    ex:identificador "DO_MERSMB01" ;
    ex:detalladoEnEsquema ex:Esquema_ConfiguracionPrestacion_1239 .

ex:ComponenteElectrico_ModuloLIANDED
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo LIANDED MERSMB01"@es ;
    ex:textoExtracto "LIANDED MERSMB01 [...] 21 21 [...] + 24V"@es ;
    ex:identificador "MERSMB01" ;
    ex:detalladoEnEsquema ex:Esquema_ConfiguracionPrestacion_1239 .

ex:ComponenteElectrico_Schneider_DDHL
    a ex:ComponenteElectrico ;
    rdfs:label "Componente Schneider (DDHL)"@es ;
    ex:textoExtracto "SSCCHHAAGIIEENNNLL DDHDL [...] 4ON VD"@es ;
    ex:identificador "DDHL_Schneider" ;
    ex:detalladoEnEsquema ex:Esquema_ConfiguracionPrestacion_1239 .