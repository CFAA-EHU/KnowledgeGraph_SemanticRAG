@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametrosJog_1243
    a               ex:Parametro ;
    rdfs:label      "Parámetros de Jog del CNC"@es ;
    ex:textoExtracto "El CNC siempre ofrece 16 parámetros; si el teclado de jog dispone de menos teclas, los parámetros que no tengan asociada ninguna tecla no tendrán ninguna función."@es ;
    ex:identificador "16" ;
    ex:ilustradoEn   ex:TablaAsignacionTeclasJog_1243 .

ex:TablaAsignacionTeclasJog_1243 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de relación entre módulo hardware y teclas de usuario (JOG-PANEL)"@es ;
    ex:textoExtracto "La relación entre estos parámetros y las teclas de usuario es la siguiente. | Módulo hardware. | Teclas de usuario. | | --- | --- | | JOG-PANEL | 1 2 15 16 | GKEYS | O | J |"@es .

ex:InterfazJogPanel_1243
    a               ex:InterfazUsuario ;
    rdfs:label      "JOG-PANEL"@es ;
    ex:textoExtracto "JOG-PANEL"@es ;
    ex:tieneComponente ex:TeclaJog_1_1243, ex:TeclaJog_2_1243, ex:TeclaJog_15_1243, ex:TeclaJog_16_1243 .

ex:TeclaJog_1_1243
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tecla de usuario 1 (JOG-PANEL)"@es ;
    ex:textoExtracto "1"@es ;
    ex:identificador "1" .

ex:TeclaJog_2_1243
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tecla de usuario 2 (JOG-PANEL)"@es ;
    ex:textoExtracto "2"@es ;
    ex:identificador "2" .

ex:TeclaJog_15_1243
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tecla de usuario 15 (JOG-PANEL)"@es ;
    ex:textoExtracto "15"@es ;
    ex:identificador "15" .

ex:TeclaJog_16_1243
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tecla de usuario 16 (JOG-PANEL)"@es ;
    ex:textoExtracto "16"@es ;
    ex:identificador "16" .