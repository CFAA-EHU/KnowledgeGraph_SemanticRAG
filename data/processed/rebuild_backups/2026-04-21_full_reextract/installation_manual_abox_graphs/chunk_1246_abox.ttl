@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionPrestacion_15_1_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros PLC para configuración de prestación (Sección 15.1.1)"@es ;
    ex:textoExtracto """
| Marca y registros de PLC. | Significado. |
| --- | --- |
| KEYDIS1 a KEYDIS3 | Estos registros inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente.
| KEYDIS1_1 a KEYDIS3_1 ꞏꞏ KEYDIS1_8 a KEYDIS3_8 | Estos registros inhiben (bit=1) las teclas y los conmutadores en cada panel de mando.
| KEYLED1 / KEYLED2 | Estos registros controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente.
| KEYLED1_1 / KEYLED2_1 ꞏꞏ KEYLED1_8 / KEYLED2_8 | Estos registros controlan los led (lámparas) de las teclas de cada panel de mando."""@es ;
    ex:documentadoEn ex:Pagina_665_669 .

ex:Sistema_ControlPanelesMando
    a ex:Sistema ;
    rdfs:label "Sistema de control de paneles de mando (KEYDIS/KEYLED)"@es ;
    ex:textoExtracto "Los registros KEYDIS1, KEYDIS2 y KEYDIS3 inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente. Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente."@es ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionPrestacion_15_1_1 .

ex:Parametro_KEYDIS1
    a ex:Parametro ;
    rdfs:label "KEYDIS1"@es ;
    ex:identificador "KEYDIS1" ;
    ex:textoExtracto "Registro PLC que inhibe (bit=1) las teclas y conmutadores en todos los paneles de mando simultáneamente."@es ;
    ex:monitoreaParametro ex:Sistema_ControlPanelesMando .

ex:Parametro_KEYDIS2
    a ex:Parametro ;
    rdfs:label "KEYDIS2"@es ;
    ex:identificador "KEYDIS2" ;
    ex:textoExtracto "Registro PLC que inhibe (bit=1) las teclas y conmutadores en todos los paneles de mando simultáneamente."@es ;
    ex:monitoreaParametro ex:Sistema_ControlPanelesMando .

ex:Parametro_KEYDIS3
    a ex:Parametro ;
    rdfs:label "KEYDIS3"@es ;
    ex:identificador "KEYDIS3" ;
    ex:textoExtracto "Registro PLC que inhibe (bit=1) las teclas y conmutadores en todos los paneles de mando simultáneamente."@es ;
    ex:monitoreaParametro ex:Sistema_ControlPanelesMando .

ex:Parametro_KEYLED1
    a ex:Parametro ;
    rdfs:label "KEYLED1"@es ;
    ex:identificador "KEYLED1" ;
    ex:textoExtracto "Registro PLC que controla los led (lámparas) de las teclas de todos los paneles de mando simultáneamente."@es ;
    ex:monitoreaParametro ex:Sistema_ControlPanelesMando .

ex:Parametro_KEYLED2
    a ex:Parametro ;
    rdfs:label "KEYLED2"@es ;
    ex:identificador "KEYLED2" ;
    ex:textoExtracto "Registro PLC que controla los led (lámparas) de las teclas de todos los paneles de mando simultáneamente."@es ;
    ex:monitoreaParametro ex:Sistema_ControlPanelesMando .

ex:InterfazUsuario_PanelesMando
    a ex:InterfazUsuario ;
    rdfs:label "Paneles de mando (teclas, conmutadores y leds)"@es ;
    ex:textoExtracto "Interfaz compuesta por teclas, conmutadores y leds (lámparas) distribuidos en múltiples paneles de mando (hasta 8)."@es ;
    ex:controla ex:Sistema_ControlPanelesMando ;
    ex:compuestoPor ex:ComponenteElectrico_TeclasConmutadores ,
                    ex:ComponenteElectrico_LedsIndicadores .