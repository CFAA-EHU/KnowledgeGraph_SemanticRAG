@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Registro_KEYLED1
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1" ;
    ex:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." ;
    ex:identificador "KEYLED1" ;
    ex:controla ex:LamparasTeclas_Global .

ex:Registro_KEYLED2
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2" ;
    ex:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." ;
    ex:identificador "KEYLED2" ;
    ex:controla ex:LamparasTeclas_Global .

ex:LamparasTeclas_Global
    a ex:ComponenteElectrico ;
    rdfs:label "Lámparas de teclas (todos los paneles)" ;
    ex:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ex:Registro_KEYLED1_n
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_n (por panel)" ;
    ex:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." ;
    ex:identificador "KEYLED1_n" ;
    ex:controla ex:LamparasTeclas_PanelIndividual .

ex:Registro_KEYLED2_n
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_n (por panel)" ;
    ex:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." ;
    ex:identificador "KEYLED2_n" ;
    ex:controla ex:LamparasTeclas_PanelIndividual .

ex:LamparasTeclas_PanelIndividual
    a ex:ComponenteElectrico ;
    rdfs:label "Lámparas de teclas (por panel individual)" ;
    ex:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." .

ex:Registro_KEYLED1_1
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_1 (primer panel de jog)" ;
    ex:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" ;
    ex:identificador "KEYLED1_1" .

ex:Registro_KEYLED2_1
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_1 (primer panel de jog)" ;
    ex:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" ;
    ex:identificador "KEYLED2_1" .

ex:Registro_KEYLED1_2
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_2 (segundo panel de jog)" ;
    ex:textoExtracto "KEYLED1_2 y KEYLED2_2 al segundo [panel de jog]" ;
    ex:identificador "KEYLED1_2" .

ex:Registro_KEYLED2_2
    a ex:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_2 (segundo panel de jog)" ;
    ex:textoExtracto "KEYLED1_2 y KEYLED2_2 al segundo [panel de jog]" ;
    ex:identificador "KEYLED2_2" .

ex:PanelJog_1
    a ex:InterfazUsuario ;
    rdfs:label "Primer panel de jog" ;
    ex:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" ;
    ex:tieneComponente ex:Registro_KEYLED1_1, ex:Registro_KEYLED2_1 .

ex:PanelJog_2
    a ex:InterfazUsuario ;
    rdfs:label "Segundo panel de jog" ;
    ex:textoExtracto "KEYLED1_2 y KEYLED2_2 al segundo [panel de jog]" ;
    ex:tieneComponente ex:Registro_KEYLED1_2, ex:Registro_KEYLED2_2 .