@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionPanelesJog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de paneles de jog mediante registros PLC"@es ;
    ex:textoExtracto """
| Marca y registros de PLC. | Significado. |
| --- | --- |
| KEYBD1CH a KEYBD8CH | Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina.
...
| 0 | Configuración definida en los parámetros máquina. |
| 1 | Panel de jog asignado al canal 1. |
...
| FF | Panel de jog asignado al canal activo. |
...
| PANELOFF PANELOFF1 a PANELOFF8 | Si el PLC pone una de estas marcas a (=1) se deshabilita el panel de jog correspondiente."""@es .

ex:Parametro_KEYBD1CH
    a ex:Parametro ;
    rdfs:label "Registro KEYBD1CH"@es ;
    ex:identificador "KEYBD1CH" ;
    ex:valor "0" , "1" , "2" , "3" , "4" , "FF" ;
    ex:textoExtracto "KEYBD1CH a KEYBD8CH: Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPanelesJog .

ex:Parametro_PANELOFF1
    a ex:Parametro ;
    rdfs:label "Registro PANELOFF1"@es ;
    ex:identificador "PANELOFF1" ;
    ex:valor "0" , "1" ;
    ex:textoExtracto "PANELOFF1: Si el PLC pone esta marca a (=1) se deshabilita el panel de jog correspondiente (primer panel del bus CAN)."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPanelesJog .

ex:InterfazUsuario_PanelJog_1
    a ex:InterfazUsuario ;
    rdfs:label "Panel de jog 1 (bus CAN)"@es ;
    ex:textoExtracto "Panel de jog integrado en el bus CAN, controlable mediante registros KEYBD1CH y PANELOFF1."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPanelesJog .

ex:Sistema_BusCAN
    a ex:Sistema ;
    rdfs:label "Bus CAN de interfaz de usuario"@es ;
    ex:textoExtracto "Bus CAN que integra paneles de jog y teclados. Cada marca PANELOFF afecta solo al panel de jog correspondiente sin alterar otros elementos del bus."@es ;
    ex:tieneComponente ex:InterfazUsuario_PanelJog_1 ;
    ex:documentadoEn ex:Tabla_ConfiguracionPanelesJog .

ex:Parametro_KEYBD1CH
    ex:controla ex:InterfazUsuario_PanelJog_1 .

ex:Parametro_PANELOFF1
    ex:controla ex:InterfazUsuario_PanelJog_1 .