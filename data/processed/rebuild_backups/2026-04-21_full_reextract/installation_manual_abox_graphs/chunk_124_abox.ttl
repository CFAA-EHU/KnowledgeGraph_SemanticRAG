@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_NumeracionEntradasDigitales_CANopen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de numeración de entradas digitales (bus CANopen)"@es ;
    ex:textoExtracto """
| Columna. | Significado. |
| --- | --- |
| MNEMONIC | Mnemónico del bloque lógico. |
| NODE | Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os. |
| BLOCK | Número de bloque lógico. |
| ADDRESS | Dirección base del bloque lógico. |
| NDI | Número de entradas digitales del módulo.
"""@es ;
    ex:identificador "2.3.21" .

ex:Parametro_MNEMONIC
    a ex:Parametro ;
    rdfs:label "MNEMONIC" ;
    ex:textoExtracto "Mnemónico del bloque lógico."@es ;
    ex:documentadoEn ex:Tabla_NumeracionEntradasDigitales_CANopen .

ex:Parametro_NODE
    a ex:Parametro ;
    rdfs:label "NODE" ;
    ex:textoExtracto "Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os."@es ;
    ex:documentadoEn ex:Tabla_NumeracionEntradasDigitales_CANopen .

ex:Parametro_BLOCK
    a ex:Parametro ;
    rdfs:label "BLOCK" ;
    ex:textoExtracto "Número de bloque lógico."@es ;
    ex:documentadoEn ex:Tabla_NumeracionEntradasDigitales_CANopen .

ex:Parametro_ADDRESS
    a ex:Parametro ;
    rdfs:label "ADDRESS" ;
    ex:textoExtracto "Dirección base del bloque lógico."@es ;
    ex:documentadoEn ex:Tabla_NumeracionEntradasDigitales_CANopen .

ex:Parametro_NDI
    a ex:Parametro ;
    rdfs:label "NDI" ;
    ex:textoExtracto "Número de entradas digitales del módulo."@es ;
    ex:documentadoEn ex:Tabla_NumeracionEntradasDigitales_CANopen .