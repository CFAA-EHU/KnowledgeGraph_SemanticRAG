@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SoftkeyHelper_txt
    a ex:InterfazUsuario ;
    rdfs:label "SoftkeyHelper.txt" ;
    ex:textoExtracto "Los textos de ayuda están definidos en el archivo SoftkeyHelper.txt, y puede haber un archivo por cada idioma, los cuales se guardan en la carpeta \"..\\MTB\\data\\Lang\"." ;
    ex:identificador "SoftkeyHelper.txt" .

ex:ModoAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "[ AUTOMATIC MODE]" ;
    ex:ilustradoEn ex:SoftkeyHelper_txt .

ex:Softkey_AUTO1
    a ex:InterfazUsuario ;
    rdfs:label "AUTO1" ;
    ex:textoExtracto "AUTO1=Seleccionar programa" ;
    ex:documentadoEn ex:SoftkeyHelper_txt ;
    ex:habilitadoPor ex:ModoAutomatico .

