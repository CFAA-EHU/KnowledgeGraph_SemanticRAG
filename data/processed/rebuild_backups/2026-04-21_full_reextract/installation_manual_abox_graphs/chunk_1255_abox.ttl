@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto RCS-S" ;
    ex:textoExtracto "El módulo \"RCS-S\" permite disponer de un número adicional de entradas de contaje y salidas analógicas (I/Os remotas). Estos módulos se conectan a la unidad central a través del bus Sercos-II, siendo un nodo más dentro del bus." ;
    ex:identificador "RCS-S" .

ex:RCS_S_4F4AO
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S-4F4AO" ;
    ex:textoExtracto "4 entradas de contaje. - Señal incremental TTL, TTL diferencial y Vpp. - Protocolo SSI, FeeDat, EnDat 2.1 y EnDat 2.2. 4 salidas analógicas ±10 V (16 bits) de propósito general." ;
    ex:identificador "RCS-S-4F4AO" ;
    ex:tieneComponente ex:E21A, ex:E21B, ex:E21C, ex:E21D, ex:I37A, ex:I37B .

ex:E21A
    a ex:ComponenteElectrico ;
    rdfs:label "Conector E21A" ;
    ex:textoExtracto "Conector ꞏE21Aꞏ. Entrada de contaje." ;
    ex:identificador "E21A" .

ex:E21B
    a ex:ComponenteElectrico ;
    rdfs:label "Conector E21B" ;
    ex:textoExtracto "Conector ꞏE21Bꞏ. Entrada de contaje." ;
    ex:identificador "E21B" .

ex:E21C
    a ex:ComponenteElectrico ;
    rdfs:label "Conector E21C" ;
    ex:textoExtracto "Conector ꞏE21Cꞏ. Entrada de contaje." ;
    ex:identificador "E21C" .

ex:E21D
    a ex:ComponenteElectrico ;
    rdfs:label "Conector E21D" ;
    ex:textoExtracto "Conector ꞏE21Dꞏ. Entrada de contaje." ;
    ex:identificador "E21D" .

ex:I37A
    a ex:ComponenteElectrico ;
    rdfs:label "Conector I37A" ;
    ex:textoExtracto "Conector ꞏI37Aꞏ. 2 salidas analógicas de propósito general." ;
    ex:identificador "I37A" .

ex:I37B
    a ex:ComponenteElectrico ;
    rdfs:label "Conector I37B" ;
    ex:textoExtracto "Conector ꞏI37Bꞏ. 2 salidas analógicas de propósito general." ;
    ex:identificador "I37B" .

ex:Tabla_Especificaciones_RCS_S
    a ex:Tabla ;
    rdfs:label "Tabla de especificaciones del módulo RCS-S" ;
    ex:textoExtracto "Módulo | Descripción. | --- | --- | RCS-S-4F4AO | 4 entradas de contaje. - Señal incremental TTL, TTL diferencial y Vpp. - Protocolo SSI, FeeDat, EnDat 2.1 y EnDat 2.2. 4 salidas analógicas ±10 V (16 bits) de propósito general." ;
    ex:documentadoEn ex:RCS_S_4F4AO .