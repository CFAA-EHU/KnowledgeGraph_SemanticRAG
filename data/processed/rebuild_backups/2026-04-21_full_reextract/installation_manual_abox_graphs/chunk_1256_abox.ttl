@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloContadoraSercos
    a               ex:ComponenteElectrico ;
    rdfs:label      "Contadora Sercos"@es ;
    ex:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos. Desde el punto de vista de parametrización, las contadoras Sercos tienen una doble identificación, física y lógica"@es ;
    ex:monitoreaParametro ex:Parametro_NSERCOUNT, ex:Parametro_SERCOUNTID .

ex:Parametro_NSERCOUNT
    a               ex:Parametro ;
    rdfs:label      "NSERCOUNT" ;
    ex:identificador "NSERCOUNT" ;
    ex:textoExtracto "Número de nodos contadoras Sercos en el bus"@es ;
    ex:valor        "1..8" .

ex:Parametro_SERCOUNTID
    a               ex:Parametro ;
    rdfs:label      "SERCOUNTID" ;
    ex:identificador "SERCOUNTID" ;
    ex:textoExtracto "Tabla de identificadores de la ruleta asociadas a las contadoras Sercos"@es .

ex:Tabla_SERCOUNTID a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla SERCOUNTID"@es ;
    ex:textoExtracto "La tabla SERCOUNTID de los parámetros máquina generales, nos permite enlazar la numeración lógica de las contadoras Sercos (1..8) con la numeración física determinada por la ruleta de cada nodo"@es ;
    ex:documentadoEn ex:Pagina_675 .

ex:Pagina_675
    a               ex:Pagina ;
    rdfs:label      "Página 675" ;
    ex:identificador "675" ;
    ex:textoExtracto "Sección 15.4.1 Configurar el módulo como un nodo del bus Sercos"@es .