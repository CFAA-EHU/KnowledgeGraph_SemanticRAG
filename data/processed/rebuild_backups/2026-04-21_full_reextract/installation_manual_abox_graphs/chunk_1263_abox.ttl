@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrizacionEjes a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parametrización de ejes (pág. 678-679)"@es ;
    ex:textoExtracto """
| Eje. | Parámetro. | Valor. |
| --- | --- | --- |
| Eje X. | DRIVETYPE, COUNTERTYPE, COUNTERID, ANAOUTTYPE, ANAOUTID | Analógico, Contadora Sercos, 5, Contadora Sercos, 6 |
| Eje Y. | DRIVETYPE, COUNTERTYPE, COUNTERID, ANAOUTTYPE, ANAOUTID | Analógico, Contadora Sercos, 3, Contadora Sercos, 5 |
| Eje Z. | DRIVETYPE, COUNTERTYPE, COUNTERID, ANAOUTTYPE, ANAOUTID | Analógico, Contadora Sercos, 1, Contadora Sercos, 4 |
| Eje U. | DRIVETYPE, DRIVEID, OPMODEP, FBACKSRC, COUNTERTYPE, COUNTERID | Sercos, 2, Velocidad, Externa, Contadora Sercos, 2 |
| Eje V. | DRIVETYPE, DRIVEID | Sercos, 1 |
| Volante | MANPG, COUNTERTYPE, COUNTERID | 1, Contadora Sercos, 6 |
| Cabezal S | DRIVETYPE, DRIVEID | Sercos, 4 |
""" .

### Parametros extraidos (solo los mas especificos y justificables)
ex:Parametro_Drivetype_EjeX
    a ex:Parametro ;
    rdfs:label "DRIVETYPE (Eje X)"@es ;
    ex:identificador "DRIVETYPE" ;
    ex:valor "Analógico" ;
    ex:textoExtracto "Eje X [...] DRIVETYPE [...] Analógico" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .

ex:Parametro_Countertype_EjeX
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE (Eje X)"@es ;
    ex:identificador "COUNTERTYPE" ;
    ex:valor "Contadora Sercos" ;
    ex:textoExtracto "Eje X [...] COUNTERTYPE [...] Contadora Sercos" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .

ex:Parametro_Counterid_EjeX_5
    a ex:Parametro ;
    rdfs:label "COUNTERID (Eje X, valor 5)"@es ;
    ex:identificador "COUNTERID" ;
    ex:valor "5" ;
    ex:textoExtracto "Eje X [...] COUNTERID [...] 5" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .

ex:Parametro_Drivetype_EjeU
    a ex:Parametro ;
    rdfs:label "DRIVETYPE (Eje U)"@es ;
    ex:identificador "DRIVETYPE" ;
    ex:valor "Sercos" ;
    ex:textoExtracto "Eje U [...] DRIVETYPE [...] Sercos" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .

ex:Parametro_Opmodep_EjeU
    a ex:Parametro ;
    rdfs:label "OPMODEP (Eje U)"@es ;
    ex:identificador "OPMODEP" ;
    ex:valor "Velocidad" ;
    ex:textoExtracto "Eje U [...] OPMODEP [...] Velocidad" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .

ex:Parametro_Driveid_CabezalS
    a ex:Parametro ;
    rdfs:label "DRIVEID (Cabezal S)"@es ;
    ex:identificador "DRIVEID" ;
    ex:valor "4" ;
    ex:textoExtracto "Cabezal S [...] DRIVEID [...] 4" ;
    ex:documentadoEn ex:TablaParametrizacionEjes .