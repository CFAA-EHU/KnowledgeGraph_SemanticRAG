@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosCANopen_1265 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros para configuración de entradas/salidas digitales CANopen"@es ;
    ex:textoExtracto """
    | Parámetro. | Significado. |
    | --- | --- |
    | NDIMOD | Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0). |
    | DIMODADDR | Direcciones base de los bloques lógicos de entradas digitales. |
    | MNEMONIC | Mnemónico del bloque lógico. |
    | NODE | Número de nodo de la cabecera al que pertenece el bloque lógico. Valores posibles: De 1 a 126 (por defecto; 0). |
    | BLOCK | Número de bloque lógico. Valores posibles: De 1 a 64 (por defecto; 0). |
    | ADDRESS | Dirección base del bloque lógico. Valores posibles: De 1 a 1017 (por defecto; el primer valor válido). |
    | NDI | Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0)."""@es .

ex:Parametro_NDIMOD
    a               ex:Parametro ;
    rdfs:label      "NDIMOD" ;
    ex:identificador "NDIMOD" ;
    ex:valor        "0..42" ;
    ex:textoExtracto "Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_DIMODADDR
    a               ex:Parametro ;
    rdfs:label      "DIMODADDR" ;
    ex:identificador "DIMODADDR" ;
    ex:textoExtracto "Direcciones base de los bloques lógicos de entradas digitales."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_MNEMONIC
    a               ex:Parametro ;
    rdfs:label      "MNEMONIC" ;
    ex:identificador "MNEMONIC" ;
    ex:textoExtracto "Mnemónico del bloque lógico."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_NODE
    a               ex:Parametro ;
    rdfs:label      "NODE" ;
    ex:identificador "NODE" ;
    ex:valor        "1..126" ;
    ex:textoExtracto "Número de nodo de la cabecera al que pertenece el bloque lógico. Valores posibles: De 1 a 126 (por defecto; 0)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_BLOCK
    a               ex:Parametro ;
    rdfs:label      "BLOCK" ;
    ex:identificador "BLOCK" ;
    ex:valor        "1..64" ;
    ex:textoExtracto "Número de bloque lógico. Valores posibles: De 1 a 64 (por defecto; 0)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_ADDRESS
    a               ex:Parametro ;
    rdfs:label      "ADDRESS" ;
    ex:identificador "ADDRESS" ;
    ex:valor        "1..1017" ;
    ex:textoExtracto "Dirección base del bloque lógico. Valores posibles: De 1 a 1017 (por defecto; el primer valor válido)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .

ex:Parametro_NDI
    a               ex:Parametro ;
    rdfs:label      "NDI" ;
    ex:identificador "NDI" ;
    ex:valor        "8..1024 (múltiplo de 8)" ;
    ex:textoExtracto "Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCANopen_1265 .