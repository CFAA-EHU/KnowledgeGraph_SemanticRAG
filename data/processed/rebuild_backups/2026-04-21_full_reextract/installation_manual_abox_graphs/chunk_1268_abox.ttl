PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_1268
    a                     ex:Sistema ;
    rdfs:label            "PLC con gestión de bus CANopen"@es ;
    ex:textoExtracto      "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus."@es ;
    ex:identificador       "1...1024" .  # Rango de recursos gestionados