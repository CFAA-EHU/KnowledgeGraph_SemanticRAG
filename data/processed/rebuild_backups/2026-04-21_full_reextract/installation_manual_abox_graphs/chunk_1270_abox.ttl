ex:ModuloEntradasDigitales_24I_N3_2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 3, módulo 2)"@es ;
    ex:textoExtracto "2 módulos de 24 entradas digitales"@es ;
