@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Nodo2_RIO5
    a ex:Sistema ;
    rdfs:label "Nodo 2: Grupo remoto RIO5"@es ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno."@es ;
    ex:identificador "Nodo 2" ;
    ex:tieneComponente ex:ModuloEntradasDigitales_24I_N2_1, ex:ModuloEntradasDigitales_24I_N2_2, ex:ModuloEntradasDigitales_24I_N2_3 .

ex:Nodo3_RIO5
    a ex:Sistema ;
    rdfs:label "Nodo 3: Grupo remoto RIO5"@es ;
    ex:textoExtracto "Nodo 3: Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno."@es ;
    ex:identificador "Nodo 3" ;
    ex:tieneComponente ex:ModuloEntradasDigitales_24I_N3_1, ex:ModuloEntradasDigitales_24I_N3_2 .

ex:ModuloEntradasDigitales_24I_N2_1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 1)"@es ;
    ex:textoExtracto "3 módulos de 24 entradas digitales"@es ;
    ex:identificador "24I/1" .

ex:ModuloEntradasDigitales_24I_N2_2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 2)"@es ;
    ex:textoExtracto "3 módulos de 24 entradas digitales"@es ;
    ex:identificador "24I/2" .

ex:ModuloEntradasDigitales_24I_N2_3
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 3)"@es ;
    ex:textoExtracto "3 módulos de 24 entradas digitales"@es ;
