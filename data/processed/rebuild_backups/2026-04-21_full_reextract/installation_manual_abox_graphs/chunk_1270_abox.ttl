ex:Modulo_ER_24I16O
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ER 24I/16O"@es ;
    ex:textoExtracto "ER 24I/16O" ;
    ex:identificador "ER 24I/16O" .

ex:Esquema_ConexionRIO5
    a ex:Esquema ;
    rdfs:label "Esquema de conexión RIO5 (páginas 682-685)"@es ;
    ex:textoExtracto "POW X1 SP ADD 9AB 8 765 L C X2 X3 | ER 24I/16O CHS O+214V GND +24V X4 GON8D O+294V X5 EED10 GON16D 4 0 RESS CD 3 E 2F1 ERR I1 RUN X6 T 10 AN GLS ND SHH I 1 2 H I 1 3 GLS ND SHH H X7 I24"@es ;
    ex:detalladoEnEsquema ex:Modulo_ER_24I16O .

ex:Grupo1_EntradasDigitales
    a ex:ComponenteElectrico ;
    rdfs:label "Grupo 1: 24 entradas digitales"@es ;
    ex:textoExtracto "Grupo ꞏ1ꞏ: 24 entradas digitales"@es ;
