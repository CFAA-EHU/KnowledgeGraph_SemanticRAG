@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaRIO5_ConfiguracionIO
    a               ex:Sistema ;
    rdfs:label      "Configuración de E/S para módulos RIO5"@es ;
    ex:textoExtracto """
    Cada módulo RIO5 se debe configurar como un bloque lógico.
    Se desea configurar cada nodo RIO5 de la siguiente manera:
    • El primer nodo RIO5 como un bloque de 24 entradas a partir de la I1.
    • El segundo nodo RIO5 como tres bloques de 24 entradas a partir de la I49, I73 e I97.
    • El tercer nodo RIO5 como dos bloques de 24 entradas a partir de la I257 e I129.
    """@es ;
    ex:tieneComponente  ex:Parametro_NDIMOD ;
    ex:tieneComponente  ex:NodoRIO5_1 ;
    ex:tieneComponente  ex:NodoRIO5_2 ;
    ex:tieneComponente  ex:NodoRIO5_3 .

ex:Parametro_NDIMOD
    a               ex:Parametro ;
    rdfs:label      "NDIMOD"@es ;
    ex:identificador "6" ;
    ex:textoExtracto "NDIMOD | 6 | En la serie RIO5, cada módulo se debe configurar como un bloque lógico. Cada módulo doble (módulo con dos placas) cuenta como dos bloques."@es ;
    ex:valor         "6"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:NodoRIO5_1
    a               ex:ComponenteElectrico ;
    rdfs:label      "Primer nodo RIO5 (bloque de 24 entradas desde I1)"@es ;
    ex:textoExtracto "El primer nodo RIO5 como un bloque de 24 entradas a partir de la I1."@es .

ex:NodoRIO5_2
    a               ex:ComponenteElectrico ;
    rdfs:label      "Segundo nodo RIO5 (tres bloques de 24 entradas desde I49, I73, I97)"@es ;
    ex:textoExtracto "El segundo nodo RIO5 como tres bloques de 24 entradas a partir de la I49, I73 e I97."@es .

ex:NodoRIO5_3
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tercer nodo RIO5 (dos bloques de 24 entradas desde I257, I129)"@es ;
    ex:textoExtracto "El tercer nodo RIO5 como dos bloques de 24 entradas a partir de la I257 e I129."@es .