@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:BusCANopen_Ejemplo2
    a ex:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 2)" ;
    ex:textoExtracto "Ejemplo 2. Un bus CANopen dispone de los siguientes grupos remotos." ;
    ex:tieneComponente ex:Nodo1_RIOW_Ejemplo2, ex:Nodo2_RIOW_Ejemplo2 ;
    ex:compuestoPor ex:Parametro_NDIMOD_Ejemplo2, ex:Parametro_DIMODADDR_Ejemplo2, ex:Parametro_NDOMOD_Ejemplo2, ex:Parametro_DOMODADDR_Ejemplo2 .

ex:Nodo1_RIOW_Ejemplo2
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIOW)" ;
    ex:identificador "Nodo 1" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOW con 16 entradas y 8 salidas digitales." ;
    ex:tieneComponente ex:EntradasDigitales_Nodo1_RIOW_1_16, ex:SalidasDigitales_Nodo1_RIOW_81_88 ;
    ex:monitoreaParametro ex:Parametro_DIMODADDR_Nodo1_Ejemplo2 .

ex:EntradasDigitales_Nodo1_RIOW_1_16
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 16 entradas digitales (Nodo 1 RIOW, I1-I32)" ;
    ex:textoExtracto "16 entradas digitales. [...] El primer nodo RIOW como 2 bloques, uno de 8 entradas a partir de la I1 y el resto a partir de I33." ;
    ex:tieneFrecuencia ex:Frecuencia_ConfiguracionBloques_Nodo1 .

ex:SalidasDigitales_Nodo1_RIOW_81_88
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 8 salidas digitales (Nodo 1 RIOW, O81-O88)" ;
    ex:textoExtracto "8 salidas digitales. [...] un bloque de 8 salidas a partir de la O81." .

ex:Nodo2_RIOW_Ejemplo2
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOW)" ;
    ex:identificador "Nodo 2" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOW con 8 entradas y 8 salidas digitales." ;
    ex:tieneComponente ex:EntradasDigitales_Nodo2_RIOW_113_120, ex:SalidasDigitales_Nodo2_RIOW_49_56 ;
    ex:monitoreaParametro ex:Parametro_DIMODADDR_Nodo2_Ejemplo2 .

ex:EntradasDigitales_Nodo2_RIOW_113_120
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 8 entradas digitales (Nodo 2 RIOW, I113-I120)" ;
    ex:textoExtracto "8 entradas digitales. [...] un bloque de 8 entradas a partir de la I113." .

ex:SalidasDigitales_Nodo2_RIOW_49_56
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 8 salidas digitales (Nodo 2 RIOW, O49-O56)" ;
    ex:textoExtracto "8 salidas digitales. [...] un bloque de 8 salidas a partir de O49." .

ex:Parametro_NDIMOD_Ejemplo2
    a ex:Parametro ;
    rdfs:label "Parámetro NDIMOD" ;
    ex:identificador "NDIMOD" ;
    ex:valor "3" ;
    ex:textoExtracto "| NDIMOD | 3 | 3 bloques; 2 para el primer nodo y 1 para el segundo." .

ex:Parametro_DIMODADDR_Ejemplo2
    a ex:Parametro ;
    rdfs:label "Parámetro DIMODADDR" ;
    ex:identificador "DIMODADDR" ;
    ex:textoExtracto "DIMODADDR | - - - | Ver tabla inferior." .

ex:Parametro_NDOMOD_Ejemplo2
    a ex:Parametro ;
    rdfs:label "Parámetro NDOMOD" ;
    ex:identificador "NDOMOD" ;
    ex:valor "2" ;
    ex:textoExtracto "| NDOMOD | 2 | 2 bloques, uno para cada nodo RIOW." .

ex:Parametro_DOMODADDR_Ejemplo2
    a ex:Parametro ;
    rdfs:label "Parámetro DOMODADDR" ;
    ex:identificador "DOMODADDR" ;
    ex:textoExtracto "DOMODADDR | - - - | Ver tabla inferior." .

ex:BusCANopen_Ejemplo3
    a ex:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 3)" ;
    ex:textoExtracto "Ejemplo 3. Un bus CANopen dispone de los siguientes grupos remotos." ;
    ex:tieneComponente ex:Nodo1_RIOR_Ejemplo3, ex:Nodo2_RIOR_Ejemplo3 .

ex:Nodo1_RIOR_Ejemplo3
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIOR)" ;
    ex:identificador "Nodo 1" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .

ex:Nodo2_RIOR_Ejemplo3
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOR)" ;
    ex:identificador "Nodo 2" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .