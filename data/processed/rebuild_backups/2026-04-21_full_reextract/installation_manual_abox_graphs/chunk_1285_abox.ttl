@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaIdiomasDisponibles a ex:Tabla ;
    ex:textoExtracto "Lista de idiomas disponibles. | Código. | Idioma. | [...] | zh-CHT | Chino (Tradicional)." ;
    rdfs:label "Tabla de códigos de idiomas disponibles en la aplicación" .

ex:ParametroLanguage a ex:Parametro ;
    ex:identificador "Language" ;
    ex:valor "en" ;
    ex:textoExtracto "<setting name=\"Language\" serializeAs=\"String\"> <value>en</value>" ;
    ex:documentadoEn ex:TablaIdiomasDisponibles .

ex:ParametroLocalLanguage a ex:Parametro ;
    ex:identificador "LocalLanguage" ;
    ex:valor "zh-CHS" ;
    ex:textoExtracto "<setting name=\"LocalLanguage\" serializeAs=\"String\"> <value>zh-CHS</value>" ;
    ex:documentadoEn ex:TablaIdiomasDisponibles .

ex:FicheroConfiguracionExpert a ex:InterfazUsuario ;
    ex:identificador "..\\LantekInside\\Expert\\Expert.exe.config" ;
    ex:textoExtracto "Editar el fichero ..\\LantekInside\\Expert\\Expert.exe.config con un editor de texto." ;
    ex:tieneComponente ex:ParametroLanguage, ex:ParametroLocalLanguage .

ex:MenuPrincipal a ex:InterfazUsuario ;
    ex:textoExtracto "Abrir la aplicación e ir al menú principal. En el botón general, seleccionar uno de los idiomas." .