@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SensorGap_1289
    a               ex:Sensor ;
    rdfs:label      "Sensor del gap"@es ;
    ex:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje. Fagor Automation recomienda utilizar una entrada del regulador."@es ;
    ex:monitoreaParametro ex:ParametroGap_1289 ;
    ex:detalladoEnEsquema ex:EsquemaConexionSensorGap_1289 .

ex:ParametroGap_1289
    a               ex:Parametro ;
    rdfs:label      "Parámetro GAPANAINTYPE y GAPANAINID"@es ;
    ex:identificador "GAPANAINTYPE", "GAPANAINID" ;
    ex:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor."@es .

ex:EsquemaConexionSensorGap_1289
    a               ex:Esquema ;
    rdfs:label      "Esquema eléctrico: Conexión del sensor del gap"@es ;
    ex:textoExtracto "Esquema eléctrico. Conexión del sensor a una entrada analógica del regulador Sercos. El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5); para utilizar la segunda, utilizar los pines 2 y 3."@es ;
    ex:ilustradoEn   ex:Pagina_696 .

ex:Pagina_696
    a               ex:Pagina ;
    rdfs:label      "Página 696 - Sección 16.2.1 Conexionado del sensor del gap"@es ;
    ex:identificador "696" ;
    ex:textoExtracto "Sección 16.2.1 Conexionado del sensor del gap."@es .

ex:ModuloRemotoRIO5_1289
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo remoto RIO5"@es ;
    ex:identificador "RIO5" ;
    ex:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es .

ex:ModuloRemotoRIOR_1289
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo remoto RIOR"@es ;
    ex:identificador "RIOR" ;
    ex:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es .

ex:ReguladorSercos_1289
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador Sercos con interfaz A1/SI"@es ;
    ex:textoExtracto "regulador Sercos de cualquier eje [...] Las entradas analógicas del regulador son una opción de hardware; para disponer de ellas, el regulador debe disponer de una interfaz de comunicación con entradas analógicas A1 o SI."@es ;
    ex:tieneComponente ex:InterfazAnalogicaA1_1289 .

ex:InterfazAnalogicaA1_1289
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de entradas analógicas A1/SI"@es ;
    ex:identificador "A1", "SI" ;
    ex:textoExtracto "interfaz de comunicación con entradas analógicas A1 o SI"@es .