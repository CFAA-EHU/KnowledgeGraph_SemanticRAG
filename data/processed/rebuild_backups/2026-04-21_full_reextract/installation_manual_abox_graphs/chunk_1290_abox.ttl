@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EjeControlGap
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje que controla el gap"@es ;
    ex:textoExtracto "El eje que controla el gap no debe ajustarse del modo estándar, sino que se hará con movimientos de aproximación con el control de gap activo."@es ;
    ex:monitoreaParametro ex:Parametro_GAPGAIN, ex:Parametro_FFGAIN, ex:Parametro_ACFGAIN, ex:Parametro_PROGAIN ;
    ex:controla    ex:SensorGap .

ex:SensorGap
    a               ex:Sensor ;
    rdfs:label      "Sensor de gap"@es ;
    ex:textoExtracto "La variable G.GAP refleja el valor real del gap, detectado por el sensor."@es .

ex:Parametro_GAPGAIN
    a               ex:Parametro ;
    rdfs:label      "GAPGAIN" ;
    ex:identificador "GAPGAIN" ;
    ex:valor         "0.20" ;
    ex:textoExtracto "• GAPGAIN = 0.20."@es .

ex:Parametro_FFGAIN
    a               ex:Parametro ;
    rdfs:label      "FFGAIN" ;
    ex:identificador "FFGAIN" ;
    ex:valor         "90 %" ;
    ex:textoExtracto "• FFGAIN = 90 %."@es .

ex:Parametro_ACFGAIN
    a               ex:Parametro ;
    rdfs:label      "ACFGAIN" ;
    ex:identificador "ACFGAIN" ;
    ex:valor         "30 %" ;
    ex:textoExtracto "• ACFGAIN = 30 %."@es .

ex:Parametro_PROGAIN
    a               ex:Parametro ;
    rdfs:label      "PROGAIN" ;
    ex:identificador "PROGAIN" ;
    ex:textoExtracto "De estos movimientos se obtendrán los parámetros GAPGAIN, PROGAIN, FFGAIN y ACFGAIN."@es .

ex:Parametro_LOOPTIME
    a               ex:Parametro ;
    rdfs:label      "LOOPTIME" ;
    ex:identificador "LOOPTIME" ;
    ex:valor         "2" ;
    ex:textoExtracto "Se recomienda utilizar un tiempo de ciclo de 2 milisegundos (LOOPTIME=2)."@es .

ex:Tabla_ParametrosSercosVelocidad a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros para Sercos velocidad analógico"@es ;
    ex:textoExtracto "| Sercos velocidad Analógico. | Sercos posición. | --- | --- | • GAPGAIN = 0.20. • FFGAIN = 90 %. • ACFGAIN = 30 %. | • GAPGAIN = 0.20. • Se recomienda reducir los valores de FFGAIN entre un 0.5 y un 1 % respecto de los valores de un ajuste estándar. • Los valores de ACFGAIN pueden coincidir con los de un ajuste estándar. |"@es ;
    ex:documentadoEn ex:Pagina_697 .

ex:Pagina_697
    a               ex:Pagina ;
    rdfs:label      "Página 697 - Ajuste del eje que controla el gap"@es ;
    ex:identificador "697" ;
    ex:textoExtracto "El eje que controla el gap no debe ajustarse del modo estándar, sino que se hará con movimientos de aproximación con el control de gap activo."@es .

ex:PerfilVelocidadAceleracionGap
    a               ex:Figura ;
    rdfs:label      "Perfil de velocidad y aceleración sin sobrepasamiento en el gap"@es ;
    ex:textoExtracto "Perfil de velocidad y aceleración sin sobrepasamiento en el gap. A) La variable G.GAP refleja el valor real del gap, detectado por el sensor. B) La variable A.FLWE.Z refleja el error de seguimiento del eje Z. C) La señal DIFF(A.TPOS.Z) nos indica la velocidad en Z. D) La señal DIFF(DIFF(A.TPOS.Z)) nos indica la aceleración en Z."@es ;
    ex:ilustradoEn  ex:Pagina_697 .