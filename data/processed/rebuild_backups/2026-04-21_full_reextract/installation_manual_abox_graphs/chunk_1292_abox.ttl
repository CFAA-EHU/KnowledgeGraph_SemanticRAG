@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionSensorGap_1292
    a               ex:Sistema ;
    rdfs:label      "Configuración del sensor del gap"@es ;
    ex:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor. [...] Ajustar la señal de colisión del sensor."@es ;
    ex:tieneComponente
        ex:SensorGap_1292 ,
        ex:Parametro_GAPANAINTYPE_1292 ,
        ex:Parametro_GAPANAINID_1292 ,
        ex:Parametro_GAPSENSOROFFSET_1292 ,
        ex:Parametro_GAPSENSORCH_1292 ,
        ex:Parametro_GAPDISTLIMIT_1292 ,
        ex:Parametro_GAPVOLTLIMIT_1292 .

ex:SensorGap_1292
    a               ex:Sensor ;
    rdfs:label      "Sensor del gap"@es ;
    ex:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor."@es ;
    ex:monitoreaParametro
        ex:Parametro_GAPANAINTYPE_1292 ,
        ex:Parametro_GAPANAINID_1292 ,
        ex:Parametro_GAPSENSOROFFSET_1292 ,
        ex:Parametro_GAPSENSORCH_1292 ,
        ex:Parametro_GAPDISTLIMIT_1292 ,
        ex:Parametro_GAPVOLTLIMIT_1292 .

ex:Parametro_GAPANAINTYPE_1292
    a               ex:Parametro ;
    rdfs:label      "GAPANAINTYPE" ;
    ex:identificador "GAPANAINTYPE" ;
    ex:textoExtracto "Este parámetro indica dónde está ubicada la entrada analógica conectada al sensor; en los módulos remotos CAN o en un regulador Sercos. Se recomienda utilizar una entrada del regulador."@es .

ex:Parametro_GAPANAINID_1292
    a               ex:Parametro ;
    rdfs:label      "GAPANAINID" ;
    ex:identificador "GAPANAINID" ;
    ex:textoExtracto "Este parámetro identifica la entrada analógica donde está conectado el sensor; si remoto CAN, de 1 a 60; si regulador, de 101 a 132 o de 201 a 232. [...] El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la entrada analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)."@es ;
    ex:valor         "101-132, 201-232 (regulador) / 1-60 (CAN)" .

ex:Parametro_GAPSENSOROFFSET_1292
    a               ex:Parametro ;
    rdfs:label      "GAPSENSOROFFSET" ;
    ex:identificador "GAPSENSOROFFSET" ;
    ex:textoExtracto "Offset (en milivoltios) a aplicar al sensor desde el CNC. Si se utiliza una entrada analógica Fagor, no es necesario definir este parámetro, ya que todas ellas disponen de un offset propio."@es .

ex:Parametro_GAPSENSORCH_1292
    a               ex:Parametro ;
    rdfs:label      "GAPSENSORCH" ;
    ex:identificador "GAPSENSORCH" ;
    ex:textoExtracto "Cambiar el signo de la señal del sensor."@es .

ex:Parametro_GAPDISTLIMIT_1292
    a               ex:Parametro ;
    rdfs:label      "GAPDISTLIMIT" ;
    ex:identificador "GAPDISTLIMIT" ;
    ex:textoExtracto "Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)."@es .

ex:Parametro_GAPVOLTLIMIT_1292
    a               ex:Parametro ;
    rdfs:label      "GAPVOLTLIMIT" ;
    ex:identificador "GAPVOLTLIMIT" ;
    ex:textoExtracto "Voltaje (en milivoltios) que corresponde al recorrido límite del sensor (parámetro GAPDISTLIMIT)."@es .