@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaSenalesPLC_16_2_6 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de señales lógicas del PLC (Sección 16.2.6)" ;
    ex:textoExtracto "Señales lógicas de consulta. | Señales del PLC. | Significado. | [...] INTOL | El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL..." .

ex:Parametro_GAPMIN
    a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:textoExtracto "los parámetros GAPMIN-GAPMAX" ;
    ex:monitoreaParametro ex:Senal_INPOSGAP .

ex:Parametro_GAPMAX
    a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:textoExtracto "los parámetros GAPMIN-GAPMAX" ;
    ex:monitoreaParametro ex:Senal_INPOSGAP .

ex:Parametro_GAPTOL
    a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:textoExtracto "el parámetro GAPTOL" ;
    ex:monitoreaParametro ex:Senal_INTOL .

ex:Parametro_GAPERRORCANCEL
    a ex:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ex:textoExtracto "según lo definido en el parámetro GAPERRORCANCEL" ;
    ex:documentadoEn ex:TablaSenalesPLC_16_2_6 .

ex:Parametro_GAPTOLCANCEL
    a ex:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ex:textoExtracto "según lo definido en el parámetro GAPTOLCANCEL" ;
    ex:documentadoEn ex:TablaSenalesPLC_16_2_6 .

ex:Senal_INPOSGAP
    a ex:Sensor ;
    rdfs:label "INPOSGAP" ;
    ex:textoExtracto "INPOSGAP | El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX..." ;
    ex:documentadoEn ex:TablaSenalesPLC_16_2_6 ;
    ex:controla ex:SistemaEjes .

ex:Senal_INTOL
    a ex:Sensor ;
    rdfs:label "INTOL" ;
    ex:textoExtracto "INTOL | El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL..." ;
    ex:documentadoEn ex:TablaSenalesPLC_16_2_6 ;
    ex:controla ex:SistemaEjes .

ex:SistemaEjes
    a ex:Sistema ;
    rdfs:label "Sistema de movimiento de ejes" ;
    ex:textoExtracto "el CNC detiene el movimiento de los ejes respetando la rampa de frenado y controlando el GAP durante la rampa" .