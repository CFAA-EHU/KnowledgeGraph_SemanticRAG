@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_ENABLEGAP
    a               ex:ComponenteElectrico ;
    rdfs:label      "ENABLEGAP" ;
    ex:textoExtracto
        "ENABLEGAP | Marca activa por defecto. El PLC desactiva esta marca para deshabilitar"@es ;
    ex:identificador
        "ENABLEGAP" .

ex:Se_al_STOP
    a               ex:ComponenteElectrico ;
    rdfs:label      "_STOP" ;
    ex:textoExtracto
        "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas."@es ;
    ex:identificador
        "_STOP" .

ex:Tecla_STOP_CNC
    a               ex:InterfazUsuario ;
    rdfs:label      "[STOP]" ;
    ex:textoExtracto
        "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC."@es ;
    ex:identificador
        "STOP" .