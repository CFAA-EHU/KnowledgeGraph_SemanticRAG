@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SensorGap_1299
    a               ex:Sensor ;
    rdfs:label      "Sensor de detección del gap"@es ;
    ex:textoExtracto "Valor real del gap, detectado por el sensor."@es ;
    ex:monitoreaParametro ex:ParametroGap_1299 ;
    ex:identificador "V.G.GAP" .

ex:ParametroGap_1299
    a               ex:Parametro ;
    rdfs:label      "Valor real del gap"@es ;
    ex:textoExtracto "V.G.GAP Valor real del gap, detectado por el sensor."@es ;
    ex:identificador "V.G.GAP" .

ex:ParametroCompensacionGap_1299
    a               ex:Parametro ;
    rdfs:label      "Compensación del gap en eje Z"@es ;
    ex:textoExtracto "A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap."@es ;
    ex:identificador "A.GAPCOMP.Z" ;
    ex:valor         "Compensación en eje Z"@es .

ex:ParametroPosicionZ_1299
    a               ex:Parametro ;
    rdfs:label      "Cota máquina real en eje Z (sensor)"@es ;
    ex:textoExtracto "A.POS.Z Eje Z. Cotas máquina reales del sensor."@es ;
    ex:identificador "A.POS.Z" .

ex:ParametroPosicionX_1299
    a               ex:Parametro ;
    rdfs:label      "Cota máquina real en eje X"@es ;
    ex:textoExtracto "A.POS.X Eje X. Cotas máquina reales."@es ;
    ex:identificador "A.POS.X" .