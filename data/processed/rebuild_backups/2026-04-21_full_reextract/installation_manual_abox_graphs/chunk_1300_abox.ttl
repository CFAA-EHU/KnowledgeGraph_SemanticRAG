@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_ManiobraGapRetiro
    a                   ex:Sistema ;
    rdfs:label          "PLC Gap Retraction Maneuver" ;
    ex:textoExtracto    "DFU {conditions} AND NOT M666 AND NOT INCYCLE = RES ENABLEGAP = RES ENABLELEAP = SET IRESETZ = TG1 333 12 ; Tiempo de espera, 12 milisegundos. T333 = M666 DFD M666 = RES IRESETZ = MOVE ABS (Z, 513000,50000000,NULL) DFDB B10KEYLED1 = SET ENABLEGAP = SET ENABLELEAP" ;
    ex:identificador    "TG1 333" ;
    ex:tieneComponente  ex:Temporizador_T333 ;
    ex:tieneComponente  ex:Senal_M666 ;
    ex:tieneComponente  ex:Interfaz_B10KEYLED1 .

ex:Temporizador_T333
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Timer T333" ;
    ex:textoExtracto    "T333 = M666 ; Tiempo de espera, 12 milisegundos" ;
    ex:valor            "12"^^xsd:integer .

ex:Senal_M666
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Signal M666" ;
    ex:textoExtracto    "NOT M666 ; T333 = M666 ; DFD M666" .

ex:Interfaz_B10KEYLED1
    a                   ex:InterfazUsuario ;
    rdfs:label          "B10KEYLED1 Interface" ;
    ex:textoExtracto    "DFDB B10KEYLED1 = SET ENABLEGAP = SET ENABLELEAP" .