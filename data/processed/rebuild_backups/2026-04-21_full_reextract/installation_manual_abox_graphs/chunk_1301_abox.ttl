@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Cinematica_TYPE
    a               ex:Parametro ;
    rdfs:label      "TYPE" ;
    ex:textoExtracto "Las dimensiones que hay que parametrizar dependen del tipo de cinemática, definido en el parámetro TYPE."@es ;
    ex:identificador "TYPE" .

ex:InterfazUsuario_CNC_ConfiguracionCinematica
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de configuración de cinemáticas del CNC" ;
    ex:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina."@es ;
    ex:monitoreaParametro ex:Parametro_Cinematica_TYPE .

ex:Sistema_CinematicasPersonalizables
    a               ex:Sistema ;
    rdfs:label      "Sistema de cinemáticas personalizables" ;
    ex:textoExtracto "El fabricante puede personalizar hasta 6 cinemáticas distintas para una misma máquina. [...] Además de estas cinemáticas, el OEM puede integrar 6 cinemáticas adicionales."@es ;
    ex:tieneComponente ex:InterfazUsuario_CNC_ConfiguracionCinematica .