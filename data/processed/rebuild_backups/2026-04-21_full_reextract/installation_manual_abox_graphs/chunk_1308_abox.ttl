@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcedimientoMedicionCabezalAngular_17_2
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Procedimiento de medición con reloj comparador para cabezal angular YZ 45°"@es ;
    ex:textoExtracto       "En este ejemplo se calculan las dimensiones de un cabezal angular YZ de 45º (el mismo que el del ejemplo anterior), parámetro TYPE con valor ꞏ6ꞏ. [...] Cómo utilizar el reloj comparador. Cuando sea necesario tocar un cilindro con un reloj comparador, el contacto se debe realizar sobre la línea exterior del cilindro."@es ;
    ex:requiereConsumible  ex:CilindroReferencia_17_2 ;
    ex:requiereMantenimiento ex:Parametro_TDATA1_17_2 ;
    ex:ilustradoEn         ex:EsquemaPosicionamiento_17_2 .

ex:CilindroReferencia_17_2
    a               ex:Consumible ;
    rdfs:label      "Cilindro de diámetro conocido para calibración"@es ;
    ex:textoExtracto "un cilindro de diámetro conocido colocado en el cabezal"@es .

ex:Parametro_TDATA1_17_2
    a               ex:Parametro ;
    rdfs:label      "Parámetro TDATA1 (cálculo de primer contacto)"@es ;
    ex:textoExtracto "Cálculo del parámetro TDATA1. Primer contacto. [...] Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal."@es ;
    ex:valor         "Y=R"@es .

ex:EsquemaPosicionamiento_17_2
    a               ex:Esquema ;
    rdfs:label      "Esquema de posicionamiento para medición con reloj comparador (ejes B, C, Y, Z)"@es ;
    ex:textoExtracto "B=0º [...] C=0º [...] Desplazar la mesa en el eje Y hasta que el reloj y el cilindro se toquen en el punto 1. [...] Z Y R 1 Segundo contacto."@es .

ex:RelojComparador_17_2
    a               ex:Herramienta ;
    rdfs:label      "Reloj comparador para medición de precisión"@es ;
    ex:textoExtracto "un reloj comparador [...] Es recomendable que el reloj esté lo más perpendicular posible a la tangente de la superficie a medir."@es ;
    ex:ilustradoEn   ex:EsquemaPosicionamiento_17_2 .