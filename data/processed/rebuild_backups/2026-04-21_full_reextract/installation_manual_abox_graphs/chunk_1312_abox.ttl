ex:Tabla_17_2_CalculoDimensionesCabezalAngular a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de cálculo de dimensiones para cabezal angular (Sección 17.2)"@es ;
    ex:textoExtracto """
X = 0,5·(X + X)
TDATA6 = 2·(X – TDATA1)
TDATA5 | Dimensión a calcular.
ΔX | Cota que indica el CNC.
TDATA6 45 O X M Z TDATA1 Y
"""@es ;
    ex:identificador "17.2" ;
    ex:documentadoEn ex:Pagina_712_715 .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 | Dimensión a calcular."@es ;
    ex:documentadoEn ex:Tabla_17_2_CalculoDimensionesCabezalAngular .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA6 = 2·(X – TDATA1)"@es ;
    ex:documentadoEn ex:Tabla_17_2_CalculoDimensionesCabezalAngular .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "TDATA6 = 2·(X – TDATA1)"@es ;
    ex:documentadoEn ex:Tabla_17_2_CalculoDimensionesCabezalAngular .

ex:Parametro_DeltaX
    a ex:Parametro ;
    rdfs:label "ΔX" ;
    ex:textoExtracto "ΔX | Cota que indica el CNC."@es ;
    ex:documentadoEn ex:Tabla_17_2_CalculoDimensionesCabezalAngular .