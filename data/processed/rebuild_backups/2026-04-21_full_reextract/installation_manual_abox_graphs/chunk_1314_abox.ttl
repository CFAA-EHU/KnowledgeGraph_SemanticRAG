@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3 (coordenada Y del eje A)"@es ;
    ex:textoExtracto "La coordenada en el eje Y es el parámetro TDATA3"@es ;
    ex:valor "TDATA3" .

ex:Esquema_MesaRotativa_EjeA
    a ex:Esquema ;
    rdfs:label "Esquema de cálculo de coordenadas del eje A (mesa rotativa)"@es ;
    ex:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A."@es ;
    ex:ilustradoEn ex:Parametro_TDATA3 .