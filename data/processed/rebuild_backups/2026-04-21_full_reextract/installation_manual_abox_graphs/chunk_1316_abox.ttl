@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "TDATA3 = 0,5·(ΔY + ΔY)" ;
    ex:valor "0,5·(ΔY1 + ΔY2)"^^xsd:string .

ex:Parametro_Pz
    a ex:Parametro ;
    rdfs:label "Pz" ;
    ex:textoExtracto "Pz = 0,5·(ΔZ + ΔZ – R)" ;
    ex:valor "0,5·(ΔZ1 + ΔZ2 – R)"^^xsd:string .

ex:Parametro_DeltaY1
    a ex:Parametro ;
    rdfs:label "ΔY1" ;
    ex:textoExtracto "ΔY1, ΔZ1: Cotas que indica el CNC." .

ex:Parametro_DeltaY2
    a ex:Parametro ;
    rdfs:label "ΔY2" ;
    ex:textoExtracto "ΔY2, ΔZ2: Cotas que indica el CNC." .

ex:Parametro_DeltaZ1
    a ex:Parametro ;
    rdfs:label "ΔZ1" ;
    ex:textoExtracto "ΔZ1: Cotas que indica el CNC." .

ex:Parametro_DeltaZ2
    a ex:Parametro ;
    rdfs:label "ΔZ2" ;
    ex:textoExtracto "ΔZ2: Cotas que indica el CNC." .

ex:Parametro_RadioCilindro
    a ex:Parametro ;
    rdfs:label "R" ;
    ex:textoExtracto "R: Radio del cilindro." .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2 (mostrado en el dibujo del procedimiento)." .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:textoExtracto "TDATA4 (mostrado en el dibujo del procedimiento)." .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 (mostrado en el dibujo del procedimiento)." .

ex:Parametro_X1
    a ex:Parametro ;
    rdfs:label "X1" ;
    ex:textoExtracto "X1: Cota anotada en palpación (punto 1)." .

ex:Parametro_Z
    a ex:Parametro ;
    rdfs:label "Z" ;
    ex:textoExtracto "Z: Cota anotada en palpación (punto 2)." .

ex:Sistema_CalibracionMesaRotativa
    a ex:Sistema ;
    rdfs:label "Sistema de calibración de mesa rotativa" ;
    ex:textoExtracto "Procedimiento para preselección de origen en X (A=90°, B=-90°) y cálculo de parámetros mediante palpación en ejes X/Z." ;
    ex:tieneComponente ex:Parametro_TDATA3, ex:Parametro_Pz, ex:Parametro_DeltaY1, ex:Parametro_DeltaY2,
                      ex:Parametro_DeltaZ1, ex:Parametro_DeltaZ2, ex:Parametro_RadioCilindro,
                      ex:Parametro_TDATA2, ex:Parametro_TDATA4, ex:Parametro_TDATA5,
                      ex:Parametro_X1, ex:Parametro_Z .

ex:Figura_ProcedimientoCalibracion
    a ex:Figura ;
    rdfs:label "Diagrama de posiciones para calibración" ;
    ex:textoExtracto "Dibujo con posiciones de ejes A/B (0°, -90°) y puntos de palpación (1, 2, 3)." ;
    ex:ilustradoEn ex:Sistema_CalibracionMesaRotativa .