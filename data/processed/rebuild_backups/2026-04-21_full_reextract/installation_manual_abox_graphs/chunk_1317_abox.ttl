@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2 = ΔX + r + E" ;
    ex:valor "ΔX + r + E" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:textoExtracto "TDATA4 = TDATA4 – Pz" ;
    ex:valor "TDATA4 – Pz" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 = F – E" ;
    ex:valor "F – E" .

ex:Parametro_Pz
    a ex:Parametro ;
    rdfs:label "Pz" ;
    ex:textoExtracto "Pz | Coordenada del eje A." ;
    ex:identificador "Pz" .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    rdfs:label "ΔZ" ;
    ex:textoExtracto "ΔZ, ΔZ1 | Cotas que indica el CNC." ;
    ex:identificador "ΔZ" .

ex:Parametro_DeltaZ1
    a ex:Parametro ;
    rdfs:label "ΔZ1" ;
    ex:textoExtracto "ΔZ, ΔZ1 | Cotas que indica el CNC." ;
    ex:identificador "ΔZ1" .

ex:Parametro_DeltaX
    a ex:Parametro ;
    rdfs:label "ΔX" ;
    ex:textoExtracto "ΔX, ΔX1 | Cotas que indica el CNC." ;
    ex:identificador "ΔX" .

ex:Parametro_DeltaX1
    a ex:Parametro ;
    rdfs:label "ΔX1" ;
    ex:textoExtracto "ΔX, ΔX1 | Cotas que indica el CNC." ;
    ex:identificador "ΔX1" .

ex:Parametro_R
    a ex:Parametro ;
    rdfs:label "R" ;
    ex:textoExtracto "R | Radio del cilindro." ;
    ex:identificador "R" .

ex:Parametro_r
    a ex:Parametro ;
    rdfs:label "r" ;
    ex:textoExtracto "r | Radio de la bola del palpador." ;
    ex:identificador "r" .

ex:Parametro_E
    a ex:Parametro ;
    rdfs:label "E" ;
    ex:textoExtracto "E = 0,5·(ΔX + ΔZ + 2R + r)" ;
    ex:valor "0,5·(ΔX + ΔZ + 2R + r)" .

ex:Parametro_F
    a ex:Parametro ;
    rdfs:label "F" ;
    ex:textoExtracto "F = ΔZ – Pz" ;
    ex:valor "ΔZ – Pz" .

ex:Tabla_17_3_CalculoParametros
    a ex:Tabla ;
    rdfs:label "Tabla de cálculo de parámetros para mesa rotativa" ;
    ex:textoExtracto "TDATA2, TDATA4, TDATA5 | Parámetros a calcular." ;
    ex:detalladoEnEsquema ex:Esquema_MesaRotativa .

ex:Esquema_MesaRotativa
    a ex:Esquema ;
    rdfs:label "Esquema de mesa rotativa con cotas y palpado" ;
    ex:textoExtracto "Según el cuadro sombreado del dibujo. E = 0,5·(ΔX + ΔZ +2R+r)" ;
    ex:ilustradoEn ex:Tabla_17_3_CalculoParametros .