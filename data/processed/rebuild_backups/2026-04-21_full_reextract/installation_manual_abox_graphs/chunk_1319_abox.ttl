@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MINDMCOVR
    a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:identificador "MINDMCOVR" ;
    ex:textoExtracto "Mínimo override DMC de todos los ejes del canal." ;
    ex:monitoreaParametro ex:Sistema_DMC .

ex:Parametro_MAXDMCOVR
    a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:identificador "MAXDMCOVR" ;
    ex:textoExtracto "Máximo override DMC de todos los ejes del canal." ;
    ex:monitoreaParametro ex:Sistema_DMC .

ex:Parametro_MAXOVR
    a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:identificador "MAXOVR" ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)" ;
    ex:textoExtracto "control dinámico del mecanizado (DMC)" ;
    ex:controla ex:Parametro_MINDMCOVR, ex:Parametro_MAXDMCOVR .

ex:InterfazUsuario_ConmutadorOverride
    a ex:InterfazUsuario ;
    rdfs:label "Conmutador del panel de mando (override JOG)" ;
    ex:textoExtracto "el conmutador del panel de mando" ;
    ex:controla ex:Parametro_MINDMCOVR, ex:Parametro_MAXDMCOVR .

ex:Tabla_ParametrosOverrideDMC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Parámetros de override para DMC" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | MINDMCOVR | Mínimo override DMC de todos los ejes del canal. | MAXDMCOVR | Máximo override DMC de todos los ejes del canal." ;
    ex:documentadoEn ex:Pagina_722 ;
    ex:detalladoEnEsquema ex:Sistema_DMC .

ex:Pagina_722
    a ex:Pagina ;
    ex:identificador "722" ;
    ex:textoExtracto "18.1 Puesta a punto. - 18.1.1 Configurar los límites del override para el DMC." ;
    ex:ilustradoEn ex:Manual .