@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sentencia_DMCOFF
    a                   ex:AccionProhibida ;
    rdfs:label          "Sentencia #DMCOFF" ;
    ex:textoExtracto     "La sentencia #DMCOFF desactiva el DMC." ;
    ex:identificador     "#DMCOFF" .

ex:Funcion_M02 a ex:Tabla ;
     a                   ex:AccionProhibida ;
    rdfs:label          "Función M02 (fin de programa)" ;
    ex:textoExtracto     "Las funciones M02 o M30 (fin de programa) [...] desactivan el DMC." ;
    ex:identificador     "M02" .

ex:Funcion_M30 a ex:Tabla ;
     a                   ex:AccionProhibida ;
    rdfs:label          "Función M30 (fin de programa)" ;
    ex:textoExtracto     "Las funciones M02 o M30 (fin de programa) [...] desactivan el DMC." ;
    ex:identificador     "M30" .

ex:Reset_CNC
    a                   ex:AccionProhibida ;
    rdfs:label          "Reset del CNC" ;
    ex:textoExtracto     "el reset también desactivan el DMC." .

ex:Funcion_M5 a ex:Tabla ;
     a                   ex:AccionProhibida ;
    rdfs:label          "Parada de cabezal (función M5)" ;
    ex:textoExtracto     "Una parada de cabezal, función M5, desactiva el DMC." ;
    ex:identificador     "M5" .

ex:DMC
    a                   ex:Sistema ;
    rdfs:label          "DMC (Dynamic Motion Control)" ;
    ex:textoExtracto     "La sentencia #DMCOFF desactiva el DMC. [...] desactivan el DMC." .