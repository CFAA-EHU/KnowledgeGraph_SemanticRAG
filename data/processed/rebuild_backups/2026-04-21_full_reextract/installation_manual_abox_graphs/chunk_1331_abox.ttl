ex:Tabla_ResumenVariablesDMC_1331 a ex:Tabla ;
     a                       ex:Tabla ;
    ex:textoExtracto         "Variables. | PRG | PLC | INT | ... (V.)TM.NCUTTERST[tool][offset] Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes. | (V.)[ch].G.DMCPWRSP Potencia objetivo... (V.)[ch].G.LEARNEDPWRSP Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal)."@es ;
    rdfs:label              "Tabla de resumen de variables DMC (pág. 725-726)"@es .

ex:Parametro_TM_NCUTTERST
    a                       ex:Parametro ;
    ex:identificador         "TM.NCUTTERST[tool][offset]" ;
    ex:textoExtracto         "Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes."@es ;
    ex:valor                 "Dientes"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCPWRSP
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCPWRSP" ;
    ex:textoExtracto         "Potencia objetivo, definida como porcentaje de la potencia nominal del cabezal. Valor programado en el comando PWRSP de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ex:valor                 "Porcentaje"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCOVRMIN
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCOVRMIN" ;
    ex:textoExtracto         "Mínimo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMIN de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ex:valor                 "Porcentaje"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCOVRMAX
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCOVRMAX" ;
    ex:textoExtracto         "Máximo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMAX de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ex:valor                 "Porcentaje"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCFZMIN
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCFZMIN" ;
    ex:textoExtracto         "Mínimo avance por diente permitido durante el DMC. Valor programado en el comando FZMIN de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente."@es ;
    ex:valor                 "Milímetros/diente o pulgadas/diente"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCFZMAX
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCFZMAX" ;
    ex:textoExtracto         "Máximo avance por diente permitido durante el DMC. Valor programado en el comando FZMAX de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente."@es ;
    ex:valor                 "Milímetros/diente o pulgadas/diente"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_DMCON
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.DMCON" ;
    ex:textoExtracto         "Estado del DMC. Unidades: -."@es ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .

ex:Parametro_LEARNEDPWRSP
    a                       ex:Parametro ;
    ex:identificador         "[ch].G.LEARNEDPWRSP" ;
    ex:textoExtracto         "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ex:valor                 "Porcentaje"^^xsd:string ;
    ex:documentadoEn         ex:Tabla_ResumenVariablesDMC_1331 .