@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DMC_LEARNEDPWRSP
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.LEARNEDPWRSP" ;
    ex:identificador "G.LEARNEDPWRSP" ;
    ex:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:Parametro_DMC_ACTPWR
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCACTPWR" ;
    ex:identificador "G.DMCACTPWR" ;
    ex:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:Parametro_DMC_OVR
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCOVR" ;
    ex:identificador "G.DMCOVR" ;
    ex:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:Parametro_DMC_FZ
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCFZ" ;
    ex:identificador "G.DMCFZ" ;
    ex:textoExtracto "Avance por diente calculado por el DMC. Unidades: Milímetros/diente o pulgadas/diente." ;
    ex:valor "Milímetros/diente o pulgadas/diente"^^xsd:string .

ex:Parametro_DMC_NOLOADPWR
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCNOLOADPWR" ;
    ex:identificador "G.DMCNOLOADPWR" ;
    ex:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios." ;
    ex:valor "Kilowatios"^^xsd:string .

ex:Parametro_DMC_SAVEDTIME
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCSAVEDTIME" ;
    ex:identificador "G.DMCSAVEDTIME" ;
    ex:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos." ;
    ex:valor "Segundos"^^xsd:string .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "DMC (Dynamic Machining Control)" ;
    ex:textoExtracto "Sistema de control dinámico que calcula y mide parámetros como potencia, avance y tiempo en procesos de mecanizado." ;
    ex:monitoreaParametro ex:Parametro_DMC_LEARNEDPWRSP ,
                        ex:Parametro_DMC_ACTPWR ,
                        ex:Parametro_DMC_OVR ,
                        ex:Parametro_DMC_FZ ,
                        ex:Parametro_DMC_NOLOADPWR ,
                        ex:Parametro_DMC_SAVEDTIME .