@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaDatosHerramienta_1334 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de herramientas (número de dientes)"@es ;
    ex:textoExtracto "Tabla de herramientas. A B (A)Tipo de herramienta. (B)Número de dientes (entre 1 y 100)."@es ;
    ex:documentadoEn ex:Manual_Seccion18_3 .

ex:Parametro_NCUTTERS_1334
    a               ex:Parametro ;
    rdfs:label      "Número de dientes (NCUTTERS)"@es ;
    ex:valor        "1-100" ;
    ex:textoExtracto "Número de dientes (entre 1 y 100)."@es ;
    ex:documentadoEn ex:TablaDatosHerramienta_1334 .

ex:Variable_V_G_NCUTTERS_1334
    a               ex:Parametro ;
    rdfs:label      "(V.)[ch].G.NCUTTERS" ;
    ex:valor        "Dientes" ;
    ex:textoExtracto "(V.)[ch].G.NCUTTERS | Herramienta en preparación. Número de dientes. Unidades: Dientes."@es ;
    ex:documentadoEn ex:TablaDatosHerramienta_1334 .

ex:Variable_TM_NCUTTERS_1334
    a               ex:Parametro ;
    rdfs:label      "(V.)[ch].TM.NCUTTERS[offset]" ;
    ex:valor        "Dientes" ;
    ex:textoExtracto "(V.)[ch].TM.NCUTTERS[offset] | Corrector [offset] de la herramienta activa. Número de dientes. Unidades: Dientes."@es ;
    ex:documentadoEn ex:TablaDatosHerramienta_1334 .

ex:Variable_TM_NCUTTERST_1334
    a               ex:Parametro ;
    rdfs:label      "(V.)TM.NCUTTERST[tool][offset]" ;
    ex:valor        "Dientes" ;
    ex:textoExtracto "(V.)TM.NCUTTERST[tool][offset] | Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes."@es ;
    ex:documentadoEn ex:TablaDatosHerramienta_1334 .

