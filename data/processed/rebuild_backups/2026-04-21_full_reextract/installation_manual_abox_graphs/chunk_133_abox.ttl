@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NPT100
    a ex:Parametro ;
    rdfs:label "NPT100" ;
    ex:identificador "MPG.NPT100" ;
    ex:textoExtracto "NPT100 Número total de entradas PT100 activas. Valores posibles: De 0 a 10. Valor por defecto: 0 (no hay entradas PT100 activas)." ;
    ex:valor "0" .

ex:Parametro_PT100_EntradasActivas
    a ex:Parametro ;
    rdfs:label "Tabla de entradas PT100 activas" ;
    ex:identificador "MPG.PT100[nb]" ;
    ex:textoExtracto "PT100 Tabla de entradas PT100 activas. Este parámetro muestra la lista de entradas PT100 activas en el bus CAN. PT100 n Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32. Valor por defecto: 0 (no se desea activar la entrada PT100)." ;
    ex:valor "0" .

ex:Sensor_PT100_Generico
    a ex:Sensor ;
    rdfs:label "Sonda PT100" ;
    ex:textoExtracto "Una entrada PT100 debe estar activa si tiene una de estas sondas de temperatura conectada." .

ex:Tabla_AsignacionEntradasAnalogicas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Asignación de entradas analógicas para módulos RIO5 y RIOR" ;
    ex:textoExtracto "Ejemplo. En un sistema con un módulo RIO5 (nodo 1) y un RIOR (nodo 2), el CNC identifica las entradas analógicas de la siguiente manera. • (address = 1) RIO5 - Entradas analógicas: 1..4; Entradas PT100: 5..6 • (address = 2) RIOR - Entradas analógicas: 1..2; Entradas PT100: 3..4" ;
    ex:ilustradoEn ex:Manual_Principal .

ex:Sistema_ModulosRIO
    a ex:Sistema ;
    rdfs:label "Sistema de módulos RIO5 y RIOR" ;
    ex:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6). Los módulos RIOR tienen 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." ;
    ex:tieneComponente ex:Modulo_RIO5 ;
    ex:tieneComponente ex:Modulo_RIOR ;
    ex:detalladoEnEsquema ex:Tabla_AsignacionEntradasAnalogicas .

ex:Modulo_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIO5" ;
    ex:identificador "nodo 1" ;
    ex:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." .

ex:Modulo_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIOR" ;
    ex:identificador "nodo 2" ;
    ex:textoExtracto "Los módulos RIOR tienen 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." .

ex:EntradaAnalogica_AI1_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI1 (RIO5)" ;
    ex:identificador "AI1" ;
    ex:textoExtracto "Entradas analógicas (AI1..AI4) del módulo RIO5." .

ex:EntradaAnalogica_AI5_PT100_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI5 (RIO5)" ;
    ex:identificador "AI5" ;
    ex:textoExtracto "Entradas PT100 (AI5..AI6) del módulo RIO5." ;
    ex:monitoreaParametro ex:Parametro_PT100_EntradasActivas .