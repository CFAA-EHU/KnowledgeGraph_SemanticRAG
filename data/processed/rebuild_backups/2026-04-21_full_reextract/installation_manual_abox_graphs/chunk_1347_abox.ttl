@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2433
    a               ex:AvisoSeguridad ;
    ex:identificador "2433" ;
    ex:textoExtracto "Es obligatorio programar ON/OFF. DETECCIÓN Durante la ejecución. CAUSA Falta programar el comando ON/OFF para activar o anular la función. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Incluir el comando ON para activar la función (por ejemplo, #DMCON [...]) o el comando OFF para anularla (por ejemplo, #DMC OFF)." ;
    rdfs:label      "Error 2433: Falta programación ON/OFF" .

ex:Error_2458
    a               ex:AvisoSeguridad ;
    ex:identificador "2458" ;
    ex:textoExtracto "#DMC ON:El cabezal master debe tener el parámetro DMCSPDL = Sí. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." ;
    rdfs:label      "Error 2458: Cabezal sin permiso DMC (DMCSPDL)" .

ex:Parametro_DMCSPDL
    a               ex:Parametro ;
    ex:identificador "DMCSPDL" ;
    ex:valor         "Sí" ;
    ex:textoExtracto "El cabezal master debe tener el parámetro DMCSPDL = Sí" ;
    rdfs:label      "Parámetro DMCSPDL (permiso DMC)" .

ex:Comando_DMCON
    a               ex:InterfazUsuario ;
    ex:identificador "#DMCON" ;
    ex:textoExtracto "comando ON para activar la función (por ejemplo, #DMCON [...])" ;
    rdfs:label      "Comando #DMCON (activación DMC)" .

ex:Comando_DMCOFF
    a               ex:InterfazUsuario ;
    ex:identificador "#DMC OFF" ;
    ex:textoExtracto "comando OFF para anularla (por ejemplo, #DMC OFF)" ;
    rdfs:label      "Comando #DMC OFF (desactivación DMC)" .

ex:Error_2433
    ex:solucionaFallo ex:Comando_DMCON , ex:Comando_DMCOFF .

ex:Error_2458
    ex:solucionaFallo ex:Parametro_DMCSPDL .