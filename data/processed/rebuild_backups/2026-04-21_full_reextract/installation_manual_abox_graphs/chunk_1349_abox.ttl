@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjesRotativos_1349
    a                   ex:InterfazUsuario ;
    rdfs:label          "Configuración gráficos para ciclos de ejes rotativos (modelo M)"@es ;
    ex:textoExtracto    "En los gráficos F3D hay que cargar la configuración máquina (archivo xca) correspondiente a la configuración de ejes definida. Los archivos xca se pueden cargar bien desde el menú de softkeys o bien desde el programa mediante la sentencia #DEFGRAPH."@es ;
    ex:identificador    "F3D" ;
    ex:documentadoEn    ex:Manual_19_1 .

ex:ArchivoConfiguracionXCA_1349
    a                   ex:Parametro ;
    rdfs:label          "Archivo de configuración máquina (xca) para ejes rotativos"@es ;
    ex:textoExtracto    "archivo xca [...] están los archivos de configuración para máquinas con plato divisor"@es ;
    ex:identificador    "xca" ;
    ex:detalladoEnEsquema ex:ConfiguracionEjesRotativos_1349 ;
    ex:valor            "../Fagor/Grafdata/Machines/Mill" .

ex:SentenciaDEFGRAPH_1349
    a                   ex:Parametro ;
    rdfs:label          "Sentencia #DEFGRAPH para carga de configuración"@es ;
    ex:textoExtracto    "Los archivos xca se pueden cargar [...] desde el programa mediante la sentencia #DEFGRAPH"@es ;
    ex:identificador    "#DEFGRAPH" ;
    ex:monitoreaParametro ex:ArchivoConfiguracionXCA_1349 .

ex:Manual_19_1
    a                   ex:Pagina ;
    rdfs:label          "Sección 19.1: Configurar los gráficos para los ciclos de ejes rotativos"@es ;
    ex:textoExtracto    "GRÁFICOS HD. - 19 19. - 19.1 Configurar los gráficos para los ciclos de ejes rotativos"@es ;
    ex:identificador    "19.1" .