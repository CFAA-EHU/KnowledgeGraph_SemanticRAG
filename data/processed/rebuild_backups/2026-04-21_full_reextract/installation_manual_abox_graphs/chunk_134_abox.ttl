@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaEntradasAnalogicas_RIO5
    a               ex:Sistema ;
    rdfs:label      "Sistema de entradas analógicas RIO5" ;
    ex:textoExtracto "address = 1) RIO5 - Entradas analógicas. - 1..4 - Entradas PT100. - 5..6" ;
    ex:identificador "address = 1" ;
    ex:tieneComponente ex:SensorPT100_5, ex:SensorPT100_6 .

ex:SistemaEntradasAnalogicas_RIOR
    a               ex:Sistema ;
    rdfs:label      "Sistema de entradas analógicas RIOR" ;
    ex:textoExtracto "address = 2) RIOR - Entradas analógicas. - 7..8 - Entradas PT100. - 9..10" ;
    ex:identificador "address = 2" ;
    ex:tieneComponente ex:SensorPT100_9 .

ex:SensorPT100_5
    a               ex:Sensor ;
    rdfs:label      "Sensor PT100 (entrada 5)" ;
    ex:textoExtracto "PT100 1 = 5" ;
    ex:identificador "5" ;
    ex:monitoreaParametro ex:ParametroTemperatura_5 .

ex:SensorPT100_6
    a               ex:Sensor ;
    rdfs:label      "Sensor PT100 (entrada 6)" ;
    ex:textoExtracto "PT100 2 = 6" ;
    ex:identificador "6" ;
    ex:monitoreaParametro ex:ParametroTemperatura_6 .

ex:SensorPT100_9
    a               ex:Sensor ;
    rdfs:label      "Sensor PT100 (entrada 9)" ;
    ex:textoExtracto "PT100 3 = 9" ;
    ex:identificador "9" ;
    ex:monitoreaParametro ex:ParametroTemperatura_9 .

ex:ParametroTemperatura_5
    a               ex:Parametro ;
    rdfs:label      "Parámetro de temperatura (entrada 5)" ;
    ex:textoExtracto "PT100 1 = 5" ;
    ex:valor        "5" .

ex:ParametroTemperatura_6
    a               ex:Parametro ;
    rdfs:label      "Parámetro de temperatura (entrada 6)" ;
    ex:textoExtracto "PT100 2 = 6" ;
    ex:valor        "6" .

ex:ParametroTemperatura_9
    a               ex:Parametro ;
    rdfs:label      "Parámetro de temperatura (entrada 9)" ;
    ex:textoExtracto "PT100 3 = 9" ;
    ex:valor        "9" .

ex:ParametroNPT100
    a               ex:Parametro ;
    rdfs:label      "Número de entradas PT100 activas" ;
    ex:textoExtracto "NPT100 = 3" ;
    ex:valor        "3" .