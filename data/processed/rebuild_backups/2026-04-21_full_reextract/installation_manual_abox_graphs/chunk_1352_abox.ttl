@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" .

ex:InterfazUsuario_GraficosCiclosEjesRotativos
    a ex:InterfazUsuario ;
    rdfs:label "Gráficos para ciclos de ejes rotativos" ;
    ex:textoExtracto "Configurar los gráficos para los ciclos de ejes rotativos. Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS) y según la opción elegida en la tabla de herramientas." ;
    ex:monitoreaParametro ex:Parametro_FACEAXIS ;
    ex:monitoreaParametro ex:Parametro_LONGAXIS .

ex:Tabla_Herramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ex:textoExtracto "según la opción elegida en la tabla de herramientas" .