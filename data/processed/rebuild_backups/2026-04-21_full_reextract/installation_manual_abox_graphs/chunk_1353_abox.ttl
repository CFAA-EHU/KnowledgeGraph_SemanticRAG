@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "Si los parámetros máquina LONGAXIS o FACEAXIS cambian, hay que reiniciar el CNC para que los gráficos asuman la nueva configuración." .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "Si los parámetros máquina LONGAXIS o FACEAXIS cambian, hay que reiniciar el CNC para que los gráficos asuman la nueva configuración." .

ex:InterfazUsuario_GraficosCNC
    a ex:InterfazUsuario ;
    rdfs:label "Gráficos de configuración de ejes rotativos (CNC)" ;
    ex:textoExtracto "Configurar los gráficos para los ciclos de ejes rotativos [...] Si no están parametrizados los ejes, la posición por defecto de la herramienta en las diferentes configuraciones de máquina será la siguiente." ;
    ex:monitoreaParametro ex:Parametro_LONGAXIS ;
    ex:monitoreaParametro ex:Parametro_FACEAXIS .