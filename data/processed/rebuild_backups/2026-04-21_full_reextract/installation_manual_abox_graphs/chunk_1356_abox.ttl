@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguradorTopologiaKPA_EtherCAT_Studio
    a ex:Sistema ;
    rdfs:label "KPA EtherCAT Studio" ;
    ex:identificador "KPA EtherCAT Studio" ;
    ex:textoExtracto "Fagor suministra bajo licencia el configurador \"KPA EtherCAT Studio\" (de Koening-pa GmbH), que puede funcionar tanto en modo online como offline; en ambos casos es necesaria la licencia." .

ex:FicheroENI_EtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ex:identificador "fagor_ethercatConfFile.xml" ;
    ex:textoExtracto "El configurador de la topología genera el fichero ENI que contiene la información de los dispositivos EtherCAT conectados al CNC. Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"fagor_ethercatConfFile.xml\"." ;
    ex:documentadoEn ex:ConfiguradorTopologiaKPA_EtherCAT_Studio .

ex:ProgramaFagorEtherCATMapper
    a ex:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ex:identificador "Fagor EtherCAT Mapper" ;
    ex:textoExtracto "Este fichero también lo utiliza el programa \"Fagor EtherCAT Mapper\" para conocer los recursos disponibles en el bus." .

ex:LicenciaPendrive_KPA_EtherCAT_Studio
    a ex:ElementoSeguridad ;
    rdfs:label "Licencia vinculada a pendrive para KPA EtherCAT Studio" ;
    ex:textoExtracto "Fagor entrega un pendrive con el instalador y la licencia del configurador \"KPA EtherCAT Studio\". Esta licencia está vinculada al pendrive; el usuario podrá tener el configurador instalado en varios equipos, pero necesitará conectar el pendrive para utilizarlo." ;
    ex:habilitadoPor ex:ConfiguradorTopologiaKPA_EtherCAT_Studio .