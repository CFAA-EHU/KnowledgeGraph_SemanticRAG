@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguradorEtherCAT_Studio
    a ex:InterfazUsuario ;
    rdfs:label "Studio. Configurador EtherCAT"@es ;
    ex:textoExtracto "Studio. Configurador EtherCAT."@es ;
    ex:identificador "Studio" .

ex:ModuloEtherCAT_MasterWin64
    a ex:InterfazUsuario ;
    rdfs:label "Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet"@es ;
    ex:textoExtracto "Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet."@es ;
    ex:identificador "Master (Win64)" .

ex:UtilidadLicencias_KPA
    a ex:InterfazUsuario ;
    rdfs:label "KPA Licensing utilities. Acceso a la licencia de uso"@es ;
    ex:textoExtracto "KPA Licensing utilities. Acceso a la licencia de uso."@es ;
    ex:identificador "KPA Licensing utilities" .

ex:Tabla_IconosConfigurador a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de iconos del configurador EtherCAT"@es ;
    ex:textoExtracto "| Icono. | Función. | --- | --- |  | Studio. Configurador EtherCAT. |  | Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet. |  | KPA Licensing utilities. Acceso a la licencia de uso."@es ;
    ex:ilustradoEn ex:ConfiguradorEtherCAT_Studio ;
    ex:ilustradoEn ex:ModuloEtherCAT_MasterWin64 ;
    ex:ilustradoEn ex:UtilidadLicencias_KPA .