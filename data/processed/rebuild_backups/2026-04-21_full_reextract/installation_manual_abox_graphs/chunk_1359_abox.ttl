@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorLicenciaArranque
    a ex:AvisoSeguridad ;
    rdfs:label "Error de licencia al arrancar el programa"@es ;
    ex:textoExtracto "Error de licencia al arrancar el programa. El pendrive con la licencia debe estar conectado al PC. Si al arrancar el programa se produce el siguiente error, significa que el programa no encuentra la licencia."@es ;
    ex:solucionaFallo ex:FalloLicenciaNoEncontrada .

ex:FalloLicenciaNoEncontrada
    a ex:DiagnosticoFallo ;
    rdfs:label "Licencia no encontrada"@es ;
    ex:textoExtracto "El pendrive con la licencia debe estar conectado al PC. [...] significa que el programa no encuentra la licencia."@es .

ex:LicenciaBasicaFagor
    a ex:Sistema ;
    rdfs:label "Licencia Básica (Fagor)"@es ;
    ex:identificador "Básica" ;
    ex:textoExtracto "Fagor suministra la licencia 'Básica', que permite configurar el bus. Algunas opciones del configurador no estarán disponibles con esta licencia."@es .

ex:ProcedimientoSeleccionLicencia
    a ex:TareaMantenimiento ;
    rdfs:label "Selección manual de unidad de licencia"@es ;
    ex:textoExtracto "Pulsar el botón 'Browse' para seleccionar la unidad donde está conectado el pendrive y volver a pulsar el botón 'Ok'."@es ;
    ex:solucionaFallo ex:FalloLicenciaNoEncontrada .

ex:AvisoLicenciaModulos
    a ex:AvisoSeguridad ;
    rdfs:label "Error de licencia durante la detección de módulos"@es ;
    ex:textoExtracto "Error de licencia durante la detección de modulos. Ignorar este aviso."@es .