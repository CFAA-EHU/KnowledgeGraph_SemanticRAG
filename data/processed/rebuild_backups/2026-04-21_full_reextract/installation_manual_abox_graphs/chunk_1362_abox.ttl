@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ExportarConfiguracion_1362
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Exportar archivo de configuración (ETG Standard)"@es ;
    ex:textoExtracto    "Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Export\" y \"Export Master Configuration ETG Standard\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es ;
    ex:requiereMantenimiento ex:InterfazUsuario_1362 ;
    ex:ejecutadoPor    ex:Personal_1362 .

ex:InterfazUsuario_1362
    a                   ex:InterfazUsuario ;
    rdfs:label          "Interfaz de topología (ventana izquierda)"@es ;
    ex:textoExtracto    "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Export\" y \"Export Master Configuration ETG Standard\"."@es .

ex:Personal_1362
    a                   ex:Personal ;
    rdfs:label          "Operador de CNC"@es ;
    ex:textoExtracto    "Este es el archivo que se debe copiar al CNC."@es .

ex:ArchivoConfiguracion_1362
    a                   ex:Parametro ;
    rdfs:label          "Archivo de configuración ETG Standard (*.xml)"@es ;
    ex:textoExtracto    "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es ;
    ex:valor            "*.xml" .