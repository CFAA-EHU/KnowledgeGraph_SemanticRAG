ex:TablaUnidadesAnalogicas_748 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Unidades de entradas/salidas analógicas (pág. 748)" ;
    ex:textoExtracto "Entradas analógicas en tensión (V) | Décimas de milivoltio [...] Entradas para sondas de temperatura Pt100" ;
    ex:ilustradoEn ex:ManualBrochado .

ex:Parametro_EntradaAnalogicaTension
    a ex:Parametro ;
    rdfs:label "Unidad de entradas analógicas en tensión" ;
    ex:valor "décimas de milivoltio" ;
    ex:textoExtracto "Entradas analógicas en tensión (V). | Décimas de milivoltio." ;
    ex:documentadoEn ex:TablaUnidadesAnalogicas_748 .

ex:Parametro_EntradaAnalogicaCorriente
    a ex:Parametro ;
    rdfs:label "Unidad de entradas analógicas en corriente" ;
    ex:valor "microamperios" ;
    ex:textoExtracto "Entradas analógicas en corriente (mA). | Microamperios." ;
    ex:documentadoEn ex:TablaUnidadesAnalogicas_748 .

ex:Parametro_SalidaAnalogicaTension
    a ex:Parametro ;
    rdfs:label "Unidad de salidas analógicas en tensión" ;
    ex:valor "décimas de milivoltio" ;
    ex:textoExtracto "Salidas analógicas en tensión (V). | Décimas de milivoltio." ;
    ex:documentadoEn ex:TablaUnidadesAnalogicas_748 .

ex:Parametro_SalidaAnalogicaCorriente
    a ex:Parametro ;
    rdfs:label "Unidad de salidas analógicas en corriente" ;
