    ex:textoExtracto "Módulo (0) IB IL 24 DI 8 - HD-ECO | I1…I8 [...] Módulo (5) IB IL AI 4 - U-PAC | R3...R6" ;
    ex:ilustradoEn ex:ManualBrochado .

