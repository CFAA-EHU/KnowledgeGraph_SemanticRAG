@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_1366_UnidadesRecursosEtherCAT a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de unidades para recursos EtherCAT (pág. 748)"@es ;
    ex:textoExtracto """
| Entradas analógicas en corriente (mA). | Microamperios. |
| Salidas analógicas en tensión (V). | Décimas de milivoltio. |
| Salidas analógicas en corriente (mA). | Microamperios. |
| Entradas para sondas de temperatura Pt100. | Décimas de grado. |
"""@es .

ex:Parametro_EntradaCorriente_mA
    a ex:Parametro ;
    rdfs:label "Entradas analógicas en corriente (mA)"@es ;
    ex:valor "Microamperios"@es ;
    ex:documentadoEn ex:Tabla_1366_UnidadesRecursosEtherCAT ;
    ex:textoExtracto "Entradas analógicas en corriente (mA). | Microamperios."@es .

ex:Parametro_SalidaTension_V
    a ex:Parametro ;
    rdfs:label "Salidas analógicas en tensión (V)"@es ;
    ex:valor "Décimas de milivoltio"@es ;
    ex:documentadoEn ex:Tabla_1366_UnidadesRecursosEtherCAT ;
    ex:textoExtracto "Salidas analógicas en tensión (V). | Décimas de milivoltio."@es .

ex:Parametro_SalidaCorriente_mA
    a ex:Parametro ;
    rdfs:label "Salidas analógicas en corriente (mA)"@es ;
    ex:valor "Microamperios"@es ;
    ex:documentadoEn ex:Tabla_1366_UnidadesRecursosEtherCAT ;
    ex:textoExtracto "Salidas analógicas en corriente (mA). | Microamperios."@es .

ex:Parametro_EntradaPt100
    a ex:Parametro ;
    rdfs:label "Entradas para sondas de temperatura Pt100"@es ;
    ex:valor "Décimas de grado"@es ;
    ex:documentadoEn ex:Tabla_1366_UnidadesRecursosEtherCAT ;
    ex:textoExtracto "Entradas para sondas de temperatura Pt100. | Décimas de grado."@es .