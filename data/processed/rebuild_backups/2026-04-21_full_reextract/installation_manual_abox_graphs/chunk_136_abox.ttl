@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloRIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIOR" ;
    ex:textoExtracto "Entradas analógicas del módulo RIOR. • Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767. • Rango de medida ±20 miliamperios." ;
    ex:identificador "RIOR" .

ex:Parametro_ResolucionAnalogica_RIOR
    a ex:Parametro ;
    rdfs:label "Resolución de entradas analógicas (módulo RIOR)" ;
    ex:textoExtracto "Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767." ;
    ex:valor "±32767" .

ex:Parametro_RangoMedida_RIOR
    a ex:Parametro ;
    rdfs:label "Rango de medida (módulo RIOR)" ;
    ex:textoExtracto "Rango de medida ±20 miliamperios." ;
    ex:valor "±20 mA" .

ex:Parametro_FactorConversion_RIOR
    a ex:Parametro ;
    rdfs:label "Factor de conversión (módulo RIOR)" ;
    ex:textoExtracto "Factor = 200 / 32767 = 0,0061035 (para devolver el valor en decimiliamperios)" ;
    ex:valor "0.0061035" .

ex:ModuloRIOR
    ex:monitoreaParametro ex:Parametro_ResolucionAnalogica_RIOR ;
    ex:monitoreaParametro ex:Parametro_RangoMedida_RIOR ;
    ex:monitoreaParametro ex:Parametro_FactorConversion_RIOR .