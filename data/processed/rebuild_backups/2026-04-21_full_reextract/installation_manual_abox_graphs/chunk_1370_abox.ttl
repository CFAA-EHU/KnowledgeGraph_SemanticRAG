@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_1370
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de visualización de esclavos y módulos"@es ;
    ex:textoExtracto "Para mostrar todos los esclavos, hacer clic en el icono \"Ver esclavos\". El segundo nivel está formado por los módulos que pertenecen al esclavo. Al hacer clic sobre un módulo, el programa muestra su lista de recursos."@es ;
    ex:ilustradoEn ex:Esquema_TopologiaBus_1370 .

ex:Esquema_TopologiaBus_1370
    a ex:Esquema ;
    rdfs:label "Topología del bus (vista de bloques)"@es ;
    ex:textoExtracto "Topología del bus (vista de bloques)."@es .