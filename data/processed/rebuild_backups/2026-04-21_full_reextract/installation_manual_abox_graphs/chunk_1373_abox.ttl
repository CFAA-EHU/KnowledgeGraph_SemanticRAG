@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_ConfiguracionBus
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración del bus"@es ;
    ex:textoExtracto "Modificar la numeración de los recursos de todo el bus. Modificar los recursos en la barra superior y el programa actualiza los recursos de todo el bus."@es ;
    ex:tieneComponente ex:Parametro_EntradasDigitales_Bus,
                       ex:Parametro_SalidasDigitales_Bus .

ex:InterfazUsuario_ConfiguracionNodo
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de nodo (vista de bloques)"@es ;
    ex:textoExtracto "En la vista de bloques, hacer clic sobre el nombre de la cabecera y definir el número con el que empiezan los recursos del nodo."@es .

ex:InterfazUsuario_ConfiguracionModulo
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de módulo (vista de bloques)"@es ;
    ex:textoExtracto "En la vista de bloques, hacer clic sobre un módulo y definir el número con el que empiezan sus recursos; el resto de recursos se numeran de forma correlativa."@es .

ex:Parametro_EntradasDigitales_Bus
    a ex:Parametro ;
    rdfs:label "Parámetro de entradas digitales (bus)"@es ;
    ex:textoExtracto "Entradas digitales. Primera = 10 Offset = 100"@es ;
    ex:valor "Primera: 10 ; Offset: 100"@es .

ex:Parametro_SalidasDigitales_Bus
    a ex:Parametro ;
    rdfs:label "Parámetro de salidas digitales (bus)"@es ;
    ex:textoExtracto "Salidas digitales. Primera = 21 Offset = 50 Offset = 100 Offset = 100"@es ;
    ex:valor "Primera: 21 ; Offset: 50, 100, 100"@es .