@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Overlapped_Configuracion_Modulo
    a                   ex:Parametro ;
    rdfs:label          "Overlapped" ;
    ex:textoExtracto    "La ficha \"Overlapped\" define si se permite la superposición de recursos en diferentes módulos." ;
    ex:valor            "Right", "No" .

ex:LoadFilter_Accion
    a                   ex:AccionProhibida ;
    rdfs:label          "Load filter" ;
    ex:textoExtracto    "Cada vez que se modifica está opción, hay que validarla con el icono \"Load filter\" situado en la parte superior derecha." .

ex:InterfazUsuario_Overlapped
    a                   ex:InterfazUsuario ;
    rdfs:label          "Ficha Overlapped" ;
    ex:textoExtracto    "La ficha \"Overlapped\" define si se permite la superposición de recursos en diferentes módulos." ;
    ex:tieneComponente  ex:Overlapped_Configuracion_Modulo ;
    ex:tieneComponente  ex:LoadFilter_Accion .

ex:Parametro_Starts
    a                   ex:Parametro ;
    rdfs:label          "Starts" ;
    ex:identificador    "81" ;
    ex:textoExtracto    "Starts=81" ;
    ex:valor            "81" .

ex:Error_AsignacionRecurso
    a                   ex:AvisoSeguridad ;
    rdfs:label          "Error de asignación de recurso" ;
    ex:textoExtracto    "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." ;
    ex:mitigaRiesgo     ex:Overlapped_Configuracion_Modulo .