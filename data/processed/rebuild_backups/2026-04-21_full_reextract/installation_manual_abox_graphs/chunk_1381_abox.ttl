@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OpenPCS_Remoto_1381
    a                     ex:Sistema ;
    rdfs:label            "OpenPCS remoto"@es ;
    ex:textoExtracto      "El OpenPCS deberá estar instalado en un PC externo, el cual podrá estar conectado al CNC a través de una red o un cable cruzado. [...] Configurar el CNC para utilizar el PLC remoto."@es ;
    ex:identificador      "IEC-61131" .

ex:Parametro_PLCTYPE_MPG_1381
    a                     ex:Parametro ;
    rdfs:label            "PLCTYPE (MPG)"@es ;
    ex:textoExtracto      "Tipo de PLC; estándar IEC-61131 y/o Fagor."@es ;
    ex:identificador      "PLCTYPE" ;
    ex:valor               "IEC-61131 y/o Fagor"@es ;
    ex:documentadoEn       ex:Tabla_ParametrosPLC_1381 .

ex:Tabla_ParametrosPLC_1381 a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla de parámetros PLC (MPG)"@es ;
    ex:textoExtracto      "La siguiente tabla muestra a quién afecta el arranque (RUN) y la parada (STOP) del PLC en función de este parámetro, así como el estado de la marca PLCREADY."@es .

ex:Script_OpenPCS_1381
    a                     ex:Componente ;
    rdfs:label            "Script de configuración OpenPCS"@es ;
    ex:textoExtracto      "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."@es ;
    ex:documentadoEn       ex:Sistema ;
    ex:identificador      "..\\Fagor\\Plc\\Openpcs" .

ex:Conexion_Red_FagorCNCTCP_1381
    a                     ex:InterfazUsuario ;
    rdfs:label            "Conexión FagorCNCTCP"@es ;
    ex:textoExtracto      "Para modificar la conexión, en el menú PLC > Connections seleccionar la opción FagorCNCTCP y pulsar Edit. [...] Definir la IP adecuada (la del CNC)."@es ;
    ex:identificador      "FagorCNCTCP" .

ex:Modulo_Hardware_OpenPCS_1381
    a                     ex:Componente ;
    rdfs:label            "Módulo hardware OpenPCS"@es ;
    ex:textoExtracto      "El script crea el módulo hardware para el que se va a compilar el programa PLC."@es ;
    ex:compuestoPor        ex:Conexion_Red_FagorCNCTCP_1381 ;
    ex:tieneComponente     ex:Script_OpenPCS_1381 .