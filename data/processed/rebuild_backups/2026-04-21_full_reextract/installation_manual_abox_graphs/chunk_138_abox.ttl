@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionPalpador a ex:Tabla ;
    rdfs:label "Tabla de configuración de palpadores"@es ;
    ex:textoExtracto """
| PROBEDATA |  |
| --- | --- |
| PROBETYPE1 | Tipo de palpador 1. |
| PROBETYPE2 | Tipo de palpador 2. |
| PRBDI1 | Número de entrada asociada al palpador 1. |
| PRBDI2 | Número de entrada asociada al palpador 2. |
| PRBPULSE1 | Nivel lógico de activación del palpador 1. |
| PRBPULSE2 | Nivel lógico de activación del palpador 2. |
"""@es .

ex:Parametro_PROBETYPE1 a ex:Parametro ;
    rdfs:label "PROBETYPE1" ;
    ex:identificador "PROBETYPE1" ;
    ex:textoExtracto "Tipo de palpador 1."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .

ex:Parametro_PROBETYPE2 a ex:Parametro ;
    rdfs:label "PROBETYPE2" ;
    ex:identificador "PROBETYPE2" ;
    ex:textoExtracto "Tipo de palpador 2."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .

ex:Parametro_PRBDI1 a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:identificador "PRBDI1" ;
    ex:textoExtracto "Número de entrada asociada al palpador 1."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .

ex:Parametro_PRBDI2 a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:identificador "PRBDI2" ;
    ex:textoExtracto "Número de entrada asociada al palpador 2."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .

ex:Parametro_PRBPULSE1 a ex:Parametro ;
    rdfs:label "PRBPULSE1" ;
    ex:identificador "PRBPULSE1" ;
    ex:textoExtracto "Nivel lógico de activación del palpador 1."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .

ex:Parametro_PRBPULSE2 a ex:Parametro ;
    rdfs:label "PRBPULSE2" ;
    ex:identificador "PRBPULSE2" ;
    ex:textoExtracto "Nivel lógico de activación del palpador 2."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionPalpador .