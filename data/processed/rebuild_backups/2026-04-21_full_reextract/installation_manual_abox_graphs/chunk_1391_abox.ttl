@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PROGAIN
    a ex:Parametro ;
    rdfs:label "Ganancia proporcional (PROGAIN)" ;
    ex:textoExtracto "ajuste de la ganancia proporcional (PROGAIN)" ;
    ex:monitoreaParametro ex:Sensor_ErrorSeguimiento .

ex:Parametro_FFGAIN
    a ex:Parametro ;
    rdfs:label "Ganancia de feed-forward (FFGAIN)" ;
    ex:textoExtracto "bloque \"FFGAIN\"" ;
    ex:monitoreaParametro ex:Sensor_ErrorSeguimiento .

ex:Sensor_ErrorSeguimiento
    a ex:Sensor ;
    rdfs:label "Sensor de error de seguimiento (ε)" ;
    ex:textoExtracto "señal de error \"ε\"" .

ex:Sistema_FeedForward
    a ex:Sistema ;
    rdfs:label "Sistema de control feed-forward" ;
    ex:textoExtracto "esquema de bloques de feed-forward" ;
    ex:compuestoPor ex:Parametro_FFGAIN, ex:Parametro_PROGAIN ;
    ex:controla ex:Componente_ActuadorEje ;
    ex:detalladoEnEsquema ex:Esquema_BloquesFeedForward .

ex:Componente_ActuadorEje
    a ex:Actuador ;
    rdfs:label "Actuador de eje (Analog output)" ;
    ex:textoExtracto "\"Analog output\" que actúa sobre la \"Actual position\"" .

ex:Esquema_BloquesFeedForward
    a ex:Esquema ;
    rdfs:label "Esquema de bloques de feed-forward" ;
    ex:textoExtracto "esquema de bloques de feed-forward: \"Programmed Feedrate\" alimenta un bloque \"FFGAIN\"" ;
    ex:ilustradoEn ex:Figura_OscilogramaAjusteCorrecto, ex:Figura_OscilogramaAjusteIncorrecto, ex:Figura_PanelAjusteACForward .

ex:Figura_OscilogramaAjusteCorrecto
    a ex:Figura ;
    rdfs:label "Oscilograma: Ajuste correcto con feed forward" ;
    ex:textoExtracto "oscilograma \"Ajuste correcto con feed forward\". Se representan \"Actual Feed\" y \"Following Error (E)\" con icono de verificación. El avance alcanza el valor objetivo con sobreimpulso mínimo y el error de seguimiento permanece acotado sin invertir signo; la escala indicada es 10 µm por cuadro." .

ex:Figura_OscilogramaAjusteIncorrecto
    a ex:Figura ;
    rdfs:label "Oscilograma: Ajuste incorrecto con feed forward" ;
    ex:textoExtracto "oscilograma \"Ajuste incorrecto con feed forward\" con icono de equis. El \"Following Error (E)\" presenta picos que invierten signo y oscilaciones amortiguadas, evidenciando exceso de feed-forward o ganancias mal calibradas. Misma escala (10 µm por cuadro)." .

ex:Figura_PanelAjusteACForward
    a ex:Figura ;
    rdfs:label "Panel: Ajuste apropiado para AC-Forward" ;
    ex:textoExtracto "panel \"Ajuste apropiado\" (icono de verificación) para AC-Forward: respuesta del sistema sin ganancia AC-forward (10 µm por cuadro) frente a respuesta con AC-forward (1 µm por cuadro)." .