@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Parametros de aceleracion/jerk
ex:Parametrizacion_AltaACCEL_BajoACCJERK
    a ex:Parametro ;
    rdfs:label "Configuración: ACCEL máxima y ACCJERK mínimo"@es ;
    ex:textoExtracto "ACCEL máxima y ACCJERK mínimo"@es ;
    ex:monitoreaParametro ex:G00FEED_Parametro .

ex:Parametrizacion_BajaACCEL_AltoACCJERK
    a ex:Parametro ;
    rdfs:label "Configuración: ACCEL menor y ACCJERK mayor"@es ;
    ex:textoExtracto "ACCEL menor y ACCJERK mayor, que acorta el tiempo hasta aceleración máxima y mantiene más tiempo la meseta"@es ;
    ex:monitoreaParametro ex:G00FEED_Parametro .

ex:G00FEED_Parametro
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "Fórmulas anotadas relacionan ACCEL y ACCJERK con G00FEED y t"@es .

ex:ACCEL_Parametro
    a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "ACCEL = (3/2)·G00FEED/(60·t)"@es ;
    ex:valor "ACCEL" .

ex:ACCJERK_Parametro
    a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "ACCJERK = 3·ACCEL/t"@es ;
    ex:valor "ACCJERK" .

ex:TripticoAceleracionSenoCuadrado
    a ex:Figura ;
    rdfs:label "Tríptico de aceleración seno-cuadrado"@es ;
    ex:textoExtracto "tríptico de aceleración seno-cuadrado con v(t), a(t) y j(t), comparando igualmente dos configuraciones (máxima vs. menor aceleración con jerk mayor). La aceleración describe un pulso simétrico tipo seno-cuadrado y el jerk presenta lóbulos centrados"@es ;
    ex:ilustradoEn ex:Pagina_207 .

### Sistema de encoder lineal
ex:EsquemaEncoderLineal
    a ex:Esquema ;
    rdfs:label "Esquema de encoder lineal con referencia codificada"@es ;
    ex:textoExtracto "esquema de encoder lineal con referencia codificada: se dibuja la regla con el 'cero del cristal (OG)', el 'cero máquina (OM)' y el desplazamiento 'ABSOFF'. Una lupa esquematiza la serigrafía; la flecha de lectura indica que el origen de codificación puede quedar dentro o fuera de la regla"@es ;
    ex:detalladoEnEsquema ex:EncoderLineal_Componente .

ex:EncoderLineal_Componente
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder lineal"@es ;
    ex:textoExtracto "regla con el 'cero del cristal (OG)', el 'cero máquina (OM)' y el desplazamiento 'ABSOFF'"@es .

ex:ABSOFF_Parametro
    a ex:Parametro ;
    rdfs:label "ABSOFF" ;
    ex:textoExtracto "desplazamiento 'ABSOFF'"@es ;
    ex:valor "ABSOFF" .

ex:EXTMULT_Parametro
    a ex:Parametro ;
    rdfs:label "EXTMULT" ;
    ex:textoExtracto "uso de ABSOFF y EXTMULT en la referencia"@es ;
    ex:valor "EXTMULT" .

### Banda de error de seguimiento
ex:GraficoBandaErrorSeguimiento
    a ex:Figura ;
    rdfs:label "Gráfico de banda de error para monitorización lineal"@es ;
    ex:textoExtracto "gráfico de banda de error para monitorización lineal del error de seguimiento: en el plano (Fe)–(F) se representa una zona sombreada con límites proporcionales a F (pendiente ±%FEDYNFAC) y el umbral MAXFLWE desde el que se activa la supervisión dinámica"@es ;
    ex:ilustradoEn ex:Pagina_220 .

ex:FEDYNFAC_Parametro
    a ex:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ex:textoExtracto "límites proporcionales a F (pendiente ±%FEDYNFAC)"@es ;
    ex:valor "FEDYNFAC" .

ex:MAXFLWE_Parametro
    a ex:Parametro ;
    rdfs:label "MAXFLWE" ;
    ex:textoExtracto "umbral MAXFLWE desde el que se activa la supervisión dinámica"@es ;
    ex:valor "MAXFLWE" .

ex:AlarmaErrorSeguimiento
    a ex:Alarma ;
    rdfs:label "Alarma por error de seguimiento"@es ;
    ex:textoExtracto "Fuera de la banda se indica 'ERROR', visualizando el criterio de aceptación"@es ;
    ex:activaAlarma ex:GraficoBandaErrorSeguimiento .