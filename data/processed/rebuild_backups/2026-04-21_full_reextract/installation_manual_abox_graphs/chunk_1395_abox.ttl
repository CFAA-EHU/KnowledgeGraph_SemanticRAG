@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_AsignacionTeclasJog_245
    a ex:Esquema ;
    rdfs:label "Esquema de asignación de teclas JOG (pág. 245)"@es ;
    ex:textoExtracto "Esquema de ejemplo que combina iconos de teclas (X±, Y±, '4±', '5±', '+', '−', 'R') con flechas de sentido. Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R."@es ;
    ex:ilustradoEn ex:InterfazUsuario_JogPanel .

ex:InterfazUsuario_JogPanel
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario JOG-PANEL"@es ;
    ex:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido."@es ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionTeclasJog_245 ;
    ex:tieneComponente ex:Tecla_Rapido_R, ex:Tecla_Eje_X, ex:Tecla_Eje_Y, ex:Tecla_Eje_4, ex:Tecla_Eje_5 .

ex:Tecla_Rapido_R
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla R (avance rápido)"@es ;
    ex:textoExtracto "tecla de rápido R"@es ;
    ex:ilustradoEn ex:Esquema_AsignacionTeclasJog_245 .

ex:Tecla_Eje_X
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de eje X (±)"@es ;
    ex:textoExtracto "teclas de sentido (+/−) y de eje (X, Y, 4, 5)"@es ;
    ex:identificador "X±" ;
    ex:ilustradoEn ex:Esquema_AsignacionTeclasJog_245 .

ex:Tecla_Eje_Y
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de eje Y (±)"@es ;
    ex:textoExtracto "teclas de sentido (+/−) y de eje (X, Y, 4, 5)"@es ;
    ex:identificador "Y±" ;
    ex:ilustradoEn ex:Esquema_AsignacionTeclasJog_245 .

ex:Tecla_Eje_4
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de eje 4 (±)"@es ;
    ex:textoExtracto "teclas de sentido (+/−) y de eje (X, Y, 4, 5)"@es ;
    ex:identificador "4±" ;
    ex:ilustradoEn ex:Esquema_AsignacionTeclasJog_245 .

ex:Tecla_Eje_5
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de eje 5 (±)"@es ;
    ex:textoExtracto "teclas de sentido (+/−) y de eje (X, Y, 4, 5)"@es ;
    ex:identificador "5±" ;
    ex:ilustradoEn ex:Esquema_AsignacionTeclasJog_245 .

ex:Esquema_AsignacionTeclasLCD10K_246
    a ex:Esquema ;
    rdfs:label "Esquema de teclado LCD-10K (pág. 246)"@es ;
    ex:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog."@es ;
    ex:ilustradoEn ex:InterfazUsuario_LCD10K .

ex:InterfazUsuario_LCD10K
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario LCD-10K"@es ;
    ex:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−."@es ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionTeclasLCD10K_246 ;
    ex:tieneComponente ex:Tecla_R_LCD10K, ex:Tecla_XPos_LCD10K, ex:Tecla_XNeg_LCD10K, ex:Tecla_YPos_LCD10K, ex:Tecla_YNeg_LCD10K, ex:Tecla_4Pos_LCD10K, ex:Tecla_4Neg_LCD10K, ex:Tecla_5Pos_LCD10K, ex:Tecla_5Neg_LCD10K .

