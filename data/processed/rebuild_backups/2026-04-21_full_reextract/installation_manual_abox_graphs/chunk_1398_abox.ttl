@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)" ;
    ex:valor "desplazamiento herramienta vs. eje secundario" .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)" ;
    ex:valor "desplazamiento herramienta vs. eje secundario" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:textoExtracto "TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)" ;
    ex:valor "desplazamiento herramienta vs. eje secundario" .

ex:Parametro_TDATA13
    a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:textoExtracto "TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" ;
    ex:valor "posición cabezal vs. punto de referencia" .

ex:Parametro_TDATA14
    a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:textoExtracto "TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" ;
    ex:valor "posición cabezal vs. punto de referencia" .

ex:Parametro_TDATA15
    a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:textoExtracto "TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" ;
    ex:valor "posición cabezal vs. punto de referencia" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "distancias TDATA2–TDATA5 hacia el punto de referencia" ;
    ex:valor "distancia vs. punto de referencia" .

ex:Parametro_TDATA10
    a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:textoExtracto "sentido de giro (TDATA10/TDATA11)" ;
    ex:valor "sentido de giro (0/1)" .

ex:Parametro_TDATA11
    a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:textoExtracto "sentido de giro (TDATA10/TDATA11)" ;
    ex:valor "sentido de giro (0/1)" .

ex:Esquema_ReglaManoDerecha
    a ex:Esquema ;
    rdfs:label "Regla de la mano derecha (DIN 66217)" ;
    ex:textoExtracto "Dibujo de 'regla de la mano derecha' con ejes X, Y, Z y un croquis de giro alrededor del eje lineal positivo indicado por el pulgar. Ilustra el criterio de signo para TDATA10/TDATA11 en ejes rotativos." ;
    ex:ilustradoEn ex:Parametro_TDATA10, ex:Parametro_TDATA11 .

ex:Esquema_MesaRotativa_TYPE9
    a ex:Esquema ;
    rdfs:label "Cinemática mesa rotativa TYPE=9" ;
    ex:textoExtracto "Conjunto de esquemas de mesa rotativa AB: vista iso con distancias TDATA2–TDATA5 hacia el punto de referencia, y diagramas del sentido de giro (TDATA10/TDATA11) desde el punto de vista de la herramienta." ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2, ex:Parametro_TDATA5, ex:Parametro_TDATA10, ex:Parametro_TDATA11 .

ex:Esquema_MesaRotativa_TYPE10_TYPE11
    a ex:Esquema ;
    rdfs:label "Cinemática mesas rotativas TYPE=10 y TYPE=11" ;
    ex:textoExtracto "Dos bloques de viñetas para mesas AC y BA con cotas TDATA2–TDATA5 y pares de dibujos que comparan configuraciones de sentido de giro (TDATA10/TDATA11 = 0/1)." ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2, ex:Parametro_TDATA5, ex:Parametro_TDATA10, ex:Parametro_TDATA11 .

ex:Esquema_MesaRotativa_TYPE12
    a ex:Esquema ;
    rdfs:label "Cinemática mesa rotativa TYPE=12" ;
    ex:textoExtracto "Viñetas de mesa BC con distancias TDATA2–TDATA5 y los dos casos de sentido de giro posibles." ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2, ex:Parametro_TDATA5, ex:Parametro_TDATA10, ex:Parametro_TDATA11 .