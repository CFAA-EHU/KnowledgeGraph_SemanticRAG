@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "RTCP origen respecto a cero máquina/pieza (TDATA7)"@es ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "Un diagrama adicional contrasta el origen de RTCP respecto a cero máquina/pieza (TDATA7) mediante ejes X′-Y′."@es .

ex:Parametro_TDATA16
    a ex:Parametro ;
    rdfs:label "Sistema de coordenadas RTCP (TDATA16)"@es ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina)."@es ;
    ex:valor "0,1" .

ex:Esquema_RTCP_B30
    a ex:Esquema ;
    rdfs:label "Diagrama comparativo RTCP ON B-30"@es ;
    ex:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 [...] frente a TDATA16=1 [...]. Se visualizan ejes X′-Z′ y vector de inclinación B."@es ;
    ex:detalladoEnEsquema ex:Parametro_TDATA16 .

ex:Figura_CinematicasCabezalMesa_Intro
    a ex:Figura ;
    rdfs:label "Iconos introductorios de cinemáticas cabezal-mesa"@es ;
    ex:textoExtracto "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa."@es ;
    ex:ilustradoEn ex:Sistema_CinematicoCabezalMesa .

ex:Sistema_CinematicoCabezalMesa
    a ex:Sistema ;
    rdfs:label "Sistema cinemático cabezal-mesa (tipos 13–16)"@es ;
    ex:textoExtracto "Funcionan como leyenda visual previa a las hojas de tipos 13–16."@es .

ex:Parametro_TDATA1
    a ex:Parametro ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA2
    a ex:Parametro ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA3
    a ex:Parametro ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA4
    a ex:Parametro ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA5
    a ex:Parametro ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA6
    a ex:Parametro ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "Cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina"@es .

ex:Parametro_TDATA11
    a ex:Parametro ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "Incluye croquis de inversión del sentido de giro (TDATA11=0/1)."@es ;
    ex:valor "0,1" .

ex:Parametro_TDATA13
    a ex:Parametro ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA13…TDATA15 para colocación del cabezal"@es .

ex:Parametro_TDATA14
    a ex:Parametro ;
    ex:identificador "TDATA14" ;
    ex:textoExtracto "TDATA13…TDATA15 para colocación del cabezal"@es .

ex:Parametro_TDATA15
    a ex:Parametro ;
    ex:identificador "TDATA15" ;
    ex:textoExtracto "TDATA13…TDATA15 para colocación del cabezal"@es .

ex:Figura_Tipos13_14
    a ex:Figura ;
    rdfs:label "Croquis de cinemáticas cabezal-mesa (tipos 13 y 14)"@es ;
    ex:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal."@es ;
    ex:ilustradoEn ex:Sistema_CinematicoCabezalMesa ;
    ex:detalladoEnEsquema ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3,
                        ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6,
                        ex:Parametro_TDATA11, ex:Parametro_TDATA13,
                        ex:Parametro_TDATA14, ex:Parametro_TDATA15 .