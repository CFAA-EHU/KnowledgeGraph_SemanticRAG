@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PROBETYPE1
    a ex:Parametro ;
    rdfs:label "PROBETYPE1" ;
    ex:identificador "MPG.PROBETYPE1" ;
    ex:textoExtracto "PROBETYPE1 Tipo de palpador 1. Valores posibles: Remoto / Local / Gap (sólo modelo láser). Valor por defecto: Remoto. Variable asociada: (V.)MPG.PROBETYPE1" ;
    ex:valor "Remoto" .

ex:Parametro_PROBETYPE2
    a ex:Parametro ;
    rdfs:label "PROBETYPE2" ;
    ex:identificador "MPG.PROBETYPE2" ;
    ex:textoExtracto "PROBETYPE2 Tipo de palpador 2. Valores posibles: Remoto / Local / Gap (sólo modelo láser). Valor por defecto: Remoto. Variable asociada: (V.)MPG.PROBETYPE2" ;
    ex:valor "Remoto" .

ex:Parametro_PRBDI1
    a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:identificador "MPG.PRBDI1" ;
    ex:textoExtracto "PRBDI1 Número de entrada asociada al palpador 1. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado). Variable asociada: (V.)MPG.PRBDI1" ;
    ex:valor "0" .

ex:Parametro_PRBDI2
    a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:identificador "MPG.PRBDI2" ;
    ex:textoExtracto "PRBDI2 Número de entrada asociada al palpador 2. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado). Variable asociada: (V.)MPG.PRBDI2" ;
    ex:valor "0" .

ex:Sensor_ProximidadGap
    a ex:Sensor ;
    rdfs:label "Sensor de proximidad (Gap)" ;
    ex:textoExtracto "opción \"Gap\" para utilizar el sensor de proximidad como palpador (por ejemplo, para medir la inclinación de una chapa). La opción \"Gap\" sólo está disponible en el modelo láser." .

ex:Tabla_PROBEDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla PROBEDATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla PROBEDATA." ;
    ex:tieneComponente ex:Parametro_PROBETYPE1, ex:Parametro_PROBETYPE2, ex:Parametro_PRBDI1, ex:Parametro_PRBDI2 .