@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EsquemaCinematica_TYPE18
    a ex:Esquema ;
    ex:identificador "TYPE=18" ;
    ex:textoExtracto "Esquema de cinemática TYPE=18 con ejes X-Y-Z y rotaciones A/C. Incluye anotaciones TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) y numeración del orden de los giros (1º-3º). Las flechas y signos (+/−) marcan la dirección positiva según norma; se destaca la relación del eje rotativo con los lineales." ;
    rdfs:label "Esquema de cinemática TYPE=18 (ejes X-Y-Z, rotaciones A/C)" .

ex:EsquemaCinematica_TYPE19
    a ex:Esquema ;
    ex:identificador "TYPE=19" ;
    ex:textoExtracto "Esquema de cinemática TYPE=19 con ejes lineales X-Y-Z y rotaciones A/C/B. Se detallan TDATA 1, 2, 7, 8, 11 y otros para offsets y sentidos; incluye orden de rotaciones y referencias de signo para los vectores de giro." ;
    rdfs:label "Esquema de cinemática TYPE=19 (ejes X-Y-Z, rotaciones A/C/B)" .

ex:EsquemaCinematica_TYPE20
    a ex:Esquema ;
    ex:identificador "TYPE=20" ;
    ex:textoExtracto "Esquema de cinemática TYPE=20 con ejes X-Y-Z y rotación B, con despieces laterales que indican TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) y la secuencia 1º-3º. Las flechas muestran direccionalidad y el signo de cada componente." ;
    rdfs:label "Esquema de cinemática TYPE=20 (ejes X-Y-Z, rotación B)" .

ex:Parametro_TDATA1
    a ex:Parametro ;
    ex:identificador "TDATA 1" ;
    ex:monitoreaParametro ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) en TYPE=18; TDATA 1, 2, 7, 8, 11 en TYPE=19; TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) en TYPE=20" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    ex:identificador "TDATA 2" ;
    ex:monitoreaParametro ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) en TYPE=18; TDATA 1, 2, 7, 8, 11 en TYPE=19; TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) en TYPE=20" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    ex:identificador "TDATA 7" ;
    ex:monitoreaParametro ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) en TYPE=18; TDATA 1, 2, 7, 8, 11 en TYPE=19; TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) en TYPE=20" .

ex:Parametro_TDATA8
    a ex:Parametro ;
    ex:identificador "TDATA 8" ;
    ex:monitoreaParametro ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19 ;
    ex:textoExtracto "TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) en TYPE=18; TDATA 1, 2, 7, 8, 11 en TYPE=19" .

ex:EjeLineal_X
    a ex:ComponenteMecanico ;
    ex:identificador "Eje X" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "Ejes lineales X-Y-Z en esquemas TYPE=18, TYPE=19 y TYPE=20" .

ex:EjeLineal_Y
    a ex:ComponenteMecanico ;
    ex:identificador "Eje Y" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "Ejes lineales X-Y-Z en esquemas TYPE=18, TYPE=19 y TYPE=20" .

ex:EjeLineal_Z
    a ex:ComponenteMecanico ;
    ex:identificador "Eje Z" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "Ejes lineales X-Y-Z en esquemas TYPE=18, TYPE=19 y TYPE=20" .

ex:EjeRotativo_A
    a ex:ComponenteMecanico ;
    ex:identificador "Eje A" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19 ;
    ex:textoExtracto "Rotaciones A/C en TYPE=18; rotaciones A/C/B en TYPE=19" .

ex:EjeRotativo_B
    a ex:ComponenteMecanico ;
    ex:identificador "Eje B" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE19, ex:EsquemaCinematica_TYPE20 ;
    ex:textoExtracto "Rotación B en TYPE=19 y TYPE=20" .

ex:EjeRotativo_C
    a ex:ComponenteMecanico ;
    ex:identificador "Eje C" ;
    ex:detalladoEnEsquema ex:EsquemaCinematica_TYPE18, ex:EsquemaCinematica_TYPE19 ;
    ex:textoExtracto "Rotaciones A/C en TYPE=18; rotaciones A/C/B en TYPE=19" .