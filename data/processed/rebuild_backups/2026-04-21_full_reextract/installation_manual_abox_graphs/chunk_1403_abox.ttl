@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2 (posición)" ;
    ex:textoExtracto "Se representan offsets TDATA2 (posición)" ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4 (offset angular)" ;
    ex:textoExtracto "Se representan offsets TDATA4 (offset angular)" ;
    ex:identificador "TDATA4" .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6 (desalineamiento)" ;
    ex:textoExtracto "Se representan offsets TDATA6 (desalineamiento)" ;
    ex:identificador "TDATA6" .

ex:Parametro_TDATA10
    a ex:Parametro ;
    rdfs:label "TDATA10 (sentido de giro)" ;
    ex:textoExtracto "determinar el sentido de giro del eje giratorio (TDATA10)" ;
    ex:identificador "TDATA10" .

ex:Figura_ReglaManoDerechaXYZ
    a ex:Figura ;
    rdfs:label "Regla de la mano derecha para ejes X-Y-Z" ;
    ex:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos. Tres bocetos de mano señalan dirección positiva del eje lineal (pulgar) y giro asociado (curvatura de dedos)" ;
    ex:ilustradoEn ex:Pagina_274 .

ex:Figura_ReglaManoDerechaEjeC
    a ex:Figura ;
    rdfs:label "Regla de la mano derecha aplicada al eje C" ;
    ex:textoExtracto "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10)" ;
    ex:ilustradoEn ex:Pagina_276 .

ex:Esquema_EjeC_Cilindrico
    a ex:Esquema ;
    rdfs:label "Esquema del eje C cilíndrico (#CYL)" ;
    ex:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza. Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular)" ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA4 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA10 ;
    ex:ilustradoEn ex:Pagina_277 .

ex:Pagina_274
    a ex:Pagina ;
    rdfs:label "Página 274 - Definición de cinemáticas del eje C (tipos 41–42)" ;
    ex:textoExtracto "Páginas: 274 | Sección: 2. PARÁMETROS MÁQUINA · Definición de las cinemáticas del eje C (tipos 41–42)" ;
    ex:identificador "274" .

ex:Pagina_276
    a ex:Pagina ;
    rdfs:label "Página 276 - Definición de cinemáticas del eje C (tipo 43)" ;
    ex:textoExtracto "Páginas: 276 | Sección: 2. PARÁMETROS MÁQUINA · Definición de las cinemáticas del eje C (tipo 43)" ;
    ex:identificador "276" .

ex:Pagina_277
    a ex:Pagina ;
    rdfs:label "Página 277 - Esquema del eje C cilíndrico" ;
    ex:textoExtracto "Páginas: 277 | Sección: 2. PARÁMETROS MÁQUINA · Definición de las cinemáticas del eje C" ;
    ex:identificador "277" .