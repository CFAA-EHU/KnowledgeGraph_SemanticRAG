@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2 (posición del rotativo)" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4 (offset angular)" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA4" .

ex:Parametro_TDATA10
    a ex:Parametro ;
    rdfs:label "TDATA10 (sentido de giro)" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA10" .

ex:Parametro_TDATA8
    a ex:Parametro ;
    rdfs:label "TDATA8 (sentido de giro del eje rotativo principal)" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA8" .

ex:Parametro_TDATA18
    a ex:Parametro ;
    rdfs:label "TDATA18 (sentido de giro del eje rotativo secundario)" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA18" .

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9 (distinción manual/servo del eje principal)" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA9" .

ex:Parametro_TDATA19
    a ex:Parametro ;
    rdfs:label "TDATA19 (distinción manual/servo del eje secundario)" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA19" .

ex:Esquema_CinematicaCabezalTipo50
    a ex:Esquema ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal (tipo 50)" ;
    ex:textoExtracto "Conjunto de diagramas: pictogramas de cabezales (esférico, ortogonal, angular) y tres vistas con vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección). Ejes X-Y-Z, flechas, y etiquetas TDATA1–26 indican componentes, posiciones de reposo y sentidos." ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2 , ex:Parametro_TDATA4 , ex:Parametro_TDATA10 .

ex:Esquema_ReglaManoDerecha
    a ex:Esquema ;
    rdfs:label "Regla de la mano derecha para ejes rotativos" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:detalladoEnEsquema ex:Parametro_TDATA8 , ex:Parametro_TDATA9 , ex:Parametro_TDATA18 , ex:Parametro_TDATA19 .

ex:Sistema_CinematicaCabezal
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática de cabezal (tipo 50)" ;
    ex:textoExtracto "Diagramas vectoriales ampliados para el cabezal: se muestran orígenes de los vectores de traslación (T1, T2, T3) y dirección (V1, V2, V3), con indicación de distancias relativas al punto de referencia máquina y signos de las componentes." ;
    ex:compuestoPor ex:Parametro_TDATA2 , ex:Parametro_TDATA4 , ex:Parametro_TDATA10 ;
    ex:ilustradoEn ex:Esquema_CinematicaCabezalTipo50 .

ex:Sistema_CinematicaMesa
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática de mesa (tipo 51)" ;
    ex:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2." .