@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ConfiguracionPalpador_140
    a ex:Parametro ;
    rdfs:label "Parámetro de configuración del palpador"@es ;
    ex:textoExtracto "Este parámetro indica el número de la entrada a la que está conectado el palpador."@es ;
    ex:identificador "Configuración_Palpador" .

ex:Sensor_Proximidad_140
    a ex:Sensor ;
    rdfs:label "Sensor de proximidad"@es ;
    ex:textoExtracto "para un sensor de proximidad, no es necesario definir este parámetro."@es .

ex:EntradaDigital_140
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada digital (física o lógica)"@es ;
    ex:textoExtracto "La entrada digital podrá ser una entrada física del módulo o una entrada lógica del PLC."@es .

ex:PLC_140
    a ex:Sistema ;
    rdfs:label "PLC (Controlador Lógico Programable)"@es ;
    ex:textoExtracto "el PLC considera entradas lógicas a aquellas entradas que no existen como físicas"@es ;
    ex:tieneComponente ex:EntradaDigital_140 .

ex:ModuloRemoto_140
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas"@es ;
    ex:textoExtracto "si en los módulos remotos están numeradas las entradas 1 a 256"@es ;
    ex:tieneComponente ex:EntradaDigital_140 .