@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Interfaz de visualización de errores (pág. 403)
ex:Interfaz_MessagesAndErrors
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz MESSAGES AND ERRORS"@es ;
    ex:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc."@es ;
    ex:ilustradoEn ex:Figura_VisualizacionErroresPLC .

ex:Figura_VisualizacionErroresPLC
    a ex:Figura ;
    rdfs:label "Diagrama de visualización de errores y mensajes del PLC"@es ;
    ex:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc."@es .

### Parámetro de temporización (págs. 402-403)
ex:Parametro_MINAENDW
    a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:identificador "MINAENDW" ;
    ex:textoExtracto "El gráfico ilustra [...] el tiempo mínimo definido (MINAENDW) antes de concluir la operación."@es ;
    ex:monitoreaParametro ex:Sensor_AUXEND ;
    ex:ilustradoEn ex:Figura_DiagramaTemporalSincronizado, ex:Figura_DiagramaTemporalNoSincronizado .

### Señales digitales (págs. 402-403)
ex:Sensor_SSTROBE
    a ex:Sensor ;
    rdfs:label "SSTROBE" ;
    ex:identificador "SSTROBE" ;
    ex:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es ;
    ex:ilustradoEn ex:Figura_DiagramaTemporalSincronizado, ex:Figura_DiagramaTemporalNoSincronizado .

ex:Sensor_MSTROBE
    a ex:Sensor ;
    rdfs:label "MSTROBE" ;
    ex:identificador "MSTROBE" ;
    ex:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es ;
    ex:ilustradoEn ex:Figura_DiagramaTemporalSincronizado, ex:Figura_DiagramaTemporalNoSincronizado .

ex:Sensor_AUXEND
    a ex:Sensor ;
    rdfs:label "AUXEND" ;
    ex:identificador "AUXEND" ;
    ex:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es ;
    ex:ilustradoEn ex:Figura_DiagramaTemporalSincronizado, ex:Figura_DiagramaTemporalNoSincronizado .

### Figuras de diagramas temporales
ex:Figura_DiagramaTemporalSincronizado
    a ex:Figura ;
    rdfs:label "Diagrama temporal de transferencia sincronizada (SSTROBE/MSTROBE/AUXEND)"@es ;
    ex:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos y numeradas (1–4) para indicar la secuencia de ejecución. Se resalta el parámetro de temporización MINAENDW mediante una cota horizontal."@es .

ex:Figura_DiagramaTemporalNoSincronizado
    a ex:Figura ;
    rdfs:label "Diagrama temporal de transferencia no sincronizada (SSTROBE/MSTROBE/PLC EXECUTION)"@es ;
    ex:textoExtracto "Diagrama temporal con SSTROBE/MSTROBE y la traza 'PLC EXECUTION', incluyendo una cota de duración MINAENDW. Muestra que, en transferencias no sincronizadas, el CNC mantiene el 'strobe' durante el tiempo mínimo y continúa la ejecución sin esperar confirmación del PLC."@es .