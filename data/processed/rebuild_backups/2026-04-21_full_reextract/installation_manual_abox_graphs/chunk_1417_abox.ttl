@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas y diagramas
ex:DiagramaTemporal_PLC_Se_alesEjes
    a ex:Esquema ;
    rdfs:label "Diagrama temporal de señales PARK/UNPARK/DRENA/REFPOIN desde PLC"@es ;
    ex:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC. Representa PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis) con numeración (1–4) de eventos. La gráfica distingue claramente la iniciación por PARKED, el comienzo de PARK/UNPARK por parte del CNC y la finalización con restablecimiento de habilitaciones."@es ;
    ex:identificador "Señales de consulta de los ejes y cabezales (PLC)" .

### Interfaces de usuario
ex:OP_PANEL_TecladoUsuario
    a ex:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL con teclado de usuario y bloque de teclas de jog"@es ;
    ex:textoExtracto "Fotografía del panel OP-PANEL con teclado de usuario y bloque de teclas de jog. Se distinguen pulsadores iluminables, con agrupación jerárquica por funciones (usuario, jog, husillo, start/stop) y distribución matricial que el texto asocia a bits KEYBD1/2/3."@es ;
    ex:ilustradoEn ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:OP_PANEL_329
    a ex:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL-329 (selector circular, pulsadores de jog en columna)"@es ;
    ex:textoExtracto "Fotografía del panel OP-PANEL-329 mostrando un layout compacto: selector circular, pulsadores de jog en columna y teclas de usuario en bloque. La imagen ilustra la codificación por bits de las teclas (user y jog) que se consultan en KEYBD1/2/3 y variantes por panel."@es ;
    ex:ilustradoEn ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:QC_C65_10K
    a ex:InterfazUsuario ;
    rdfs:label "Panel QC-C65□-10K (pantalla integrada, keypad numérico y teclas de jog)"@es ;
    ex:textoExtracto "Fotografía del panel QC-C65□-10K con pantalla integrada y keypad numérico; a la derecha, un bloque de teclas de jog dispuesto en rejilla. La figura apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx para este modelo."@es ;
    ex:ilustradoEn ex:DiagramaTemporal_PLC_Se_alesEjes .

### Componentes lógicos (señales como parámetros monitorizados)
ex:Se_al_PARK
    a ex:Parametro ;
    rdfs:label "PARK(axis)"@es ;
    ex:textoExtracto "Representa PARK(axis) en el diagrama temporal de maniobra desde PLC."@es ;
    ex:monitoreaParametro ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:Se_al_UNPARK
    a ex:Parametro ;
    rdfs:label "UNPARK(axis)"@es ;
    ex:textoExtracto "Representa UNPARK(axis) en el diagrama temporal de maniobra desde PLC."@es ;
    ex:monitoreaParametro ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:Se_al_PARKED
    a ex:Parametro ;
    rdfs:label "PARKED(axis)"@es ;
    ex:textoExtracto "Representa PARKED(axis) en el diagrama temporal, con iniciación por PARKED."@es ;
    ex:monitoreaParametro ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:Se_al_DRENA
    a ex:Parametro ;
    rdfs:label "DRENA(axis)"@es ;
    ex:textoExtracto "Representa DRENA(axis) en el diagrama temporal de maniobra desde PLC."@es ;
    ex:monitoreaParametro ex:DiagramaTemporal_PLC_Se_alesEjes .

ex:Se_al_REFPOIN
    a ex:Parametro ;
    rdfs:label "REFPOIN(axis)"@es ;
    ex:textoExtracto "Representa REFPOIN(axis) en el diagrama temporal de maniobra desde PLC."@es ;
    ex:monitoreaParametro ex:DiagramaTemporal_PLC_Se_alesEjes .

### Registros de consulta (agrupados como sistema lógico)
ex:Registros_KEYBD
    a ex:Sistema ;
    rdfs:label "Registros KEYBD1/KEYBD2/KEYBD3 para mapeo de teclas"@es ;
    ex:textoExtracto "Bits KEYBD1/2/3 asociados a la distribución matricial de pulsadores en los paneles OP-PANEL, OP-PANEL-329 y QC-C65-10K."@es ;
    ex:tieneComponente ex:OP_PANEL_TecladoUsuario, ex:OP_PANEL_329, ex:QC_C65_10K .