@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagramaEstadosServoEnable
    a                       ex:Esquema ;
    rdfs:label              "Diagrama de estados para SERVOON/ENABLE"@es ;
    ex:textoExtracto         "Diagrama de estados para SERVOON/ENABLE con trazas 'Velocity Command', ventanas de DWELL y condición de ERROR. Expone la lógica de habilitación del regulador, la espera configurada por DWELL y el disparo de error si no se cumple la condición de servo activo antes del movimiento."@es ;
    ex:ilustradoEn           ex:SeccionEntradasSalidasCNC .

ex:SeccionEntradasSalidasCNC
    a                       ex:InterfazUsuario ;
    rdfs:label              "Entradas y salidas lógicas del CNC · Señales modificables de los ejes y cabezales"@es ;
    ex:textoExtracto         "Sección del manual que documenta señales lógicas modificables de ejes, cabezales y teclas del CNC."@es ;
    ex:identificador         "Páginas 448, 451, 453, 461"@es .

ex:DiagramaCambioGamaGEAR1_GEAR2
    a                       ex:Esquema ;
    rdfs:label              "Diagrama temporal de cambio de gama (GEAR1→GEAR2)"@es ;
    ex:textoExtracto         "Diagrama temporal de cambio de gama (GEAR1→GEAR2) con señales MFUN, MSTROBE, AUXEND, indicadores GEAR1/GEAR2, pista 'CHANGE' y referencia MINAENDW. Describe la secuencia: solicitud M4x, comienzo/fin de cambio (AUXEND), confirmación de gama y liberación del strobe."@es ;
    ex:detalladoEnEsquema    ex:SeccionEntradasSalidasCNC .

ex:DiagramaOscilacionCabezalPLC
    a                       ex:Esquema ;
    rdfs:label              "Diagrama temporal de oscilación del cabezal controlada por PLC"@es ;
    ex:textoExtracto         "Diagrama temporal de oscilación del cabezal controlada por PLC durante cambio de gama, con trazas MFUN, MSTROBE, AUXEND, GEAR1/GEAR4 y señales SANALOG/PLCCNTL. Representa conmutación de control al PLC, consigna analógica residual y devolución del control al CNC."@es ;
    ex:detalladoEnEsquema    ex:SeccionEntradasSalidasCNC .

ex:ModuloOP_PANEL_H_E
    a                       ex:InterfazUsuario ;
    rdfs:label              "Módulo OP-PANEL-H/E"@es ;
    ex:textoExtracto         "Imagen del módulo OP-PANEL-H/E con distribución completa de teclado: override de husillo, sentidos de giro, posicionamiento, START/STOP, ZERO, RESET y teclas de usuario con leds. Se ilustra qué grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS."@es ;
    ex:documentadoEn         ex:SeccionEntradasSalidasCNC ;
    ex:identificador         "OP-PANEL-H/E" .

ex:TeclasIluminablesKEYLED
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Teclas con iluminación KEYLED2/KEYLEDHBLS"@es ;
    ex:textoExtracto         "grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS"@es ;
    ex:tieneComponente       ex:ModuloOP_PANEL_H_E .