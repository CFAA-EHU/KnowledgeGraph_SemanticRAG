@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_AsignacionBitsTeclasOP_PANEL_H_E
    a ex:Esquema ;
    rdfs:label "Esquema de asignación de bits a teclas del OP-PANEL-H/E"@es ;
    ex:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos."@es ;
    ex:ilustradoEn ex:InterfazUsuario_OP_PANEL_H_E .

ex:InterfazUsuario_OP_PANEL_H_E
    a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL-H/E"@es ;
    ex:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado)."@es ;
    ex:tieneComponente ex:Tecla_Husillo ,
                       ex:Tecla_Ejecucion ,
                       ex:Tecla_Interbloqueo ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP_PANEL_H_E .

ex:Tecla_Husillo
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de husillo"@es ;
    ex:textoExtracto "énfasis en funciones de husillo"@es ;
    ex:ilustradoEn ex:Esquema_AsignacionBitsTeclasOP_PANEL_H_E .

ex:Tecla_Ejecucion
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de ejecución"@es ;
    ex:textoExtracto "énfasis en funciones de [...] ejecución"@es ;
    ex:ilustradoEn ex:Esquema_AsignacionBitsTeclasOP_PANEL_H_E .

ex:Tecla_Interbloqueo
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla de interbloqueo"@es ;
    ex:textoExtracto "énfasis en funciones de [...] interbloqueos"@es ;
    ex:ilustradoEn ex:Esquema_AsignacionBitsTeclasOP_PANEL_H_E .

ex:Sistema_IluminacionTeclas
    a ex:Sistema ;
    rdfs:label "Sistema KEYLED2/KEYLEDHBLS"@es ;
    ex:textoExtracto "qué grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS"@es ;
    ex:controla ex:Tecla_Husillo ,
                ex:Tecla_Ejecucion ,
                ex:Tecla_Interbloqueo .

ex:Fotografia_ReferenciaOP_PANEL
    a ex:Figura ;
    rdfs:label "Fotografía de referencia del OP-PANEL"@es ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) usadas como referencia visual para 'Registros KEYDIS…'. Muestran físicamente las teclas de usuario y de jog cuya inhibición se controla por bit"@es ;
    ex:ilustradoEn ex:InterfazUsuario_OP_PANEL .

ex:InterfazUsuario_OP_PANEL
    a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL"@es ;
    ex:textoExtracto "Fotografías de referencia para registros KEYDIS"@es .

ex:Figura_RejillaTeclasJog
    a ex:Figura ;
    rdfs:label "Rejilla de teclas de jog y bloque de funciones"@es ;
    ex:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2"@es ;
    ex:ilustradoEn ex:InterfazUsuario_OP_PANEL .

ex:Sistema_AlmacenHerramientasTorreta
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas tipo torreta para torno"@es ;
    ex:textoExtracto "Ilustración de un almacén tipo torreta para torno: se observa una torreta indexable con varios portaherramientas montados radialmente, cada uno con su plaquita o fresa, y la posición de trabajo orientada hacia el punto de mecanizado. La vista enfatiza la disposición circular de estaciones y el giro de la torreta para presentar la herramienta activa."@es ;
    ex:compuestoPor ex:TorretaIndexable ,
                    ex:Portaherramientas_01 ,
                    ex:Portaherramientas_02 ,
                    ex:PlaquitaMecanizado_01 ,
                    ex:Fresa_01 .

ex:TorretaIndexable
    a ex:ComponenteMecanico ;
    rdfs:label "Torreta indexable"@es ;
    ex:textoExtracto "torreta indexable con varios portaherramientas montados radialmente [...] disposición circular de estaciones y el giro de la torreta"@es .

ex:Portaherramientas_01
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas (estación 1)"@es ;
    ex:textoExtracto "varios portaherramientas montados radialmente"@es .

ex:Portaherramientas_02
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas (estación 2)"@es ;
    ex:textoExtracto "varios portaherramientas montados radialmente"@es .

ex:PlaquitaMecanizado_01
    a ex:Consumible ;
    rdfs:label "Plaquita de mecanizado"@es ;
    ex:textoExtracto "cada uno con su plaquita o fresa"@es .

ex:Fresa_01
    a ex:Consumible ;
    rdfs:label "Fresa"@es ;
    ex:textoExtracto "cada uno con su plaquita o fresa"@es .