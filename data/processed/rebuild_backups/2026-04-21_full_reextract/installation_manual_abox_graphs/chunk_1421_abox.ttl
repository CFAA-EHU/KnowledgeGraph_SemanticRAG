@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_AlmacenHerramientasSinBrazo
    a ex:Figura ;
    rdfs:label "Ilustración de almacén síncrono sin brazo cambiador"@es ;
    ex:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal; el carrusel se posiciona frente al husillo para realizar el intercambio directamente, sin intervención de brazo. La imagen resalta el plato portaherramientas circular y la proximidad al cabezal."@es ;
    ex:ilustradoEn ex:Pagina_469 .

ex:Figura_AlmacenHerramientasConBrazoSimple
    a ex:Figura ;
    rdfs:label "Ilustración de almacén síncrono con brazo cambiador (1–2 pinzas)"@es ;
    ex:textoExtracto "Ilustración de un almacén síncrono con brazo cambiador (1–2 pinzas): se aprecia un disco portaherramientas cercano al cabezal y un brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo. Se sugiere la secuencia de toma y depósito, con el brazo actuando solo cuando no hay mecanizado."@es ;
    ex:ilustradoEn ex:Pagina_469 .

ex:Figura_AlmacenHerramientasAsincrono
    a ex:Figura ;
    rdfs:label "Ilustración de almacén asíncrono con brazo cambiador"@es ;
    ex:textoExtracto "Ilustración de un almacén asíncrono con brazo cambiador: cadena tipo 'crawler' o almacén lineal alejado del cabezal y un brazo de doble pinza desplazándose de forma independiente. La escena muestra el movimiento del brazo mientras la cadena transporta portaherramientas, optimizando tiempos al poder moverse durante el mecanizado."@es ;
    ex:ilustradoEn ex:Pagina_472 .

ex:Aviso_CompatibilidadSoftwareV2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso sobre compatibilidad de marcas y registros en OPENPCS REMOTO V2.00+"@es ;
    ex:textoExtracto "Recuadro informativo con icono 'i' (aviso) sobre compatibilidad de marcas y registros con versiones anteriores del software; enfatiza que, desde V2.00, las señales sin referencia explícita pasan a referirse al primer canal o almacén."@es ;
    ex:documentadoEn ex:Pagina_761 .

ex:Pagina_469
    a ex:Pagina ;
    rdfs:label "Página 469 (Sección 7.1: Tipos de almacén)"@es ;
    ex:identificador "469" ;
    ex:textoExtracto "Sección 7.1 Tipos de almacén (Gestión de herramientas y almacén)"@es .

ex:Pagina_472
    a ex:Pagina ;
    rdfs:label "Página 472 (Sección 7.3: Comunicación entre el gestor y el PLC)"@es ;
    ex:identificador "472" ;
    ex:textoExtracto "Sección 7.3 Comunicación entre el gestor y el PLC"@es .

ex:Pagina_761
    a ex:Pagina ;
    rdfs:label "Página 761 (Sección OPENPCS REMOTO 21.21)"@es ;
    ex:identificador "761" ;
    ex:textoExtracto "Sección OPENPCS REMOTO. - 21 21."@es .