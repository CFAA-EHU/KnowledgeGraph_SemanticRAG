@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_AlmacenTorreta
    a ex:Figura ;
    rdfs:label "Ilustración de torreta de torno con herramientas"@es ;
    ex:textoExtracto "Ilustración de torreta de torno con varias estaciones y herramientas montadas; se destaca la herramienta activa alineada con el punto de trabajo."@es ;
    ex:ilustradoEn ex:Pagina_492 .

ex:Figura_AlmacenCarruselSinBrazo
    a ex:Figura ;
    rdfs:label "Ilustración de carrusel sin brazo cambiador"@es ;
    ex:textoExtracto "Ilustración del carrusel próximo al cabezal sin brazo: el plato de herramientas se orienta y acerca al husillo para transferir la herramienta directamente."@es ;
    ex:ilustradoEn ex:Pagina_502 .

ex:Figura_AlmacenCarruselBrazo1Pinza
    a ex:Figura ;
    rdfs:label "Ilustración de carrusel con brazo de 1 pinza"@es ;
    ex:textoExtracto "Ilustración del carrusel cercano al cabezal con un brazo de una sola pinza. El brazo extrae la herramienta del carrusel y la entrega al husillo."@es ;
    ex:ilustradoEn ex:Pagina_514 .

ex:Figura_AlmacenCarruselBrazo2Pinzas
    a ex:Figura ;
    rdfs:label "Ilustración de carrusel con brazo de 2 pinzas"@es ;
    ex:textoExtracto "Ilustración del carrusel con brazo de dos pinzas: se distinguen dos mordazas para operaciones de toma y entrega en secuencia cruzada."@es ;
    ex:ilustradoEn ex:Pagina_514 .

ex:Pagina_492
    a ex:Pagina ;
    ex:identificador "7.8" ;
    ex:textoExtracto "Sección 7.8: Almacén síncrono sin brazo cambiador"@es .

ex:Pagina_502
    a ex:Pagina ;
    ex:identificador "7.9" ;
    ex:textoExtracto "Sección 7.9: Almacén síncrono con brazo cambiador de 1 pinza"@es .

ex:Pagina_514
    a ex:Pagina ;
    ex:identificador "7.10" ;
    ex:textoExtracto "Sección 7.10: Almacén síncrono con brazo cambiador de 2 pinzas"@es .

ex:SistemaCambioHerramientas_Torreta
    a ex:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (torreta)"@es ;
    ex:textoExtracto "Se destaca la herramienta activa alineada con el punto de trabajo. La composición apoya el texto sobre secuencia de cambio (giro de torreta) y la imposibilidad de cambiar durante el mecanizado, incluyendo el papel de T y M06."@es ;
    ex:ilustradoEn ex:Figura_AlmacenTorreta .

ex:SistemaCambioHerramientas_CarruselSinBrazo
    a ex:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (carrusel sin brazo)"@es ;
    ex:textoExtracto "El plato de herramientas se orienta y acerca al husillo para transferir la herramienta directamente. Se sugiere el flujo en dos fases (T para preselección y M06 para el cambio)."@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselSinBrazo .

ex:SistemaCambioHerramientas_Brazo1Pinza
    a ex:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (brazo 1 pinza)"@es ;
    ex:textoExtracto "El brazo extrae la herramienta del carrusel y la entrega al husillo; se aprecia la trayectoria de transferencia y la lógica de dos fases (T y M06)."@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselBrazo1Pinza .

ex:SistemaCambioHerramientas_Brazo2Pinzas
    a ex:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (brazo 2 pinzas)"@es ;
    ex:textoExtracto "Dos mordazas para operaciones de toma y entrega en secuencia cruzada (pinza 1 ↔ cabezal, pinza 2 ↔ carrusel), minimizando el tiempo de intercambio."@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselBrazo2Pinzas .

ex:Herramienta_Torreta
    a ex:Herramienta ;
    rdfs:label "Herramienta activa en torreta"@es ;
    ex:textoExtracto "Herramienta activa alineada con el punto de trabajo"@es ;
    ex:ilustradoEn ex:Figura_AlmacenTorreta .

ex:Herramienta_Carrusel
    a ex:Herramienta ;
    rdfs:label "Herramienta en carrusel"@es ;
    ex:textoExtracto "Herramienta transferida directamente del plato al husillo"@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselSinBrazo .

ex:ComponenteMecanico_Brazo1Pinza
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de 1 pinza"@es ;
    ex:textoExtracto "Brazo de una sola pinza que extrae la herramienta del carrusel y la entrega al husillo"@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselBrazo1Pinza .

ex:ComponenteMecanico_Brazo2Pinzas
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de 2 pinzas"@es ;
    ex:textoExtracto "Brazo con dos mordazas para operaciones de toma y entrega en secuencia cruzada"@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselBrazo2Pinzas .

ex:ComponenteMecanico_PlatoCarrusel
    a ex:ComponenteMecanico ;
    rdfs:label "Plato de herramientas del carrusel"@es ;
    ex:textoExtracto "Plato de herramientas que se orienta y acerca al husillo"@es ;
    ex:ilustradoEn ex:Figura_AlmacenCarruselSinBrazo .