@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaGantryTandem
    a ex:Sistema ;
    rdfs:label "Sistema de arquitectura gantry con precarga en tándem"@es ;
    ex:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. [...] Diagrama con flechas que indican aceleración hacia la derecha; el piñón maestro aplica mayor par motor, mientras el esclavo compensa con par opuesto para mantener la tensión mecánica y minimizar el juego durante el arranque."@es ;
    ex:tieneComponente ex:MotorMaestroGantry, ex:MotorEsclavoGantry, ex:ReductorMaestroGantry, ex:ReductorEsclavoGantry, ex:PinonMaestroGantry, ex:PinonEsclavoGantry, ex:CremalleraGantry ;
    ex:ilustradoEn ex:EsquemaPrecargaTandem .

ex:MotorMaestroGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Motor maestro (gantry)"@es ;
    ex:textoExtracto "motor (maestro) [...] el piñón maestro aplica mayor par motor"@es .

ex:MotorEsclavoGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Motor esclavo (gantry)"@es ;
    ex:textoExtracto "motor (esclavo) [...] el esclavo compensa con par opuesto"@es .

ex:ReductorMaestroGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Reductor del motor maestro (gantry)"@es ;
    ex:textoExtracto "trenes motor–reductor–piñón"@es .

ex:ReductorEsclavoGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Reductor del motor esclavo (gantry)"@es ;
    ex:textoExtracto "trenes motor–reductor–piñón"@es .

ex:PinonMaestroGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Piñón maestro (gantry)"@es ;
    ex:textoExtracto "piñón maestro aplica mayor par motor"@es .

ex:PinonEsclavoGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Piñón esclavo (gantry)"@es ;
    ex:textoExtracto "el esclavo compensa con par opuesto para mantener la tensión mecánica"@es .

ex:CremalleraGantry
    a ex:ComponenteMecanico ;
    rdfs:label "Cremallera (gantry)"@es ;
    ex:textoExtracto "dos motores (maestro y esclavo) engranados sobre la misma cremallera"@es .

ex:EsquemaPrecargaTandem
    a ex:Esquema ;
    rdfs:label "Esquema de precarga en tándem (efecto de la precarga)"@es ;
    ex:textoExtracto "Esquema lateral de dos trenes motor–reductor–piñón contra cremallera inmóviles; vectores opuestos de par en maestro y esclavo visualizan una tracción previa que elimina holguras cuando el sistema está parado. [...] Gráfico similar al anterior, pero con precarga dominante sobre la fricción"@es ;
    ex:ilustradoEn ex:Pagina_575, ex:Pagina_576 .

ex:Pagina_575
    a ex:Pagina ;
    ex:identificador "575" ;
    ex:textoExtracto "Sección: Efecto de la precarga (tándem). Títulos: Precarga en reposo / Precarga con aceleración"@es .

ex:Pagina_576
    a ex:Pagina ;
    ex:identificador "576" ;
    ex:textoExtracto "Sección: Efecto de la precarga (tándem). Títulos: Precarga a velocidad constante / Precarga con deceleración"@es .