@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EsquemaPaso3_CompensacionVolumetrica
    a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 3) del plano XY con patrón de relleno completo en X para cada fila Y(Pn)"@es ;
    ex:textoExtracto "Esquema 3D (Paso 3) del plano XY con el patrón de relleno completo en X para cada fila Y(Pn). Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2 y cómo se genera la lista ordenada de puntos antes de subir de cota Z."@es ;
    ex:identificador "Paso 3" .

ex:EsquemaPaso4_CompensacionVolumetrica
    a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2)"@es ;
    ex:textoExtracto "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2): desde X(P1), Y(P1), Z(P2) se repite el barrido en X e Y. Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano."@es ;
    ex:identificador "Paso 4" .

ex:EsquemaPaso5_CompensacionVolumetrica
    a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 5) mostrando varios planos intermedios Z"@es ;
    ex:textoExtracto "Esquema 3D (Paso 5) mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance. La representación enfatiza la construcción volumétrica por capas, manteniendo los incrementos definidos para cada eje."@es ;
    ex:identificador "Paso 5" .

ex:EsquemaPaso6_CompensacionVolumetrica
    a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn)"@es ;
    ex:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn). Se observan todas las capas Z apiladas, el patrón de serpenteo por planos y la malla completa que sustenta la interpolación de errores dentro del volumen."@es ;
    ex:identificador "Paso 6" .

ex:Parametro_NPOINTSAX1
    a ex:Parametro ;
    rdfs:label "Contador NPOINTSAX1"@es ;
    ex:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es ;
    ex:ilustradoEn ex:EsquemaPaso3_CompensacionVolumetrica .

ex:Parametro_NPOINTSAX2
    a ex:Parametro ;
    rdfs:label "Contador NPOINTSAX2"@es ;
    ex:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es ;
    ex:ilustradoEn ex:EsquemaPaso3_CompensacionVolumetrica .

ex:Parametro_Z_P2
    a ex:Parametro ;
    rdfs:label "Cota Z(P2)"@es ;
    ex:textoExtracto "Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano."@es ;
    ex:ilustradoEn ex:EsquemaPaso4_CompensacionVolumetrica .

ex:Parametro_Z_Pn
    a ex:Parametro ;
    rdfs:label "Cota Z(Pn)"@es ;
    ex:textoExtracto "volumen totalmente relleno hasta Z(Pn)"@es ;
    ex:ilustradoEn ex:EsquemaPaso6_CompensacionVolumetrica .