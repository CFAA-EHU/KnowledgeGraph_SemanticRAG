@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_RIO5_24DI_16DO
    a ex:Esquema ;
    rdfs:label "Esquema de bastidor RIO5 (24+24 DI / 16+16 DO)"@es ;
    ex:textoExtracto "bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales. El esquema visual refuerza la partición en dos bloques lógicos de entradas, mostrando la continuidad del cableado y las regletas de conexión."@es ;
    ex:identificador "Grupo 3" .

ex:Sistema_RIO5
    a ex:Sistema ;
    rdfs:label "Bastidor RIO5"@es ;
    ex:textoExtracto "bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales"@es ;
    ex:detalladoEnEsquema ex:Esquema_RIO5_24DI_16DO ;
    ex:tieneComponente ex:ComponenteElectrico_RIO5_Entradas_1_24, ex:ComponenteElectrico_RIO5_Entradas_25_48, ex:ComponenteElectrico_RIO5_Salidas_1_16, ex:ComponenteElectrico_RIO5_Salidas_17_32 .

ex:ComponenteElectrico_RIO5_Entradas_1_24
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 1 de entradas digitales (24 DI) - RIO5"@es ;
    ex:textoExtracto "bloques lógicos de entradas"@es ;
    ex:identificador "I1-I24" .

ex:ComponenteElectrico_RIO5_Entradas_25_48
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 2 de entradas digitales (24 DI) - RIO5"@es ;
    ex:textoExtracto "bloques lógicos de entradas"@es ;
    ex:identificador "I25-I48" .

ex:ComponenteElectrico_RIO5_Salidas_1_16
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 1 de salidas digitales (16 DO) - RIO5"@es ;
    ex:textoExtracto "16+16 salidas digitales"@es ;
    ex:identificador "O1-O16" .

ex:ComponenteElectrico_RIO5_Salidas_17_32
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 2 de salidas digitales (16 DO) - RIO5"@es ;
    ex:textoExtracto "16+16 salidas digitales"@es ;
    ex:identificador "O17-O32" .

ex:Esquema_RIOW_Nodo1
    a ex:Esquema ;
    rdfs:label "Esquema de módulo RIOW (Nodo 1: 16 DI / 8 DO)"@es ;
    ex:textoExtracto "módulo RIOW con 16 entradas y 8 salidas. Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO, destacando la segmentación en bloques lógicos independientes (entradas/salidas) y su indexación inicial (I1/O81 en el ejemplo)."@es ;
    ex:identificador "Nodo 1 (RIOW)" .

ex:Sistema_RIOW_Nodo1
    a ex:Sistema ;
    rdfs:label "Módulo RIOW (Nodo 1)"@es ;
    ex:textoExtracto "módulo RIOW con 16 entradas y 8 salidas"@es ;
    ex:detalladoEnEsquema ex:Esquema_RIOW_Nodo1 ;
    ex:tieneComponente ex:ComponenteElectrico_RIOW_N1_Entradas, ex:ComponenteElectrico_RIOW_N1_Salidas .

ex:ComponenteElectrico_RIOW_N1_Entradas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 16 entradas digitales - RIOW Nodo 1"@es ;
    ex:textoExtracto "bloques 8DI/8DO"@es ;
    ex:identificador "I1-I16 (base O81)" .

ex:ComponenteElectrico_RIOW_N1_Salidas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 8 salidas digitales - RIOW Nodo 1"@es ;
    ex:textoExtracto "8 salidas"@es ;
    ex:identificador "O81-O88" .

ex:Esquema_RIOW_Nodo2
    a ex:Esquema ;
    rdfs:label "Esquema de módulo RIOW (Nodo 2: 8 DI / 8 DO)"@es ;
    ex:textoExtracto "módulo RIOW con 8 entradas y 8 salidas. El gráfico muestra bastidores más compactos 8DI y 8DO, con conectores y rotulación de canales, evidenciando su asignación a direcciones base no consecutivas para evitar solapamientos."@es ;
    ex:identificador "Nodo 2 (RIOW)" .

ex:Sistema_RIOW_Nodo2
    a ex:Sistema ;
    rdfs:label "Módulo RIOW (Nodo 2)"@es ;
    ex:textoExtracto "módulo RIOW con 8 entradas y 8 salidas"@es ;
    ex:detalladoEnEsquema ex:Esquema_RIOW_Nodo2 ;
    ex:tieneComponente ex:ComponenteElectrico_RIOW_N2_Entradas, ex:ComponenteElectrico_RIOW_N2_Salidas .

ex:ComponenteElectrico_RIOW_N2_Entradas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas digitales - RIOW Nodo 2"@es ;
    ex:textoExtracto "bastidores más compactos 8DI"@es .

ex:ComponenteElectrico_RIOW_N2_Salidas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 8 salidas digitales - RIOW Nodo 2"@es ;
    ex:textoExtracto "8DO"@es .

ex:Esquema_RIOR_Nodo1
    a ex:Esquema ;
    rdfs:label "Esquema de tarjeta RIOR (48 DI / 32 DO)"@es ;
    ex:textoExtracto "tarjeta RIOR con 48 entradas y 32 salidas digitales. Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)."@es ;
    ex:identificador "Nodo 1 (RIOR)" .

ex:Sistema_RIOR_Nodo1
    a ex:Sistema ;
    rdfs:label "Tarjeta RIOR (Nodo 1)"@es ;
    ex:textoExtracto "tarjeta RIOR con 48 entradas y 32 salidas digitales"@es ;
    ex:detalladoEnEsquema ex:Esquema_RIOR_Nodo1 ;
    ex:tieneComponente ex:ComponenteElectrico_RIOR_Entradas, ex:ComponenteElectrico_RIOR_Salidas .

ex:ComponenteElectrico_RIOR_Entradas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 48 entradas digitales - RIOR"@es ;
    ex:textoExtracto "único bloque lógico de 48 DI"@es ;
    ex:identificador "I1-I48" .

ex:ComponenteElectrico_RIOR_Salidas
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 32 salidas digitales - RIOR"@es ;
    ex:textoExtracto "bloque lógico de 32 DO"@es ;
    ex:identificador "O1-O32" .