@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SWTOUTPUT
    a ex:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ex:textoExtracto "Salida digital local asociada a la conmutación sincronizada. Valores posibles: De 0 a NLOCOUT (Número de salidas digitales locales). Valor por defecto: 0. Variable asociada: (V.)MPG.SWTOUTPUT" ;
    ex:valor "0" ;
    ex:identificador "MPG.SWTOUTPUT" .

ex:Parametro_SWTDELAY
    a ex:Parametro ;
    rdfs:label "SWTDELAY" ;
    ex:textoExtracto "Retardo del dispositivo asociado a la conmutación sincronizada. Valores posibles: De 0 a 100 ms. Valor por defecto: 0 ms. Variable asociada: (V.)MPG.SWTDELAY" ;
    ex:valor "0 ms" ;
    ex:identificador "MPG.SWTDELAY" .

ex:Parametro_SWTG0FEED
    a ex:Parametro ;
    rdfs:label "SWTG0FEED" ;
    ex:textoExtracto "Respetar el avance G00 durante la conmutación sincronizada. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SWTG0FEED" ;
    ex:valor "Sí" ;
    ex:identificador "MPG.SWTG0FEED" .

ex:Parametro_NLOCOUT
    a ex:Parametro ;
    rdfs:label "NLOCOUT" ;
    ex:textoExtracto "Número de salidas digitales locales. Para la conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ex:valor "8" ;
    ex:identificador "NLOCOUT" .

ex:Sistema_ConmutacionSincronizada
    a ex:Sistema ;
    rdfs:label "Sistema de conmutación sincronizada" ;
    ex:textoExtracto "Se denomina conmutación sincronizada al proceso de controlar el estado de una salida digital local del CNC en función del tipo de movimiento programado en los ejes. Las transiciones de G0 a G1/G2/G3 activan la salida digital seleccionada. Las transiciones de G1/G2/G3 a G0 desactivan la salida digital seleccionada." ;
    ex:monitoreaParametro ex:Parametro_SWTOUTPUT ;
    ex:monitoreaParametro ex:Parametro_SWTDELAY ;
    ex:monitoreaParametro ex:Parametro_SWTG0FEED ;
    ex:monitoreaParametro ex:Parametro_NLOCOUT .

ex:ComponenteElectrico_LIO1
    a ex:ComponenteElectrico ;
    rdfs:label "Salida local LI/O1" ;
    ex:textoExtracto "salidas locales asociadas a los pines LI/O1 (salida local 1)" ;
    ex:controla ex:Sistema_ConmutacionSincronizada .

ex:ComponenteElectrico_LIO2
    a ex:ComponenteElectrico ;
    rdfs:label "Salida local LI/O2" ;
    ex:textoExtracto "salidas locales asociadas a los pines LI/O2 (salida local 2)" ;
    ex:controla ex:Sistema_ConmutacionSincronizada .