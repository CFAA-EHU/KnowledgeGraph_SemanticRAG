@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Interfaz_KPA_EtherCAT_Studio
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz KPA EtherCAT Studio"@es ;
    ex:textoExtracto       "Captura de la interfaz de 'KPA EtherCAT Studio' con la vista principal de topología a la izquierda, panel de mensajes/ayuda a la derecha y bandeja del sistema mostrando el servicio 'Master (Win64)'. Se señalan zonas A, B, C para topología, ayuda y mensajes, respectivamente; incluye iconos de atajo a 'Master (Win64)', 'Studio' y utilidades de licencia."@es ;
    ex:identificador      "KPA EtherCAT Studio" .

ex:AvisoLicencia_NoLicenseFound
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Aviso: No license found"@es ;
    ex:textoExtracto       "aviso de 'No license found' al arrancar, con botón 'Browse' para seleccionar la unidad USB del dongle"@es ;
    ex:ilustradoEn         ex:Interfaz_KPA_EtherCAT_Studio .

ex:AvisoLicencia_Basica
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Advertencia de licencia Básica"@es ;
    ex:textoExtracto       "advertencia de licencia durante la detección de módulos, indicada como ignorables con la licencia 'Básica'"@es ;
    ex:ilustradoEn         ex:Interfaz_KPA_EtherCAT_Studio .

ex:Proceso_EscaneoOnline_BusEtherCAT
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Escaneo online del bus EtherCAT"@es ;
    ex:textoExtracto       "Secuencia de capturas para el escaneo online del bus: selección del adaptador Ethernet, comando contextual 'Scan configuration' sobre el máster que descubre cabeceras, y pestaña 'MDP modules' con acción 'Upload detected Module Ident list'. Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados."@es ;
    ex:documentadoEn       ex:Interfaz_KPA_EtherCAT_Studio .

ex:Sistema_BusEtherCAT
    a                     ex:Sistema ;
    rdfs:label            "Bus EtherCAT (topología configurable)"@es ;
    ex:textoExtracto       "Configurar la topología del bus"@es ;
    ex:detalladoEnEsquema  ex:Interfaz_KPA_EtherCAT_Studio .

ex:Servicio_Master_Win64
    a                     ex:Componente ;
    rdfs:label            "Master (Win64)"@es ;
    ex:textoExtracto       "bandeja del sistema mostrando el servicio 'Master (Win64)'"@es ;
    ex:compuestoPor        ex:Sistema_BusEtherCAT .