@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de topología EtherCAT (OpenPCS Remoto)" ;
    ex:textoExtracto "Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados. [...] Flechas destacan los comandos de menú contextual." ;
    ex:textoExtracto "Modo offline en dos pasos ilustrados: (1) 'Append Slave' para añadir cabeceras desde el catálogo, (2) arrastrar módulos desde 'MDP modules' (derecha) a la topología (izquierda). Flechas curvas indican el 'drag & drop' y se ven tarjetas de módulo con nombre y tipo." .

ex:InterfazUsuario_FagorEtherCATMapper
    a ex:InterfazUsuario ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ex:textoExtracto "Vista general del 'Fagor EtherCAT Mapper': captura con (A) barra de iconos y nombre del ENI cargado, (B) barra de configuración por defecto (fichas de entradas/salidas y registros), (C) validación 'Overlapped', (D) topología en árbol, y (E) topología en bloques." ;
    ex:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." .

ex:AccionProhibida_DetachMasterSinExportar
    a ex:AccionProhibida ;
    rdfs:label "Detach master sin exportar configuración" ;
    ex:textoExtracto "Procedimiento en capturas para 'Attach master' (acoplar el máster y detectar recursos por nodo) y 'Detach master' previo a exportar." .

ex:Sistema_EtherCAT
    a ex:Sistema ;
    rdfs:label "Sistema EtherCAT (topología y mapeo)" ;
    ex:textoExtracto "Configurar la topología del bus. [...] Mapear los recursos EtherCAT a recursos del PLC." ;
    ex:detalladoEnEsquema ex:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus ;
    ex:detalladoEnEsquema ex:InterfazUsuario_FagorEtherCATMapper .

ex:TareaMantenimiento_ExportarConfiguracionMaster
    a ex:TareaMantenimiento ;
    rdfs:label "Exportar configuración maestra EtherCAT" ;
    ex:textoExtracto "(Arriba) Diálogo de exportación 'Export → Export Master Configuration ETG Standard' para generar el XML de configuración." ;
    ex:documentadoEn ex:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus .

ex:TareaMantenimiento_GuardarProyectoECSN
    a ex:TareaMantenimiento ;
    rdfs:label "Guardar proyecto *.ecsn" ;
    ex:textoExtracto "(abajo) opción 'File → Save' para guardar proyecto *.ecsn. Se observan rutas de archivo, nombres propuestos y botones de confirmación." ;
    ex:documentadoEn ex:InterfazUsuario_OpenPCSRemoto_ConfiguracionTopologiaBus .