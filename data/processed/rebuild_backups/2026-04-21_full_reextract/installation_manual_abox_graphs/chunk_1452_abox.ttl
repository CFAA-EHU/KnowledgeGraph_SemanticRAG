@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_OpenPCSRemoto_EtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración EtherCAT en OpenPCS Remoto" ;
    ex:textoExtracto "barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible') y vista de árbol que despliega esclavos y módulos mostrando sus recursos; indicadores 'Starts/Offset' para numeración y opción 'Ver esclavos'." ;
    ex:ilustradoEn ex:Figura_EsquemaBloquesEtherCAT .

ex:Figura_EsquemaBloquesEtherCAT
    a ex:Figura ;
    rdfs:label "Esquema de bloques cromáticos del bus EtherCAT" ;
    ex:textoExtracto "Vista en bloques del bus con leyenda cromática: azul (entradas digitales), morado (salidas digitales), rojo/gris (mapeos a/desde registros PLC), verde/amarillo (AI/AO Fagor)." .

ex:Sistema_EtherCAT_MapeoRecursos
    a ex:Sistema ;
    rdfs:label "Sistema de mapeo de recursos EtherCAT a PLC" ;
    ex:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." ;
    ex:compuestoPor ex:ComponenteElectrico_EntradasDigitales_EtherCAT ;
    ex:compuestoPor ex:ComponenteElectrico_SalidasDigitales_EtherCAT ;
    ex:compuestoPor ex:ComponenteElectrico_RegistrosPLC_EtherCAT ;
    ex:compuestoPor ex:ComponenteElectrico_AI_AO_Fagor ;
    ex:detalladoEnEsquema ex:Figura_EsquemaBloquesEtherCAT ;
    ex:documentadoEn ex:InterfazUsuario_OpenPCSRemoto_EtherCAT .

ex:ComponenteElectrico_EntradasDigitales_EtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales (DI) EtherCAT" ;
    ex:textoExtracto "azul (entradas digitales)" ;
    ex:identificador "DI" .

ex:ComponenteElectrico_SalidasDigitales_EtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales (DO) EtherCAT" ;
    ex:textoExtracto "morado (salidas digitales)" ;
    ex:identificador "DO" .

ex:ComponenteElectrico_RegistrosPLC_EtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Registros PLC mapeados desde/ hacia EtherCAT" ;
    ex:textoExtracto "rojo/gris (mapeos a/desde registros PLC)" ;
    ex:identificador "Registros_PLC" .

ex:ComponenteElectrico_AI_AO_Fagor
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas/Salidas analógicas (AI/AO) Fagor" ;
    ex:textoExtracto "verde/amarillo (AI/AO Fagor)" ;
    ex:identificador "AI_AO_Fagor" .

ex:Parametro_Starts_EtherCAT
    a ex:Parametro ;
    rdfs:label "Parámetro 'Starts' para numeración de recursos EtherCAT" ;
    ex:textoExtracto "campos 'Starts/Offset/Visible' [...] indicadores 'Starts/Offset' para numeración" ;
    ex:valor "10"^^xsd:integer ; # Ejemplo del texto: "DI primera=10"
    ex:monitoreaParametro ex:InterfazUsuario_OpenPCSRemoto_EtherCAT .

ex:Parametro_Offset_EtherCAT
    a ex:Parametro ;
    rdfs:label "Parámetro 'Offset' para desplazamiento de recursos EtherCAT" ;
    ex:textoExtracto "campos 'Starts/Offset/Visible' [...] offset=100" ;
    ex:valor "100"^^xsd:integer ; # Ejemplo del texto: "offset=100"
    ex:monitoreaParametro ex:InterfazUsuario_OpenPCSRemoto_EtherCAT .