@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OpenPCS_InterfazConexionFagorCNCTCP
    a ex:InterfazUsuario ;
    rdfs:label "Diálogo Connections → FagorCNCTCP → Edit"@es ;
    ex:textoExtracto "Diálogo \"Connections → FagorCNCTCP → Edit\" del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a \"Settings\"."@es ;
    ex:tieneComponente ex:OpenPCS_ParametroIP ,
                       ex:OpenPCS_ParametroHost ,
                       ex:OpenPCS_ParametroPuerto ,
                       ex:OpenPCS_BotonOK ,
                       ex:OpenPCS_BotonCancel ,
                       ex:OpenPCS_AccesoSettings .

ex:OpenPCS_ParametroIP
    a ex:Parametro ;
    rdfs:label "Parámetro IP (127.0.0.1 → IP del CNC)"@es ;
    ex:textoExtracto "edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC)"@es ;
    ex:valor "127.0.0.1" .

ex:OpenPCS_ParametroHost
    a ex:Parametro ;
    rdfs:label "Parámetro Host"@es ;
    ex:textoExtracto "campos de host/puerto"@es .

ex:OpenPCS_ParametroPuerto
    a ex:Parametro ;
    rdfs:label "Parámetro Puerto"@es ;
    ex:textoExtracto "campos de host/puerto"@es .

ex:OpenPCS_BotonOK
    a ex:Componente ;
    rdfs:label "Botón OK"@es ;
    ex:textoExtracto "botones \"OK/Cancel\""@es .

ex:OpenPCS_BotonCancel
    a ex:Componente ;
    rdfs:label "Botón Cancel"@es ;
    ex:textoExtracto "botones \"OK/Cancel\""@es .

ex:OpenPCS_AccesoSettings
    a ex:Componente ;
    rdfs:label "Acceso a Settings"@es ;
    ex:textoExtracto "Se destaca el acceso a \"Settings\""@es .

ex:OpenPCS_InterfazSettings
    a ex:InterfazUsuario ;
    rdfs:label "Diálogo Settings de conexión FagorCNCTCP"@es ;
    ex:textoExtracto "Diálogo \"Settings\" de la conexión mostrando edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC); campos de host/puerto y botones \"OK/Cancel\"."@es ;
    ex:tieneComponente ex:OpenPCS_ParametroIP ,
                       ex:OpenPCS_ParametroHost ,
                       ex:OpenPCS_ParametroPuerto ,
                       ex:OpenPCS_BotonOK ,
                       ex:OpenPCS_BotonCancel .