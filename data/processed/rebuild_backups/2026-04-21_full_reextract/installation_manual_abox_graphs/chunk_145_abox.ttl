@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SWTG0FEED
    a ex:Parametro ;
    rdfs:label "SWTG0FEED" ;
    ex:identificador "SWTG0FEED" ;
    ex:textoExtracto "SWTG0FEED | Significado. [...] Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)."@es ;
    ex:valor "Sí/No" .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)."@es .

ex:ModoOperacion_AvanceRapido
    a ex:ModoOperacion ;
    rdfs:label "Avance rápido (G0)" ;
    ex:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)."@es ;
    ex:controla ex:Parametro_G00FEED ;
    ex:habilitadoPor ex:Parametro_SWTG0FEED .

ex:ModoOperacion_AvanceConstante
    a ex:ModoOperacion ;
    rdfs:label "Avance constante (G1/G2/G3)" ;
    ex:textoExtracto "El corte se ejecuta a avance constante (con el avance del G1/G2/G3 anterior), sin acelerar en los tramos en G0."@es ;
    ex:mitigaRiesgo [
        a ex:AvisoSeguridad ;
        rdfs:label "Riesgo de excitación de frecuencias de la máquina" ;
        ex:textoExtracto "Esta opción permite evitar posibles problemas de excitación de frecuencias de la máquina, obteniendo mejor calidad del corte, tanto en precisión como superficial."@es
    ] .

ex:InterfazUsuario_ComandoSWTOUT
    a ex:InterfazUsuario ;
    rdfs:label "#SWTOUT" ;
    ex:identificador "#SWTOUT" ;
    ex:textoExtracto "Desde el programa pieza se puede modificar este comportamiento con la sentencia #SWTOUT."@es ;
    ex:controla ex:ModoOperacion_AvanceRapido, ex:ModoOperacion_AvanceConstante .