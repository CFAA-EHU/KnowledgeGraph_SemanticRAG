@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Parametros_GAPCONTROL a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros GAPCONTROL"@es ;
    ex:textoExtracto "GAPCONTROL Tabla de parámetros del control del gap. Este parámetro muestra la tabla para definir el control del gap."@es ;
    ex:detalladoEnEsquema ex:Sistema_ControlGap .

ex:Sistema_ControlGap
    a ex:Sistema ;
    rdfs:label "Sistema de control del gap"@es ;
    ex:textoExtracto "Sistema para definir y gestionar parámetros de control del gap en el proceso."@es ;
    ex:tieneComponente ex:Sensor_Gap ;
    ex:monitoreaParametro ex:Param_GAPANAINTYPE ,
                        ex:Param_GAPANAINID ,
                        ex:Param_GAPDISTLIMIT ,
                        ex:Param_GAPVOLTLIMIT ,
                        ex:Param_GAPSENSOROFFSET ,
                        ex:Param_GAPSENSORCH ,
                        ex:Param_GAPGAIN ,
                        ex:Param_GAPAPPROACHDYN ,
                        ex:Param_GAPSENSORFILTER ,
                        ex:Param_GAPERRORCANCEL ,
                        ex:Param_GAPMIN ,
                        ex:Param_GAPMAX ,
                        ex:Param_GAPTOLCANCEL ,
                        ex:Param_GAPTOL ,
                        ex:Param_GAPCOLLISIONMODE ,
                        ex:Param_GAPTONEG .

ex:Sensor_Gap
    a ex:Sensor ;
    rdfs:label "Sensor de gap"@es ;
    ex:textoExtracto "Sensor conectado a entradas analógicas para medición y control del gap."@es ;
    ex:identificador "GAPSENSOR" ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPANAINTYPE
    a ex:Parametro ;
    rdfs:label "GAPANAINTYPE" ;
    ex:identificador "GAPANAINTYPE" ;
    ex:textoExtracto "Tipo de entrada analógica conectada al sensor. Valores posibles: Remoto CAN / Regulador / Captación / EtherCAT. Valor por defecto: Regulador."@es ;
    ex:valor "Regulador" ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPANAINID
    a ex:Parametro ;
    rdfs:label "GAPANAINID" ;
    ex:identificador "GAPANAINID" ;
    ex:textoExtracto "Número de entrada analógica conectada al sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPDISTLIMIT
    a ex:Parametro ;
    rdfs:label "GAPDISTLIMIT" ;
    ex:identificador "GAPDISTLIMIT" ;
    ex:textoExtracto "Distancia que corresponde a la señal analógica límite del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPVOLTLIMIT
    a ex:Parametro ;
    rdfs:label "GAPVOLTLIMIT" ;
    ex:identificador "GAPVOLTLIMIT" ;
    ex:textoExtracto "Voltaje que corresponde al recorrido límite del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPSENSOROFFSET
    a ex:Parametro ;
    rdfs:label "GAPSENSOROFFSET" ;
    ex:identificador "GAPSENSOROFFSET" ;
    ex:textoExtracto "Offset a aplicar al sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPSENSORCH
    a ex:Parametro ;
    rdfs:label "GAPSENSORCH" ;
    ex:identificador "GAPSENSORCH" ;
    ex:textoExtracto "Cambiar el signo de la señal del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPGAIN
    a ex:Parametro ;
    rdfs:label "GAPGAIN" ;
    ex:identificador "GAPGAIN" ;
    ex:textoExtracto "Ganancia proporcional a aplicar en GAPCTRL."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPAPPROACHDYN
    a ex:Parametro ;
    rdfs:label "GAPAPPROACHDYN" ;
    ex:identificador "GAPAPPROACHDYN" ;
    ex:textoExtracto "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPSENSORFILTER
    a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:identificador "GAPSENSORFILTER" ;
    ex:textoExtracto "Tabla para configurar el filtro del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPERRORCANCEL
    a ex:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ex:identificador "GAPERRORCANCEL" ;
    ex:textoExtracto "Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPMIN
    a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:identificador "GAPMIN" ;
    ex:textoExtracto "Límite mínimo del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPMAX
    a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:identificador "GAPMAX" ;
    ex:textoExtracto "Límite máximo del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPTOLCANCEL
    a ex:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ex:identificador "GAPTOLCANCEL" ;
    ex:textoExtracto "Anular el error de gap fuera del rango definido por GAPTOL."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPTOL
    a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:identificador "GAPTOL" ;
    ex:textoExtracto "Margen de tolerancia del error."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPCOLLISIONMODE
    a ex:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ex:identificador "GAPCOLLISIONMODE" ;
    ex:textoExtracto "Comportamiento del CNC ante una colisión del sensor."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .

ex:Param_GAPTONEG
    a ex:Parametro ;
    rdfs:label "GAPTONEG" ;
    ex:identificador "GAPTONEG" ;
    ex:textoExtracto "Bloque de movimiento en #GAPCTRL hacia cota descendente."@es ;
    ex:documentadoEn ex:Tabla_Parametros_GAPCONTROL .