@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPG_GAPAPPROACHDYN
    a ex:Parametro ;
    rdfs:label "MPG.GAPAPPROACHDYN" ;
    ex:identificador "V.MPG.GAPAPPROACHDYN" ;
    ex:valor "80%" ;
    ex:textoExtracto "Valor por defecto: 80 %. Variable asociada: (V.)MPG.GAPAPPROACHDYN. Este parámetro reduce, en el porcentaje definido, el valor de GAPGAIN del eje del sensor durante la aproximación a la chapa." .

ex:Parametro_GAPSENSORFILTER
    a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:identificador "GAPSENSORFILTER" ;
    ex:textoExtracto "Tabla para configurar el filtro del sensor. Este parámetro muestra la tabla para configurar el filtro del sensor." .

ex:Sensor_Gap
    a ex:Sensor ;
    ex:textoExtracto "valor de GAPGAIN del eje del sensor durante la aproximación a la chapa" ;
    ex:monitoreaParametro ex:Parametro_MPG_GAPAPPROACHDYN ;
    ex:monitoreaParametro ex:Parametro_GAPSENSORFILTER .