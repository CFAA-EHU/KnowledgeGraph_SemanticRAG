@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GAPTOL
    a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:identificador "MPG.GAPTOL" ;
    ex:valor "0.1000" ;
    ex:textoExtracto "GAPTOL Margen de tolerancia del error. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 0.1000 mm / 0.00394 inch." .

ex:Parametro_GAPTOLCANCEL
    a ex:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ex:textoExtracto "El comportamiento del CNC depende del parámetro GAPTOLCANCEL." ;
    ex:textoExtracto "Sí. El CNC anula el error de gap fuera de tolerancia y no detiene el movimiento de los ejes. / No. El CNC da error de gap fuera de tolerancia y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa." .

ex:Parametro_GAPCOLLISIONMODE
    a ex:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ex:identificador "MPG.GAPCOLLISIONMODE" ;
    ex:valor "No mostrar error" ;
    ex:textoExtracto "GAPCOLLISIONMODE Comportamiento del CNC ante una colisión del sensor. Valores posibles: No mostrar error / Mostrar error. Valor por defecto: No dar error." .

ex:Parametro_GAPTONEG
    a ex:Parametro ;
    rdfs:label "GAPTONEG" ;
    ex:identificador "MPG.GAPTONEG" ;
    ex:valor "Sí" ;
    ex:textoExtracto "GAPTONEG Bloque de movimiento en #GAPCTRL hacia cota descendente. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:textoExtracto "Sí. El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales)." .

ex:Sensor_ControlGap
    a ex:Sensor ;
    rdfs:label "Sensor de control del gap" ;
    ex:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION." .

ex:Tabla_ParametrosGap a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de control del gap" ;
    ex:textoExtracto "Tabla con valores y significados de GAPTOL, GAPTOLCANCEL, GAPCOLLISIONMODE y GAPTONEG en el control del gap." ;
    ex:documentadoEn ex:Manual_Operacion .

ex:Tabla_ParametrosGap a ex:Tabla ;
    ex:detalladoEnEsquema ex:Parametro_GAPTOL ;
    ex:detalladoEnEsquema ex:Parametro_GAPTOLCANCEL ;
    ex:detalladoEnEsquema ex:Parametro_GAPCOLLISIONMODE ;
    ex:detalladoEnEsquema ex:Parametro_GAPTONEG .

ex:Sensor_ControlGap
    ex:monitoreaParametro ex:Parametro_GAPTOL .