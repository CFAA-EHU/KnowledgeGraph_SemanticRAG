@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Leapfrog a ex:ModoOperacion ;
    rdfs:label "Leapfrog" ;
    ex:textoExtracto "Respuesta dinámica del salto durante el leapfrog. [...] Suavizar el movimiento va a hacer que aumente el tiempo de mecanizado cuando hay leapfrogs." .

ex:Parametro_LEAPDYNOVR a ex:Parametro ;
    rdfs:label "LEAPDYNOVR" ;
    ex:identificador "MPG.LEAPDYNOVR" ;
    ex:valor "100" ;
    ex:textoExtracto "LEAPDYNOVR Respuesta dinámica del salto durante el leapfrog. Valores posibles: De 10 a 100000 %. Valor por defecto: 100 %." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Parametro_ACCEL a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Parametro_DECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Parametro_ACCJERK a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración. [...] Cuanto menor sea el valor asignado a estos parámetros, la respuesta de la máquina será más suave pero aumentará el tiempo de aceleración / deceleración." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Parametro_DECJERK a ex:Parametro ;
    rdfs:label "DECJERK" ;
    ex:textoExtracto "Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración. [...] Cuanto menor sea el valor asignado a estos parámetros, la respuesta de la máquina será más suave pero aumentará el tiempo de aceleración / deceleración." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Parametro_SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Tipo de aceleración por defecto; lineal, trapezoidal y seno cuadrado (square sine)." ;
    ex:monitoreaParametro ex:Leapfrog .

ex:Tabla_ParametrosLeapfrog a ex:Tabla ;
    rdfs:label "Tabla de parámetros de leapfrog" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | SLOPETYPE | Tipo de aceleración por defecto; lineal, trapezoidal y seno cuadrado (square sine). | ACCEL/DECEL | Aceleración y deceleración. [...] | ACCJERK/DECJERK | Jerk de aceleración y deceleración. [...] |" ;
    ex:documentadoEn ex:Leapfrog .

ex:Parametro_ACCEL ex:detalladoEnEsquema ex:Tabla_ParametrosLeapfrog .
ex:Parametro_DECEL ex:detalladoEnEsquema ex:Tabla_ParametrosLeapfrog .
ex:Parametro_ACCJERK ex:detalladoEnEsquema ex:Tabla_ParametrosLeapfrog .
ex:Parametro_DECJERK ex:detalladoEnEsquema ex:Tabla_ParametrosLeapfrog .
ex:Parametro_SLOPETYPE ex:detalladoEnEsquema ex:Tabla_ParametrosLeapfrog .