@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_LASERFOLLOW a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros LASERFOLLOW"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW."@es ;
    ex:identificador "LASERFOLLOW" .

ex:Parametro_LASERFOLLOWAXIS
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWAXIS" ;
    ex:textoExtracto "LASERFOLLOWAXIS Eje esclavo al que se aplica el FOLLOW. Valores posibles: X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: 0 (no hay compensación). Variable asociada: (V.)MPG.LASERFOLLOW"@es ;
    ex:valor "X, X1...X9, C, C1...C9" ;
    ex:documentadoEn ex:Tabla_LASERFOLLOW ;
    ex:identificador "(V.)MPG.LASERFOLLOW" .

ex:Parametro_LASERFOLLOWOFFSET
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWOFFSET" ;
    ex:textoExtracto "LASERFOLLOWOFFSET Offset del origen del triedro respecto del eje esclavo. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)MPG.LASERFOLLOWOFFSET"@es ;
    ex:valor "±99999.9999 mm / ±3937.00787 inch" ;
    ex:documentadoEn ex:Tabla_LASERFOLLOW ;
    ex:identificador "(V.)MPG.LASERFOLLOWOFFSET" .

ex:Parametro_LASERFOLLOW1
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW1" ;
    ex:textoExtracto "LASERFOLLOW1 Efecto del primer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta. Variable asociada: (V.)MPG.LASERFOLLOW1"@es ;
    ex:valor "No afecta / Positivo / Negativo" ;
    ex:documentadoEn ex:Tabla_LASERFOLLOW ;
    ex:identificador "(V.)MPG.LASERFOLLOW1" .

ex:Parametro_LASERFOLLOW2
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW2" ;
    ex:textoExtracto "LASERFOLLOW2 Efecto del segundo eje del triedro sobre el eje esclavo."@es ;
    ex:documentadoEn ex:Tabla_LASERFOLLOW .