@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LASERFOLLOW2
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW2" ;
    ex:identificador "LASERFOLLOW2" ;
    ex:textoExtracto "LASERFOLLOW2 Efecto del segundo eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta." ;
    ex:valor "No afecta" .

ex:Parametro_LASERFOLLOW3
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW3" ;
    ex:identificador "LASERFOLLOW3" ;
    ex:textoExtracto "LASERFOLLOW3 Efecto del tercer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta." ;
    ex:valor "No afecta" .

ex:Tabla_LASERFOLLOW a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros LASERFOLLOW" ;
    ex:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW." ;
    ex:tieneComponente ex:Parametro_LASERFOLLOW2 ;
    ex:tieneComponente ex:Parametro_LASERFOLLOW3 .