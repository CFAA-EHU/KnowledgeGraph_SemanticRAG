@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NKEYBD
    a ex:Parametro ;
    rdfs:label "NKEYBD" ;
    ex:textoExtracto "NKEYBD Número de paneles de jog. Valores posibles: De 1 a 8. Valor por defecto: 1." ;
    ex:valor "1-8" ;
    ex:identificador "V.MPG.NKEYBD" .

ex:Parametro_KEYBDCH
    a ex:Parametro ;
    rdfs:label "KEYBDCH" ;
    ex:textoExtracto "KEYBDCH Lista de paneles de jog del sistema. Este parámetro muestra la tabla para asignar los paneles de jog a los canales." ;
    ex:identificador "V.MPG.KEYBDCH" .

ex:Tabla_AsignacionPanelesJog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla KEYBDCH" ;
    ex:textoExtracto "KEYBDCH | Canal asignado\nKEYBDnCH | Canal al que está asignado el panel de jog (CH1/CH2/CH3/CH4 o Canal activo)." ;
    ex:detalladoEnEsquema ex:Parametro_KEYBDCH .

ex:Parametro_KEYBDnCH
    a ex:Parametro ;
    rdfs:label "KEYBDnCH" ;
    ex:textoExtracto "KEYBDnCH Canal al que está asignado el panel de jog. Valores posibles: Canal activo / CH1 / CH2 / CH3 / CH4. Valor por defecto: Canal activo." ;
    ex:valor "CH1, CH2, CH3, CH4, Canal activo" ;
    ex:identificador "V.MPG.KEYBDCH[jog]" ;
    ex:documentadoEn ex:Tabla_AsignacionPanelesJog .

ex:Sistema_BusCAN
    a ex:Sistema ;
    rdfs:label "Bus CAN (conmutador Address)" ;
    ex:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address). El primer panel de jog será el de numeración más baja y así sucesivamente." .

ex:InterfazUsuario_PanelJog
    a ex:InterfazUsuario ;
    rdfs:label "Panel de jog" ;
    ex:textoExtracto "Panel de mando (jog) conectado al bus CAN, asignable a canales (CH1-CH4) o al canal activo. Operativo incluso si el canal asignado no es el activo." ;
    ex:compuestoPor ex:Sistema_BusCAN .