@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PLCTYPE
    a ex:Parametro ;
    rdfs:label "PLCTYPE" ;
    ex:identificador "MPG.PLCTYPE" ;
    ex:textoExtracto "PLCTYPE Tipo de PLC. Valores posibles: IEC / IEC+Fagor / Fagor. Valor por defecto: IEC. Variable asociada: (V.)MPG.PLCTYPE" ;
    ex:valor "IEC" .

ex:Tabla_ComportamientoPLC a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "La siguiente tabla muestra a quién afecta el arranque (RUN) y la parada (STOP) del PLC en función de este parámetro, así como el estado de la marca PLCREADY." .