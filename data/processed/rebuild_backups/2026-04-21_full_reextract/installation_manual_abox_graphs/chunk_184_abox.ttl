@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CHNSPDL
    a ex:Parametro ;
    rdfs:label "CHNSPDL" ;
    ex:identificador "CHNSPDL" ;
    ex:textoExtracto "CHNSPDL Número de cabezales del canal. Valores posibles: De 0 a 4. Valor por defecto: 1. Este parámetro establece el número de cabezales del canal, estén servocontrolados o no." ;
    ex:valor "0-4"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_CHSPDLNAME
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME" ;
    ex:identificador "CHSPDLNAME" ;
    ex:textoExtracto "CHSPDLNAME Lista de cabezales del canal. Este parámetro muestra la tabla para definir los nombres de los cabezales. El número de cabezales del canal lo establece el parámetro CHNSPDL." .

ex:Tabla_CHSPDLNAME a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de nombres de cabezales (CHSPDLNAME)" ;
    ex:textoExtracto "| CHSPDLNAME |  | --- | --- | CHSPDLNAME n | Nombre de los cabezales. |" ;
    ex:documentadoEn ex:Parametro_CHSPDLNAME .

ex:Parametro_SPDLNAME
    a ex:Parametro ;
    rdfs:label "SPDLNAME" ;
    ex:identificador "SPDLNAME" ;
    ex:textoExtracto "CHSPDLNAME n Nombre de los cabezales. Valores posibles: Cualquier cabezal definido en SPDLNAME." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "La suma de los cabezales asignados a los canales tampoco podrá superar el número de cabezales del sistema, definido en el parámetro NSPDL." ;
    ex:tieneComponente ex:Parametro_NSPDL .

ex:Parametro_NSPDL
    a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:identificador "NSPDL" ;
    ex:textoExtracto "número de cabezales del sistema, definido en el parámetro NSPDL" .