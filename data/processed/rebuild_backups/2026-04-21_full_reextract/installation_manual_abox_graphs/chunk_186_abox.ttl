@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionCabezalesCanal a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de cabezales del canal"@es ;
    ex:textoExtracto "CHSPDLNAME | Índice en el canal. --- CHSPDLNAME 1 | Índice ꞏ1ꞏ. CHSPDLNAME 2 | Índice ꞏ2ꞏ. CHSPDLNAME 3 | Índice ꞏ3ꞏ."@es ;
    ex:identificador "Tabla_2.4.3_ConfiguracionCabezales" .

ex:Parametro_CHSPDLNAME_1
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME 1" ;
    ex:textoExtracto "CHSPDLNAME 1 | Índice ꞏ1ꞏ."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_ConfiguracionCabezalesCanal .

ex:Parametro_CHSPDLNAME_2
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME 2" ;
    ex:textoExtracto "CHSPDLNAME 2 | Índice ꞏ2ꞏ."@es ;
    ex:valor "2" ;
    ex:documentadoEn ex:Tabla_ConfiguracionCabezalesCanal .

ex:Parametro_CHSPDLNAME_3
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME 3" ;
    ex:textoExtracto "CHSPDLNAME 3 | Índice ꞏ3ꞏ."@es ;
    ex:valor "3" ;
    ex:documentadoEn ex:Tabla_ConfiguracionCabezalesCanal .