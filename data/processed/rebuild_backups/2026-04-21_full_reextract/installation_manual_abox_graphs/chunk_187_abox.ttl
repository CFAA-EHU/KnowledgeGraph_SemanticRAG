@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CAXNAME
    a ex:Parametro ;
    rdfs:label "CAXNAME" ;
    ex:textoExtracto "CAXNAME Nombre por defecto del eje C. Valores posibles: Cualquier nombre de eje válido; X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: C." ;
    ex:valor "C" ;
    ex:identificador "MPG.CAXNAME" .

ex:Parametro_ALIGNC
    a ex:Parametro ;
    rdfs:label "ALIGNC" ;
    ex:textoExtracto "ALIGNC Alineamiento del eje C para mecanizado diametral. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:identificador "MPG.ALIGNC" .

ex:Tabla_Significado_ALIGNC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Significado de ALIGNC" ;
    ex:textoExtracto "| ALIGNC | Significado. | --- | --- | Sí. | (1)Mecanizado hasta el centro. (2)Girar 180° el eje C. (3)Continuar el mecanizado retrocediendo la herramienta. | No. | " ;
    ex:ilustradoEn ex:Parametro_ALIGNC .