@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosHSC a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros del modo HSC"@es ;
    ex:textoExtracto "HSC Tabla de parámetros del modo HSC. Este parámetro muestra la tabla para definir el modo HSC de trabajo."@es ;
    ex:identificador "HSC" .

ex:ModoHSC
    a               ex:ModoOperacion ;
    rdfs:label      "Modo HSC"@es ;
    ex:textoExtracto "modo HSC de trabajo"@es ;
    ex:identificador "HSC" ;
    ex:documentadoEn ex:TablaParametrosHSC .