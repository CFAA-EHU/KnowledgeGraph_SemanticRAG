@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FTIMELIM
    a ex:Parametro ;
    rdfs:label "FTIMELIM" ;
    ex:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." ;
    ex:valor "0" , "200%" , "300%" ;
    ex:monitoreaParametro ex:ModoOperacion_HSC .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC (canal)" ;
    ex:textoExtracto "Configuración del modo HSC (canal)." .