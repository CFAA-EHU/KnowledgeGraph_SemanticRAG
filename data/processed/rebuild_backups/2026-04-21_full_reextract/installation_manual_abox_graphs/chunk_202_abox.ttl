@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_2.4.8_CondicionesPorDefecto_Canal
    a               ex:Figura ;
    rdfs:label      "Gráficas de velocidad, aceleración y jerk por tipo de perfil"@es ;
    ex:textoExtracto "La siguiente figura muestra, para cada uno de los casos, las gráficas de velocidad (v), aceleración (a) y jerk (j)."@es ;
    ex:ilustradoEn   ex:Pagina_124 .

ex:Parametro_Velocidad
    a               ex:Parametro ;
    rdfs:label      "Velocidad (v)"@es ;
    ex:textoExtracto "gráficas de velocidad (v)"@es ;
    ex:monitoreaParametro ex:Figura_2.4.8_CondicionesPorDefecto_Canal .

ex:Parametro_Aceleracion
    a               ex:Parametro ;
    rdfs:label      "Aceleración (a)"@es ;
    ex:textoExtracto "gráficas de [...] aceleración (a)"@es ;
    ex:monitoreaParametro ex:Figura_2.4.8_CondicionesPorDefecto_Canal .

ex:Parametro_Jerk
    a               ex:Parametro ;
    rdfs:label      "Jerk (j)"@es ;
    ex:textoExtracto "gráficas de [...] jerk (j)"@es ;
    ex:monitoreaParametro ex:Figura_2.4.8_CondicionesPorDefecto_Canal .

ex:ModoOperacion_LinealTrapezoidal
    a               ex:ModoOperacion ;
    rdfs:label      "Perfil lineal trapezoidal"@es ;
    ex:textoExtracto "Los desplazamientos más rápidos se consiguen con la aceleración lineal"@es ;
    ex:ilustradoEn   ex:Figura_2.4.8_CondicionesPorDefecto_Canal .

ex:ModoOperacion_SenoCuadrado
    a               ex:ModoOperacion ;
    rdfs:label      "Perfil seno cuadrado"@es ;
    ex:textoExtracto "los más lentos con la seno cuadrado"@es ;
    ex:ilustradoEn   ex:Figura_2.4.8_CondicionesPorDefecto_Canal .