@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G0MODAL
    a ex:Parametro ;
    rdfs:label "G0MODAL" ;
    ex:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63. [...] La función G00 no es modal; hay que programarla en cada bloque de avance rápido." ;
    ex:valor "Sí/No" .

ex:Parametro_IMOVE
    a ex:Parametro ;
    rdfs:label "IMOVE" ;
    ex:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No." ;
    ex:valor "G0/G1" .

ex:Parametro_G2G3MODAL
    a ex:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ex:textoExtracto "G2G3MODAL: La programación en G2/G3 se mantiene modal. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí/No" .

ex:ModoOperacion_G00
    a ex:ModoOperacion ;
    rdfs:label "G00 (Avance rápido)" ;
    ex:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." ;
    ex:controla ex:Parametro_G0MODAL .

ex:ModoOperacion_G01
    a ex:ModoOperacion ;
    rdfs:label "G01 (Interpolación lineal)" ;
    ex:textoExtracto "G1 se mantiene modal. En el ámbito de influencia de un ciclo fijo se mantendrá activa la última G programada." .

ex:ModoOperacion_G02_G03
    a ex:ModoOperacion ;
    rdfs:label "G02/G03 (Interpolación circular)" ;
    ex:textoExtracto "G2G3MODAL: La programación en G2/G3 se mantiene modal." ;
    ex:controla ex:Parametro_G2G3MODAL .

ex:Pagina_126
    a ex:Pagina ;
    ex:identificador "126" ;
    ex:textoExtracto "Ver 'IMOVE Tipo de movimiento (G0/G1) por defecto.' en la página 126." .

ex:Parametro_IMOVE
    ex:documentadoEn ex:Pagina_126 .