@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ICORNER
    a ex:Parametro ;
    rdfs:label "ICORNER (Tipo de arista)" ;
    ex:identificador "(V.)[ch].MPG.ICORNER" ;
    ex:textoExtracto "ICORNER Tipo de arista (G5/G7/G50) por defecto. Valores posibles: G50 / G5 / G7. Valor por defecto: G50. Variable asociada: (V.)[ch].MPG.ICORNER Este parámetro indica el tipo de arista que asume el CNC por defecto. Se dispone de tres tipos de aristas a saber, arista viva (G7), arista matada (G5) y arista semimatada (G50)." ;
    ex:valor "G50" .

ex:Parametro_ROUNDTYPE
    a ex:Parametro ;
    rdfs:label "ROUNDTYPE (Tipo de redondeo en G5)" ;
    ex:identificador "(V.)[ch].MPG.ROUNDTYPE" ;
    ex:textoExtracto "ROUNDTYPE Tipo de redondeo en G5 por defecto. Valores posibles: Error cordal / %Avance. Valor por defecto: Error cordal. Variable asociada: (V.)[ch].MPG.ROUNDTYPE Este parámetro indica el tipo de redondeo que se aplica por defecto cuando se trabaja en arista matada." ;
    ex:valor "Error cordal" .

ex:Parametro_MAXROUND
    a ex:Parametro ;
    rdfs:label "MAXROUND (Máximo error de redondeo en G5)" ;
    ex:textoExtracto "MAXROUND Máximo error de redondeo en G5." .

ex:ModoOperacion_G5
    a ex:ModoOperacion ;
    rdfs:label "G5 (Arista matada)" ;
    ex:textoExtracto "arista matada (G5)" ;
    ex:monitoreaParametro ex:Parametro_ROUNDTYPE ;
    ex:monitoreaParametro ex:Parametro_MAXROUND .

ex:ModoOperacion_G7
    a ex:ModoOperacion ;
    rdfs:label "G7 (Arista viva)" ;
    ex:textoExtracto "arista viva (G7)" .

ex:ModoOperacion_G50
    a ex:ModoOperacion ;
    rdfs:label "G50 (Arista semimatada)" ;
    ex:textoExtracto "arista semimatada (G50)" .

ex:Parametro_INPOSW
    a ex:Parametro ;
    rdfs:label "INPOSW (Banda de muerte)" ;
    ex:textoExtracto "Cuando se trabaja en arista viva, el CNC comienza la ejecución del siguiente desplazamiento cuando el eje entra en la banda de muerte, definida en el parámetro INPOSW." .