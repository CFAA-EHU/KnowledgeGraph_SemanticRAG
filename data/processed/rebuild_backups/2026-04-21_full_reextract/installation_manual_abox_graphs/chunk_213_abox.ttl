@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXROUND
    a               ex:Parametro ;
    rdfs:label      "MAXROUND" ;
    ex:identificador "MAXROUND" ;
    ex:valor        "0.1000 mm / 0.00394 inch" ;
    ex:textoExtracto "MAXROUND Máximo error de redondeo en G5. Valores posibles: De 0.02 a 99999.9999 mm o grados / de 0.00079 a 3937.00787 inch. Valor por defecto: 0.1000 mm o grados / 0.00394 inch." .

ex:Parametro_ROUNDFEED
    a               ex:Parametro ;
    rdfs:label      "ROUNDFEED" ;
    ex:identificador "ROUNDFEED" ;
    ex:textoExtracto "avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado. Dependiendo de la opción seleccionada, habrá que definir el parámetro MAXROUND o ROUNDFEED." .

ex:Variable_MPG_MAXROUND
    a               ex:Parametro ;
    rdfs:label      "(V.)[ch].MPG.MAXROUND" ;
    ex:identificador "(V.)[ch].MPG.MAXROUND" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.MAXROUND. Este parámetro define la desviación máxima permitida entre el punto programado y el perfil resultante del matado de arista." .