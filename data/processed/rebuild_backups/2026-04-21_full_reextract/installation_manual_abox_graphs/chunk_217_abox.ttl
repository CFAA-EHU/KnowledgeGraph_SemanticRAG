@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_FeedOverride_217 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de comportamiento del feed override (FEEDND)"@es ;
    ex:textoExtracto """
| FEEDND | Significado. |
| --- | --- |
| Sí. | El avance programado será la resultante de componer los movimientos sobre
todos los ejes del canal. |
| No. | Si alguno de los ejes principales tiene desplazamiento programado, el avance
programado será la resultante de componer el movimiento sólo sobre estos ejes. El resto de los ejes se desplazan al avance que les corresponda para terminar
el movimiento todos a los vez. Sólo se limita el avance programado si algún eje pudiera sobrepasar su
MAXFEED. Si no están programados ninguno de los ejes principales, el avance
programado se alcanzará en aquel eje que más movimiento realiza, terminando
todos a la vez."""@es ;
    ex:documentadoEn ex:Pagina_132 ;
    ex:ilustradoEn ex:Manual_Tecnico .

ex:Parametro_FEEDND
    a ex:Parametro ;
    rdfs:label "FEEDND" ;
    ex:identificador "FEEDND" ;
    ex:textoExtracto "Parámetro que determina si el avance programado considera todos los ejes o solo los principales."@es ;
    ex:documentadoEn ex:Tabla_FeedOverride_217 .

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "Límite máximo de avance programado por eje."@es ;
    ex:monitoreaParametro ex:Parametro_FEEDND ;
    ex:documentadoEn ex:Tabla_FeedOverride_217 .