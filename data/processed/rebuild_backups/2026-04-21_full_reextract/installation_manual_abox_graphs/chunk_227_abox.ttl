@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CUTTINGON
    a ex:Parametro ;
    rdfs:label "Parámetro CUTTINGON" ;
    ex:identificador "(V.)[ch].MPG.CUTTINGON" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON. Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGON. Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Cuttingon.fst)." ;
    ex:valor "Cuttingon.fst" .

ex:Parametro_CUTTINGOFF
    a ex:Parametro ;
    rdfs:label "Parámetro CUTTINGOFF" ;
    ex:identificador "(V.)[ch].MPG.CUTTINGOFF" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGOFF. Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGOFF. Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Cuttingoff.fst)." ;
    ex:valor "Cuttingoff.fst" .

ex:Parametro_FINALSUB
    a ex:Parametro ;
    rdfs:label "Parámetro FINALSUB" ;
    ex:identificador "(V.)[ch].MPG.FINALSUB" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.FINALSUB. Este parámetro indica el nombre de la subrutina asociada a la sentencia #FINALSUB. Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada." .

ex:Parametro_OEMSUB_G18x
    a ex:Parametro ;
    rdfs:label "Parámetro OEMSUB (G180-G189)" ;
    ex:identificador "(V.)[ch].MPG.OEMSUB" ;
    ex:textoExtracto "Subrutinas asociadas a las funciones G180 a G189. Valores posibles: Cualquier texto de hasta 64 caracteres." .

ex:ModoOperacion_Cutting
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación CUTTING" ;
    ex:textoExtracto "Al comienzo de la subrutina Cuttingon.fst (o cuando el OEM lo considere necesario), el OEM debe activar la marca CUTTING (asignarle valor 1) para indicar al PLC que empieza la operación de cutting. [...] Al final de la subrutina Cuttingoff.fst (o cuando el OEM lo considere necesario), el OEM debe desactivar la marca CUTTING (asignarle valor 0) para indicar al CNC que ha finalizado la operación de cutting." ;
    ex:monitoreaParametro ex:Parametro_CUTTINGON ;
    ex:monitoreaParametro ex:Parametro_CUTTINGOFF .