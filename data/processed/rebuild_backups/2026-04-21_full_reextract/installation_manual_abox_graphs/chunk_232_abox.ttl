@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PROBEDATA
    a ex:Parametro ;
    rdfs:label "PROBEDATA" ;
    ex:textoExtracto "PROBEDATA Parámetros del palpador relativos al canal. Este parámetro muestra la tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal, según el parámetro CHAXISNAME." ;
    ex:monitoreaParametro ex:Tabla_PosicionPalpador .

ex:Tabla_PosicionPalpador a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de posición del palpador de sobremesa" ;
    ex:textoExtracto "La tabla dispone de los siguientes parámetros para su configuración." ;
    ex:documentadoEn ex:Manual_Seccion2_4_15 .