@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_PROBEDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla PROBEDATA" ;
    ex:textoExtracto "| PROBEDATA |  | | --- | --- | | PRB1MAX | Cota máxima del palpador (primer eje del canal). | | PRB1MIN | Cota mínima del palpador (primer eje del canal). | | PRB2MAX | Cota máxima del palpador (segundo eje del canal). | | PRB2MIN | Cota mínima del palpador (segundo eje del canal). | | PRB3MAX | Cota máxima del palpador (tercer eje del canal). | | PRB3MIN | Cota mínima del palpador (tercer eje del canal)." .

ex:Parametro_PRB1MAX
    a ex:Parametro ;
    rdfs:label "PRB1MAX" ;
    ex:identificador "PRB1MAX" ;
    ex:textoExtracto "Cota máxima del palpador (primer eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .

ex:Parametro_PRB1MIN
    a ex:Parametro ;
    rdfs:label "PRB1MIN" ;
    ex:identificador "PRB1MIN" ;
    ex:textoExtracto "Cota mínima del palpador (primer eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .

ex:Parametro_PRB2MAX
    a ex:Parametro ;
    rdfs:label "PRB2MAX" ;
    ex:identificador "PRB2MAX" ;
    ex:textoExtracto "Cota máxima del palpador (segundo eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .

ex:Parametro_PRB2MIN
    a ex:Parametro ;
    rdfs:label "PRB2MIN" ;
    ex:identificador "PRB2MIN" ;
    ex:textoExtracto "Cota mínima del palpador (segundo eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .

ex:Parametro_PRB3MAX
    a ex:Parametro ;
    rdfs:label "PRB3MAX" ;
    ex:identificador "PRB3MAX" ;
    ex:textoExtracto "Cota máxima del palpador (tercer eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .

ex:Parametro_PRB3MIN
    a ex:Parametro ;
    rdfs:label "PRB3MIN" ;
    ex:identificador "PRB3MIN" ;
    ex:textoExtracto "Cota mínima del palpador (tercer eje del canal)." ;
    ex:documentadoEn ex:Tabla_PROBEDATA .