@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PRB3MAX
    a ex:Parametro ;
    rdfs:label "PRB3MAX (Cota máxima del palpador, tercer eje)"@es ;
    ex:identificador "(V.)[ch].MPG.PRB3MAX" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.PRB3MAX [...] Cota mínima del palpador (tercer eje del canal)."@es ;
    ex:valor "0"^^xsd:decimal ;
    ex:monitoreaParametro ex:Maquina_CNC .

ex:Parametro_PRB3MIN
    a ex:Parametro ;
    rdfs:label "PRB3MIN (Cota mínima del palpador, tercer eje)"@es ;
    ex:identificador "(V.)[ch].MPG.PRB3MIN" ;
    ex:textoExtracto "PRB3MIN Cota mínima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch."@es ;
    ex:valor "0"^^xsd:decimal ;
    ex:monitoreaParametro ex:Maquina_CNC .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC (Torno)"@es ;
    ex:textoExtracto "Si se trata de un CNC modelo TORNO, las cotas deben expresarse en radios."@es ;
    ex:tieneComponente ex:PalpadorSobremesa .

ex:PalpadorSobremesa
    a ex:ComponenteMecanico ;
    rdfs:label "Palpador de sobremesa"@es ;
    ex:textoExtracto "palpador de sobremesa que se utiliza para la calibración de herramientas. Se definirán en cotas absolutas y estarán referidas al cero máquina."@es .