@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_PosicionPalpadorSobremesa
    a ex:Esquema ;
    rdfs:label "Esquema de posición del palpador de sobremesa"@es ;
    ex:textoExtracto """
| Z
Y
Y X Z
PRB2MAX
PRB3MAX
PRB2MIN X PRB3MIN X
PRB1MIN PRB1MAX PRB1MIN PRB1MAX
""" ;
    ex:identificador "2.4.15" .

ex:Parametro_PRB1MIN
    a ex:Parametro ;
    rdfs:label "PRB1MIN (límite mínimo del palpador 1)"@es ;
    ex:textoExtracto "PRB1MIN" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .

ex:Parametro_PRB1MAX
    a ex:Parametro ;
    rdfs:label "PRB1MAX (límite máximo del palpador 1)"@es ;
    ex:textoExtracto "PRB1MAX" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .

ex:Parametro_PRB2MIN
    a ex:Parametro ;
    rdfs:label "PRB2MIN (límite mínimo del palpador 2)"@es ;
    ex:textoExtracto "PRB2MIN" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .

ex:Parametro_PRB2MAX
    a ex:Parametro ;
    rdfs:label "PRB2MAX (límite máximo del palpador 2)"@es ;
    ex:textoExtracto "PRB2MAX" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .

ex:Parametro_PRB3MIN
    a ex:Parametro ;
    rdfs:label "PRB3MIN (límite mínimo del palpador 3)"@es ;
    ex:textoExtracto "PRB3MIN" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .

ex:Parametro_PRB3MAX
    a ex:Parametro ;
    rdfs:label "PRB3MAX (límite máximo del palpador 3)"@es ;
    ex:textoExtracto "PRB3MAX" ;
    ex:detalladoEnEsquema ex:Esquema_PosicionPalpadorSobremesa .