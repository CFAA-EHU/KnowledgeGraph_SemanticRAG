@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FUNPLC
    a ex:Parametro ;
    rdfs:label "FUNPLC" ;
    ex:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FUNPLC" ;
    ex:identificador "FUNPLC" ;
    ex:valor "No" .

ex:Tabla_FuncionesM a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ex:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

ex:ModoOperacion_BusquedaBloque
    a ex:ModoOperacion ;
    rdfs:label "Búsqueda de bloque" ;
    ex:textoExtracto "La búsqueda de bloque permite recuperar la historia del programa hasta un bloque determinado, que podrá estar en un programa o una subrutina, de tal forma que si a continuación se reanuda la ejecución a partir de ese bloque, lo hará en las mismas condiciones que si se hubiera ejecutado desde el principio." ;
    ex:documentadoEn ex:Pagina_141 .

ex:InterfazUsuario_Softkey_MHSF
    a ex:InterfazUsuario ;
    rdfs:label "Softkey MHSF" ;
    ex:textoExtracto "el CNC muestra la softkey \"MHSF\" para poder ejecutar cualquier función de este tipo, modificando así las condiciones de mecanizado." ;
    ex:ilustradoEn ex:ModoOperacion_BusquedaBloque .

ex:Pagina_141
    a ex:Pagina ;
    rdfs:label "Página 141" ;
    ex:identificador "141" ;
    ex:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque..." .