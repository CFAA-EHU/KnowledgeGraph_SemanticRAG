@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SUBINTSTOP
    a ex:Parametro ;
    rdfs:label "SUBINTSTOP" ;
    ex:identificador "(V.)[ch].MPG.SUBINTSTOP" ;
    ex:textoExtracto "SUBINTSTOP Ejecutar subrutinas de interrupción con programa parado o sin programa en ejecución. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No" .

ex:ModoOperacion_Automatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "Para poder ejecutar la subrutina cuando no hay programa en ejecución, el canal debe estar en modo automático" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "no se permite ejecutar la subrutina desde el modo manual" .