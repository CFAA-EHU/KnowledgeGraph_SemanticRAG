@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:textoExtracto "MAXFEED Máximo avance de mecanizado sobre la trayectoria. Valores posibles: De 0 a 500000.0000 mm/min / de 0 a 19685.03937 inch/min. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.MAXFEED Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) sobre la trayectoria; si se define con valor ꞏ0ꞏ, no se limita el avance." ;
    ex:valor "0" ;
    ex:identificador "(V.)[ch].MPG.MAXFEED" .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "Si no se limita el avance de mecanizado, el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED." ;
    ex:identificador "(V.)[ch].PLC.G00FEED" .

ex:Parametro_DEFAULTFEED
    a ex:Parametro ;
    rdfs:label "DEFAULTFEED" ;
    ex:textoExtracto "DEFAULTFEED Asumir MAXFEED para los desplazamientos en G1/G2/G3 sin avance activo. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.DEFAULTFEED Este parámetro determina si los ejes se desplazan al avance definido en MAXFEED cuando se programa un movimiento en G01/G02/G03 sin programar el avance." ;
    ex:valor "No" ;
    ex:identificador "(V.)[ch].MPG.DEFAULTFEED" .

ex:Parametro_MAXFEED ex:monitoreaParametro ex:Parametro_G00FEED .