@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_avanceRapidoAutomatico
    a               ex:ModoOperacion ;
    rdfs:label      "Avance rápido para modo automático"@es ;
    ex:textoExtracto
        "2.4.19 Avance rápido para el modo automático. [...] El avance rápido no está disponible para el modo automático."@es ;
    .

ex:InterfazUsuario_panelJog
    a               ex:InterfazUsuario ;
    rdfs:label      "Panel de jog"@es ;
    ex:textoExtracto
        "tecla \"rápido\" del panel de jog"@es ;
    .

ex:Parametro_EXRAPID
    a               ex:Parametro ;
    rdfs:label      "EXRAPID" ;
    ex:identificador "EXRAPID" ;
    ex:textoExtracto
        "marca EXRAPID de PLC"@es ;
    ex:habilitadoPor ex:InterfazUsuario_panelJog ;
    .

ex:Tabla_2419_significadoRapiden a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla 2.4.19 - Significado de RAPIDEN"@es ;
    ex:textoExtracto
        """
| RAPIDEN | Significado. |
| --- | --- |
| Deshabilitado. | El avance rápido no está disponible para el modo automático. |
| EXRAPID o tecla rápido. | Para activar el avance rápido sólo es necesario activar la marca EXRAPID de PLC o pulsar la tecla "rápido" del panel de jog. |
| EXRAPID y tecla rápido. | Para activar el avance rápido hay que activar la marca EXRAPID de PLC y pulsar la tecla "rápido" del panel de jog. |
        """@es ;
    ex:documentadoEn ex:ModoOperacion_avanceRapidoAutomatico ;
    .