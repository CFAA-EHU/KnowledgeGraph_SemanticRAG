@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AvanceRapido
    a ex:Parametro ;
    rdfs:label "Parámetro de avance rápido"@es ;
    ex:textoExtracto "Si el parámetro se define con valor ꞏ0ꞏ, no se limita el avance. Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados."@es ;
    ex:identificador "0" .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED."@es .

ex:Parametro_FRAPIDEN
    a ex:Parametro ;
    rdfs:label "FRAPIDEN" ;
    ex:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN"@es .

ex:Parametro_AvanceMaximoPLC
    a ex:Parametro ;
    rdfs:label "Avance máximo fijado por PLC"@es ;
    ex:textoExtracto "ni tampoco al avance máximo fijado por PLC (variable"@es .