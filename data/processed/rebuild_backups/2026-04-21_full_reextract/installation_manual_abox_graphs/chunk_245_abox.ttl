@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN" ;
    ex:identificador "G00FEED" .

ex:Parametro_FRAPIDEN
    a ex:Parametro ;
    rdfs:label "FRAPIDEN" ;
    ex:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN" ;
    ex:identificador "FRAPIDEN" .

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal" ;
    ex:identificador "MAXFEED" .

ex:VariablePLC_G00FEED
    a ex:Parametro ;
    rdfs:label "Variable PLC G00FEED" ;
    ex:textoExtracto "El avance rápido no podrá superar [...] al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)" ;
    ex:identificador "(V.)PLC.G00FEED" .

ex:VariablePLC_F
    a ex:Parametro ;
    rdfs:label "Variable PLC F" ;
    ex:textoExtracto "El avance rápido podrá superar [...] al avance activo definido por PLC (variable (V.)PLC.F)" ;
    ex:identificador "(V.)PLC.F" .

ex:ModoOperacion_AvanceRapidoAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático" ;
    ex:textoExtracto "Los roscados se ejecutan al avance programado. El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED). El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)" ;
    ex:monitoreaParametro ex:Parametro_G00FEED ;
    ex:monitoreaParametro ex:Parametro_FRAPIDEN ;
    ex:monitoreaParametro ex:Parametro_MAXFEED ;
    ex:monitoreaParametro ex:VariablePLC_G00FEED ;
    ex:monitoreaParametro ex:VariablePLC_F .