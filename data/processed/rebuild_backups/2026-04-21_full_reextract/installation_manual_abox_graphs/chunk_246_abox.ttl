@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXACCEL
    a ex:Parametro ;
    rdfs:label "MAXACCEL" ;
    ex:identificador "(V.)[ch].MPG.MAXACCEL" ;
    ex:textoExtracto "Máxima aceleración sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 600000000.0000 mm/min / de 0.00004 a 23622047.24409 inch/min. Valor por defecto: No hay avance máximo. Este parámetro permite suavizar el avance sobre la trayectoria, limitando la aceleración máxima sobre ella." ;
    ex:valor "600000000.0000 mm/min (límite superior)" .

ex:Parametro_MAXJERK
    a ex:Parametro ;
    rdfs:label "MAXJERK" ;
    ex:identificador "(V.)[ch].MPG.MAXJERK" ;
    ex:textoExtracto "Máximo jerk sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 6E11 mm/min / de 0.00004 a 2.362E10 inch/min. Valor por defecto: No hay avance máximo. Este parámetro permite suavizar el avance sobre la trayectoria, limitando el jerk máximo sobre ella." ;
    ex:valor "6E11 mm/min (límite superior)" .

ex:Variable_Temporal_MAXACCEL
    a ex:Parametro ;
    rdfs:label "Variable temporal MAXACCEL" ;
    ex:identificador "(V.)[ch].G.MAXACCEL" ;
    ex:textoExtracto "La variable (V.)[ch].G.MAXACCEL permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina. El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset." .

ex:Variable_Temporal_MAXJERK
    a ex:Parametro ;
    rdfs:label "Variable temporal MAXJERK" ;
    ex:identificador "(V.)[ch].G.MAXJERK" ;
    ex:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." .

ex:Parametro_MAXACCEL
    ex:monitoreaParametro ex:Variable_Temporal_MAXACCEL .

ex:Parametro_MAXJERK
    ex:monitoreaParametro ex:Variable_Temporal_MAXJERK .