@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXJERK a ex:Parametro ;
    rdfs:label "Variable (V.)[ch].G.MAXJERK"@es ;
    ex:identificador "G.MAXJERK" ;
    ex:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina."@es ;
    ex:valor "temporal"@es .

ex:Maquina_CNC a ex:Maquina ;
    ex:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina."@es ;
    ex:monitoreaParametro ex:Parametro_MAXJERK .