@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MaximoJerkyTrayectoria
    a               ex:Parametro ;
    rdfs:label      "Parámetro máquina de límite de jerk sobre trayectoria"@es ;
    ex:textoExtracto
        "el CNC recupera el valor fijado por el parámetro máquina. [...] el CNC no aplica ningún límite al jerk sobre la trayectoria, ni siquiera el fijado por parámetro máquina."@es ;
    ex:identificador "M30" .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto
        "el CNC recupera el valor fijado por el parámetro máquina", "el CNC no aplica ningún límite al jerk sobre la trayectoria"@es ;
    ex:monitoreaParametro ex:Parametro_MaximoJerkyTrayectoria .