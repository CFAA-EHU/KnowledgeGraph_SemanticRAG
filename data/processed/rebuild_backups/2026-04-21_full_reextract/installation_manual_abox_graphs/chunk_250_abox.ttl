@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CURVFREQRES
    a               ex:Parametro ;
    rdfs:label      "CURVFREQRES" ;
    ex:identificador "CURVFREQRES" ;
    ex:textoExtracto "CURVFREQRES Primera frecuencia de resonancia de la máquina en los arcos. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 0." ;
    ex:valor         "0-500.0000 Hz"^^xsd:string ;
    ex:monitoreaParametro ex:Maquina_CNC .

ex:Maquina_CNC
    a               ex:Maquina ;
    ex:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .