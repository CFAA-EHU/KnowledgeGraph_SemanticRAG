@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SERCOSDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros Sercos (SERCOSDATA)"@es ;
    ex:textoExtracto """
| SERCOSDATA |  |
| --- | --- |
| DRIVEID | Dirección del regulador Sercos. |
| OPMODEP | Modo de operación principal del regulador Sercos. |
| FBACKSRC | Tipo de captación. |
| FBACKDIFF | Máxima diferencia entre captaciones. |
| ULTRAIPO | Parámetro actualmente sin función. |
| FBACKTIME | Constante de tiempo para la captación mixta.
"""@es .

ex:Parametro_DRIVEID
    a ex:Parametro ;
    rdfs:label "DRIVEID"@es ;
    ex:identificador "DRIVEID" ;
    ex:textoExtracto "Dirección del regulador Sercos."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP"@es ;
    ex:identificador "OPMODEP" ;
    ex:textoExtracto "Modo de operación principal del regulador Sercos."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_FBACKSRC
    a ex:Parametro ;
    rdfs:label "FBACKSRC"@es ;
    ex:identificador "FBACKSRC" ;
    ex:textoExtracto "Tipo de captación."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_FBACKDIFF
    a ex:Parametro ;
    rdfs:label "FBACKDIFF"@es ;
    ex:identificador "FBACKDIFF" ;
    ex:textoExtracto "Máxima diferencia entre captaciones."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_ULTRAIPO
    a ex:Parametro ;
    rdfs:label "ULTRAIPO"@es ;
    ex:identificador "ULTRAIPO" ;
    ex:textoExtracto "Parámetro actualmente sin función."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_FBACKTIME
    a ex:Parametro ;
    rdfs:label "FBACKTIME"@es ;
    ex:identificador "FBACKTIME" ;
    ex:textoExtracto "Constante de tiempo para la captación mixta."@es ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .