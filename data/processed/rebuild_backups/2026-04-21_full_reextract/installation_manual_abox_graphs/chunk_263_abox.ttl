@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DRIVEID
    a ex:Parametro ;
    rdfs:label "DRIVEID (Dirección del regulador Sercos)" ;
    ex:textoExtracto "DRIVEID Dirección del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro indica la posición (nodo) que ocupa el regulador en la conexión Sercos." ;
    ex:valor "1"^^xsd:integer ;
    ex:identificador "V.[ch].MPA.DRIVEID.xn" ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP (Modo de operación principal del regulador Sercos)" ;
    ex:textoExtracto "OPMODEP Modo de operación principal del regulador Sercos. [...] Valores posibles: Posición / Velocidad. [...] Este parámetro indica el modo de operación del regulador Sercos; consigna de velocidad o de posición." ;
    ex:valor "Posición" ;
    ex:identificador "V.[ch].MPA.OPMODEP.xn" ;
    ex:documentadoEn ex:Tabla_SERCOSDATA .

ex:Tabla_SERCOSDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla SERCOSDATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla SERCOSDATA." .

ex:ModoOperacion_SercosPosicion
    a ex:ModoOperacion ;
    rdfs:label "Modo Sercos posición" ;
    ex:textoExtracto "Se recomienda que los ejes (excepto ejes tándem) operen en modo Sercos posición [...] La búsqueda de cero la controla el CNC." .

ex:ModoOperacion_SercosVelocidad
    a ex:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad" ;
    ex:textoExtracto "los cabezales lo hagan en modo Sercos velocidad. [...] Los ejes tándem deberán operar obligatoriamente en modo Sercos velocidad. [...] La consigna se envía al regulador en diezmilésimas de rpm del motor." .

ex:ComponenteElectrico_Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor (asociado a regulador Sercos)" ;
    ex:textoExtracto "La consigna se envía al regulador en diezmilésimas de rpm del motor. [...] feedback del regulador al CNC llega como cota absoluta, en diezmilésimas de milímetro o milésimas de grado." ;
    ex:monitoreaParametro ex:Parametro_OPMODEP .