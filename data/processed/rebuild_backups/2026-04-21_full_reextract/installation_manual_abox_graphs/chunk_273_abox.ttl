@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_MLINKDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MLINKDATA"@es ;
    ex:textoExtracto """
    | MLINKDATA |  |
    | --- | --- |
    | DRIVEID | Dirección del regulador. |
    | OPMODEP | Modo de operación principal del regulador. |
    | OPTION | Activar las opciones del regulador.
    """@es ;
    ex:documentadoEn ex:Pagina_152 .

ex:Pagina_152
    a ex:Pagina ;
    ex:identificador "152" ;
    ex:textoExtracto "2.5.4 Configurar un regulador Mechatrolink."@es .

ex:Parametro_DRIVEID
    a ex:Parametro ;
    rdfs:label "DRIVEID" ;
    ex:textoExtracto "Dirección del regulador."@es ;
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP" ;
    ex:textoExtracto "Modo de operación principal del regulador."@es ;
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Parametro_OPTION
    a ex:Parametro ;
    rdfs:label "OPTION" ;
    ex:textoExtracto "Activar las opciones del regulador."@es ;
    ex:documentadoEn ex:Tabla_MLINKDATA .