@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS (Eje transversal)"@es ;
    ex:textoExtracto "FACEAXIS Eje transversal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.FACEAXIS.xn"@es ;
    ex:valor "Sí/No"@es ;
    ex:identificador "FACEAXIS" .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS (Eje longitudinal)"@es ;
    ex:textoExtracto "LONGAXIS Eje longitudinal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.LONGAXIS.xn"@es ;
    ex:valor "Sí/No"@es ;
    ex:identificador "LONGAXIS" .

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "CAXIS (Eje rotativo)"@es ;
    ex:textoExtracto "El eje rotativo debe tener su parámetro máquina CAXIS = Sí"@es ;
    ex:valor "Sí/No"@es ;
    ex:identificador "CAXIS" .

ex:Tabla_PersonalizacionEjesTorno a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Personalización habitual de ejes en torno"@es ;
    ex:textoExtracto "Personalización habitual en torno: En tornos hay indicar cuál es el eje longitudinal y el transversal. | Eje X. | FACEAXIS = Sí | LONGAXIS = No | Eje Z. | FACEAXIS = No | LONGAXIS = Sí | Resto de los ejes. | FACEAXIS = No | LONGAXIS = No"@es ;
    ex:documentadoEn ex:Manual_ConfiguracionEjes .

ex:Tabla_PersonalizacionEjesFresadoraRotativos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Personalización habitual de ejes en fresadora con ejes rotativos"@es ;
    ex:textoExtracto "Personalización habitual en fresadora con ejes rotativos: El eje rotativo debe tener su parámetro máquina CAXIS = Sí; el eje lineal asociado al eje rotativo debe tener su parámetro máquina LONGAXIS=Sí; el eje transversal debe tener su parámetro máquina FACEAXIS=Sí."@es ;
    ex:documentadoEn ex:Manual_ConfiguracionEjes .

ex:Manual_ConfiguracionEjes
    a ex:Manual ;
    rdfs:label "Sección 2.5.6: Configuración de ejes en máquinas tipo torno"@es ;
    ex:textoExtracto "FACEAXIS Eje transversal... Personalización habitual en fresadora con ejes rotativos: En este tipo de máquina, para utilizar los ciclos asociados a los eje rotativos, es necesario indicar cuál es el eje longitudinal y el transversal."@es ;
    ex:identificador "2.5.6" .

ex:Parametro_FACEAXIS
    ex:documentadoEn ex:Manual_ConfiguracionEjes ;
    ex:documentadoEn ex:Tabla_PersonalizacionEjesTorno ;
    ex:documentadoEn ex:Tabla_PersonalizacionEjesFresadoraRotativos .

ex:Parametro_LONGAXIS
    ex:documentadoEn ex:Manual_ConfiguracionEjes ;
    ex:documentadoEn ex:Tabla_PersonalizacionEjesTorno ;
    ex:documentadoEn ex:Tabla_PersonalizacionEjesFresadoraRotativos .

ex:Parametro_CAXIS
    ex:documentadoEn ex:Tabla_PersonalizacionEjesFresadoraRotativos .