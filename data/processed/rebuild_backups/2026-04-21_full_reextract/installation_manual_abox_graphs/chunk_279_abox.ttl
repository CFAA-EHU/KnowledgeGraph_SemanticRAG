@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CAXIS
    a ex:Parametro ;
    rdfs:label "CAXIS" ;
    ex:textoExtracto "parámetro máquina CAXIS = Sí" ;
    ex:valor "Sí" .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "parámetro máquina LONGAXIS=Sí" ;
    ex:valor "Sí" .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "parámetro máquina FACEAXIS=Sí" ;
    ex:valor "Sí" .

ex:EjeRotativo_A
    a ex:ComponenteMecanico ;
    rdfs:label "Eje A (rotativo)" ;
    ex:textoExtracto "Eje A. [...] CAXIS=Sí" ;
    ex:monitoreaParametro ex:Parametro_CAXIS .

ex:EjeLineal_X
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (lineal asociado al rotativo)" ;
    ex:textoExtracto "Eje X (eje lineal asociado al rotativo). [...] LONGAXIS = Sí" ;
    ex:monitoreaParametro ex:Parametro_LONGAXIS .

ex:EjeTransversal_Z
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (transversal)" ;
    ex:textoExtracto "Eje Z. [...] FACEAXIS = Sí" ;
    ex:monitoreaParametro ex:Parametro_FACEAXIS .

ex:Tabla_ConfiguracionEjesTorno a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Personalización habitual en torno (eje rotativo A)" ;
    ex:textoExtracto "Personalización habitual en torno (si el eje rotativo es el A): | Eje A. | - - - | - - - | CAXIS=Sí | Eje X (eje lineal asociado al rotativo). | FACEAXIS = No | LONGAXIS = Sí | CAXIS=No | Eje Z. | FACEAXIS = Sí | LONGAXIS = No | CAXIS=No" ;
    ex:ilustradoEn ex:EjeRotativo_A, ex:EjeLineal_X, ex:EjeTransversal_Z .