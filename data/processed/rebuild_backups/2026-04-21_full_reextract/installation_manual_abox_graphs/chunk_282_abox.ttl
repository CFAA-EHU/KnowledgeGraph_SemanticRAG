@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SYNCSET
    a ex:Parametro ;
    rdfs:label "SYNCSET" ;
    ex:textoExtracto "SYNCSET Set de parámetros para la sincronización. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 4. Valor por defecto: 1." ;
    ex:valor "1" ;
    ex:identificador "V.[ch].MPA.SYNCSET.xn" .

ex:Parametro_DSYNCVELW
    a ex:Parametro ;
    rdfs:label "DSYNCVELW" ;
    ex:textoExtracto "DSYNCVELW Ventana de sincronización en velocidad. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta." ;
    ex:valor "100 mm/min / 3.937 inch/min / 3600 grados/min / 10 rpm" ;
    ex:identificador "V.[ch].MPA.DSYNCVELW.xn" .

ex:Sistema_SincronizacionEjes
    a ex:Sistema ;
    rdfs:label "Sistema de sincronización de ejes y cabezales" ;
    ex:textoExtracto "SYNCSET Set de parámetros para la sincronización. [...] Si los cabezales maestro y esclavo se encuentra en el mismo canal, el cabezal maestro asume el set definido en su parámetro SYNCSET. [...] Cuando los cabezales se sincronizan en velocidad, el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio)." ;
    ex:tieneComponente ex:Parametro_SYNCSET ;
    ex:tieneComponente ex:Parametro_DSYNCVELW .