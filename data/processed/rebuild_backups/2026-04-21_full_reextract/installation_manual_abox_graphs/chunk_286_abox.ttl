@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LIMIT
    a               ex:Parametro ;
    rdfs:label      "LIMIT+" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- no tienen significado. [...] Hay límites de recorrido fijados por LIMIT+ y LIMIT-."@es ;
    ex:identificador "LIMIT+" .

ex:Parametro_LIMIT
    a               ex:Parametro ;
    rdfs:label      "LIMIT-" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- no tienen significado. [...] Hay límites de recorrido fijados por LIMIT+ y LIMIT-."@es ;
    ex:identificador "LIMIT-" .

ex:Parametro_AXISMODE_Linearlike
    a               ex:Parametro ;
    rdfs:label      "AXISMODE = Linearlike" ;
    ex:textoExtracto "Comportamiento cuando AXISMODE = Linearlike. Actúa parecido a un eje lineal."@es ;
    ex:identificador "AXISMODE=Linearlike" .

ex:Parametro_SHORTESTWAY
    a               ex:Parametro ;
    rdfs:label      "SHORTESTWAY" ;
    ex:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es ;
    ex:identificador "SHORTESTWAY" .

ex:Parametro_UNIDIR
    a               ex:Parametro ;
    rdfs:label      "UNIDIR" ;
    ex:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado. UNIDIR Sentido de giro único."@es ;
    ex:identificador "UNIDIR" .

ex:Parametro_MODUPLIM
    a               ex:Parametro ;
    rdfs:label      "MODUPLIM" ;
    ex:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es ;
    ex:identificador "MODUPLIM" .

ex:Parametro_MODLOWLIM
    a               ex:Parametro ;
    rdfs:label      "MODLOWLIM" ;
    ex:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es ;
    ex:identificador "MODLOWLIM" .

ex:ModoOperacion_EjeRotativo_Linearlike
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de operación de eje rotativo (Linearlike)" ;
    ex:textoExtracto "Comportamiento cuando AXISMODE = Linearlike. Actúa parecido a un eje lineal. Se pueden programar desplazamientos en G0/G1 y G90/G91. El contaje es libre y en grados (no le afecta mm/inch)."@es ;
    ex:identificador "AXISMODE_Linearlike" .