@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "UNIDIR (Sentido de giro único)" ;
    ex:textoExtracto "UNIDIR Sentido de giro único. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No (ambos sentidos) / Positivo / Negativo. Valor por defecto: No (ambos sentidos)." ;
    ex:valor "No (ambos sentidos)" ;
    ex:monitoreaParametro ex:Sistema_EjesRotativos .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY (Posicionamiento por camino más corto)" ;
    ex:textoExtracto "SHORTESTWAY Posicionamiento por el camino más corto. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No" ;
    ex:monitoreaParametro ex:Sistema_EjesRotativos .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "Los parámetros [...] MODUPLIM [...] no tienen significado." ;
    ex:monitoreaParametro ex:Sistema_EjesRotativos .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "Los parámetros [...] MODLOWLIM [...] no tienen significado." ;
    ex:monitoreaParametro ex:Sistema_EjesRotativos .

ex:Sistema_EjesRotativos
    a ex:Sistema ;
    rdfs:label "Sistema de ejes rotativos" ;
    ex:textoExtracto "Configuración de los ejes rotativos: límites de recorrido fijados por LIMIT+ y LIMIT-." .