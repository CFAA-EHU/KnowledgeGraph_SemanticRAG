@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ShortestWay
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:identificador "SHORTESTWAY" ;
    ex:textoExtracto "Este parámetro indica si los desplazamientos en G90 de los ejes rotativos se realizan por el camino más corto. [...] SHORTESTWAY = Sí" ;
    ex:valor "Sí" .