@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:modcomp_289
    a ex:Parametro ;
    rdfs:label "MODCOMP (Compensación de módulo)" ;
    ex:textoExtracto "MODCOMP Compensación de módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No (sin compensación)." ;
    ex:valor "Sí / No" ;
    ex:identificador "V.[ch].MPA.MODCOMP.xn" ;
    ex:monitoreaParametro ex:modnrot_289, ex:moder_289 .

ex:modnrot_289
    a ex:Parametro ;
    rdfs:label "MODNROT" ;
    ex:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

ex:moder_289
    a ex:Parametro ;
    rdfs:label "MODERR" ;
    ex:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

ex:axisMode_289
    a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando AXISMODE = Módulo." ;
    ex:valor "Módulo" .