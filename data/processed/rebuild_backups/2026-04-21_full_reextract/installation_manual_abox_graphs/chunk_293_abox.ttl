@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SPDLTIME
    a ex:Parametro ;
    rdfs:label "Tiempo estimado para función S (SPDLTIME)"@es ;
    ex:identificador "V.[ch].MPA.SPDLTIME.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.SPDLTIME.xn [...] parámetro que indica el tiempo estimado para el proceso de la función S."@es ;
    ex:valor "0" ;
    ex:monitoreaParametro ex:ModoOperacion_EDISIMU .

ex:Parametro_SPDLSTOP
    a ex:Parametro ;
    rdfs:label "Parada de cabezal (SPDLSTOP)"@es ;
    ex:textoExtracto "Las funciones M2, M30, un error o un reset paran el cabezal."@es .

ex:ModoOperacion_EDISIMU
    a ex:ModoOperacion ;
    rdfs:label "Modo EDISIMU"@es ;
    ex:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa."@es .

ex:Se_al_SSTROBE
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SSTROBE"@es ;
    ex:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1."@es .

ex:Se_al_SFUN1
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SFUN1"@es ;
    ex:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1."@es .