@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_STEPOVR
    a ex:Parametro ;
    rdfs:label "STEPOVR" ;
    ex:textoExtracto "Este parámetro define el paso incremental para modificar la velocidad de giro programada, mediante las teclas de speed override del panel de mando. Parámetro sin función cuando el panel de mando dispone del conmutador speed override." ;
    ex:valor "5" ;
    ex:identificador "(V.)[ch].MPA.STEPOVR.xn" .

ex:Parametro_MINOVR
    a ex:Parametro ;
    rdfs:label "MINOVR" ;
    ex:textoExtracto "Override (%) mínimo permitido para el cabezal. Este parámetro establece el porcentaje mínimo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ex:valor "50" ;
    ex:identificador "(V.)[ch].MPA.MINOVR.xn" .

ex:Parametro_MAXOVR
    a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:textoExtracto "Override (%) máximo permitido para el cabezal. Este parámetro establece el porcentaje máximo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ex:valor "150" ;
    ex:identificador "(V.)[ch].MPA.MAXOVR.xn" .

ex:InterfazUsuario_PanelMando
    a ex:InterfazUsuario ;
    rdfs:label "Panel de mando" ;
    ex:textoExtracto "panel de mando (teclas o conmutador speed override)" ;
    ex:monitoreaParametro ex:Parametro_STEPOVR ;
    ex:monitoreaParametro ex:Parametro_MINOVR ;
    ex:monitoreaParametro ex:Parametro_MAXOVR .