@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:THREADOVR
    a                     ex:Parametro ;
    rdfs:label            "THREADOVR" ;
    ex:identificador      "THREADOVR" ;
    ex:textoExtracto      "THREADOVR Variación máxima permitida para el override durante el roscado. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se permite variar el override)." ;
    ex:valor              "0-100%" ;
    ex:monitoreaParametro ex:OverrideCabezal .

ex:OverrideCabezal
    a                     ex:Parametro ;
    rdfs:label            "Override del cabezal" ;
    ex:textoExtracto      "variación máxima permitida para el override durante el roscado [...] máxima variación de override permitida para el cabezal, tanto para aumentarlo como para disminuirlo." .

ex:MINOVR
    a                     ex:Parametro ;
    rdfs:label            "MINOVR" ;
    ex:identificador      "MINOVR" ;
    ex:textoExtracto      "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ex:MAXOVR
    a                     ex:Parametro ;
    rdfs:label            "MAXOVR" ;
    ex:identificador      "MAXOVR" ;
    ex:textoExtracto      "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ex:FFGAIN
    a                     ex:Parametro ;
    rdfs:label            "FFGAIN" ;
    ex:identificador      "FFGAIN" ;
    ex:textoExtracto      "El feed forward se define con el parámetro FFGAIN y se puede modificar desde el PLC mediante variables." .

ex:FFWTYPE
    a                     ex:Parametro ;
    rdfs:label            "FFWTYPE" ;
    ex:identificador      "FFWTYPE" ;
    ex:textoExtracto      "El CNC no permite modificar el override del cabezal durante un roscado si detecta que en alguna gama de los ejes implicados no está activo el feed forward (parámetro FFWTYPE) o si el feed forward activo es inferior al 90%." .

ex:CiclosFijosRosca_T
    a                     ex:ModoOperacion ;
    rdfs:label            "Ciclos fijos de roscado del modelo T" ;
    ex:identificador      "G86, G87" ;
    ex:textoExtracto      "Ciclos fijos de roscado del modelo ꞏTꞏ (G86, G87 y sus equivalentes del editor de ciclos)." ;
    ex:requiereMantenimiento ex:OverrideCabezal .

ex:G33
    a                     ex:ModoOperacion ;
    rdfs:label            "Rosca electrónica (G33)" ;
    ex:identificador      "G33" ;
    ex:textoExtracto      "modificar el override del cabezal durante el roscado electrónico (G33)" ;
    ex:requiereMantenimiento ex:OverrideCabezal .