@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DWELL
    a ex:Parametro ;
    rdfs:label "DWELL (Temporización para ejes muertos)"@es ;
    ex:textoExtracto "DWELL Temporización para ejes muertos. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 (no hay temporización)."@es ;
    ex:valor "0-1000000 ms" ;
    ex:identificador "DWELL" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "Cuando está gobernado por el CNC (desplazamientos) se dice que el eje está 'vivo' y cuando está quieto (freno activo) se dice que el eje está 'muerto'."@es .

ex:ModoOperacion_EjeVivo
    a ex:ModoOperacion ;
    rdfs:label "Modo 'Eje Vivo' (desplazamiento activo)"@es ;
    ex:textoExtracto "Cuando está gobernado por el CNC (desplazamientos) se dice que el eje está 'vivo'."@es ;
    ex:habilitadoPor ex:Parametro_DWELL .

ex:ModoOperacion_EjeMuerto
    a ex:ModoOperacion ;
    rdfs:label "Modo 'Eje Muerto' (freno activo)"@es ;
    ex:textoExtracto "Cuando está quieto (freno activo) se dice que el eje está 'muerto'."@es ;
    ex:requiereMantenimiento ex:Parametro_DWELL .