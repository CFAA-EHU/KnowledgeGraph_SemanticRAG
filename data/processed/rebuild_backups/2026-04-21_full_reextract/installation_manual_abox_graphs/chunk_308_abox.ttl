@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DIAMPROG
    a ex:Parametro ;
    rdfs:label "DIAMPROG" ;
    ex:textoExtracto "DIAMPROG Programación en diámetros. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "Sí / No" ;
    ex:identificador "V.[ch].MPA.DIAMPROG.xn" .

ex:ModoOperacion_FACEAXIS
    a ex:ModoOperacion ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí." ;
    ex:valor "Sí / No" .

ex:Funcion_G151 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "G151" ;
    ex:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152." .

ex:Funcion_G152 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "G152" ;
    ex:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí. Los desplazamientos respecto al cero máquina (#MCS) siempre se realizan según este parámetro." ;
    ex:monitoreaParametro ex:Parametro_DIAMPROG ;
    ex:monitoreaParametro ex:ModoOperacion_FACEAXIS .