@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PROBEFEED
    a ex:Parametro ;
    rdfs:label "PROBEFEED" ;
    ex:textoExtracto "Si PROBEFEED se define con valor 0, el CNC calcula y utiliza el valor máximo que puede tener este parámetro." ;
    ex:valor "0" .

ex:Parametro_PROBEDELAY
    a ex:Parametro ;
    rdfs:label "PROBEDELAY" ;
    ex:textoExtracto "PROBEDELAY Retardo de la señal de palpador 1. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo)." ;
    ex:valor "0" .

ex:AvisoSeguridad_WarningValidacionEje
    a ex:AvisoSeguridad ;
    rdfs:label "Warning de validación de parámetros del eje" ;
    ex:textoExtracto "En caso contrario se mostrará un warning al validar los parámetros del eje, en el que se informa del máximo avance que se puede alcanzar." .