@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FLIMIT
    a ex:Parametro ;
    rdfs:label "FLIMIT" ;
    ex:identificador "FLIMIT" ;
    ex:textoExtracto "FLIMIT Límite máximo de seguridad para el avance del eje. Parámetro válido para ejes lineales y rotativos. [...] Este parámetro establece el límite máximo de seguridad para el avance del eje, a aplicar por ejemplo, cuando se realizan labores de mantenimiento en la máquina, operaciones con las seguridades deshabilitadas (puertas abiertas), etc." ;
    ex:valor "0 a 500000.0000 mm/min / 0 a 19685.03937 inch/min / 0 a 72000000.0000 grados/min" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_SLIMIT
    a ex:Parametro ;
    rdfs:label "SLIMIT" ;
    ex:identificador "SLIMIT" ;
    ex:textoExtracto "SLIMIT Límite máximo de seguridad para la velocidad del cabezal. Parámetro válido para cabezales. [...] Valor por defecto: 0 (no hay limitación)." ;
    ex:valor "0 a 200000.0000 rpm" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El valor definido se activa desde el PLC (marcas FLIMITAC o FLIMITACCHC1) y el CNC lo aplica en el bloque en ejecución. [...] Cuando hay un avance máximo fijado por PLC (variable (V.)PLC.G00FEED), el CNC aplica el avance más restrictivo." .

ex:Variable_PLC_G00FEED
    a ex:Parametro ;
    rdfs:label "Variable PLC G00FEED" ;
    ex:identificador "(V.)PLC.G00FEED" ;
    ex:textoExtracto "Cuando hay un avance máximo fijado por PLC (variable (V.)PLC.G00FEED), el CNC aplica el avance más restrictivo." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Marca_PLC_FLIMITAC
    a ex:Parametro ;
    rdfs:label "Marca PLC FLIMITAC" ;
    ex:identificador "FLIMITAC" ;
    ex:textoExtracto "El valor definido se activa desde el PLC (marcas FLIMITAC o FLIMITACCHC1) y el CNC lo aplica en el bloque en ejecución." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Marca_PLC_FLIMITACCHC1
    a ex:Parametro ;
    rdfs:label "Marca PLC FLIMITACCHC1" ;
    ex:identificador "FLIMITACCHC1" ;
    ex:textoExtracto "El valor definido se activa desde el PLC (marcas FLIMITAC o FLIMITACCHC1) y el CNC lo aplica en el bloque en ejecución." ;
    ex:monitoreaParametro ex:Sistema_CNC .