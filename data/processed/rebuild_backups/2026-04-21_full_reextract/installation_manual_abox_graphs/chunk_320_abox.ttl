@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SLIMIT
    a ex:Parametro ;
    rdfs:label "SLIMIT" ;
    ex:identificador "SLIMIT" ;
    ex:textoExtracto "SLIMIT Límite máximo de seguridad para la velocidad del cabezal. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 200000.0000 rpm. Valor por defecto: 0 (no hay limitación)." ;
    ex:valor "0-200000.0000 rpm" ;
    ex:monitoreaParametro ex:VelocidadCabezal .

ex:VelocidadCabezal
    a ex:Parametro ;
    rdfs:label "velocidad del cabezal" ;
    ex:textoExtracto "límite máximo de seguridad para la velocidad del cabezal" .

ex:PLC_SLIMITAC
    a ex:ComponenteElectrico ;
    rdfs:label "marca SLIMITAC (PLC)" ;
    ex:textoExtracto "El valor definido se activa desde el PLC (marcas SLIMITAC o SLIMITACSPDL)" ;
    ex:controla ex:SLIMIT .

ex:PLC_SLIMITACSPDL
    a ex:ComponenteElectrico ;
    rdfs:label "marca SLIMITACSPDL (PLC)" ;
    ex:textoExtracto "El valor definido se activa desde el PLC (marcas SLIMITAC o SLIMITACSPDL)" ;
    ex:controla ex:SLIMIT .

ex:CNC_SeguridadVelocidad
    a ex:Sistema ;
    rdfs:label "Sistema de limitación de velocidad (CNC)" ;
    ex:textoExtracto "el CNC lo aplica en el bloque en ejecución. Al desactivar los límites, el CNC recupera la velocidad programada." ;
    ex:controla ex:SLIMIT .