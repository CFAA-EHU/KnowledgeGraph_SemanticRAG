@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Manual
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo de trabajo manual" ;
    ex:textoExtracto       "Avance en modo jog continuo. [...] Máximo porcentaje de aceleración de ejecución en G201."@es ;
    ex:tieneComponente    ex:Parametro_JOGFEED ,
                          ex:Parametro_JOGRAPFEED ,
                          ex:Parametro_MAXMANFEED ,
                          ex:Parametro_MAXMANACC ,
                          ex:Parametro_INCJOGDIST ,
                          ex:Parametro_INCJOGFEED ,
                          ex:Parametro_MPGRESOL ,
                          ex:Parametro_MPGFILTER ,
                          ex:Parametro_MANPOSSW ,
                          ex:Parametro_MANNEGSW ,
                          ex:Parametro_MANFEEDP ,
                          ex:Parametro_IPOFEEDP ,
                          ex:Parametro_MANACCP ,
                          ex:Parametro_IPOACCP .

ex:Parametro_JOGFEED
    a               ex:Parametro ;
    rdfs:label      "JOGFEED" ;
    ex:identificador "JOGFEED" ;
    ex:textoExtracto "Avance en modo jog continuo."@es .

