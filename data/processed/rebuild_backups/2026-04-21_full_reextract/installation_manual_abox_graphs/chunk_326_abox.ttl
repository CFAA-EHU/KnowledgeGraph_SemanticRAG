@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXMANFEED
    a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:textoExtracto "Este parámetro define el avance máximo para los desplazamientos en jog continuo en modo manual." ;
    ex:valor "10000.0000 mm/min / 393.70079 inch/min / 10000.0000 grados/min" ;
    ex:identificador "(V.)[ch].MPA.MAXMANFEED.xn" ;
    ex:documentadoEn ex:Tabla_MANUAL .

ex:Parametro_MAXMANACC
    a ex:Parametro ;
    rdfs:label "MAXMANACC" ;
    ex:textoExtracto "Aceleración máxima en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:valor "De 0.0010 a 600000000.0000 mm/s²" ;
    ex:documentadoEn ex:Tabla_MANUAL .

ex:Tabla_MANUAL a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL." .