@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXMANACC
    a ex:Parametro ;
    rdfs:label "MAXMANACC (Aceleración máxima en jog continuo)" ;
    ex:textoExtracto "Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valores posibles (2): De 0.00004 a 23622047.2440 inch/s². Valores posibles (3): De 0.0010 a 600000000.0000 grados/s². Valor por defecto: 10000.0000 mm/s² / 393.70079 inch/s² / 10000.0000 grados/s²." ;
    ex:valor "10000.0000 mm/s² / 393.70079 inch/s² / 10000.0000 grados/s²" ;
    ex:identificador "MPA.MAXMANACC.xn" ;
    ex:documentadoEn ex:Tabla_MANUAL .

ex:Tabla_MANUAL a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANUAL (Parámetros de modo manual)" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL." .

ex:Parametro_INCJOGDIST
    a ex:Parametro ;
    rdfs:label "INCJOGDIST (Tabla de desplazamientos en jog incremental)" ;
    ex:textoExtracto "Tabla de desplazamientos en jog incremental. Este parámetro muestra la tabla para definir los desplazamientos del eje en cada posición del conmutador de jog. La tabla consta de cinco parámetros, uno para cada posición del conmutador del panel de mando: INCJOGDIST1 (ꞏ1ꞏ), INCJOGDIST2 (ꞏ10ꞏ), INCJOGDIST3 (ꞏ100ꞏ), INCJOGDIST4 (ꞏ1000ꞏ), INCJOGDIST5 (ꞏ10000ꞏ)." ;
    ex:documentadoEn ex:Tabla_MANUAL .

ex:Parametro_INCJOGDIST1
    a ex:Parametro ;
    rdfs:label "INCJOGDIST1 (Posición ꞏ1ꞏ del conmutador)" ;
    ex:textoExtracto "INCJOGDIST1 Posición ꞏ1ꞏ del conmutador." ;
    ex:valor "De 0.0001 a 99999.9999 mm / De 0.0000 a 3937.00787 inch" ;
    ex:documentadoEn ex:Parametro_INCJOGDIST .

ex:Parametro_INCJOGDIST2
    a ex:Parametro ;
    rdfs:label "INCJOGDIST2 (Posición ꞏ10ꞏ del conmutador)" ;
    ex:textoExtracto "INCJOGDIST2 Posición ꞏ10ꞏ del conmutador." ;
    ex:valor "De 0.0001 a 99999.9999 mm / De 0.0000 a 3937.00787 inch" ;
    ex:documentadoEn ex:Parametro_INCJOGDIST .

ex:Parametro_INCJOGDIST3
    a ex:Parametro ;
    rdfs:label "INCJOGDIST3 (Posición ꞏ100ꞏ del conmutador)" ;
    ex:textoExtracto "INCJOGDIST3 Posición ꞏ100ꞏ del conmutador." ;
    ex:valor "De 0.0001 a 99999.9999 mm / De 0.0000 a 3937.00787 inch" ;
    ex:documentadoEn ex:Parametro_INCJOGDIST .

ex:Parametro_INCJOGDIST4
    a ex:Parametro ;
    rdfs:label "INCJOGDIST4 (Posición ꞏ1000ꞏ del conmutador)" ;
    ex:textoExtracto "INCJOGDIST4 Posición ꞏ1000ꞏ del conmutador." ;
    ex:valor "De 0.0001 a 99999.9999 mm / De 0.0000 a 3937.00787 inch" ;
    ex:documentadoEn ex:Parametro_INCJOGDIST .

ex:Parametro_INCJOGDIST5
    a ex:Parametro ;
    rdfs:label "INCJOGDIST5 (Posición ꞏ10000ꞏ del conmutador)" ;
    ex:textoExtracto "INCJOGDIST5 Posición ꞏ10000ꞏ del conmutador." ;
    ex:valor "De 0.0001 a 99999.9999 mm / De 0.0000 a 3937.00787 inch" ;
    ex:documentadoEn ex:Parametro_INCJOGDIST .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ex:textoExtracto "MODO DE TRABAJO MANUAL. JOG INCREMENTAL." .