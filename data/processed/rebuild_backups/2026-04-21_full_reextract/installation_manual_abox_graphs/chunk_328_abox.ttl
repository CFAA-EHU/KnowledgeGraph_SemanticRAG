@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INCJOGDIST
    a ex:Parametro ;
    rdfs:label "Distancia incremental de jog (INCJOGDIST)"@es ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.INCJOGDIST[pos].xn. En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog."@es ;
    ex:identificador "MPA.INCJOGDIST" ;
    ex:valor "Rango 1: 0.0001 a 99999.9999 mm / Rango 2: 0.0000 a 3937.00787 inch / Rango 3: 0.0001 a 99999.9999 grados"@es .