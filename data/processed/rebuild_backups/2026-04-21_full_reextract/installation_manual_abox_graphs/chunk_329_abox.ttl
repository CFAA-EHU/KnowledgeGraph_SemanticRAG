@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosDesplazamientoManual a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de desplazamiento en modo manual"@es ;
    ex:textoExtracto """
| Parámetro. | Desplazamiento. |
| --- | --- |
| INCJOGDIST1 | 0.0010 mm o grados / 0.00003937 inch. |
| INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch. |
| INCJOGDIST3 | 0.1000 mm o grados / 0.00393700 inch. |
| INCJOGDIST4 | 1.0000 mm o grados / 0.03937007 inch. |
| INCJOGDIST5 | 10.000 mm o grados / 0.39370078 inch. |
""" .

ex:Parametro_INCJOGDIST1
    a ex:Parametro ;
    rdfs:label "INCJOGDIST1" ;
    ex:identificador "INCJOGDIST1" ;
    ex:valor "0.0010" ;
    ex:textoExtracto "INCJOGDIST1 | 0.0010 mm o grados / 0.00003937 inch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosDesplazamientoManual .

ex:Parametro_INCJOGDIST2
    a ex:Parametro ;
    rdfs:label "INCJOGDIST2" ;
    ex:identificador "INCJOGDIST2" ;
    ex:valor "0.0100" ;
    ex:textoExtracto "INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosDesplazamientoManual .

ex:Parametro_INCJOGDIST3
    a ex:Parametro ;
    rdfs:label "INCJOGDIST3" ;
    ex:identificador "INCJOGDIST3" ;
    ex:valor "0.1000" ;
    ex:textoExtracto "INCJOGDIST3 | 0.1000 mm o grados / 0.00393700 inch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosDesplazamientoManual .

ex:Parametro_INCJOGDIST4
    a ex:Parametro ;
    rdfs:label "INCJOGDIST4" ;
    ex:identificador "INCJOGDIST4" ;
    ex:valor "1.0000" ;
    ex:textoExtracto "INCJOGDIST4 | 1.0000 mm o grados / 0.03937007 inch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosDesplazamientoManual .

ex:Parametro_INCJOGDIST5
    a ex:Parametro ;
    rdfs:label "INCJOGDIST5" ;
    ex:identificador "INCJOGDIST5" ;
    ex:valor "10.000" ;
    ex:textoExtracto "INCJOGDIST5 | 10.000 mm o grados / 0.39370078 inch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosDesplazamientoManual .