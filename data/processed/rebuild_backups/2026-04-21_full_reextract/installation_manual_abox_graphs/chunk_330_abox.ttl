@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_INCJOGFEED a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de avances de jog incremental"@es ;
    ex:textoExtracto "INCJOGFEED Tabla de avances de jog incremental. [...] La tabla consta de cinco parámetros, uno para cada posición del conmutador de jog."@es ;
    ex:tieneComponente ex:Parametro_INCJOGFEED1, ex:Parametro_INCJOGFEED2, ex:Parametro_INCJOGFEED3, ex:Parametro_INCJOGFEED4, ex:Parametro_INCJOGFEED5 .

ex:Parametro_INCJOGFEED1
    a ex:Parametro ;
    rdfs:label "INCJOGFEED1" ;
    ex:identificador "INCJOGFEED1" ;
    ex:textoExtracto "INCJOGFEED1 Posición ꞏ1ꞏ del conmutador."@es ;
    ex:valor "1000.0000"^^xsd:float ;  # Valor por defecto en mm/min
    ex:documentadoEn ex:Tabla_INCJOGFEED .

ex:Parametro_INCJOGFEED2
    a ex:Parametro ;
    rdfs:label "INCJOGFEED2" ;
    ex:identificador "INCJOGFEED2" ;
    ex:textoExtracto "INCJOGFEED2 Posición ꞏ10ꞏ del conmutador."@es ;
    ex:valor "10000.0000"^^xsd:float ;  # Inferido por escalado x10 desde INCJOGFEED1
    ex:documentadoEn ex:Tabla_INCJOGFEED .

ex:Parametro_INCJOGFEED3
    a ex:Parametro ;
    rdfs:label "INCJOGFEED3" ;
    ex:identificador "INCJOGFEED3" ;
    ex:textoExtracto "INCJOGFEED3 Posición ꞏ100ꞏ del conmutador."@es ;
    ex:valor "100000.0000"^^xsd:float ;  # Inferido por escalado x100 desde INCJOGFEED1
    ex:documentadoEn ex:Tabla_INCJOGFEED .

ex:Parametro_INCJOGFEED4
    a ex:Parametro ;
    rdfs:label "INCJOGFEED4" ;
    ex:identificador "INCJOGFEED4" ;
    ex:textoExtracto "INCJOGFEED4 Posición ꞏ1000ꞏ del conmutador."@es ;
    ex:valor "200000.0000"^^xsd:float ;  # Límite máximo según rango (1-200000 mm/min)
    ex:documentadoEn ex:Tabla_INCJOGFEED .

ex:Parametro_INCJOGFEED5
    a ex:Parametro ;
    rdfs:label "INCJOGFEED5" ;
    ex:identificador "INCJOGFEED5" ;
    ex:textoExtracto "INCJOGFEED5 Posición ꞏ10000ꞏ del conmutador."@es ;
    ex:valor "200000.0000"^^xsd:float ;  # Límite máximo según rango (1-200000 mm/min)
    ex:documentadoEn ex:Tabla_INCJOGFEED .

ex:Tabla_MPGRESOL a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de resoluciones del volante"@es ;
    ex:textoExtracto "MPGRESOL Tabla de resoluciones del volante. [...] La tabla consta de tres parámetros, uno para cada posición del conmutador de jog."@es ;
    ex:tieneComponente ex:Parametro_MPGRESOL1 .

ex:Parametro_MPGRESOL1
    a ex:Parametro ;
    rdfs:label "MPGRESOL1" ;
    ex:identificador "MPGRESOL1" ;
    ex:textoExtracto "MPGRESOL1 Posición ꞏ1ꞏ del conmutador."@es ;
    ex:documentadoEn ex:Tabla_MPGRESOL .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ex:textoExtracto "MODO DE TRABAJO MANUAL. VOLANTES."@es ;
    ex:detalladoEnEsquema ex:Tabla_INCJOGFEED, ex:Tabla_MPGRESOL .

ex:InterfazUsuario_ConmutadorJog
    a ex:InterfazUsuario ;
    rdfs:label "Conmutador de jog del panel de mando"@es ;
    ex:textoExtracto "posiciones del conmutador del panel de mando"@es ;
    ex:ilustradoEn ex:Tabla_INCJOGFEED, ex:Tabla_MPGRESOL .