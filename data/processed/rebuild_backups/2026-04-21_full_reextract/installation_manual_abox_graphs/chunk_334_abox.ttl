@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPGRESOL1
    a ex:Parametro ;
    rdfs:label "Resolución del volante (MPGRESOL1)" ;
    ex:textoExtracto "Un volante de 100 impulsos/vuelta proporciona 1 impulso por marca. MPGRESOL1 = 0.0010 mm. [...] Un volante de 25 impulsos/vuelta proporciona 1 impulso por cada 4 marcas. MPGRESOL1 = 0.0040 mm." ;
    ex:valor "0.0010 mm" , "0.0005 mm" , "0.0040 mm" .

ex:Parametro_MPGFILTER
    a ex:Parametro ;
    rdfs:label "Tiempo de filtro del volante (MPGFILTER)" ;
    ex:textoExtracto "MPGFILTER Tiempo de filtro para el volante. [...] Valores posibles: De 1 a 1000. Valor por defecto: 10." ;
    ex:valor "10" ;
    ex:textoExtracto "Este filtro suaviza los desplazamientos del volante, evitando variaciones bruscas. El parámetro indica de cuantos ciclos CNC se realiza la media de los impulsos recibidos." .

ex:Parametro_MANPOSSW
    a ex:Parametro ;
    rdfs:label "Recorrido positivo máximo con G201 (MANPOSSW)" ;
    ex:textoExtracto "MANPOSSW Máximo recorrido positivo con G201. [...] Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 99999.9999 mm / 3937.00787 inch / 99999.9999 grados." ;
    ex:valor "99999.9999" .

ex:Parametro_MANNEGSW
    a ex:Parametro ;
    rdfs:label "Recorrido negativo máximo con G201 (MANNEGSW)" ;
    ex:textoExtracto "MANNEGSW Máximo recorrido negativo con G201. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:valor "99999.9999" .

ex:Tabla_Manual a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros MANUAL" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL. Consultar el parámetro máquina de ejes MANNEGSW." ;
    ex:documentadoEn ex:Manual .

ex:ComponenteElectrico_Volante
    a ex:ComponenteElectrico ;
    rdfs:label "Volante con disco graduado" ;
    ex:textoExtracto "El volante dispone de un disco graduado de 100 posiciones y se desea una resolución de 0.001 mm para la posición ꞏ1ꞏ del conmutador." ;
    ex:monitoreaParametro ex:Parametro_MPGRESOL1 ;
    ex:monitoreaParametro ex:Parametro_MPGFILTER .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual (G201)" ;
    ex:textoExtracto "MODO DE TRABAJO MANUAL. INTERVENCIÓN MANUAL." ;
    ex:tieneFrecuencia [
        a ex:Frecuencia ;
        rdfs:label "Frecuencia de uso en intervención manual" ;
        ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."
    ] .