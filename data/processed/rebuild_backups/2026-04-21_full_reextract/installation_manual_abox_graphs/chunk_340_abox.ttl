@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LSCRWCOMP
    a               ex:Parametro ;
    rdfs:label      "LSCRWCOMP - Compensación de husillo" ;
    ex:textoExtracto "LSCRWCOMP Compensación de husillo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor        "No"^^xsd:string ;
    ex:identificador "LSCRWCOMP" .

ex:Parametro_LSCRWDATA
    a               ex:Parametro ;
    rdfs:label      "LSCRWDATA - Tabla de compensación de husillo" ;
    ex:textoExtracto "LSCRWDATA Tabla de compensación de husillo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra la tabla para definir la compensación de husillo." ;
    ex:identificador "LSCRWDATA" .

ex:Tabla_CompensacionHusillo a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de configuración de compensación de husillo" ;
    ex:textoExtracto "La tabla dispone de los siguientes parámetros para su configuración." ;
    ex:documentadoEn ex:Parametro_LSCRWDATA .