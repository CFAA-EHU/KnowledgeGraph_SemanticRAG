@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_LSCRWCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación de husillo (LSCRWCOMP)" ;
    ex:textoExtracto "La tabla de compensación de husillo puede disponer de hasta 1000 puntos." ;
    ex:tieneComponente ex:Parametro_NPOINTS, ex:Parametro_TYPLSCRW, ex:Parametro_BIDIR, ex:Parametro_REFNEED .

ex:Parametro_NPOINTS
    a ex:Parametro ;
    rdfs:label "NPOINTS" ;
    ex:identificador "NPOINTS" ;
    ex:textoExtracto "NPOINTS Número de puntos de la tabla. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: De 0 a 1000. Valor por defecto: 0 (no hay tabla)." ;
    ex:valor "0-1000"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_TYPLSCRW
    a ex:Parametro ;
    rdfs:label "TYPLSCRW" ;
    ex:identificador "TYPLSCRW" ;
    ex:textoExtracto "TYPLSCRW Método de compensación (tipo de cotas). [...] Valores posibles: Real / Teórica. Valor por defecto: Real." ;
    ex:valor "Real/Teórica"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_BIDIR
    a ex:Parametro ;
    rdfs:label "BIDIR" ;
    ex:identificador "BIDIR" ;
    ex:textoExtracto "BIDIR Compensación bidireccional. [...] Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "Sí/No"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_REFNEED
    a ex:Parametro ;
    rdfs:label "REFNEED" ;
    ex:identificador "REFNEED" ;
    ex:textoExtracto "REFNEED Búsqueda de cero necesaria. [...] Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "Sí/No"^^<http://www.w3.org/2001/XMLSchema#string> .