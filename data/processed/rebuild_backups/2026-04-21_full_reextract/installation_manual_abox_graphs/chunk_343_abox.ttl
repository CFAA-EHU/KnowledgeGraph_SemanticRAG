@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CompensacionHusillo_RefNeed
    a ex:Parametro ;
    rdfs:label "Parámetro REFNEED para compensación de husillo"@es ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.REFNEED.xn. Este parámetro indica si es necesario referenciar el eje para empezar a aplicar la compensación."@es ;
    ex:identificador "MPA.REFNEED.xn" ;
    ex:valor "No" ;
    ex:documentadoEn ex:Tabla_LSCRWCOMP .

ex:Tabla_LSCRWCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de compensación de husillo (LSCRWCOMP)"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP."@es ;
    ex:identificador "LSCRWCOMP" .

ex:Parametro_CompensacionHusillo_Data
    a ex:Parametro ;
    rdfs:label "Parámetro DATA de compensación de husillo por puntos"@es ;
    ex:textoExtracto "DATA Compensación de husillo en cada punto. Este parámetro muestra la lista de puntos y valores de compensación."@es ;
    ex:documentadoEn ex:Tabla_LSCRWCOMP .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC con regulador analógico, Sercos o simulado"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. El CNC sólo permite acceder a esta tabla cuando está definido."@es ;
    ex:monitoreaParametro ex:Parametro_CompensacionHusillo_RefNeed ;
    ex:monitoreaParametro ex:Parametro_CompensacionHusillo_Data .