@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FiltroPasoBajo
    a ex:Componente ;
    rdfs:label "Filtro paso bajo" ;
    ex:textoExtracto "El filtro \"paso bajo\", para un misma frecuencia, necesita menos orden y como consecuencia, introduce menos retardo. Este tipo de filtro introduce un desfase no constante, dependiente de las frecuencias." .