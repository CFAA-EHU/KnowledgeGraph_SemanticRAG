@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaFILTER a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla FILTER" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER." .

ex:ParametroFREQUENCY
    a ex:Parametro ;
    rdfs:label "FREQUENCY" ;
    ex:textoExtracto "Frecuencia de corte o central. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 500.0 Hz. Valor por defecto: 30.0 Hz." ;
    ex:valor "30.0" ;
    ex:documentadoEn ex:TablaFILTER .

ex:ParametroNORBWIDTH
    a ex:Parametro ;
    rdfs:label "NORBWIDTH" ;
    ex:textoExtracto "Anchura de banda normalizada. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100.0. Valor por defecto: 1.0." ;
    ex:valor "1.0" ;
    ex:documentadoEn ex:TablaFILTER .

ex:ParametroSHARE
    a ex:Parametro ;
    rdfs:label "SHARE" ;
    ex:textoExtracto "Porcentaje de señal que pasa a través del filtro. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 100." ;
    ex:valor "100" ;
    ex:documentadoEn ex:TablaFILTER .