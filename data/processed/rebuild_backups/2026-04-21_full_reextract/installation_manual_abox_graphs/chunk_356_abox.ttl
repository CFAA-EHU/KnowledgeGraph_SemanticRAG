@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NPARSETS
    a ex:Parametro ;
    rdfs:label "NPARSETS" ;
    ex:textoExtracto "Número de sets de parámetros disponibles. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 1 a 4. Valor por defecto: 1." ;
    ex:valor "1-4" ;
    ex:identificador "V.[ch].MPA.NPARSETS.xn" .

ex:Parametro_DEFAULTSET
    a ex:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ex:textoExtracto "Set de parámetros por defecto en el encendido. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 4. Valor por defecto: 1." ;
    ex:valor "0-4" ;
    ex:identificador "V.[ch].MPA.DEFAULTSET.xn" .

ex:Funcion_G112 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "G112" ;
    ex:textoExtracto "Para seleccionar un set de parámetros en el eje desde el programa pieza, usar la función G112." ;
    ex:identificador "G112" .

ex:Funcion_M19 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "M19" ;
    ex:textoExtracto "El CNC arranca sin gama, y nada más arrancar el CNC ejecuta una M19." ;
    ex:identificador "M19" .

ex:Funcion_G74 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "G74" ;
    ex:textoExtracto "El CNC arranca sin gama, y nada más arrancar el CNC ejecuta una [...] G74." ;
    ex:identificador "G74" .

ex:Funcion_M02 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "M02" ;
    ex:textoExtracto "En los ejes, el parámetro DEFAULTSET indica el set de parámetros que asume el CNC [...] después de ejecutarse M02, M30 o después de un reset." ;
    ex:identificador "M02" .

ex:Funcion_M30 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "M30" ;
    ex:textoExtracto "En los ejes, el parámetro DEFAULTSET indica el set de parámetros que asume el CNC [...] después de ejecutarse M02, M30 o después de un reset." ;
    ex:identificador "M30" .

ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Sercos" ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. [...] Si cae el anillo Sercos y el regulador pone la gama por defecto." .