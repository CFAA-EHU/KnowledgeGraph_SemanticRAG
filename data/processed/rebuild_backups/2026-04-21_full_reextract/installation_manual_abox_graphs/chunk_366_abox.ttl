@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INPUTREV2
    a ex:Parametro ;
    rdfs:label "INPUTREV2" ;
    ex:identificador "INPUTREV2" ;
    ex:valor "1"^^xsd:integer ;
    ex:textoExtracto "Vueltas eje motor (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ex:monitoreaParametro ex:Maquina_EjeCaptacionExterna .

ex:Parametro_OUTPUTREV2
    a ex:Parametro ;
    rdfs:label "OUTPUTREV2" ;
    ex:identificador "OUTPUTREV2" ;
    ex:valor "1"^^xsd:integer ;
    ex:textoExtracto "Vueltas eje máquina (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ex:monitoreaParametro ex:Maquina_EjeCaptacionExterna .

ex:Parametro_NPULSES2
    a ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:identificador "NPULSES2" ;
    ex:valor "1250"^^xsd:integer ;
    ex:textoExtracto "Número de impulsos del encoder (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Este parámetro define el número de impulsos por vuelta del encoder para la segunda captación." ;
    ex:monitoreaParametro ex:Componente_SensorEncoderCaptacionExterna .

ex:Parametro_SINMAGNI
    a ex:Parametro ;
    rdfs:label "SINMAGNI" ;
    ex:identificador "SINMAGNI" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "Factor de multiplicación para la señal de captación senoidal. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ex:monitoreaParametro ex:Componente_SensorCaptacionSenosoidal .

ex:Maquina_EjeCaptacionExterna
    a ex:Maquina ;
    rdfs:label "Eje de captación externa" ;
    ex:textoExtracto "Parámetros válidos para ejes lineales, rotativos y cabezales en regulador Sercos." ;
    ex:tieneComponente ex:Componente_SensorEncoderCaptacionExterna .

ex:Componente_SensorEncoderCaptacionExterna
    a ex:Sensor ;
    rdfs:label "Encoder de captación externa" ;
    ex:textoExtracto "Número de impulsos del encoder (captación externa). Si se emplea un reductor en el eje se deberá tener en cuenta todo el conjunto al definir el número de impulsos por vuelta." .

ex:Componente_SensorCaptacionSenosoidal
    a ex:Sensor ;
    rdfs:label "Sensor de captación senoidal" ;
    ex:textoExtracto "Factor de multiplicación para la señal de captación senoidal en regulador analógico y simulado." .