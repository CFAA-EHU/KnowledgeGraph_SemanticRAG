@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_TiposEncoder a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de tipos de encoder y parámetros asociados"@es ;
    ex:textoExtracto """
| Tipo de encóder. | PITCH | NPULSES | SINMAGNI |
| --- | --- | --- | --- |
| Eje rotativo. Encoder rotativo. Señales cuadradas. | Giro del eje por vuelta del encoder | Número de impulsos. | 0 |
| Eje rotativo. Encóder rotativo. Señales senoidales. | Giro del eje por vuelta del encoder | Número de impulsos. | Factor de multiplicación. |
| Eje lineal. Encoder rotativo. Señales cuadradas. | Paso del husillo. | Número de impulsos. | 0 |
| Eje lineal. Encóder rotativo. Señales senoidales. | Paso del husillo. | Número de impulsos. | Factor de multiplicación. |
| Encoder lineal. Señales cuadradas. | Paso del encoder. | 0 | 0 |
| Encóder lineal. Señales senoidales. | Paso del encoder. | 0 | Factor de multiplicación. |
""" .

ex:Parametro_Pitch
    a ex:Parametro ;
    rdfs:label "PITCH" ;
    ex:textoExtracto "Giro del eje por vuelta del encoder; Paso del husillo; Paso del encoder"@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Parametro_NPulses
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "Número de impulsos"@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Parametro_SinMagni
    a ex:Parametro ;
    rdfs:label "SINMAGNI" ;
    ex:textoExtracto "Factor de multiplicación; 0"@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderRotativoCuadrado
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo (señales cuadradas)"@es ;
    ex:textoExtracto "Eje rotativo. Encoder rotativo. Señales cuadradas."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderRotativoSenoidal
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo (señales senoidales)"@es ;
    ex:textoExtracto "Eje rotativo. Encóder rotativo. Señales senoidales."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderLinealCuadrado
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder lineal (señales cuadradas)"@es ;
    ex:textoExtracto "Encoder lineal. Señales cuadradas."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderLinealSenoidal
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder lineal (señales senoidales)"@es ;
    ex:textoExtracto "Encóder lineal. Señales senoidales."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderRotativoLinealCuadrado
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo (eje lineal, señales cuadradas)"@es ;
    ex:textoExtracto "Eje lineal. Encoder rotativo. Señales cuadradas."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .

ex:Componente_EncoderRotativoLinealSenoidal
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo (eje lineal, señales senoidales)"@es ;
    ex:textoExtracto "Eje lineal. Encóder rotativo. Señales senoidales."@es ;
    ex:documentadoEn ex:Tabla_TiposEncoder .