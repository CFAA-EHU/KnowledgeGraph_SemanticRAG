@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HWFBACKAL
    a               ex:Parametro ;
    rdfs:label      "Parámetro HWFBACKAL" ;
    ex:identificador "V.[ch].MPA.HWFBACKAL[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.HWFBACKAL[set].xn. Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." ;
    ex:habilitadoPor ex:Alarma_CaptacionHardware .

ex:Alarma_CaptacionHardware
    a               ex:Alarma ;
    rdfs:label      "Alarma de captación por hardware" ;
    ex:textoExtracto "Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." ;
    ex:activaAlarma ex:ComponenteElectrico_ConectorAlarma .

ex:ComponenteElectrico_ConectorAlarma
    a               ex:ComponenteElectrico ;
    rdfs:label      "Conector de alarma" ;
    ex:textoExtracto "pin de alarma del conector" .