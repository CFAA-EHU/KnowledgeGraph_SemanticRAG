@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_BAKANOUT
    a ex:Parametro ;
    rdfs:label "BAKANOUT" ;
    ex:identificador "BAKANOUT" ;
    ex:textoExtracto "BAKANOUT Impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: Con regulador analógico, entre ±32767 / con regulador Sercos, entre ±1000 rpm. Valor por defecto: 0 (no se aplica)." ;
    ex:valor "0"^^xsd:string .

ex:Parametro_BAKTIME
    a ex:Parametro ;
    rdfs:label "BAKTIME" ;
    ex:identificador "BAKTIME" ;
    ex:textoExtracto "La duración de esta consigna adicional depende de los parámetros BAKTIME y PEAKDISP." .

ex:Parametro_PEAKDISP
    a ex:Parametro ;
    rdfs:label "PEAKDISP" ;
    ex:identificador "PEAKDISP" ;
    ex:textoExtracto "La duración de esta consigna adicional depende de los parámetros BAKTIME y PEAKDISP." .

ex:Variable_V_MPA_BAKANOUT
    a ex:Parametro ;
    rdfs:label "Variable (V.)[ch].MPA.BAKANOUT[set].xn" ;
    ex:identificador "(V.)[ch].MPA.BAKANOUT[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.BAKANOUT[set].xn Impulso adicional de consigna para recuperar la posible holgura del husillo en las inversiones de movimiento." .