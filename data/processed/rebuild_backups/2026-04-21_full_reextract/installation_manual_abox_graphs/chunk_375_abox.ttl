@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CompensacionHolgura_BAKANOUT a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de compensación de holgura (BAKANOUT)"@es ;
    ex:textoExtracto """
| BAKANOUT | Consigna. |
| --- | --- |
| -32767 ꞏꞏꞏ -3277 ꞏꞏꞏ 1 ꞏꞏꞏ 3277 ꞏꞏꞏ 32767 | -10 V. ꞏꞏꞏ -1 V. ꞏꞏꞏ 0,3 mV. ꞏꞏꞏ 1 V. ꞏꞏꞏ 10 V.""" ;
    ex:identificador "BAKANOUT" .

ex:Parametro_BAKANOUT
    a               ex:Parametro ;
    rdfs:label      "Parámetro BAKANOUT (consigna de compensación)"@es ;
    ex:textoExtracto "BAKANOUT | Consigna."@es ;
    ex:identificador "BAKANOUT" ;
    ex:valor         "-32767 a 32767" , "Equivalente a -10 V a 10 V" ;
    ex:documentadoEn ex:Tabla_CompensacionHolgura_BAKANOUT .