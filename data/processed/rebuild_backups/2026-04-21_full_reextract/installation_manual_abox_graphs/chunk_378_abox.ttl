@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_BAKANOUT
    a ex:Parametro ;
    rdfs:label "BAKANOUT" ;
    ex:textoExtracto "parámetro BAKANOUT distinto de cero" ;
    ex:valor "distinto de cero" .

ex:Parametro_PEAKDISP
    a ex:Parametro ;
    rdfs:label "PEAKDISP" ;
    ex:textoExtracto "El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica, a la que el CNC corta el pico de inversión en dicho eje (impulso adicional de consigna)." ;
    ex:valor "[rev/min]" .