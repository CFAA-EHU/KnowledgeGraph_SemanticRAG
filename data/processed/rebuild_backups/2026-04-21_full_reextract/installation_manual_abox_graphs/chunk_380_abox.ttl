@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REVEHYST
    a ex:Parametro ;
    rdfs:label "REVEHYST" ;
    ex:identificador "REVEHYST" ;
    ex:textoExtracto "Histéresis para aplicar el impulso adicional de consigna en las inversiones de movimiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:decimal ;
    ex:monitoreaParametro ex:Parametro_PEAKDISP .

ex:Parametro_PEAKDISP
    a ex:Parametro ;
    rdfs:label "PEAKDISP" ;
    ex:identificador "PEAKDISP" ;
    ex:textoExtracto "La captación indica la distancia parámetros PEAKDISP. Posición teórica. movimiento (PEAKDISP)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_BACKLASH
    a ex:Parametro ;
    rdfs:label "BACKLASH" ;
    ex:identificador "BACKLASH" ;
    ex:textoExtracto "En el caso de que se tengan ejes definidos como visualizador, en estos ejes se tendrá en cuenta el valor del parámetro BACKLASH." .