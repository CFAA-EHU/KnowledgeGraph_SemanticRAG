@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosAvanceG00 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de avance rápido G00 y velocidad máxima"@es ;
    ex:textoExtracto """
| Variable. | Parámetros máquina. |  | Avance. |  |
| --- | --- | --- | --- | --- |
| (V.)PLC.G00FEED | G00FEED (eje) | MAXFEED (eje) | G00 | G01, G02, ꞏꞏꞏ |
| 0 | 10000 | 0 | 10000 | 10000 |
| 0 | 10000 | 6000 | 10000 | 6000 |
| 4000 | 10000 | 6000 | 4000 | 4000 |
| 7000 | 10000 | 6000 | 7000 | 6000 |
| 12000 | 10000 | 6000 | 10000 | 6000 |
"""@es .

ex:Parametro_MAXVOLT
    a ex:Parametro ;
    rdfs:label "MAXVOLT"@es ;
    ex:identificador "MAXVOLT" ;
    ex:valor "9500" ;
    ex:textoExtracto "MAXVOLT Consigna para alcanzar G00FEED. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: De 0 a 10000.0000 mV. Valor por defecto: 9500 mV (9.5 V)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosAvanceG00 .

ex:Parametro_MAXFREQ
    a ex:Parametro ;
    rdfs:label "MAXFREQ"@es ;
    ex:identificador "MAXFREQ" ;
    ex:valor "50" ;
    ex:textoExtracto "MAXFREQ Frecuencia necesaria para alcanzar G00FEED. [...] Valores posibles: De 0.0010 a 10000.0000 Hz. Valor por defecto: 50 Hz."@es ;
    ex:documentadoEn ex:Tabla_ParametrosAvanceG00 .

ex:Parametro_MAXRPM
    a ex:Parametro ;
    rdfs:label "MAXRPM"@es ;
    ex:identificador "MAXRPM" ;
    ex:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales."@es ;
    ex:documentadoEn ex:Tabla_ParametrosAvanceG00 .

ex:Componente_MotorEje
    a ex:ComponenteMecanico ;
    rdfs:label "Motor de eje (lineal/rotativo/cabezal)"@es ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales."@es ;
    ex:monitoreaParametro ex:Parametro_MAXVOLT ;
    ex:monitoreaParametro ex:Parametro_MAXRPM .

ex:Componente_CabezalLaser
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal láser"@es ;
    ex:textoExtracto "Modelo láser. Consigna que debe proporcionar el CNC para que el cabezal alcance la potencia del generador definida en G00FEED."@es ;
    ex:monitoreaParametro ex:Parametro_MAXVOLT ;
    ex:monitoreaParametro ex:Parametro_MAXFREQ .