@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXRPM
    a ex:Parametro ;
    rdfs:label "MAXRPM" ;
    ex:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para Mechatrolink velocidad e Inverter. Valores posibles: De 0 a 100000 rpm. Valor por defecto: 3000 rpm." ;
    ex:valor "3000 rpm" ;
    ex:identificador "V.[ch].MPA.MAXRPM[set].xn" .

ex:ComponenteElectrico_Motor
    a ex:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ex:textoExtracto "Revoluciones máximas del motor" ;
    ex:monitoreaParametro ex:Parametro_MAXRPM .