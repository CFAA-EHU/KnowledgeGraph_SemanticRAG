@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FRAPIDEN
    a ex:Parametro ;
    rdfs:label "FRAPIDEN" ;
    ex:identificador "FRAPIDEN" ;
    ex:textoExtracto "FRAPIDEN Avance rápido del eje, para los desplazamientos en el modo automático. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:valor "0"^^xsd:decimal ;  # Valor por defecto
    ex:monitoreaParametro ex:Maquina_Actual .  # Relación implícita con la máquina configurada

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED. El avance rápido no podrá superar al definido en los parámetros G00FEED del eje." ;
    ex:monitoreaParametro ex:Maquina_Actual .

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal." ;
    ex:monitoreaParametro ex:Maquina_Actual .

ex:Parametro_RAPIDEN
    a ex:Parametro ;
    rdfs:label "RAPIDEN" ;
    ex:identificador "RAPIDEN" ;
    ex:textoExtracto "Avance máximo del eje para el programa en ejecución, cuando está activo el avance rápido para el modo automático (parámetro RAPIDEN)." ;
    ex:monitoreaParametro ex:Maquina_Actual .

ex:Variable_PLC_G00FEED
    a ex:Parametro ;
    rdfs:label "PLC.G00FEED" ;
    ex:identificador "PLC.G00FEED" ;
    ex:textoExtracto "El avance rápido no podrá superar [...] al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." ;
    ex:monitoreaParametro ex:Maquina_Actual .

ex:Variable_PLC_F
    a ex:Parametro ;
    rdfs:label "PLC.F" ;
    ex:identificador "PLC.F" ;
    ex:textoExtracto "El avance rápido podrá superar [...] al avance activo definido por PLC (variable (V.)PLC.F)." ;
    ex:monitoreaParametro ex:Maquina_Actual .

ex:ModoOperacion_AvanceRapidoAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático" ;
    ex:textoExtracto "FRAPIDEN Avance rápido del eje, para los desplazamientos en el modo automático." ;
    ex:controla ex:Parametro_FRAPIDEN ;
    ex:habilitadoPor ex:Parametro_RAPIDEN .

ex:Maquina_Actual
    a ex:Maquina ;
    rdfs:label "Máquina configurada" ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:tieneComponente ex:Parametro_FRAPIDEN , ex:Parametro_G00FEED , ex:Parametro_MAXFEED , ex:Parametro_RAPIDEN .