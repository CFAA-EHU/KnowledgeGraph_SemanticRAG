@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GananciaACForward
    a               ex:Parametro ;
    rdfs:label      "Ganancia AC-forward" ;
    ex:textoExtracto "Ajuste apropiado. Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro). Picos invertidos; ajuste inapropiado. Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)." ;
    ex:valor         "10 µm/cuadro (sin ganancia), 1 µm/cuadro (con ganancia)" .

ex:ModoOperacion_AjusteApropiado
    a               ex:ModoOperacion ;
    rdfs:label      "Ajuste apropiado (sin ganancia)" ;
    ex:textoExtracto "Ajuste apropiado. Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)." ;
    ex:monitoreaParametro ex:Parametro_GananciaACForward .

ex:ModoOperacion_AjusteInapropiado
    a               ex:ModoOperacion ;
    rdfs:label      "Ajuste inapropiado (con ganancia)" ;
    ex:textoExtracto "Picos invertidos; ajuste inapropiado. Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)." ;
    ex:monitoreaParametro ex:Parametro_GananciaACForward .