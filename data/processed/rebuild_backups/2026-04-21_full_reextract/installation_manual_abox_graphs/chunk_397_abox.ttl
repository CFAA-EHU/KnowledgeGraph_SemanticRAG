@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ACFWGAIN
    a               ex:Parametro ;
    rdfs:label      "Programmed ACFWGAIN"@es ;
    ex:textoExtracto "Programmed ACFWGAIN Acceleration"@es ;
    ex:monitoreaParametro ex:Sistema_ControlAceleracion .

ex:Parametro_FFGAIN
    a               ex:Parametro ;
    rdfs:label      "FFGAIN"@es ;
    ex:textoExtracto "Programmed FFGAIN Feedrate"@es ;
    ex:monitoreaParametro ex:Sistema_ControlAvance .

ex:Parametro_PROGAIN
    a               ex:Parametro ;
    rdfs:label      "PROGAIN"@es ;
    ex:textoExtracto "Analog Nominal PROGAIN output"@es ;
    ex:monitoreaParametro ex:Sistema_ControlPosicion .

ex:Parametro_ErrorSeguimiento
    a               ex:Parametro ;
    rdfs:label      "Error de seguimiento (ε)"@es ;
    ex:textoExtracto "minimizando el error de seguimiento \"\" en los arranques, frenadas y cambios de sentido"@es .

ex:Sistema_ControlAceleracion
    a               ex:Sistema ;
    rdfs:label      "Sistema de control de aceleración"@es ;
    ex:textoExtracto "mejoran la respuesta del sistema en los cambios de aceleración"@es .

ex:Sistema_ControlAvance
    a               ex:Sistema ;
    rdfs:label      "Sistema de control de avance (feedrate)"@es ;
    ex:textoExtracto "Programmed FFGAIN Feedrate"@es .

ex:Sistema_ControlPosicion
    a               ex:Sistema ;
    rdfs:label      "Sistema de control de posición"@es ;
    ex:textoExtracto "Actual position"@es .