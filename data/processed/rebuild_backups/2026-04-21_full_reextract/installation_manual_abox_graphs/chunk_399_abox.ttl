    a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" ;
    ex:identificador "LACC1" .

ex:Parametro_LACC2
    a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" ;
    ex:identificador "LACC2" .

