@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LFEED
    a ex:Parametro ;
    rdfs:label "LFEED" ;
    ex:textoExtracto "LFEED Velocidad de cambio de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "3000 mm/min / 118.11023 inch/min / 1080000 grados/min / 3000 rpm"^^xsd:string ;
    ex:monitoreaParametro ex:Parametro_LACC1, ex:Parametro_LACC2 .

ex:Parametro_LACC1
    a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:textoExtracto "Aceleración según el parámetro LACC1 hasta alcanzar el avance indicado en LFEED." ;
    ex:valor "0 a 200000.0000 mm/min / 0 a 7874.01575 inch/min / 0 a 36000000.0000 grados/min / 0 a 100000.0000 rpm"^^xsd:string .

ex:Parametro_LACC2
    a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:textoExtracto "Aceleración según el parámetro LACC2 hasta alcanzar el avance programado." ;
    ex:valor "0 a 200000.0000 mm/min / 0 a 7874.01575 inch/min / 0 a 36000000.0000 grados/min / 0 a 100000.0000 rpm"^^xsd:string .

ex:Variable_MPA_LFEED
    a ex:Parametro ;
    rdfs:label "(V.)[ch].MPA.LFEED[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.LFEED[set].xn" ;
    ex:monitoreaParametro ex:Parametro_LFEED .