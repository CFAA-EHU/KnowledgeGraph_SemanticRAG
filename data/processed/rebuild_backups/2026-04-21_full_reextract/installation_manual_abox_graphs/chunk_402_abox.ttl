ex:Tabla_ParametrosAceleracionG0 a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "G0ACDCJERK | Significado. --- | --- Sí. | Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0. No. | Los movimientos en G0 utilizan los parámetros ACCEL y DECEL." ;
    ex:documentadoEn ex:Pagina_205_207 ;
    ex:tieneComponente ex:Parametro_G0ACDCJERK ;
    ex:detalladoEnEsquema ex:Parametro_ACCELG0, ex:Parametro_DECELG0, ex:Parametro_ACCEL, ex:Parametro_DECEL .