@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ACCJERK
    a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "Jerk de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "45000.000 mm/s³ / 1771.65354 inch/s³ / 45000.000 grados/s³"^^xsd:string ;
    ex:identificador "V.[ch].MPA.ACCJERK[set].xn" .

ex:Parametro_DECJERK
    a ex:Parametro ;
    rdfs:label "DECJERK" ;
    ex:textoExtracto "Jerk de deceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:identificador "Consultar el parámetro máquina DECJERK" .

ex:Parametro_ACCEL
    a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "La aceleración pasa a ser constante y su valor es ACCEL." .

ex:Parametro_DECEL
    a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "La deceleración pasa a ser constante y su valor es DECEL." .

ex:ModoOperacion_AceleracionTrapezoidal
    a ex:ModoOperacion ;
    rdfs:label "Aceleración trapezoidal y seno cuadrado" ;
    ex:textoExtracto "1 El eje se empieza a mover con una aceleración uniformemente creciente, con una pendiente limitada por ACCJERK, hasta alcanzar la aceleración indicada en ACCEL. 2 La aceleración pasa a ser constante y su valor es ACCEL. 3 Antes de alcanzar la velocidad programada hay una aceleración uniformemente decreciente, con una pendiente limitada por ACCJERK. 4 Continúa con el avance programado y con aceleración 0. 5 Cuando se desea disminuir la velocidad o parar el eje, se aplica una deceleración, con una pendiente limitada por DECJERK. 6 La deceleración pasa a ser constante y su valor es DECEL. 7 Antes de alcanzar la velocidad programada, o pararse, hay una deceleración limitada por DECJERK." ;
    ex:monitoreaParametro ex:Parametro_ACCJERK ;
    ex:monitoreaParametro ex:Parametro_DECJERK ;
    ex:monitoreaParametro ex:Parametro_ACCEL ;
    ex:monitoreaParametro ex:Parametro_DECEL .