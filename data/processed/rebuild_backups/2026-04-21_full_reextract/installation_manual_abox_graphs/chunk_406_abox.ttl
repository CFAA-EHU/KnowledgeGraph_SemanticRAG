@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G0ACDCJERK
    a ex:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ex:textoExtracto "G0ACDCJERK | Significado." ;
    ex:identificador "G0ACDCJERK" .

ex:Parametro_ACCJERKG0
    a ex:Parametro ;
    rdfs:label "ACCJERKG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." ;
    ex:identificador "ACCJERKG0" .

ex:Parametro_DECJERKG0
    a ex:Parametro ;
    rdfs:label "DECJERKG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." ;
    ex:identificador "DECJERKG0" .

ex:Parametro_ACCJERK
    a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." ;
    ex:identificador "ACCJERK" .

ex:Parametro_DECJERK
    a ex:Parametro ;
    rdfs:label "DECJERK" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." ;
    ex:identificador "DECJERK" .

ex:Parametro_ACCJERK_ejemplo1
    a ex:Parametro ;
    rdfs:label "ACCJERK (ejemplo 1, aceleración trapezoidal)" ;
    ex:textoExtracto "ACCEL = 2 x ACCJERK = 2 x 60 x 0,5" ;
    ex:valor "60" .

ex:Parametro_ACCJERK_ejemplo2
    a ex:Parametro ;
    rdfs:label "ACCJERK (ejemplo 2, aceleración trapezoidal)" ;
    ex:textoExtracto "ACCEL = 3/2 x ACCJERK = 3/2 x 60 x 0,5" ;
    ex:valor "60" .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "el eje parado alcance G00FEED a la máxima aceleración" ;
    ex:identificador "G00FEED" .

ex:Tabla_406_parametros_aceleracion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración G0ACDCJERK" ;
    ex:textoExtracto "| G0ACDCJERK | Significado. | --- | --- | Sí. | Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. | No. | Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." ;
    ex:documentadoEn ex:Pagina_205 .

ex:Pagina_205
    a ex:Pagina ;
    ex:identificador "205" ;
    ex:ilustradoEn ex:Manual_Broaching ;
    ex:textoExtracto "Sección 2.6.9 Aceleración trapezoidal y seno cuadrado." .

