@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ACCEL
    a ex:Parametro ;
    rdfs:label "Parámetro ACCEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:monitoreaParametro ex:Movimiento_G1_G2_G3 .

ex:Parametro_DECEL
    a ex:Parametro ;
    rdfs:label "Parámetro DECEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:monitoreaParametro ex:Movimiento_G1_G2_G3 .

ex:Parametro_G0ACDCJERK
    a ex:Parametro ;
    rdfs:label "Parámetro G0ACDCJERK" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" ;
    ex:monitoreaParametro ex:Movimiento_G0 .

ex:Movimiento_G1_G2_G3
    a ex:ModoOperacion ;
    rdfs:label "Movimientos en G1, G2 y G3" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:Movimiento_G0
    a ex:ModoOperacion ;
    rdfs:label "Movimientos en G0" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

ex:Movimiento_G33_HSC_FAST
    a ex:ModoOperacion ;
    rdfs:label "Movimientos con roscado (G33) y HSC FAST" ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en los movimientos con roscado (G33) y con HSC FAST" .