@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ex:textoExtracto "Configuración del modo HSC" ;
    ex:tieneComponente ex:Parametro_CORNERACC, ex:Parametro_CURVACC, ex:Parametro_CORNERJERK,
                       ex:Parametro_CURVJERK, ex:Parametro_FASTACC, ex:Parametro_MAXERROR,
                       ex:Parametro_CONTERROR .

ex:Parametro_CORNERACC
    a ex:Parametro ;
    rdfs:label "CORNERACC" ;
    ex:textoExtracto "Aceleración máxima permitida en las esquinas." ;
    ex:valor "Aceleración máxima" .

ex:Parametro_CURVACC
    a ex:Parametro ;
    rdfs:label "CURVACC" ;
    ex:textoExtracto "Aceleración máxima permitida en curvatura." ;
    ex:valor "Aceleración máxima" .

ex:Parametro_CORNERJERK
    a ex:Parametro ;
    rdfs:label "CORNERJERK" ;
    ex:textoExtracto "Jerk máximo permitido en las esquinas." ;
    ex:valor "Jerk máximo" .

ex:Parametro_CURVJERK
    a ex:Parametro ;
    rdfs:label "CURVJERK" ;
    ex:textoExtracto "Jerk máximo permitido en curvatura." ;
    ex:valor "Jerk máximo" .

ex:Parametro_FASTACC
    a ex:Parametro ;
    rdfs:label "FASTACC" ;
    ex:textoExtracto "Aceleración máxima permitida (modo FAST)." ;
    ex:valor "Aceleración máxima" .

ex:Parametro_MAXERROR
    a ex:Parametro ;
    rdfs:label "MAXERROR" ;
    ex:textoExtracto "Error de posición." ;
    ex:valor "Error de posición" .

ex:Parametro_CONTERROR
    a ex:Parametro ;
    rdfs:label "CONTERROR" ;
    ex:textoExtracto "Tolerancia por eje." ;
    ex:valor "Tolerancia" .