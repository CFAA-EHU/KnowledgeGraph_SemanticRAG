@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CORNERJERK
    a ex:Parametro ;
    rdfs:label "CORNERJERK" ;
    ex:textoExtracto "CORNERJERK Jerk máximo permitido en las esquinas. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:valor "0"^^xsd:string ;  # Valor por defecto
    ex:identificador "V.[ch].MPA.CORNERJERK[set].xn" .

ex:Parametro_CURVJERK
    a ex:Parametro ;
    rdfs:label "CURVJERK" ;
    ex:textoExtracto "CURVJERK Jerk máximo permitido en curvatura. Parámetro válido para ejes lineales, rotativos y cabezales." .