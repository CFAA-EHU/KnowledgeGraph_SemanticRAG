@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "I0TYPE (Tipo de I0)" ;
    ex:textoExtracto "I0TYPE Tipo de I0. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No codificado / Codificado creciente / Codificado decreciente. Valor por defecto: No codificado." ;
    ex:valor "No codificado" ;
    ex:monitoreaParametro ex:Encoder_Generico .

ex:Encoder_Generico
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder (genérico)" ;
    ex:textoExtracto "Este parámetro indica como es el tipo de I0 del encoder." .