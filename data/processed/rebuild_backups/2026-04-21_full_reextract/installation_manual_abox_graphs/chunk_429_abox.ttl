@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_3753 a ex:AvisoSeguridad ;
    rdfs:label "Error 3753"@es ;
    ex:textoExtracto "mostrará el error 3753. Con este error, el usuario decide la validez de la cota."@es ;
    ex:identificador "3753" .

ex:Parametro_MAXDIFREF a ex:Parametro ;
    rdfs:label "MAXDIFREF"@es ;
    ex:textoExtracto "Si la diferencia es menor que MAXDIFREF, el CNC arranca con la nueva posición calculada por el encóder [...] Si la diferencia es mayor que MAXDIFREF, el CNC arrancará con la posición guardada"@es ;
    ex:identificador "MAXDIFREF" .

ex:Marca_REFPOIN a ex:Parametro ;
    rdfs:label "REFPOIN"@es ;
    ex:textoExtracto "el CNC [...] pone la marca de PLC REFPOIN = 1"@es ;
    ex:identificador "REFPOIN" ;
    ex:valor "1" .