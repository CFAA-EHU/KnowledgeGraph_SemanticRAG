@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EncoderLinealFagorFox
    a               ex:Sensor ;
    rdfs:label      "Encoder lineal Fagor FOX"@es ;
    ex:identificador "FOX" ;
    ex:textoExtracto "El transductor lineal Fagor \"FOX\" dispone de un periodo de gramaje del cristal de 100 µm y de un periodo de señal de contaje de 4 µm."@es ;
    ex:monitoreaParametro ex:ParametroPeriodoGramajeFox, ex:ParametroPeriodoSenalFox .

ex:ParametroPeriodoGramajeFox
    a               ex:Parametro ;
    rdfs:label      "Periodo de gramaje del cristal (Encoder FOX)"@es ;
    ex:valor         "100 µm" ;
    ex:textoExtracto "periodo de gramaje del cristal de 100 µm"@es .

ex:ParametroPeriodoSenalFox
    a               ex:Parametro ;
    rdfs:label      "Periodo de señal de contaje (Encoder FOX)"@es ;
    ex:valor         "4 µm" ;
    ex:textoExtracto "periodo de señal de contaje de 4 µm"@es .

ex:ParametroEXTMULT
    a               ex:Parametro ;
    rdfs:label      "EXTMULT (Encoder Fagor)"@es ;
    ex:valor         "25" ;
    ex:textoExtracto "EXTMULT = 100 / 4 = 25"@es .

ex:TablaValoresEncoderFagor a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Valores EXTMULT para encoders Fagor con señal I0 codificada"@es ;
    ex:textoExtracto "Valores que se deben asignar para los encóder Fagor con señal I0 codificada."@es ;
    ex:documentadoEn ex:ManualBrochado ;
    ex:ilustradoEn  ex:Pagina_214_218 .

ex:EncoderRotativo_HOSO_90k
    a               ex:Sensor ;
    rdfs:label      "Encoder rotativo Fagor HO SO 90.000 impulsos"@es ;
    ex:identificador "HO SO 90.000 imp" ;
    ex:textoExtracto "HO SO 90.000 imp|ulsos."@es ;
    ex:monitoreaParametro ex:ParametroEXTMULT_90k .

ex:ParametroEXTMULT_90k
    a               ex:Parametro ;
    rdfs:label      "EXTMULT para HO SO 90.000 impulsos"@es ;
    ex:valor         "5" ;
    ex:textoExtracto "HO SO 90.000 imp|ulsos. | 5"@es .

ex:EncoderRotativo_HOSO_180k
    a               ex:Sensor ;
    rdfs:label      "Encoder rotativo Fagor HO SO 180.000 impulsos"@es ;
    ex:identificador "HO SO 180.000 imp" ;
    ex:textoExtracto "HO SO 180.000 im|pulsos."@es ;
    ex:monitoreaParametro ex:ParametroEXTMULT_180k .

ex:ParametroEXTMULT_180k
    a               ex:Parametro ;
    rdfs:label      "EXTMULT para HO SO 180.000 impulsos"@es ;
    ex:valor         "10" ;
    ex:textoExtracto "HO SO 180.000 im|pulsos. | 10"@es .

ex:EncoderRotativo_HOPSOP_18k
    a               ex:Sensor ;
    rdfs:label      "Encoder rotativo Fagor HOP SOP 18.000 impulsos"@es ;
    ex:identificador "HOP SOP 18.000 imp" ;
    ex:textoExtracto "HOP SOP 18.000 imp|ulsos."@es ;
    ex:monitoreaParametro ex:ParametroEXTMULT_18k .

ex:ParametroEXTMULT_18k
    a               ex:Parametro ;
    rdfs:label      "EXTMULT para HOP SOP 18.000 impulsos"@es ;
    ex:valor         "1" ;
    ex:textoExtracto "HOP SOP 18.000 imp|ulsos. | 1"@es .

ex:ParametroI0CODDI1
    a               ex:Parametro ;
    rdfs:label      "I0CODDI1 (Paso entre I0 codificados fijos)"@es ;
    ex:textoExtracto "I0CODDI1 Paso entre 2 I0 codificados fijos. Parámetro válido para ejes lineales, rotativos y cabezales. Valor por defecto: 1000."@es ;
    ex:valor         "1000" .

ex:ParametroI0CODDI2
    a               ex:Parametro ;
    rdfs:label      "I0CODDI2 (Paso entre I0 codificados variables)"@es ;
    ex:textoExtracto "I0CODDI2 Paso entre 2 I0 codificados variables. Parámetro válido para ejes lineales, rotativos y cabezales. Valor por defecto: 1001."@es ;
    ex:valor         "1001" .