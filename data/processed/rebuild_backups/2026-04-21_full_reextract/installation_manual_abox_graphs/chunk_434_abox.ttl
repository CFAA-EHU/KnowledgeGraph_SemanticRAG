@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_I0CODDI2
    a ex:Parametro ;
    rdfs:label "Parámetro I0CODDI2" ;
    ex:identificador "I0CODDI2" ;
    ex:valor "1001" ;
    ex:textoExtracto "Valor por defecto: 1001. Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn"@es .

ex:Parametro_EXTMULT
    a ex:Parametro ;
    rdfs:label "Parámetro EXTMULT (multiplicador externo)" ;
    ex:textoExtracto "Número de ondas entre I0 fijos = 20000/(20 x EXTMULT) = 1000"@es .

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "Parámetro I0TYPE" ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado."@es .

ex:Tabla_ValoresEncoderFagor a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores para encóder Fagor con señal I0 codificada" ;
    ex:textoExtracto "Valores que se deben asignar para los encóder Fagor con señal I0 codificada."@es ;
    ex:documentadoEn ex:Manual_CNC .

ex:ComponenteElectrico_EncoderLinealFagor
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder lineal Fagor" ;
    ex:textoExtracto "Ejemplo con encóder lineal Fagor."@es ;
    ex:monitoreaParametro ex:Parametro_I0CODDI2 ;
    ex:detalladoEnEsquema ex:Tabla_ValoresEncoderFagor .

ex:ComponenteElectrico_EncoderRotativoFagor
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo Fagor" ;
    ex:textoExtracto "Encoder rotativo. Valores para 90.000, 180.000 y 18.000 impulsos."@es ;
    ex:monitoreaParametro ex:Parametro_I0CODDI1 ;
    ex:monitoreaParametro ex:Parametro_I0CODDI2 ;
    ex:detalladoEnEsquema ex:Tabla_ValoresEncoderFagor .

ex:Parametro_I0CODDI1
    a ex:Parametro ;
    rdfs:label "Parámetro I0CODDI1" ;
    ex:identificador "I0CODDI1" ;
    ex:valor "1000" ;
    ex:textoExtracto "I0CODDI1 | I0CODDI2 --- | --- 1000 | 1001"@es .