@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FLWEMONITOR
    a ex:Parametro ;
    rdfs:label "Parámetro de seguimiento MPA.MINFLWE"@es ;
    ex:identificador "V.[ch].MPA.MINFLWE[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn. El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR"@es ;
    ex:valor "1.0000 mm / 0.03937 inch / 1.0000 grados" ;
    .