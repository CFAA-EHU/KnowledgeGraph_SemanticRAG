@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SERVOOFF
    a ex:Parametro ;
    rdfs:label "SERVOOFF" ;
    ex:identificador "SERVOOFF" ;
    ex:valor "-32767 a 32767" ;
    ex:textoExtracto "SERVOOFF Compensación del offset. [...] Valores posibles: Entre ±32767. Valor por defecto: 0. [...] correspondiendo para el valor ±32767 la consigna de ±10 V." ;
    ex:monitoreaParametro ex:Sistema_ReguladorAnalogico .

ex:Parametro_MINANOUT
    a ex:Parametro ;
    rdfs:label "MINANOUT" ;
    ex:identificador "MINANOUT" ;
    ex:valor "0 a 32767" ;
    ex:textoExtracto "MINANOUT Consigna mínima. [...] Valores posibles: De 0 a 32767. Valor por defecto: 0. [...] correspondiendo para el valor 32767 la consigna de 10 V." ;
    ex:monitoreaParametro ex:Sistema_ReguladorAnalogico .

ex:Sistema_ReguladorAnalogico
    a ex:Sistema ;
    rdfs:label "Regulador analógico" ;
    ex:textoExtracto "Parámetro válido para regulador analógico. [...] Variable asociada: (V.)[ch].MPA.SERVOOFF[set].xn ; (V.)[ch].MPA.MINANOUT[set].xn" .

ex:Tabla_ConsignasSERVOOFF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de consignas SERVOOFF" ;
    ex:textoExtracto "| SERVOOFF | Consigna. | --- | --- | -32767 ꞏꞏꞏ 32767 | -10 V. ꞏꞏꞏ 10 V. |" ;
    ex:documentadoEn ex:Pagina_225 .

ex:Tabla_ConsignasMINANOUT a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de consignas MINANOUT" ;
    ex:textoExtracto "| MINANOUT | Consigna. | --- | --- | 1 ꞏꞏꞏ 32767 | 0,3 mV. ꞏꞏꞏ 10 V. |" ;
    ex:documentadoEn ex:Pagina_225 .

ex:Pagina_225
    a ex:Pagina ;
    rdfs:label "Página 225" ;
    ex:identificador "225" ;
    ex:textoExtracto "Sección 2.6.19 Configuración de la consigna analógica." .