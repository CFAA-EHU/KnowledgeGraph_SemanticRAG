@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ANAOUTTYPE
    a ex:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ex:textoExtracto "Tipo de salida analógica asociada al eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto CAN." ;
    ex:valor "Remoto CAN" .

ex:ANAOUTID
    a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Número de la salida analógica asociada al eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Módulos remotos, de 1 a 16 / Regulador Sercos, de 101 a 132 ó de 201 a 232 / Contadora Sercos, de 1 a 32. Valor por defecto: 0." ;
    ex:valor "0" .

ex:ModuloRemotoCAN
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto CAN" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los módulos remotos CAN. Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." .

ex:ReguladorSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ex:textoExtracto "Regulador Sercos, de 101 a 132 ó de 201 a 232." .

ex:ContadoraSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (RCS-S)" ;
    ex:textoExtracto "Contadora Sercos, de 1 a 32." .

ex:ANAOUTTYPE
    ex:monitoreaParametro ex:ANAOUTID .

ex:ModuloRemotoCAN
    ex:tieneComponente ex:ANAOUTID .

ex:ReguladorSercos
    ex:tieneComponente ex:ANAOUTID .

ex:ContadoraSercos
    ex:tieneComponente ex:ANAOUTID .