@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_107
    a ex:Parametro ;
    rdfs:label "Parámetro de salida analógica 107" ;
    ex:identificador "107" ;
    ex:textoExtracto "si el parámetro se define con el valor ꞏ107ꞏ, indica que se utiliza la entrada analógica ꞏ1ꞏ del regulador cuya dirección lógica es ꞏ7ꞏ" ;
    ex:valor "107" .

ex:Parametro_OP1
    a ex:Parametro ;
    rdfs:label "Parámetro OP1 del regulador" ;
    ex:identificador "OP1" ;
    ex:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ex:valor "0" .

ex:Parametro_OP2
    a ex:Parametro ;
    rdfs:label "Parámetro OP2 del regulador" ;
    ex:identificador "OP2" ;
    ex:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ex:valor "0" .

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "Parámetro COUNTERTYPE (Tipo de entrada de captación del eje)" ;
    ex:identificador "COUNTERTYPE" ;
    ex:textoExtracto "COUNTERTYPE Tipo de entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto." ;
    ex:valor "Remoto" .

ex:Variable_V_G_ANAO_107
    a ex:Parametro ;
    rdfs:label "Variable V.G.ANAO[107]" ;
    ex:identificador "V.G.ANAO[107]" ;
    ex:textoExtracto "para consultar la tensión en esa salida hay que escribir la variable de la forma V.G.ANAO[107]" ;
    ex:valor "V.G.ANAO[107]" .

ex:Variable_MPA_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "Variable asociada (V.)[ch].MPA.COUNTERTYPE[set].xn" ;
    ex:identificador "(V.)[ch].MPA.COUNTERTYPE[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.COUNTERTYPE[set].xn" .