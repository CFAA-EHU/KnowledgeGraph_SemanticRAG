@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FEEDBACKTYPE
    a               ex:Parametro ;
    rdfs:label      "FEEDBACKTYPE" ;
    ex:textoExtracto "tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE)" ;
    ex:valor        "FeeDat, EnDat" .

ex:Parametro_ENCODERINFO
    a               ex:Parametro ;
    rdfs:label      "ENCODERINFO" ;
    ex:textoExtracto "ENCODERINFO Información del encóder. Cuando el tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE), este parámetro muestra una tabla de parámetros con la información del encóder." ;
    ex:monitoreaParametro ex:Parametro_FEEDBACKTYPE .

ex:Tabla_ParametrosEncoder a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros del encóder" ;
    ex:textoExtracto "este parámetro muestra una tabla de parámetros con la información del encóder" ;
    ex:documentadoEn ex:Parametro_ENCODERINFO .