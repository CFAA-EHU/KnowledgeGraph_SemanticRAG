@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosEncoder_458 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros del encóder (pág. 230-231)" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | NAME | Nomenclatura del encóder. | TYPE | Tipo de encóder. | RESOLUTION | Resolución del encóder. | SERIALNUMBER | Número de serie del encóder. | DATALENGTH | Número de bits que constituyen el dato en la transmisión." ;
    ex:tieneComponente
        ex:Parametro_NAME_458 ,
        ex:Parametro_TYPE_458 ,
        ex:Parametro_RESOLUTION_458 ,
        ex:Parametro_SERIALNUMBER_458 ,
        ex:Parametro_DATALENGTH_458 .

ex:Parametro_NAME_458
    a ex:Parametro ;
    rdfs:label "NAME" ;
    ex:identificador "NAME" ;
    ex:textoExtracto "Nomenclatura del encóder." .

ex:Parametro_TYPE_458
    a ex:Parametro ;
    rdfs:label "TYPE" ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "Tipo de encóder." .

ex:Parametro_RESOLUTION_458
    a ex:Parametro ;
    rdfs:label "RESOLUTION" ;
    ex:identificador "RESOLUTION" ;
    ex:textoExtracto "Resolución del encóder." .

ex:Parametro_SERIALNUMBER_458
    a ex:Parametro ;
    rdfs:label "SERIALNUMBER" ;
    ex:identificador "SERIALNUMBER" ;
    ex:textoExtracto "Número de serie del encóder." .

ex:Parametro_DATALENGTH_458
    a ex:Parametro ;
    rdfs:label "DATALENGTH" ;
    ex:identificador "DATALENGTH" ;
    ex:textoExtracto "Número de bits que constituyen el dato en la transmisión." .