@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametroEncoder_DATALENGTH
    a ex:Parametro ;
    rdfs:label "DATALENGTH (Número de bits del encóder)"@es ;
    ex:textoExtracto "parámetro del encóder. DATALENGTH Número de bits que constituyen el dato en la transmisión."@es ;
    ex:identificador "DATALENGTH" ;
    ex:valor "Variable asociada (valor guardado): (V.)[ch].MPA.DE_DATALENGTH[set].xn ; Variable asociada (valor leído): (V.)[ch].A.CDE_DATALENGTH[set].xn"@es ;
    ex:monitoreaParametro ex:Encoder .