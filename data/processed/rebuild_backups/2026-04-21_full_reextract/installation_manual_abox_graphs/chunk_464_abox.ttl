@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSICLKFREQ
    a ex:Parametro ;
    rdfs:label "SSICLKFREQ" ;
    ex:identificador "SSICLKFREQ" ;
    ex:valor "400" ;
    ex:textoExtracto "SSICLKFREQ = 1 / T = 400. | 400 kHz." ;
    ex:textoExtracto "SSICLKFREQ Frecuencia para la comunicación SSI. Valores posibles: De 59 a 7500 kHz. Valor por defecto: 150 kHz." .

ex:Parametro_SSIDATALENGTH
    a ex:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ex:identificador "SSIDATALENGTH" ;
    ex:textoExtracto "SSIDATALENGTH = n | Longitud de bits de la cota." .

ex:Parametro_SSICRCBITS
    a ex:Parametro ;
    rdfs:label "SSICRCBITS" ;
    ex:identificador "SSICRCBITS" ;
    ex:valor "0" ;
    ex:textoExtracto "SSICRCBITS = 0 | No hay bits de CRC." .

ex:Parametro_SSISTARTBITS
    a ex:Parametro ;
    rdfs:label "SSISTARTBITS" ;
    ex:identificador "SSISTARTBITS" ;
    ex:valor "0" ;
    ex:textoExtracto "SSISTARTBITS = 0 | No hay bits de start." .

ex:Parametro_SSIPACKFORMAT
    a ex:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ex:identificador "SSIPACKFORMAT" ;
    ex:valor "3" ;
    ex:textoExtracto "SSIPACKFORMAT = 3 | Data + Alarm." .

ex:Parametro_SSIALARMBITS
    a ex:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ex:identificador "SSIALARMBITS" ;
    ex:valor "1" ;
    ex:textoExtracto "SSIALARMBITS = 1 | 1 bit de alarma/acknowledge." .

ex:Parametro_SSIDATAMODE
    a ex:Parametro ;
    rdfs:label "SSIDATAMODE" ;
    ex:identificador "SSIDATAMODE" ;
    ex:valor "1" ;
    ex:textoExtracto "SSIDATAMODE = 1 | MSB Primero." .

ex:Parametro_SSIALARMLEVEL
    a ex:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ex:identificador "SSIALARMLEVEL" ;
    ex:valor "1" ;
    ex:textoExtracto "SSIALARMLEVEL = 1 | El acknowledge se indica con data a 0; por tanto, se produce una señal de alarma cuando el bit es un 1." .

ex:Tabla_FrecuenciasMaximasSSI a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Frecuencias máximas recomendadas para comunicación SSI según longitud de cable" ;
    ex:textoExtracto "Longitud. | Frecuencia máxima. --- | --- Hasta 20 metros. | 600 kHz. Hasta 50 metros. | 400 kHz. Hasta 75 metros. | 300 kHz. Hasta 100 metros. | 250 kHz." .

ex:Sistema_ComunicacionSSI_FagorLA
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación SSI para regla absoluta Fagor LA" ;
    ex:textoExtracto "Ejemplo para regla absoluta Fagor (Fagor LA). Ejemplo de parametrización para la conexión de la regla absoluta Fagor LA, configurada con los parámetros por defecto con los que sale de fábrica." ;
    ex:tieneComponente ex:Parametro_SSICLKFREQ , ex:Parametro_SSIDATALENGTH , ex:Parametro_SSICRCBITS ,
                      ex:Parametro_SSISTARTBITS , ex:Parametro_SSIPACKFORMAT , ex:Parametro_SSIALARMBITS ,
                      ex:Parametro_SSIDATAMODE , ex:Parametro_SSIALARMLEVEL ;
    ex:detalladoEnEsquema ex:Tabla_FrecuenciasMaximasSSI .