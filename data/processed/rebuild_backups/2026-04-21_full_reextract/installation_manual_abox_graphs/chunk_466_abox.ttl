@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSIALARMLEVEL
    a ex:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ex:textoExtracto "Valores que pueden provocar que el encoder transmita uno o más bits indicando algún tipo de error." ;
    ex:identificador "SSIALARMLEVEL" .

ex:Parametro_SSICRCTYPE
    a ex:Parametro ;
    rdfs:label "SSICRCTYPE" ;
    ex:textoExtracto "Tipo de cálculo a realizar cuando el encoder transmita información adicional a la cota para realizar algún tipo de comprobación de coherencia en los datos." ;
    ex:identificador "SSICRCTYPE" .

ex:Parametro_SSIDATALENGTH
    a ex:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ex:textoExtracto "Número de bits de la transmisión SSI que constituyen la cota. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ex:identificador "SSIDATALENGTH" ;
    ex:valor "0" .

ex:Parametro_SSIPACKFORMAT
    a ex:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ex:textoExtracto "Formato de paquete SSI. [...] Este parámetro indica en que orden van a llegar los diferentes tipos de datos que constituyen la transmisión SSI." ;
    ex:identificador "SSIPACKFORMAT" ;
    ex:valor "Data" .

ex:Parametro_SSIOPERATION
    a ex:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ex:textoExtracto "Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1." ;
    ex:identificador "SSIOPERATION" .

ex:Tabla_ParametrosSSI a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros SSI (Tipo de captación SSI)" ;
    ex:textoExtracto "| Parámetro. | Significado. | [...] SSIPACKFORMAT [...] SSIOPERATION [...]" ;
    ex:documentadoEn ex:Pagina_232_236 ;
    ex:tieneComponente ex:Parametro_SSIALARMLEVEL ;
    ex:tieneComponente ex:Parametro_SSICRCTYPE ;
    ex:tieneComponente ex:Parametro_SSIDATALENGTH ;
    ex:tieneComponente ex:Parametro_SSIPACKFORMAT ;
    ex:tieneComponente ex:Parametro_SSIOPERATION .

ex:Pagina_232_236
    a ex:Pagina ;
    rdfs:label "Páginas 232-236 (Sección 2.6.25 Tipo de captación SSI)" ;
    ex:textoExtracto "Sección 2.6.25 Tipo de captación SSI." .