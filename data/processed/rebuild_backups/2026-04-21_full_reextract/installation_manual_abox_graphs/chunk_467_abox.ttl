@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSIOPERATION
    a ex:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ex:textoExtracto "SSIOPERATION Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SSIOPRATION[set].xn" ;
    ex:identificador "SSIOPERATION" ;
    ex:valor "0-1" .