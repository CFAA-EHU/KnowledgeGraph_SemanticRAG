@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSICRCTYPE
    a ex:Parametro ;
    rdfs:label "SSICRCTYPE (Tipo de CRC)"@es ;
    ex:textoExtracto "SSICRCTYPE Tipo de CRC. Valores posibles: No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN. Valor por defecto: No calcular CRC."@es ;
    ex:valor "No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN"@es ;
    ex:identificador "SSICRCTYPE" .

ex:Parametro_SSICRCBITS
    a ex:Parametro ;
    rdfs:label "SSICRCBITS"@es ;
    ex:textoExtracto "Este parámetro sólo tiene sentido en el caso de que SSICRCBITS sea distinto de 0."@es ;
    ex:identificador "SSICRCBITS" .

ex:Tabla_FormatoDatosSSI a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de formatos de datos SSI"@es ;
    ex:textoExtracto "| Valor. | Significado. | --- | --- | 0 | Los datos llegan en formato binario. | 1 | Los datos llegan en formato Gray Code."@es ;
    ex:documentadoEn ex:Manual_Broaching .

ex:Variable_V_MPA_SSICRCTYPE
    a ex:Parametro ;
    rdfs:label "(V.)[ch].MPA.SSICRCTYPE[set].xn"@es ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.SSICRCTYPE[set].xn"@es ;
    ex:identificador "(V.)[ch].MPA.SSICRCTYPE[set].xn" .