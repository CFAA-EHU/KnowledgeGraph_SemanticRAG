@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionVolantes_238_239
    a ex:Tabla ;
    rdfs:label "Tabla de configuración de volantes (pág. 238-239)"@es ;
    ex:textoExtracto """
| Orden del teclado. | Numeración de los volantes. |
| --- | --- |
| Primer teclado en el bus. | -1 -2 -3 |
| Segundo teclado en el bus. | -4 -5 -6 |
| Tercer teclado en el bus. | -7 -8 -9
"""@es ;
    ex:documentadoEn ex:Pagina_238_239_ModoManual .

ex:Pagina_238_239_ModoManual
    a ex:Pagina ;
    rdfs:label "Páginas 238-239: 2.7.1 Configuración de los volantes"@es ;
    ex:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes."@es .

ex:InterfazUsuario_PrimerTecladoBus
    a ex:InterfazUsuario ;
    rdfs:label "Primer teclado en el bus"@es ;
    ex:identificador "1-2-3" ;
    ex:textoExtracto "Primer teclado en el bus. | -1 -2 -3"@es ;
    ex:ilustradoEn ex:Tabla_ConfiguracionVolantes_238_239 .

ex:InterfazUsuario_SegundoTecladoBus
    a ex:InterfazUsuario ;
    rdfs:label "Segundo teclado en el bus"@es ;
    ex:identificador "4-5-6" ;
    ex:textoExtracto "Segundo teclado en el bus. | -4 -5 -6"@es ;
    ex:ilustradoEn ex:Tabla_ConfiguracionVolantes_238_239 .

ex:InterfazUsuario_TercerTecladoBus
    a ex:InterfazUsuario ;
    rdfs:label "Tercer teclado en el bus"@es ;
    ex:identificador "7-8-9" ;
    ex:textoExtracto "Tercer teclado en el bus. | -7 -8 -9"@es ;
    ex:ilustradoEn ex:Tabla_ConfiguracionVolantes_238_239 .