@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HWFBTYPE
    a ex:Parametro ;
    rdfs:label "HWFBTYPE" ;
    ex:textoExtracto "HWFBTYPE Tipo de captación asociada a la entrada del volante. Valores posibles: TTL / TTLDIFF. Valor por defecto: TTLDIFF." ;
    ex:valor "TTLDIFF" .

ex:Parametro_MPGAXIS
    a ex:Parametro ;
    rdfs:label "MPGAXIS" ;
    ex:textoExtracto "MPGAXIS Nombre del eje asociado al volante. Valores posibles: Cualquier eje definido en AXISNAME. [...] Para definir un volante individual, definir el nombre del eje al que está asociado. Para definir un volante general, no asignar ningún valor al parámetro, dejarlo en blanco." .

ex:Tabla_MANPG a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANPG" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANPG." ;
    ex:documentadoEn ex:Manual_ModoManual .

ex:Manual_ModoManual
    a ex:Manual ;
    rdfs:label "Sección 2.7 Parámetros máquina del modo manual" ;
    ex:textoExtracto "Volantes conectados a través de los grupos remotos CAN. [...] Volantes conectados a través de una entrada 'Variable'." ;
    ex:tieneComponente ex:Tabla_MANPG .

ex:Sistema_CAN
    a ex:Sistema ;
    rdfs:label "Sistema de grupos remotos CAN" ;
    ex:textoExtracto "Volantes conectados a través de los grupos remotos CAN. Los volantes se numeran de 1 a 40." ;
    ex:detalladoEnEsquema ex:Manual_ModoManual .

ex:Sistema_RCS_S
    a ex:Sistema ;
    rdfs:label "Sistema RCS-S (contadora Sercos)" ;
    ex:textoExtracto "Volantes conectados a través de los módulos RCS-S (contadora Sercos). Los volantes se numeran de 1 a 32." ;
    ex:detalladoEnEsquema ex:Manual_ModoManual ;
    ex:identificador "SERCOUNTID" .

ex:Interfaz_HBH3_HBH4
    a ex:InterfazUsuario ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ex:textoExtracto "El terminal remoto HBH3/HBH4 siempre tendrá valor ꞏ1ꞏ. [...] Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir." ;
    ex:documentadoEn ex:Manual_ModoManual .