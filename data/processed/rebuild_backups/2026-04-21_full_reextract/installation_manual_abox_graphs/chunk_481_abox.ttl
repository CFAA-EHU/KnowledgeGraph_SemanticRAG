@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_JOGKEYDEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla JOGKEYDEF" ;
    ex:textoExtracto "Tablas para configurar las teclas de jog. [...] Hay disponible una tabla para cada teclado de jog." ;
    ex:documentadoEn ex:Pagina_240 .

ex:Tabla_JOGKEYBD2DEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla JOGKEYBD2DEF" ;
    ex:textoExtracto "JOGKEYBD2DEF n [...] Hay disponible una tabla para cada teclado de jog." ;
    ex:documentadoEn ex:Pagina_240 .

ex:Tabla_JOGKEYBD8DEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla JOGKEYBD8DEF" ;
    ex:textoExtracto "JOGKEYBD8DEF n [...] Hay disponible una tabla para cada teclado de jog." ;
    ex:documentadoEn ex:Pagina_240 .

ex:Parametro_JOGKEYDEF
    a ex:Parametro ;
    rdfs:label "JOGKEYDEF" ;
    ex:identificador "JOGKEYDEF" ;
    ex:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog. [...] Variable asociada: (V.)MPMAN.JOGKEYDEF[jk]" ;
    ex:documentadoEn ex:Tabla_JOGKEYDEF ;
    ex:valor "1- a 10+, 1 a 10, R, +, -" .

ex:Parametro_JOGKEYBD2DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD2DEF" ;
    ex:identificador "JOGKEYBD2DEF" ;
    ex:textoExtracto "JOGKEYBD2DEF al segundo [panel de jog]." ;
    ex:documentadoEn ex:Tabla_JOGKEYBD2DEF ;
    ex:valor "1- a 10+, 1 a 10, R, +, -" .

ex:Parametro_JOGKEYBD8DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD8DEF" ;
    ex:identificador "JOGKEYBD8DEF" ;
    ex:textoExtracto "JOGKEYBD8DEF n [...] El número de teclas de jog disponibles depende del tipo teclado." ;
    ex:documentadoEn ex:Tabla_JOGKEYBD8DEF ;
    ex:valor "1- a 10+, 1 a 10, R, +, -" .

ex:InterfazUsuario_PanelJog1
    a ex:InterfazUsuario ;
    rdfs:label "Primer panel de jog" ;
    ex:textoExtracto "El primer panel de jog será el de numeración más baja [...] según el orden que ocupan dentro del bus CAN." ;
    ex:tieneComponente ex:Parametro_JOGKEYDEF .

ex:InterfazUsuario_PanelJog2
    a ex:InterfazUsuario ;
    rdfs:label "Segundo panel de jog" ;
    ex:textoExtracto "JOGKEYBD2DEF al segundo [panel de jog]." ;
    ex:tieneComponente ex:Parametro_JOGKEYBD2DEF .

ex:InterfazUsuario_PanelJog8
    a ex:InterfazUsuario ;
    rdfs:label "Octavo panel de jog" ;
    ex:textoExtracto "JOGKEYBD8DEF n [...] El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN." ;
    ex:tieneComponente ex:Parametro_JOGKEYBD8DEF .

ex:Pagina_240
    a ex:Pagina ;
    rdfs:label "Página 240" ;
    ex:identificador "240" ;
    ex:textoExtracto "JOGKEYDEF JOGKEYBD2DEF JOGKEYBD8DEF Tablas para configurar las teclas de jog." .

ex:Pagina_241
    a ex:Pagina ;
    rdfs:label "Página 241" ;
    ex:identificador "241" ;
    ex:textoExtracto "El número de teclas de jog disponibles depende del tipo teclado, que en algunos casos puede tener hasta 15 teclas." .