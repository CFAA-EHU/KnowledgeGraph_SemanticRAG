@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TerminalRemoto_HBH3_HBH4
    a               ex:ComponenteElectrico ;
    rdfs:label      "Terminal remoto HBH3/HBH4" ;
    ex:textoExtracto "Para obtener más información sobre el terminal remoto HBH3/HBH4, consultar su manual." .

ex:Parametro_HBHIP
    a               ex:Parametro ;
    rdfs:label      "HBHIP (Dirección IP del volante HBH)" ;
    ex:identificador "HBHIP" ;
    ex:valor         "0" ;
    ex:textoExtracto "HBHIP Dirección IP del volante HBH. Valores posibles: De 0 a 15 caracteres. Valor por defecto: 0. Variable asociada: (V.)MPMAN.HBHIP Dirección IP del volante HBH." ;
    ex:monitoreaParametro ex:TerminalRemoto_HBH3_HBH4 .