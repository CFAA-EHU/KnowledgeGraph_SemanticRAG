@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:VolanteEjeX
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Volante individual del eje X"@es ;
    ex:textoExtracto    "Volante individual del eje X. Entrada captación: Teclado (MPG1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (X): 0.001, 0.01, 0.1"@es ;
    ex:identificador    "MPG1" ;
    ex:tieneComponente  ex:DiscoGraduadoVolanteX ;
    ex:controla        ex:EjeX .

ex:VolanteEjeY
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Volante individual del eje Y"@es ;
    ex:textoExtracto    "Volante individual del eje Y. Entrada captación: Teclado (MPG2). Disco graduado de 100 posiciones. Impulsos/vuelta: 200 Resoluciones (Y): 0.001, 0.01, 0.1"@es ;
    ex:identificador    "MPG2" ;
    ex:tieneComponente  ex:DiscoGraduadoVolanteY ;
    ex:controla        ex:EjeY .

ex:VolanteGeneralZA
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Volante general para ejes Z, A"@es ;
    ex:textoExtracto    "Volante general para el resto de ejes (Z, A). Entrada captación: Contador (X1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (Z): 0.001, 0.01, 0.1 Resoluciones (A): 0.01, 0.1, 1"@es ;
    ex:identificador    "X1" ;
    ex:tieneComponente  ex:DiscoGraduadoVolanteZA ;
    ex:controla        ex:EjeZ, ex:EjeA .

ex:DiscoGraduadoVolanteX
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Disco graduado de 100 posiciones (Volante X)"@es ;
    ex:textoExtracto    "Disco graduado de 100 posiciones. Impulsos/vuelta: 100"@es ;
    ex:valor            "100"^^xsd:integer .

ex:DiscoGraduadoVolanteY
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Disco graduado de 100 posiciones (Volante Y)"@es ;
    ex:textoExtracto    "Disco graduado de 100 posiciones. Impulsos/vuelta: 200"@es ;
    ex:valor            "100"^^xsd:integer .

ex:DiscoGraduadoVolanteZA
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Disco graduado de 100 posiciones (Volante ZA)"@es ;
    ex:textoExtracto    "Disco graduado de 100 posiciones. Impulsos/vuelta: 100"@es ;
    ex:valor            "100"^^xsd:integer .

ex:EjeX
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Eje X"@es ;
    ex:textoExtracto    "Eje X"@es .

ex:EjeY
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Eje Y"@es ;
    ex:textoExtracto    "Eje Y"@es .

ex:EjeZ
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Eje Z"@es ;
    ex:textoExtracto    "Eje Z"@es .

ex:EjeA
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Eje A"@es ;
    ex:textoExtracto    "Eje A"@es .

ex:ParametroNMPG
    a                   ex:Parametro ;
    rdfs:label          "Número de volantes (NMPG)"@es ;
    ex:textoExtracto    "NMPG | 3 | Sistema con 3 volantes."@es ;
    ex:identificador    "NMPG" ;
    ex:valor            "3"^^xsd:integer .

ex:ParametroCOUNTERTYPE_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Tipo de contador (COUNTERTYPE) para volante X"@es ;
    ex:textoExtracto    "COUNTERTYPE | Teclado | Volante conectado al teclado."@es ;
    ex:identificador    "COUNTERTYPE" ;
    ex:valor            "Teclado"@es .

ex:ParametroCOUNTERID_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Identificador de conector (COUNTERID) para volante X"@es ;
    ex:textoExtracto    "COUNTERID | -1 | Conector MPG1."@es ;
    ex:identificador    "COUNTERID" ;
    ex:valor            "-1"^^xsd:integer .

ex:ParametroMPGAXIS_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Eje asociado (MPGAXIS) para volante X"@es ;
    ex:textoExtracto    "MPGAXIS | X | Eje asociado."@es ;
    ex:identificador    "MPGAXIS" ;
    ex:valor            "X"@es .

ex:ParametroMPGRESOL1_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Resolución 1 (MPGRESOL 1) para volante X"@es ;
    ex:textoExtracto    "MPGRESOL 1 | 0.001 | Resolución 0.001"@es ;
    ex:identificador    "MPGRESOL_1" ;
    ex:valor            "0.001"^^xsd:decimal .

ex:ParametroMPGRESOL10_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Resolución 10 (MPGRESOL 10) para volante X"@es ;
    ex:textoExtracto    "MPGRESOL 10 | 0.01 | Resolución 0.01"@es ;
    ex:identificador    "MPGRESOL_10" ;
    ex:valor            "0.01"^^xsd:decimal .

ex:ParametroMPGRESOL100_VolanteX
    a                   ex:Parametro ;
    rdfs:label          "Resolución 100 (MPGRESOL 100) para volante X"@es ;
    ex:textoExtracto    "MPGRESOL 100 | 0.1 | Resolución 0.1"@es ;
    ex:identificador    "MPGRESOL_100" ;
    ex:valor            "0.1"^^xsd:decimal .

ex:SistemaVolantesPersonalizado
    a                   ex:Sistema ;
    rdfs:label          "Sistema de volantes personalizado para ejes X, Y, Z, A"@es ;
    ex:textoExtracto    "Personalización de los volantes. En una máquina con ejes X, Y, Z, A se desea disponer de un volante individual para el eje X, un volante individual para el eje Y e un volante general para los ejes Z, A."@es ;
    ex:tieneComponente  ex:VolanteEjeX, ex:VolanteEjeY, ex:VolanteGeneralZA ;
    ex:documentadoEn    ex:TablaParametrosVolantes .

ex:TablaParametrosVolantes a ex:Tabla ;
     a                   ex:Tabla ;
    rdfs:label          "Tabla de parámetros de personalización de volantes"@es ;
    ex:textoExtracto    "Volante asociado al eje X (MANPG 1)... Volante asociado al eje Y (MANPG 2)..."@es .