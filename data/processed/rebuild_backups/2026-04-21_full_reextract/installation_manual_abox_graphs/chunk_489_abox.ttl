@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosVolanteJog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de volante y teclas JOG"@es ;
    ex:textoExtracto """
| Parámetro máquina. | Valor. | Significado. |
| --- | --- | --- |
| COUNTERTYPE | Remoto. | Volante conectado a los módulos remotos. |
| COUNTERID | 1 | Entrada de contaje X1. |
| MPGAXIS |  | Volante asociado al resto de los ejes. |
| Z - MPGRESOL 1 | 0.001 | Eje Z. Resolución 0.001 |
| Z - MPGRESOL 10 | 0.01 | Eje Z. Resolución 0.01 |
| Z - MPGRESOL 100 | 0.1 | Eje Z. Resolución 0.1 |
| A - MPGRESOL 1 | 0.01 | Eje A. Resolución 0.01 |
| A - MPGRESOL 10 | 0.1 | Eje A. Resolución 0.1 |
| A - MPGRESOL 100 | 1 | Eje A. Resolución 1
""" .

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:identificador "COUNTERTYPE" ;
    ex:valor "Remoto" ;
    ex:textoExtracto "COUNTERTYPE | Remoto. | Volante conectado a los módulos remotos."@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:identificador "COUNTERID" ;
    ex:valor "1" ;
    ex:textoExtracto "COUNTERID | 1 | Entrada de contaje X1."@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_MPGAXIS
    a ex:Parametro ;
    rdfs:label "MPGAXIS" ;
    ex:identificador "MPGAXIS" ;
    ex:textoExtracto "MPGAXIS |  | Volante asociado al resto de los ejes."@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_Z_MPGRESOL_1
    a ex:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 1)" ;
    ex:identificador "Z-MPGRESOL_1" ;
    ex:valor "0.001" ;
    ex:textoExtracto "Z - MPGRESOL 1 | 0.001 | Eje Z. Resolución 0.001"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_Z_MPGRESOL_10
    a ex:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 10)" ;
    ex:identificador "Z-MPGRESOL_10" ;
    ex:valor "0.01" ;
    ex:textoExtracto "Z - MPGRESOL 10 | 0.01 | Eje Z. Resolución 0.01"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_Z_MPGRESOL_100
    a ex:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 100)" ;
    ex:identificador "Z-MPGRESOL_100" ;
    ex:valor "0.1" ;
    ex:textoExtracto "Z - MPGRESOL 100 | 0.1 | Eje Z. Resolución 0.1"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_A_MPGRESOL_1
    a ex:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 1)" ;
    ex:identificador "A-MPGRESOL_1" ;
    ex:valor "0.01" ;
    ex:textoExtracto "A - MPGRESOL 1 | 0.01 | Eje A. Resolución 0.01"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_A_MPGRESOL_10
    a ex:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 10)" ;
    ex:identificador "A-MPGRESOL_10" ;
    ex:valor "0.1" ;
    ex:textoExtracto "A - MPGRESOL 10 | 0.1 | Eje A. Resolución 0.1"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Parametro_A_MPGRESOL_100
    a ex:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 100)" ;
    ex:identificador "A-MPGRESOL_100" ;
    ex:valor "1" ;
    ex:textoExtracto "A - MPGRESOL 100 | 1 | Eje A. Resolución 1"@es ;
    ex:documentadoEn ex:TablaParametrosVolanteJog .

ex:Interfaz_JOG_PANEL
    a ex:InterfazUsuario ;
    rdfs:label "Teclado JOG-PANEL"@es ;
    ex:textoExtracto "Ejemplo 1: Teclado JOG-PANEL. [...] Personalización de las teclas de jog. En una máquina con los ejes X, Y, U, V definidos como AXISNAME 1, 2, 3, 4 se desea desplazar los ejes X, Y con las teclas del mismo nombre, el eje U con las del 4º y el V con las del 5º."@es .

ex:Interfaz_LCD_10K
    a ex:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K"@es ;
    ex:textoExtracto "Ejemplo 4: Teclado LCD-10K. [...] Ejemplo 5: Teclado LCD-10K. [...] Ejemplo 6: Teclado LCD-10K."@es .