@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MTABLESIZE
    a ex:Parametro ;
    rdfs:label "MTABLESIZE" ;
    ex:identificador "MTABLESIZE" ;
    ex:valor "50" ;
    ex:textoExtracto "MTABLESIZE Número de elementos de la tabla. Valores posibles: de 0 a 200. Valor por defecto: 50." .

ex:Tabla_FuncionesM a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ex:identificador "DATA" ;
    ex:textoExtracto "DATA Tabla de funciones M. Muestra la tabla de personalización de funciones M." ;
    ex:tieneComponente ex:Parametro_MNUM ;
    ex:tieneComponente ex:Parametro_SYNCHTYPE ;
    ex:tieneComponente ex:Parametro_MPROGNAME ;
    ex:tieneComponente ex:Parametro_MTIME ;
    ex:tieneComponente ex:Parametro_MPLC ;
    ex:tieneComponente ex:Parametro_COMMENT .

ex:Parametro_MNUM
    a ex:Parametro ;
    rdfs:label "MNUM" ;
    ex:identificador "MNUM" ;
    ex:textoExtracto "MNUM Número de la función M. Valores posibles: de 0 a 65535." ;
    ex:documentadoEn ex:Tabla_FuncionesM .

ex:Parametro_SYNCHTYPE
    a ex:Parametro ;
    rdfs:label "SYNCHTYPE" ;
    ex:identificador "SYNCHTYPE" ;
    ex:valor "Antes-Antes" ;
    ex:textoExtracto "SYNCHTYPE Tipo de sincronización. Valores posibles: Sin sincronización / Antes-Antes / Antes-Después / Después-Después. Valor por defecto: Antes-Antes." ;
    ex:documentadoEn ex:Tabla_FuncionesM .

ex:Parametro_MPROGNAME
    a ex:Parametro ;
    rdfs:label "MPROGNAME" ;
    ex:identificador "MPROGNAME" ;
    ex:textoExtracto "MPROGNAME Nombre de subrutina asociada a la función M." ;
    ex:documentadoEn ex:Tabla_FuncionesM .

ex:Parametro_MTIME
    a ex:Parametro ;
    rdfs:label "MTIME" ;
    ex:identificador "MTIME" ;
    ex:textoExtracto "MTIME Tiempo estimado para la función M." ;
    ex:documentadoEn ex:Tabla_FuncionesM .

ex:Parametro_MPLC
    a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:identificador "MPLC" ;
    ex:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque." ;
    ex:documentadoEn ex:Tabla_FuncionesM .

ex:Parametro_COMMENT
    a ex:Parametro ;
    rdfs:label "COMMENT" ;
    ex:identificador "COMMENT" ;
    ex:textoExtracto "COMMENT Descripción de la función M." ;
    ex:documentadoEn ex:Tabla_FuncionesM .