@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ALIGNC
    a ex:Parametro ;
    rdfs:label "ALIGNC" ;
    ex:textoExtracto "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES/NO." ;
    ex:valor "YES/NO" .

ex:Parametro_TYPE_41
    a ex:Parametro ;
    rdfs:label "TYPE = 41" ;
    ex:identificador "41" ;
    ex:textoExtracto "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES." .

ex:Parametro_TYPE_42
    a ex:Parametro ;
    rdfs:label "TYPE = 42" ;
    ex:identificador "42" ;
    ex:textoExtracto "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = NO." .

ex:Parametro_TYPE_43
    a ex:Parametro ;
    rdfs:label "TYPE = 43" ;
    ex:identificador "43" ;
    ex:textoExtracto "Eje C. Mecanizado en la superficie cilíndrica." .

ex:Parametro_TYPE_50
    a ex:Parametro ;
    rdfs:label "TYPE = 50" ;
    ex:identificador "50" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal." .

ex:Parametro_TYPE_51
    a ex:Parametro ;
    rdfs:label "TYPE = 51" ;
    ex:identificador "51" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de mesa." .

ex:Parametro_TYPE_52
    a ex:Parametro ;
    rdfs:label "TYPE = 52" ;
    ex:identificador "52" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa." .

ex:Tabla_ConfiguracionCinematicas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de cinemáticas (TYPE 41-52)" ;
    ex:textoExtracto "TYPE = 41 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES. [...] TYPE = 52 | Definición vectorial de cinemáticas de cabezal–mesa." ;
    ex:ilustradoEn ex:Pagina_251_255 .

ex:Pagina_251_255
    a ex:Pagina ;
    rdfs:label "Páginas 251-255 (Sección 2.9.1: Configuración de las cinemáticas)" ;
    ex:identificador "251-255" ;
    ex:textoExtracto "Sección 2.9.1 Configuración de las cinemáticas." .