@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HEADREF
    a ex:Parametro ;
    rdfs:label "HEADREF" ;
    ex:identificador "MPK.HEADREF" ;
    ex:textoExtracto "HEADREF Posición de referencia máquina HEAD/TOOL. Valores posibles: Tool base / Head base / Auto tool base. Valor por defecto: Tool base." ;
    ex:valor "Tool base" .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." ;
    ex:valor "0" .

