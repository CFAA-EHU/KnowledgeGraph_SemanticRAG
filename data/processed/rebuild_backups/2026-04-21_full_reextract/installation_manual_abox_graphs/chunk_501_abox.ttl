ex:Tabla_ConfiguracionCinematica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Configuración de parámetros de cinemática (TYPE=41/42/43)" ;
    ex:textoExtracto "HEADREF Posición de referencia máquina HEAD/TOOL. Valores posibles: Tool base / Head base / Auto tool base. Valor por defecto: Tool base." ;
    ex:documentadoEn ex:Parametro_HEADREF ;
    ex:documentadoEn ex:Parametro_TDATA1 , ex:Parametro_TDATA2 , ex:Parametro_TDATA3 ,
                     ex:Parametro_TDATA13 , ex:Parametro_TDATA14 , ex:Parametro_TDATA15 .