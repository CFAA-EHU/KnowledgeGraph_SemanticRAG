@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Seccion2_9_2_DefinicionCinematicasCabezal
    a ex:Pagina ;
    ex:identificador "2.9.2" ;
    ex:textoExtracto "Definición de las cinemáticas del cabezal (tipos 1 a 8). Se pueden controlar cabezales esféricos, ortogonales y angulares."@es ;
    rdfs:label "Sección 2.9.2: Definición de cinemáticas de cabezal"@es .

ex:CabezalEsferico
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal esférico."@es ;
    ex:documentadoEn ex:Seccion2_9_2_DefinicionCinematicasCabezal ;
    rdfs:label "Cabezal esférico"@es .

ex:CabezalOrtogonal
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal ortogonal."@es ;
    ex:documentadoEn ex:Seccion2_9_2_DefinicionCinematicasCabezal ;
    rdfs:label "Cabezal ortogonal"@es .

ex:CabezalAngular
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal angular. [...] el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z) y el eje secundario o arrastrado (5) formará un determinado ángulo."@es ;
    ex:documentadoEn ex:Seccion2_9_2_DefinicionCinematicasCabezal ;
    rdfs:label "Cabezal angular"@es .

ex:EjeRotativoPrincipal
    a ex:ComponenteMecanico ;
    ex:identificador "4" ;
    ex:textoExtracto "eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z)"@es ;
    ex:compuestoPor ex:EjeRotativoSecundario ;
    rdfs:label "Eje rotativo principal (4)"@es .

ex:EjeRotativoSecundario
    a ex:ComponenteMecanico ;
    ex:identificador "5" ;
    ex:textoExtracto "eje secundario o arrastrado (5) formará un determinado ángulo"@es ;
    rdfs:label "Eje rotativo secundario (5)"@es .

ex:SistemaEjesPrincipales
    a ex:Sistema ;
    ex:textoExtracto "los ejes principales son X Y Z y los rotativos asociados a los mismos A, B, C"@es ;
    ex:documentadoEn ex:Seccion2_9_2_DefinicionCinematicasCabezal ;
    rdfs:label "Sistema de ejes principales (X, Y, Z) y rotativos (A, B, C)"@es .

ex:TablaParametrosTDATA a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "TDATA1··TDATA7 Dimensiones del cabezal. [...] A continuación se indica qué parámetros deben definirse con cada modelo de cabezal y el significado de los mismos."@es ;
    ex:documentadoEn ex:Seccion2_9_2_DefinicionCinematicasCabezal ;
    rdfs:label "Tabla de parámetros TDATA1 a TDATA7 para dimensiones de cabezal"@es .

ex:Parametro_TDATA1
    a ex:Parametro ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA1 (distancia nariz mandrino - eje secundario, eje Z)"@es .

ex:Parametro_TDATA2
    a ex:Parametro ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA2 (distancia eje secundario - principal, eje X)"@es .

ex:Parametro_TDATA3
    a ex:Parametro ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA3 (distancia eje secundario - principal, eje Y)"@es .

ex:Parametro_TDATA4
    a ex:Parametro ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "TDATA4 Indica la distancia entre el eje rotativo secundario y el principal según el eje Z."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA4 (distancia eje secundario - principal, eje Z)"@es .

ex:Parametro_TDATA5
    a ex:Parametro ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA5 (distancia eje herramienta - eje secundario, eje X)"@es .

ex:Parametro_TDATA6
    a ex:Parametro ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA6 (distancia eje herramienta - eje secundario, eje Y)"@es .

ex:Parametro_TDATA7
    a ex:Parametro ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos."@es ;
    ex:documentadoEn ex:TablaParametrosTDATA ;
    rdfs:label "Parámetro TDATA7 (ángulo entre ejes rotativos principal y secundario)"@es .