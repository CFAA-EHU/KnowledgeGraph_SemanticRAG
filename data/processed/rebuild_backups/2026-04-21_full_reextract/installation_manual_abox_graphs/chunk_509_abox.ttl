@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_TDATA12 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de cinemáticas del cabezal (TDATA12)" ;
    ex:textoExtracto "TDATA12 | Significado... 0 | Los dos ejes son servocontrolados. 1 | Eje principal manual y eje secundario servocontrolado. 2 | Eje principal servocontrolado y eje secundario manual. 3 | Los dos ejes son manuales." .

ex:Parametro_TDATA12
    a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:identificador "TDATA12" ;
    ex:textoExtracto "TDATA12 | Significado." ;
    ex:documentadoEn ex:Tabla_TDATA12 .

ex:Parametro_TDATA13
    a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA13: Distancia entre el eje rotativo principal y el punto de referencia, según el eje X." .

ex:Parametro_TDATA14
    a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:identificador "TDATA14" ;
    ex:textoExtracto "TDATA14: Distancia entre el eje rotativo principal y el punto de referencia, según el eje Y." .

ex:Parametro_TDATA15
    a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:identificador "TDATA15" ;
    ex:textoExtracto "TDATA15: Distancia entre el eje rotativo principal y el punto de referencia, según el eje Z." .