@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje X." ;
    ex:valor "Distancia eje X (eje rotativo secundario → referencia máquina)" .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Y." ;
    ex:valor "Distancia eje Y (eje rotativo secundario → referencia máquina)" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "TDATA4 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Z." ;
    ex:valor "Distancia eje Z (eje rotativo secundario → referencia máquina)" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje rotativo secundario y el principal." ;
    ex:valor "Distancia entre ejes (rotativo secundario ↔ principal)" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0." ;
    ex:valor "0 (cero máquina) o 1 (cero pieza)" .

ex:Sistema_CinematicaMesaGiratoria_Tipos9_12
    a ex:Sistema ;
    rdfs:label "Cinemática de mesa giratoria (tipos 9 a 12)" ;
    ex:textoExtracto "Se pueden controlar los siguientes tipos de mesas giratorias. [...] En este tipo de cinemática se recomienda definir este parámetro con valor ꞏ1ꞏ." ;
    ex:tieneComponente ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA7 .