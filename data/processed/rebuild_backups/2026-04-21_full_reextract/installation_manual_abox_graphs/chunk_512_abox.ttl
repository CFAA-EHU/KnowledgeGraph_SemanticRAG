@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA10 a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:textoExtracto "TDATA 10 = 0 / TDATA 10 = 1"@es ;
    ex:valor "0,1" ;
    ex:documentadoEn ex:Tabla_CinematicasMesa_Tipos9_12 .

ex:Parametro_TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:textoExtracto "TDATA 11 = 0 / TDATA 11 = 1"@es ;
    ex:valor "0,1" ;
    ex:documentadoEn ex:Tabla_CinematicasMesa_Tipos9_12 .

ex:Parametro_TDATA12 a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:textoExtracto "TDATA12 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 3. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados."@es ;
    ex:valor "0,1,2,3" ;
    ex:documentadoEn ex:Tabla_CinematicasMesa_Tipos9_12 .

ex:Parametro_TDATA16 a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:textoExtracto "TDATA16 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 / 1. Valor por defecto: 0."@es ;
    ex:valor "0,1" ;
    ex:documentadoEn ex:Tabla_CinematicasMesa_Tipos9_12 .

ex:Tabla_CinematicasMesa_Tipos9_12 a ex:Tabla ;
    rdfs:label "Tabla de cinemáticas de mesa (tipos 9 a 12)"@es ;
    ex:textoExtracto "TYPE=10 [...] TYPE=11 [...] TYPE=12 [...] TDATA12 Ejes rotativos manuales o servocontrolados [...] TDATA16 Girar el sistema de coordenadas pieza al girar la mesa."@es ;
    ex:identificador "2.9.3" .

ex:ModoOperacion_RTCP a ex:ModoOperacion ;
    rdfs:label "RTCP" ;
    ex:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ex:documentadoEn ex:Tabla_CinematicasMesa_Tipos9_12 .