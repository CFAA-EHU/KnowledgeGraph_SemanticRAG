@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TDATA8
    a ex:Parametro ;
    rdfs:label "TDATA8" ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:float .

ex:TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9" ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:float .

ex:TDATA10
    a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:identificador "TDATA10" ;
    ex:textoExtracto "Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer .

ex:TDATA11
    a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer .

ex:DIN66217
    a ex:Directiva ;
    rdfs:label "DIN 66217" ;
    ex:identificador "DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." .

ex:TDATA10
    ex:cumpleNormativa ex:DIN66217 .

ex:TDATA11
    ex:cumpleNormativa ex:DIN66217 .

ex:ConfiguracionCinematicaTipos13a16
    a ex:ModoOperacion ;
    rdfs:label "Configuración cinemática (tipos 13 a 16)" ;
    ex:textoExtracto "En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta, por lo que se parametrizará TDATA10=1 TDATA11=1." ;
    ex:tieneComponente ex:TDATA10, ex:TDATA11 .