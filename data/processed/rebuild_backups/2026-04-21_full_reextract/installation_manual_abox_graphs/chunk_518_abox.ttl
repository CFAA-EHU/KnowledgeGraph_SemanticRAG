@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA12
    a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:textoExtracto "TDATA12 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 3. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." ;
    ex:valor "0" .

ex:Parametro_TDATA13
    a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:textoExtracto "TDATA13 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje X." .

ex:Parametro_TDATA14
    a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:textoExtracto "TDATA14 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Y." .

ex:Parametro_TDATA15
    a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:textoExtracto "TDATA15 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Z." .

ex:Tabla_TDATA12_Significado a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Significado de valores TDATA12" ;
    ex:textoExtracto "0: Los dos ejes son servocontrolados. 1: Eje principal manual y eje secundario servocontrolado. 2: Eje principal servocontrolado y eje secundario manual. 3: Los dos ejes son manuales." ;
    ex:documentadoEn ex:Parametro_TDATA12 .

ex:Cinematica_Tipo15
    a ex:ModoOperacion ;
    rdfs:label "Cinemática TYPE=15" ;
    ex:textoExtracto "TYPE=15. TDATA 13(+) TDATA 14(+). TDATA 15(+). TDATA11 = 0/1. Configuraciones A/B con ejes Z, X, Y." ;
    ex:tieneComponente ex:Parametro_TDATA11 ,
        ex:Parametro_TDATA12 ,
        ex:Parametro_TDATA13 ,
        ex:Parametro_TDATA14 ,
        ex:Parametro_TDATA15 .

ex:Cinematica_Tipo16
    a ex:ModoOperacion ;
    rdfs:label "Cinemática TYPE=16" ;
    ex:textoExtracto "TYPE=16. TDATA 13(+) TDATA 14(+). TDATA 15(+). TDATA11 = 0/1. Configuraciones B/C con ejes Z, X, Y." ;
    ex:tieneComponente ex:Parametro_TDATA11 ,
        ex:Parametro_TDATA12 ,
        ex:Parametro_TDATA13 ,
        ex:Parametro_TDATA14 ,
        ex:Parametro_TDATA15 .

ex:Parametro_TDATA11
    a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:textoExtracto "TDATA11 = 0/1" ;
    ex:valor "0" , "1" .