@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EjeRotativoSecundario_Cabezal_Tipos17_24
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje rotativo secundario (cabezal tipos 17-24)"@es ;
    ex:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro."@es ;
    ex:identificador "tipos 17-24" .

ex:EjeRotativoTerciario_Cabezal_Tipos17_24
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje rotativo terciario (cabezal tipos 17-24)"@es ;
    ex:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su giro..."@es ;
    ex:identificador "tipos 17-24" .

ex:SistemaCinematico_Cabezal_Tipos17_24
    a               ex:Sistema ;
    rdfs:label      "Sistema cinemático del cabezal (tipos 17 a 24)"@es ;
    ex:textoExtracto "Definición de las cinemáticas del cabezal (tipos 17 a 24)."@es ;
    ex:identificador "tipos 17-24" ;
    ex:tieneComponente ex:EjeRotativoSecundario_Cabezal_Tipos17_24 ;
    ex:tieneComponente ex:EjeRotativoTerciario_Cabezal_Tipos17_24 .