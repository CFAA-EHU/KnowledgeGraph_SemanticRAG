@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2: Posición del eje rotativo" ;
    ex:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Indica la posición del eje rotativo según el eje de la herramienta." ;
    ex:valor "0" ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4: Offset angular para el eje rotativo" ;
    ex:textoExtracto "TDATA4 Offset angular para el eje rotativo. Valores posibles: Entre ±999999999.0000º Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "TDATA4" .

ex:Parametro_TDATA10 a ex:Parametro ;
    rdfs:label "TDATA10: Sentido de giro del eje giratorio" ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "TDATA10" .

ex:Funcion_CYL a ex:InterfazUsuario ;
    rdfs:label "Función #CYL" ;
    ex:textoExtracto "Estas cinemáticas se seleccionan mediante la función #CYL desde el programa pieza." ;
    ex:identificador "#CYL" .

ex:Tabla_CinematicasTipo43 a ex:Tabla ;
    rdfs:label "Tabla de cinemáticas tipo 43" ;
    ex:textoExtracto "Si al ejecutar esta función no se selecciona la cinemática, el CNC cogerá de la primera cinemática del tipo 43 definida en la tabla." ;
    ex:identificador "Tipo 43" .

ex:Normativa_DIN66217 a ex:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ex:textoExtracto "Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ex:identificador "DIN 66217" .

ex:Parametro_TDATA10 ex:cumpleNormativa ex:Normativa_DIN66217 .
ex:Parametro_TDATA2 ex:documentadoEn ex:Tabla_CinematicasTipo43 .
ex:Parametro_TDATA4 ex:documentadoEn ex:Tabla_CinematicasTipo43 .
ex:Parametro_TDATA10 ex:documentadoEn ex:Tabla_CinematicasTipo43 .