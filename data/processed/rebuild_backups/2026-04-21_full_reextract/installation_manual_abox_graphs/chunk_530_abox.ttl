ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1 (coordenada X de T1)" ;
    ex:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)" ;
    ex:valor "TDATA1(+)" .

