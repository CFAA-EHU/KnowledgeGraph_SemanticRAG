ex:Sistema_CinematicaCabezalTipo50
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática vectorial del cabezal (tipo 50)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50). T2: Vector traslación del segundo eje rotativo. T3: Vector traslación del portaherramientas. V1: Vector dirección del primer eje rotativo. V2: Vector dirección del segundo eje rotativo. V3: Vector dirección del portaherramientas." ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6,
                        ex:Parametro_TDATA11, ex:Parametro_TDATA12, ex:Parametro_TDATA13, ex:Parametro_TDATA14, ex:Parametro_TDATA15, ex:Parametro_TDATA16,
                        ex:Parametro_TDATA21, ex:Parametro_TDATA22, ex:Parametro_TDATA23, ex:Parametro_TDATA24, ex:Parametro_TDATA25, ex:Parametro_TDATA26 .