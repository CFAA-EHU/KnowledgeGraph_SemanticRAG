@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11: Distancia del eje rotativo secundario al principal (eje X)"@es ;
    ex:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X)."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA11" .

ex:Parametro_TDATA12 a ex:Parametro ;
    rdfs:label "TDATA12: Distancia del eje rotativo secundario al principal (eje Y)"@es ;
    ex:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA12" .

ex:Parametro_TDATA13 a ex:Parametro ;
    rdfs:label "TDATA13: Distancia del eje rotativo secundario al principal (eje Z)"@es ;
    ex:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA13" .

ex:Parametro_TDATA14 a ex:Parametro ;
    rdfs:label "TDATA14: Componente X del vector dirección del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)."@es ;
    ex:identificador "TDATA14" .

ex:Parametro_TDATA15 a ex:Parametro ;
    rdfs:label "TDATA15: Componente Y del vector dirección del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)."@es ;
    ex:identificador "TDATA15" .

ex:Parametro_TDATA16 a ex:Parametro ;
    rdfs:label "TDATA16: Componente Z del vector dirección del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)."@es ;
    ex:identificador "TDATA16" .

ex:Parametro_TDATA17 a ex:Parametro ;
    rdfs:label "TDATA17: Posición de reposo del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)."@es ;
    ex:valor "±99999.9999°"@es ;
    ex:identificador "TDATA17" .

ex:Parametro_TDATA18 a ex:Parametro ;
    rdfs:label "TDATA18: Sentido de giro del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ex:valor "0 (DIN 66217) / 1 (contrario a DIN 66217)"@es ;
    ex:identificador "TDATA18" .

ex:Parametro_TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19: Modo de control del eje rotativo secundario"@es ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado."@es ;
    ex:valor "0 (servocontrolado) / 1 (manual)"@es ;
    ex:identificador "TDATA19" .

ex:Parametro_TDATA21 a ex:Parametro ;
    rdfs:label "TDATA21: Vector traslación del portaherramientas (eje X)"@es ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas. [...] Este vector traslación indica la distancia desde la base del portaherramientas al punto de referencia del eje rotativo secundario."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA21" .

ex:Parametro_TDATA22 a ex:Parametro ;
    rdfs:label "TDATA22: Vector traslación del portaherramientas (eje Y)"@es ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA22" .

ex:Parametro_TDATA23 a ex:Parametro ;
    rdfs:label "TDATA23: Vector traslación del portaherramientas (eje Z)"@es ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas."@es ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"@es ;
    ex:identificador "TDATA23" .

ex:Sistema_CinematicaCabezalTipo50 a ex:Sistema ;
    rdfs:label "Sistema de cinemática de cabezal (tipo 50)"@es ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50)."@es ;
    ex:tieneComponente ex:Parametro_TDATA11, ex:Parametro_TDATA12, ex:Parametro_TDATA13,
                      ex:Parametro_TDATA14, ex:Parametro_TDATA15, ex:Parametro_TDATA16,
                      ex:Parametro_TDATA17, ex:Parametro_TDATA18, ex:Parametro_TDATA19,
                      ex:Parametro_TDATA21, ex:Parametro_TDATA22, ex:Parametro_TDATA23 .