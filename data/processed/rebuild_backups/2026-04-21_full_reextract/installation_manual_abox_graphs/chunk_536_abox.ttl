@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MesaTipo51
    a ex:Sistema ;
    rdfs:label "Mesa con cinemática tipo 51 (máx. 2 ejes rotativos)"@es ;
    ex:textoExtracto "Esta cinemática permite controlar cualquier tipo de mesa que tenga como máximo dos ejes rotativos. Definición vectorial de la cinemáticas."@es ;
    ex:tieneComponente ex:EjeRotativo1 ;
    ex:tieneComponente ex:EjeRotativo2 .

ex:EjeRotativo1
    a ex:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo (T1, V1)"@es ;
    ex:textoExtracto "Cada uno de los ejes rotativos de la cinemática se define mediante un vector traslación (posición del eje) y un vector dirección (dirección del eje). V1 T1: Vector traslación del primer eje rotativo. V1: Vector dirección del primer eje rotativo."@es ;
    ex:tieneComponente ex:VectorTraslacion1 ;
    ex:tieneComponente ex:VectorDireccion1 .

ex:EjeRotativo2
    a ex:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo (T2, V2)"@es ;
    ex:textoExtracto "T2: Vector traslación del segundo eje rotativo. V2: Vector dirección del segundo eje rotativo."@es ;
    ex:tieneComponente ex:VectorTraslacion2 ;
    ex:tieneComponente ex:VectorDireccion2 .

ex:VectorTraslacion1
    a ex:Parametro ;
    rdfs:label "Vector traslación T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ex:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ex:valor "TDATA1,TDATA2,TDATA3" .

ex:VectorDireccion1
    a ex:Parametro ;
    rdfs:label "Vector dirección V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ex:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ex:valor "TDATA4,TDATA5,TDATA6" .

ex:VectorTraslacion2
    a ex:Parametro ;
    rdfs:label "Vector traslación T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ex:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ex:valor "TDATA11,TDATA12,TDATA13" .

ex:VectorDireccion2
    a ex:Parametro ;
    rdfs:label "Vector dirección V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ex:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ex:valor "TDATA14,TDATA15,TDATA16" .