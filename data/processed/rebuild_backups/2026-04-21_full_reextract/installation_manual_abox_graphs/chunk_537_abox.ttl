@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1 (Distancia eje X)" ;
    ex:textoExtracto "TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ex:valor "0"^^xsd:decimal ;
    ex:identificador "TDATA1" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2 (Distancia eje Y)" ;
    ex:textoExtracto "TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ex:valor "0"^^xsd:decimal ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3 (Distancia eje Z)" ;
    ex:textoExtracto "TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ex:valor "0"^^xsd:decimal ;
    ex:identificador "TDATA3" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7 (Posición de reposo)" ;
    ex:textoExtracto "TDATA7 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:decimal ;
    ex:identificador "TDATA7" .

ex:Parametro_TDATA8
    a ex:Parametro ;
    rdfs:label "TDATA8 (Sentido de giro)" ;
    ex:textoExtracto "TDATA8 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer ;
    ex:identificador "TDATA8" .

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9 (Tipo de control)" ;
    ex:textoExtracto "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer ;
    ex:identificador "TDATA9" .

ex:Sistema_CinematicaMesaTipo51
    a ex:Sistema ;
    rdfs:label "Cinemática de mesa (tipo 51)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51). Vector traslación del eje rotativo principal. [...] TDATA1···TDATA9" ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA7, ex:Parametro_TDATA8, ex:Parametro_TDATA9 .