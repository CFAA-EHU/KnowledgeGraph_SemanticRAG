@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X)." ;
    ex:valor "0"^^xsd:decimal .  # Valor por defecto

ex:Parametro_TDATA12 a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:identificador "TDATA12" ;
    ex:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA13 a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA14 a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:identificador "TDATA14" ;
    ex:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA15 a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:identificador "TDATA15" ;
    ex:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA16 a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA17 a ex:Parametro ;
    rdfs:label "TDATA17" ;
    ex:identificador "TDATA17" ;
    ex:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA18 a ex:Parametro ;
    rdfs:label "TDATA18" ;
    ex:identificador "TDATA18" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer .

ex:Parametro_TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19" ;
    ex:identificador "TDATA19" ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer .

ex:Parametro_TDATA20 a ex:Parametro ;
    rdfs:label "TDATA20" ;
    ex:identificador "TDATA20" ;
    ex:textoExtracto "TDATA20 Origen para aplicar el RTCP." .

ex:Sistema_CinematicaMesaTipo51 a ex:Sistema ;
    rdfs:label "Cinemática de mesa (tipo 51)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51)." ;
    ex:tieneComponente ex:Parametro_TDATA11, ex:Parametro_TDATA12, ex:Parametro_TDATA13, ex:Parametro_TDATA14, ex:Parametro_TDATA15, ex:Parametro_TDATA16, ex:Parametro_TDATA17, ex:Parametro_TDATA18, ex:Parametro_TDATA19, ex:Parametro_TDATA20 .