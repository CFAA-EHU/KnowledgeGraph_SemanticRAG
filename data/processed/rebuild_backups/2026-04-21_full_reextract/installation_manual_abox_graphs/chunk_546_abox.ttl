ex:Tabla_Cinematica_52 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de definición vectorial de cinemáticas (tipo 52)"@es ;
    ex:textoExtracto """
    | T4 (TDATA31, TDATA32, TDATA33 |
    | --- |
    | T5 (TDATA41, TDATA42, TDATA43 |
     V4 (TDATA34, TDATA35, TDATA36) V5 (TDATA44, TDATA45, TDATA46) V2 TDATA 11(+) TDATA 2(+) TDATA 1(+) TDATA 12(+) TDATA 21(+) Z V1 V1 Y X TDATA 3(+) V3 V2 TDATA 13(+) V2 TDATA 23(+) V3 V3 TDATA 22(+) V4 V5 Z Z Y X
     TDATA 41(+) TDATA 31(+)
    """ ;
    ex:identificador "Tipo 52" .

