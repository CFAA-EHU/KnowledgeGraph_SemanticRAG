@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA17
    a ex:Parametro ;
    rdfs:label "TDATA17 (Posición de reposo del eje longitudinal)"@es ;
    ex:textoExtracto "Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0."@es ;
    ex:identificador "TDATA17" ;
    ex:valor "0" .

ex:Parametro_TDATA18
    a ex:Parametro ;
    rdfs:label "TDATA18 (Sentido de giro del eje rotativo secundario)"@es ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ex:identificador "TDATA18" ;
    ex:valor "0" .

ex:Parametro_TDATA19
    a ex:Parametro ;
    rdfs:label "TDATA19 (Tipo de control del eje rotativo secundario)"@es ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0."@es ;
    ex:identificador "TDATA19" ;
    ex:valor "0" .

ex:Parametro_TDATA8
    a ex:Parametro ;
    rdfs:label "TDATA8 (Parámetro relacionado con TDATA18)"@es ;
    ex:textoExtracto "Consultar el parámetro TDATA8."@es ;
    ex:identificador "TDATA8" .