ex:Sistema_CinematicaTipo52
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática tipo 52 (cabezal–mesa)"@es ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)."@es ;
    ex:tieneComponente ex:Param_TDATA19 ;
    ex:tieneComponente ex:Param_TDATA21 ;
    ex:tieneComponente ex:Param_TDATA22 ;
    ex:tieneComponente ex:Param_TDATA23 ;
    ex:tieneComponente ex:Param_TDATA24 ;
    ex:tieneComponente ex:Param_TDATA25 ;
    ex:tieneComponente ex:Param_TDATA26 ;
    ex:tieneComponente ex:Param_TDATA31 ;
    ex:tieneComponente ex:Param_TDATA32 ;
    ex:tieneComponente ex:Param_TDATA33 .