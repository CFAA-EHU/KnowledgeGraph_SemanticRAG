    ex:textoExtracto "TDATA26 Componente del vector dirección del portaherramientas (eje Z)."@es ;
    ex:valor "0" .

ex:Param_TDATA31
    a ex:Parametro ;
    rdfs:label "TDATA31 - Vector traslación X del eje rotativo principal"@es ;
    ex:identificador "TDATA31" ;
    ex:textoExtracto "TDATA31 Distancia del eje rotativo principal al punto de referencia máquina (eje X)."@es ;
    ex:valor "0" .

