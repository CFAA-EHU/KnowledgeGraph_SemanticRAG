@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TDATA31
    a ex:Parametro ;
    rdfs:label "TDATA31" ;
    ex:identificador "TDATA31" ;
    ex:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ex:valor "0"^^xsd:float .  # Valor por defecto según texto

ex:TDATA32
    a ex:Parametro ;
    rdfs:label "TDATA32" ;
    ex:identificador "TDATA32" ;
    ex:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ex:valor "0"^^xsd:float .

ex:TDATA33
    a ex:Parametro ;
    rdfs:label "TDATA33" ;
    ex:identificador "TDATA33" ;
    ex:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ex:valor "0"^^xsd:float .

ex:TDATA34
    a ex:Parametro ;
    rdfs:label "TDATA34" ;
    ex:identificador "TDATA34" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje X)." .

ex:TDATA35
    a ex:Parametro ;
    rdfs:label "TDATA35" ;
    ex:identificador "TDATA35" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Y)." .

ex:TDATA36
    a ex:Parametro ;
    rdfs:label "TDATA36" ;
    ex:identificador "TDATA36" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Z)." .

ex:SistemaCinematicoTipo52
    a ex:Sistema ;
    rdfs:label "Sistema cinemático tipo 52 (cabezal–mesa)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ex:tieneComponente ex:TDATA31, ex:TDATA32, ex:TDATA33, ex:TDATA34, ex:TDATA35, ex:TDATA36 .