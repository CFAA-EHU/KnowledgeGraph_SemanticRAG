@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA34
    a ex:Parametro ;
    rdfs:label "TDATA34" ;
    ex:identificador "TDATA34" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje X)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA35
    a ex:Parametro ;
    rdfs:label "TDATA35" ;
    ex:identificador "TDATA35" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Y)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA36
    a ex:Parametro ;
    rdfs:label "TDATA36" ;
    ex:identificador "TDATA36" ;
    ex:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Z)." ;
    ex:valor "1"^^xsd:decimal .

ex:Parametro_TDATA37
    a ex:Parametro ;
    rdfs:label "TDATA37" ;
    ex:identificador "TDATA37" ;
    ex:textoExtracto "Posición de reposo del eje rotativo principal de la mesa. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA38
    a ex:Parametro ;
    rdfs:label "TDATA38" ;
    ex:identificador "TDATA38" ;
    ex:textoExtracto "Sentido de giro del eje rotativo principal de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ex:valor "0"^^xsd:integer .

ex:Parametro_TDATA39
    a ex:Parametro ;
    rdfs:label "TDATA39" ;
    ex:identificador "TDATA39" ;
    ex:textoExtracto "Eje rotativo principal de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual)." ;
    ex:valor "0"^^xsd:integer .

ex:Parametro_TDATA40
    a ex:Parametro ;
    rdfs:label "TDATA40" ;
    ex:identificador "TDATA40" ;
    ex:textoExtracto "Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza)." ;
    ex:valor "0"^^xsd:integer .

ex:Sistema_CinematicaTipo52
    a ex:Sistema ;
    rdfs:label "Cinemática tipo 52 (cabezal–mesa)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ex:tieneComponente ex:Parametro_TDATA34 ;
    ex:tieneComponente ex:Parametro_TDATA35 ;
    ex:tieneComponente ex:Parametro_TDATA36 ;
    ex:tieneComponente ex:Parametro_TDATA37 ;
    ex:tieneComponente ex:Parametro_TDATA38 ;
    ex:tieneComponente ex:Parametro_TDATA39 ;
    ex:tieneComponente ex:Parametro_TDATA40 .