@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NKINAX
    a ex:Parametro ;
    rdfs:label "NKINAX" ;
    ex:identificador "NKINAX" ;
    ex:textoExtracto "NKINAX Número de ejes de la cinemática. Valores posibles: De 0 a 8. Valor por defecto: 0." ;
    ex:valor "0-8"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_PARAM_D_SIZE
    a ex:Parametro ;
    rdfs:label "PARAM_D_SIZE" ;
    ex:identificador "PARAM_D_SIZE" ;
    ex:textoExtracto "PARAM_D_SIZE Número de parámetros en formato decimal. Valores posibles: De 0 a 100. Valor por defecto: 0." ;
    ex:valor "0-100"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_TDATA1_100
    a ex:Parametro ;
    rdfs:label "TDATA1··100" ;
    ex:identificador "TDATA1··100" ;
    ex:textoExtracto "TDATA1··100 Parámetros para configurar la cinemática (formato decimal). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros." .

ex:Parametro_PARAM_I_SIZE
    a ex:Parametro ;
    rdfs:label "PARAM_I_SIZE" ;
    ex:identificador "PARAM_I_SIZE" ;
    ex:textoExtracto "PARAM_I_SIZE Número de parámetros en formato entero. Valores posibles: De 0 a 100. Valor por defecto: 0." ;
    ex:valor "0-100"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_TDATA_I1_100
    a ex:Parametro ;
    rdfs:label "TDATA_I1··100" ;
    ex:identificador "TDATA_I1··100" ;
    ex:textoExtracto "TDATA_I1··100 Parámetros para configurar la cinemática (formato entero). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros." .

ex:Parametro_AUXCTE_SIZE
    a ex:Parametro ;
    rdfs:label "AUXCTE_SIZE" ;
    ex:identificador "AUXCTE_SIZE" ;
    ex:textoExtracto "AUXCTE_SIZE Tamaño del área de variables auxiliares. Valores posibles: De 0 a 1000 bytes. Valor por defecto: 0." ;
    ex:valor "0-1000 bytes"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_KINDATA_SIZE
    a ex:Parametro ;
    rdfs:label "KINDATA_SIZE" ;
    ex:identificador "KINDATA_SIZE" ;
    ex:textoExtracto "KINDATA_SIZE Tamaño del área de datos de propósito general. Valores posibles: De 0 a 100000 bytes. Valor por defecto: 0." ;
    ex:valor "0-100000 bytes"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Sistema_CinematicasOEM
    a ex:Sistema ;
    rdfs:label "Cinemáticas OEM (tipos 100 a 105)" ;
    ex:textoExtracto "En las cinemáticas OEM hay que indicar el número de parámetros, variables auxiliares y datos de propósito general que se utilizan." ;
    ex:tieneComponente ex:Parametro_NKINAX ;
    ex:tieneComponente ex:Parametro_PARAM_D_SIZE ;
    ex:tieneComponente ex:Parametro_TDATA1_100 ;
    ex:tieneComponente ex:Parametro_PARAM_I_SIZE ;
    ex:tieneComponente ex:Parametro_TDATA_I1_100 ;
    ex:tieneComponente ex:Parametro_AUXCTE_SIZE ;
    ex:tieneComponente ex:Parametro_KINDATA_SIZE .