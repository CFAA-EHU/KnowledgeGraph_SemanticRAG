@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia entre parámetros de cinemática vectorial (tipo 50) y cinemática tipo 5" ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 5. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA2 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA15 |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |
| TDATA11 | TDATA5*COS(TDATA7) |
| TDATA12 | TDATA3 |
| TDATA13 | TDATA5*SIN(TDATA7) |
| TDATA14 | COS(TDATA7) |
| TDATA15 | 0 |
| TDATA16 | SIN(TDATA7) |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |
| TDATA21 | 0 |
| TDATA22 | TDATA6 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 |
""" .

ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia entre parámetros de cinemática vectorial (tipo 50) y cinemática tipo 6" ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 6. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA3 |
| TDATA3 | TDATA15 |
| TDATA4 | 0 |
| TDATA5 | 1 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3.
""" .

ex:Parametro_TYPE_Tipo50
    a ex:Parametro ;
    rdfs:label "TYPE (cinemática tipo 50)" ;
    ex:identificador "TYPE" ;
    ex:valor "50" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TYPE | 50" .

ex:Parametro_TDATA1_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 50)" ;
    ex:identificador "TDATA1" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TDATA1 | TDATA2 (tipo 5) / TDATA13 (tipo 6)" .

ex:Parametro_TDATA2_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA2 (cinemática tipo 50)" ;
    ex:identificador "TDATA2" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TDATA2 | TDATA14 (tipo 5) / TDATA3 (tipo 6)" .

ex:Parametro_TDATA3_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA3 (cinemática tipo 50)" ;
    ex:identificador "TDATA3" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TDATA3 | TDATA15 (tipo 5) / TDATA15 (tipo 6)" .

ex:Parametro_TDATA9_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA9 (cinemática tipo 50)" ;
    ex:identificador "TDATA9" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3." .

ex:Parametro_TDATA12_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA12 (cinemática tipo 50)" ;
    ex:identificador "TDATA12" ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo5 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo50_Tipo6 ;
    ex:textoExtracto "TDATA12 | Parámetro condicional para TDATA9 y TDATA19" .