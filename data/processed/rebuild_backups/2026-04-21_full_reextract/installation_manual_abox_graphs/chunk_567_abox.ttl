@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_RedefinicionCinematicaTipo9a51 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de redefinición: cinemática tipo 9 → tipo 51 (vectorial)"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 9. |
| TYPE | 51 |
| TDATA1 | 0 |
| TDATA2 | -TDATA3 |
| TDATA3 | -(TDATA5+TDATA4) |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA10 | TDATA7 |
| TDATA11 | -TDATA2 |
| TDATA12 | 0 |
| TDATA13 | TDATA5 |
| TDATA14 | 0 |
| TDATA15 | 1 |
| TDATA16 | 0 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA20 | TDATA7 |
| TDATA31 | TDATA16 |
"""@es .

ex:Tabla_RedefinicionCinematicaTipo10a51 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de redefinición: cinemática tipo 10 → tipo 51 (vectorial)"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 10. |
| TYPE | 51 |
| TDATA1 | 0 |
| TDATA2 | -(TDATA5+TDATA3) |
| TDATA3 | -TDATA4 |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA10 | TDATA7 |
| TDATA11 | -TDATA2 |
| TDATA12 | TDATA5 |
| TDATA13 | 0 |
| TDATA14 | 0 |
| TDATA15 | 0 |
| TDATA16 | 1 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA20 | TDATA7 |
| TDATA31 | TDATA16 |
"""@es .

ex:Parametro_TYPE_51
    a ex:Parametro ;
    rdfs:label "TYPE (cinemática tipo 51)"@es ;
    ex:identificador "TYPE" ;
    ex:valor "51" ;
    ex:textoExtracto "TYPE | 51"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo9a51 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo10a51 .

ex:Parametro_TDATA1_51
    a ex:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 51)"@es ;
    ex:identificador "TDATA1" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA1 | 0"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo9a51 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo10a51 .

ex:Parametro_TDATA4_51
    a ex:Parametro ;
    rdfs:label "TDATA4 (cinemática tipo 51)"@es ;
    ex:identificador "TDATA4" ;
    ex:valor "1" ;
    ex:textoExtracto "TDATA4 | 1"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo9a51 ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo10a51 .

ex:Parametro_TDATA15_51_Tipo9
    a ex:Parametro ;
    rdfs:label "TDATA15 (cinemática tipo 51 desde tipo 9)"@es ;
    ex:identificador "TDATA15" ;
    ex:valor "1" ;
    ex:textoExtracto "TDATA15 | 1"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo9a51 .

ex:Parametro_TDATA16_51_Tipo10
    a ex:Parametro ;
    rdfs:label "TDATA16 (cinemática tipo 51 desde tipo 10)"@es ;
    ex:identificador "TDATA16" ;
    ex:valor "1" ;
    ex:textoExtracto "TDATA16 | 1"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo10a51 .