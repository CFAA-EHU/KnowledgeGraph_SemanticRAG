@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_RedefinicionCinematica_51_11 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia entre parámetros de cinemática vectorial (tipo 51) y cinemática tipo 11"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 11. |
| --- | --- |
| TYPE | 51 |
| TDATA1 | -(TDATA2) |
| TDATA2 | 0 |
| TDATA3 | -(TDATA5+TDATA4) |
| TDATA4 | 0 |
| TDATA5 | 1 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA10 | TDATA7 |
| TDATA11 | 0 |
| TDATA12 | -TDATA3 |
| TDATA13 | TDATA5 |
| TDATA14 | 1 |
| TDATA15 | 0 |
| TDATA16 | 0 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA20 | TDATA17 |
| TDATA31 | TDATA16 |
"""@es ;
    ex:documentadoEn ex:Pagina_293_308 .

