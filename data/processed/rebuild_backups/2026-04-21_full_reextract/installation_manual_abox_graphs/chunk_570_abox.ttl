@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CinematicaVectorial_Tipo52 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática vectorial tipo 52 vs tipo 13/14"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 13. |
| --- | --- |
| TYPE | 52 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| ... [fragmento truncado por brevedad] ...
| TDATA52 | A elegir. |
Adaptar una cinemática tipo 14 a una cinemática tipo 52."""@es ;
    ex:identificador "Tipo52" .

ex:Parametro_TYPE
    a ex:Parametro ;
    rdfs:label "TYPE (cinemática tipo 52)"@es ;
    ex:textoExtracto "TYPE | 52"@es ;
    ex:valor "52" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA1 | TDATA13"@es ;
    ex:valor "TDATA13" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA2 | TDATA14"@es ;
    ex:valor "TDATA14" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA3 | TDATA15"@es ;
    ex:valor "TDATA15" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA4 | 0"@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA31
    a ex:Parametro ;
    rdfs:label "TDATA31 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA31 | -TDATA4"@es ;
    ex:valor "-TDATA4" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA40
    a ex:Parametro ;
    rdfs:label "TDATA40 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA40 | A elegir."@es ;
    ex:valor "A_elegir" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA49
    a ex:Parametro ;
    rdfs:label "TDATA49 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA49 | 1"@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .

ex:Parametro_TDATA52
    a ex:Parametro ;
    rdfs:label "TDATA52 (cinemática tipo 52)"@es ;
    ex:textoExtracto "TDATA52 | A elegir."@es ;
    ex:valor "A_elegir" ;
    ex:documentadoEn ex:Tabla_CinematicaVectorial_Tipo52 .