@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TransformacionAngularEjeInclinado
    a ex:ModoOperacion ;
    rdfs:label "Transformación angular de eje inclinado"@es ;
    ex:textoExtracto "La transformación angular de eje inclinado permite programar desplazamientos en coordenadas cartesianas y ejecutarlos en un plano no cartesiano; es decir, en un plano donde los ejes no están a 90º entre ellos."@es ;
    ex:textoExtracto "Un caso típico es el eje X de torno que por motivos de robustez no forma 90º con el eje Z, sino que tiene otro valor."@es ;
    ex:textoExtracto "Para poder programar en el sistema cartesiano (Z-X), hay que activar una transformación angular de eje inclinado que convierta los movimientos a los ejes reales no perpendiculares (Z-X')."@es .

ex:SistemaCartesiano_ZX
    a ex:Sistema ;
    rdfs:label "Sistema cartesiano (Z-X)"@es ;
    ex:textoExtracto "programar en el sistema cartesiano (Z-X)"@es .

ex:SistemaEjesNoPerpendiculares_ZX
    a ex:Sistema ;
    rdfs:label "Sistema de ejes no perpendiculares (Z-X')"@es ;
    ex:textoExtracto "ejes reales no perpendiculares (Z-X')"@es ;
    ex:textoExtracto "Un caso típico es el eje X de torno que [...] no forma 90º con el eje Z, sino que tiene otro valor. X [...] Eje angular. Z [...] Eje ortogonal."@es .

ex:EjeX
    a ex:ComponenteMecanico ;
    rdfs:label "Eje angular X'"@es ;
    ex:textoExtracto "X' [...] Eje angular"@es .

ex:EjeZ
    a ex:ComponenteMecanico ;
    rdfs:label "Eje ortogonal Z"@es ;
    ex:textoExtracto "Z [...] Eje ortogonal"@es .

ex:Sentencia_ANGAX_ON
    a ex:Parametro ;
    rdfs:label "#ANGAX ON" ;
    ex:identificador "#ANGAX ON" ;
    ex:textoExtracto "la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON"@es .

ex:TransformacionAngularEjeInclinado
    ex:controla ex:SistemaEjesNoPerpendiculares_ZX ;
    ex:habilitadoPor ex:Sentencia_ANGAX_ON .

ex:SistemaEjesNoPerpendiculares_ZX
    ex:compuestoPor ex:EjeX ;
    ex:compuestoPor ex:EjeZ .