@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ANGAXNA
    a ex:Parametro ;
    rdfs:label "ANGAXNA" ;
    ex:identificador "ANGAXNA" ;
    ex:textoExtracto "Nombre del eje angular (eje inclinado). Variable asociada: (V.)MPK.ANGAXNA[ang]" ;
    ex:valor "X" .

ex:Parametro_ORTAXNA
    a ex:Parametro ;
    rdfs:label "ORTAXNA" ;
    ex:identificador "ORTAXNA" ;
    ex:textoExtracto "Nombre del eje ortogonal. Variable asociada: (V.)MPK.ORTAXNA[ang]" ;
    ex:valor "Z" .

ex:Parametro_ANGANTR
    a ex:Parametro ;
    rdfs:label "ANGANTR" ;
    ex:identificador "ANGANTR" ;
    ex:textoExtracto "Ángulo entre el eje cartesiano y el eje inclinado. Valores posibles: Entre ±360.0000º. Valor por defecto: 30 grados. Variable asociada: (V.)MPK.ANGANTR[ang]" ;
    ex:valor "60º" .

ex:Parametro_OFFANGAX
    a ex:Parametro ;
    rdfs:label "OFFANGAX" ;
    ex:identificador "OFFANGAX" ;
    ex:textoExtracto "Offset del origen de la transformación angular. Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)MPK.OFFANGAX[ang]" ;
    ex:valor "0" .

ex:Tabla_ParametrosTransformacionAngular a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de transformación angular" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | ANGAXNA | Nombre del eje angular (eje inclinado). | ORTAXNA | Nombre del eje ortogonal. | ANGANTR | Ángulo entre el eje cartesiano y el eje inclinado. | OFFANGAX | Offset del origen de la transformación angular." ;
    ex:tieneComponente ex:Parametro_ANGAXNA ;
    ex:tieneComponente ex:Parametro_ORTAXNA ;
    ex:tieneComponente ex:Parametro_ANGANTR ;
    ex:tieneComponente ex:Parametro_OFFANGAX .