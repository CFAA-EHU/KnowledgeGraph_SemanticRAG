@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NPARAL
    a ex:Parametro ;
    rdfs:label "NPARAL" ;
    ex:textoExtracto "NPARAL Número de cinemáticas de ejes paralelos. Valores posibles: De 0 a 6. Valor por defecto: 0. Variable asociada: (V.)MPK.NPARAL" ;
    ex:valor "0" ;
    ex:identificador "(V.)MPK.NPARAL" .

ex:Parametro_PARALAX
    a ex:Parametro ;
    rdfs:label "PARALAX" ;
    ex:textoExtracto "PARALAX Eje principal de la transformación. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.PARALAX[nb]" ;
    ex:identificador "(V.)MPK.PARALAX[nb]" .

ex:Parametro_ADDAX
    a ex:Parametro ;
    rdfs:label "ADDAX" ;
    ex:textoExtracto "ADDAX Eje aditivo paralelo. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.ADDAX[nb]" ;
    ex:identificador "(V.)MPK.ADDAX[nb]" .

ex:Parametro_ADDORG
    a ex:Parametro ;
    rdfs:label "ADDORG" ;
    ex:textoExtracto "ADDORG Distancia entre los cero máquina de ambos ejes. Valores posibles: ±214748.3647 mm / Valor por defecto: 0. Variable asociada: (V.)MPK.ADDORG[nb]" ;
    ex:valor "0" ;
    ex:identificador "(V.)MPK.ADDORG[nb]" .

ex:Parametro_PARALINI
    a ex:Parametro ;
    rdfs:label "PARALINI" ;
    ex:textoExtracto "PARALINI Estado de la cinemática paralela en el arranque." .

ex:Tabla_PARALLEL_n a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de cinemáticas de ejes paralelos (PARALLEL n)" ;
    ex:textoExtracto "PARALLEL n Tabla de cinemáticas de ejes paralelos. Muestra las tablas de configuración de las cinemáticas de ejes paralelos." ;
    ex:tieneComponente ex:Parametro_PARALAX ,
                       ex:Parametro_ADDAX ,
                       ex:Parametro_ADDORG ,
                       ex:Parametro_PARALINI .