@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PARALAX_OFF
    a ex:Parametro ;
    rdfs:label "PARALAX OFF" ;
    ex:textoExtracto "PARALAX OFF | Cinemática desactivada." ;
    ex:valor "OFF" .

ex:Parametro_PARALAX_VIS
    a ex:Parametro ;
    rdfs:label "PARALAX VIS" ;
    ex:textoExtracto "PARALAX VIS. | Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." ;
    ex:valor "VIS" .

ex:ModoOperacion_VisualizacionCinematica
    a ex:ModoOperacion ;
    rdfs:label "Modo visualización de cinemática paralela" ;
    ex:textoExtracto "Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ex:Tabla_581_CinematicaEjesParalelos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de cinemática de ejes paralelos (pág. 312-313)" ;
    ex:textoExtracto "| Valor. | Significado. | --- | --- | PARALAX OFF | Cinemática desactivada. | PARALAX VIS. | Cinemática activa en modo visualización..." ;
    ex:tieneComponente ex:Parametro_PARALAX_OFF ;
    ex:tieneComponente ex:Parametro_PARALAX_VIS ;
    ex:ilustradoEn ex:ModoOperacion_VisualizacionCinematica .