@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GestionAlmacen_Tipo
    a               ex:Parametro ;
    rdfs:label      "TYPE (Tipo de almacén)" ;
    ex:textoExtracto "TYPE Tipo de almacén. Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo. Valor por defecto: Síncrono." ;
    ex:valor        "Síncrono" ;
    ex:identificador "TM.MZTYPE[mz]" .

ex:Parametro_GestionAlmacen_Ciclico
    a               ex:Parametro ;
    rdfs:label      "CYCLIC (Cambiador de herramientas cíclico)" ;
    ex:textoExtracto "CYCLIC Cambiador de herramientas cíclico." .

ex:Parametro_GestionAlmacen_Optimizacion
    a               ex:Parametro ;
    rdfs:label      "OPTIMIZE (Optimización de la gestión)" ;
    ex:textoExtracto "OPTIMIZE Optimización de la gestión." .

ex:Parametro_GestionAlmacen_M6Alone
    a               ex:Parametro ;
    rdfs:label      "M6ALONE (Acción al ejecutar M06 sin T seleccionada)" ;
    ex:textoExtracto "M6ALONE Acción al ejecutar una M06 sin T seleccionada." .

ex:Tabla_Management_Magazine a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla MANAGEMENT (Gestión del almacén)" ;
    ex:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén. Este parámetro muestra los datos para configurar la gestión del almacén." ;
    ex:tieneComponente ex:Parametro_GestionAlmacen_Tipo ,
                      ex:Parametro_GestionAlmacen_Ciclico ,
                      ex:Parametro_GestionAlmacen_Optimizacion ,
                      ex:Parametro_GestionAlmacen_M6Alone .