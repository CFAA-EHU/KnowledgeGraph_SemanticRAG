@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_GestionAlmacen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de gestión del almacén de herramientas"@es ;
    ex:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| Síncrono + 1 brazos. Síncrono + 2 brazos. | Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal. [...] Un cambiador de herramientas del tipo no-cíclico permite realizar varias búsquedas de herramienta seguidas, sin efectuar necesariamente el cambio de herramienta (función M06).
CYCLIC Cambiador de herramientas cíclico. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZCYCLIC[mz]
OPTIMIZE Optimización de la gestión. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZOPTIMIZED[mz]
"""@es .

ex:Parametro_CYCLIC
    a ex:Parametro ;
    rdfs:label "CYCLIC (Cambiador de herramientas cíclico)"@es ;
    ex:identificador "TM.MZCYCLIC[mz]" ;
    ex:valor "Sí" ;
    ex:textoExtracto "CYCLIC Cambiador de herramientas cíclico. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZCYCLIC[mz]"@es ;
    ex:documentadoEn ex:Tabla_GestionAlmacen .

ex:Parametro_OPTIMIZE
    a ex:Parametro ;
    rdfs:label "OPTIMIZE (Optimización de la gestión)"@es ;
    ex:identificador "TM.MZOPTIMIZED[mz]" ;
    ex:valor "Sí" ;
    ex:textoExtracto "OPTIMIZE Optimización de la gestión. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZOPTIMIZED[mz]"@es ;
    ex:documentadoEn ex:Tabla_GestionAlmacen .

ex:Sistema_AlmacenHerramientas_Sincrono
    a ex:Sistema ;
    rdfs:label "Sistema de almacén síncrono con brazo cambiador (1 o 2 pinzas)"@es ;
    ex:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza, porque el brazo entraría en colisión."@es ;
    ex:documentadoEn ex:Tabla_GestionAlmacen .

ex:ComponenteMecanico_BrazoCambiador_1Pinza
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de 1 pinza"@es ;
    ex:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal."@es ;
    ex:compuestoPor ex:Sistema_AlmacenHerramientas_Sincrono .

ex:ComponenteMecanico_BrazoCambiador_2Pinzas
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de 2 pinzas"@es ;
    ex:textoExtracto "ejemplo con 2 pinzas [...] el brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio."@es ;
    ex:compuestoPor ex:Sistema_AlmacenHerramientas_Sincrono .

ex:Herramienta_Generica
    a ex:Herramienta ;
    rdfs:label "Herramienta genérica del almacén"@es ;
    ex:textoExtracto "el brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio."@es .