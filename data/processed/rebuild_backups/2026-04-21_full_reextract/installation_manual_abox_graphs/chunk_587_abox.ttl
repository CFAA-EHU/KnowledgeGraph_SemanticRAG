@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_RESPECTSIZES
    a ex:Parametro ;
    rdfs:label "RESPECTSIZES" ;
    ex:textoExtracto "RESPECTSIZES En almacén rándom, buscar huecos del mismo tamaño. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.RESPECTSIZES Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ex:valor "No" ;
    ex:documentadoEn ex:Tabla_MAGAZINE_MANAGEMENT .

ex:Parametro_M6ALONE
    a ex:Parametro ;
    rdfs:label "M6ALONE" ;
    ex:textoExtracto "M6ALONE Acción al ejecutar una M06 sin herramienta seleccionada. Valores posibles: Nada / Mostrar un aviso / Mostrar un error. Valor por defecto: Mostrar un error. Variable asociada: (V.)TM.MZM6ALONE[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ex:valor "Mostrar un error" ;
    ex:documentadoEn ex:Tabla_MAGAZINE_MANAGEMENT .

ex:Tabla_MAGAZINE_MANAGEMENT a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "MAGAZINE // MANAGEMENT" ;
    ex:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .