@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametrosComunicacionHMI_588
    a               ex:Parametro ;
    rdfs:label      "Parámetros de comunicación HMI-CNC"@es ;
    ex:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC. Para validar los cambios que se realicen en estos parámetros es necesario reinicializar el CNC."@es ;
    ex:monitoreaParametro ex:InterfazHMI_588 .

ex:InterfazHMI_588
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz HMI (Human-Machine Interface)"@es ;
    ex:textoExtracto "Parámetros máquina del HMI (interface)"@es .