@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ResolucionVentanaPrincipal a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de resolución de la ventana principal"@es ;
    ex:textoExtracto """
| RESOLUTION. (valor) | Tamaño del interface (píxeles). |
| --- | --- |
| 19\" | 1280 × 1024. |
| 21\" LANDSCAPE | 1300 × 1080. El interface no ocupa toda la pantalla para permitir un teclado virtual. |
| 21\" PORTRAIT | 1080 × 1400. El interface no ocupa toda la pantalla para permitir un teclado virtual.
"""@es ;
    ex:detalladoEnEsquema ex:InterfazUsuario_VentanaPrincipal .

ex:InterfazUsuario_VentanaPrincipal
    a ex:InterfazUsuario ;
    rdfs:label "Ventana principal del HMI"@es ;
    ex:textoExtracto "Dimensiones y resolución de la ventana principal"@es ;
    ex:monitoreaParametro ex:Parametro_Resolution ,
                         ex:Parametro_Width ,
                         ex:Parametro_Height .

ex:Parametro_Resolution
    a ex:Parametro ;
    rdfs:label "RESOLUTION"@es ;
    ex:identificador "RESOLUTION" ;
    ex:textoExtracto "Tamaño del interface (píxeles)."@es ;
    ex:valor "1920x1080"^^xsd:string ;  # Valor representativo de la tabla
    ex:documentadoEn ex:Tabla_ResolucionVentanaPrincipal .

ex:Parametro_Width
    a ex:Parametro ;
    rdfs:label "WIDTH"@es ;
    ex:identificador "WIDTH" ;
    ex:textoExtracto """
WIDTH Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles.
Parámetro incluido en la tabla WINDOW.
"""@es ;
    ex:valor "800"^^xsd:integer ;  # Valor por defecto
    ex:documentadoEn ex:Tabla_ResolucionVentanaPrincipal .

ex:Parametro_Height
    a ex:Parametro ;
    rdfs:label "HEIGHT"@es ;
    ex:identificador "HEIGHT" ;
    ex:textoExtracto """
HEIGHT Altura de la ventana. Valores posibles: De 480 a 1050 píxeles. Valor por defecto: 600 píxeles.
Parámetro incluido en la tabla WINDOW.
"""@es ;
    ex:valor "600"^^xsd:integer ;  # Valor por defecto
    ex:documentadoEn ex:Tabla_ResolucionVentanaPrincipal .