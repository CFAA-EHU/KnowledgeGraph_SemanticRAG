@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ModoInterfaceEstandar
    a ex:Parametro ;
    rdfs:label "Modo de interfaz estándar" ;
    ex:textoExtracto "Árbol de softkeys basado en menús y submenús; es decir, hay distintos niveles de softkeys dentro de un mismo modo de trabajo." ;
    ex:valor "Estándar" .

ex:Parametro_ModoInterfaceDesplegables
    a ex:Parametro ;
    rdfs:label "Modo de interfaz desplegables" ;
    ex:textoExtracto "Árbol de softkeys basado en menús desplegables, de manera que únicamente hay un nivel de softkeys. No hay submenús de softkeys, simplificando así la operativa." ;
    ex:valor "Desplegables" .

ex:Parametro_VMENU
    a ex:Parametro ;
    rdfs:label "Posición del menú vertical de softkeys (VMENU)" ;
    ex:textoExtracto "Posición del menú vertical de softkeys. Valores posibles: Izquierda / Derecha. Valor por defecto: Derecha." ;
    ex:valor "Derecha" .

ex:Parametro_LANGUAGE
    a ex:Parametro ;
    rdfs:label "Idioma de trabajo (LANGUAGE)" ;
    ex:textoExtracto "Idioma de trabajo. Valor por defecto: English. Seleccionar un idioma entre los disponibles." ;
    ex:valor "English" .

ex:Parametro_FFORMAT
    a ex:Parametro ;
    rdfs:label "Formato de visualización de F programada (FFORMAT)" ;
    ex:textoExtracto "Formato de visualización de la F programada. Valor por defecto: 5.2. Este parámetro establece el formato numérico (enteros y decimales) para visualizar el avance." ;
    ex:valor "5.2" .

ex:Parametro_SFORMAT
    a ex:Parametro ;
    rdfs:label "Formato de visualización de S programada (SFORMAT)" ;
    ex:textoExtracto "Formato de visualización de la S programada. Valor por defecto: 5.1. Este parámetro establece el formato numérico (enteros y decimales) para visualizar la velocidad." ;
    ex:valor "5.1" .

ex:Parametro_MMINCHSOFTKEY
    a ex:Parametro ;
    rdfs:label "Mostrar softkey para cambio mm/pulgadas (MMINCHSOFTKEY)" ;
    ex:textoExtracto "Mostrar la softkey para cambiar el formato de visualización entre milímetros y pulgadas. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No" .

ex:InterfazUsuario_Personalizacion
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario personalizable" ;
    ex:textoExtracto "Personalización del interface. VMENU, LANGUAGE, FFORMAT, SFORMAT, MMINCHSOFTKEY." ;
    ex:tieneComponente ex:Parametro_VMENU ;
    ex:tieneComponente ex:Parametro_LANGUAGE ;
    ex:tieneComponente ex:Parametro_FFORMAT ;
    ex:tieneComponente ex:Parametro_SFORMAT ;
    ex:tieneComponente ex:Parametro_MMINCHSOFTKEY ;
    ex:tieneComponente ex:Parametro_ModoInterfaceEstandar ;
    ex:tieneComponente ex:Parametro_ModoInterfaceDesplegables .