@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tecla_NEXT
    a ex:InterfazUsuario ;
    rdfs:label "Tecla NEXT" ;
    ex:textoExtracto "Configuración del teclado (tecla [NEXT])."@es ;
    ex:tieneComponente ex:Menu_Configuracion_NEXT .

ex:Menu_Configuracion_NEXT
    a ex:InterfazUsuario ;
    rdfs:label "Menú de configuración (tecla NEXT)" ;
    ex:textoExtracto "El menú estará deshabilitado. [...] El menú muestra los componentes o modos de trabajo del CNC."@es ;
    ex:tieneComponente ex:Opcion_Deshabilitado, ex:Opcion_Paginas, ex:Opcion_Canales, ex:Opcion_Componentes .

ex:Opcion_Deshabilitado
    a ex:Parametro ;
    rdfs:label "Deshabilitado" ;
    ex:valor "Deshabilitado" ;
    ex:textoExtracto "Deshabilitado. El menú estará deshabilitado."@es .

ex:Opcion_Paginas
    a ex:Parametro ;
    rdfs:label "Páginas" ;
    ex:valor "Páginas" ;
    ex:textoExtracto "Páginas. El menú muestra las distintas páginas o pantallas del modo de trabajo activo."@es .

ex:Opcion_Canales
    a ex:Parametro ;
    rdfs:label "Canales" ;
    ex:valor "Canales" ;
    ex:textoExtracto "Canales. El menú muestra la lista de canales disponibles."@es .

ex:Opcion_Componentes
    a ex:Parametro ;
    rdfs:label "Componentes" ;
    ex:valor "Componentes" ;
    ex:textoExtracto "Componentes. El menú muestra los componentes o modos de trabajo del CNC."@es .