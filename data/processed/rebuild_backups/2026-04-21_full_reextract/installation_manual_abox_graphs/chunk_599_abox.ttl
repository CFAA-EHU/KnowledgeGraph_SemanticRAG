@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tecla_ESC
    a ex:InterfazUsuario ;
    rdfs:label "Tecla [ESC]" ;
    ex:textoExtracto "En cada componente, la tecla [ESC] primero sube de menú hasta alcanzar el menú principal del componente." .

ex:Parametro_NPREVIOUS
    a ex:Parametro ;
    rdfs:label "NPREVIOUS" ;
    ex:identificador "NPREVIOUS" ;
    ex:valor "1" ;
    ex:textoExtracto "NPREVIOUS Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1." ;
    ex:documentadoEn ex:Tabla_ESCAPEKEY .

ex:Tabla_ESCAPEKEY a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla ESCAPEKEY" ;
    ex:identificador "ESCAPEKEY" ;
    ex:textoExtracto "Parámetro incluido en la tabla ESCAPEKEY." .