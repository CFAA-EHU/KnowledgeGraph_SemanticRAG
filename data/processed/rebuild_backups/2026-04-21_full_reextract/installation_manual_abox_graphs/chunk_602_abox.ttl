@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GRAPHTYPE
    a ex:Parametro ;
    rdfs:label "GRAPHTYPE" ;
    ex:textoExtracto "GRAPHTYPE Lista de gráficos en cada canal. En el modelo torno, este parámetro muestra la tabla para definir la configuración de los gráficos en cada canal." ;
    ex:identificador "GRAPHTYPE" .

ex:Parametro_GRAPHTYPECH_n
    a ex:Parametro ;
    rdfs:label "GRAPHTYPECH n" ;
    ex:textoExtracto "GRAPHTYPECH n Tipo de gráfico en cada canal. Valores posibles: Torno horizontal o vertical; X+ Z+ / X- Z+ / X+ Z- / X- Z-. Valor por defecto: Horizontal X+ Z+." ;
    ex:identificador "GRAPHTYPECH n" ;
    ex:valor "Horizontal X+ Z+"^^xsd:string .

ex:Tabla_GRAPHTYPE a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla GRAPHTYPE" ;
    ex:textoExtracto "Parámetro incluido en la tabla GRAPHTYPE." ;
    ex:documentadoEn ex:Manual_Torno ;
    ex:tieneComponente ex:Parametro_GRAPHTYPECH_n .

ex:InterfazUsuario_FGUIM
    a ex:InterfazUsuario ;
    rdfs:label "Aplicación FGUIM" ;
    ex:textoExtracto "Para ello, utilizando la aplicación FGUIM, se deben modificar las propiedades Channel1 y Channel2 de la ventana gráfica para poder ver en un gráfico la ejecución de ambos canales." .

ex:Sistema_TornoTT
    a ex:Sistema ;
    rdfs:label "Torno de doble torreta (TT)" ;
    ex:textoExtracto "También es posible representar los gráficos de un torno de doble torreta (torno TT)." ;
    ex:ilustradoEn ex:InterfazUsuario_FGUIM .