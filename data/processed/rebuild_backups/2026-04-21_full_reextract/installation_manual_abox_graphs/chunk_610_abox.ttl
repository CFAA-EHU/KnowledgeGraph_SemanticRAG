@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosMTB a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros genéricos del fabricante (V.MTB.P[i])"@es ;
    ex:textoExtracto """
| Mnemónico. | Valor. | V.MTB.P[i] | V.MTB.PF[i] |
| --- | --- | --- | --- |
| P0 | 7 | V.MTB.P[0] = 7 | V.MTB.PF[0] = 70000 |
| P8 | 12,5 | V.MTB.P[8] = 12,5 | V.MTB.PF[8] = 125000
"""@es ;
    ex:tieneComponente ex:ParametroP0, ex:ParametroP8 .

ex:ParametroP0
    a ex:Parametro ;
    rdfs:label "Parámetro P0 (V.MTB.P[0])"@es ;
    ex:identificador "P0" ;
    ex:valor "7" ;
    ex:textoExtracto "P0 | 7 | V.MTB.P[0] = 7 | V.MTB.PF[0] = 70000"@es .

ex:ParametroP8
    a ex:Parametro ;
    rdfs:label "Parámetro P8 (V.MTB.P[8])"@es ;
    ex:identificador "P8" ;
    ex:valor "12.5" ;
    ex:textoExtracto "P8 | 12,5 | V.MTB.P[8] = 12,5 | V.MTB.PF[8] = 125000"@es .

ex:ModoSetup
    a ex:ModoOperacion ;
    rdfs:label "Modo Setup (acceso a parámetros)"@es ;
    ex:textoExtracto """
Modo Setup. Las variables pueden modificar los parámetros de solo lectura, desde un programa pieza. [...] Los nuevos valores se mantienen tras reiniciar o apagar el CNC.
"""@es .

ex:ModoUser
    a ex:ModoOperacion ;
    rdfs:label "Modo User (acceso a parámetros)"@es ;
    ex:textoExtracto """
Modo User. Las variables sólo pueden escribir los parámetros con permiso de escritura. [...] Los nuevos valores se mantienen tras reiniciar o apagar el CNC.
"""@es .

ex:AtributoMODE
    a ex:Parametro ;
    rdfs:label "Atributo MODE (modo de acceso al parámetro)"@es ;
    ex:textoExtracto """
MODE Modo de acceso al parámetro desde su variable. Valores posibles: Lectura / Escritura. Valor por defecto: Lectura.
"""@es ;
    ex:valor "Lectura" .

ex:AtributoINCHES
    a ex:Parametro ;
    rdfs:label "Atributo INCHES (afectación por cambio de unidades)"@es ;
    ex:textoExtracto """
INCHES El parámetro se ve afectado por el cambio de unidades. Valores posibles: Sí / No. Valor por defecto: Sí.
"""@es ;
    ex:valor "Sí" .

ex:AtributoCOMMENT
    a ex:Parametro ;
    rdfs:label "Atributo COMMENT (descripción OEM)"@es ;
    ex:textoExtracto """
COMMENT Descripción del parámetro OEM. [...] Los comentarios se guardan en el archivo MTBComments.txt.
"""@es .