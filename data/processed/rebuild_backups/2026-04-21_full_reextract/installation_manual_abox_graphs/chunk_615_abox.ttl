@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloPrimerCiclo_CY1
    a ex:Sistema ;
    rdfs:label "Módulo del primer ciclo (CY1)"@es ;
    ex:textoExtracto "Módulo del primer ciclo (CY1). [...] El PLC ejecuta el módulo de primer ciclo una única vez, cuando arranca el programa de PLC. Este módulo permite inicializar los diferentes recursos y variables antes de proceder a la ejecución del programa."@es ;
    ex:identificador "CY1" .

ex:ModuloPrincipal_PRG
    a ex:Sistema ;
    rdfs:label "Módulo principal (PRG)"@es ;
    ex:textoExtracto "Módulo principal. [...] El módulo principal comienza con la proposición directiva PRG y termina con la proposición directiva END. El PLC ejecuta el módulo principal de forma cíclica, con la frecuencia fijada por el parámetro PRGFREQ."@es ;
    ex:identificador "PRG" ;
    ex:tieneComponente ex:Parametro_PRGFREQ .

ex:ModuloEjecucionPeriodica_PE
    a ex:Sistema ;
    rdfs:label "Módulo de ejecución periódica (PE)"@es ;
    ex:textoExtracto "Módulo de ejecución periódica. [...] El módulo periódico comienza con la proposición directiva PE y termina con la proposición directiva END. El PLC ejecuta el módulo periódico de forma periódica, con la frecuencia fijada en la directiva PE."@es ;
    ex:identificador "PE" .

ex:Parametro_PRGFREQ
    a ex:Parametro ;
    rdfs:label "PRGFREQ" ;
    ex:textoExtracto "El parámetro PRGFREQ indica con qué frecuencia (cada cuántos ciclos de CNC) el PLC ejecuta un ciclo completo del módulo principal."@es ;
    ex:valor "2"^^xsd:integer ;  # Ejemplo extraído del texto: "PRGFREQ=2"
    ex:identificador "PRGFREQ" .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "periodo de muestreo de 4 ms (LOOPTIME=4)"@es ;
    ex:valor "4"^^xsd:integer ;
    ex:identificador "LOOPTIME" .

ex:EstructuraModularPLC_Seccion3_2
    a ex:Sistema ;
    rdfs:label "Estructura modular del programa de PLC (Sección 3.2)"@es ;
    ex:textoExtracto "El programa PLC puede estar formado por los siguientes módulos. Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE) y finalizar con la proposición directiva END."@es ;
    ex:compuestoPor ex:ModuloPrimerCiclo_CY1 ;
    ex:compuestoPor ex:ModuloPrincipal_PRG ;
    ex:compuestoPor ex:ModuloEjecucionPeriodica_PE .