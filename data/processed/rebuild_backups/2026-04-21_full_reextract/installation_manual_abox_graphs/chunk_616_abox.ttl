@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloPeriodico_PE30000
    a               ex:ModoOperacion ;
    rdfs:label      "Módulo periódico PE 30000"@es ;
    ex:identificador "PE 30000" ;
    ex:textoExtracto "Una tarea que es suficiente evaluarla cada 30 segundos se definirá en un módulo periódico que se ejecute cada 30 segundos (PE 30000)."@es ;
    ex:tieneFrecuencia ex:Frecuencia_30segundos .

ex:Frecuencia_30segundos
    a               ex:Frecuencia ;
    rdfs:label      "30 segundos"@es ;
    ex:valor        "30"^^<http://www.w3.org/2001/XMLSchema#integer> ;
    ex:textoExtracto "módulo periódico que se ejecute cada 30 segundos"@es .