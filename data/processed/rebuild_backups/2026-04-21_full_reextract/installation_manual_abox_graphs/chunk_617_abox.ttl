@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloPrincipal_PRG
    a ex:Sistema ;
    rdfs:label "Módulo principal (PRG)" ;
    ex:textoExtracto "El procesamiento del módulo principal se desarrolla de la siguiente forma: [...] El PLC ejecuta el módulo principal (PRG)." ;
    ex:identificador "PRG" .

ex:ModuloPeriodico_PE
    a ex:Sistema ;
    rdfs:label "Módulo periódico (PE)" ;
    ex:textoExtracto "El procesamiento del módulo periódico se desarrolla de la siguiente forma: [...] El PLC ejecuta el módulo periódico." ;
    ex:identificador "PE" .

ex:EntradasFisicas_ModulosRemotos
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas físicas (módulos remotos)" ;
    ex:textoExtracto "El PLC asigna a los recursos I los valores que disponen en este momento las entradas físicas (módulos remotos)." .

ex:SalidasFisicas_ModulosRemotos
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas físicas (módulos remotos)" ;
    ex:textoExtracto "El PLC asigna a las salidas físicas (módulos remotos) los valores que disponen en este momento los recursos O del PLC." .

ex:VariablesInternas_CNC
    a ex:Parametro ;
    rdfs:label "Variables internas del CNC" ;
    ex:textoExtracto "El PLC asume los valores que disponen las variables internas del CNC (CNCREADY, START, FHOUT, ...)." ;
    ex:identificador "CNCREADY, START, FHOUT, EMERGEN, STOP, FEEDHOL" .

ex:ModuloPrincipal_PRG
    ex:monitoreaParametro ex:VariablesInternas_CNC ;
    ex:tieneComponente ex:EntradasFisicas_ModulosRemotos ;
    ex:tieneComponente ex:SalidasFisicas_ModulosRemotos .

ex:ModuloPeriodico_PE
    ex:tieneComponente ex:EntradasFisicas_ModulosRemotos ;
    ex:tieneComponente ex:SalidasFisicas_ModulosRemotos .