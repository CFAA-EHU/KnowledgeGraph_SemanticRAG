@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_Recursos_EntradasSalidas
    a ex:Sistema ;
    rdfs:label "Recursos de E/S del PLC"@es ;
    ex:textoExtracto "El PLC dispone de los siguientes recursos. • Entradas (I1-I1024) y salidas (O1-O1024). [...] Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico."@es ;
    ex:tieneComponente ex:PLC_Entradas_Globales, ex:PLC_Salidas_Globales, ex:PLC_EntradasLocales, ex:PLC_SalidasLocales .

ex:PLC_Entradas_Globales
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas globales del PLC (I1-I1024)"@es ;
    ex:identificador "I1-I1024" ;
    ex:textoExtracto "Entradas (I1-I1024). [...] Las entradas son elementos que proporcionan información al PLC de las señales que se reciben del exterior."@es .

ex:PLC_Salidas_Globales
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas globales del PLC (O1-O1024)"@es ;
    ex:identificador "O1-O1024" ;
    ex:textoExtracto "Salidas (O1-O1024). [...] Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico."@es .

ex:PLC_EntradasLocales
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas locales del PLC (LI1-LI16)"@es ;
    ex:identificador "LI1-LI16" ;
    ex:textoExtracto "Entradas locales (LI1-LI16). [...] Las unidades centrales ICU y MCU disponen de 8 entradas digitales [...] Se denominan entradas locales porque se encuentran en la unidad central."@es .

ex:PLC_SalidasLocales
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas locales del PLC (LO1-LO8)"@es ;
    ex:identificador "LO1-LO8" ;
    ex:textoExtracto "Salidas locales (LO1-LO8). [...] un conjunto de 8 señales digitales locales que pueden configurarse tanto de entrada como de salida."@es .

ex:PLC_Recursos_Memoria
    a ex:Sistema ;
    rdfs:label "Recursos de memoria y temporización del PLC"@es ;
    ex:textoExtracto "Marcas (M1-M8192). [...] Mensajes (MSG1-MSG1024). [...] Errores (ERR1-ERR1024). [...] Relojes (CLK). [...] Registros (R1-R1024). [...] Temporizadores (T1-T512). [...] Contadores (C1-C256)."@es ;
    ex:tieneComponente ex:PLC_Marcas, ex:PLC_Mensajes, ex:PLC_Errores, ex:PLC_Relojes, ex:PLC_Registros, ex:PLC_Temporizadores, ex:PLC_Contadores .

ex:PLC_Marcas
    a ex:Parametro ;
    rdfs:label "Marcas del PLC (M1-M8192)"@es ;
    ex:identificador "M1-M8192" ;
    ex:textoExtracto "Marcas (M1-M8192). [...] Los recursos M [...] mantiene su valor entre arranque y arranque del CNC."@es .

ex:PLC_Mensajes
    a ex:Parametro ;
    rdfs:label "Mensajes del PLC (MSG1-MSG1024)"@es ;
    ex:identificador "MSG1-MSG1024" ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024). [...] Los recursos MSG [...] se inicializan a (=0) en el arranque del PLC."@es .

ex:PLC_Errores
    a ex:Parametro ;
    rdfs:label "Errores del PLC (ERR1-ERR1024)"@es ;
    ex:identificador "ERR1-ERR1024" ;
    ex:textoExtracto "Errores (ERR1-ERR1024). [...] Los recursos ERR [...] se inicializan a (=0) en el arranque del PLC."@es .

ex:PLC_Relojes
    a ex:Parametro ;
    rdfs:label "Relojes del PLC (CLK)"@es ;
    ex:identificador "CLK" ;
    ex:textoExtracto "Relojes (CLK). [...] Los recursos CLK [...] se inicializan a (=0) en el arranque del PLC."@es .

ex:PLC_Registros
    a ex:Parametro ;
    rdfs:label "Registros del PLC (R1-R1024)"@es ;
    ex:identificador "R1-R1024" ;
    ex:textoExtracto "Registros (R1-R1024). [...] Los recursos R mantiene su valor entre arranque y arranque del CNC."@es .

ex:PLC_Temporizadores
    a ex:Parametro ;
    rdfs:label "Temporizadores del PLC (T1-T512)"@es ;
    ex:identificador "T1-T512" ;
    ex:textoExtracto "Temporizadores (T1-T512). [...] Los recursos T se inicializan a (=0) en el arranque del PLC."@es .

ex:PLC_Contadores
    a ex:Parametro ;
    rdfs:label "Contadores del PLC (C1-C256)"@es ;
    ex:identificador "C1-C256" ;
    ex:textoExtracto "Contadores (C1-C256). [...] Los recursos C mantiene su valor entre arranque y arranque del CNC."@es .