@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_ALARM
    a ex:Alarma ;
    rdfs:label "Señal _ALARM"@es ;
    ex:textoExtracto "Los errores no activan la alarma del CNC, señal (_ALARM)."@es .

ex:RelojesPLC
    a ex:Sistema ;
    rdfs:label "Relojes internos del PLC"@es ;
    ex:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC."@es ;
    ex:identificador "CLK" .

ex:MarcaReloj_0
    a ex:Parametro ;
    rdfs:label "Marca de reloj CLK0"@es ;
    ex:textoExtracto "Todos ellos se inicializan a (=0) en el arranque del PLC."@es ;
    ex:valor "0" ;
    ex:monitoreaParametro ex:RelojesPLC .