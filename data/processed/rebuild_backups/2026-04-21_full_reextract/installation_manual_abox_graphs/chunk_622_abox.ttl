@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_Programa_622
    a               ex:Sistema ;
    rdfs:label      "Programa de PLC (sección 3.4)"@es ;
    ex:textoExtracto "en el programa de PLC. Se representan mediante CLK seguido del número de reloj que se desea referenciar. Todos ellos se inicializan a (=0) en el arranque del PLC."@es ;
    ex:identificador "Sección 3.4 - Recursos del PLC"@es .

ex:MarcaReloj_CLK_622
    a               ex:Parametro ;
    rdfs:label      "Marca de reloj (CLK)"@es ;
    ex:textoExtracto "Se representan mediante CLK seguido del número de reloj que se desea referenciar. Todos ellos se inicializan a (=0) en el arranque del PLC."@es ;
    ex:monitoreaParametro ex:PLC_Programa_622 ;
    ex:valor "Inicialización: 0"@es .

ex:Tabla_PeriodosReloj_622 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de medios periodos de marcas de reloj"@es ;
    ex:textoExtracto "Estas son las marcas de reloj disponibles. Junto a ellas se indica su medio periodo o cada cuanto tiempo cambia de estado (0/1)."@es ;
    ex:documentadoEn ex:PLC_Programa_622 .