@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaNumeracionE_S
    a ex:Sistema ;
    rdfs:label "Sistema de numeración de entradas/salidas físicas" ;
    ex:textoExtracto "Desde los parámetros máquina se puede personalizar la numeración de los módulos de entradas y salidas. Si no se definen estos parámetros, el CNC numera los módulos automáticamente según el orden de los módulos remotos." ;
    ex:tieneComponente ex:ModuloRemotoGrupo1, ex:ModuloRemotoGrupo2, ex:ModuloRemotoGrupo3 ;
    ex:tieneComponente ex:ModuloPersonalizado1, ex:ModuloPersonalizado2, ex:ModuloPersonalizado3, ex:ModuloPersonalizado4 ;
    ex:monitoreaParametro ex:ParametroIndiceBase .

ex:ParametroIndiceBase
    a ex:Parametro ;
    rdfs:label "Índice base de numeración" ;
    ex:textoExtracto "Los valores del índice base deben ser múltiplos de 16, más 1 (es decir, 1, 17, 33...)." ;
    ex:valor "1, 17, 33, 49, 65, 81, 97, 113" .

ex:ModuloRemotoGrupo1
    a ex:ComponenteElectrico ;
    rdfs:label "Grupo 1 de módulos remotos" ;
    ex:identificador "Grupo 1" ;
    ex:textoExtracto "O1...O32 | I1...I48" ;
    ex:compuestoPor ex:SalidasGrupo1_1_32, ex:EntradasGrupo1_1_48 .

ex:SalidasGrupo1_1_32
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O1 a O32 (Grupo 1)" ;
    ex:identificador "O1...O32" ;
    ex:textoExtracto "O1...O32" .

ex:EntradasGrupo1_1_48
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I1 a I48 (Grupo 1)" ;
    ex:identificador "I1...I48" ;
    ex:textoExtracto "I1...I48" .

ex:ModuloRemotoGrupo2
    a ex:ComponenteElectrico ;
    rdfs:label "Grupo 2 de módulos remotos" ;
    ex:identificador "Grupo 2" ;
    ex:textoExtracto "O33...O48 | I49...I64" ;
    ex:compuestoPor ex:SalidasGrupo2_33_48, ex:EntradasGrupo2_49_64 .

ex:SalidasGrupo2_33_48
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O33 a O48 (Grupo 2)" ;
    ex:identificador "O33...O48" ;
    ex:textoExtracto "O33...O48" .

ex:EntradasGrupo2_49_64
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I49 a I64 (Grupo 2)" ;
    ex:identificador "I49...I64" ;
    ex:textoExtracto "I49...I64" .

ex:ModuloRemotoGrupo3
    a ex:ComponenteElectrico ;
    rdfs:label "Grupo 3 de módulos remotos" ;
    ex:identificador "Grupo 3" ;
    ex:textoExtracto "O49...O64 | I65...I96" ;
    ex:compuestoPor ex:SalidasGrupo3_49_64, ex:EntradasGrupo3_65_96 .

ex:SalidasGrupo3_49_64
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O49 a O64 (Grupo 3)" ;
    ex:identificador "O49...O64" ;
    ex:textoExtracto "O49...O64" .

ex:EntradasGrupo3_65_96
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I65 a I96 (Grupo 3)" ;
    ex:identificador "I65...I96" ;
    ex:textoExtracto "I65...I96" .

ex:ModuloPersonalizado1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 1 (numeración personalizada)" ;
    ex:identificador "Módulo 1" ;
    ex:textoExtracto "Módulo 1. | 1 | I1...I16 | 33 O33...O48" ;
    ex:compuestoPor ex:EntradasMod1_1_16, ex:SalidasMod1_33_48 .

ex:EntradasMod1_1_16
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I1 a I16 (Módulo 1 personalizado)" ;
    ex:identificador "I1...I16" ;
    ex:textoExtracto "I1...I16" .

ex:SalidasMod1_33_48
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O33 a O48 (Módulo 1 personalizado)" ;
    ex:identificador "O33...O48" ;
    ex:textoExtracto "O33...O48" .

ex:ModuloPersonalizado2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 2 (numeración personalizada)" ;
    ex:identificador "Módulo 2" ;
    ex:textoExtracto "Módulo 2. | 33 | I33...I48 | 81 O81...O96" ;
    ex:compuestoPor ex:EntradasMod2_33_48, ex:SalidasMod2_81_96 .

ex:EntradasMod2_33_48
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I33 a I48 (Módulo 2 personalizado)" ;
    ex:identificador "I33...I48" ;
    ex:textoExtracto "I33...I48" .

ex:SalidasMod2_81_96
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O81 a O96 (Módulo 2 personalizado)" ;
    ex:identificador "O81...O96" ;
    ex:textoExtracto "O81...O96" .

ex:ModuloPersonalizado3
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 3 (numeración personalizada)" ;
    ex:identificador "Módulo 3" ;
    ex:textoExtracto "Módulo 3. | 97 | I97...I112 | 49 O49...O64" ;
    ex:compuestoPor ex:EntradasMod3_97_112, ex:SalidasMod3_49_64 .

ex:EntradasMod3_97_112
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I97 a I112 (Módulo 3 personalizado)" ;
    ex:identificador "I97...I112" ;
    ex:textoExtracto "I97...I112" .

ex:SalidasMod3_49_64
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales O49 a O64 (Módulo 3 personalizado)" ;
    ex:identificador "O49...O64" ;
    ex:textoExtracto "O49...O64" .

ex:ModuloPersonalizado4
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 4 (numeración personalizada, solo entradas)" ;
    ex:identificador "Módulo 4" ;
    ex:textoExtracto "Módulo 4. | 113 | I113...I128 | - - - - - -" ;
    ex:compuestoPor ex:EntradasMod4_113_128 .

ex:EntradasMod4_113_128
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales I113 a I128 (Módulo 4 personalizado)" ;
    ex:identificador "I113...I128" ;
    ex:textoExtracto "I113...I128" .