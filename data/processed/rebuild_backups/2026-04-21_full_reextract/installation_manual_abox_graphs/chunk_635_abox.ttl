@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EntradaCPR_Contador
    a               ex:InterfazUsuario ;
    rdfs:label      "Entrada de preselección (CPR)"@es ;
    ex:identificador "CPR" ;
    ex:textoExtracto "Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es ;
    ex:monitoreaParametro ex:Parametro_ValorContador .

ex:Parametro_ValorContador
    a               ex:Parametro ;
    rdfs:label      "Valor de cuenta del contador"@es ;
    ex:valor        "0 a ±2147483647" ;
    ex:textoExtracto "El valor de la cuenta puede indicarse con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y ± 2.147.483.647."@es .