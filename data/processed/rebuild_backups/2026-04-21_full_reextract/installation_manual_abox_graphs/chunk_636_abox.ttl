@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Contador_C20
    a ex:ComponenteElectrico ;
    rdfs:label "Contador C20" ;
    ex:textoExtracto "Preselecciona el contador C20 con el valor 100." ;
    ex:identificador "C20" ;
    ex:monitoreaParametro ex:Parametro_ValorC20 .

ex:Parametro_ValorC20
    a ex:Parametro ;
    rdfs:label "Valor del contador C20" ;
    ex:textoExtracto "Preselecciona el contador C20 con el valor 100." ;
    ex:valor "100"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Contador_C22
    a ex:ComponenteElectrico ;
    rdfs:label "Contador C22" ;
    ex:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." ;
    ex:identificador "C22" ;
    ex:monitoreaParametro ex:Parametro_ValorC22 .

ex:Parametro_ValorC22
    a ex:Parametro ;
    rdfs:label "Valor del contador C22" ;
    ex:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." ;
    ex:valor "R200" .  # Valor referenciado dinámicamente

ex:Contador_Generico
    a ex:ComponenteElectrico ;
    rdfs:label "Contador genérico (C1, C25, C102, etc.)" ;
    ex:textoExtracto "(C) Salida de estado. Indica el estado lógico del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." ;
    ex:monitoreaParametro ex:Parametro_EstadoLogicoContador ;
    ex:monitoreaParametro ex:Parametro_ValorCuentaContador .

ex:Parametro_EstadoLogicoContador
    a ex:Parametro ;
    rdfs:label "Estado lógico del contador (C=1 si cuenta es cero, C=0 en otros casos)" ;
    ex:textoExtracto "El estado lógico del contador será C=1 cuando el valor de la cuenta sea cero y C=0 el resto de los casos." ;
    ex:valor "0"^^<http://www.w3.org/2001/XMLSchema#integer>, "1"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_ValorCuentaContador
    a ex:Parametro ;
    rdfs:label "Valor de la cuenta interna del contador" ;
    ex:textoExtracto "Indica el valor de la cuenta interna del contador. [...] Su representación C123 coincide con la salida de estado pero se utilizan en instrucciones de tipo distinto." ;
    ex:valor "32 bits" .  # Representación de la variable

ex:Instruccion_MOV_C123_R200
    a ex:TareaMantenimiento ;  # Aproximación más cercana para instrucción de transferencia
    rdfs:label "Instrucción MOV C123 R200" ;
    ex:textoExtracto "I2 = MOV C123 R200. Transfiere la cuenta de C123 al registro R200." ;
    ex:controla ex:Parametro_ValorCuentaContador .

ex:Instruccion_CPS_C123_GT_1000
    a ex:TareaMantenimiento ;  # Aproximación para instrucción de comparación
    rdfs:label "Instrucción CPS C123 > 1000" ;
    ex:textoExtracto "CPS C123 GT 1000 = M100. Compara si la cuenta de C123 es mayor que 1000, en cuyo caso activa la marca M100." ;
    ex:monitoreaParametro ex:Parametro_ValorCuentaContador ;
    ex:activaAlarma ex:Marca_M100 .  # Aproximación: marca como alarma lógica

ex:Marca_M100
    a ex:Alarma ;
    rdfs:label "Marca M100" ;
    ex:textoExtracto "CPS C123 GT 1000 = M100. [...] activa la marca M100." ;
    ex:identificador "M100" .