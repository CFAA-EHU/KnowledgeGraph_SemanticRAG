@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloPrimerCiclo_PLC
    a               ex:Sistema ;
    rdfs:label      "Módulo del primer ciclo (CY1)"@es ;
    ex:textoExtracto "Módulo del primer ciclo (CY1)."@es ;
    ex:identificador "CY1" .

ex:ModuloPrincipal_PLC
    a               ex:Sistema ;
    rdfs:label      "Módulo principal (PRG)"@es ;
    ex:textoExtracto "Módulo principal (PRG)."@es ;
    ex:identificador "PRG" .

ex:ModuloEjecucionPeriodica_PLC
    a               ex:Sistema ;
    rdfs:label      "Módulo de ejecución periódica (PE)"@es ;
    ex:textoExtracto "Módulo de ejecución periódica (PE)."@es ;
    ex:identificador "PE" .

ex:Directiva_CY1
    a               ex:Directiva ;
    rdfs:label      "Directiva CY1"@es ;
    ex:textoExtracto "proposición directiva que lo define (CY1)"@es ;
    ex:identificador "CY1" .

ex:Directiva_PRG
    a               ex:Directiva ;
    rdfs:label      "Directiva PRG"@es ;
    ex:textoExtracto "proposición directiva que lo define (PRG)"@es ;
    ex:identificador "PRG" .

ex:Directiva_PE
    a               ex:Directiva ;
    rdfs:label      "Directiva PE"@es ;
    ex:textoExtracto "proposición directiva que lo define (PE)"@es ;
    ex:identificador "PE" .

ex:Directiva_END
    a               ex:Directiva ;
    rdfs:label      "Directiva END"@es ;
    ex:textoExtracto "finalizar con la proposición directiva END"@es ;
    ex:identificador "END" .

ex:Directiva_REA
    a               ex:Directiva ;
    rdfs:label      "Directiva REA"@es ;
    ex:textoExtracto "sobre la forma en que debe ejecutarse el mismo (REA)"@es ;
    ex:identificador "REA" .

ex:Directiva_IMA
    a               ex:Directiva ;
    rdfs:label      "Directiva IMA"@es ;
    ex:textoExtracto "sobre la forma en que debe ejecutarse el mismo (IMA)"@es ;
    ex:identificador "IMA" .

ex:ProposicionLogica_Ejemplo1
    a               ex:Parametro ;
    rdfs:label      "Expresión lógica: I32 AND I36 AND M111 = O25"@es ;
    ex:textoExtracto "I32 AND I36 AND M111 = O25"@es ;
    ex:valor         "I32 AND I36 AND M111 = O25" .

ex:ProposicionLogica_Ejemplo2
    a               ex:Parametro ;
    rdfs:label      "Expresión lógica multilineal sin carácter de partición"@es ;
    ex:textoExtracto "I32 AND I36 AND M111\n= O25"@es ;
    ex:valor         "I32 AND I36 AND M111\n= O25" .

ex:ProposicionLogica_Ejemplo3
    a               ex:Parametro ;
    rdfs:label      "Expresión lógica multilineal con saltos de línea"@es ;
    ex:textoExtracto "I32\nAND I36\nAND M111\n= O25"@es ;
    ex:valor         "I32\nAND I36\nAND M111\n= O25" .

ex:ProposicionLogica_Ejemplo4
    a               ex:Parametro ;
    rdfs:label      "Expresión lógica multilineal con carácter \"\\\""@es ;
    ex:textoExtracto "I32\\\nAND I36\\\nAND M111\n= O25"@es ;
    ex:valor         "I32\\\nAND I36\\\nAND M111\n= O25" .

ex:Comentario_PLC
    a               ex:InterfazUsuario ;
    rdfs:label      "Comentario en programa PLC"@es ;
    ex:textoExtracto "Todos los comentarios deben comenzar con el carácter punto y coma \";\". Las líneas que comienzan con el carácter \";\" son consideradas como comentario y no se ejecutan."@es ;
    ex:identificador ";" .

ex:ModuloPrimerCiclo_PLC
    ex:cumpleNormativa ex:Directiva_CY1 ;
    ex:cumpleNormativa ex:Directiva_END .

ex:ModuloPrincipal_PLC
    ex:cumpleNormativa ex:Directiva_PRG ;
    ex:cumpleNormativa ex:Directiva_END .

ex:ModuloEjecucionPeriodica_PLC
    ex:cumpleNormativa ex:Directiva_PE ;
    ex:cumpleNormativa ex:Directiva_END .