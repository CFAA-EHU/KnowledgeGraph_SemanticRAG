@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Directiva_PRG
    a ex:Directiva ;
    rdfs:label "PRG" ;
    ex:textoExtracto "PRG Módulo principal." ;
    ex:identificador "PRG" .

ex:Directiva_PE_t
    a ex:Directiva ;
    rdfs:label "PE t" ;
    ex:textoExtracto "PE t Módulo periódico. Se ejecuta cada t milisegundos." ;
    ex:identificador "PE t" .

ex:Directiva_CY1
    a ex:Directiva ;
    rdfs:label "CY1" ;
    ex:textoExtracto "CY1 Módulo de primer ciclo." ;
    ex:identificador "CY1" .

ex:Directiva_END
    a ex:Directiva ;
    rdfs:label "END" ;
    ex:textoExtracto "END Final del módulo o subrutina. Hay que definirlo para cada módulo o subrutina." ;
    ex:identificador "END" .

ex:Directiva_REA
    a ex:Directiva ;
    rdfs:label "REA" ;
    ex:textoExtracto "REA, IMA Valores reales o imagen." ;
    ex:identificador "REA" .

ex:Directiva_IMA
    a ex:Directiva ;
    rdfs:label "IMA" ;
    ex:textoExtracto "REA, IMA Valores reales o imagen." ;
    ex:identificador "IMA" .

ex:Directiva_L
    a ex:Directiva ;
    rdfs:label "L" ;
    ex:textoExtracto "L Etiqueta." ;
    ex:identificador "L" .

ex:Directiva_SUB
    a ex:Directiva ;
    rdfs:label "SUB" ;
    ex:textoExtracto "SUB Definición de subrutina." ;
    ex:identificador "SUB" .

ex:Directiva_DEF
    a ex:Directiva ;
    rdfs:label "DEF" ;
    ex:textoExtracto "DEF, PDEF Definición de símbolo." ;
    ex:identificador "DEF" .

ex:Directiva_PDEF
    a ex:Directiva ;
    rdfs:label "PDEF" ;
    ex:textoExtracto "DEF, PDEF Definición de símbolo." ;
    ex:identificador "PDEF" .

ex:Directiva_NOMONIT
    a ex:Directiva ;
    rdfs:label "NOMONIT" ;
    ex:textoExtracto "NOMONIT No monitorización." ;
    ex:identificador "NOMONIT" .

ex:Directiva_EXTERN
    a ex:Directiva ;
    rdfs:label "EXTERN" ;
    ex:textoExtracto "EXTERN Definición de subrutina externa." ;
    ex:identificador "EXTERN" .

ex:Manual_EstructuraModularPLC
    a ex:Manual ;
    rdfs:label "Estructura modular del programa de PLC" ;
    ex:textoExtracto "Ver en la página '3.2 Estructura modular del programa de PLC.' 337." ;
    ex:identificador "3.2" .

ex:Directiva_PRG
    ex:documentadoEn ex:Manual_EstructuraModularPLC .

ex:Directiva_PE_t
    ex:documentadoEn ex:Manual_EstructuraModularPLC .

ex:Directiva_CY1
    ex:documentadoEn ex:Manual_EstructuraModularPLC .

ex:Directiva_END
    ex:documentadoEn ex:Manual_EstructuraModularPLC .