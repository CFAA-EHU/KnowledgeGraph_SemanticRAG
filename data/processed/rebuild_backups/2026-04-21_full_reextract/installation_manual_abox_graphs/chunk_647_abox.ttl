@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_CY1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo CY1" ;
    ex:textoExtracto "CY1 [...] END" ;
    ex:identificador "CY1" .

ex:Modulo_PRG
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo PRG" ;
    ex:textoExtracto "PRG [...] END" ;
    ex:identificador "PRG" .

ex:Modulo_PE100
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo PE 100" ;
    ex:textoExtracto "PE 100 [...] END" ;
    ex:identificador "PE 100" .

ex:Subrutina_A22
    a ex:ComponenteElectrico ;
    rdfs:label "Subrutina A22" ;
    ex:textoExtracto "SUB A22 [...] END" ;
    ex:identificador "A22" .

ex:Subrutina_EXTERN_TEMPERATURE
    a ex:ComponenteElectrico ;
    rdfs:label "Subrutina externa TEMPERATURE" ;
    ex:textoExtracto "; Subrutina externa\nEXTERN TEMPERATURE" ;
    ex:identificador "EXTERN_TEMPERATURE" .

ex:Simbolo_COOL_I12
    a ex:Parametro ;
    rdfs:label "Símbolo COOL I12" ;
    ex:textoExtracto "DEF COOL I12" ;
    ex:identificador "I12" ;
    ex:valor "COOL" .

ex:Simbolo_FAN_I23
    a ex:Parametro ;
    rdfs:label "Símbolo /FAN I23" ;
    ex:textoExtracto "DEF /FAN I23" ;
    ex:identificador "I23" ;
    ex:valor "/FAN" .

ex:Parametro_NOMONIT
    a ex:Parametro ;
    rdfs:label "Parámetro NOMONIT" ;
    ex:textoExtracto "| ; Sin monitorización\nNOMONIT" ;
    ex:identificador "NOMONIT" .