@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_649
    a                       ex:InterfazUsuario ;
    rdfs:label              "Interfaz de consulta de recursos del sistema"@es ;
    ex:textoExtracto        "Testean el estado de los recursos y devuelven su estado lógico. • Entradas (I1-I1024) • Salidas (O1-O1024) • Entradas locales (LI1-LI16) • Salidas locales (LO1-LO8) • Marcas (M1-M8192) • Mensajes (MSG1-MSG1024) • Errores (ERR1-ERR1024) • Relojes (CLK) • Registros (R1-R1024) • Bit de registros (B0-B31 R1-R1024) • Estado de los temporizadores (T1-T512) • Estado de los contadores (C1-C256) • Marcas de comunicación CNC-PLC."@es ;
    ex:tieneComponente      ex:Entrada_I12 ;
    ex:tieneComponente      ex:Tecla_START .

ex:Entrada_I12
    a                       ex:ComponenteElectrico ;
    ex:identificador         "I12" ;
    rdfs:label              "Entrada I12"@es ;
    ex:textoExtracto         "Devuelve un 1 si la entrada I12 se encuentra activa y un 0 en caso contrario."@es ;
    ex:monitoreaParametro    ex:Parametro_EstadoI12 .

ex:Parametro_EstadoI12
    a                       ex:Parametro ;
    rdfs:label              "Estado lógico de la entrada I12"@es ;
    ex:valor                 "0" , "1" ;
    ex:textoExtracto         "Devuelve un 1 si la entrada I12 se encuentra activa y un 0 en caso contrario."@es .

ex:Tecla_START
    a                       ex:ComponenteElectrico ;
    ex:identificador         "START" ;
    rdfs:label              "Tecla START del panel frontal"@es ;
    ex:textoExtracto         "Devuelve un 1 cuando la tecla start del panel frontal está pulsada y un 0 en caso contrario."@es ;
    ex:monitoreaParametro    ex:Parametro_EstadoSTART .

ex:Parametro_EstadoSTART
    a                       ex:Parametro ;
    rdfs:label              "Estado lógico de la tecla START"@es ;
    ex:valor                 "0" , "1" ;
    ex:textoExtracto         "Devuelve un 1 cuando la tecla start del panel frontal está pulsada y un 0 en caso contrario."@es .