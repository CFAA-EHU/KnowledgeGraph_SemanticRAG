@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_DFU
    a ex:InterfazUsuario ;
    rdfs:label "DFU (Detectar flanco de subida)" ;
    ex:textoExtracto "DFU Detectar flanco de subida. Detecta si se ha producido un flanco de subida, cambio de estado de 0 a 1, en el recurso especificado. Devuelve un \"1\" si se ha producido." ;
    ex:identificador "DFU" .

ex:Instruccion_DFD
    a ex:InterfazUsuario ;
    rdfs:label "DFD (Detectar flanco de bajada)" ;
    ex:textoExtracto "DFD Detectar flanco de bajada. Detecta si se ha producido un flanco de bajada, cambio de estado de 1 a 0, en el recurso especificado. Devuelve un \"1\" si se ha producido." ;
    ex:identificador "DFD" .

ex:Sistema_Comunicacion_CNC_PLC
    a ex:Sistema ;
    rdfs:label "Marcas de comunicación CNC-PLC" ;
    ex:textoExtracto "Marcas de comunicación CNC-PLC" ;
    ex:tieneComponente ex:Instruccion_DFU, ex:Instruccion_DFD .

ex:Parametro_I23
    a ex:Parametro ;
    rdfs:label "I23" ;
    ex:identificador "I23" ;
    ex:textoExtracto "DFU I23" .

ex:Parametro_B3R120
    a ex:Parametro ;
    rdfs:label "B3R120" ;
    ex:identificador "B3R120" ;
    ex:textoExtracto "DFU B3R120" .

ex:Parametro_AUXEND
    a ex:Parametro ;
    rdfs:label "AUXEND" ;
    ex:identificador "AUXEND" ;
    ex:textoExtracto "DFU AUXEND" .

ex:Parametro_O32
    a ex:Parametro ;
    rdfs:label "O32" ;
    ex:identificador "O32" ;
    ex:textoExtracto "DFD O32" .

ex:Parametro_M45
    a ex:Parametro ;
    rdfs:label "M45" ;
    ex:identificador "M45" ;
    ex:textoExtracto "DFD M45" .

ex:Parametro_CLK
    a ex:Parametro ;
    rdfs:label "CLK" ;
    ex:identificador "CLK" ;
    ex:textoExtracto "CLK" .