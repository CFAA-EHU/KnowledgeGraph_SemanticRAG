@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InstruccionesAccion_PLC_4_4
    a ex:Sistema ;
    rdfs:label "Instrucciones de acción del PLC (Sección 4.4)"@es ;
    ex:textoExtracto "Las instrucciones de acción, en función del resultado obtenido en la expresión lógica permiten alterar el estado de los recursos del PLC y de las marcas de comunicación CNC-PLC. [...] Las instrucciones de acción pueden alterar el estado de todos los recursos del PLC excepto de las entradas físicas utilizadas."@es ;
    ex:tieneComponente ex:Entrada_I2, ex:Salida_O3, ex:Marca_M100, ex:Temporizador_TG1, ex:Contador_CPR1 .

ex:Entrada_I2
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada I2"@es ;
    ex:textoExtracto "La salida O3 mostrará el estado de la entrada I2. [...] Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2."@es ;
    ex:identificador "I2" .

ex:Salida_O3
    a ex:ComponenteElectrico ;
    rdfs:label "Salida O3"@es ;
    ex:textoExtracto "La salida O3 mostrará el estado de la entrada I2."@es ;
    ex:identificador "O3" .

ex:Marca_M100
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M100"@es ;
    ex:textoExtracto "La marca M100 mostrará el estado negado de la entrada I2."@es ;
    ex:identificador "M100" .

ex:Temporizador_TG1
    a ex:ComponenteElectrico ;
    rdfs:label "Temporizador TG1 (entrada de arranque T2)"@es ;
    ex:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2."@es ;
    ex:identificador "TG1" .

ex:Contador_CPR1
    a ex:ComponenteElectrico ;
    rdfs:label "Contador C1 (preselección valor 100)"@es ;
    ex:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100."@es ;
    ex:identificador "CPR 1" ;
    ex:valor "100" .