@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InstruccionBinaria_Asignacion_TG1_T4
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Asignación de entrada TG1 a temporizador T4"@es ;
    ex:textoExtracto       "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4."@es ;
    ex:identificador      "TG1 4 100" .

ex:InstruccionBinaria_ExpresionLogica_M111
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Asignación de expresión lógica a marca M111"@es ;
    ex:textoExtracto       "Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))."@es ;
    ex:identificador      "M111" .

ex:Marca_CNC_PLC_I3
    a                     ex:Parametro ;
    rdfs:label            "Marca CNC-PLC I3"@es ;
    ex:textoExtracto       "Marca CNC-PLC I3"@es ;
    ex:identificador      "I3" .

ex:Temporizador_T4
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Temporizador T4"@es ;
    ex:textoExtracto       "entrada de arranque TG1 del temporizador T4"@es ;
    ex:identificador      "T4" .

ex:Entrada_TG1
    a                     ex:Parametro ;
    rdfs:label            "Entrada de arranque TG1"@es ;
    ex:textoExtracto       "entrada de arranque TG1 del temporizador T4"@es ;
    ex:identificador      "TG1" .

ex:Marca_M111
    a                     ex:Parametro ;
    rdfs:label            "Marca M111"@es ;
    ex:textoExtracto       "marca M111"@es ;
    ex:identificador      "M111" .