@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_RupturaSecuencia_443
    a               ex:Sistema ;
    rdfs:label      "Subrutina de ruptura de secuencia (4.4.3)"@es ;
    ex:textoExtracto
        "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0). [...] Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina."@es ;
    ex:identificador "4.4.3" .

ex:Instruccion_RET
    a               ex:AccionProhibida ;
    rdfs:label      "Instrucción RET (retorno de subrutina)"@es ;
    ex:textoExtracto
        "RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es '0', será ignorada por el PLC."@es ;
    ex:solucionaFallo ex:Subrutina_RupturaSecuencia_443 .