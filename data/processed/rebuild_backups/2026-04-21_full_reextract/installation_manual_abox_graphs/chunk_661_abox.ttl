@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InstruccionADS a ex:Parametro ;
    rdfs:label "Instrucción ADS (suma)"@es ;
    ex:textoExtracto "=ADS R100 R101 R102 ; R102 = 1234 + 100 = 1334"@es ;
    ex:identificador "ADS" .

ex:InstruccionSBS a ex:Parametro ;
    rdfs:label "Instrucción SBS (resta)"@es ;
    ex:textoExtracto "=SBS R100 R101 R103 ; R103 = 1234 - 100 = 1134"@es ;
    ex:identificador "SBS" .

ex:InstruccionMLS a ex:Parametro ;
    rdfs:label "Instrucción MLS (multiplicación)"@es ;
    ex:textoExtracto "=MLS R100 R101 R104 ; R104 = 1234 x 100 = 123400"@es ;
    ex:identificador "MLS" .

ex:InstruccionDVS a ex:Parametro ;
    rdfs:label "Instrucción DVS (división)"@es ;
    ex:textoExtracto "=DVS R100 R101 R105 ; R105 = 1234 : 100 = 12"@es ;
    ex:identificador "DVS" .

ex:InstruccionMDS a ex:Parametro ;
    rdfs:label "Instrucción MDS (módulo)"@es ;
    ex:textoExtracto "=MDS R100 R101 R106 ; R106 = 1234 MOD 100 = 34"@es ;
    ex:identificador "MDS" .

ex:ParametroSANALOG a ex:Parametro ;
    rdfs:label "Parámetro SANALOG"@es ;
    ex:textoExtracto "MLS SANALOG 10000 R115 = DVS R115 32767 R115 ; Consigna cabezal en mV"@es ;
    ex:identificador "SANALOG" ;
    ex:valor "10000" .

ex:SeccionInstruccionesAritmeticas a ex:Pagina ;
    rdfs:label "Sección 4.4.4: Instrucciones de acción aritméticas"@es ;
    ex:textoExtracto "Ejemplos con R100=1234 y R101=100."@es ;
    ex:identificador "4.4.4" .

ex:InstruccionADS ex:documentadoEn ex:SeccionInstruccionesAritmeticas .
ex:InstruccionSBS ex:documentadoEn ex:SeccionInstruccionesAritmeticas .
ex:InstruccionMLS ex:documentadoEn ex:SeccionInstruccionesAritmeticas .
ex:InstruccionDVS ex:documentadoEn ex:SeccionInstruccionesAritmeticas .
ex:InstruccionMDS ex:documentadoEn ex:SeccionInstruccionesAritmeticas .
ex:ParametroSANALOG ex:documentadoEn ex:SeccionInstruccionesAritmeticas .