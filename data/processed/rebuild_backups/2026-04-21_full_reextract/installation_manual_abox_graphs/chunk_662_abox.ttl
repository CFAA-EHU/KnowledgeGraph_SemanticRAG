@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionLogica_AND
    a ex:AccionProhibida ;
    rdfs:label "Operación lógica AND" ;
    ex:textoExtracto "AND R1/1024 R1/1024 R1/1024 [...] Ejemplos con R200 = B1001 0010 y R201 = B0100 0101. () = AND R200 R201 R202 ; R202 = B0" ;
    ex:identificador "AND" .

ex:OperacionLogica_OR
    a ex:AccionProhibida ;
    rdfs:label "Operación lógica OR" ;
    ex:textoExtracto "OR R CNC-PLC R CNC-PLC R CNC-PLC [...] () = OR R200 R201 R203 ; R203 = B11010111" ;
    ex:identificador "OR" .

ex:OperacionLogica_XOR
    a ex:AccionProhibida ;
    rdfs:label "Operación lógica XOR" ;
    ex:textoExtracto "XOR R CNC-PLC R CNC-PLC R CNC-PLC [...] () = XOR R200 R201 R204 ; R204 = B11010111" ;
    ex:identificador "XOR" .

ex:RotacionRegistro_RR1
    a ex:AccionProhibida ;
    rdfs:label "Rotación de registro a derechas tipo 1 (RR1)" ;
    ex:textoExtracto "Rotación de registros. [...] Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. [...] RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." ;
    ex:identificador "RR1" .

ex:RotacionRegistro_RR2
    a ex:AccionProhibida ;
    rdfs:label "Rotación de registro a derechas tipo 2 (RR2)" ;
    ex:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." ;
    ex:identificador "RR2" .

ex:RotacionRegistro_RL1
    a ex:AccionProhibida ;
    rdfs:label "Rotación de registro a izquierdas tipo 1 (RL1)" ;
    ex:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro." ;
    ex:identificador "RL1" .

ex:RotacionRegistro_RL2
    a ex:AccionProhibida ;
    rdfs:label "Rotación de registro a izquierdas tipo 2 (RL2)" ;
    ex:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." ;
    ex:identificador "RL2" .

ex:Registro_R200
    a ex:Parametro ;
    rdfs:label "Registro R200" ;
    ex:textoExtracto "Ejemplos con R200 = B1001 0010" ;
    ex:identificador "R200" ;
    ex:valor "B10010010" .

ex:Registro_R201
    a ex:Parametro ;
    rdfs:label "Registro R201" ;
    ex:textoExtracto "R201 = B0100 0101" ;
    ex:identificador "R201" ;
    ex:valor "B01000101" .

ex:Registro_R202
    a ex:Parametro ;
    rdfs:label "Registro R202" ;
    ex:textoExtracto "() = AND R200 R201 R202 ; R202 = B0" ;
    ex:identificador "R202" ;
    ex:valor "B00000000" .

ex:Registro_R203
    a ex:Parametro ;
    rdfs:label "Registro R203" ;
    ex:textoExtracto "() = OR R200 R201 R203 ; R203 = B11010111" ;
    ex:identificador "R203" ;
    ex:valor "B11010111" .

ex:Registro_R204
    a ex:Parametro ;
    rdfs:label "Registro R204" ;
    ex:textoExtracto "() = XOR R200 R201 R204 ; R204 = B11010111" ;
    ex:identificador "R204" ;
    ex:valor "B11010111" .

ex:Registro_R205
    a ex:Parametro ;
    rdfs:label "Registro R205" ;
    ex:textoExtracto "() = AND B1111 R201 R205 ; R205 = B00000101" ;
    ex:identificador "R205" ;
    ex:valor "B00000101" .

ex:Registro_R206
    a ex:Parametro ;
    rdfs:label "Registro R206" ;
    ex:textoExtracto "() = OR R200 B1111 R206 ; R206 = B10011111" ;
    ex:identificador "R206" ;
    ex:valor "B10011111" .

ex:Registro_R207
    a ex:Parametro ;
    rdfs:label "Registro R207" ;
    ex:textoExtracto "() = XOR B1010 B1110 R207 ; R207 = B00000100" ;
    ex:identificador "R207" ;
    ex:valor "B00000100" .

ex:Registro_R100
    a ex:Parametro ;
    rdfs:label "Registro R100" ;
    ex:textoExtracto "RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." ;
    ex:identificador "R100" .