@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Accion_CNCRD
    a               ex:AccionProhibida ;
    rdfs:label      "CNCRD (Lectura de variables CNC)" ;
    ex:textoExtracto "CNCRD [...] Permiten la lectura (CNCRD) de las variables internas del CNC, siendo su formato de programación: CNCRD (Variable, Registro, Marca)" ;
    ex:identificador "CNCRD" .

ex:Accion_CNCWR
    a               ex:AccionProhibida ;
    rdfs:label      "CNCWR (Escritura de variables CNC)" ;
    ex:textoExtracto "CNCWR [...] Permiten la escritura (CNCWR) de las variables internas del CNC, siendo su formato de programación: CNCWR (Registro, Variable, Marca)" ;
    ex:identificador "CNCWR" .

ex:Interfaz_CNC_Variables
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de variables del CNC" ;
    ex:textoExtracto "Lectura (CNCRD) y escritura (CNCWR) de las variables del CNC" ;
    ex:tieneComponente ex:Accion_CNCRD , ex:Accion_CNCWR .