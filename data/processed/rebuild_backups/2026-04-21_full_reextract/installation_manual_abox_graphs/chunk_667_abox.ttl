@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConsultaAsincrona_M11
    a ex:Parametro ;
    rdfs:label "Consulta asíncrona M11 (CNCRD TM.TOOL)"@es ;
    ex:textoExtracto "<condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11) no repetir la consulta mientras no finalice la misma."@es ;
    ex:identificador "M11" .

ex:ConsultaSincrona_M12
    a ex:Parametro ;
    rdfs:label "Consulta síncrona M12 (CNCRD G.FREAL)"@es ;
    ex:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12)"@es ;
    ex:identificador "M12" .

ex:Parametro_R11
    a ex:Parametro ;
    rdfs:label "Parámetro R11 (CPS)"@es ;
    ex:textoExtracto "DFD M11 AND CPS R11 EQ 3 = ..."@es ;
    ex:identificador "R11" .

ex:Parametro_R12
    a ex:Parametro ;
    rdfs:label "Parámetro R12 (CPS)"@es ;
    ex:textoExtracto "CPS R12 GT 2000 = ..."@es ;
    ex:identificador "R12" ;
    ex:valor "2000" .

ex:SistemaControl_667
    a ex:Sistema ;
    rdfs:label "Sistema de control de consultas CNCRD/CPS"@es ;
    ex:textoExtracto "Ejemplo de acceso a variables asíncronas [...] Ejemplos de acceso a variables síncronas [...]"@es ;
    ex:tieneComponente ex:ConsultaAsincrona_M11, ex:ConsultaSincrona_M12, ex:Parametro_R11, ex:Parametro_R12 ;
    ex:monitoreaParametro ex:Parametro_R11, ex:Parametro_R12 .