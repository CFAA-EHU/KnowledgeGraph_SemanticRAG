@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_CAM_OFF a ex:ModoOperacion ;
    rdfs:label "CAM OFF" ;
    ex:textoExtracto "comando CAM OFF. Alcanzado dicho comando, la ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva." .

ex:Comando_CAM_SELECT a ex:ModoOperacion ;
    rdfs:label "CAM SELECT" ;
    ex:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo" ;
    ex:identificador "CAM SELECT" .

ex:Comando_CAM_DESELECT a ex:ModoOperacion ;
    rdfs:label "CAM DESELECT" ;
    ex:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)" ;
    ex:identificador "CAM DESELECT" .

ex:LevaElectronica a ex:Componente ;
    rdfs:label "Leva electrónica" ;
    ex:textoExtracto "ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva" ;
    ex:tieneComponente ex:PerfilLeva .

ex:PerfilLeva a ex:Parametro ;
    rdfs:label "Perfil de leva" ;
    ex:textoExtracto "final del perfil de leva" .

ex:ArchivoLeva a ex:InterfazUsuario ;
    rdfs:label "Archivo de leva" ;
    ex:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC" .