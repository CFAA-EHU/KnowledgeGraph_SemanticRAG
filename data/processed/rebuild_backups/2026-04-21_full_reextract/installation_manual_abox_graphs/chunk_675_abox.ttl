@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:LevaElectronica_Archivo
    a               ex:Componente ;
    rdfs:label      "Leva electrónica de archivo"@es ;
    ex:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC. Al ejecutar una leva desde un archivo, el CNC lee sus datos de manera dinámica"@es .

ex:Comando_CAM_SELECT
    a               ex:InterfazUsuario ;
    rdfs:label      "CAM SELECT"@es ;
    ex:identificador "CAM SELECT (cam, file)"@es ;
    ex:textoExtracto "El formato de programación para cada uno de ellos es el siguiente. CAM SELECT (cam, file)"@es ;
    ex:controla     ex:LevaElectronica_Archivo .

ex:Comando_CAM_DESELECT
    a               ex:InterfazUsuario ;
    rdfs:label      "CAM DESELECT"@es ;
    ex:identificador "CAM DESELECT (cam)"@es ;
    ex:textoExtracto "CAM DESELECT (cam)"@es ;
    ex:controla     ex:LevaElectronica_Archivo .

ex:Comando_CAM_ON
    a               ex:InterfazUsuario ;
    rdfs:label      "CAM ON"@es ;
    ex:identificador "#CAM ON (CNC) / CAM ON (PLC)"@es ;
    ex:textoExtracto "para activarla, utilizar la sentencia #CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)"@es ;
    ex:habilitadoPor ex:LevaElectronica_Archivo .

ex:Comando_CAM_OFF
    a               ex:InterfazUsuario ;
    rdfs:label      "CAM OFF"@es ;
    ex:identificador "CAM OFF"@es ;
    ex:textoExtracto "La ejecución del comando CAM OFF implica eliminar la sincronización de la leva"@es ;
    ex:controla     ex:LevaElectronica_Archivo .

ex:SistemaCNC
    a               ex:Sistema ;
    rdfs:label      "CNC"@es ;
    ex:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC"@es ;
    ex:tieneComponente ex:LevaElectronica_Archivo ;
    ex:controla     ex:Comando_CAM_SELECT, ex:Comando_CAM_ON .

ex:SistemaPLC
    a               ex:Sistema ;
    rdfs:label      "PLC"@es ;
    ex:textoExtracto "el cual se puede cargar desde el [...] PLC. Al ejecutar una leva desde un archivo, el CNC lee sus datos de manera dinámica"@es ;
    ex:controla     ex:Comando_CAM_ON .