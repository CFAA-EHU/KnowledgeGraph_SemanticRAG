@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosLevaElectronica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de la leva electrónica"@es ;
    ex:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| cam | Número de leva. |
| file | Nombre y dirección (path) del archivo con los datos de la leva.
"""@es ;
    ex:tieneComponente ex:Parametro_cam ;
    ex:tieneComponente ex:Parametro_file .

ex:Parametro_cam
    a ex:Parametro ;
    rdfs:label "cam"@es ;
    ex:textoExtracto "cam | Número de leva."@es ;
    ex:identificador "cam" ;
    ex:valor "Número de leva"@es .

ex:Parametro_file
    a ex:Parametro ;
    rdfs:label "file"@es ;
    ex:textoExtracto "file | Nombre y dirección (path) del archivo con los datos de la leva."@es ;
    ex:identificador "file" ;
    ex:valor "Nombre y dirección (path) del archivo con los datos de la leva"@es .