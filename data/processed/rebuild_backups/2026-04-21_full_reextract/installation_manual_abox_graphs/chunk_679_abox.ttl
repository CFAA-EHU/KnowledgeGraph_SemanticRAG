@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_NEXT
    a ex:ModoOperacion ;
    rdfs:label "NEXT" ;
    ex:textoExtracto "NEXT El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ex:ModoOperacion_NULL
    a ex:ModoOperacion ;
    rdfs:label "NULL" ;
    ex:textoExtracto "NULL El eje alcanza la posición indicada a avance nulo." .

ex:ModoOperacion_WAITINPOS
    a ex:ModoOperacion ;
    rdfs:label "WAITINPOS" ;
    ex:textoExtracto "WAITINPOS El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." .

ex:Parametro_F500
    a ex:Parametro ;
    rdfs:label "F 500" ;
    ex:valor "500" ;
    ex:textoExtracto "F 500 250" .

ex:Parametro_F250
    a ex:Parametro ;
    rdfs:label "F 250" ;
    ex:valor "250" ;
    ex:textoExtracto "F 500 250" .

ex:Comando_MOVE_ABS_1
    a ex:AccionProhibida ;  # Asumiendo que comandos de movimiento no autorizados en modo manual son prohibidos
    rdfs:label "MOVE ABS (X, 500000, 5000000, PRESENT)" ;
    ex:textoExtracto ".. = MOVE ABS (X, 500000, 5000000, PRESENT)" .

ex:Comando_MOVE_ABS_2
    a ex:AccionProhibida ;
    rdfs:label "MOVE ABS (X, 1000000, 2500000, NEXT)" ;
    ex:textoExtracto ".. = MOVE ABS (X, 1000000, 2500000, NEXT)" ;
    ex:habilitadoPor ex:ModoOperacion_NEXT .

ex:Comando_MOVE_ABS_3
    a ex:AccionProhibida ;
    rdfs:label "MOVE ABS (X, 1500000, 1250000, NULL)" ;
    ex:textoExtracto ".. = MOVE ABS (X, 1500000, 1250000, NULL)" ;
    ex:habilitadoPor ex:ModoOperacion_NULL .