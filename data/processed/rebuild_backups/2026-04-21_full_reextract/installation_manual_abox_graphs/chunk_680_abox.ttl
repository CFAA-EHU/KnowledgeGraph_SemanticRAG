@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Posicionamiento_4_4_8 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores de posicionamiento (4.4.8)"@es ;
    ex:textoExtracto "125 Pos 50mm 100mm 150mm"@es ;
    ex:identificador "4.4.8" .

ex:Parametro_Posicion_125
    a ex:Parametro ;
    rdfs:label "Posición 125"@es ;
    ex:valor "125" ;
    ex:textoExtracto "125"@es ;
    ex:documentadoEn ex:Tabla_Posicionamiento_4_4_8 .

ex:Parametro_Posicion_50mm
    a ex:Parametro ;
    rdfs:label "Posición 50 mm"@es ;
    ex:valor "50mm" ;
    ex:textoExtracto "50mm"@es ;
    ex:documentadoEn ex:Tabla_Posicionamiento_4_4_8 .

ex:Parametro_Posicion_100mm
    a ex:Parametro ;
    rdfs:label "Posición 100 mm"@es ;
    ex:valor "100mm" ;
    ex:textoExtracto "100mm"@es ;
    ex:documentadoEn ex:Tabla_Posicionamiento_4_4_8 .

ex:Parametro_Posicion_150mm
    a ex:Parametro ;
    rdfs:label "Posición 150 mm"@es ;
    ex:valor "150mm" ;
    ex:textoExtracto "150mm"@es ;
    ex:documentadoEn ex:Tabla_Posicionamiento_4_4_8 .