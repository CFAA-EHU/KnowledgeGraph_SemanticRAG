@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_FOLLOW_ON
    a ex:ModoOperacion ;
    rdfs:label "FOLLOW ON" ;
    ex:textoExtracto "Activar el movimiento de sincronización con las cotas reales (FOLLOW ON)" ;
    ex:identificador "FOLLOW ON" .

ex:ModoOperacion_TFOLLOW_ON
    a ex:ModoOperacion ;
    rdfs:label "TFOLLOW ON" ;
    ex:textoExtracto "con las cotas teóricas (TFOLLOW ON)" ;
    ex:identificador "TFOLLOW ON" .

ex:ModoOperacion_FOLLOW_OFF
    a ex:ModoOperacion ;
    rdfs:label "FOLLOW OFF" ;
    ex:textoExtracto "cancelar el movimiento de sincronización (FOLLOW OFF)" ;
    ex:identificador "FOLLOW OFF" .

ex:Parametro_master
    a ex:Parametro ;
    rdfs:label "master" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ex:Parametro_slave
    a ex:Parametro ;
    rdfs:label "slave" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ex:Parametro_Nnratio
    a ex:Parametro ;
    rdfs:label "Nnratio" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ex:Parametro_Ddratio
    a ex:Parametro ;
    rdfs:label "Ddratio" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ex:Parametro_synctype
    a ex:Parametro ;
    rdfs:label "synctype" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ex:Manual_Especifico_MovimientoIndependiente
    a ex:Manual ;
    rdfs:label "Manual específico de movimiento independiente" ;
    ex:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad. Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes." .