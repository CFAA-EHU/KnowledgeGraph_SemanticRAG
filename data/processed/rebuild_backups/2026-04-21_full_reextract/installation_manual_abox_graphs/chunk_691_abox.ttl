@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_TOUCHPROBE
    a ex:TareaMantenimiento ;
    rdfs:label "Instrucción TOUCHPROBE" ;
    ex:textoExtracto "La instrucción TOUCHPROBE podrá activarse de forma simultánea para cualquiera de los 2 palpadores y para cualquiera de los ejes del sistema." ;
    ex:requiereMantenimiento ex:SistemaLatcheoCotas .

ex:SistemaLatcheoCotas
    a ex:Sistema ;
    rdfs:label "Sistema de latcheo de cotas" ;
    ex:textoExtracto "Todos los procesos de latcheo activos que estén asignados a un mismo palpador, se desactivan al producirse un evento de latch sobre cualquiera de ellos." ;
    ex:tieneComponente ex:Palpador_1, ex:Palpador_2, ex:Eje_X, ex:Eje_Y ;
    ex:compuestoPor ex:InterpoladorIndependiente .

ex:Palpador_1
    a ex:Sensor ;
    rdfs:label "Palpador 1" ;
    ex:identificador "PRBDI1" ;
    ex:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1." ;
    ex:monitoreaParametro ex:Parametro_PROBE1ACTIVE .

ex:Palpador_2
    a ex:Sensor ;
    rdfs:label "Palpador 2" ;
    ex:identificador "PRBDI2" ;
    ex:textoExtracto "El palpador 2 será el asignado al parámetro PRBDI2." ;
    ex:monitoreaParametro ex:Parametro_PROBE2ACTIVE .

ex:Eje_X
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "·· = TOUCHPROBE (X,1) ·· = TOUCHPROBE (X,2)" .

ex:Eje_Y
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Y" ;
    ex:textoExtracto "·· = TOUCHPROBE (Y,1) ·· = TOUCHPROBE (Y,2)" .

ex:InterpoladorIndependiente
    a ex:ComponenteElectrico ;
    rdfs:label "Interpolador independiente" ;
    ex:textoExtracto "El interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento." ;
    ex:controla ex:Palpador_1, ex:Palpador_2, ex:Eje_X, ex:Eje_Y ;
    ex:activaAlarma ex:Senal_LATCH1DONE, ex:Senal_LATCH2DONE, ex:Senal_LATCH1ACTIVE, ex:Senal_LATCH2ACTIVE .

ex:Senal_LATCH1DONE
    a ex:AvisoSeguridad ;
    rdfs:label "LATCH1DONE(axis)" ;
    ex:textoExtracto "El interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento." .

ex:Senal_LATCH2DONE
    a ex:AvisoSeguridad ;
    rdfs:label "LATCH2DONE(axis)" ;
    ex:textoExtracto "El interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento." .

ex:Senal_LATCH1ACTIVE
    a ex:AvisoSeguridad ;
    rdfs:label "LATCH1ACTIVE(axis)" ;
    ex:textoExtracto "El interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso." .

ex:Senal_LATCH2ACTIVE
    a ex:AvisoSeguridad ;
    rdfs:label "LATCH2ACTIVE(axis)" ;
    ex:textoExtracto "El interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso." .

ex:Parametro_PROBE1ACTIVE
    a ex:Parametro ;
    rdfs:label "PROBE1ACTIVE" ;
    ex:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." ;
    ex:valor "activo/inactivo" .

ex:Parametro_PROBE2ACTIVE
    a ex:Parametro ;
    rdfs:label "PROBE2ACTIVE" ;
    ex:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." ;
    ex:valor "activo/inactivo" .

ex:Senal_IRESET
    a ex:AccionProhibida ;
    rdfs:label "IRESET(axis)" ;
    ex:textoExtracto "Si el PLC activa la marca IRESET(axis), cancela el proceso de latcheo en el eje y el interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso." .