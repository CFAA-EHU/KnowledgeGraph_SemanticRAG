@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marcador_PROBE1ACTIVE
    a ex:ComponenteElectrico ;
    rdfs:label "PROBE1ACTIVE" ;
    ex:textoExtracto "PROBE1ACTIVE [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ex:Marcador_PROBE2ACTIVE
    a ex:ComponenteElectrico ;
    rdfs:label "PROBE2ACTIVE" ;
    ex:textoExtracto "PROBE2ACTIVE [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ex:Marcador_LATCH1ACTIVE
    a ex:ComponenteElectrico ;
    rdfs:label "LATCH1ACTIVE(axis)" ;
    ex:textoExtracto "LATCH1ACTIVE(axis) [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ex:Marcador_LATCH2ACTIVE
    a ex:ComponenteElectrico ;
    rdfs:label "LATCH2ACTIVE(axis)" ;
    ex:textoExtracto "LATCH2ACTIVE(axis) [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ex:Marcador_IRESET
    a ex:ComponenteElectrico ;
    rdfs:label "IRESET(axis)" ;
    ex:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." .

ex:InterfazUsuario_LatcheoCotas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de latcheo de cotas con palpador/entrada digital" ;
    ex:textoExtracto "Instrucciones de latcheo de cotas con un palpador o entrada digital." ;
    ex:tieneComponente ex:Marcador_PROBE1ACTIVE ;
    ex:tieneComponente ex:Marcador_PROBE2ACTIVE ;
    ex:tieneComponente ex:Marcador_LATCH1ACTIVE ;
    ex:tieneComponente ex:Marcador_LATCH2ACTIVE ;
    ex:tieneComponente ex:Marcador_IRESET .