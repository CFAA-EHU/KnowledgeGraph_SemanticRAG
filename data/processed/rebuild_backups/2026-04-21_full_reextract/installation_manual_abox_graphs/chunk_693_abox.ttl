@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcesoLatcheoCotas_693
    a ex:TareaMantenimiento ;
    rdfs:label "Proceso de latcheo de cotas con palpador o entrada digital" ;
    ex:textoExtracto "palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso. Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje. Un reset del canal cancela los procesos de latcheo en todos los ejes del canal. Las funciones M02 y M30 no se darán por ejecutadas hasta que finalicen todos los procesos de latcheo activos en los ejes del canal." ;
    ex:requiereMantenimiento ex:SistemaControlEjes_693 .

ex:SistemaControlEjes_693
    a ex:Sistema ;
    rdfs:label "Sistema de control de ejes para latcheo" ;
    ex:textoExtracto "LATCH1DONE(axis) LATCH2DONE(axis) El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." ;
    ex:tieneComponente ex:PalpadorLatcheo_693 ;
    ex:tieneComponente ex:PLC_693 ;
    ex:tieneComponente ex:InterpoladorEjes_693 ;
    ex:tieneComponente ex:VariableLATCH1_693 ;
    ex:tieneComponente ex:VariableLATCH2_693 .

ex:PalpadorLatcheo_693
    a ex:Sensor ;
    rdfs:label "Palpador para latcheo de cotas" ;
    ex:textoExtracto "palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." ;
    ex:monitoreaParametro ex:VariableLATCH1_693 ;
    ex:monitoreaParametro ex:VariableLATCH2_693 .

ex:PLC_693
    a ex:Actuador ;
    rdfs:label "PLC (Controlador Lógico Programable) para gestión de latcheo" ;
    ex:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." ;
    ex:controla ex:ProcesoLatcheoCotas_693 .

ex:InterpoladorEjes_693
    a ex:ComponenteElectrico ;
    rdfs:label "Interpolador independiente de ejes" ;
    ex:textoExtracto "El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." ;
    ex:controla ex:VariableLATCH1_693 ;
    ex:controla ex:VariableLATCH2_693 .

ex:VariableLATCH1_693
    a ex:Parametro ;
    rdfs:label "Variable LATCH1DONE(axis) - Cota máquina del palpador 1" ;
    ex:identificador "LATCH1DONE(axis)" ;
    ex:textoExtracto "LATCH1DONE(axis) [...] Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Cota máquina obtenida del latcheo del palpador 1 en el eje ꞏxnꞏ." ;
    ex:valor "Cota máquina obtenida del latcheo del palpador 1 en el eje ꞏxnꞏ" .

ex:VariableLATCH2_693
    a ex:Parametro ;
    rdfs:label "Variable LATCH2DONE(axis) - Cota máquina del palpador 2" ;
    ex:identificador "LATCH2DONE(axis)" ;
    ex:textoExtracto "LATCH2DONE(axis) [...] Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales." ;
    ex:valor "Cota máquina obtenida del latcheo del palpador 2 en el eje ꞏxnꞏ" .

ex:VariableLATCH1_xn_693
    a ex:Parametro ;
    rdfs:label "Variable [V.][ch].A.LATCH1.xn - Valor de ejecución del latcheo" ;
    ex:identificador "[V.][ch].A.LATCH1.xn" ;
    ex:textoExtracto "[ V.][ch].A.LATCH1.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." ;
    ex:monitoreaParametro ex:PalpadorLatcheo_693 .