@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaZonasTrabajo
    a ex:Sistema ;
    rdfs:label "Sistema de gestión de zonas de trabajo (PLC/CNCWR)"@es ;
    ex:textoExtracto "Las zonas de trabajo se pueden definir, habilitar y deshabilitar desde el PLC mediante el comando CNCWR, escribiendo las variables correspondientes."@es ;
    ex:tieneComponente ex:Param_ZONELIMITTOL, ex:Param_ZONEST, ex:Param_ZONELOWLIM, ex:Param_ZONEUPLIM,
                      ex:Param_ZONECIRAX1, ex:Param_ZONECIRAX2, ex:Param_ZONECIR1, ex:Param_ZONECIR2,
                      ex:Param_ZONER, ex:Param_ZONETOOLWATCH .

ex:Param_ZONELIMITTOL
    a ex:Parametro ;
    rdfs:label "[ch].A.ZONELIMITTOL.xn" ;
    ex:identificador "[ch].A.ZONELIMITTOL.xn" ;
    ex:textoExtracto "Distancia de seguridad de los límites de las zonas de trabajo."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONEST
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONEST[k]" ;
    ex:identificador "[ch].G.ZONEST[k]" ;
    ex:textoExtracto "Estado de la zona de trabajo [k]. (0=Zona deshabilitada). (1=Zona habilitada como zona de no entrada). (2=Zona habilitada como zona de no salida)."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONELOWLIM
    a ex:Parametro ;
    rdfs:label "[ch].A.ZONELOWLIM[k].xn" ;
    ex:identificador "[ch].A.ZONELOWLIM[k].xn" ;
    ex:textoExtracto "Límite inferior de la zona [k]."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONEUPLIM
    a ex:Parametro ;
    rdfs:label "[ch].A.ZONEUPLIM[k].xn" ;
    ex:identificador "[ch].A.ZONEUPLIM[k].xn" ;
    ex:textoExtracto "Límite superior de la zona [k]."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONECIRAX1
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONECIRAX1[k]" ;
    ex:identificador "[ch].G.ZONECIRAX1[k]" ;
    ex:textoExtracto "Eje lógico correspondiente a la primera cota del centro de la zona [k]."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONECIRAX2
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONECIRAX2[k]" ;
    ex:identificador "[ch].G.ZONECIRAX2[k]" ;
    ex:textoExtracto "Eje lógico correspondiente a la segunda cota del centro de la zona [k]."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONECIR1
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONECIR1[k]" ;
    ex:identificador "[ch].G.ZONECIR1[k]" ;
    ex:textoExtracto "Cota del centro de la zona [k], según el primer eje que define la zona circular."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONECIR2
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONECIR2[k]" ;
    ex:identificador "[ch].G.ZONECIR2[k]" ;
    ex:textoExtracto "Cota del centro de la zona [k], según el segundo eje que define la zona circular."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONER
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONER[k]" ;
    ex:identificador "[ch].G.ZONER[k]" ;
    ex:textoExtracto "Radio de la zona [k] (zona circular)."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .

ex:Param_ZONETOOLWATCH
    a ex:Parametro ;
    rdfs:label "[ch].G.ZONETOOLWATCH[k]" ;
    ex:identificador "[ch].G.ZONETOOLWATCH[k]" ;
    ex:textoExtracto "Vigilar la punta o la base de la herramienta. (0=Vigilar la punta de la herramienta). (1=Vigilar la base de la herramienta). (2=Vigilar tanto la punta como la base de la herramienta)."@es ;
    ex:monitoreaParametro ex:SistemaZonasTrabajo .