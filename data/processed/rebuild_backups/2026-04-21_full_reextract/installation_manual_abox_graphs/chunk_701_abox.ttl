@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InstruccionesProgramacionCNC_4_6
    a ex:InterfazUsuario ;
    rdfs:label "Instrucciones de programación CNC (Sección 4.6)"@es ;
    ex:textoExtracto """
    NOT Invierte el resultado de la consulta.
    AND Función lógica \"Y\". OR Función lógica \"O\". XOR Función lógica \"O Exclusivo\". \\
    ( ) Instrucción de consulta de valor 1.
    Instrucciones de acción:
    • Instrucciones de acción binarias de asignación: = I, = O, = M, = MSG, = ERR, = TEN, = TRS, = TGn, = CUP, = CDW, = CEN, = CPR, = B
    • Instrucciones de acción binarias condicionadas: = SET, = RES, = CPL
    • Instrucciones de ruptura de secuencia: = JMP, = CAL, = RET
    • Instrucciones aritméticas: = MOV, = NGU, = NGS, = ADS, = SBS, = MLS, = DVS, = MDS
    """@es ;
    ex:identificador "4.6" .

ex:OperadorLogico_NOT a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Operador NOT"@es ;
    ex:textoExtracto "NOT Invierte el resultado de la consulta."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:OperadorLogico_AND a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Operador AND"@es ;
    ex:textoExtracto "AND Función lógica \"Y\"."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:OperadorLogico_OR a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Operador OR"@es ;
    ex:textoExtracto "OR Función lógica \"O\"."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:OperadorLogico_XOR a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Operador XOR"@es ;
    ex:textoExtracto "XOR Función lógica \"O Exclusivo\"."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionAsignacion_I
    a ex:Parametro ;
    rdfs:label "Instrucción de asignación I"@es ;
    ex:textoExtracto "= I 1/1024"@es ;
    ex:valor "1/1024" ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionAsignacion_O
    a ex:Parametro ;
    rdfs:label "Instrucción de asignación O"@es ;
    ex:textoExtracto "= O 1/1024"@es ;
    ex:valor "1/1024" ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionAsignacion_M
    a ex:Parametro ;
    rdfs:label "Instrucción de asignación M"@es ;
    ex:textoExtracto "= M 1/8192"@es ;
    ex:valor "1/8192" ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionCondicional_SET
    a ex:Parametro ;
    rdfs:label "Instrucción condicional SET"@es ;
    ex:textoExtracto "= SET Si expresión \"1\" asigna \"1\" al recurso."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionCondicional_RES
    a ex:Parametro ;
    rdfs:label "Instrucción condicional RES"@es ;
    ex:textoExtracto "= RES Si expresión \"1\" asigna \"0\" al recurso."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionRuptura_JMP
    a ex:Parametro ;
    rdfs:label "Instrucción de ruptura JMP"@es ;
    ex:textoExtracto "= JMP L Salto incondicional."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .

ex:InstruccionAritmetica_MOV
    a ex:Parametro ;
    rdfs:label "Instrucción aritmética MOV"@es ;
    ex:textoExtracto "= MOV Mover."@es ;
    ex:documentadoEn ex:InstruccionesProgramacionCNC_4_6 .