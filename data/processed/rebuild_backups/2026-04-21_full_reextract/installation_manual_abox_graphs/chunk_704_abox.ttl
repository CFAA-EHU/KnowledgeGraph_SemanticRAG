@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RegistroMFUN1
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN1 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN2
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN2 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN3
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN3 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN4
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN4 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN5
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN5 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN6
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN6 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:RegistroMFUN7
    a ex:ComponenteElectrico ;
    rdfs:label "Registro MFUN7 (32 bits)" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." .

ex:FuncionM100 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M100" ;
    ex:textoExtracto "si en un bloque se encuentran programadas las funciones M100, M120 y M135, el CNC pasará al PLC la siguiente información." .

ex:FuncionM120 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M120" ;
    ex:textoExtracto "si en un bloque se encuentran programadas las funciones M100, M120 y M135, el CNC pasará al PLC la siguiente información." .

ex:FuncionM135 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M135" ;
    ex:textoExtracto "si en un bloque se encuentran programadas las funciones M100, M120 y M135, el CNC pasará al PLC la siguiente información." .

ex:SistemaComunicacionCNC_PLC
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC para funciones M" ;
    ex:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución." ;
    ex:tieneComponente ex:RegistroMFUN1, ex:RegistroMFUN2, ex:RegistroMFUN3, ex:RegistroMFUN4, ex:RegistroMFUN5, ex:RegistroMFUN6, ex:RegistroMFUN7 ;
    ex:controla ex:FuncionM100, ex:FuncionM120, ex:FuncionM135 .