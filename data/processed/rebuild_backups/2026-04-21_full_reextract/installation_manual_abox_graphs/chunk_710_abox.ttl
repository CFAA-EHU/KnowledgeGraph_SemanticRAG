@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_MFUNC_Registros_Canal1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros MFUN para canal 1"@es ;
    ex:textoExtracto """
| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
| --- | --- | --- |
| 100 | 135 | $FFFFFFFF
""" ;
    ex:identificador "MFUN*C1" .

ex:Tabla_MFUNC_Registros_Canal2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros MFUN para canal 2"@es ;
    ex:textoExtracto """
| MFUN1C2 | MFUN2C2 | MFUN3C2 - MFUN7C2 |
| --- | --- | --- |
| 88 | 75 | $FFFFFFFF
""" ;
    ex:identificador "MFUN*C2" .

ex:Parametro_MFUNC1
    a ex:Parametro ;
    rdfs:label "Comando MFUNC1* (Canal 1)"@es ;
    ex:textoExtracto "MFUNC1* Para el canal 1"@es ;
    ex:identificador "MFUNC1*" ;
    ex:valor "Canal_1" .

ex:Parametro_MFUNC2
    a ex:Parametro ;
    rdfs:label "Comando MFUNC2* (Canal 2)"@es ;
    ex:textoExtracto "MFUNC2* Para el canal 2"@es ;
    ex:identificador "MFUNC2*" ;
    ex:valor "Canal_2" .

ex:Parametro_MFUNC3
    a ex:Parametro ;
    rdfs:label "Comando MFUNC3* (Canal 3)"@es ;
    ex:textoExtracto "MFUNC3* Para el canal 3"@es ;
    ex:identificador "MFUNC3*" ;
    ex:valor "Canal_3" .

ex:Parametro_MFUNC4
    a ex:Parametro ;
    rdfs:label "Comando MFUNC4* (Canal 4)"@es ;
    ex:textoExtracto "MFUNC4* Para el canal 4"@es ;
    ex:identificador "MFUNC4*" ;
    ex:valor "Canal_4" .

ex:Parametro_Terminador_MFUN
    a ex:Parametro ;
    rdfs:label "Valor terminador de registros MFUN"@es ;
    ex:textoExtracto "$FFFFFFFF" ;
    ex:identificador "MFUN_TERMINADOR" ;
    ex:valor "$FFFFFFFF" ;
    ex:documentadoEn ex:Tabla_MFUNC_Registros_Canal1 ;
    ex:documentadoEn ex:Tabla_MFUNC_Registros_Canal2 .

ex:Sistema_Analisis_Funciones_M
    a ex:Sistema ;
    rdfs:label "Sistema de análisis de funciones M programadas en canales"@es ;
    ex:textoExtracto "Analizar si una función ha sido programada en el canal. Para poder conocer si una determinada función M se encuentra programada en el bloque en ejecución, se puede utilizar uno de los siguientes métodos: • Analizar todos los registros MFUN del canal uno a uno, hasta encontrar dicha función M o hasta que uno de ellos tenga el valor $FFFFFFFF. • Utilizar uno de los siguientes comandos que permiten analizar todos los registros MFUN del canal a la vez."@es ;
    ex:tieneComponente ex:Parametro_MFUNC1 , ex:Parametro_MFUNC2 , ex:Parametro_MFUNC3 , ex:Parametro_MFUNC4 , ex:Parametro_Terminador_MFUN ;
    ex:detalladoEnEsquema ex:Tabla_MFUNC_Registros_Canal1 , ex:Tabla_MFUNC_Registros_Canal2 .