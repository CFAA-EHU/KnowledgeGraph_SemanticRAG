@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CNC_715
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC multicabezal" ;
    ex:textoExtracto "El CNC puede disponer de hasta cuatro cabezales. En un mismo bloque se podrán controlar todos ellos de forma independiente; es decir, a cada cabezal se le podrá dar una orden diferente."@es ;
    ex:tieneComponente ex:Cabezal1_715, ex:Cabezal2_715, ex:Cabezal3_715, ex:Cabezal4_715 ;
    ex:controla      ex:Parametro_SPDLNAME_715, ex:Registro_SFUN1_715, ex:Registro_SFUN2_715, ex:Registro_SFUN3_715, ex:Registro_SFUN4_715 ;
    ex:monitoreaParametro ex:Parametro_SPDLNAME_715 .

ex:Cabezal1_715
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal 1" ;
    ex:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es ;
    ex:identificador "1" .

ex:Cabezal2_715
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal 2" ;
    ex:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es ;
    ex:identificador "2" .

ex:Cabezal3_715
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal 3" ;
    ex:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es ;
    ex:identificador "3" .

ex:Cabezal4_715
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal 4" ;
    ex:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es ;
    ex:identificador "4" .

ex:Parametro_SPDLNAME_715
    a               ex:Parametro ;
    rdfs:label      "Parámetro SPDLNAME" ;
    ex:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME."@es ;
    ex:identificador "SPDLNAME" .

ex:Registro_SFUN1_715
    a               ex:Parametro ;
    rdfs:label      "Registro SFUN1" ;
    ex:textoExtracto "El CNC indica el PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Estos registros hacen referencia al número de cabezal; son independientes del canal en el que se encuentra el cabezal."@es ;
    ex:identificador "SFUN1" ;
    ex:valor         "1000"^^xsd:string .

ex:Registro_SFUN2_715
    a               ex:Parametro ;
    rdfs:label      "Registro SFUN2" ;
    ex:textoExtracto "El CNC indica el PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Estos registros hacen referencia al número de cabezal; son independientes del canal en el que se encuentra el cabezal."@es ;
    ex:identificador "SFUN2" ;
    ex:valor         "550"^^xsd:string .

ex:Registro_SFUN3_715
    a               ex:Parametro ;
    rdfs:label      "Registro SFUN3" ;
    ex:textoExtracto "El CNC indica el PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta."@es ;
    ex:identificador "SFUN3" ;
    ex:valor         "$FFFFFFFF"^^xsd:string .

ex:Registro_SFUN4_715
    a               ex:Parametro ;
    rdfs:label      "Registro SFUN4" ;
    ex:textoExtracto "El CNC indica el PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución. Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta."@es ;
    ex:identificador "SFUN4" ;
    ex:valor         "$FFFFFFFF"^^xsd:string .

ex:Comando_SP1FUN_715
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando SP1FUN*" ;
    ex:textoExtracto "Comandos SP1FUN* - SP4FUN*. Analizar si una función auxiliar ha sido programada para un cabezal. SP1FUN* Para el cabezal 1."@es ;
    ex:identificador "SP1FUN*" ;
    ex:controla      ex:Cabezal1_715 .

ex:Comando_SP2FUN_715
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando SP2FUN*" ;
    ex:textoExtracto "Comandos SP1FUN* - SP4FUN*. Analizar si una función auxiliar ha sido programada para un cabezal. SP2FUN* Para el cabezal 2."@es ;
    ex:identificador "SP2FUN*" ;
    ex:controla      ex:Cabezal2_715 .

ex:Comando_SP3FUN_715
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando SP3FUN*" ;
    ex:textoExtracto "Comandos SP1FUN* - SP4FUN*. Analizar si una función auxiliar ha sido programada para un cabezal. SP3FUN* Para el cabezal 3."@es ;
    ex:identificador "SP3FUN*" ;
    ex:controla      ex:Cabezal3_715 .

ex:Comando_SP4FUN_715
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando SP4FUN*" ;
    ex:textoExtracto "Comandos SP1FUN* - SP4FUN*. Analizar si una función auxiliar ha sido programada para un cabezal. SP4FUN* Para el cabezal 4."@es ;
    ex:identificador "SP4FUN*" ;
    ex:controla      ex:Cabezal4_715 .