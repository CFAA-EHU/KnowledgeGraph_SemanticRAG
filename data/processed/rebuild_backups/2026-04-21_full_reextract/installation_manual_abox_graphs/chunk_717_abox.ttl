@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionesM_H_S a ex:Tabla ;
     a ex:Sistema ;
    rdfs:label "Sistema de transferencia de funciones M, H y S"@es ;
    ex:textoExtracto "La transferencia de las funciones M y H se realiza por canal. La transferencia de las funciones S no depende del canal. Al ejecutarse un bloque que contiene las funciones M, H, S se pasa la siguiente información al PLC."@es ;
    ex:tieneComponente ex:FuncionesM ;
    ex:tieneComponente ex:FuncionesH ;
    ex:tieneComponente ex:FuncionesS ;
    ex:tieneComponente ex:Parametro_MINAENDW ;
    ex:tieneComponente ex:Senal_MSTROBE ;
    ex:tieneComponente ex:Senal_HSTROBE ;
    ex:tieneComponente ex:Senal_SSTROBE ;
    ex:tieneComponente ex:Senal_AUXEND ;
    ex:tieneComponente ex:Registro_MFUN1_a_MFUN7 ;
    ex:tieneComponente ex:Registro_HFUN1_a_HFUN7 ;
    ex:tieneComponente ex:Registro_SFUN1_a_SFUN4 .

ex:FuncionesM a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Funciones M (M00-M44)"@es ;
    ex:textoExtracto "M00 M01 M02 M03 M04 M05 M06 M08 M09 M19 M30 M41 M42 M43 M44. El CNC asigna a los registros MFUN1 a MFUN7 del canal los números de las funciones M programadas en el bloque."@es ;
    ex:identificador "M00-M44" .

ex:FuncionesH a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Funciones H"@es ;
    ex:textoExtracto "El CNC asigna a los registros HFUN1 a HFUN7 del canal los números de las funciones H programadas."@es .

ex:FuncionesS a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Funciones S"@es ;
    ex:textoExtracto "El CNC asigna a los registros SFUN1 a SFUN4 los valores de la S programada en cada cabezal."@es .

ex:Parametro_MINAENDW
    a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "Esta marca [MSTROBE/HSTROBE] se mantiene a (=1) durante el tiempo indicado en el parámetro MINAENDW."@es ;
    ex:valor "Tiempo de activación de strobe (ms)"@es .

ex:Senal_MSTROBE
    a ex:ComponenteElectrico ;
    rdfs:label "MSTROBE" ;
    ex:textoExtracto "El CNC activa la salida lógica general MSTROBE para indicar al PLC que debe ejecutarlas [funciones M]. Esta marca se mantiene a (=1) durante el tiempo indicado en el parámetro MINAENDW."@es .

ex:Senal_HSTROBE
    a ex:ComponenteElectrico ;
    rdfs:label "HSTROBE" ;
    ex:textoExtracto "El CNC activa la salida lógica general HSTROBE para indicar al PLC que debe ejecutarlas [funciones H]."@es .

ex:Senal_SSTROBE
    a ex:ComponenteElectrico ;
    rdfs:label "SSTROBE" ;
    ex:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla [función S]."@es .

ex:Senal_AUXEND
    a ex:ComponenteElectrico ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "El CNC esperará [...] la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC."@es .

ex:Registro_MFUN1_a_MFUN7
    a ex:ComponenteElectrico ;
    rdfs:label "Registros MFUN1 a MFUN7"@es ;
    ex:textoExtracto "El CNC asigna a los registros MFUN1 a MFUN7 del canal los números de las funciones M programadas en el bloque."@es ;
    ex:identificador "MFUN1-MFUN7" .

ex:Registro_HFUN1_a_HFUN7
    a ex:ComponenteElectrico ;
    rdfs:label "Registros HFUN1 a HFUN7"@es ;
    ex:textoExtracto "El CNC asigna a los registros HFUN1 a HFUN7 del canal los números de las funciones H programadas."@es ;
    ex:identificador "HFUN1-HFUN7" .

ex:Registro_SFUN1_a_SFUN4
    a ex:ComponenteElectrico ;
    rdfs:label "Registros SFUN1 a SFUN4"@es ;
    ex:textoExtracto "El CNC asigna a los registros SFUN1 a SFUN4 los valores de la S programada en cada cabezal."@es ;
    ex:identificador "SFUN1-SFUN4" .