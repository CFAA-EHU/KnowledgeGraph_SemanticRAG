@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ArchivoOEM_TXT
    a                   ex:InterfazUsuario ;
    rdfs:label          "OEM.txt" ;
    ex:identificador    "OEM.txt" ;
    ex:textoExtracto    "El fichero OEM.txt tendrá la siguiente estructura. [ 10] Texto de ayuda. [ 27] Texto de ayuda. [ 33] Texto de ayuda."^^rdfs:Literal .

ex:TextoAyuda_10
    a                   ex:InterfazUsuario ;
    rdfs:label          "Texto de ayuda 10" ;
    ex:identificador    "10" ;
    ex:textoExtracto    "[ 10] Texto de ayuda."^^rdfs:Literal ;
    ex:documentadoEn    ex:ArchivoOEM_TXT .

ex:TextoAyuda_27
    a                   ex:InterfazUsuario ;
    rdfs:label          "Texto de ayuda 27" ;
    ex:identificador    "27" ;
    ex:textoExtracto    "[ 27] Texto de ayuda."^^rdfs:Literal ;
    ex:documentadoEn    ex:ArchivoOEM_TXT .

ex:TextoAyuda_33
    a                   ex:InterfazUsuario ;
    rdfs:label          "Texto de ayuda 33" ;
    ex:identificador    "33" ;
    ex:textoExtracto    "[ 33] Texto de ayuda."^^rdfs:Literal ;
    ex:documentadoEn    ex:ArchivoOEM_TXT .

ex:RutaAsociacionMensajes
    a                   ex:InterfazUsuario ;
    rdfs:label          "Ruta de asociación de mensajes de ayuda" ;
    ex:identificador    "C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt" ;
    ex:textoExtracto    "El campo 'Archivo asociado' estará definido de la forma: C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt#27"^^rdfs:Literal .