@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Manual
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de operación manual" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de operación manual." ;
    ex:identificador "MANUAL, MANUALC1, MANUALC2, MANUALC3, MANUALC4" .

ex:ModoOperacion_Automatico
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de operación automático" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de operación automático." ;
    ex:identificador "AUTOMAT, AUTOMATC1, AUTOMATC2, AUTOMATC3, AUTOMATC4" .

ex:ModoOperacion_MDI
    a               ex:ModoOperacion ;
    rdfs:label      "Modo MDI (introducción manual de datos)" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo MDI (introducción manual de datos)." ;
    ex:textoExtracto "Si estando en modo automático se selecciona MDI se activan las marcas AUTOMAT y MDI. Si estando en modo manual se selecciona MDI se activan las marcas MANUAL y MDI." ;
    ex:identificador "MDI, MDIC1, MDIC2, MDIC3, MDIC4" .

ex:ModoOperacion_BloqueABloque
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de ejecución 'bloque a bloque'" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de ejecución 'bloque a bloque'." ;
    ex:textoExtracto "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT. Si estando en modo manual se selecciona –bloque a bloque– se activan las marcas MANUAL y SBOUT." ;
    ex:identificador "SBOUT, SBOUTC1, SBOUTC2, SBOUTC3, SBOUTC4" .

ex:Alarma_CicloPalpador
    a               ex:Alarma ;
    rdfs:label      "Alarma de error en ciclo de palpador" ;
    ex:textoExtracto "de un ciclo de palpador (o incluso fuera de éste), detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel '0')." .

ex:ComponenteElectrico_ReleEmergencia
    a               ex:ComponenteElectrico ;
    rdfs:label      "Relé de emergencia" ;
    ex:textoExtracto "detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel '0')." .

ex:InterfazUsuario_SenalesConsulta
    a               ex:InterfazUsuario ;
    rdfs:label      "Señales de consulta generales del CNC" ;
    ex:textoExtracto "Sección 6.1 Señales de consulta generales." ;
    ex:ilustradoEn   ex:ModoOperacion_Manual, ex:ModoOperacion_Automatico, ex:ModoOperacion_MDI, ex:ModoOperacion_BloqueABloque ;
    ex:activaAlarma ex:Alarma_CicloPalpador .