@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Automatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT." .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "Si estando en modo manual se selecciona –bloque a bloque– se activan las marcas MANUAL y SBOUT." .

ex:InterfazUsuario_Se_alesConsulta
    a ex:InterfazUsuario ;
    rdfs:label "Señales de consulta generales" ;
    ex:textoExtracto "Sección 6.1 Señales de consulta generales." ;
    ex:ilustradoEn ex:Pagina_406_417 .

ex:Pagina_406_417
    a ex:Pagina ;
    ex:identificador "406-417" ;
    ex:textoExtracto "Sección 6.1 Señales de consulta generales (páginas 406 a 417)." .

ex:Sensor_INCYCLEC1
    a ex:Sensor ;
    rdfs:label "INCYCLEC1" ;
    ex:identificador "INCYCLEC1" ;
    ex:textoExtracto "INCYCLEC1 (también se puede programar como INCYCLE)" ;
    ex:monitoreaParametro ex:Parametro_EstadoCanalC1 .

ex:Sensor_INCYCLEC2
    a ex:Sensor ;
    rdfs:label "INCYCLEC2" ;
    ex:identificador "INCYCLEC2" ;
    ex:textoExtracto "INCYCLEC2" ;
    ex:monitoreaParametro ex:Parametro_EstadoCanalC2 .

ex:Sensor_INCYCLEC3
    a ex:Sensor ;
    rdfs:label "INCYCLEC3" ;
    ex:identificador "INCYCLEC3" ;
    ex:textoExtracto "INCYCLEC3" ;
    ex:monitoreaParametro ex:Parametro_EstadoCanalC3 .

ex:Sensor_INCYCLEC4
    a ex:Sensor ;
    rdfs:label "INCYCLEC4" ;
    ex:identificador "INCYCLEC4" ;
    ex:textoExtracto "INCYCLEC4" ;
    ex:monitoreaParametro ex:Parametro_EstadoCanalC4 .

ex:Parametro_EstadoCanalC1
    a ex:Parametro ;
    rdfs:label "Estado del canal 1 (CNC)" ;
    ex:textoExtracto "El canal del CNC pone esta marca a [INCYCLEC1]." .

ex:Parametro_EstadoCanalC2
    a ex:Parametro ;
    rdfs:label "Estado del canal 2 (CNC)" ;
    ex:textoExtracto "INCYCLEC2." .

ex:Parametro_EstadoCanalC3
    a ex:Parametro ;
    rdfs:label "Estado del canal 3 (CNC)" ;
    ex:textoExtracto "INCYCLEC3." .

ex:Parametro_EstadoCanalC4
    a ex:Parametro ;
    rdfs:label "Estado del canal 4 (CNC)" ;
    ex:textoExtracto "INCYCLEC4." .

ex:AvisoSeguridad_MarcaAUTOMAT
    a ex:AvisoSeguridad ;
    rdfs:label "Marca AUTOMAT" ;
    ex:identificador "AUTOMAT" ;
    ex:textoExtracto "se activan las marcas AUTOMAT y SBOUT" ;
    ex:ilustradoEn ex:InterfazUsuario_Se_alesConsulta .

ex:AvisoSeguridad_MarcaSBOUT
    a ex:AvisoSeguridad ;
    rdfs:label "Marca SBOUT" ;
    ex:identificador "SBOUT" ;
    ex:textoExtracto "se activan las marcas AUTOMAT y SBOUT" ;
    ex:ilustradoEn ex:InterfazUsuario_Se_alesConsulta .

ex:AvisoSeguridad_MarcaMANUAL
    a ex:AvisoSeguridad ;
    rdfs:label "Marca MANUAL" ;
    ex:identificador "MANUAL" ;
    ex:textoExtracto "se activan las marcas MANUAL y SBOUT" ;
    ex:ilustradoEn ex:InterfazUsuario_Se_alesConsulta .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El canal del CNC pone esta marca a [INCYCLEC1]." ;
    ex:tieneComponente ex:Sensor_INCYCLEC1 , ex:Sensor_INCYCLEC2 , ex:Sensor_INCYCLEC3 , ex:Sensor_INCYCLEC4 .