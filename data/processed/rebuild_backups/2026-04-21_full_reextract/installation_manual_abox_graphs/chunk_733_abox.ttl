    a ex:Sensor ;
    rdfs:label "THREADC4" ;
    ex:identificador "THREADC4" ;
    ex:textoExtracto "THREADC4 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)."@es ;
