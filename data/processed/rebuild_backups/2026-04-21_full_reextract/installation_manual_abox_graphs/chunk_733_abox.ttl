ex:SenalTAPPINGC1
    a ex:Sensor ;
    rdfs:label "TAPPINGC1" ;
    ex:identificador "TAPPINGC1" ;
    ex:textoExtracto "TAPPINGC1 (también se puede programar como TAPPING) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoConMacho .

ex:SenalTAPPINGC2
    a ex:Sensor ;
    rdfs:label "TAPPINGC2" ;
    ex:identificador "TAPPINGC2" ;
    ex:textoExtracto "TAPPINGC2 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoConMacho .

ex:SenalTAPPINGC3
    a ex:Sensor ;
    rdfs:label "TAPPINGC3" ;
    ex:identificador "TAPPINGC3" ;
    ex:textoExtracto "TAPPINGC3 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoConMacho .

ex:SenalTAPPINGC4
    a ex:Sensor ;
    rdfs:label "TAPPINGC4" ;
    ex:identificador "TAPPINGC4" ;
    ex:textoExtracto "TAPPINGC4 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoConMacho .

ex:ParametroRoscadoElectronico
    a ex:Parametro ;
    rdfs:label "Roscado electrónico (G33)"@es ;
    ex:textoExtracto "bloque de roscado electrónico (G33)"@es .

ex:ParametroRoscadoConMacho
    a ex:Parametro ;
    rdfs:label "Ciclo fijo de roscado con macho"@es ;
    ex:textoExtracto "ciclo fijo de roscado con macho"@es .

ex:InterfazSenalesCNC
    a ex:InterfazUsuario ;
    rdfs:label "Señales de consulta generales del CNC"@es ;
    ex:textoExtracto "Señales de consulta generales. [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando [...]"@es ;
    ex:tieneComponente ex:SenalTHREADC1, ex:SenalTHREADC2, ex:SenalTHREADC3, ex:SenalTHREADC4,
                       ex:SenalTAPPINGC1, ex:SenalTAPPINGC2, ex:SenalTAPPINGC3, ex:SenalTAPPINGC4 .