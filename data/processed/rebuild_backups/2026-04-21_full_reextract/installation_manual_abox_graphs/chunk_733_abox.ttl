@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SenalTHREADC1
    a ex:Sensor ;
    rdfs:label "THREADC1" ;
    ex:identificador "THREADC1" ;
    ex:textoExtracto "THREADC1 (también se puede programar como THREAD) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoElectronico .

ex:SenalTHREADC2
    a ex:Sensor ;
    rdfs:label "THREADC2" ;
    ex:identificador "THREADC2" ;
    ex:textoExtracto "THREADC2 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)."@es ;
    ex:monitoreaParametro ex:ParametroRoscadoElectronico .

ex:SenalTHREADC3
    a ex:Sensor ;
    rdfs:label "THREADC3" ;
    ex:identificador "THREADC3" ;
    ex:textoExtracto "THREADC3 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)."@es ;
