@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_RIGID
    a ex:InterfazUsuario ;
    rdfs:label "Señal RIGID (roscado rígido)" ;
    ex:textoExtracto "Hay una marca para cada canal. [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado rígido (G63). Los roscados con macho (G84 en fresadora y G83 en torno) parametrizados como roscados rígidos ponen esta marca a (=1) durante todo el roscado, incluida la temporización en el fondo de la rosca." ;
    ex:identificador "RIGID, RIGIDC1, RIGIDC2, RIGIDC3, RIGIDC4" .

ex:Senal_CSS
    a ex:InterfazUsuario ;
    rdfs:label "Señal CSS (velocidad de corte constante)" ;
    ex:textoExtracto "Hay una marca para cada canal. [...] El canal del CNC pone esta marca a (=1) cuando está seleccionada la función de velocidad de corte constante (G96)." ;
    ex:identificador "CSS, CSSC1, CSSC2, CSSC3, CSSC4" .

ex:Senal_INTEREND
    a ex:InterfazUsuario ;
    rdfs:label "Señal INTEREND (fin de desplazamiento teórico)" ;
    ex:textoExtracto "El canal del CNC pone la marca INTEREND a (=1) cuando ha finalizado el desplazamiento teórico de los ejes (cuando deja de enviar consigna)." ;
    ex:identificador "INTEREND, INTERENDC1, INTERENDC2, INTERENDC3, INTERENDC4" .

ex:Senal_INPOSI
    a ex:InterfazUsuario ;
    rdfs:label "Señal INPOSI (en posición)" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. INPOSI[...]" ;
    ex:identificador "INPOSI" .

ex:Senal_ADVINPOS
    a ex:InterfazUsuario ;
    rdfs:label "Señal ADVINPOS (anticipo de posición)" ;
    ex:textoExtracto "También puede utilizarse la marca ADVINPOS." ;
    ex:identificador "ADVINPOS" ;
    ex:documentadoEn ex:Pagina_414 .

ex:Pagina_414
    a ex:Pagina ;
    rdfs:label "Página 414 (referencia a ADVINPOS)" ;
    ex:textoExtracto "Ver en la página 414. \"ADVINPOS\"." .

ex:Ciclo_G84
    a ex:ModoOperacion ;
    rdfs:label "Ciclo fijo G84 (roscado con macho en fresadora)" ;
    ex:textoExtracto "En fresadora, ciclo G84, la marca se mantiene activa durante todo el ciclo (incluyendo los bloques de movimiento al punto inicial, etc)." ;
    ex:identificador "G84" .

ex:Ciclo_G83
    a ex:ModoOperacion ;
    rdfs:label "Ciclo fijo G83 (roscado con macho en torno)" ;
    ex:textoExtracto "En torno, ciclo G83, la marca se mantiene activa sólo durante el tiempo que dura el roscado." ;
    ex:identificador "G83" .

ex:Ciclo_G63
    a ex:ModoOperacion ;
    rdfs:label "Ciclo G63 (roscado rígido)" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado rígido (G63)." ;
    ex:identificador "G63" .

ex:Funcion_G96 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función G96 (velocidad de corte constante)" ;
    ex:textoExtracto "El canal del CNC pone la marca CSS a (=1) cuando está seleccionada la función de velocidad de corte constante (G96)." ;
    ex:identificador "G96" .

ex:Senal_RoscadoMacho
    a ex:InterfazUsuario ;
    rdfs:label "Señal de ciclo fijo de roscado con macho" ;
    ex:textoExtracto "CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho. La marca se mantiene activa durante la posible temporización que se haya programado en el fondo de la rosca." .