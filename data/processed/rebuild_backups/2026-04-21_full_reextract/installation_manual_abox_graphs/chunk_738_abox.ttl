    a ex:Parametro ;
    rdfs:label "MFUN1C2" ;
    ex:valor "88" ;
    ex:textoExtracto "MFUN1C2 | [...] | 88"@es ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .

ex:Parametro_MFUN2C2
    a ex:Parametro ;
    rdfs:label "MFUN2C2" ;
