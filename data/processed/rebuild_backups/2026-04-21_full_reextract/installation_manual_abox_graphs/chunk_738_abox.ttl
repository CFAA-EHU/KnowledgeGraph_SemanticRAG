ex:Sistema_ComunicacionCNC_PLC
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC"@es ;
    ex:textoExtracto "el CNC pasará al PLC la siguiente información"@es ;
    ex:tieneComponente ex:Parametro_MFUN1C1 , ex:Parametro_MFUN2C1 , ex:Parametro_MFUN3C1_a_MFUN7C1 ,
                      ex:Parametro_MFUN1C2 , ex:Parametro_MFUN2C2 , ex:Parametro_MFUN3C2_a_MFUN7C2 ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .