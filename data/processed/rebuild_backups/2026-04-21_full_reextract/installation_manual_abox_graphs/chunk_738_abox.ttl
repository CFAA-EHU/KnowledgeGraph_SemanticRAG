    ex:textoExtracto "MFUN2C2 | [...] | 75"@es ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .

ex:Parametro_MFUN3C1_a_MFUN7C1
    a ex:Parametro ;
    rdfs:label "MFUN3C1 - MFUN7C1" ;
    ex:valor "$FFFFFFFF" ;
    ex:textoExtracto "MFUN3C1 - MFUN7C1 | [...] | $FFFFFFFF"@es ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .

ex:Parametro_MFUN3C2_a_MFUN7C2
    a ex:Parametro ;
