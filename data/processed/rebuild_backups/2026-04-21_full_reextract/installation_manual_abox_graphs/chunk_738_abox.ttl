@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SenalesConsultaGenerales_6_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de señales de consulta generales (Sección 6.1)"@es ;
    ex:textoExtracto """
    | MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
    | --- | --- | --- |
    | 100 | 135 | $FFFFFFFF |

    | MFUN1C2 | MFUN2C2 | MFUN3C2 - MFUN7C2 |
    | --- | --- | --- |
    | 88 | 75 | $FFFFFFFF |
    """@es ;
    ex:identificador "Sección 6.1 - Señales de consulta generales" .

ex:Parametro_MFUN1C1
    a ex:Parametro ;
    rdfs:label "MFUN1C1" ;
    ex:valor "100" ;
    ex:textoExtracto "MFUN1C1 | [...] | 100"@es ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .

ex:Parametro_MFUN2C1
    a ex:Parametro ;
    rdfs:label "MFUN2C1" ;
    ex:valor "135" ;
    ex:textoExtracto "MFUN2C1 | [...] | 135"@es ;
    ex:documentadoEn ex:Tabla_SenalesConsultaGenerales_6_1 .

