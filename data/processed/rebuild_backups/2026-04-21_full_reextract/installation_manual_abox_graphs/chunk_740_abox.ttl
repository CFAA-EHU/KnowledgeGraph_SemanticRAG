@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Se_alesConsulta_6_1
    a ex:Tabla ;
    rdfs:label "Tabla de señales de consulta generales (Sección 6.1)"@es ;
    ex:textoExtracto """
    | HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 |
    | --- | --- | --- |
    | 10 | 20 | $FFFFFFFF |

    | HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 |
    | --- | --- | --- |
    | 30 | 40 | $FFFFFFFF |
    """@es ;
    ex:identificador "6.1" .

ex:Parametro_HFUN1C1
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN1C1"@es ;
    ex:textoExtracto "HFUN1C1 | 10"@es ;
    ex:valor "10" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Parametro_HFUN2C1
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN2C1"@es ;
    ex:textoExtracto "HFUN2C1 | 20"@es ;
    ex:valor "20" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Parametro_HFUN3C1
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN3C1"@es ;
    ex:textoExtracto "HFUN3C1 - HFUN7C1 | $FFFFFFFF"@es ;
    ex:valor "$FFFFFFFF" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Parametro_HFUN1C2
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN1C2"@es ;
    ex:textoExtracto "HFUN1C2 | 30"@es ;
    ex:valor "30" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Parametro_HFUN2C2
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN2C2"@es ;
    ex:textoExtracto "HFUN2C2 | 40"@es ;
    ex:valor "40" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Parametro_HFUN3C2
    a ex:Parametro ;
    rdfs:label "Parámetro HFUN3C2"@es ;
    ex:textoExtracto "HFUN3C2 - HFUN7C2 | $FFFFFFFF"@es ;
    ex:valor "$FFFFFFFF" ;
    ex:documentadoEn ex:Tabla_Se_alesConsulta_6_1 .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres"@es ;
    ex:monitoreaParametro ex:Parametro_HFUN1C1 , ex:Parametro_HFUN2C1 , ex:Parametro_HFUN3C1 ,
                        ex:Parametro_HFUN1C2 , ex:Parametro_HFUN2C2 , ex:Parametro_HFUN3C2 .

ex:InterfazUsuario_PLC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz PLC"@es ;
    ex:textoExtracto "el CNC pasará al PLC la siguiente información"@es .