@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:BLKSEARCHC1
    a ex:Parametro ;
    rdfs:label "BLKSEARCHC1" ;
    ex:identificador "BLKSEARCHC1" ;
    ex:textoExtracto "BLKSEARCHC1 (también se puede programar como BLKSEARCH)" ;
    ex:monitoreaParametro ex:ModoBusquedaBloque .

ex:BLKSEARCHC2
    a ex:Parametro ;
    rdfs:label "BLKSEARCHC2" ;
    ex:identificador "BLKSEARCHC2" ;
    ex:textoExtracto "BLKSEARCHC2" ;
    ex:monitoreaParametro ex:ModoBusquedaBloque .

ex:BLKSEARCHC3
    a ex:Parametro ;
    rdfs:label "BLKSEARCHC3" ;
    ex:identificador "BLKSEARCHC3" ;
    ex:textoExtracto "BLKSEARCHC3" ;
    ex:monitoreaParametro ex:ModoBusquedaBloque .

ex:BLKSEARCHC4
    a ex:Parametro ;
    rdfs:label "BLKSEARCHC4" ;
    ex:identificador "BLKSEARCHC4" ;
    ex:textoExtracto "BLKSEARCHC4" ;
    ex:monitoreaParametro ex:ModoBusquedaBloque .

ex:ADVINPOSC1
    a ex:Parametro ;
    rdfs:label "ADVINPOSC1" ;
    ex:identificador "ADVINPOSC1" ;
    ex:textoExtracto "ADVINPOSC1 (también se puede programar como ADVINPOS)" ;
    ex:monitoreaParametro ex:SenalAvancePosicion .

ex:ADVINPOSC2
    a ex:Parametro ;
    rdfs:label "ADVINPOSC2" ;
    ex:identificador "ADVINPOSC2" ;
    ex:textoExtracto "ADVINPOSC2" ;
    ex:monitoreaParametro ex:SenalAvancePosicion .

ex:ADVINPOSC3
    a ex:Parametro ;
    rdfs:label "ADVINPOSC3" ;
    ex:identificador "ADVINPOSC3" ;
    ex:textoExtracto "ADVINPOSC3" ;
    ex:monitoreaParametro ex:SenalAvancePosicion .

ex:ADVINPOSC4
    a ex:Parametro ;
    rdfs:label "ADVINPOSC4" ;
