ex:ModoBusquedaBloque
    a ex:ModoOperacion ;
    rdfs:label "Modo búsqueda de bloque" ;
    ex:textoExtracto "opción –búsqueda de bloque– en el modo de operación automático" .

ex:SenalAvancePosicion
    a ex:Parametro ;
    rdfs:label "Señal de avance en posición" ;
    ex:textoExtracto "El canal del CNC pone esta señal" .