@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_ADVINPOSC1
    a ex:InterfazUsuario ;
    rdfs:label "ADVINPOSC1" ;
    ex:identificador "ADVINPOSC1" ;
    ex:textoExtracto "ADVINPOSC1 (también se puede programar como ADVINPOS) [...] El canal del CNC pone esta señal a nivel lógico alto un tiempo antes de llegar los ejes a posición. Este tiempo lo fija el parámetro máquina ANTIME."@es ;
    ex:monitoreaParametro ex:Parametro_ANTIME .

ex:Senal_ADVINPOSC2
    a ex:InterfazUsuario ;
    rdfs:label "ADVINPOSC2" ;
    ex:identificador "ADVINPOSC2" ;
    ex:textoExtracto "ADVINPOSC2"@es .

ex:Senal_ADVINPOSC3
    a ex:InterfazUsuario ;
    rdfs:label "ADVINPOSC3" ;
    ex:identificador "ADVINPOSC3" ;
    ex:textoExtracto "ADVINPOSC3"@es .

ex:Senal_ADVINPOSC4
    a ex:InterfazUsuario ;
    rdfs:label "ADVINPOSC4" ;
    ex:identificador "ADVINPOSC4" ;
    ex:textoExtracto "ADVINPOSC4"@es .

ex:Parametro_ANTIME
    a ex:Parametro ;
    rdfs:label "ANTIME" ;
    ex:identificador "ANTIME" ;
    ex:textoExtracto "Este tiempo lo fija el parámetro máquina ANTIME. Si la duración total del movimiento es inferior al valor especificado en el parámetro ANTIME, la marca se pone a (=1) inmediatamente."@es .

ex:Senal_CAXISC1
    a ex:InterfazUsuario ;
    rdfs:label "CAXISC1" ;
    ex:identificador "CAXISC1" ;
    ex:textoExtracto "CAXISC1 (también se puede programar como CAXIS) [...] El canal del CNC pone esta marca a (=1) cuando el cabezal está trabajando como eje C."@es .

