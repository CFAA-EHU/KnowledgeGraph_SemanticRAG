@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MMCWDG
    a ex:Parametro ;
    rdfs:label "MMCWDG" ;
    ex:textoExtracto "MMCWDG [...] indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." ;
    ex:valor "0 (operativo), 1 (bloqueo)" .

ex:TANGACTIV
    a ex:Parametro ;
    rdfs:label "TANGACTIV (control tangencial)" ;
    ex:textoExtracto "TANGACTIV [...] El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." .

ex:TANGACTIVC1
    a ex:Parametro ;
    rdfs:label "TANGACTIVC1" ;
    ex:identificador "C1" ;
    ex:textoExtracto "TANGACTIVC1 (marca para canal 1)" ;
    ex:valor "0 (inactivo), 1 (activo)" .

ex:TANGACTIVC2
    a ex:Parametro ;
    rdfs:label "TANGACTIVC2" ;
    ex:identificador "C2" ;
    ex:textoExtracto "TANGACTIVC2 (marca para canal 2)" ;
    ex:valor "0 (inactivo), 1 (activo)" .

ex:TANGACTIVC3
    a ex:Parametro ;
    rdfs:label "TANGACTIVC3" ;
    ex:identificador "C3" ;
    ex:textoExtracto "TANGACTIVC3 (marca para canal 3)" ;
    ex:valor "0 (inactivo), 1 (activo)" .

ex:TANGACTIVC4
    a ex:Parametro ;
    rdfs:label "TANGACTIVC4" ;
    ex:identificador "C4" ;
    ex:textoExtracto "TANGACTIVC4 (marca para canal 4)" ;
    ex:valor "0 (inactivo), 1 (activo)" .

ex:RETRAEND
    a ex:Parametro ;
    rdfs:label "RETRAEND" ;
    ex:textoExtracto "RETRAEND [...] El canal del CNC pone esta marca a (=1) para cancelar la función retrace." .

ex:RETRAENDC1
    a ex:Parametro ;
    rdfs:label "RETRAENDC1" ;
    ex:identificador "C1" ;
    ex:textoExtracto "RETRAENDC1 (marca para canal 1)" ;
    ex:valor "0 (inactivo), 1 (cancelación retrace)" .

ex:RETRAENDC2
    a ex:Parametro ;
    rdfs:label "RETRAENDC2" ;
    ex:identificador "C2" ;
    ex:textoExtracto "RETRAENDC2 (marca para canal 2)" ;
    ex:valor "0 (inactivo), 1 (cancelación retrace)" .

ex:RETRAENDC3
    a ex:Parametro ;
    rdfs:label "RETRAENDC3" ;
    ex:identificador "C3" ;
    ex:textoExtracto "RETRAENDC3 (marca para canal 3)" ;
    ex:valor "0 (inactivo), 1 (cancelación retrace)" .

ex:RETRAENDC4
    a ex:Parametro ;
    rdfs:label "RETRAENDC4" ;
    ex:identificador "C4" ;
    ex:textoExtracto "RETRAENDC4 (marca para canal 4)" ;
    ex:valor "0 (inactivo), 1 (cancelación retrace)" .

ex:RETRACE
    a ex:Parametro ;
    rdfs:label "RETRACE" ;
    ex:textoExtracto "RETRACE [...] Si el PLC quita automáticamente la marca RETRACE con la marca RETRAEND, el CNC continua con la ejecución normal del programa." ;
    ex:valor "0 (inactivo), 1 (retrace activo)" .

ex:AvisoRetraceActivo
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de retrace activo" ;
    ex:textoExtracto "el CNC mostrará un aviso indicando que se debe desactivar esta marca para continuar con la ejecución del programa." .