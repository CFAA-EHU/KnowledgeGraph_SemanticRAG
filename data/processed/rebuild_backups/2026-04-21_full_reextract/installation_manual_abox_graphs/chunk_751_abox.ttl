@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_DINDISTC2C1
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTC2C1" ;
    ex:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3. Utilizar estas marcas para que la interrupción del programa, la reanudación y la ejecución bloque a bloque en uno de los canales afecte a todos los canales implicados en el reparto de pasadas." ;
    ex:identificador "DINDISTC2C1" .

ex:Marca_DINDISTC2C3
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTC2C3" ;
    ex:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3. Utilizar estas marcas para que la interrupción del programa, la reanudación y la ejecución bloque a bloque en uno de los canales afecte a todos los canales implicados en el reparto de pasadas." ;
    ex:identificador "DINDISTC2C3" .

ex:Marca_DINDISTYPE
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPE" ;
    ex:textoExtracto "DINDISTYPE Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4 Esta marca está asociada a la distribución dinámica del mecanizado entre" ;
    ex:identificador "DINDISTYPE" .

ex:Marca_DINDISTYPEC1
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPEC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" ;
    ex:identificador "DINDISTYPEC1" .

ex:Marca_DINDISTYPEC2
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPEC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" ;
    ex:identificador "DINDISTYPEC2" .

ex:Marca_DINDISTYPEC3
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPEC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" ;
    ex:identificador "DINDISTYPEC3" .

ex:Marca_DINDISTYPEC4
    a ex:ComponenteElectrico ;
    rdfs:label "Marca DINDISTYPEC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" ;
    ex:identificador "DINDISTYPEC4" .

ex:Canal_1
    a ex:Componente ;
    rdfs:label "Canal 1" ;
    ex:textoExtracto "el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ y ꞏ3ꞏ" ;
    ex:identificador "1" .

ex:Canal_2
    a ex:Componente ;
    rdfs:label "Canal 2" ;
    ex:textoExtracto "el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ y ꞏ3ꞏ" ;
    ex:identificador "2" .

ex:Canal_3
    a ex:Componente ;
    rdfs:label "Canal 3" ;
    ex:textoExtracto "el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ y ꞏ3ꞏ" ;
    ex:identificador "3" .

ex:Canal_4
    a ex:Componente ;
    rdfs:label "Canal 4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4" ;
    ex:identificador "4" .

ex:Sistema_DistribucionDinamica
    a ex:Sistema ;
    rdfs:label "Sistema de distribución dinámica del mecanizado" ;
    ex:textoExtracto "Esta marca está asociada a la distribución dinámica del mecanizado entre" ;
    ex:tieneComponente ex:Marca_DINDISTYPE ;
    ex:tieneComponente ex:Marca_DINDISTYPEC1 ;
    ex:tieneComponente ex:Marca_DINDISTYPEC2 ;
    ex:tieneComponente ex:Marca_DINDISTYPEC3 ;
    ex:tieneComponente ex:Marca_DINDISTYPEC4 ;
    ex:tieneComponente ex:Marca_DINDISTC2C1 ;
    ex:tieneComponente ex:Marca_DINDISTC2C3 ;
    ex:tieneComponente ex:Canal_1 ;
    ex:tieneComponente ex:Canal_2 ;
    ex:tieneComponente ex:Canal_3 ;
    ex:tieneComponente ex:Canal_4 .