@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_DINDISTYPEC1
    a ex:InterfazUsuario ;
    rdfs:label "Marca DINDISTYPEC1" ;
    ex:textoExtracto "DINDISTYPEC1 [...] Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." ;
    ex:identificador "DINDISTYPEC1" .

ex:Marca_DINDISTYPEC2
    a ex:InterfazUsuario ;
    rdfs:label "Marca DINDISTYPEC2" ;
    ex:textoExtracto "DINDISTYPEC2 [...] Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." ;
    ex:identificador "DINDISTYPEC2" .

ex:Marca_DINDISTYPEC3
    a ex:InterfazUsuario ;
    rdfs:label "Marca DINDISTYPEC3" ;
    ex:textoExtracto "DINDISTYPEC3 [...] Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." ;
    ex:identificador "DINDISTYPEC3" .

ex:Marca_DINDISTYPEC4
    a ex:InterfazUsuario ;
    rdfs:label "Marca DINDISTYPEC4" ;
    ex:textoExtracto "DINDISTYPEC4 [...] Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." ;
    ex:identificador "DINDISTYPEC4" .

ex:Marca_SERPLCAC
    a ex:InterfazUsuario ;
    rdfs:label "Marca SERPLCAC" ;
    ex:textoExtracto "SERPLCAC [...] Esta marca está asociada al cambio de la gama de trabajo o del set de parámetros de un regulador Sercos (variable (V.)[ch].A.SETGE.xn)." ;
    ex:identificador "SERPLCAC" .

ex:Marca_OVERTEMP
    a ex:InterfazUsuario ;
    rdfs:label "Marca OVERTEMP" ;
    ex:textoExtracto "OVERTEMP [...] Esta marca indica el estado de la temperatura del CNC." ;
    ex:identificador "OVERTEMP" .

ex:Parametro_TemperaturaMaximaAmbiente
    a ex:Parametro ;
    rdfs:label "Temperatura máxima ambiente permitida" ;
    ex:textoExtracto "60 ºC (140 ºF)" ;
    ex:valor "60" .

ex:Parametro_TemperaturaCriticaAmbiente
    a ex:Parametro ;
    rdfs:label "Temperatura crítica ambiente (invalida START)" ;
    ex:textoExtracto "65ºC (149ºF)" ;
    ex:valor "65" .

ex:Aviso_W169
    a ex:AvisoSeguridad ;
    rdfs:label "Warning W169 (sobretemperatura)" ;
    ex:textoExtracto "El CNC activa esta marca y muestra el warning W169 avisando de esta circunstancia [temperatura > 60 ºC]." ;
    ex:identificador "W169" .

ex:AccionProhibida_ReanudarOperacionSobreTemperatura
    a ex:AccionProhibida ;
    rdfs:label "Reanudar operación con temperatura ambiente > 65 ºC" ;
    ex:textoExtracto "El CNC no permitirá reanudar [la ejecución] tras una interrupción, una inspección de herramienta, etc. [si temperatura > 65 ºC]." .

ex:Error_E173
    a ex:AvisoSeguridad ;
    rdfs:label "Error E173 (temperatura > 65 ºC)" ;
    ex:textoExtracto "El CNC comprueba que la temperatura ambiente no sobrepase los 65ºC (149ºF), y en caso de superar dicho valor, invalida el [START] y muestra el error E173." ;
    ex:identificador "E173" .

ex:Marca_OVERTEMP
    ex:activaAlarma ex:Aviso_W169 ;
    ex:activaAlarma ex:Error_E173 .