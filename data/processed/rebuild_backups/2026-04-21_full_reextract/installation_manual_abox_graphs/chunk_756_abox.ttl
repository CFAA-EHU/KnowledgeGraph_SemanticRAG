@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Parametros de control DMC
ex:DMCPWRPEAK
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ex:textoExtracto "DMCPWRPEAK [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si la potencia leída supera a la potencia a alcanzar (potencia objetivo + potencia en vacío) en el porcentaje definido en el parámetro DMCPEAKSIZE." ;
    ex:identificador "DMCPWRPEAK" .

ex:DMCPWRPEAKC1
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 1" ;
    ex:textoExtracto "DMCPWRPEAKC1" ;
    ex:identificador "DMCPWRPEAKC1" .

ex:DMCPWRPEAKC2
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 2" ;
    ex:textoExtracto "DMCPWRPEAKC2" ;
    ex:identificador "DMCPWRPEAKC2" .

ex:DMCPWRPEAKC3
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 3" ;
    ex:textoExtracto "DMCPWRPEAKC3" ;
    ex:identificador "DMCPWRPEAKC3" .

ex:DMCPWRPEAKC4
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 4" ;
    ex:textoExtracto "DMCPWRPEAKC4" ;
    ex:identificador "DMCPWRPEAKC4" .

ex:DMCPEAKSIZE
    a ex:Parametro ;
    rdfs:label "DMCPEAKSIZE" ;
    ex:textoExtracto "porcentaje definido en el parámetro DMCPEAKSIZE" ;
    ex:identificador "DMCPEAKSIZE" .

ex:DMCPWRHOLD
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD" ;
    ex:textoExtracto "DMCPWRHOLD [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si todos los valores de potencia leídos a lo largo de 2 segundos exceden la potencia a alcanzar multiplicada por el parámetro DMCPOWERFACTOR." ;
    ex:identificador "DMCPWRHOLD" .

ex:DMCPWRHOLDC1
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD Canal 1" ;
    ex:textoExtracto "DMCPWRHOLDC1" ;
    ex:identificador "DMCPWRHOLDC1" .

ex:DMCPWRHOLDC2
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD Canal 2" ;
    ex:textoExtracto "DMCPWRHOLDC2" ;
    ex:identificador "DMCPWRHOLDC2" .

ex:DMCPWRHOLDC3
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD Canal 3" ;
    ex:textoExtracto "DMCPWRHOLDC3" ;
    ex:identificador "DMCPWRHOLDC3" .

ex:DMCPWRHOLDC4
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD Canal 4" ;
    ex:textoExtracto "DMCPWRHOLDC4" ;
    ex:identificador "DMCPWRHOLDC4" .

ex:DMCPOWERFACTOR
    a ex:Parametro ;
    rdfs:label "DMCPOWERFACTOR" ;
    ex:textoExtracto "potencia a alcanzar multiplicada por el parámetro DMCPOWERFACTOR" ;
    ex:identificador "DMCPOWERFACTOR" .

### Parametros de corte láser
ex:ADVCUTOFF
    a ex:Parametro ;
    rdfs:label "ADVCUTOFF" ;
    ex:textoExtracto "ADVCUTOFF [...] El CNC activa esta marca (cambio de 0 a 1) durante la ejecución de microjoints, cuando el láser alcanza la distancia G.ADVCUTOFFW o el tiempo G.ADVCUTOFFT antes del #CUTTING OFF." ;
    ex:identificador "ADVCUTOFF" .

ex:G_ADVCUTOFFW
    a ex:Parametro ;
    rdfs:label "G.ADVCUTOFFW" ;
    ex:textoExtracto "distancia G.ADVCUTOFFW" ;
    ex:identificador "G.ADVCUTOFFW" .

ex:G_ADVCUTOFFT
    a ex:Parametro ;
    rdfs:label "G.ADVCUTOFFT" ;
    ex:textoExtracto "tiempo G.ADVCUTOFFT" ;
    ex:identificador "G.ADVCUTOFFT" .

### Parametros de compensación cinemática
ex:KINCOMP1
    a ex:Parametro ;
    rdfs:label "KINCOMP1" ;
    ex:textoExtracto "KINCOMP1 [...] Cada cinemática tiene una compensación asociada (parámetro COMPID). KINCOMP1 está asociado a COMPID 1" ;
    ex:identificador "KINCOMP1" .

ex:KINCOMP2
    a ex:Parametro ;
    rdfs:label "KINCOMP2" ;
    ex:textoExtracto "KINCOMP2" ;
    ex:identificador "KINCOMP2" .

ex:KINCOMP3
    a ex:Parametro ;
    rdfs:label "KINCOMP3" ;
    ex:textoExtracto "KINCOMP3" ;
    ex:identificador "KINCOMP3" .

ex:KINCOMP4
    a ex:Parametro ;
    rdfs:label "KINCOMP4" ;
    ex:textoExtracto "KINCOMP4" ;
    ex:identificador "KINCOMP4" .

ex:KINCOMP5
    a ex:Parametro ;
    rdfs:label "KINCOMP5" ;
    ex:textoExtracto "KINCOMP5" ;
    ex:identificador "KINCOMP5" .

ex:KINCOMP6
    a ex:Parametro ;
    rdfs:label "KINCOMP6" ;
    ex:textoExtracto "KINCOMP6 [...] Cada cinemática tiene una compensación asociada (parámetro COMPID). KINCOMP6 está asociado a COMPID 6" ;
    ex:identificador "KINCOMP6" .

ex:COMPID
    a ex:Parametro ;
    rdfs:label "COMPID" ;
    ex:textoExtracto "parámetro COMPID [...] Cada cinemática tiene una compensación asociada" ;
    ex:identificador "COMPID" .

### Sistema de control (ancla para relaciones)
ex:SistemaControlDMC
    a ex:Sistema ;
    rdfs:label "Sistema de Control DMC (Fagor)" ;
    ex:textoExtracto "los gráficos STD (gráficos estándar Fagor) [...] Con el DMC activo, el canal del CNC activa (=1) esta marca si..." ;
    ex:tieneComponente ex:DMCPWRPEAK, ex:DMCPWRHOLD, ex:ADVCUTOFF, ex:KINCOMP1, ex:KINCOMP2, ex:KINCOMP3, ex:KINCOMP4, ex:KINCOMP5, ex:KINCOMP6 ;
    ex:monitoreaParametro ex:DMCPEAKSIZE, ex:DMCPOWERFACTOR, ex:G_ADVCUTOFFW, ex:G_ADVCUTOFFT, ex:COMPID .