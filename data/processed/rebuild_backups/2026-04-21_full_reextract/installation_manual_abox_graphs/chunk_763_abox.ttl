@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HIRTH
    a               ex:Parametro ;
    rdfs:label      "Parámetro máquina HIRTH"@es ;
    ex:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth."@es ;
    ex:identificador "HIRTH" .

ex:ModoOperacion_G170
    a               ex:ModoOperacion ;
    rdfs:label      "Función G170"@es ;
    ex:textoExtracto "La función G170 indica que el eje trabaje como un eje rotativo o lineal normal."@es ;
    ex:identificador "G170" .

ex:ModoOperacion_G171
    a               ex:ModoOperacion ;
    rdfs:label      "Función G171"@es ;
    ex:textoExtracto "La función G171 indica que el eje trabaje como eje Hirth (función por defecto)."@es ;
    ex:identificador "G171" .

ex:Sensor_MATCH_axis
    a               ex:Sensor ;
    rdfs:label      "Señal MATCH(axis)"@es ;
    ex:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien."@es ;
    ex:identificador "MATCH(axis)" ;
    ex:monitoreaParametro ex:Parametro_HIRTH .