@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ManiobraAparcarEje
    a ex:TareaMantenimiento ;
    rdfs:label "Maniobra para aparcar un eje o cabezal desde el CNC"@es ;
    ex:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC. 1 Cuando se ejecuta la sentencia de programación #PARK el CNC comprueba si se puede aparcar el eje requerido. En caso afirmativo, el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente. En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA). Además, el CNC envía al regulador el comando para aparcar el eje."@es ;
    ex:identificador "#PARK" .

ex:ManiobraDesaparcarEje
    a ex:TareaMantenimiento ;
    rdfs:label "Maniobra para desaparcar un eje o cabezal desde el CNC"@es ;
    ex:textoExtracto "Maniobra para desaparcar un eje o cabezal desde el CNC. 4 Cuando se ejecuta la sentencia de programación #UNPARK el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente. En el caso de ejes digitales el CNC envía al regulador el comando para desaparcar el eje."@es ;
    ex:identificador "#UNPARK" .

ex:SenalPARK
    a ex:Parametro ;
    rdfs:label "Señal PARK"@es ;
    ex:textoExtracto "el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente"@es ;
    ex:valor "1" .

ex:SenalPARKED
    a ex:Parametro ;
    rdfs:label "Señal PARKED"@es ;
    ex:textoExtracto "el PLC pone la marca PARKED a (=1) [...] el CNC reconocerá que se ha aparcado el eje al detectar que se ha activado la señal PARKED"@es ;
    ex:valor "1" .

ex:SenalUNPARK
    a ex:Parametro ;
    rdfs:label "Señal UNPARK"@es ;
    ex:textoExtracto "el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente"@es ;
    ex:valor "1" .

ex:SenalREFPOIN
    a ex:Parametro ;
    rdfs:label "Señal REFPOIN"@es ;
    ex:textoExtracto "Se resetean las señales PARK y REFPOIN dando por finalizado el proceso [...] Se resetean las señales UNPARK y REFPOIN"@es .

ex:SensorPresenciaEje
    a ex:Sensor ;
    rdfs:label "Sensor de presencia de eje"@es ;
    ex:textoExtracto "Tras comprobar que el eje se ha aparcado (sensores de presencia) el PLC pone la marca PARKED a (=1) [...] Tras comprobar que el eje se ha desaparcado (sensores de presencia) el PLC pone la marca PARKED a (=0)"@es ;
    ex:monitoreaParametro ex:SenalPARKED .

ex:ReguladorEjeDigital
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador de eje digital"@es ;
    ex:textoExtracto "En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA) [...] En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)"@es ;
    ex:identificador "DRENA" .

ex:SistemaControlAparcado
    a ex:Sistema ;
    rdfs:label "Sistema de control de aparcado/desaparcado de ejes"@es ;
    ex:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC [...] Maniobra para desaparcar un eje o cabezal desde el CNC"@es ;
    ex:tieneComponente ex:SensorPresenciaEje , ex:ReguladorEjeDigital ;
    ex:compuestoPor ex:ManiobraAparcarEje , ex:ManiobraDesaparcarEje .

ex:ManiobraAparcarEje
    ex:requiereMantenimiento ex:SistemaControlAparcado ;
    ex:controla ex:SenalPARK , ex:SenalPARKED .

ex:ManiobraDesaparcarEje
    ex:requiereMantenimiento ex:SistemaControlAparcado ;
    ex:controla ex:SenalUNPARK , ex:SenalPARKED .