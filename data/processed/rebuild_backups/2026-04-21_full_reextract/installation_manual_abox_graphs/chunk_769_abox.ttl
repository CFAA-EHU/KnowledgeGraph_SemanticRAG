@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SensorPresenciaEjeB
    a ex:Sensor ;
    rdfs:label "Sensor de presencia del eje B" ;
    ex:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje \"B\" PARKB AND NOT I15 = SET PARKEDB" ;
    ex:identificador "I15" ;
    ex:monitoreaParametro ex:Se_alPARKEDB .

ex:Se_alPARKEDB
    a ex:Parametro ;
    rdfs:label "Señal PARKEDB" ;
    ex:textoExtracto "SET PARKEDB [...] RES PARKEDB" ;
    ex:valor "PARKEDB" .

ex:Se_alPARKB
    a ex:Parametro ;
    rdfs:label "Señal PARKB" ;
    ex:textoExtracto "petición para aparcar el eje \"B\" (PARKB)" ;
    ex:valor "PARKB" .

ex:Se_alUNPARKB
    a ex:Parametro ;
    rdfs:label "Señal UNPARKB" ;
    ex:textoExtracto "petición para desaparcar el eje \"B\" (UNPARKB)" ;
    ex:valor "UNPARKB" .

ex:Se_alDRENAB
    a ex:Parametro ;
    rdfs:label "Señal DRENAB" ;
    ex:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB =" ;
    ex:valor "DRENAB" .

ex:SistemaControlEjeB
    a ex:Sistema ;
    rdfs:label "Sistema de control del eje B" ;
    ex:textoExtracto "El CNC reconocerá que se ha completado el proceso al detectar que se ha desactivado la señal PARKED. Se resetean las señales UNPARK y REFPOIN. En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)." ;
    ex:tieneComponente ex:SensorPresenciaEjeB ;
    ex:controla ex:Se_alPARKEDB ;
    ex:controla ex:Se_alDRENAB .