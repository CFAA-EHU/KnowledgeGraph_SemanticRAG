@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_alCNC_ActivoEje
    a ex:ComponenteElectrico ;
    rdfs:label "Señal de eje activo (CNC)" ;
    ex:textoExtracto "se encuentra activo en el eje. El CNC pone esta marca a (=0) cuando se suspende (congela) o anula el control tangencial del eje." .

ex:Se_alCNC_LOPEN
    a ex:ComponenteElectrico ;
    rdfs:label "LOPEN(axis)" ;
    ex:identificador "LOPEN(axis)" ;
    ex:textoExtracto "El CNC activa esta marca para indicar al PLC que el lazo de posición del eje está abierto." .

ex:Se_alCNC_MAXDIFF
    a ex:ComponenteElectrico ;
    rdfs:label "MAXDIFF(axis)" ;
    ex:identificador "MAXDIFF(axis)" ;
    ex:textoExtracto "Esta marca se utiliza en los ejes gantry. El CNC activa (=1) esta marca cuando no puede corregir la diferencia de cota entre el eje maestro y esclavo, ya que la diferencia es superior a la indicada por el parámetro MAXDIFF(axis)." .

ex:Parametro_MAXDIFF
    a ex:Parametro ;
    rdfs:label "Parámetro MAXDIFF(axis)" ;
    ex:identificador "MAXDIFF(axis)" ;
    ex:textoExtracto "parámetro MAXDIFF(axis)" ;
    ex:monitoreaParametro ex:Se_alCNC_MAXDIFF .