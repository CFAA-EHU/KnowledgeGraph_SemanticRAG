@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DSYNCPOSW
    a ex:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ex:textoExtracto "valor por defecto se define en el parámetro máquina DSYNCPOSW" ;
    ex:valor "máximo error en posición permitido" .

ex:Funcion_M41 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "M41" ;
    ex:textoExtracto "deberá estar activa la función M41 en el CNC" .

ex:Marca_GEAR1
    a ex:InterfazUsuario ;
    rdfs:label "GEAR1" ;
    ex:textoExtracto "la marca GEAR1" .

ex:Marca_GEAROK1
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK1" ;
    ex:identificador "GEAROK1" ;
    ex:textoExtracto "GEAROK1 (también se puede programar como GEAROK)" .

ex:Marca_GEAROK2
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK2" ;
    ex:identificador "GEAROK2" ;
    ex:textoExtracto "GEAROK2" .

ex:Marca_GEAROK3
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK3" ;
    ex:identificador "GEAROK3" ;
    ex:textoExtracto "GEAROK3" .

ex:Marca_GEAROK4
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK4" ;
    ex:identificador "GEAROK4" ;
    ex:textoExtracto "GEAROK4" .

ex:Marca_GEAROK5
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK5" ;
    ex:identificador "GEAROK5" ;
    ex:textoExtracto "GEAROK5" .

ex:Marca_GEAROK6
    a ex:InterfazUsuario ;
    rdfs:label "GEAROK6" ;
    ex:identificador "GEAROK6" ;
    ex:textoExtracto "GEAROK6" .

ex:Sistema_Cabezales
    a ex:Sistema ;
    rdfs:label "Sistema de cabezales" ;
    ex:textoExtracto "Hay una marca para cada cabezal" ;
    ex:tieneComponente ex:Marca_GEAROK1, ex:Marca_GEAROK2, ex:Marca_GEAROK3, ex:Marca_GEAROK4, ex:Marca_GEAROK5, ex:Marca_GEAROK6 ;
    ex:monitoreaParametro ex:Parametro_DSYNCPOSW .

ex:Marca_GEAROK1
    ex:habilitadoPor ex:Funcion_M41 ;
    ex:habilitadoPor ex:Marca_GEAR1 .