@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterpoladorIndependiente_780
    a               ex:ComponenteElectrico ;
    rdfs:label      "Interpolador independiente"@es ;
    ex:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso."@es ;
    ex:identificador "Interpolador independiente"@es .

ex:MarcaLatcheo_780
    a               ex:Sensor ;
    rdfs:label      "Marca de latcheo"@es ;
    ex:textoExtracto "marca al activar un proceso de latcheo en el eje con el palpador indicado"@es ;
    ex:monitoreaParametro ex:ProcesoLatcheo_780 .

ex:ProcesoLatcheo_780
    a               ex:ModoOperacion ;
    rdfs:label      "Proceso de latcheo"@es ;
    ex:textoExtracto "proceso de latcheo en el eje con el palpador indicado"@es ;
    ex:controla    ex:MarcaLatcheo_780 .

ex:PLC_780
    a               ex:Actuador ;
    rdfs:label      "PLC"@es ;
    ex:textoExtracto "Si el PLC activa la"@es ;
    ex:identificador "PLC"@es .