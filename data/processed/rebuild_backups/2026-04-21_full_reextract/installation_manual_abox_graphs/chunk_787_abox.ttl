@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:NEXTPOS
    a ex:Parametro ;
    rdfs:label "NEXTPOS" ;
    ex:identificador "NEXTPOS" ;
    ex:textoExtracto "NEXTPOS [...] Este registro indica la posición de almacén que ocupa la siguiente herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), en un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ex:NEXTPOSMZ1
    a ex:Parametro ;
    rdfs:label "NEXTPOSMZ1" ;
    ex:identificador "NEXTPOSMZ1" ;
    ex:textoExtracto "NEXTPOSMZ1 (también se puede programar como NEXTPOS)" .

ex:NEXTPOSMZ2
    a ex:Parametro ;
    rdfs:label "NEXTPOSMZ2" ;
    ex:identificador "NEXTPOSMZ2" ;
    ex:textoExtracto "NEXTPOSMZ2" .

ex:NEXTPOSMZ3
    a ex:Parametro ;
    rdfs:label "NEXTPOSMZ3" ;
    ex:identificador "NEXTPOSMZ3" ;
    ex:textoExtracto "NEXTPOSMZ3" .

ex:NEXTPOSMZ4
    a ex:Parametro ;
    rdfs:label "NEXTPOSMZ4" ;
    ex:identificador "NEXTPOSMZ4" ;
    ex:textoExtracto "NEXTPOSMZ4" .

ex:TWORNOUT
    a ex:Parametro ;
    rdfs:label "TWORNOUT" ;
    ex:identificador "TWORNOUT" ;
    ex:textoExtracto "TWORNOUT" .