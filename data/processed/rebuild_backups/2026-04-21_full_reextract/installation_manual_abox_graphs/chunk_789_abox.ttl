@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_Keybd1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD1" ;
    ex:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado. [...] Registros KEYBD1 / KEYBD1_1 a KEYBD1_8. Teclas de usuario. Registros KEYBD1 / KEYBD1_1 a KEYBD1_8. Teclas de jog." ;
    ex:identificador "KEYBD1" .

ex:InterfazUsuario_Keybd2 a ex:InterfazUsuario ;
    rdfs:label "KEYBD2" ;
    ex:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado. [...] Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector de movimiento (volante, jog incremental o jog continuo)." ;
    ex:identificador "KEYBD2" .

ex:InterfazUsuario_Keybd3 a ex:InterfazUsuario ;
    rdfs:label "KEYBD3" ;
    ex:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado." ;
    ex:identificador "KEYBD3" .

ex:InterfazUsuario_Keybd1_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD1_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 [...] Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD1_1" .

ex:InterfazUsuario_Keybd2_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD2_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 [...] Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD2_1" .

ex:InterfazUsuario_Keybd3_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD3_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 [...] Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD3_1" .

ex:Tabla_Keybd2_Bits a ex:Tabla ;
    rdfs:label "Tabla de bits KEYBD2" ;
    ex:textoExtracto "| Bit. | Tecla. | --- | --- | 0 | Spindle override + | 1 | Spindle clockwise | 2 | Spindle positioning | 3 | Spindle stop | 4 | Spindle override - | 5 | Spindle counterclockwise | 6 | START | 7 | STOP | 8 | Generic Key 1 | 9 | Generic Key 2 |" ;
    ex:documentadoEn ex:InterfazUsuario_Keybd2 .

ex:Parametro_SpindleOverridePlus a ex:Parametro ;
    rdfs:label "Spindle override +" ;
    ex:textoExtracto "Bit 0: Spindle override +" ;
    ex:valor "0" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_SpindleClockwise a ex:Parametro ;
    rdfs:label "Spindle clockwise" ;
    ex:textoExtracto "Bit 1: Spindle clockwise" ;
    ex:valor "1" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_SpindlePositioning a ex:Parametro ;
    rdfs:label "Spindle positioning" ;
    ex:textoExtracto "Bit 2: Spindle positioning" ;
    ex:valor "2" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_SpindleStop a ex:Parametro ;
    rdfs:label "Spindle stop" ;
    ex:textoExtracto "Bit 3: Spindle stop" ;
    ex:valor "3" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_SpindleOverrideMinus a ex:Parametro ;
    rdfs:label "Spindle override -" ;
    ex:textoExtracto "Bit 4: Spindle override -" ;
    ex:valor "4" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_SpindleCounterclockwise a ex:Parametro ;
    rdfs:label "Spindle counterclockwise" ;
    ex:textoExtracto "Bit 5: Spindle counterclockwise" ;
    ex:valor "5" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_Start a ex:Parametro ;
    rdfs:label "START" ;
    ex:textoExtracto "Bit 6: START" ;
    ex:valor "6" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_Stop a ex:Parametro ;
    rdfs:label "STOP" ;
    ex:textoExtracto "Bit 7: STOP" ;
    ex:valor "7" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_GenericKey1 a ex:Parametro ;
    rdfs:label "Generic Key 1" ;
    ex:textoExtracto "Bit 8: Generic Key 1" ;
    ex:valor "8" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .

ex:Parametro_GenericKey2 a ex:Parametro ;
    rdfs:label "Generic Key 2" ;
    ex:textoExtracto "Bit 9: Generic Key 2" ;
    ex:valor "9" ;
    ex:ilustradoEn ex:Tabla_Keybd2_Bits .