@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:se_al_STOP
    a ex:InterfazUsuario ;
    rdfs:label "Señal _STOP" ;
    ex:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

ex:tecla_STOP_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Tecla [STOP] del CNC" ;
    ex:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC." .

ex:marca_XFERINH
    a ex:Parametro ;
    rdfs:label "Marca _XFERINH" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes: _XFERINH (también se puede programar como _XFERINHC1)." ;
    ex:identificador "_XFERINH" .

ex:marca_XFERINHC1
    a ex:Parametro ;
    rdfs:label "Marca _XFERINHC1" ;
    ex:textoExtracto "_XFERINHC1 (también se puede programar como _XFERINH)." ;
    ex:identificador "_XFERINHC1" .

ex:marca_XFERINHC2
    a ex:Parametro ;
    rdfs:label "Marca _XFERINHC2" ;
    ex:textoExtracto "_XFERINHC2" ;
    ex:identificador "_XFERINHC2" .

ex:marca_XFERINHC3
    a ex:Parametro ;
    rdfs:label "Marca _XFERINHC3" ;
    ex:textoExtracto "_XFERINHC3" ;
    ex:identificador "_XFERINHC3" .

ex:marca_XFERINHC4
    a ex:Parametro ;
    rdfs:label "Marca _XFERINHC4" ;
    ex:textoExtracto "_XFERINHC4" ;
    ex:identificador "_XFERINHC4" .

ex:parametro_XFITOIND
    a ex:Parametro ;
    rdfs:label "Parámetro XFITOIND" ;
    ex:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND." ;
    ex:identificador "XFITOIND" .

ex:canal_CNC_1
    a ex:Componente ;
    rdfs:label "Canal 1 del CNC" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes: _XFERINHC1." ;
    ex:controla ex:marca_XFERINHC1 .

ex:canal_CNC_2
    a ex:Componente ;
    rdfs:label "Canal 2 del CNC" ;
    ex:textoExtracto "_XFERINHC2" ;
    ex:controla ex:marca_XFERINHC2 .

ex:canal_CNC_3
    a ex:Componente ;
    rdfs:label "Canal 3 del CNC" ;
    ex:textoExtracto "_XFERINHC3" ;
    ex:controla ex:marca_XFERINHC3 .

ex:canal_CNC_4
    a ex:Componente ;
    rdfs:label "Canal 4 del CNC" ;
    ex:textoExtracto "_XFERINHC4" ;
    ex:controla ex:marca_XFERINHC4 .

ex:movimiento_jog
    a ex:ModoOperacion ;
    rdfs:label "Movimiento en jog" ;
    ex:textoExtracto "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto." .

ex:movimiento_eje_independiente
    a ex:ModoOperacion ;
    rdfs:label "Movimiento de eje independiente" ;
    ex:textoExtracto "Esta marca siempre afecta a los movimientos de eje independiente programados desde el CNC; los programados desde el PLC dependen del parámetro XFITOIND." .