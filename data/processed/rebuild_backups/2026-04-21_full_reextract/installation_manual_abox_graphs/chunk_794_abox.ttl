@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_XFITOIND a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración XFITOIND"@es ;
    ex:textoExtracto """
| XFITOIND | Significado. |
| --- | --- |
| Sí | La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC. |
| No | La marca _XFERINH no afecta a los movimientos de eje independiente programados desde el PLC; sí afecta a los programados desde el CNC. """@es ;
    ex:identificador "XFITOIND" .

ex:Parametro_XFERINH
    a ex:Parametro ;
    rdfs:label "Parámetro _XFERINH"@es ;
    ex:textoExtracto "La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC."@es ;
    ex:identificador "_XFERINH" ;
    ex:documentadoEn ex:Tabla_XFITOIND .

ex:Sistema_ControlMovimiento
    a ex:Sistema ;
    rdfs:label "Sistema de control de movimientos de eje independiente"@es ;
    ex:textoExtracto "movimientos de eje independiente programados desde el PLC y CNC"@es ;
    ex:monitoreaParametro ex:Parametro_XFERINH .

ex:InterfazUsuario_PLC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz PLC"@es ;
    ex:textoExtracto "movimientos de eje independiente programados desde el PLC"@es ;
    ex:controla ex:Sistema_ControlMovimiento .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz CNC"@es ;
    ex:textoExtracto "movimientos de eje independiente programados desde el CNC"@es ;
    ex:controla ex:Sistema_ControlMovimiento .