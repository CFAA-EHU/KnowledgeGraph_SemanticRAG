@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLCREADY
    a ex:Parametro ;
    rdfs:label "PLCREADY" ;
    ex:textoExtracto "Esta marca indica si el PLC está en marcha (=1) o parado (=0). Debe estar a (=1) para que el CNC permita el avance de los ejes y el giro del cabezal. Si se le asigna el (=0) se detiene la ejecución del programa del PLC y muestra un error." ;
    ex:valor "0,1" .

ex:NOWAITC1
    a ex:Parametro ;
    rdfs:label "NOWAITC1" ;
    ex:textoExtracto "Hay una marca para cada canal. Se aplica a la sincronización de canales. El PLC pone esta marca a (=1) para anular todas las sincronizaciones con el canal del CNC." ;
    ex:valor "0,1" .

ex:NOWAITC2
    a ex:Parametro ;
    rdfs:label "NOWAITC2" ;
    ex:textoExtracto "Hay una marca para cada canal. Se aplica a la sincronización de canales." ;
    ex:valor "0,1" .

ex:NOWAITC3
    a ex:Parametro ;
    rdfs:label "NOWAITC3" ;
    ex:textoExtracto "Hay una marca para cada canal. Se aplica a la sincronización de canales." ;
    ex:valor "0,1" .

ex:NOWAITC4
    a ex:Parametro ;
    rdfs:label "NOWAITC4" ;
    ex:textoExtracto "Hay una marca para cada canal. Se aplica a la sincronización de canales." ;
    ex:valor "0,1" .

ex:DISCROSS1
    a ex:Parametro ;
    rdfs:label "DISCROSS1" ;
    ex:textoExtracto "Se aplica a las tablas de compensación cruzada definidas en los parámetros máquina. El PLC pone la marca a (=1) para deshabilitar la tabla 1." ;
    ex:valor "0,1" .

ex:DISCROSS17
    a ex:Parametro ;
    rdfs:label "DISCROSS17" ;
    ex:textoExtracto "Hay una marca para cada tabla. El PLC pone la marca a (=1) para deshabilitar la tabla." ;
    ex:valor "0,1" .

ex:EXRAPIDC1
    a ex:Parametro ;
    rdfs:label "EXRAPIDC1 (EXRAPID)" ;
    ex:textoExtracto "Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa, para los desplazamientos programados. El funcionamiento de esta señal depende de cómo esté definido el parámetro RAPIDEN." ;
    ex:valor "0,1" .

ex:EXRAPIDC2
    a ex:Parametro ;
    rdfs:label "EXRAPIDC2" ;
    ex:textoExtracto "Hay una marca para cada canal. Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa." ;
    ex:valor "0,1" .

ex:EXRAPIDC3
    a ex:Parametro ;
    rdfs:label "EXRAPIDC3" ;
    ex:textoExtracto "Hay una marca para cada canal. Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa." ;
    ex:valor "0,1" .

ex:EXRAPIDC4
    a ex:Parametro ;
    rdfs:label "EXRAPIDC4" ;
    ex:textoExtracto "Hay una marca para cada canal. Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa." ;
    ex:valor "0,1" .

ex:PLCABORT
    a ex:Parametro ;
    rdfs:label "PLCABORT" ;
    ex:textoExtracto "Hay una marca para cada canal." ;
    ex:valor "0,1" .

ex:ParametrosSincronizacionCNC
    a ex:Sistema ;
    rdfs:label "Parámetros de sincronización y control del CNC" ;
    ex:textoExtracto "Señales modificables generales para sincronización de canales, compensación cruzada y control de avance rápido en el CNC." ;
    ex:tieneComponente ex:PLCREADY ;
    ex:tieneComponente ex:NOWAITC1, ex:NOWAITC2, ex:NOWAITC3, ex:NOWAITC4 ;
    ex:tieneComponente ex:DISCROSS1, ex:DISCROSS17 ;
    ex:tieneComponente ex:EXRAPIDC1, ex:EXRAPIDC2, ex:EXRAPIDC3, ex:EXRAPIDC4 ;
    ex:tieneComponente ex:PLCABORT .