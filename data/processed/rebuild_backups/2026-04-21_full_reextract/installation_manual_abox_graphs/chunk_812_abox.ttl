@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionRetrace a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función RETRACE" ;
    ex:textoExtracto "La función retrace también finaliza tras ejecutar M30, con un reset y cuando el canal del CNC pone a (=1) la marca RETRAEND. La función retrace debe estar habilitada en el parámetro máquina RETRACAC." ;
    ex:identificador "RETRACE" .

ex:ParametroRetracac
    a ex:Parametro ;
    rdfs:label "Parámetro RETRACAC" ;
    ex:textoExtracto "La función retrace debe estar habilitada en el parámetro máquina RETRACAC." ;
    ex:identificador "RETRACAC" ;
    ex:monitoreaParametro ex:FuncionRetrace .

ex:MarcaRetraend
    a ex:ComponenteElectrico ;
    rdfs:label "Marca RETRAEND" ;
    ex:textoExtracto "La función retrace también finaliza [...] cuando el canal del CNC pone a (=1) la marca RETRAEND." ;
    ex:identificador "RETRAEND" ;
    ex:controla ex:FuncionRetrace .

ex:VolanteMPG1
    a ex:ComponenteMecanico ;
    rdfs:label "Primer volante (MPG1)" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. [...] la marca INHIBITMPG1 deshabilita el primer volante" ;
    ex:identificador "MPG1" .

ex:VolanteMPG2
    a ex:ComponenteMecanico ;
    rdfs:label "Segundo volante (MPG2)" ;
    ex:textoExtracto "la marca INHIBITMPG2 el segundo [volante] y así sucesivamente." ;
    ex:identificador "MPG2" .

ex:MarcaInhibitMPG1
    a ex:ComponenteElectrico ;
    rdfs:label "Marca INHIBITMPG1" ;
    ex:textoExtracto "la marca INHIBITMPG1 deshabilita el primer volante" ;
    ex:identificador "INHIBITMPG1" ;
    ex:controla ex:VolanteMPG1 .

ex:MarcaInhibitMPG2
    a ex:ComponenteElectrico ;
    rdfs:label "Marca INHIBITMPG2" ;
    ex:textoExtracto "la marca INHIBITMPG2 el segundo [volante]" ;
    ex:identificador "INHIBITMPG2" ;
    ex:controla ex:VolanteMPG2 .

ex:VariableGHandp
    a ex:Parametro ;
    rdfs:label "Variable (V.)G.HANDP[hw]" ;
    ex:textoExtracto "Número de impulsos enviados por el volante desde el arranque del sistema. [...] la variable asociada al volante no guarda los impulsos que envía el volante." ;
    ex:identificador "G.HANDP" ;
    ex:monitoreaParametro ex:VolanteMPG1 , ex:VolanteMPG2 .

ex:TecladoKEYBD1CH
    a ex:InterfazUsuario ;
    rdfs:label "Configuración teclado KEYBD1CH" ;
    ex:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales. [...] KEYBD1CH" ;
    ex:identificador "KEYBD1CH" .

ex:TecladoKEYBD8CH
    a ex:InterfazUsuario ;
    rdfs:label "Configuración teclado KEYBD8CH" ;
    ex:textoExtracto "Estos registros podrán asociar un panel de jog a un canal en concreto. [...] KEYBD8CH" ;
    ex:identificador "KEYBD8CH" .