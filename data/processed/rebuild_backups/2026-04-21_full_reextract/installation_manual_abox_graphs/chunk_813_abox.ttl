@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Se_alesModificablesGenerales
    a ex:Tabla ;
    rdfs:label "Tabla de señales modificables generales (KEYBD1CH-KEYBD8CH, VOLCOMP1-VOLCOMP4)" ;
    ex:textoExtracto """
| KEYBD1CH
ꞏꞏ
KEYBD8CH | Significado. |
| --- | --- |
| 0 | Configuración definida en los parámetros máquina. |
| 1 | Panel de jog asignado al canal 1. |
| 2 | Panel de jog asignado al canal 2. |
| 3 | Panel de jog asignado al canal 3. |
| 4 | Panel de jog asignado al canal 4. |
| FF | Panel de jog asignado al canal activo.
---
VOLCOMP1 VOLCOMP4 Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). Si el PLC desactiva una de estas marcas (cambio de 1 a 0), el CNC desactiva la compensación volumétrica correspondiente.""" .

ex:Parametro_KEYBD1CH
    a ex:Parametro ;
    rdfs:label "KEYBD1CH" ;
    ex:identificador "KEYBD1CH" ;
    ex:textoExtracto "KEYBD1CH [...] Significado: 0 = Configuración definida en los parámetros máquina, 1 = Panel de jog asignado al canal 1, ..., FF = Panel de jog asignado al canal activo." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:Parametro_KEYBD8CH
    a ex:Parametro ;
    rdfs:label "KEYBD8CH" ;
    ex:identificador "KEYBD8CH" ;
    ex:textoExtracto "KEYBD8CH [...] Significado: 0 = Configuración definida en los parámetros máquina, 4 = Panel de jog asignado al canal 4, FF = Panel de jog asignado al canal activo." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:Parametro_VOLCOMP1
    a ex:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ex:identificador "VOLCOMP1" ;
    ex:textoExtracto "VOLCOMP1 [...] Si el PLC activa esta marca (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:Parametro_VOLCOMP4
    a ex:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ex:identificador "VOLCOMP4" ;
    ex:textoExtracto "VOLCOMP4 [...] Si el PLC desactiva esta marca (cambio de 1 a 0), el CNC desactiva la compensación volumétrica correspondiente." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:Parametro_VOLCOMP
    a ex:Parametro ;
    rdfs:label "VOLCOMP (compensación volumétrica)" ;
    ex:textoExtracto "parámetro VOLCOMP [...] compensación volumétrica correspondiente." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:InterfazUsuario_PanelJog
    a ex:InterfazUsuario ;
    rdfs:label "Panel de jog" ;
    ex:textoExtracto "Panel de jog asignado al canal 1/2/3/4/activo (KEYBD1CH-KEYBD8CH: valores 1-4, FF)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .