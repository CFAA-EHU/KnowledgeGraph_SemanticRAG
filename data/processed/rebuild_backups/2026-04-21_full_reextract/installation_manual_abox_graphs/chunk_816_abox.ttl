@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FLIMITACCH
    a ex:Parametro ;
    rdfs:label "FLIMITACCH" ;
    ex:textoExtracto "FLIMITACCH Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. FLIMITACCHC1 (también se puede programar como FLIMITACCH) FLIMITACCHC2 FLIMITACCHC3 FLIMITACCHC4" ;
    ex:identificador "FLIMITACCH" .

ex:Parametro_FLIMITACCHC1
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC1" ;
    ex:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" ;
    ex:identificador "FLIMITACCHC1" .

ex:Parametro_FLIMITACCHC2
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC2" ;
    ex:textoExtracto "FLIMITACCHC2" ;
    ex:identificador "FLIMITACCHC2" .

ex:Parametro_FLIMITACCHC3
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC3" ;
    ex:textoExtracto "FLIMITACCHC3" ;
    ex:identificador "FLIMITACCHC3" .

ex:Parametro_FLIMITACCHC4
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC4" ;
    ex:textoExtracto "FLIMITACCHC4" ;
    ex:identificador "FLIMITACCHC4" .