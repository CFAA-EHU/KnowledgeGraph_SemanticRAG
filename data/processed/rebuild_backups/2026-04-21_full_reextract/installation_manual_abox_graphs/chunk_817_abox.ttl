@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FLIMITACCH
    a ex:Parametro ;
    rdfs:label "FLIMITACCH (Límite de seguridad para avance)" ;
    ex:textoExtracto "FLIMITACCH [...] Si el PLC activa esta marca, el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del canal, durante la ejecución del bloque." ;
    ex:identificador "FLIMITACCH" .

ex:FLIMITACCHC1
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC1 (Límite de seguridad para avance, canal 1)" ;
    ex:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" ;
    ex:identificador "FLIMITACCHC1" .

ex:FLIMITACCHC2
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC2 (Límite de seguridad para avance, canal 2)" ;
    ex:textoExtracto "FLIMITACCHC2" ;
    ex:identificador "FLIMITACCHC2" .

ex:FLIMITACCHC3
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC3 (Límite de seguridad para avance, canal 3)" ;
    ex:textoExtracto "FLIMITACCHC3" ;
    ex:identificador "FLIMITACCHC3" .

ex:FLIMITACCHC4
    a ex:Parametro ;
    rdfs:label "FLIMITACCHC4 (Límite de seguridad para avance, canal 4)" ;
    ex:textoExtracto "FLIMITACCHC4" ;
    ex:identificador "FLIMITACCHC4" .

ex:FLIMIT
    a ex:Parametro ;
    rdfs:label "FLIMIT (Parámetro de límite de avance)" ;
    ex:textoExtracto "parámetro FLIMIT" ;
    ex:identificador "FLIMIT" .

ex:SLIMITAC
    a ex:Parametro ;
    rdfs:label "SLIMITAC (Límite de seguridad para velocidad)" ;
    ex:textoExtracto "SLIMITAC [...] Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en todos los cabezales del sistema, durante la ejecución del bloque actual." ;
    ex:identificador "SLIMITAC" .

ex:SLIMIT
    a ex:Parametro ;
    rdfs:label "SLIMIT (Parámetro de límite de velocidad)" ;
    ex:textoExtracto "parámetro SLIMIT" ;
    ex:identificador "SLIMIT" .

ex:PT100OFF1
    a ex:Parametro ;
    rdfs:label "PT100OFF1 (Deshabilitación de sonda PT100, entrada 1)" ;
    ex:textoExtracto "PT100OFF1 [...] Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n). La marca PT100OFF1 corresponde a la sonda de la entrada 1" ;
    ex:identificador "PT100OFF1" .

ex:PT100OFF20
    a ex:Parametro ;
    rdfs:label "PT100OFF20 (Deshabilitación de sonda PT100, entrada 20)" ;
    ex:textoExtracto "PT100OFF20 [...] La marca PT100OFF2 a la sonda de la entrada 2 y así sucesivamente." ;
    ex:identificador "PT100OFF20" .

ex:PT100
    a ex:Sensor ;
    rdfs:label "PT100 (Sonda de temperatura)" ;
    ex:textoExtracto "Las entradas PT100 se activan desde los parámetro máquina. Si la entrada está activa en el parámetro máquina y no hay una sonda conectada, el CNC da el error correspondiente." .

ex:INT1
    a ex:Parametro ;
    rdfs:label "INT1 (Marca de interrupción, canal 1)" ;
    ex:textoExtracto "INT1 [...] Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de INT1" ;
    ex:identificador "INT1" .

ex:INT4
    a ex:Parametro ;
    rdfs:label "INT4 (Marca de interrupción, canal 4)" ;
    ex:textoExtracto "INT4 [...] para el resto de marcas es equivalente." ;
    ex:identificador "INT4" .

ex:PLC
    a ex:Actuador ;
    rdfs:label "PLC (Controlador lógico programable)" ;
    ex:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad [...] El PLC dispone de las siguientes marcas para poder deshabilitar la sonda temporalmente" .

ex:CNC
    a ex:Sistema ;
    rdfs:label "CNC (Sistema de control numérico)" ;
    ex:textoExtracto "el CNC activa los límites de seguridad para el avance [...] el CNC deshabilita la sonda correspondiente" .

ex:PLC ex:controla ex:FLIMITACCH .
ex:PLC ex:controla ex:SLIMITAC .
ex:PLC ex:controla ex:PT100OFF1 .
ex:PLC ex:controla ex:PT100OFF20 .
ex:PLC ex:controla ex:INT1 .
ex:PLC ex:controla ex:INT4 .

ex:CNC ex:monitoreaParametro ex:FLIMIT .
ex:CNC ex:monitoreaParametro ex:SLIMIT .
ex:CNC ex:monitoreaParametro ex:PT100 .