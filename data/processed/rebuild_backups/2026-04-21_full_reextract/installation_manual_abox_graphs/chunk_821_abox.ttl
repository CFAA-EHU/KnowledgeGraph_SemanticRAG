@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaMonitorizacionPalpadores
    a ex:Sistema ;
    rdfs:label "Sistema de monitorización de palpadores CNC" ;
    ex:textoExtracto "Monitorización a nivel de lazo, controlando todas las situaciones de colisión en cualquiera de los dos palpadores. El CNC puede monitorizar los palpadores conectados a las entradas locales y a las entradas remotas CAN. El CNC monitoriza las 2 entradas de palpador a la vez." ;
    ex:tieneComponente ex:EntradaLocal1, ex:EntradaLocal2, ex:EntradasRemotasCAN ;
    ex:activaAlarma ex:AlarmaCaptacionLocal1, ex:AlarmaCaptacionLocal2 ;
    ex:monitoreaParametro ex:ParametroFBACKAL .

ex:EntradaLocal1
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada de captación local 1 (LCOUNTALARMOFF1)" ;
    ex:identificador "LCOUNTALARMOFF1" ;
    ex:textoExtracto "Estas marcas están referidas a las entradas de captación local 1 (LCOUNTALARMOFF1) y 2 (LCOUNTALARMOFF2)." .

ex:EntradaLocal2
    a ex:ComponenteElectrico ;
    rdfs:label "Entrada de captación local 2 (LCOUNTALARMOFF2)" ;
    ex:identificador "LCOUNTALARMOFF2" ;
    ex:textoExtracto "Estas marcas están referidas a las entradas de captación local 1 (LCOUNTALARMOFF1) y 2 (LCOUNTALARMOFF2)." .

ex:EntradasRemotasCAN
    a ex:InterfazUsuario ;
    rdfs:label "Entradas remotas CAN para palpadores" ;
    ex:textoExtracto "El CNC puede monitorizar los palpadores conectados a las entradas locales y a las entradas remotas CAN." .

ex:AlarmaCaptacionLocal1
    a ex:Alarma ;
    rdfs:label "Alarma de captación de entrada local 1" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente. Si el PLC desactiva una de estas marcas (cambio de 1 a 0), habilita las alarmas de captación." .

ex:AlarmaCaptacionLocal2
    a ex:Alarma ;
    rdfs:label "Alarma de captación de entrada local 2" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente. Si el PLC desactiva una de estas marcas (cambio de 1 a 0), habilita las alarmas de captación." .

ex:ParametroFBACKAL
    a ex:Parametro ;
    rdfs:label "Parámetro FBACKAL" ;
    ex:identificador "FBACKAL" ;
    ex:textoExtracto "El report de alarma está condicionado al parámetro FBACKAL." ;
    ex:textoExtracto "No se detecta alarma en caso de configurar el contaje local como TTL no diferencial." .

ex:RegistroRKIN1
    a ex:ComponenteElectrico ;
    rdfs:label "Registro RKIN1 para comunicación PLC-cinemáticas" ;
    ex:identificador "RKIN1" ;
    ex:textoExtracto "RKIN1 [...] Estos registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ex:RegistroRKIN32
    a ex:ComponenteElectrico ;
    rdfs:label "Registro RKIN32 para comunicación PLC-cinemáticas" ;
    ex:identificador "RKIN32" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ex:MarcaCOLLISIONOFF
    a ex:ComponenteElectrico ;
    rdfs:label "Marca COLLISIONOFF para deshabilitar detección de colisión" ;
    ex:identificador "COLLISIONOFF" ;
    ex:textoExtracto "COLLISIONOFF [...] Hay una marca para cada canal." .