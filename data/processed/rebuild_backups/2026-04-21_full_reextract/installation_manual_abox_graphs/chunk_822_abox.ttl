@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_RKIN1
    a ex:Parametro ;
    rdfs:label "RKIN1" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." ;
    ex:monitoreaParametro ex:Sistema_ComunicacionPLC .

ex:Parametro_RKIN32
    a ex:Parametro ;
    rdfs:label "RKIN32" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." ;
    ex:monitoreaParametro ex:Sistema_ComunicacionPLC .

ex:Parametro_COLLISIONOFFC1
    a ex:Parametro ;
    rdfs:label "COLLISIONOFFC1" ;
    ex:identificador "COLLISIONOFFC1" ;
    ex:textoExtracto "COLLISIONOFFC1 (también se puede programar como COLLISIONOFF)" ;
    ex:controla ex:Sistema_FCAS .

ex:Parametro_COLLISIONOFFC2
    a ex:Parametro ;
    rdfs:label "COLLISIONOFFC2" ;
    ex:identificador "COLLISIONOFFC2" ;
    ex:textoExtracto "COLLISIONOFFC2" ;
    ex:controla ex:Sistema_FCAS .

ex:Parametro_COLLISIONOFFC3
    a ex:Parametro ;
    rdfs:label "COLLISIONOFFC3" ;
    ex:identificador "COLLISIONOFFC3" ;
    ex:textoExtracto "COLLISIONOFFC3" ;
    ex:controla ex:Sistema_FCAS .

ex:Parametro_COLLISIONOFFC4
    a ex:Parametro ;
    rdfs:label "COLLISIONOFFC4" ;
    ex:identificador "COLLISIONOFFC4" ;
    ex:textoExtracto "COLLISIONOFFC4" ;
    ex:controla ex:Sistema_FCAS .

ex:Parametro_VIRTUALJOGENA
    a ex:Parametro ;
    rdfs:label "VIRTUALJOGENA" ;
    ex:identificador "VIRTUALJOGENA" ;
    ex:textoExtracto "VIRTUALJOGENA El PLC utiliza esta marca para habilitar" ;
    ex:habilitadoPor ex:Actuador_PLC .

ex:Sistema_ComunicacionPLC
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación PLC-cinemáticas" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." ;
    ex:tieneComponente ex:Actuador_PLC .

ex:Sistema_FCAS
    a ex:Sistema ;
    rdfs:label "FCAS (control de colisiones)" ;
    ex:textoExtracto "Si el PLC activa esta marca (cambio de 0 a 1), desactiva la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." ;
    ex:controla ex:AvisoSeguridad_ControlColisiones .

ex:Actuador_PLC
    a ex:Actuador ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC utiliza esta marca para habilitar" ;
    ex:controla ex:Sistema_FCAS .

ex:AvisoSeguridad_ControlColisiones
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de control de colisiones" ;
    ex:textoExtracto "Si el PLC activa esta marca (cambio de 0 a 1), desactiva la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .