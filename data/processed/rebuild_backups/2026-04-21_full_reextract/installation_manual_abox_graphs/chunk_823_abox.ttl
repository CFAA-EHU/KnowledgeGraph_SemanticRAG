@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FCAS
    a ex:Parametro ;
    rdfs:label "FCAS (control de colisiones)" ;
    ex:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." ;
    ex:monitoreaParametro ex:SistemaControlColisiones .

ex:SistemaControlColisiones
    a ex:Sistema ;
    rdfs:label "Sistema de control de colisiones" ;
    ex:textoExtracto "la opción FCAS (control de colisiones)." .

ex:VIRTUALJOGENA
    a ex:Parametro ;
    rdfs:label "VIRTUALJOGENA" ;
    ex:textoExtracto "El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." ;
    ex:habilitadoPor ex:TecladoVirtualJog .

ex:TecladoVirtualJog
    a ex:InterfazUsuario ;
    rdfs:label "Teclado virtual de jog" ;
    ex:textoExtracto "teclado virtual de jog (teclado en pantalla)." .

ex:DMCONC1
    a ex:Parametro ;
    rdfs:label "DMCONC1" ;
    ex:identificador "DMCONC1" ;
    ex:textoExtracto "DMCONC1 (también se puede programar como DMCON). Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." ;
    ex:controla ex:DMC .

ex:DMCONC2
    a ex:Parametro ;
    rdfs:label "DMCONC2" ;
    ex:identificador "DMCONC2" ;
    ex:textoExtracto "DMCONC2. Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." ;
    ex:controla ex:DMC .

ex:DMCONC3
    a ex:Parametro ;
    rdfs:label "DMCONC3" ;
    ex:identificador "DMCONC3" ;
    ex:textoExtracto "DMCONC3. Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." ;
    ex:controla ex:DMC .

ex:DMCONC4
    a ex:Parametro ;
    rdfs:label "DMCONC4" ;
    ex:identificador "DMCONC4" ;
    ex:textoExtracto "DMCONC4. Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." ;
    ex:controla ex:DMC .

ex:DMC
    a ex:Sistema ;
    rdfs:label "DMC (Dynamic Motion Control)" ;
    ex:textoExtracto "el CNC desactiva el DMC. [...] el CNC reactiva el DMC." .