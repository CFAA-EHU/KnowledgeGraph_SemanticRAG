@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_alDetencionSincronizacion
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Señal de detención de sincronización" ;
    ex:textoExtracto      "si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula. El sistema permanece en espera hasta que se desactive la señal para reanudar la ejecución y el movimiento desde el punto en el que se detuvo."@es ;
    ex:monitoreaParametro ex:EstadoSincronizacionEjes .

ex:EstadoSincronizacionEjes
    a                     ex:Parametro ;
    rdfs:label            "Estado de sincronización de ejes" ;
    ex:textoExtracto      "se detiene el movimiento de sincronización, pasando a velocidad nula. [...] Para los ejes independientes, esta señal también detiene el testeo de la sincronización."@es .

ex:IndicadorSrealCabezales
    a                     ex:InterfazUsuario ;
    rdfs:label            "Indicador 'Sreal' en cabezales" ;
    ex:textoExtracto      "Para los cabezales, el texto 'Sreal' aparece en color rojo cuando esta marca está activa para el cabezal. Si en la pantalla no se dispone de este texto, no se muestra el estado de esta marca."@es ;
    ex:ilustradoEn         ex:PantallaModoAutomatico, ex:PantallaModoManual .

ex:IndicadorEjeActivo
    a                     ex:InterfazUsuario ;
    rdfs:label            "Indicador de eje activo (color rojo)" ;
    ex:textoExtracto      "Para los ejes, el nombre del eje que antecede a la cota aparece en color rojo cuando esta marca está activa para el eje."@es ;
    ex:ilustradoEn         ex:PantallaModoAutomatico, ex:PantallaModoManual .

ex:PantallaModoAutomatico
    a                     ex:InterfazUsuario ;
    rdfs:label            "Pantalla de modo automático" ;
    ex:textoExtracto      "En las pantallas de los modos automático y manual muestra el estado de esta marca."@es .

ex:PantallaModoManual
    a                     ex:InterfazUsuario ;
    rdfs:label            "Pantalla de modo manual" ;
    ex:textoExtracto      "En las pantallas de los modos automático y manual muestra el estado de esta marca."@es .

ex:Se_alAXISPOS
    a                     ex:ComponenteElectrico ;
    rdfs:label            "AXISPOS(axis)" ;
    ex:identificador       "AXISPOS" ;
    ex:textoExtracto      "AXISPOS(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, positivo (POS)."@es ;
    ex:controla           ex:MovimientoEjePositivo .

ex:Se_alAXISNEG
    a                     ex:ComponenteElectrico ;
    rdfs:label            "AXISNEG(axis)" ;
    ex:identificador       "AXISNEG" ;
    ex:textoExtracto      "AXISNEG(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, negativo (NEG)."@es ;
    ex:controla           ex:MovimientoEjeNegativo .

ex:MovimientoEjePositivo
    a                     ex:ModoOperacion ;
    rdfs:label            "Desplazamiento de eje en sentido positivo" ;
    ex:textoExtracto      "el CNC desplazará el eje correspondiente en el sentido indicado, positivo (POS) [...] aplicando al avance correspondiente el override (%) que se encuentra seleccionado."@es .

ex:MovimientoEjeNegativo
    a                     ex:ModoOperacion ;
    rdfs:label            "Desplazamiento de eje en sentido negativo" ;
    ex:textoExtracto      "el CNC desplazará el eje correspondiente en el sentido indicado, negativo (NEG) [...] aplicando al avance correspondiente el override (%) que se encuentra seleccionado."@es .

ex:Se_alSERVOON
    a                     ex:ComponenteElectrico ;
    rdfs:label            "SERVO(axis)ON" ;
    ex:identificador       "SERVOON" ;
    ex:textoExtracto      "Esta marca debe estar a (=1) para permitir el movimiento (desbloqueo) del eje correspondiente. Si durante el desplazamiento del eje o cabezal se pone la marca SERVO(axis)ON a (=0) el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente."@es ;
    ex:habilitadoPor      ex:CondicionServoON .

ex:CondicionServoON
    a                     ex:Parametro ;
    rdfs:label            "Condición para SERVOON" ;
    ex:textoExtracto      "Para disponer de control continuo del eje, la marca SERVOON debe estar siempre a (no hay errores) AND (regulador eje OK) = SERVOnON"@es .

ex:Se_alENABLE
    a                     ex:ComponenteElectrico ;
    rdfs:label            "ENABLE(axis)" ;
    ex:identificador       "ENABLE" ;
    ex:textoExtracto      "Para controlar el eje sólo en los desplazamientos, se debe utilizar la marca ENABLE. [...] El CNC la pone a (=1) cada vez que quiere mover el eje."@es .