@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_alENABLE_Eje
    a ex:ComponenteElectrico ;
    rdfs:label "Señal ENABLE(axis)" ;
    ex:identificador "ENABLE(axis)" ;
    ex:textoExtracto "el CNC la pone a (=1) cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418." .

ex:SistemaControlCNC
    a ex:Sistema ;
    rdfs:label "Sistema de control CNC" ;
    ex:textoExtracto "el CNC la pone a (=1) cada vez que quiere mover el eje" ;
    ex:controla ex:Se_alENABLE_Eje .

ex:CondicionServoON
    a ex:Parametro ;
    rdfs:label "Condición SERVOON" ;
    ex:identificador "SERVOON" ;
    ex:valor "ENABLE = SERVOON" ;
    ex:textoExtracto "AND ENABLE = SERVOON" ;
    ex:monitoreaParametro ex:Se_alENABLE_Eje .