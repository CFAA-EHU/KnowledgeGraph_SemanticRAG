@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CondicionMovimientoEje
    a ex:ModoOperacion ;
    rdfs:label "Condición de movimiento de eje (ENABLE=SERVOON)"@es ;
    ex:textoExtracto "cada vez que quiere mover el eje. [...] AND (regulador OK) AND ENABLE = SERVOON"@es ;
    ex:identificador "ENABLE(axis)" .

ex:ErrorSeguimientoEje
    a ex:AvisoSeguridad ;
    rdfs:label "Error de seguimiento por movimiento de eje bloqueado"@es ;
    ex:textoExtracto "Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de seguimiento."@es .

ex:SistemaControlCNC_828
    a ex:Sistema ;
    rdfs:label "Sistema de control CNC (gestión de servos y errores)"@es ;
    ex:textoExtracto "Al volver a controlarlo (SERVOON=1) vuelve a posición. ERROR"@es ;
    ex:activaAlarma ex:ErrorSeguimientoEje ;
    ex:controla ex:CondicionMovimientoEje .