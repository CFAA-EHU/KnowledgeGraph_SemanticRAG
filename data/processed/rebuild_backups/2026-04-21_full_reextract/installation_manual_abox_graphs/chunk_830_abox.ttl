@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_ControlEjes
    a                     ex:Actuador ;
    rdfs:label            "PLC de control de ejes" ;
    ex:textoExtracto      "Si el PLC desactiva esta marca, el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado." .

ex:ZonaProhibidaEje
    a                     ex:AccionProhibida ;
    rdfs:label            "Zona prohibida del eje" ;
    ex:textoExtracto      "en caso de que ésta haya superado los límites de software o haya invadido una zona prohibida." .

ex:LimiteSoftwareEje
    a                     ex:Parametro ;
    rdfs:label            "Límite de software del eje" ;
    ex:textoExtracto      "los límites de software y las zonas de trabajo en el eje indicado" ;
    ex:monitoreaParametro ex:PLC_ControlEjes .

ex:ParametroG198
    a                     ex:Parametro ;
    rdfs:label            "Parámetro G198" ;
    ex:identificador       "G198" ;
    ex:textoExtracto      "Los límites de software se pueden fijar mediante [...] las funciones G198/G199" .

ex:ParametroG199
    a                     ex:Parametro ;
    rdfs:label            "Parámetro G199" ;
    ex:identificador       "G199" ;
    ex:textoExtracto      "Los límites de software se pueden fijar mediante [...] las funciones G198/G199" .

ex:CNC_SistemaControl
    a                     ex:Sistema ;
    rdfs:label            "CNC (Sistema de control numérico)" ;
    ex:textoExtracto      "el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado. El CNC aplica siempre los límites de recorrido" ;
    ex:controla           ex:LimiteSoftwareEje ;
    ex:mitigaRiesgo       ex:ZonaProhibidaEje .