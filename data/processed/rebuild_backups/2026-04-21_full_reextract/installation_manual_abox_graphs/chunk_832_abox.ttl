@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_LUBRENA
    a               ex:Parametro ;
    rdfs:label      "LUBRENA(axis)" ;
    ex:textoExtracto "La marca LUBRENA indica si se desea esta prestación (=1), o no (=0). Con LUBRENA a (=1) el CNC actúa del" ;
    ex:identificador "LUBRENA" .

ex:Senal_LUBROK
    a               ex:Parametro ;
    rdfs:label      "LUBROK(axis)" ;
    ex:textoExtracto "LUBRENA(axis) LUBROK(axis) Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." ;
    ex:identificador "LUBROK" .

ex:Senal_LUBR
    a               ex:Parametro ;
    rdfs:label      "LUBR(axis)" ;
    ex:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." ;
    ex:identificador "LUBR" .

ex:Tarea_EngraseEjes
    a               ex:TareaMantenimiento ;
    rdfs:label      "Engrase de ejes" ;
    ex:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." ;
    ex:requiereMantenimiento ex:Senal_LUBR, ex:Senal_LUBRENA, ex:Senal_LUBROK .

ex:Pagina_420
    a               ex:Pagina ;
    rdfs:label      "Página 420 (Señales PARK/UNPARK y engrase)" ;
    ex:textoExtracto "Ver en la página 'PARK(axis) UNPARK(axis)' 420. LUBRENA(axis) LUBROK(axis) Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el en la página 420." ;
    ex:identificador "420" ;
    ex:documentadoEn ex:Manual_TornoCNC .