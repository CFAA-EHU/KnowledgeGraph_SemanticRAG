@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_MFUN1
    a ex:Parametro ;
    rdfs:label "MFUN1" ;
    ex:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42" ;
    ex:valor "42" .

ex:Senal_MSTROBE
    a ex:Parametro ;
    rdfs:label "MSTROBE" ;
    ex:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42 y pone la marca MSTROBE" .

ex:Senal_M1002
    a ex:Parametro ;
    rdfs:label "M1002" ;
    ex:textoExtracto "DFU MSTROBE AND CPS MFUN* EQ 42 = SET M1002" .

ex:Senal_AUXEND
    a ex:Parametro ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "Comienza el cambio y se lo indica al CNC con AUXEND a (=0). [...] Una vez que ha finalizado el cambio de gama quita el indicativo (M1002) y se lo indica al CNC con AUXEND a (=1)." ;
    ex:valor "0" , "1" .

ex:Senal_GEAR1
    a ex:Parametro ;
    rdfs:label "GEAR1" ;
    ex:textoExtracto "I21 = GEAR1" .

ex:Senal_GEAR2
    a ex:Parametro ;
    rdfs:label "GEAR2" ;
    ex:textoExtracto "I22 = GEAR2" .

ex:Parametro_MINAENDW
    a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro máquina MINAENDW" .

ex:Senal_PLCCNTL
    a ex:Parametro ;
    rdfs:label "PLCCNTL" ;
    ex:textoExtracto "Cuando el PLC pone la marca PLCCNTL a (=1), el cabezal decelera con rampa hasta detenerse y pasa a estar controlado por el PLC." ;
    ex:valor "1" .

ex:Senal_PLCCNTL1
    a ex:Parametro ;
    rdfs:label "PLCCNTL1" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL1 (también se puede programar como PLCCNTL)" .

ex:Senal_PLCCNTL2
    a ex:Parametro ;
    rdfs:label "PLCCNTL2" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL2" .

ex:Senal_PLCCNTL3
    a ex:Parametro ;
    rdfs:label "PLCCNTL3" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL3" .

ex:Senal_PLCCNTL4
    a ex:Parametro ;
    rdfs:label "PLCCNTL4" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL4" .

ex:Senal_PLCCNTL5
    a ex:Parametro ;
    rdfs:label "PLCCNTL5" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL5" .

ex:Senal_PLCCNTL6
    a ex:Parametro ;
    rdfs:label "PLCCNTL6" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL6" .

ex:Senal_SANALOG
    a ex:Parametro ;
    rdfs:label "SANALOG" ;
    ex:textoExtracto "El registro SANALOG fija la consigna de cabezal que se desea aplicar." .

ex:Senal_SANALOG1
    a ex:Parametro ;
    rdfs:label "SANALOG1" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG1 (también se puede programar como SANALOG)" .

ex:Senal_SANALOG2
    a ex:Parametro ;
    rdfs:label "SANALOG2" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG2" .

ex:Senal_SANALOG3
    a ex:Parametro ;
    rdfs:label "SANALOG3" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG3" .

ex:Senal_SANALOG4
    a ex:Parametro ;
    rdfs:label "SANALOG4" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG4" .

ex:Senal_SANALOG5
    a ex:Parametro ;
    rdfs:label "SANALOG5" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG5" .

ex:Senal_SANALOG6
    a ex:Parametro ;
    rdfs:label "SANALOG6" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SANALOG6" .

ex:Sistema_ControlCabezales
    a ex:Sistema ;
    rdfs:label "Sistema de control de cabezales" ;
    ex:textoExtracto "Se dispone de una señal para cada cabezal. [...] Estas señales se utilizan con cabezal analógico, Sercos en posición, Sercos en velocidad y Mechatrolink." ;
    ex:tieneComponente ex:Senal_PLCCNTL1 , ex:Senal_PLCCNTL2 , ex:Senal_PLCCNTL3 , ex:Senal_PLCCNTL4 , ex:Senal_PLCCNTL5 , ex:Senal_PLCCNTL6 ,
                       ex:Senal_SANALOG1 , ex:Senal_SANALOG2 , ex:Senal_SANALOG3 , ex:Senal_SANALOG4 , ex:Senal_SANALOG5 , ex:Senal_SANALOG6 .

ex:Proceso_CambioGama
    a ex:ModoOperacion ;
    rdfs:label "Cambio de gama" ;
    ex:textoExtracto "Comienza el cambio y se lo indica al CNC con AUXEND a (=0). [...] Durante el cambio se le indica al CNC que se deja la gama 1 y que se selecciona la gama 2." ;
    ex:monitoreaParametro ex:Senal_MFUN1 , ex:Senal_MSTROBE , ex:Senal_M1002 , ex:Senal_AUXEND , ex:Senal_GEAR1 , ex:Senal_GEAR2 .