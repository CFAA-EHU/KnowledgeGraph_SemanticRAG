@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Señales de control de cabezales (PLC/CNC)
ex:Senal_SANALOG
    a ex:Parametro ;
    rdfs:label "SANALOG (consigna residual)"@es ;
    ex:textoExtracto "El PLC pone en SANALOG el valor correspondiente a la consigna residual [...] asignarle a SANALOG el valor 0"@es ;
    ex:monitoreaParametro ex:SistemaControlCabezales .

ex:Marca_PLCCNTL
    a ex:Parametro ;
    rdfs:label "PLCCNTL (control PLC)"@es ;
    ex:textoExtracto "activa la marca PLCCNTL para indicar que el cabezal está controlado por el PLC [...] poner PLCCNTL a (=0)"@es ;
    ex:monitoreaParametro ex:SistemaControlCabezales .

ex:Marca_SPDLEREV
    a ex:Parametro ;
    rdfs:label "SPDLEREV (inversión giro cabezal)"@es ;
    ex:textoExtracto "Cuando el PLC pone esta marca a (=1), el CNC invierte el sentido de giro del cabezal"@es ;
    ex:monitoreaParametro ex:SistemaControlCabezales .

ex:Marca_SPDLEREV1
    a ex:Parametro ;
    rdfs:label "SPDLEREV1"@es ;
    ex:textoExtracto "SPDLEREV1 (también se puede programar como SPDLEREV)"@es ;
    ex:monitoreaParametro ex:Cabezal_1 .

ex:Marca_SPDLEREV2
    a ex:Parametro ;
    rdfs:label "SPDLEREV2"@es ;
    ex:textoExtracto "SPDLEREV2"@es ;
    ex:monitoreaParametro ex:Cabezal_2 .

ex:Marca_SPDLEREV3
    a ex:Parametro ;
    rdfs:label "SPDLEREV3"@es ;
    ex:textoExtracto "SPDLEREV3"@es ;
    ex:monitoreaParametro ex:Cabezal_3 .

ex:Marca_SPDLEREV4
    a ex:Parametro ;
    rdfs:label "SPDLEREV4"@es ;
    ex:textoExtracto "SPDLEREV4"@es ;
    ex:monitoreaParametro ex:Cabezal_4 .

ex:Marca_SPDLEREV5
    a ex:Parametro ;
    rdfs:label "SPDLEREV5"@es ;
    ex:textoExtracto "SPDLEREV5"@es ;
    ex:monitoreaParametro ex:Cabezal_5 .

ex:Marca_SPDLEREV6
    a ex:Parametro ;
    rdfs:label "SPDLEREV6"@es ;
    ex:textoExtracto "SPDLEREV6"@es ;
    ex:monitoreaParametro ex:Cabezal_6 .

ex:Marca_PLCM3
    a ex:Parametro ;
    rdfs:label "PLCM3 (función M3)"@es ;
    ex:textoExtracto "PLCM3 [...] El PLC dispone de una marca para cada cabezal"@es ;
    ex:monitoreaParametro ex:Cabezal_1 .

ex:Marca_PLCM4
    a ex:Parametro ;
    rdfs:label "PLCM4 (función M4)"@es ;
    ex:textoExtracto "PLCM4"@es ;
    ex:monitoreaParametro ex:Cabezal_1 .

ex:Marca_PLCM5
    a ex:Parametro ;
    rdfs:label "PLCM5"@es ;
    ex:textoExtracto "PLCM5"@es ;
    ex:monitoreaParametro ex:Cabezal_1 .

ex:Parametro_M19SPDLEREV
    a ex:Parametro ;
    rdfs:label "M19SPDLEREV (inversión en lazo cerrado)"@es ;
    ex:textoExtracto "depende del parámetro M19SPDLEREV"@es ;
    ex:monitoreaParametro ex:SistemaControlCabezales .

### Cabezales y sistema de control
ex:Cabezal_1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 1"@es ;
    ex:textoExtracto "SPDLEREV1 [...] PLCM3"@es .

ex:Cabezal_2
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 2"@es ;
    ex:textoExtracto "SPDLEREV2"@es .

ex:Cabezal_3
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 3"@es ;
    ex:textoExtracto "SPDLEREV3"@es .

ex:Cabezal_4
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 4"@es ;
    ex:textoExtracto "SPDLEREV4"@es .

ex:Cabezal_5
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 5"@es ;
    ex:textoExtracto "SPDLEREV5"@es .

ex:Cabezal_6
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 6"@es ;
    ex:textoExtracto "SPDLEREV6"@es .

ex:SistemaControlCabezales
    a ex:Sistema ;
    rdfs:label "Sistema de control PLC/CNC de cabezales"@es ;
    ex:textoExtracto "El PLC pone en SANALOG el valor [...] controla la oscilación del cabezal durante el cambio de gama"@es ;
    ex:controla ex:Cabezal_1 , ex:Cabezal_2 , ex:Cabezal_3 , ex:Cabezal_4 , ex:Cabezal_5 , ex:Cabezal_6 ;
    ex:tieneComponente ex:Marca_PLCCNTL , ex:Senal_SANALOG , ex:Marca_SPDLEREV , ex:Parametro_M19SPDLEREV .