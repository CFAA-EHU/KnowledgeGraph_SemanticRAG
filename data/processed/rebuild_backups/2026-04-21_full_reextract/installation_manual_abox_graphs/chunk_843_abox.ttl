@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLCM3
    a ex:Sistema ;
    rdfs:label "PLCM3" ;
    ex:textoExtracto "PLCM3SP1 (también se puede programar como PLCM3)" ;
    ex:identificador "PLCM3" .

ex:PLCM4
    a ex:Sistema ;
    rdfs:label "PLCM4" ;
    ex:textoExtracto "PLCM3 PLCM4 PLCM5" ;
    ex:identificador "PLCM4" .

ex:PLCM5
    a ex:Sistema ;
    rdfs:label "PLCM5" ;
    ex:textoExtracto "PLCM3 PLCM4 PLCM5" ;
    ex:identificador "PLCM5" .

ex:PLCM3SP1
    a ex:Componente ;
    rdfs:label "PLCM3SP1" ;
    ex:textoExtracto "PLCM3SP1 (también se puede programar como PLCM3)" ;
    ex:identificador "PLCM3SP1" ;
    ex:compuestoPor ex:PLCM3 .

ex:PLCM3SP2
    a ex:Componente ;
    rdfs:label "PLCM3SP2" ;
    ex:textoExtracto "PLCM3SP2" ;
    ex:identificador "PLCM3SP2" ;
    ex:compuestoPor ex:PLCM3 .

ex:PLCM3SP3
    a ex:Componente ;
    rdfs:label "PLCM3SP3" ;
    ex:textoExtracto "PLCM3SP3" ;
    ex:identificador "PLCM3SP3" ;
    ex:compuestoPor ex:PLCM3 .

ex:PLCM3SP4
    a ex:Componente ;
    rdfs:label "PLCM3SP4" ;
    ex:textoExtracto "PLCM3SP4" ;
    ex:identificador "PLCM3SP4" ;
    ex:compuestoPor ex:PLCM3 .

ex:PLCM3SP5
    a ex:Componente ;
    rdfs:label "PLCM3SP5" ;
    ex:textoExtracto "PLCM3SP5" ;
    ex:identificador "PLCM3SP5" ;
    ex:compuestoPor ex:PLCM3 .

ex:PLCM3SP6
    a ex:Componente ;
    rdfs:label "PLCM3SP6" ;
    ex:textoExtracto "PLCM3SP6" ;
    ex:identificador "PLCM3SP6" ;
    ex:compuestoPor ex:PLCM3 .

ex:VariableVelocidadCabezales
    a ex:Parametro ;
    rdfs:label "Variable de velocidad de cabezales (V.)PLC.S.sn" ;
    ex:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn" ;
    ex:identificador "(V.)PLC.S.sn" ;
    ex:monitoreaParametro ex:PLCM3 .

ex:ParametroAutoGear
    a ex:Parametro ;
    rdfs:label "Parámetro AUTOGEAR" ;
    ex:textoExtracto "sin generar un cambio de gama aunque éste sea automático (parámetro AUTOGEAR)" ;
    ex:identificador "AUTOGEAR" .