@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SLIMITACSPDL1
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL1" ;
    ex:identificador "SLIMITACSPDL1" ;
    ex:textoExtracto "SLIMITACSPDL1 (también se puede programar como SLIMITACSPDL)" .

ex:SLIMITACSPDL2
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL2" ;
    ex:identificador "SLIMITACSPDL2" ;
    ex:textoExtracto "SLIMITACSPDL2" .

ex:SLIMITACSPDL3
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL3" ;
    ex:identificador "SLIMITACSPDL3" ;
    ex:textoExtracto "SLIMITACSPDL3" .

ex:SLIMITACSPDL4
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL4" ;
    ex:identificador "SLIMITACSPDL4" ;
    ex:textoExtracto "SLIMITACSPDL4" .

ex:SLIMITACSPDL5
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL5" ;
    ex:identificador "SLIMITACSPDL5" ;
    ex:textoExtracto "SLIMITACSPDL5" .

ex:SLIMITACSPDL6
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL6" ;
    ex:identificador "SLIMITACSPDL6" ;
    ex:textoExtracto "SLIMITACSPDL6" .

ex:SistemaSe_alesCabezales
    a ex:Sistema ;
    rdfs:label "Sistema de señales modificables de los cabezales" ;
    ex:textoExtracto "Señales modificables de los cabezales. SLIMITACSPDL Hay una marca para cada cabezal." ;
    ex:tieneComponente ex:SLIMITACSPDL1, ex:SLIMITACSPDL2, ex:SLIMITACSPDL3, ex:SLIMITACSPDL4, ex:SLIMITACSPDL5, ex:SLIMITACSPDL6 .

ex:PLC
    a ex:Actuador ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la" ;
    ex:controla ex:SLIMITACSPDL1, ex:SLIMITACSPDL2, ex:SLIMITACSPDL3, ex:SLIMITACSPDL4, ex:SLIMITACSPDL5, ex:SLIMITACSPDL6 .

ex:CNC
    a ex:Actuador ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la" .