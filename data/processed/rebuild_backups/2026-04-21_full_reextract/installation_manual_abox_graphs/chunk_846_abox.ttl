@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SLIMITACSPDL
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL (límite de seguridad para velocidad)"@es ;
    ex:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado, durante la ejecución del bloque actual."@es ;
    ex:identificador "SLIMITACSPDL" .

ex:SLIMITACSPDL2
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL2"@es ;
    ex:textoExtracto "SLIMITACSPDL2"@es ;
    ex:identificador "SLIMITACSPDL2" .

ex:SLIMITACSPDL3
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL3"@es ;
    ex:textoExtracto "SLIMITACSPDL3"@es ;
    ex:identificador "SLIMITACSPDL3" .

ex:SLIMITACSPDL4
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL4"@es ;
    ex:textoExtracto "SLIMITACSPDL4"@es ;
    ex:identificador "SLIMITACSPDL4" .

ex:SLIMITACSPDL5
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL5"@es ;
    ex:textoExtracto "SLIMITACSPDL5"@es ;
    ex:identificador "SLIMITACSPDL5" .

ex:SLIMITACSPDL6
    a ex:Parametro ;
    rdfs:label "SLIMITACSPDL6"@es ;
    ex:textoExtracto "SLIMITACSPDL6"@es ;
    ex:identificador "SLIMITACSPDL6" .

ex:CNC_ControlVelocidad
    a ex:Sistema ;
    rdfs:label "Sistema de control de velocidad del CNC"@es ;
    ex:textoExtracto "el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado"@es ;
    ex:monitoreaParametro ex:SLIMITACSPDL, ex:SLIMITACSPDL2, ex:SLIMITACSPDL3, ex:SLIMITACSPDL4, ex:SLIMITACSPDL5, ex:SLIMITACSPDL6 .

ex:PLC_Se_alLimitacion
    a ex:Actuador ;
    rdfs:label "Señal de limitación de velocidad del PLC"@es ;
    ex:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad [...] Si el PLC desactiva esta marca, el CNC recupera la velocidad programada."@es ;
    ex:controla ex:CNC_ControlVelocidad .