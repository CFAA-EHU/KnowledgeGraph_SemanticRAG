@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GAPMIN
    a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:textoExtracto "parámetro GAPMIN" ;
    ex:valor "GAPMIN" .

ex:Parametro_GAPMAX
    a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:textoExtracto "parámetro GAPMAX" ;
    ex:valor "GAPMAX" .

ex:Parametro_GAPTOL
    a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:textoExtracto "parámetro GAPTOL" ;
    ex:valor "GAPTOL" .

ex:Alarma_GapActivo
    a ex:Alarma ;
    rdfs:label "Marca de salida del gap (GAPMIN/GAPMAX)" ;
    ex:textoExtracto "Esta marca permanece activa hasta iniciar la ejecución de un programa. [...] ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa" ;
    ex:monitoreaParametro ex:Parametro_GAPMIN ;
    ex:monitoreaParametro ex:Parametro_GAPMAX .

ex:Alarma_OutOfTol
    a ex:Alarma ;
    rdfs:label "OUTOFTOL (Fuera de tolerancia del gap)" ;
    ex:textoExtracto "El PLC activa esta marca para indicar que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa" ;
    ex:monitoreaParametro ex:Parametro_GAPTOL .