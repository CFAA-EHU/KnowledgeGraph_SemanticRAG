PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_CH2TOMZ1
    a ex:Parametro ;
    rdfs:label "CH2TOMZ1" ;
    ex:identificador "CH2TOMZ1" ;
    ex:textoExtracto "CH2TOMZ1 (también se puede programar como CH2TOMZ)" ;
    ex:valor "1"^^xsd:integer .

