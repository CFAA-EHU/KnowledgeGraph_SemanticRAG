ex:Sistema_GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén. [...] Utilizar con almacén asíncrono o síncrono con brazo. [...] Utilizar con almacén que permite herramientas de tierra." ;
    ex:tieneComponente ex:Se_al_CH2TOMZ1, ex:Se_al_CH2TOMZ2, ex:Se_al_CH2TOMZ3, ex:Se_al_CH2TOMZ4,
                      ex:Se_al_SPDLTOGRC1, ex:Se_al_SPDLTOGRC2, ex:Se_al_SPDLTOGRC3, ex:Se_al_SPDLTOGRC4,
                      ex:Se_al_GRTOSPDLC1 .