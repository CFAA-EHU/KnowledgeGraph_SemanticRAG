@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_KeyLED1
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED1" ;
    ex:textoExtracto "KEYLED1 Este registro enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente." ;
    ex:identificador "KEYLED1" .

ex:InterfazUsuario_KeyLED1_1
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED1_1" ;
    ex:textoExtracto "KEYLED1_1 Estos registros encienden los led (bit=1) de las teclas de usuario en un panel de mando. El registro KEYLED1_1 corresponde al primer panel de mando." ;
    ex:identificador "KEYLED1_1" .

ex:InterfazUsuario_KeyLED1_2
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED1_2" ;
    ex:textoExtracto "KEYLED1_2 al segundo panel de mando." ;
    ex:identificador "KEYLED1_2" .

ex:InterfazUsuario_KeyLED2
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED2" ;
    ex:textoExtracto "KEYLED2 Este registro enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente." ;
    ex:identificador "KEYLED2" .

ex:InterfazUsuario_KeyLED2_1
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED2_1" ;
    ex:textoExtracto "KEYLED2_1 Estos registros encienden los led (bit=1) de las teclas en el módulo OP-PANEL-H/E. El registro KEYLED2_1 corresponde al primer panel de mando." ;
    ex:identificador "KEYLED2_1" .

ex:InterfazUsuario_KeyLED2_2
    a ex:InterfazUsuario ;
    rdfs:label "KEYLED2_2" ;
    ex:textoExtracto "KEYLED2_2 al segundo panel de mando." ;
    ex:identificador "KEYLED2_2" .

ex:Sistema_ModulosOP_PANEL_H_E
    a ex:Sistema ;
    rdfs:label "Módulos OP-PANEL-H/E" ;
    ex:textoExtracto "módulos OP-PANEL-H/E" ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED2 ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED2_1 ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED2_2 .

ex:Sistema_PanelesMando
    a ex:Sistema ;
    rdfs:label "Paneles de mando" ;
    ex:textoExtracto "paneles de mando" ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED1 ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED1_1 ;
    ex:tieneComponente ex:InterfazUsuario_KeyLED1_2 .