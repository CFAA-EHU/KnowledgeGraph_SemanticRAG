@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Registro_KEYDIS4
    a ex:Parametro ;
    rdfs:label "Registro KEYDIS4" ;
    ex:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8. Selector del speed override." ;
    ex:identificador "KEYDIS4" .

ex:Registro_KEYDIS4_1
    a ex:Parametro ;
    rdfs:label "Registro KEYDIS4_1" ;
    ex:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8. Selector del speed override." ;
    ex:identificador "KEYDIS4_1" .

ex:Registro_KEYDIS4_8
    a ex:Parametro ;
    rdfs:label "Registro KEYDIS4_8" ;
    ex:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8. Selector del speed override." ;
    ex:identificador "KEYDIS4_8" .

ex:Registro_KEYDISHBLS1
    a ex:Parametro ;
    rdfs:label "Registro KEYDISHBLS1" ;
    ex:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante y KEYDISHBLS2 al segundo." ;
    ex:identificador "KEYDISHBLS1" .

ex:Registro_KEYDISHBLS2
    a ex:Parametro ;
    rdfs:label "Registro KEYDISHBLS2" ;
    ex:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante y KEYDISHBLS2 al segundo." ;
    ex:identificador "KEYDISHBLS2" .

ex:InterfazUsuario_VolanteHBLS_1
    a ex:InterfazUsuario ;
    rdfs:label "Primer volante HBLS" ;
    ex:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante y KEYDISHBLS2 al segundo." ;
    ex:controla ex:Registro_KEYDISHBLS1 .

ex:InterfazUsuario_VolanteHBLS_2
    a ex:InterfazUsuario ;
    rdfs:label "Segundo volante HBLS" ;
    ex:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante y KEYDISHBLS2 al segundo." ;
    ex:controla ex:Registro_KEYDISHBLS2 .