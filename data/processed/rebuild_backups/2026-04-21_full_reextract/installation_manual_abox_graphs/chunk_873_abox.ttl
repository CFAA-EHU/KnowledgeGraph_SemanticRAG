@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ComunicacionGestorPLC_731 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de comunicación Gestor-PLC (7.3.1)"@es ;
    ex:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes."@es ;
    ex:documentadoEn ex:Pagina_473 .

ex:Pagina_473
    a ex:Pagina ;
    ex:identificador "473" ;
    ex:ilustradoEn ex:Manual_Tecnico ;
    ex:textoExtracto "El gestor utiliza los siguientes registros y marcas para informar al PLC de las operaciones que debe realizar. Algunas señales son por canal mientras que otras son por almacén."@es .

ex:Sistema_ComunicacionGestorPLC
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación Gestor-PLC"@es ;
    ex:textoExtracto "El gestor utiliza los siguientes registros y marcas para informar al PLC de las operaciones que debe realizar."@es ;
    ex:detalladoEnEsquema ex:Tabla_ComunicacionGestorPLC_731 ;
    ex:tieneComponente
        ex:Marca_TMOPSTROBE_C1, ex:Marca_TMOPSTROBE_C2,
        ex:Marca_TMOPSTROBE_C3, ex:Marca_TMOPSTROBE_C4,
        ex:Registro_TMOPERATION_C1, ex:Registro_TMOPERATION_C2,
        ex:Registro_TMOPERATION_C3, ex:Registro_TMOPERATION_C4,
        ex:Registro_MZID_C1, ex:Registro_MZID_C2,
        ex:Registro_MZID_C3, ex:Registro_MZID_C4,
        ex:Registro_LEAVEPOS_MZ1, ex:Registro_LEAVEPOS_MZ2,
        ex:Registro_LEAVEPOS_MZ3, ex:Registro_LEAVEPOS_MZ4,
        ex:Registro_TAKEPOS_MZ1, ex:Registro_TAKEPOS_MZ2,
        ex:Registro_TAKEPOS_MZ3, ex:Registro_TAKEPOS_MZ4,
        ex:Registro_NEXTPOS_MZ1, ex:Registro_NEXTPOS_MZ2,
        ex:Registro_NEXTPOS_MZ3, ex:Registro_NEXTPOS_MZ4 .

