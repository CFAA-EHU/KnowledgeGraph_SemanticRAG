PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaComunicacionPLC_Gestor a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de mnemónicos de comunicación PLC-Gestor (Almacenes 1-4)"@es ;
    ex:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes. [...] El significado de las marcas y registros es el siguiente."@es ;
    ex:ilustradoEn ex:Pagina_474_475 .

ex:Pagina_474_475
    a ex:Pagina ;
    ex:identificador "474-475" ;
    ex:documentadoEn ex:ManualBrochado ;
    ex:textoExtracto "Sección 7.3.2 Comunicación PLC --> Gestor"@es .

ex:SistemaComunicacionPLC_Gestor
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación PLC-Gestor (Almacenes 1-4)"@es ;
    ex:detalladoEnEsquema ex:TablaComunicacionPLC_Gestor ;
    ex:textoExtracto "El gestor las pone a 0 una vez leídas."@es .

