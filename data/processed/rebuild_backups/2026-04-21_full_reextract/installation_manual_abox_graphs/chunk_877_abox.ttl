@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ComunicacionPLC_Gestor_732 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de marcas/registros para comunicación PLC --> Gestor (Sección 7.3.2)"@es ;
    ex:textoExtracto """
| Marcas / Registros. | Significado. |
| --- | --- |
| MZTOCH1 | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1. |
| CH1TOSPDL | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal. |
| SPDLTOCH1 | Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1. |
| SPDLTOCH2 | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2. |
| CH1TOMZ | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén.
""" .

ex:Marca_MZTOCH1
    a ex:Parametro ;
    rdfs:label "MZTOCH1" ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor_732 ;
    ex:valor "1" .

ex:Marca_CH1TOSPDL
    a ex:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor_732 ;
    ex:valor "1" .

ex:Marca_SPDLTOCH1
    a ex:Parametro ;
    rdfs:label "SPDLTOCH1" ;
    ex:identificador "SPDLTOCH1" ;
    ex:textoExtracto "Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor_732 ;
    ex:valor "1" .

ex:Marca_SPDLTOCH2
    a ex:Parametro ;
    rdfs:label "SPDLTOCH2" ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor_732 ;
    ex:valor "1" .

ex:Marca_CH1TOMZ
    a ex:Parametro ;
    rdfs:label "CH1TOMZ" ;
    ex:identificador "CH1TOMZ" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor_732 ;
    ex:valor "1" .