@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_V_ch_TM_MZMODE
    a ex:Parametro ;
    rdfs:label "Modo de funcionamiento del gestor (V.[ch].TM.MZMODE)" ;
    ex:textoExtracto "V.[ch].TM.MZMODE Modo de funcionamiento del gestor. Con valor ꞏ0ꞏ Modo normal (por defecto y tras reset). Con valor ꞏ1ꞏ Modo carga de almacén. Con valor ꞏ2ꞏ Modo descarga de almacén." ;
    ex:valor "0,1,2" .

ex:Parametro_V_ch_TM_MZSTATUS
    a ex:Parametro ;
    rdfs:label "Estado del gestor de herramientas (V.[ch].TM.MZSTATUS)" ;
    ex:textoExtracto "V.[ch].TM.MZSTATUS Estado del gestor de herramientas. Con valor ꞏ0ꞏ Funcionamiento normal. Con valor ꞏ1ꞏ Se ha producido un error. Con valor ꞏ2ꞏ Se ha producido un error pero se espera a que finalice la maniobra en marcha. Con valor ꞏ4ꞏ Emergencia." ;
    ex:valor "0,1,2,4" .

ex:Parametro_V_ch_TM_MZRUN
    a ex:Parametro ;
    rdfs:label "Gestor de herramientas en funcionamiento (V.[ch].TM.MZRUN)" ;
    ex:textoExtracto "V.[ch].TM.MZRUN Gestor de herramientas en funcionamiento. Con valor ꞏ0ꞏ No hay ninguna secuencia en ejecución. Con valor ꞏ1ꞏ Indica que hay una secuencia en ejecución." ;
    ex:valor "0,1" .

ex:Parametro_V_ch_TM_MZWAIT
    a ex:Parametro ;
    rdfs:label "Gestor procesando una maniobra (V.[ch].TM.MZWAIT)" ;
    ex:textoExtracto "V.[ch].TM.MZWAIT Gestor procesando una maniobra. Indica si hay que esperar porque hay una maniobra en marcha. Con valor ꞏ0ꞏ No hay que esperar. Con valor ꞏ1ꞏ Hay que esperar." ;
    ex:valor "0,1" .

ex:Sistema_GestionAlmacen
    a ex:Sistema ;
    rdfs:label "Sistema de gestión del almacén de herramientas" ;
    ex:textoExtracto "Las variables asociadas al almacén que intervienen directamente en la gestión del almacén son las siguientes. Se dispone de un grupo de variables para cada canal." ;
    ex:monitoreaParametro ex:Parametro_V_ch_TM_MZMODE ;
    ex:monitoreaParametro ex:Parametro_V_ch_TM_MZSTATUS ;
    ex:monitoreaParametro ex:Parametro_V_ch_TM_MZRUN ;
    ex:monitoreaParametro ex:Parametro_V_ch_TM_MZWAIT .