@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionM06 a ex:ModoOperacion ;
    rdfs:label "Función M06 (cambio de herramienta)"@es ;
    ex:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio."@es ;
    ex:identificador "M06" .

ex:TablaAlmacenHerramientas a ex:Tabla ;
    rdfs:label "Tabla de almacén de herramientas"@es ;
    ex:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén."@es .

ex:GestorHerramientas a ex:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ex:textoExtracto "el gestor actualiza la tabla de almacén"@es ;
    ex:controla ex:TablaAlmacenHerramientas .