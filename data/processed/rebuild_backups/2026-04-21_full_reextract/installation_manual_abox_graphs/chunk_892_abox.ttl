@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionT a ex:ModoOperacion ;
    rdfs:label "Función T (cambio de herramienta)"@es ;
    ex:textoExtracto "El CNC ejecuta la función T y la subrutina el bloque M06. [...] La rutina asociada a la función T ejecuta la función M06."@es ;
    ex:requiereMantenimiento ex:RutinaM06 .

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (gestión de cambio de herramienta)"@es ;
    ex:textoExtracto "Dentro de dicha rutina hay que programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta. [...] Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06."@es ;
    ex:controla ex:PLC_AlmacenTorreta ;
    ex:ejecutadoPor ex:GestorCNC .

ex:PLC_AlmacenTorreta a ex:Actuador ;
    rdfs:label "PLC del almacén tipo torreta"@es ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén. [...] El gestor envía una orden al PLC para efectuar el cambio."@es ;
    ex:controla ex:AlmacenTipoTorreta .

ex:GestorCNC a ex:Sistema ;
    rdfs:label "Gestor de CNC"@es ;
    ex:textoExtracto "El CNC ejecuta la función T y se lo indica al gestor. [...] El CNC espera a que el gestor dé por finalizada la operación."@es ;
    ex:controla ex:PLC_AlmacenTorreta .

ex:AlmacenTipoTorreta a ex:ComponenteMecanico ;
    rdfs:label "Almacén tipo torreta"@es ;
    ex:textoExtracto "Herramientas de tierra en un almacén tipo torreta. [...] giro almacén, desplazamiento almacén, brazo cambiador, etc."@es ;
    ex:compuestoPor ex:HerramientaTierra ;
    ex:compuestoPor ex:BrazoCambiador ;
    ex:compuestoPor ex:MecanismoGiroAlmacen ;
    ex:compuestoPor ex:MecanismoDesplazamientoAlmacen .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "Si en la posición de trabajo se encuentra una herramienta y se solicita otra que no se encuentra en la torreta, el CNC entiende que se trata de una herramienta de tierra."@es .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de herramientas"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ex:MecanismoGiroAlmacen a ex:ComponenteMecanico ;
    rdfs:label "Mecanismo de giro del almacén"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ex:MecanismoDesplazamientoAlmacen a ex:ComponenteMecanico ;
    rdfs:label "Mecanismo de desplazamiento del almacén"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ex:Variable_V.TM.MZMODE a ex:Parametro ;
    rdfs:label "Variable V.TM.MZMODE"@es ;
    ex:identificador "V.TM.MZMODE" ;
    ex:textoExtracto "La variable V.TM.MZMODE deberá tener el valor adecuado para realizar la carga o descarga."@es ;
    ex:monitoreaParametro ex:AlmacenTipoTorreta .