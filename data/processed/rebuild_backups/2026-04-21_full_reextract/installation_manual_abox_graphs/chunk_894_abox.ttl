@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EjemploFuncionamientoCNC_894
    a               ex:Sistema ;
    rdfs:label      "Ejemplo de funcionamiento CNC-PLC (sin herramienta en cabezal)"@es ;
    ex:textoExtracto
        "Ejemplo de funcionamiento. El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es .

ex:HerramientaT7_894
    a               ex:Herramienta ;
    rdfs:label      "Herramienta T7 (de tierra)"@es ;
    ex:identificador "T7" ;
    ex:textoExtracto
        "la herramienta T7 es de tierra"@es ;
    ex:documentadoEn
        ex:EjemploFuncionamientoCNC_894 .

ex:AlmacenHerramientas_894
    a               ex:Sistema ;
    rdfs:label      "Almacén no-random de herramientas"@es ;
    ex:textoExtracto
        "El almacén es no-random, cada herramienta ocupa la posición de su mismo número"@es ;
    ex:documentadoEn
        ex:EjemploFuncionamientoCNC_894 .