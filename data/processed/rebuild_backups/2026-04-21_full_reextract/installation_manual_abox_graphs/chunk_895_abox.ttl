ex:OperacionesAlmacen_895
    a                     ex:Sistema ;
    rdfs:label            "Operaciones del almacén (TAKEPOS, LEAVEPOS, NEXTPOS, MZID)"@es ;
    ex:textoExtracto      "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación."@es ;
    ex:identificador      "7.7.2" .

ex:Senal_TAKEPOS
    a                     ex:Parametro ;
    rdfs:label            "TAKEPOS" ;
    ex:textoExtracto      "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores."@es ;
    ex:monitoreaParametro ex:OperacionesAlmacen_895 .

