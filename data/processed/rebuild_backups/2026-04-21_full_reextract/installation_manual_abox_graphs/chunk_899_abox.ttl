@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ComunicacionPLC_M06 a ex:Sistema ;
    rdfs:label "Comunicación entre PLC y rutina M06"@es ;
    ex:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos. En el programa de la subrutina M06 que se ofrece como ejemplo se han utilizado las siguientes marcas y registros."@es ;
    ex:tieneComponente ex:Marca_M1107, ex:Marca_M1108, ex:Marca_M1109, ex:Marca_M1110, ex:Marca_M1111,
                       ex:Funcion_M109, ex:Funcion_M110 .

ex:Marca_M1107 a ex:ComponenteElectrico ;
    rdfs:label "Marca M1107 (SPDLTOGR)"@es ;
    ex:identificador "M1107" ;
    ex:textoExtracto "SPDLTOGR: La herramienta se ha llevado del cabezal a tierra."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1108 a ex:ComponenteElectrico ;
    rdfs:label "Marca M1108 (GRTOSPDL)"@es ;
    ex:identificador "M1108" ;
    ex:textoExtracto "GRTOSPDL: La herramienta se ha llevado de tierra al cabezal."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1109 a ex:ComponenteElectrico ;
    rdfs:label "Marca M1109 (MZTOSPDL)"@es ;
    ex:identificador "M1109" ;
    ex:textoExtracto "MZTOSPDL: Asumir la herramienta actual como herramienta activa."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1110 a ex:ComponenteElectrico ;
    rdfs:label "Marca M1110 (SPDLTOGR)"@es ;
    ex:identificador "M1110" ;
    ex:textoExtracto "SPDLTOGR: Asumir la herramienta actual como herramienta activa."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1111 a ex:ComponenteElectrico ;
    rdfs:label "Marca M1111 (MZROT)"@es ;
    ex:identificador "M1111" ;
    ex:textoExtracto "MZROT: Marca que indica que ya ha girado el almacén."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Funcion_M109 a ex:ComponenteElectrico ;
    rdfs:label "Función M109"@es ;
    ex:identificador "M109" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Funcion_M110 a ex:ComponenteElectrico ;
    rdfs:label "Función M110"@es ;
    ex:identificador "M110" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal."@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .