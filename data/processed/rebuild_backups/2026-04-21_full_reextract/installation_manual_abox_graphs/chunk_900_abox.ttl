@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Cambio de herramienta"@es ;
    ex:textoExtracto """
    %L SUB_MZ_ROT V.PLC.M[1111]=1 #WAIT FOR [V.PLC.M[1111]==0]; Marca MZROT al gestor.
    %L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).
    %L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.
    %L SUB_MZ_TO_SPD ; Coger la herramienta del almacén y ponerla en el cabezal.
    %L SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén.
    """@es ;
    ex:requiereMantenimiento ex:HerramientaT_D, ex:HerramientaTierra ;
    ex:ilustradoEn ex:MensajeOperario_ExtraerHerramienta, ex:MensajeOperario_InsertarHerramienta .

ex:HerramientaT_D
    a ex:Herramienta ;
    rdfs:label "Herramienta T%D"@es ;
    ex:textoExtracto "Extraer herramienta T%D y pulsar MARCHA"@es .

ex:HerramientaTierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "Colocar la herramienta de tierra en el cabezal"@es .

ex:MensajeOperario_ExtraerHerramienta
    a ex:InterfazUsuario ;
    rdfs:label "Mensaje: Extraer herramienta T%D"@es ;
    ex:textoExtracto "# MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL]"@es .

ex:MensajeOperario_InsertarHerramienta
    a ex:InterfazUsuario ;
    rdfs:label "Mensaje: Insertar herramienta T%D"@es ;
    ex:textoExtracto "# MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL]"@es .

ex:MarcaMZROT
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1111]" ;
    ex:valor "1" ;
    ex:textoExtracto "V.PLC.M[1111]=1 #WAIT FOR [V.PLC.M[1111]==0]; Marca MZROT al gestor"@es .

ex:MarcaSPDLTOGR
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1107]" ;
    ex:valor "1" ;
    ex:textoExtracto "V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor"@es .

ex:MarcaGRTOSPDL
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1108]" ;
    ex:valor "1" ;
    ex:textoExtracto "V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor"@es .

ex:MarcaMZTOSPDL
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1109]" ;
    ex:valor "1" ;
    ex:textoExtracto "V.PLC.M[1109]=1 ; Marca MZTOSPDL al gestor"@es .

ex:MarcaSPDLTOMZ
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1110]" ;
    ex:valor "1" ;
    ex:textoExtracto "V.PLC.M[1110]=1 ; Marca SPDLTOGR al gestor"@es .