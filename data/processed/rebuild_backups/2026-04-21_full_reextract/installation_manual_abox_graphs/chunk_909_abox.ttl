@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EjemploFuncionamientoCNC_PLC_493_494
    a ex:ModoOperacion ;
    rdfs:label "Ejemplo de funcionamiento CNC-PLC (pág. 493-494)"@es ;
    ex:textoExtracto "Ejemplo de funcionamiento. El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es ;
    ex:tieneComponente ex:Herramienta_T7, ex:Herramienta_T8, ex:Herramienta_T9 ;
    ex:controla ex:SistemaGestionPLC_493 .

ex:Herramienta_T7
    a ex:Herramienta ;
    rdfs:label "Herramienta T7"@es ;
    ex:identificador "T7" ;
    ex:textoExtracto "las herramientas T7, T8 y T9 son de tierra."@es .

ex:Herramienta_T8
    a ex:Herramienta ;
    rdfs:label "Herramienta T8"@es ;
    ex:identificador "T8" ;
    ex:textoExtracto "las herramientas T7, T8 y T9 son de tierra."@es .

ex:Herramienta_T9
    a ex:Herramienta ;
    rdfs:label "Herramienta T9"@es ;
    ex:identificador "T9" ;
    ex:textoExtracto "las herramientas T7, T8 y T9 son de tierra."@es .

ex:SistemaGestionPLC_493
    a ex:Sistema ;
    rdfs:label "Sistema gestor PLC (pág. 493)"@es ;
    ex:textoExtracto "los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es .