@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionMantenimiento_12
    a ex:TareaMantenimiento ;
    rdfs:label "Operación TMOPERATION=12 (Intercambio de herramienta en almacén random)" ;
    ex:identificador "TMOPERATION=12" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo cuando el almacén es random y la herramienta es especial." ;
    ex:requiereMantenimiento ex:AlmacenHerramientas_Random .

ex:OperacionMantenimiento_13
    a ex:TareaMantenimiento ;
    rdfs:label "Operación TMOPERATION=13 (Orientación de dos almacenes)" ;
    ex:identificador "TMOPERATION=13" ;
    ex:textoExtracto "Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite..." .

ex:AlmacenHerramientas_Random
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas (tipo random)" ;
    ex:textoExtracto "almacén es random y la herramienta es especial" .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro TAKEPOS (Posición de recogida de herramienta)" ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro LEAVEPOS (Posición de depósito de herramienta)" ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ex:Marca_MZROT
    a ex:InterfazUsuario ;
    rdfs:label "Marca MZROT (Indicador de finalización de operación)" ;
    ex:identificador "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .