@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Cambio de herramienta"@es ;
    ex:textoExtracto "1 ; Coger una herramienta del almacén y ponerla en el cabezal... $CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén."@es ;
    ex:identificador "M06" .

ex:SubrutinaSUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_AUTCHG" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:SubrutinaSUB_MZ_TO_SPD a ex:TareaMantenimiento ;
    rdfs:label "SUB_MZ_TO_SPD" ;
    ex:textoExtracto "LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal."@es ;
    ex:identificador "SUB_MZ_TO_SPD" .

ex:SubrutinaSUB_SPD_TO_MZ a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_MZ" ;
    ex:textoExtracto "LL SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén."@es ;
    ex:identificador "SUB_SPD_TO_MZ" .

ex:SubrutinaSUB_SPD_GMCHG a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_GMCHG" ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es ;
    ex:identificador "SUB_SPD_GMCHG" .

ex:SubrutinaSUB_GR_TO_SPD a ex:TareaMantenimiento ;
    rdfs:label "SUB_GR_TO_SPD" ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."@es ;
    ex:identificador "SUB_GR_TO_SPD" .

ex:SubrutinaSUB_SPD_TO_GR a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_GR" ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es ;
    ex:identificador "SUB_SPD_TO_GR" .

ex:Herramienta a ex:Herramienta ;
    rdfs:label "Herramienta genérica"@es ;
    ex:textoExtracto "Coger una herramienta del almacén..."@es .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "Colocar la herramienta de tierra en el cabezal..."@es .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ex:textoExtracto "ponerla en el cabezal... Dejar la herramienta del cabezal..."@es .

ex:PuntoCambioAutomatico a ex:InterfazUsuario ;
    rdfs:label "Punto de cambio automático"@es ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio automático."@es .

ex:PuntoCambioManual a ex:InterfazUsuario ;
    rdfs:label "Punto de cambio manual"@es ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio manual."@es .

ex:AlmacenHerramientas a ex:Sistema ;
    rdfs:label "Almacén de herramientas"@es ;
    ex:textoExtracto "Coger una herramienta del almacén... Dejar la herramienta del cabezal en el almacén."@es .

ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_SPD_AUTCHG .
ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_MZ_TO_SPD .
ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_SPD_TO_MZ .
ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_SPD_GMCHG .
ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_GR_TO_SPD .
ex:RutinaM06 ex:requiereMantenimiento ex:SubrutinaSUB_SPD_TO_GR .

ex:SubrutinaSUB_SPD_AUTCHG ex:ejecutadoPor ex:Cabezal .
ex:SubrutinaSUB_MZ_TO_SPD ex:ejecutadoPor ex:Cabezal .
ex:SubrutinaSUB_SPD_TO_MZ ex:ejecutadoPor ex:Cabezal .
ex:SubrutinaSUB_SPD_GMCHG ex:ejecutadoPor ex:Cabezal .
ex:SubrutinaSUB_GR_TO_SPD ex:ejecutadoPor ex:Cabezal .
ex:SubrutinaSUB_SPD_TO_GR ex:ejecutadoPor ex:Cabezal .

ex:Cabezal ex:tieneFrecuencia ex:PuntoCambioAutomatico .
ex:Cabezal ex:tieneFrecuencia ex:PuntoCambioManual .

ex:Herramienta ex:requiereMantenimiento ex:RutinaM06 .
ex:HerramientaTierra ex:requiereMantenimiento ex:RutinaM06 .

ex:AlmacenHerramientas ex:tieneComponente ex:Herramienta .