@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_alEmergenciaGestor
    a ex:Sensor ;
    rdfs:label "Señal de emergencia del gestor"@es ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas."@es ;
    ex:identificador "TMINEM" .

ex:AlarmaEmergencia
    a ex:Alarma ;
    rdfs:label "Emergencia del sistema"@es ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia."@es ;
    ex:activaAlarma ex:Se_alEmergenciaGestor .

ex:TeclaUSER12
    a ex:InterfazUsuario ;
    rdfs:label "Tecla USER12"@es ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia."@es ;
    ex:identificador "USER12" ;
    ex:controla ex:AlarmaEmergencia .

ex:L_mparaTeclaUSER12
    a ex:InterfazUsuario ;
    rdfs:label "Lámpara de la tecla USER12"@es ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia."@es ;
    ex:identificador "B11KEYLED1" ;
    ex:monitoreaParametro ex:Se_alEmergenciaGestor .

ex:TeclaUSER13
    a ex:InterfazUsuario ;
    rdfs:label "Tecla USER13"@es ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia."@es ;
    ex:identificador "USER13" ;
    ex:controla ex:AlarmaEmergencia .