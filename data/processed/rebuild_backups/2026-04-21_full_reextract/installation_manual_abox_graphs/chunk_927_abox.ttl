@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesGestorHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas"@es ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes."@es ;
    ex:ilustradoEn ex:Pagina_503_504 .

ex:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores de registros TAKEPOS y LEAVEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores."@es ;
    ex:ilustradoEn ex:Pagina_503_504 .

ex:Operacion_TMOPERATION_0
    a ex:ModoOperacion ;
    ex:identificador "0" ;
    rdfs:label "TMOPERATION 0" ;
    ex:textoExtracto "0 | No hay que hacer nada."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_1
    a ex:ModoOperacion ;
    ex:identificador "1" ;
    rdfs:label "TMOPERATION 1" ;
    ex:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_2
    a ex:ModoOperacion ;
    ex:identificador "2" ;
    rdfs:label "TMOPERATION 2" ;
    ex:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_3
    a ex:ModoOperacion ;
    ex:identificador "3" ;
    rdfs:label "TMOPERATION 3" ;
    ex:textoExtracto "3 | Poner en el cabezal una herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_4
    a ex:ModoOperacion ;
    ex:identificador "4" ;
    rdfs:label "TMOPERATION 4" ;
    ex:textoExtracto "4 | Dejar la herramienta del cabezal en tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_5
    a ex:ModoOperacion ;
    ex:identificador "5" ;
    rdfs:label "TMOPERATION 5" ;
    ex:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_6
    a ex:ModoOperacion ;
    ex:identificador "6" ;
    rdfs:label "TMOPERATION 6" ;
    ex:textoExtracto "6 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_7
    a ex:ModoOperacion ;
    ex:identificador "7" ;
    rdfs:label "TMOPERATION 7" ;
    ex:textoExtracto "7 | Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_8
    a ex:ModoOperacion ;
    ex:identificador "8" ;
    rdfs:label "TMOPERATION 8" ;
    ex:textoExtracto "8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_9
    a ex:ModoOperacion ;
    ex:identificador "9" ;
    rdfs:label "TMOPERATION 9" ;
    ex:textoExtracto "9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_10
    a ex:ModoOperacion ;
    ex:identificador "10" ;
    rdfs:label "TMOPERATION 10" ;
    ex:textoExtracto "10 | Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_11
    a ex:ModoOperacion ;
    ex:identificador "11" ;
    rdfs:label "TMOPERATION 11" ;
    ex:textoExtracto "11 | Orientar el almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_13
    a ex:ModoOperacion ;
    ex:identificador "13" ;
    rdfs:label "TMOPERATION 13" ;
    ex:textoExtracto "13 | Orientar dos almacenes."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_14
    a ex:ModoOperacion ;
    ex:identificador "14" ;
    rdfs:label "TMOPERATION 14" ;
    ex:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es ;
    ex:documentadoEn ex:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es ;
    ex:documentadoEn ex:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS .

ex:Valor_TAKEPOS_LEAVEPOS_0
    a ex:Parametro ;
    ex:identificador "0" ;
    ex:valor "0" ;
    rdfs:label "Valor 0 (TAKEPOS/LEAVEPOS)" ;
    ex:textoExtracto "0 | No hay que hacer nada."@es ;
    ex:documentadoEn ex:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS .

ex:Valor_TAKEPOS_LEAVEPOS_Menos4
    a ex:Parametro ;
    ex:identificador "-4" ;
    ex:valor "-4" ;
    rdfs:label "Valor -4 (Herramienta de tierra)" ;
    ex:textoExtracto "-4 | Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_ValoresRegistrosTAKEPOS_LEAVEPOS .