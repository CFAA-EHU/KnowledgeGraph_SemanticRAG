@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesPLC_791 a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de operaciones válidas y marcas PLC (Sección 7.9.1)"@es ;
    ex:textoExtracto        "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación. En el caso de las marcas que aparecen entre paréntesis, el gestor puede ejecutar las operaciones en cualquier orden, pero siempre debe ejecutar ambas."@es ;
    ex:identificador        "7.9.1" .

ex:HerramientaTierra_AlmacenPos4
    a                       ex:Herramienta ;
    rdfs:label              "Herramienta de tierra (Posición -4)"@es ;
    ex:textoExtracto        "Herramienta de tierra."@es ;
    ex:identificador         "-4" ;
    ex:documentadoEn        ex:Tabla_OperacionesPLC_791 .