PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosAlmacen_7_9_2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de posición en almacén (Sección 7.9.2)"@es ;
    ex:textoExtracto """
| Valor | Significado |
| --- | --- |
| 0 | No hay que hacer nada. |
| # | Posición en el almacén. |
| -4 | Herramienta de tierra. """@es ;
    ex:ilustradoEn ex:Pagina_505_506_507 .

ex:HerramientaTierra_Almacen
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra (código -4)"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "-4: Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_CodigosAlmacen_7_9_2 .