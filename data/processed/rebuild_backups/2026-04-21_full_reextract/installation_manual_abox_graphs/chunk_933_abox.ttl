@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Pinza_1
    a               ex:Actuador ;
    rdfs:label      "Pinza 1" ;
    ex:textoExtracto
        "pinza ꞏ1ꞏ"@es .

ex:HerramientaDeTierra
    a               ex:Herramienta ;
    rdfs:label      "Herramienta de tierra" ;
    ex:textoExtracto
        "Herramienta de tierra"@es .

ex:Operacion_Almacen_6
    a               ex:TareaMantenimiento ;
    rdfs:label      "Operación 6: Cambio de herramienta a herramienta de tierra" ;
    ex:identificador "TMOPERATION = 6" ;
    ex:textoExtracto
        "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta."@es ;
    ex:ejecutadoPor ex:Pinza_1 ;
    ex:requiereMantenimiento ex:HerramientaDeTierra .

ex:SecuenciaAlternativa_1_3_2
    a               ex:ModoOperacion ;
    rdfs:label      "Secuencia alternativa 1-3-2" ;
    ex:textoExtracto
        "El gestor también admite la secuencia 1-3-2."@es .