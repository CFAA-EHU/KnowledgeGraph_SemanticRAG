@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_935 a ex:TareaMantenimiento ;
    rdfs:label "Operación de transferencia de herramienta (TMOPERATION=10)"@es ;
    ex:textoExtracto "La secuencia de esta operación es la siguiente. [...] TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es ;
    ex:identificador "TMOPERATION=10" ;
    ex:requiereMantenimiento ex:Herramienta_935_1 ;
    ex:ejecutadoPor ex:Pinza_1 .

ex:Herramienta_935_1 a ex:Herramienta ;
    rdfs:label "Herramienta genérica de almacén"@es ;
    ex:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ex:Pinza_1 a ex:ComponenteMecanico ;
    rdfs:label "Pinza ꞏ1ꞏ"@es ;
    ex:textoExtracto "Coger la herramienta [...] con la pinza ꞏ1ꞏ"@es ;
    ex:identificador "1" .

ex:Cabezal_935 a ex:ComponenteMecanico ;
    rdfs:label "Cabezal de transferencia"@es ;
    ex:textoExtracto "Poner la herramienta de tierra en el cabezal [...] Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es .

ex:PosicionAlmacen_TAKEPOS a ex:Parametro ;
    rdfs:label "Posición de recogida en almacén (TAKEPOS)"@es ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ex:identificador "TAKEPOS" .

ex:PosicionTierra_LEAVEPOS a ex:Parametro ;
    rdfs:label "Posición de herramienta en tierra (LEAVEPOS=-4)"@es ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra."@es ;
    ex:identificador "LEAVEPOS" ;
    ex:valor "-4" .

ex:Marca_GRTOSPDL a ex:InterfazUsuario ;
    rdfs:label "Marca GRTOSPDL"@es ;
    ex:textoExtracto "activar la marca GRTOSPDL"@es ;
    ex:identificador "GRTOSPDL" .

ex:Marca_SPDLTOCH1 a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOCH1"@es ;
    ex:textoExtracto "activar la marca SPDLTOCH1"@es ;
    ex:identificador "SPDLTOCH1" .

ex:Marca_CH1TOMZ a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOMZ"@es ;
    ex:textoExtracto "activar la marca CH1TOMZ"@es ;
    ex:identificador "CH1TOMZ" .

ex:Marca_MZTOCH1 a ex:InterfazUsuario ;
    rdfs:label "Marca MZTOCH1"@es ;
    ex:textoExtracto "activar la marca MZTOCH1"@es ;
    ex:identificador "MZTOCH1" .