@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_937 a ex:ModoOperacion ;
    rdfs:label "Operación de intercambio de herramientas en almacén"@es ;
    ex:textoExtracto "La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1. 2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ. 3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es ;
    ex:identificador "7.9.2" .

ex:Pinza_1 a ex:Actuador ;
    rdfs:label "Pinza 1"@es ;
    ex:textoExtracto "pinza ꞏ1ꞏ"@es ;
    ex:identificador "1" .

ex:Herramienta_Cabezal a ex:Herramienta ;
    rdfs:label "Herramienta del cabezal"@es ;
    ex:textoExtracto "la herramienta del cabezal"@es .

ex:Herramienta_Almacen1 a ex:Herramienta ;
    rdfs:label "Herramienta del almacén (primera posición)"@es ;
    ex:textoExtracto "la herramienta de la pinza ꞏ1ꞏ en el almacén"@es .

ex:Herramienta_Almacen2 a ex:Herramienta ;
    rdfs:label "Herramienta del otro almacén"@es ;
    ex:textoExtracto "la herramienta del otro almacén"@es .

ex:Marca_SPDLTOCH1 a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOCH1"@es ;
    ex:textoExtracto "activar la marca SPDLTOCH1"@es ;
    ex:identificador "SPDLTOCH1" .

ex:Marca_CH1TOMZ a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOMZ"@es ;
    ex:textoExtracto "activar la marca CH1TOMZ"@es ;
    ex:identificador "CH1TOMZ" .

ex:Marca_MZTOCH1 a ex:InterfazUsuario ;
    rdfs:label "Marca MZTOCH1"@es ;
    ex:textoExtracto "activar la marca MZTOCH1"@es ;
    ex:identificador "MZTOCH1" .

ex:Marca_CH1TOSPDL a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOSPDL"@es ;
    ex:textoExtracto "activar la marca CH1TOSPDL"@es ;
    ex:identificador "CH1TOSPDL" .

ex:OperacionAlmacen_937 ex:ejecutadoPor ex:Pinza_1 ;
    ex:controla ex:Marca_SPDLTOCH1, ex:Marca_CH1TOMZ, ex:Marca_MZTOCH1, ex:Marca_CH1TOSPDL .