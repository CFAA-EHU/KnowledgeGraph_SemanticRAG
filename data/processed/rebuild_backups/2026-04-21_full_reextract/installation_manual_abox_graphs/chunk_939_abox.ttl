@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06
    a               ex:TareaMantenimiento ;
    rdfs:label      "Rutina M06 - Cambio de herramienta"@es ;
    ex:textoExtracto """
    %L SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.
    %L SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.
    %L SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1.
    %L SUB_CH1_TO_MZ ; Llevar la herramienta de la pinza 1 al almacén.
    %L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).
    %L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."""@es ;
    ex:identificador "M06" ;
    ex:requiereMantenimiento ex:Pinza1 .

ex:Pinza1
    a               ex:Actuador ;
    rdfs:label      "Pinza 1"@es ;
    ex:textoExtracto """
    Coger la herramienta del almacén con la pinza 1.
    Llevar la herramienta de la pinza 1 al cabezal.
    Coger la herramienta del cabezal con la pinza 1.
    Llevar la herramienta de la pinza 1 al almacén."""@es ;
    ex:identificador "Pinza 1" .

ex:MensajeOperario_ExtraerHerramienta
    a               ex:InterfazUsuario ;
    rdfs:label      "Mensaje: Extraer herramienta T%D y pulsar MARCHA"@es ;
    ex:textoExtracto """
    # MSG ["Extraer herramienta T%D y pulsar MARCHA", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta."""@es .

ex:MensajeOperario_InsertarHerramienta
    a               ex:InterfazUsuario ;
    rdfs:label      "Mensaje: Insertar herramienta T%D y pulsar MARCHA"@es ;
    ex:textoExtracto """
    # MSG ["Insertar herramienta T%D y pulsar MARCHA", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta."""@es .

ex:VariablePLC_M1101
    a               ex:Parametro ;
    rdfs:label      "Variable PLC M[1101] (Marca MZTOCH1)"@es ;
    ex:textoExtracto "V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor."@es ;
    ex:valor         "1" ;
    ex:identificador "M[1101]" .

