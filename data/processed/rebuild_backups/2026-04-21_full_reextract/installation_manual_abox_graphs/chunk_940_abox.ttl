@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Mensaje_InsercionHerramientaT_D
    a               ex:InterfazUsuario ;
    rdfs:label      "Mensaje inserción herramienta T%D"@es ;
    ex:textoExtracto "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta."@es ;
    ex:identificador "V.TM.NXTOOL" .

ex:Rutina_M06_CambioHerramienta
    a               ex:TareaMantenimiento ;
    rdfs:label      "Rutina M06 (Cambio de herramienta)"@es ;
    ex:textoExtracto "M06 ; Orden al gestor para comenzar el cambio de herramienta."@es ;
    ex:identificador "M06" ;
    ex:requiereMantenimiento ex:Sistema_Cabezal_Desplazamiento .

ex:Sistema_Cabezal_Desplazamiento
    a               ex:Sistema ;
    rdfs:label      "Sistema de desplazamiento del cabezal"@es ;
    ex:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal."@es ;
    ex:compuestoPor  ex:Parametro_Velocidad_Desplazamiento .

ex:Parametro_Velocidad_Desplazamiento
    a               ex:Parametro ;
    rdfs:label      "Parámetro de velocidad (F_)"@es ;
    ex:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal."@es ;
    ex:identificador "F_" .

ex:Subrutina_SPD_GMCHG
    a               ex:ModoOperacion ;
    rdfs:label      "Subrutina SPD_GMCHG (Cambio manual)"@es ;
    ex:textoExtracto "RET %L SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es ;
    ex:identificador "SUB_SPD_GMCHG" .

ex:Subrutina_SPD_AUTCHG
    a               ex:ModoOperacion ;
    rdfs:label      "Subrutina SPD_AUTCHG (Cambio automático)"@es ;
    ex:textoExtracto "RET %L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:Condicion_EjecucionSimulada
    a               ex:Parametro ;
    rdfs:label      "Condición de ejecución simulada (V.S.EXECUTION)"@es ;
    ex:textoExtracto "$IF [[[V.G.FULLSTATUS & 255]<9] | [[V.G.FULLSTATUS & 255]>13]] $IF [[V.G.CNCAUTSTATUS & 4096] | [V.G.CNCAUTSTATUS & 8192]] V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G."@es ;
    ex:identificador "V.S.EXECUTION" ;
    ex:valor         "0" .