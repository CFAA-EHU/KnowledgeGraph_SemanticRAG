@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_Caso5
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 5: Cambio de herramienta en almacén" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." ;
    ex:identificador "CASE 5" .

ex:RutinaM06_Caso6
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 6: Cambio de herramienta a tierra" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger otra de tierra." ;
    ex:identificador "CASE 6" .

ex:Subrutina_SPD_TO_GR
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_TO_GR" ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." ;
    ex:identificador "SUB_SPD_TO_GR" .

ex:Subrutina_SPD_AUTCHG
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_AUTCHG" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:Subrutina_SPD_TO_CH1
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_TO_CH1" ;
    ex:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1." ;
    ex:identificador "SUB_SPD_TO_CH1" .

ex:Subrutina_CH1_TO_MZ
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina CH1_TO_MZ" ;
    ex:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén." ;
    ex:identificador "SUB_CH1_TO_MZ" .

ex:Subrutina_MZ_TO_CH1
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina MZ_TO_CH1" ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." ;
    ex:identificador "SUB_MZ_TO_CH1" .

ex:Subrutina_CH1_TO_SPD
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina CH1_TO_SPD" ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:identificador "SUB_CH1_TO_SPD" .

ex:Pinza1
    a ex:Actuador ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza 1." .

ex:AlmacenHerramientas
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." .

ex:Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ex:textoExtracto "Quitar la herramienta del cabezal." .

ex:PuntoCambioAutomatico
    a ex:InterfazUsuario ;
    rdfs:label "Punto de cambio automático" ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio automático." .

# Relaciones entre tareas y componentes
ex:RutinaM06_Caso5
    ex:requiereMantenimiento ex:Subrutina_SPD_TO_GR ;
    ex:requiereMantenimiento ex:Subrutina_SPD_AUTCHG ;
    ex:requiereMantenimiento ex:Subrutina_SPD_TO_CH1 ;
    ex:requiereMantenimiento ex:Subrutina_CH1_TO_MZ ;
    ex:requiereMantenimiento ex:Subrutina_MZ_TO_CH1 ;
    ex:requiereMantenimiento ex:Subrutina_CH1_TO_SPD .

ex:RutinaM06_Caso6
    ex:requiereMantenimiento ex:Subrutina_SPD_AUTCHG ;
    ex:requiereMantenimiento ex:Subrutina_SPD_TO_CH1 ;
    ex:requiereMantenimiento ex:Subrutina_CH1_TO_MZ .

ex:Subrutina_SPD_TO_CH1
    ex:ejecutadoPor ex:Pinza1 ;
    ex:tieneComponente ex:Cabezal .

ex:Subrutina_CH1_TO_MZ
    ex:ejecutadoPor ex:Pinza1 ;
    ex:tieneComponente ex:AlmacenHerramientas .

ex:Subrutina_MZ_TO_CH1
    ex:ejecutadoPor ex:Pinza1 ;
    ex:tieneComponente ex:AlmacenHerramientas .

ex:Subrutina_CH1_TO_SPD
    ex:ejecutadoPor ex:Pinza1 ;
    ex:tieneComponente ex:Cabezal .

ex:Subrutina_SPD_AUTCHG
    ex:tieneComponente ex:PuntoCambioAutomatico .