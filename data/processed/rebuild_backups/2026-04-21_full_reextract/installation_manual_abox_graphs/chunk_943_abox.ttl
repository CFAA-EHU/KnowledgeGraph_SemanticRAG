@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Programa de cambio de herramientas" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1. [...] LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén." ;
    ex:identificador "M06" .

ex:PuntoCambioAutomatico a ex:ComponenteMecanico ;
    rdfs:label "Punto de cambio automático de herramientas" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:PuntoCambioManual a ex:ComponenteMecanico ;
    rdfs:label "Punto de cambio manual de herramientas" ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1." .

ex:AlmacenHerramientas a ex:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén." .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal de máquina" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:RutinaM06 ex:ejecutadoPor ex:Cabezal ;
             ex:tieneComponente ex:PuntoCambioAutomatico, ex:PuntoCambioManual, ex:Pinza1, ex:AlmacenHerramientas ;
             ex:requiereMantenimiento ex:HerramientaTierra .