@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesGestorHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas (TMOPERATION)"@es ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | [...] | 14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es ;
    ex:identificador "TMOPERATION" .

ex:ModoOperacion_0
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=0 (No acción)"@es ;
    ex:textoExtracto "0 | No hay que hacer nada."@es ;
    ex:identificador "0" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_1
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=1 (Coger herramienta del almacén)"@es ;
    ex:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal."@es ;
    ex:identificador "1" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_2
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=2 (Dejar herramienta en almacén)"@es ;
    ex:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén."@es ;
    ex:identificador "2" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_3
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=3 (Poner herramienta de tierra)"@es ;
    ex:textoExtracto "3 | Poner en el cabezal una herramienta de tierra."@es ;
    ex:identificador "3" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_4
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=4 (Dejar herramienta en tierra)"@es ;
    ex:textoExtracto "4 | Dejar la herramienta del cabezal en tierra."@es ;
    ex:identificador "4" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_5
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=5 (Intercambio en almacén)"@es ;
    ex:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén."@es ;
    ex:identificador "5" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_12
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=12 (Intercambio optimizado en almacén síncrono)"@es ;
    ex:textoExtracto "12 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada válida sólo en los siguientes tipos de almacén síncrono: • Tipo no-random con brazo cambiador de dos pinzas. • Tipo random cuando se trata de herramientas especiales."@es ;
    ex:identificador "12" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_14
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=14 (Intercambio entre almacenes)"@es ;
    ex:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es ;
    ex:identificador "14" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Registro TAKEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es ;
    ex:identificador "TAKEPOS" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Registro LEAVEPOS"@es ;
    ex:textoExtracto "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores."@es ;
    ex:identificador "LEAVEPOS" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .