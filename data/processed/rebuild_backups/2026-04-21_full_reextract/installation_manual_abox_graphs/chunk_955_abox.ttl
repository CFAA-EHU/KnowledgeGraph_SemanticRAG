@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionTM1
    a ex:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén y ponerla en el cabezal" ;
    ex:textoExtracto "TMOPERATION = 1 Coger una herramienta del almacén y ponerla en el cabezal." ;
    ex:identificador "TMOPERATION=1" ;
    ex:requiereMantenimiento ex:Pinza1 .

ex:OperacionTM2
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en el almacén" ;
    ex:textoExtracto "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén." ;
    ex:identificador "TMOPERATION=2" ;
    ex:requiereMantenimiento ex:Pinza2 .

ex:OperacionTM3
    a ex:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en el cabezal" ;
    ex:textoExtracto "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra." ;
    ex:identificador "TMOPERATION=3" .

ex:OperacionTM4
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en tierra" ;
    ex:textoExtracto "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra." ;
    ex:identificador "TMOPERATION=4" .

ex:OperacionTM5
    a ex:TareaMantenimiento ;
    rdfs:label "Intercambiar herramienta entre cabezal y almacén" ;
    ex:textoExtracto "TMOPERATION = 5 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." ;
    ex:identificador "TMOPERATION=5" ;
    ex:requiereMantenimiento ex:Pinza1, ex:Pinza2 .

ex:Pinza1
    a ex:Actuador ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "pinza ꞏ1ꞏ" ;
    ex:identificador "pinza-1" .

ex:Pinza2
    a ex:Actuador ;
    rdfs:label "Pinza 2" ;
    ex:textoExtracto "pinza ꞏ2ꞏ" ;
    ex:identificador "pinza-2" .

ex:MarcaMZTOCH1
    a ex:Sensor ;
    rdfs:label "Marca MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1" ;
    ex:identificador "MZTOCH1" .

ex:MarcaCH1TOSPDL
    a ex:Sensor ;
    rdfs:label "Marca CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" ;
    ex:identificador "CH1TOSPDL" .

ex:MarcaSPDLTOCH2
    a ex:Sensor ;
    rdfs:label "Marca SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2" ;
    ex:identificador "SPDLTOCH2" .

ex:MarcaCH2TOMZ
    a ex:Sensor ;
    rdfs:label "Marca CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ" ;
    ex:identificador "CH2TOMZ" .

ex:MarcaGRTOSPDL
    a ex:Sensor ;
    rdfs:label "Marca GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" ;
    ex:identificador "GRTOSPDL" .

ex:MarcaSPDLTOGR
    a ex:Sensor ;
    rdfs:label "Marca SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" ;
    ex:identificador "SPDLTOGR" .

ex:OperacionTM1
    ex:controla ex:MarcaMZTOCH1, ex:MarcaCH1TOSPDL .

ex:OperacionTM2
    ex:controla ex:MarcaSPDLTOCH2, ex:MarcaCH2TOMZ .

ex:OperacionTM3
    ex:controla ex:MarcaGRTOSPDL .

ex:OperacionTM4
    ex:controla ex:MarcaSPDLTOGR .

ex:OperacionTM5
    ex:controla ex:MarcaSPDLTOCH2, ex:MarcaMZTOCH1, ex:MarcaCH2TOMZ .