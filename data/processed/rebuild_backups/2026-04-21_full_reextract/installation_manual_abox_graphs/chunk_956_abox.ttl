@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Pinza_1
    a ex:Actuador ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1."@es ;
    ex:identificador "1" .

ex:Pinza_2
    a ex:Actuador ;
    rdfs:label "Pinza 2" ;
    ex:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ."@es ;
    ex:identificador "2" .

ex:Herramienta_Tierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ex:textoExtracto "TAKEPOS=-4 Herramienta de tierra."@es .

ex:Almacen_Herramientas
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es .

ex:Operacion_Almacen_7_10_2
    a ex:TareaMantenimiento ;
    rdfs:label "Operación de intercambio de herramientas en almacén (7.10.2)" ;
    ex:textoExtracto "La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2."@es ;
    ex:ejecutadoPor ex:Pinza_1, ex:Pinza_2 ;
    ex:requiereMantenimiento ex:Herramienta_Tierra .

ex:Marca_MZTOCH1
    a ex:InterfazUsuario ;
    rdfs:label "Marca MZTOCH1" ;
    ex:textoExtracto "Activar la marca MZTOCH1."@es ;
    ex:identificador "MZTOCH1" .

ex:Marca_CH2TOMZ
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH2TOMZ" ;
    ex:textoExtracto "Activar la marca CH2TOMZ."@es ;
    ex:identificador "CH2TOMZ" .

ex:Marca_CH1TOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOSPDL" ;
    ex:textoExtracto "Activar la marca CH1TOSPDL."@es ;
    ex:identificador "CH1TOSPDL" .

ex:Operacion_Almacen_7_10_2
    ex:controla ex:Marca_MZTOCH1, ex:Marca_CH2TOMZ, ex:Marca_CH1TOSPDL ;
    ex:tieneComponente ex:Almacen_Herramientas .