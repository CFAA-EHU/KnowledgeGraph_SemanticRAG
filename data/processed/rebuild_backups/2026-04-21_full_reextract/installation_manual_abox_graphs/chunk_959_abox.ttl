@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Operacion_DejarHerramientaEnTierra_959
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta de tierra (LEAVEPOS=-4)"@es ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL. 3 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR."@es ;
    ex:identificador "LEAVEPOS=-4" ;
    ex:ejecutadoPor ex:Pinza_1 .

ex:Pinza_1
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1"@es ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1."@es ;
    ex:identificador "ꞏ1ꞏ" .

ex:Marca_MZTOCH1
    a ex:InterfazUsuario ;
    rdfs:label "Marca MZTOCH1"@es ;
    ex:textoExtracto "activar la marca MZTOCH1"@es ;
    ex:identificador "MZTOCH1" .

ex:Marca_CH1TOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOSPDL"@es ;
    ex:textoExtracto "activar la marca CH1TOSPDL"@es ;
    ex:identificador "CH1TOSPDL" .

ex:Marca_SPDLTOGR
    a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOGR"@es ;
    ex:textoExtracto "activar la marca SPDLTOGR"@es ;
    ex:identificador "SPDLTOGR" .

ex:Operacion_OrientarAlmacen_959
    a ex:ModoOperacion ;
    rdfs:label "Orientar almacén (TMOPERATION=11)"@es ;
    ex:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado. Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no."@es ;
    ex:identificador "TMOPERATION=11" .

ex:Marca_MZROT
    a ex:InterfazUsuario ;
    rdfs:label "Marca MZROT"@es ;
    ex:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación"@es ;
    ex:identificador "MZROT" .

ex:Operacion_CambioHerramientaOptimizado_959
    a ex:ModoOperacion ;
    rdfs:label "Cambio de herramienta optimizado (TMOPERATION=12)"@es ;
    ex:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo en los siguientes tipos de almacén síncrono: • Tipo no-random con brazo cambiador de dos pinzas. • Tipo random cuando se trata de herramientas especiales."@es ;
    ex:identificador "TMOPERATION=12" .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro TAKEPOS"@es ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ex:identificador "TAKEPOS" ;
    ex:valor "#" .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro LEAVEPOS"@es ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es ;
    ex:identificador "LEAVEPOS" ;
    ex:valor "#" .

ex:Operacion_OrientarDosAlmacenes_959
    a ex:ModoOperacion ;
    rdfs:label "Orientar dos almacenes (TMOPERATION=13)"@es ;
    ex:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado. Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no."@es ;
    ex:identificador "TMOPERATION=13" .

ex:Parametro_NEXTPOS
    a ex:Parametro ;
    rdfs:label "Parámetro NEXTPOS"@es ;
    ex:textoExtracto "NEXTPOS=# Posición del almacén para dejar la herramienta."@es ;
    ex:identificador "NEXTPOS" ;
    ex:valor "#" .

ex:Parametro_MZID
    a ex:Parametro ;
    rdfs:label "Parámetro MZID"@es ;
    ex:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es ;
    ex:identificador "MZID" .

ex:Operacion_CambioHerramientaEntreAlmacenes_959
    a ex:ModoOperacion ;
    rdfs:label "Cambio de herramienta entre almacenes (TMOPERATION=14)"@es ;
    ex:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es ;
    ex:identificador "TMOPERATION=14" .