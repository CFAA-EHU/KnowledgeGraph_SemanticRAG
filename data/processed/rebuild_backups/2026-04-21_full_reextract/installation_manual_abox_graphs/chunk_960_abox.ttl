@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionTM14
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Dejar herramienta en almacén y coger otra"@es ;
    ex:textoExtracto      "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es ;
    ex:identificador      "TMOPERATION=14" ;
    ex:requiereMantenimiento ex:SistemaAlmacenamientoHerramientas .

ex:SistemaAlmacenamientoHerramientas
    a                     ex:Sistema ;
    rdfs:label            "Sistema de almacenamiento de herramientas"@es ;
    ex:textoExtracto      "LEAVEPOS=# Posición del almacén para dejar la herramienta. TAKEPOS=# Posición del almacén para coger la herramienta. MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es .

ex:ParametroTAKEPOS
    a                     ex:Parametro ;
    rdfs:label            "Posición de recogida de herramienta (TAKEPOS)"@es ;
    ex:textoExtracto      "TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ex:identificador      "TAKEPOS" ;
    ex:monitoreaParametro ex:SistemaAlmacenamientoHerramientas .

ex:ParametroLEAVEPOS
    a                     ex:Parametro ;
    rdfs:label            "Posición de depósito de herramienta (LEAVEPOS)"@es ;
    ex:textoExtracto      "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es ;
    ex:identificador      "LEAVEPOS" ;
    ex:monitoreaParametro ex:SistemaAlmacenamientoHerramientas .

ex:ParametroMZID
    a                     ex:Parametro ;
    rdfs:label            "Identificador de almacén origen/destino (MZID)"@es ;
    ex:textoExtracto      "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es ;
    ex:identificador      "MZID" ;
    ex:monitoreaParametro ex:SistemaAlmacenamientoHerramientas .