@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ComunicacionPLC_M06 a ex:Sistema ;
    ex:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos. En el programa de la subrutina M06 que se ofrece como ejemplo se han utilizado las siguientes marcas y registros."@es ;
    rdfs:label "Sistema de comunicación PLC-M06"@es .

### Marcas de la rutina M06 (activadas hacia PLC)
ex:Marca_M1101 a ex:ComponenteElectrico ;
    ex:identificador "M1101" ;
    ex:textoExtracto "M1101 | MZTOCH1: La herramienta se ha llevado del almacén a la pinza 1."@es ;
    rdfs:label "Marca M1101 (MZTOCH1)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1102 a ex:ComponenteElectrico ;
    ex:identificador "M1102" ;
    ex:textoExtracto "M1102 | CH1TOSPDL: La herramienta se ha llevado de la pinza 1 al cabezal."@es ;
    rdfs:label "Marca M1102 (CH1TOSPDL)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1104 a ex:ComponenteElectrico ;
    ex:identificador "M1104" ;
    ex:textoExtracto "M1104 | SPDLTOCH2: La herramienta se ha llevado del cabezal a la pinza 2."@es ;
    rdfs:label "Marca M1104 (SPDLTOCH2)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1106 a ex:ComponenteElectrico ;
    ex:identificador "M1106" ;
    ex:textoExtracto "M1106 | CH2TOMZ: La herramienta se ha llevado de la pinza 2 al almacén."@es ;
    rdfs:label "Marca M1106 (CH2TOMZ)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1107 a ex:ComponenteElectrico ;
    ex:identificador "M1107" ;
    ex:textoExtracto "M1107 | SPDLTOGR: La herramienta se ha llevado del cabezal a tierra."@es ;
    rdfs:label "Marca M1107 (SPDLTOGR)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Marca_M1108 a ex:ComponenteElectrico ;
    ex:identificador "M1108" ;
    ex:textoExtracto "M1108 | GRTOSPDL: La herramienta se ha llevado de tierra al cabezal."@es ;
    rdfs:label "Marca M1108 (GRTOSPDL)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

### Funciones M del PLC (movimientos controlados)
ex:Funcion_M101 a ex:ComponenteElectrico ;
    ex:identificador "M101" ;
    ex:textoExtracto "M101: Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1."@es ;
    rdfs:label "Función M101 (Selección y toma de herramienta)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Funcion_M102 a ex:ComponenteElectrico ;
    ex:identificador "M102" ;
    ex:textoExtracto "M102: Llevar la herramienta de la pinza 1 al cabezal."@es ;
    rdfs:label "Función M102 (Transferencia pinza 1 → cabezal)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Funcion_M104 a ex:ComponenteElectrico ;
    ex:identificador "M104" ;
    ex:textoExtracto "M104: Coger la herramienta del cabezal con la pinza 2."@es ;
    rdfs:label "Función M104 (Toma de herramienta con pinza 2)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

ex:Funcion_M106 a ex:ComponenteElectrico ;
    ex:identificador "M106" ;
    ex:textoExtracto "M106: Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2."@es ;
    rdfs:label "Función M106 (Dejar herramienta en almacén)"@es ;
    ex:compuestoPor ex:ComunicacionPLC_M06 .

### Tabla de referencia (ancla para las marcas/funciones)
ex:Tabla_MarcasFunciones_M06 a ex:Tabla ;
    ex:textoExtracto "Tabla de marcas (M1101-M1108) y funciones M (M101-M106) utilizadas en la comunicación entre la rutina M06 y el PLC."@es ;
    rdfs:label "Tabla de marcas y funciones M06-PLC"@es ;
    ex:documentadoEn ex:ComunicacionPLC_M06 .

ex:ComunicacionPLC_M06 ex:detalladoEnEsquema ex:Tabla_MarcasFunciones_M06 .