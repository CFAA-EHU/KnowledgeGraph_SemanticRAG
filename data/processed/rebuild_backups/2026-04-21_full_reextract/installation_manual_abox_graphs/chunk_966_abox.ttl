@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_CambioHerramienta
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Rutina M06: Cambio de herramienta en cabezal"@es ;
    ex:textoExtracto       "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] $CASE 6 ; Dejar la herramienta del cabezal en el almacén y coger otra de tierra."@es ;
    ex:identificador       "M06" ;
    ex:requiereMantenimiento ex:SistemaCambioAutomaticoHerramientas .

ex:SistemaCambioAutomaticoHerramientas
    a                     ex:Sistema ;
    rdfs:label            "Sistema de cambio automático de herramientas"@es ;
    ex:textoExtracto       "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:tieneComponente     ex:CabezalM06 ,
                            ex:Pinza1 ,
                            ex:Pinza2 ,
                            ex:AlmacenHerramientas .

ex:CabezalM06
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Cabezal de máquina (Rutina M06)"@es ;
    ex:textoExtracto       "Quitar la herramienta del cabezal [...] Llevar el cabezal al punto de cambio automático."@es .

ex:Pinza1
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Pinza 1 (cambio de herramientas)"@es ;
    ex:textoExtracto       "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal."@es .

ex:Pinza2
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Pinza 2 (cambio de herramientas)"@es ;
    ex:textoExtracto       "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén."@es .

ex:AlmacenHerramientas
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Almacén de herramientas"@es ;
    ex:textoExtracto       "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén."@es .