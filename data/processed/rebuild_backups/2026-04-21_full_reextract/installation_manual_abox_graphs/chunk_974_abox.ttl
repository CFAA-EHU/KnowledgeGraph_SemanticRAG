@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesGestorHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas (TMOPERATION)"@es ;
    ex:textoExtracto """
    Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes.
    | TMOPERATION | Significado. |
    | --- | --- |
    | 0 | No hay que hacer nada.
    | 1 | Coger una herramienta del brazo y ponerla en el cabezal.
    ...
    | 16 | Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén."""@es ;
    ex:identificador "TMOPERATION" .

ex:ModoOperacion_TM0
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=0 (Inacción)"@es ;
    ex:textoExtracto "No hay que hacer nada."@es ;
    ex:identificador "0" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_TM1
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=1 (Brazo → Cabezal)"@es ;
    ex:textoExtracto "Coger una herramienta del brazo y ponerla en el cabezal."@es ;
    ex:identificador "1" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas ;
    ex:requiereMantenimiento ex:TareaMantenimiento_TransporteHerramienta .

ex:ModoOperacion_TM2
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=2 (Cabezal → Almacén)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén."@es ;
    ex:identificador "2" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_TM5
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=5 (Intercambio en mismo almacén)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son del mismo almacén."@es ;
    ex:identificador "5" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_TM12
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=12 (Intercambio optimizado)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida cuando ambas herramientas son especiales y pueden colisionar en el brazo o no se desea que coincidan en el brazo cambiador."@es ;
    ex:identificador "12" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:ModoOperacion_TM14
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION=14 (Intercambio entre almacenes)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son de almacenes diferentes."@es ;
    ex:identificador "14" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:TareaMantenimiento_TransporteHerramienta
    a ex:TareaMantenimiento ;
    rdfs:label "Transporte de herramienta entre brazo/cabezal/almacén"@es ;
    ex:textoExtracto "Operaciones de cogida, colocación o intercambio de herramientas entre brazo, cabezal, almacén o tierra."@es .

ex:Herramienta_Pinza2
    a ex:Herramienta ;
    rdfs:label "Herramienta (pinza ꞏ2ꞏ)"@es ;
    ex:textoExtracto "Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén."@es ;
    ex:identificador "pinza ꞏ2ꞏ" .