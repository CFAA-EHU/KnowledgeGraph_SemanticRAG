@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:HerramientaPinza1
    a ex:Herramienta ;
    rdfs:label "Herramienta (pinza ꞏ1ꞏ)"@es ;
    ex:textoExtracto "Coger una herramienta del almacén y ponerla en el brazo (pinza ꞏ1ꞏ)."@es .

ex:HerramientaPinza2
    a ex:Herramienta ;
    rdfs:label "Herramienta (pinza ꞏ2ꞏ)"@es ;
    ex:textoExtracto "Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén."@es .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es .