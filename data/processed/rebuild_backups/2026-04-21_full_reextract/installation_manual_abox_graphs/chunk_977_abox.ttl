@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesPLC_TM a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de operaciones válidas y marcas PLC-TM"@es ;
    ex:textoExtracto """
    TM => PLC |  |  | PLC => TM |
    | --- | --- | --- | --- |
    | TMOPERATION | TAKEPOS | LEAVEPOS |  |
    | 1 | -1 | 0 | CH1TOSPDL |
    | 2 | 0 | # | SPDLTOCH2 + TCHANGEOK + CH2TOMZ |
    ...
    | 16 | # | # | CH2TOMZ + MZTOCH1 |
    """@es ;
    ex:ilustradoEn ex:Pagina_527_529 .

ex:Marca_TCHANGEOK
    a               ex:Parametro ;
    rdfs:label      "TCHANGEOK" ;
    ex:identificador "TCHANGEOK" ;
    ex:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM .

ex:Operacion_TM_1
    a               ex:ModoOperacion ;
    rdfs:label      "Operación TM 1" ;
    ex:identificador "1" ;
    ex:textoExtracto "TMOPERATION 1 | TAKEPOS -1 | LEAVEPOS 0 | CH1TOSPDL"@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM .

ex:Operacion_TM_2
    a               ex:ModoOperacion ;
    rdfs:label      "Operación TM 2" ;
    ex:identificador "2" ;
    ex:textoExtracto "TMOPERATION 2 | TAKEPOS 0 | LEAVEPOS # | SPDLTOCH2 + TCHANGEOK + CH2TOMZ"@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM ;
    ex:activaAlarma ex:Marca_TCHANGEOK .

ex:Operacion_TM_5a
    a               ex:ModoOperacion ;
    rdfs:label      "Operación TM 5 (variante a)" ;
    ex:identificador "5a" ;
    ex:textoExtracto "(a) SPDLTOCH2 + CH2TOMZ + CH1TOSPDL"@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM .

ex:Operacion_TM_5b
    a               ex:ModoOperacion ;
    rdfs:label      "Operación TM 5 (variante b)" ;
    ex:identificador "5b" ;
    ex:textoExtracto "(b) SPDLTOCH2 + CH1TOSPDL + TCHANGEOK + CH2TOMZ"@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM ;
    ex:activaAlarma ex:Marca_TCHANGEOK .

ex:Operacion_TM_9
    a               ex:ModoOperacion ;
    rdfs:label      "Operación TM 9" ;
    ex:identificador "9" ;
    ex:textoExtracto "TMOPERATION 9 | TAKEPOS -4 | LEAVEPOS # | GRTOSPDL + SPDLTOCH2 + TCHANGEOK + CH2TOMZ"@es ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_TM ;
    ex:activaAlarma ex:Marca_TCHANGEOK .