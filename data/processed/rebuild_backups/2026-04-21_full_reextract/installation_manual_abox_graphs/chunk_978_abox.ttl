@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionesPLC_7_11_1
    a               ex:ModoOperacion ;
    rdfs:label      "Operaciones válidas y marcas que activa el PLC"@es ;
    ex:textoExtracto
        "El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es ;
    ex:identificador "7.11.1" .

ex:Herramienta_T7
    a               ex:Herramienta ;
    rdfs:label      "Herramienta T7"@es ;
    ex:textoExtracto
        "las herramientas T7, T8 y T9 son de tierra"@es ;
    ex:identificador "T7" .

ex:Herramienta_T8
    a               ex:Herramienta ;
    rdfs:label      "Herramienta T8"@es ;
    ex:textoExtracto
        "las herramientas T7, T8 y T9 son de tierra"@es ;
    ex:identificador "T8" .

ex:Herramienta_T9
    a               ex:Herramienta ;
    rdfs:label      "Herramienta T9"@es ;
    ex:textoExtracto
        "las herramientas T7, T8 y T9 son de tierra"@es ;
    ex:identificador "T9" .

ex:SistemaAlmacenamientoHerramientas
    a               ex:Sistema ;
    rdfs:label      "Sistema de almacenamiento de herramientas (no-random)"@es ;
    ex:textoExtracto
        "El almacén es no-random, cada herramienta ocupa la posición de su mismo número"@es ;
    ex:tieneComponente ex:Herramienta_T7 , ex:Herramienta_T8 , ex:Herramienta_T9 .