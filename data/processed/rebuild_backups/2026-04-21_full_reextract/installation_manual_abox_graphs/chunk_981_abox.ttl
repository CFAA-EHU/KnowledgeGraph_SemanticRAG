@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosAlmacen_7_11_2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de posición en almacén (Sección 7.11.2)"@es ;
    ex:textoExtracto """
| Valor | Significado |
| --- | --- |
| 0 | No hay que hacer nada. |
| # | Posición en el almacén. |
| -1 | Pinza ꞏ1ꞏ del brazo cambiador. |
| -4 | Herramienta de tierra.
"""@es ;
    ex:ilustradoEn ex:Pagina_530_533 .

ex:PinzaBrazoCambiador
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1 del brazo cambiador"@es ;
    ex:identificador "-1" ;
    ex:textoExtracto "Pinza ꞏ1ꞏ del brazo cambiador."@es ;
    ex:documentadoEn ex:Tabla_CodigosAlmacen_7_11_2 .

ex:HerramientaTierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_CodigosAlmacen_7_11_2 .