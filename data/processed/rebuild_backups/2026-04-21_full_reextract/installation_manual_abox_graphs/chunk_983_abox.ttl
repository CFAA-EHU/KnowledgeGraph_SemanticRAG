@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AlmacenHerramientas_7_11_2
    a               ex:Sistema ;
    rdfs:label      "Almacén de herramientas del cabezal y brazo"@es ;
    ex:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén."@es .

ex:Pinza1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Pinza 1"@es ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1"@es ;
    ex:tieneComponente ex:Herramienta_Cabezal .

ex:Pinza2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Pinza 2"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ"@es ;
    ex:tieneComponente ex:Herramienta_Brazo .

ex:Herramienta_Cabezal
    a               ex:Herramienta ;
    rdfs:label      "Herramienta del cabezal"@es ;
    ex:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es .

ex:Herramienta_Brazo
    a               ex:Herramienta ;
    rdfs:label      "Herramienta del brazo cambiador"@es ;
    ex:textoExtracto "TAKEPOS=-1 Herramienta en el brazo cambiador"@es .

ex:Marca_SPDLTOCH2
    a               ex:AvisoSeguridad ;
    rdfs:label      "Marca SPDLTOCH2"@es ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es .

ex:Marca_CH2TOMZ
    a               ex:AvisoSeguridad ;
    rdfs:label      "Marca CH2TOMZ"@es ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es .

ex:OperacionCambioHerramienta
    a               ex:TareaMantenimiento ;
    rdfs:label      "Operación de cambio de herramienta (TMOPERATION=11)"@es ;
    ex:identificador "TMOPERATION=11" ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1. Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es ;
    ex:requiereMantenimiento ex:Pinza1 , ex:Pinza2 ;
    ex:ejecutadoPor ex:AlmacenHerramientas_7_11_2 .

ex:AlmacenHerramientas_7_11_2
    ex:tieneComponente ex:Herramienta_Cabezal , ex:Herramienta_Brazo .