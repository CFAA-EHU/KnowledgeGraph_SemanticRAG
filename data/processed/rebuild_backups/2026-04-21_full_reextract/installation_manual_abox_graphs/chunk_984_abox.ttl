@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_Seq1
    a ex:TareaMantenimiento ;
    rdfs:label "Primera secuencia de operación del almacén"@es ;
    ex:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es ;
    ex:identificador "Seq1" .

ex:OperacionAlmacen_Seq2
    a ex:TareaMantenimiento ;
    rdfs:label "Segunda secuencia de operación del almacén"@es ;
    ex:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL. 3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK. 5 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ."@es ;
    ex:identificador "Seq2" .

ex:OperacionHerramientaTierra_Seq1
    a ex:TareaMantenimiento ;
    rdfs:label "Primera secuencia para herramienta de tierra (TMOPERATION=6)"@es ;
    ex:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es ;
    ex:identificador "TMOPERATION=6_Seq1" .

ex:OperacionHerramientaTierra_Seq2
    a ex:TareaMantenimiento ;
    rdfs:label "Segunda secuencia para herramienta de tierra (TMOPERATION=6)"@es ;
    ex:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es ;
    ex:identificador "TMOPERATION=6_Seq2" .

ex:Pinza_1
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1"@es ;
    ex:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es ;
    ex:identificador "Pinza-1" .

ex:Pinza_2
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ"@es ;
    ex:identificador "Pinza-2" .

ex:HerramientaTierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "TAKEPOS=-4 Herramienta de tierra. [...] Poner la herramienta de tierra en el cabezal"@es ;
    ex:identificador "TAKEPOS=-4" .

ex:Marca_SPDLTOCH2
    a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOCH2"@es ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es ;
    ex:identificador "SPDLTOCH2" .

ex:Marca_CH2TOMZ
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH2TOMZ"@es ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es ;
    ex:identificador "CH2TOMZ" .

ex:Marca_CH1TOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOSPDL"@es ;
    ex:textoExtracto "activar la marca CH1TOSPDL"@es ;
    ex:identificador "CH1TOSPDL" .

ex:Marca_GRTOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca GRTOSPDL"@es ;
    ex:textoExtracto "activar la marca GRTOSPDL"@es ;
    ex:identificador "GRTOSPDL" .

ex:Marca_TCHANGEOK
    a ex:InterfazUsuario ;
    rdfs:label "Marca TCHANGEOK"@es ;
    ex:textoExtracto "activar TCHANGEOK"@es ;
    ex:identificador "TCHANGEOK" .

ex:OperacionAlmacen_Seq1
    ex:requiereMantenimiento ex:Pinza_1 , ex:Pinza_2 ;
    ex:ilustradoEn ex:Marca_SPDLTOCH2 , ex:Marca_CH2TOMZ , ex:Marca_CH1TOSPDL .

ex:OperacionAlmacen_Seq2
    ex:requiereMantenimiento ex:Pinza_1 , ex:Pinza_2 ;
    ex:ilustradoEn ex:Marca_SPDLTOCH2 , ex:Marca_CH1TOSPDL , ex:Marca_TCHANGEOK , ex:Marca_CH2TOMZ .

ex:OperacionHerramientaTierra_Seq1
    ex:requiereMantenimiento ex:Pinza_2 , ex:HerramientaTierra ;
    ex:ilustradoEn ex:Marca_SPDLTOCH2 , ex:Marca_CH2TOMZ , ex:Marca_GRTOSPDL .

ex:OperacionHerramientaTierra_Seq2
    ex:requiereMantenimiento ex:Pinza_2 , ex:HerramientaTierra ;
    ex:ilustradoEn ex:Marca_SPDLTOCH2 , ex:Marca_GRTOSPDL .