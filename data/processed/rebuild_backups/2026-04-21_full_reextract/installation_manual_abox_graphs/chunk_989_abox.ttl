@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_7_11_2
    a                     ex:ModoOperacion ;
    rdfs:label            "Operación de gestión de herramientas en almacén (Sección 7.11.2)"@es ;
    ex:textoExtracto      "LEAVEPOS=# Posición del almacén para dejar la herramienta. [...] La secuencia de esta operación es la siguiente. En esta operación, el gestor admite dos secuencias. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1."@es ;
    ex:identificador      "TMOPERATION=11" ;
    ex:tieneComponente    ex:Pinza1 .

ex:Pinza1
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Pinza 1 para manipulación de herramientas"@es ;
    ex:textoExtracto      "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1"@es ;
    ex:identificador      "pinza 1" .