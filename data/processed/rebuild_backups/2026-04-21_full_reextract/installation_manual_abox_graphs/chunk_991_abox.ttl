@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ComunicacionM06_PLC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de comunicación entre rutina M06 y PLC"@es ;
    ex:textoExtracto "Comunicación entre la rutina M06 y el PLC [...] Marcas que activa la rutina M06 para que el PLC active la marca correspondiente del gestor."@es ;
    ex:documentadoEn ex:Pagina_534 .

ex:Marca_M1100
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1100 (TCHANGEOK)"@es ;
    ex:identificador "M1100" ;
    ex:textoExtracto "M1100 | TCHANGEOK - Se puede continuar con la ejecución del programa."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_M1101
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1101 (MZTOCH1)"@es ;
    ex:identificador "M1101" ;
    ex:textoExtracto "M1101 | MZTOCH1 - La herramienta se ha llevado del almacén a la pinza 1."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_M1102
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1102 (CH1TOSPDL)"@es ;
    ex:identificador "M1102" ;
    ex:textoExtracto "M1102 | CH1TOSPDL - La herramienta se ha llevado de la pinza 1 al cabezal."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_M1104
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1104 (SPDLTOCH2)"@es ;
    ex:identificador "M1104" ;
    ex:textoExtracto "M1104 | SPDLTOCH2 - La herramienta se ha llevado del cabezal a la pinza 2."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_M1107
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1107 (SPDLTOGR)"@es ;
    ex:identificador "M1107" ;
    ex:textoExtracto "M1107 | SPDLTOGR - La herramienta se ha llevado del cabezal a tierra."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_M1108
    a ex:ComponenteElectrico ;
    rdfs:label "Marca M1108 (GRTOSPDL)"@es ;
    ex:identificador "M1108" ;
    ex:textoExtracto "M1108 | GRTOSPDL - La herramienta se ha llevado de tierra al cabezal."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Marca_CH2TOMZ
    a ex:ComponenteElectrico ;
    rdfs:label "Marca CH2TOMZ"@es ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "La marca CH2TOMZ la pondrá el PLC cuando se haya dejado la herramienta."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M101 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M101 (Selección de herramienta)"@es ;
    ex:identificador "M101" ;
    ex:textoExtracto "M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M102 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M102 (Transferencia pinza 1 a cabezal)"@es ;
    ex:identificador "M102" ;
    ex:textoExtracto "M102 | Llevar la herramienta de la pinza 1 al cabezal."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M104 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M104 (Transferencia cabezal a pinza 2)"@es ;
    ex:identificador "M104" ;
    ex:textoExtracto "M104 | Coger la herramienta del cabezal con la pinza 2."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M106 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M106 (Envío a almacén)"@es ;
    ex:identificador "M106" ;
    ex:textoExtracto "M106 | Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M121 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M121 (Posicionamiento brazo)"@es ;
    ex:identificador "M121" ;
    ex:textoExtracto "M121 | Llevar el brazo cambiador al punto de cambio."@es ;
