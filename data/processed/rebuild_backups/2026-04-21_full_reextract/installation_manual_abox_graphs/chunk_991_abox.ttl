ex:Funcion_M122 a ex:Tabla ;
     a ex:ComponenteElectrico ;
    rdfs:label "Función M122 (Retorno a almacén)"@es ;
    ex:identificador "M122" ;
    ex:textoExtracto "M122 | Llevar el brazo cambiador al almacén."@es ;
    ex:ilustradoEn ex:Tabla_ComunicacionM06_PLC .

ex:Funcion_M123 a ex:Tabla ;
