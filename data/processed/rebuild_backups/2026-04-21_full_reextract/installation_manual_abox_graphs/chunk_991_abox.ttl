ex:Pagina_534
    a ex:Pagina ;
    rdfs:label "Página 534"@es ;
    ex:identificador "534" ;
    ex:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos."@es .