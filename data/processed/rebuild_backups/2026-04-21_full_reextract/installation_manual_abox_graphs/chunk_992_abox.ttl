@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:M121 a ex:ModoOperacion ;
    rdfs:label "M121" ;
    ex:textoExtracto "M121 | Llevar el brazo cambiador al punto de cambio." ;
    ex:identificador "M121" .

ex:M122 a ex:ModoOperacion ;
    rdfs:label "M122" ;
    ex:textoExtracto "M122 | Llevar el brazo cambiador al almacén." ;
    ex:identificador "M122" .

ex:M123 a ex:ModoOperacion ;
    rdfs:label "M123" ;
    ex:textoExtracto "M123 | Retirar el brazo cambiador." ;
    ex:identificador "M123" .

ex:M106 a ex:ModoOperacion ;
    rdfs:label "M106" ;
    ex:textoExtracto "El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar." ;
    ex:identificador "M106" .

ex:PLC a ex:Actuador ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar." ;
    ex:controla ex:M106 .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ex:textoExtracto "Llevar el brazo cambiador al punto de cambio... Retirar el brazo cambiador... cuando el brazo abandona la zona de posible colisión" .