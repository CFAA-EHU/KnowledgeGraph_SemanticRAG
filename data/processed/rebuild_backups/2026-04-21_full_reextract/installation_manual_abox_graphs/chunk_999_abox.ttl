@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_Caso7
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 7: Cambio de herramienta (almacén → cabezal)" ;
    ex:textoExtracto "$BREAK $CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén. [...] LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:identificador "M06_Case7" .

ex:RutinaM06_Caso8
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 8: Cambio de herramienta (tierra → cabezal)" ;
    ex:textoExtracto "$BREAK $CASE 8 ; Dejar la herramienta del cabezal en tierra y coger otra de tierra. [...] LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." ;
    ex:identificador "M06_Case8" .

ex:RutinaM06_Caso9
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 9: Cambio de herramienta (tierra → almacén vía cabezal)" ;
    ex:textoExtracto "$BREAK $CASE 9 ; Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. [...] LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." ;
    ex:identificador "M06_Case9" .

ex:Subrutina_SUB_SPD_GMCHG
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_SPD_GMCHG" ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." ;
    ex:identificador "SUB_SPD_GMCHG" .

ex:Subrutina_SUB_SPD_TO_GR
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_SPD_TO_GR" ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." ;
    ex:identificador "SUB_SPD_TO_GR" .

ex:Subrutina_SUB_SPD_AUTCHG
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_SPD_AUTCHG" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:Subrutina_SUB_ARM_TO_CHG
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_ARM_TO_CHG" ;
    ex:textoExtracto "LL SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio." ;
    ex:identificador "SUB_ARM_TO_CHG" .

ex:Subrutina_SUB_CH1_TO_SPD
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_CH1_TO_SPD" ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:identificador "SUB_CH1_TO_SPD" .

ex:Subrutina_SUB_ARM_BACK
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_ARM_BACK" ;
    ex:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador." ;
    ex:identificador "SUB_ARM_BACK" .

ex:Subrutina_SUB_GR_TO_SPD
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_GR_TO_SPD" ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." ;
    ex:identificador "SUB_GR_TO_SPD" .

ex:Subrutina_SUB_CH2_TO_MZ
    a ex:ModoOperacion ;
    rdfs:label "Subrutina SUB_CH2_TO_MZ" ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." ;
    ex:identificador "SUB_CH2_TO_MZ" .

ex:Pinza1
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1 (almacén de herramientas)" ;
    ex:textoExtracto "pinza 1" ;
    ex:identificador "Pinza_1" .

ex:Pinza2
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2 (brazo cambiador)" ;
    ex:textoExtracto "pinza 2" ;
    ex:identificador "Pinza_2" .

ex:BrazoCambiador
    a ex:Actuador ;
    rdfs:label "Brazo cambiador de herramientas" ;
    ex:textoExtracto "brazo cambiador" ;
    ex:identificador "BrazoCambiador" .

ex:Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal de la máquina" ;
    ex:textoExtracto "cabezal" .

ex:PuntoCambioManual
    a ex:ModoOperacion ;
    rdfs:label "Punto de cambio manual" ;
    ex:textoExtracto "punto de cambio manual" ;
    ex:identificador "PuntoCambioManual" .

ex:PuntoCambioAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Punto de cambio automático" ;
    ex:textoExtracto "punto de cambio automático" ;
    ex:identificador "PuntoCambioAutomatico" .

ex:AlmacenHerramientas
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto "almacén" ;
    ex:identificador "AlmacenHerramientas" .

ex:Se_al_TCHANGEOK
    a ex:Parametro ;
    rdfs:label "Señal TCHANGEOK (confirmación de cambio)" ;
    ex:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK" ;
    ex:identificador "TCHANGEOK" ;
    ex:valor "1" .

# Relaciones entre individuos
ex:RutinaM06_Caso7
    ex:requiereMantenimiento ex:Pinza1 ;
    ex:requiereMantenimiento ex:BrazoCambiador ;
    ex:requiereMantenimiento ex:Cabezal .

ex:RutinaM06_Caso8
    ex:requiereMantenimiento ex:Cabezal .

ex:RutinaM06_Caso9
    ex:requiereMantenimiento ex:Pinza2 ;
    ex:requiereMantenimiento ex:BrazoCambiador ;
    ex:requiereMantenimiento ex:Cabezal .

ex:Subrutina_SUB_SPD_GMCHG
    ex:controla ex:PuntoCambioManual .

ex:Subrutina_SUB_SPD_AUTCHG
    ex:controla ex:PuntoCambioAutomatico .

ex:Subrutina_SUB_ARM_TO_CHG
    ex:controla ex:BrazoCambiador .

ex:Subrutina_SUB_CH1_TO_SPD
    ex:controla ex:Pinza1 .

ex:Subrutina_SUB_CH2_TO_MZ
    ex:controla ex:Pinza2 .

ex:BrazoCambiador
    ex:tieneComponente ex:Pinza2 .

ex:AlmacenHerramientas
    ex:tieneComponente ex:Pinza1 .

ex:RutinaM06_Caso7
    ex:ejecutadoPor ex:Subrutina_SUB_SPD_GMCHG ,
        ex:Subrutina_SUB_SPD_TO_GR ,
        ex:Subrutina_SUB_SPD_AUTCHG ,
        ex:Subrutina_SUB_ARM_TO_CHG ,
        ex:Subrutina_SUB_CH1_TO_SPD ,
        ex:Subrutina_SUB_ARM_BACK .

ex:RutinaM06_Caso8
    ex:ejecutadoPor ex:Subrutina_SUB_SPD_GMCHG ,
        ex:Subrutina_SUB_SPD_TO_GR ,
        ex:Subrutina_SUB_GR_TO_SPD .

ex:RutinaM06_Caso9
    ex:ejecutadoPor ex:Subrutina_SUB_SPD_GMCHG ,
        ex:Subrutina_SUB_GR_TO_SPD ,
        ex:Subrutina_SUB_SPD_AUTCHG ,
        ex:Subrutina_SUB_ARM_TO_CHG ,
        ex:Subrutina_SUB_SPD_TO_CH2 ,
        ex:Subrutina_SUB_ARM_BACK ,
        ex:Subrutina_SUB_CH2_TO_MZ ;
    ex:activaAlarma ex:Se_al_TCHANGEOK .