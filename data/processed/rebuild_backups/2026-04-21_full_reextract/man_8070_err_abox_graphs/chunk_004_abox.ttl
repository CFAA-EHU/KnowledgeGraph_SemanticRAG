@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorSistema_0001
    a ex:Alarma ;
    rdfs:label "ERROR DEL SISTEMA" ;
    ex:identificador "0001" ;
    ex:textoExtracto "'ERROR DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Errores de software o hardware que provocan datos corruptos y/o resultados incongruentes." .

ex:ErrorSistema_0002
    a ex:AvisoSeguridad ;
    rdfs:label "WARNING DEL SISTEMA" ;
    ex:identificador "0002" ;
    ex:textoExtracto "'WARNING DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Aviso de situaciones internas que pueden acabar en errores del sistema." .

ex:ErrorMemoria_0003
    a ex:Alarma ;
    rdfs:label "Error en la petición de memoria. Reiniciar Windows y CNC" ;
    ex:identificador "0003" ;
    ex:textoExtracto "'Error en la petición de memoria. Reiniciar Windows y CNC' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no dispone de suficiente memoria o la memoria se encuentra excesivamente fragmentada." .

ex:ErrorChecksumPLC_0004
    a ex:Alarma ;
    rdfs:label "Error de checksum en los datos de PLC" ;
    ex:identificador "0004" ;
    ex:textoExtracto "'Error de checksum en los datos de PLC' DETECCIÓN Durante el arranque del CNC. CAUSA Los datos del PLC relativos a marcas, contadores, temporizadores y registros salvados a disco no son válidos. El archivo plcdata.bin que contiene estos datos no existe, no es accesible o está corrupto." .

ex:ErrorApagadoCNC_0005
    a ex:Alarma ;
    rdfs:label "El CNC no se apagó correctamente, es necesario referenciar" ;
    ex:identificador "0005" ;
    ex:textoExtracto "'El CNC no se apagó correctamente, es necesario referenciar' DETECCIÓN Durante el arranque del CNC. CAUSA Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos. El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto." .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "CNC (Control Numérico Computarizado) mencionado en los errores 0001, 0002, 0003, 0004 y 0005." ;
    ex:activaAlarma ex:ErrorSistema_0001, ex:ErrorSistema_0002, ex:ErrorMemoria_0003, ex:ErrorChecksumPLC_0004, ex:ErrorApagadoCNC_0005 .