@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0010
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en test de RAM con batería" ;
    ex:identificador "0010" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El test de arranque ha detectado un error de checksum en los datos de la NVRAM y por lo tanto un fallo en la misma. CONSECUENCIA Los datos guardados pueden no ser correctos (datos relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc). SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ex:Error_0011
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de checksum en los datos de búsqueda de bloque" ;
    ex:identificador "0011" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Error de cheksum de los datos necesarios para ejecutar una búsqueda de bloque automática. CONSECUENCIA No es posible ejecutar una búsqueda de bloque automática. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ex:Error_0012
    a ex:DiagnosticoFallo ;
    rdfs:label "No hay tiempo de CPU para ejecutar todos los PREPFREQ" ;
    ex:identificador "0012" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC necesita demasiado tiempo para analizar el programa. SOLUCIÓN Reducir el número de bloques a preparar por ciclo (parámetro PREPFREQ)." .

ex:Error_0013
    a ex:DiagnosticoFallo ;
    rdfs:label "ASSERT DEL SISTEMA" ;
    ex:identificador "0013" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha generado un error sin determinar. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error_0014
    a ex:DiagnosticoFallo ;
    rdfs:label "Detectado Watchdog en la última sesión" ;
    ex:identificador "0014" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC se ha cerrado debido a un reset por watchdog. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error_0015
    a ex:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio del equipo" ;
    ex:identificador "0015" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error_0016
    a ex:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio durante el arranque del sistema operativo" ;
    ex:identificador "0016" ;
    ex:textoExtracto "Detectado apagado/reinicio durante el arranque del sistema operativo." .

ex:Parametro_PREPFREQ
    a ex:Parametro ;
    rdfs:label "PREPFREQ" ;
    ex:textoExtracto "Reducir el número de bloques a preparar por ciclo (parámetro PREPFREQ)." .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC necesita demasiado tiempo para analizar el programa." ;
    ex:tieneComponente ex:NVRAM .

ex:NVRAM
    a ex:ComponenteElectrico ;
    rdfs:label "NVRAM" ;
    ex:textoExtracto "El test de arranque ha detectado un error de checksum en los datos de la NVRAM y por lo tanto un fallo en la misma." .