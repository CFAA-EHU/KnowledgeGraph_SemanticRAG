@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0016
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 0016: Apagado/reinicio durante arranque"@es ;
    ex:textoExtracto "0016 Detectado apagado/reinicio durante el arranque del sistema operativo. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado un apagado inesperado por una caída de alimentación, durante el arranque del sistema operativo."@es ;
    ex:identificador "0016" .

ex:Error_Indeterminado_Arranque
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error indeterminado: Apagado/reinicio durante arranque del CNC"@es ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo."@es .

ex:SistemaOperativo_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema operativo del CNC"@es ;
    ex:textoExtracto "arranque del sistema operativo"@es ;
    ex:activaAlarma  ex:Error_0016 .

ex:CNC_EquipoPrincipal
    a               ex:Maquina ;
    rdfs:label      "CNC"@es ;
    ex:textoExtracto "CNC"@es ;
    ex:activaAlarma  ex:Error_0016 , ex:Error_Indeterminado_Arranque .

ex:FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation"@es ;
    ex:textoExtracto "póngase en contacto con Fagor Automation"@es .