@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0017
    a ex:Alarma ;
    rdfs:label "Detectado apagado/reinicio por caída de alimentación" ;
    ex:identificador "0017" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado un apagado inesperado por una caída de alimentación. SOLUCIÓN Revisar la alimentación del CNC. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." ;
    ex:mitigaRiesgo ex:AccionProhibida_ApagadoInesperado .

ex:Alarma_0018
    a ex:Alarma ;
    rdfs:label "Detectado apagado/reinicio por pantalla azul" ;
    ex:identificador "0018" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El cierre anterior del CNC fue debido a una excepción de bajo nivel (pantalla azul). SOLUCIÓN Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." ;
    ex:mitigaRiesgo ex:AccionProhibida_FalloSistema .

ex:Alarma_0020
    a ex:Alarma ;
    rdfs:label "Acceso a variable incorrecto" ;
    ex:identificador "0020" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC o al cambiar de página. CAUSA El CNC está accediendo a una variable de interfaz que no existe. SOLUCIÓN Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." ;
    ex:mitigaRiesgo ex:AccionProhibida_AccesoInvalido .

ex:Alarma_0021
    a ex:Alarma ;
    rdfs:label "No hay teclado de CAN" ;
    ex:identificador "0021" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN." .

ex:AccionProhibida_ApagadoInesperado
    a ex:AccionProhibida ;
    rdfs:label "Apagado inesperado por caída de alimentación" ;
    ex:textoExtracto "El CNC ha detectado un apagado inesperado por una caída de alimentación" .

ex:AccionProhibida_FalloSistema
    a ex:AccionProhibida ;
    rdfs:label "Fallo de sistema (pantalla azul)" ;
    ex:textoExtracto "El cierre anterior del CNC fue debido a una excepción de bajo nivel (pantalla azul)" .

ex:AccionProhibida_AccesoInvalido
    a ex:AccionProhibida ;
    rdfs:label "Acceso a variable de interfaz inexistente" ;
    ex:textoExtracto "El CNC está accediendo a una variable de interfaz que no existe" .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ex:textoExtracto "cambiar de página... diseñador de las páginas de su interfaz" ;
    ex:activaAlarma ex:Alarma_0020 .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "el arranque del sistema operativo... Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc" ;
    ex:activaAlarma ex:Alarma_0017, ex:Alarma_0018, ex:Alarma_0020, ex:Alarma_0021 ;
    ex:tieneComponente ex:InterfazUsuario_CNC .