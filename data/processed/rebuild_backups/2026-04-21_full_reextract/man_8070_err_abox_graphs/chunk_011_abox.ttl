@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0021
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 0021: No hay teclado de CAN"@es ;
    ex:textoExtracto "0021 No hay teclado de CAN. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN."@es ;
    ex:identificador "0021" .

ex:Error_0022
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 0022: Variable no permitida en el entorno de la puesta a punto"@es ;
    ex:textoExtracto "0022 'Variable no permitida en el entorno de la puesta a punto'"@es ;
    ex:identificador "0022" .

ex:InterfazUsuario_CNC
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de usuario del CNC"@es ;
    ex:textoExtracto "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable."@es ;
    ex:activaAlarma  ex:Error_0021, ex:Error_0022 .

ex:ModoDiagnosis
    a               ex:ModoOperacion ;
    rdfs:label      "Modo diagnosis del CNC"@es ;
    ex:textoExtracto "Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado."@es .

ex:BusCAN
    a               ex:ComponenteElectrico ;
    rdfs:label      "Bus CAN"@es ;
    ex:textoExtracto "Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado."@es ;
    ex:monitoreaParametro  ex:Parametro_EstadoBusCAN .

ex:Parametro_EstadoBusCAN
    a               ex:Parametro ;
    rdfs:label      "Estado del bus CAN"@es ;
    ex:textoExtracto "Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado."@es .

ex:TecladoCAN
    a               ex:ComponenteElectrico ;
    rdfs:label      "Teclado CAN"@es ;
    ex:textoExtracto "El CNC no ha detectado el teclado CAN."@es .