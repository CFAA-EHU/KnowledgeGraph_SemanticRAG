@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloSincronizacionHerramienta
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Inconsistencia en datos de herramienta activa"@es ;
    ex:textoExtracto "Durante el arranque del CNC. [...] La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Verificación y redefinición de herramienta activa"@es ;
        ex:textoExtracto "Comprobar cuál es la herramienta correcta antes de continuar. Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta."@es
    ] .

ex:TablaHerramientasCNC a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de herramientas del CNC"@es ;
    ex:textoExtracto "Definir en la tabla de herramientas cuál es la herramienta activa"@es .

ex:SistemaGestionHerramientas
    a               ex:Sistema ;
    rdfs:label      "Gestor de herramientas del CNC"@es ;
    ex:textoExtracto "La información de la herramienta activa guardada [...] no se corresponde con la guardada por el gestor de herramientas"@es ;
    ex:tieneComponente [
        a               ex:Herramienta ;
        rdfs:label      "Herramienta activa (referencia en sistema)"@es ;
        ex:textoExtracto "herramienta activa guardada por el gestor de herramientas"@es
    ] .

ex:FicheroDatosHerramientas
    a               ex:InterfazUsuario ;
    rdfs:label      "Fichero de datos de herramientas del CNC"@es ;
    ex:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto"@es .