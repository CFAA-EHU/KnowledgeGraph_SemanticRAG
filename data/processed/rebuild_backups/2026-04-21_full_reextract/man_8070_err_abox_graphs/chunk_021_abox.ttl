@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_ParametroModificado
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo por modificación de parámetro máquina" ;
    ex:textoExtracto "CAUSA El usuario ha modificado un parámetro máquina y es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor. SOLUCIÓN Reiniciar el CNC." ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Reinicio obligatorio del CNC tras modificación de parámetro" ;
        ex:textoExtracto "es necesario reiniciar la aplicación CNC para que el parámetro asuma su nuevo valor. SOLUCIÓN Reiniciar el CNC."
    ] .

ex:Fallo_NombreEjeInvalido
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 0044: Nombre de eje no válido o sin definir" ;
    ex:identificador "0044" ;
    ex:textoExtracto "0044 'Nombre de eje no válido o nombre de eje sin definir' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro máquina está sin definir o tiene un nombre de eje incorrecto. SOLUCIÓN Corregir los parámetros máquina." ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Corrección de parámetros de eje" ;
        ex:textoExtracto "Corregir los parámetros máquina."
    ] .

ex:Parametro_NombreEje
    a               ex:Parametro ;
    rdfs:label      "Parámetro de nombre de eje" ;
    ex:textoExtracto "El parámetro máquina está sin definir o tiene un nombre de eje incorrecto." .

ex:Parametro_Modificado
    a               ex:Parametro ;
    rdfs:label      "Parámetro máquina modificado" ;
    ex:textoExtracto "El usuario ha modificado un parámetro máquina" .