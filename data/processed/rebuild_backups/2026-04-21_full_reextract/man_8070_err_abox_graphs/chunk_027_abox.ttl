@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaCompensacion_0057 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de compensación con pendiente de error superior a 1"@es ;
    ex:identificador "0057" ;
    ex:textoExtracto "0057 'Tabla de compensación con pendiente de error superior a 1' [...] En las tablas de compensación de husillo, la diferencia entre dos errores consecutivos es mayor que la distancia que separa ambos puntos."@es ;
    ex:monitoreaParametro ex:Parametro_CompensacionHusillo .

ex:Parametro_CompensacionHusillo
    a               ex:Parametro ;
    rdfs:label      "Parámetro de compensación de husillo"@es ;
    ex:textoExtracto "Durante la validación de los parámetros máquina (tabla de compensación de husillo)."@es .

ex:AvisoSeguridad_0057
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso de error en pendiente de compensación"@es ;
    ex:textoExtracto "El valor a compensar no puede ser cero en todos los puntos. [...] CAUSA En las tablas de compensación de husillo, la diferencia entre dos errores consecutivos es mayor que la distancia que separa ambos puntos."@es ;
    ex:documentadoEn ex:TablaCompensacion_0057 .