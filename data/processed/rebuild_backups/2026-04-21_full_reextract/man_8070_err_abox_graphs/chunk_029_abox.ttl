@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0063
    a ex:Alarma ;
    rdfs:label "Alarma 0063" ;
    ex:identificador "0063" ;
    ex:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje'" ;
    ex:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina." .

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:textoExtracto "El parámetro JOGFEED es superior a G00FEED." ;
    ex:monitoreaParametro ex:Alarma_0063 .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "El parámetro JOGFEED es superior a G00FEED." ;
    ex:monitoreaParametro ex:Alarma_0063 .

ex:Parametro_INCJOGFEED
    a ex:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ex:textoExtracto "El parámetro INCJOGFEED es superior a G00FEED." ;
    ex:monitoreaParametro ex:Alarma_0063 .

ex:DiagnosticoFallo_0063
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 0063" ;
    ex:textoExtracto "CAUSA El parámetro JOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED." ;
    ex:textoExtracto "CAUSA El parámetro INCJOGFEED es superior a G00FEED." ;
    ex:solucionaFallo ex:Alarma_0063 .