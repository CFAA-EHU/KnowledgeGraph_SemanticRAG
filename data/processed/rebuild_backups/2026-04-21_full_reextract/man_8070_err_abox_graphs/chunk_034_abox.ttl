@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_0074
    a ex:DiagnosticoFallo ;
    rdfs:label "Test de tendencia sin activar" ;
    ex:identificador "0074" ;
    ex:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: En algún eje o cabezal, el test de tendencia está desactivado. SOLUCIÓN: En los ejes y cabezales, activar el test de tendencia (parámetro TENDENCY)." ;
    ex:solucionaFallo ex:Parametro_TENDENCY .

ex:DiagnosticoFallo_0075
    a ex:DiagnosticoFallo ;
    rdfs:label "Tabla de configuración de IOs no válida" ;
    ex:identificador "0075" ;
    ex:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Los parámetros NDIMOD y NDOMOD deben ser iguales al número de módulos de entradas y salidas detectados por hardware. SOLUCIÓN: Corregir los parámetros NDIMOD y NDOMOD." ;
    ex:solucionaFallo ex:Parametro_NDIMOD ;
    ex:solucionaFallo ex:Parametro_NDOMOD .

ex:DiagnosticoFallo_0076
    a ex:DiagnosticoFallo ;
    rdfs:label "La suma de ejes o cabezales por canal supera el número total de ejes o cabezales" ;
    ex:identificador "0076" ;
    ex:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: El valor del parámetro CHNAXIS es mayor que el valor del parámetro NAXIS o el valor del parámetro CHNSPDL es mayor que el valor del parámetro NSPDL. SOLUCIÓN: Corregir los parámetros máquina." ;
    ex:solucionaFallo ex:Parametro_CHNAXIS ;
    ex:solucionaFallo ex:Parametro_NAXIS ;
    ex:solucionaFallo ex:Parametro_CHNSPDL ;
    ex:solucionaFallo ex:Parametro_NSPDL .

ex:DiagnosticoFallo_0077
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje o cabezal asignado a más de un canal" ;
    ex:identificador "0077" ;
    ex:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Hay un eje o cabezal asignado a varios canales. SOLUCIÓN: Corregir los parámetros máquina CHAXISNAME y CHSPDLNAME en todos los canales." ;
    ex:solucionaFallo ex:Parametro_CHAXISNAME ;
    ex:solucionaFallo ex:Parametro_CHSPDLNAME .

ex:DiagnosticoFallo_0078
    a ex:DiagnosticoFallo ;
    rdfs:label "Los ejes maestro y esclavo deben pertenecer al mismo canal" ;
    ex:identificador "0078" ;
    ex:textoExtracto "DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Algún eje gantry está formado por ejes de canales distintos." .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT+" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." ;
    ex:valor "0" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT-" ;
    ex:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0." ;
    ex:valor "0" .

ex:Parametro_TENDENCY
    a ex:Parametro ;
    rdfs:label "TENDENCY" ;
    ex:textoExtracto "En los ejes y cabezales, activar el test de tendencia (parámetro TENDENCY)." .

ex:Parametro_NDIMOD
    a ex:Parametro ;
    rdfs:label "NDIMOD" ;
    ex:textoExtracto "Los parámetros NDIMOD y NDOMOD deben ser iguales al número de módulos de entradas y salidas detectados por hardware." .

ex:Parametro_NDOMOD
    a ex:Parametro ;
    rdfs:label "NDOMOD" ;
    ex:textoExtracto "Los parámetros NDIMOD y NDOMOD deben ser iguales al número de módulos de entradas y salidas detectados por hardware." .

ex:Parametro_CHNAXIS
    a ex:Parametro ;
    rdfs:label "CHNAXIS" ;
    ex:textoExtracto "El valor del parámetro CHNAXIS es mayor que el valor del parámetro NAXIS." .

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:textoExtracto "El valor del parámetro CHNAXIS es mayor que el valor del parámetro NAXIS." .

ex:Parametro_CHNSPDL
    a ex:Parametro ;
    rdfs:label "CHNSPDL" ;
    ex:textoExtracto "El valor del parámetro CHNSPDL es mayor que el valor del parámetro NSPDL." .

ex:Parametro_NSPDL
    a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:textoExtracto "El valor del parámetro CHNSPDL es mayor que el valor del parámetro NSPDL." .

ex:Parametro_CHAXISNAME
    a ex:Parametro ;
    rdfs:label "CHAXISNAME" ;
    ex:textoExtracto "Corregir los parámetros máquina CHAXISNAME y CHSPDLNAME en todos los canales." .

ex:Parametro_CHSPDLNAME
    a ex:Parametro ;
    rdfs:label "CHSPDLNAME" ;
    ex:textoExtracto "Corregir los parámetros máquina CHAXISNAME y CHSPDLNAME en todos los canales." .