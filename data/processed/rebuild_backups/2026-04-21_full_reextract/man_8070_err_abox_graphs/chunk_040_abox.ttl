@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_0090
    a ex:AvisoSeguridad ;
    rdfs:label "Warning 0090: Configuración de ejes por defecto"@es ;
    ex:identificador "0090" ;
    ex:textoExtracto "0090 'Se arranca con la configuración de ejes por defecto debido a errores en parámetros máquina' [...] SOLUCIÓN Al ser imposible arrancar con la configuración del usuario, el CNC arranca con la configuración por defecto. Corregir la configuración de parámetros máquina para eliminar el resto de errores y warnings."@es .

ex:AvisoSeguridad_0091
    a ex:AvisoSeguridad ;
    rdfs:label "Warning 0091: Variables DRV con ID duplicado y mnemónico inconsistente"@es ;
    ex:identificador "0091" ;
    ex:textoExtracto "0091 'Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico' [...] SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo mnemónico."@es .

ex:AvisoSeguridad_0092
    a ex:AvisoSeguridad ;
    rdfs:label "Warning 0092: Variables DRV con ID duplicado y MODE/TYPE inconsistente"@es ;
    ex:identificador "0092" ;
    ex:textoExtracto "0092 'Variables DRV con igual identificador (ID) no pueden tener diferente MODE o TYPE' [...] SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ex:AvisoSeguridad_0093
    a ex:AvisoSeguridad ;
    rdfs:label "Warning 0093: Variables DRV con mnemónico duplicado e ID/MODE/TYPE inconsistente"@es ;
    ex:identificador "0093" ;
    ex:textoExtracto "0093 'Variables DRV con igual nombre (MNEMONIC) no pueden tener diferente ID, MODE o TYPE' [...] En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente"@es .

ex:Parametro_NCHANNEL
    a ex:Parametro ;
    rdfs:label "NCHANNEL (número de canales)"@es ;
    ex:textoExtracto "Este warning se elimina sin tener que cambiar el parámetro NCHANNEL (número de canales)."@es .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "AXISNAME (nombres de ejes definidos)"@es ;
    ex:textoExtracto "el número de ejes en el sistema es mayor que el número de ejes definidos en el parámetro AXISNAME."@es .

ex:Parametro_DRV_ID
    a ex:Parametro ;
    rdfs:label "DRV.ID (identificador de variable reguladora)"@es ;
    ex:textoExtracto "Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico [...] identificador Sercos (ID)."@es .

ex:Parametro_DRV_MNEMONIC
    a ex:Parametro ;
    rdfs:label "DRV.MNEMONIC (mnemónico de variable reguladora)"@es ;
    ex:textoExtracto "Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico [...] Variables DRV con igual nombre (MNEMONIC)."@es .

ex:Parametro_DRV_MODE
    a ex:Parametro ;
    rdfs:label "DRV.MODE (modo de acceso: lectura/escritura)"@es ;
    ex:textoExtracto "diferente modo de acceso (lectura o escritura) [...] mismo modo de acceso (parámetro MODE)."@es .

ex:Parametro_DRV_TYPE
    a ex:Parametro ;
    rdfs:label "DRV.TYPE (tipo de acceso: síncrono/asíncrono)"@es ;
    ex:textoExtracto "diferente tipo de acceso (síncrono o asíncrono) [...] mismo tipo de acceso (parámetro TYPE)."@es .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "el CNC arranca con la configuración por defecto [...] validación de los parámetros máquina."@es ;
    ex:monitoreaParametro ex:Parametro_NCHANNEL ;
    ex:monitoreaParametro ex:Parametro_AXISNAME ;
    ex:monitoreaParametro ex:Parametro_DRV_ID ;
    ex:monitoreaParametro ex:Parametro_DRV_MNEMONIC ;
    ex:monitoreaParametro ex:Parametro_DRV_MODE ;
    ex:monitoreaParametro ex:Parametro_DRV_TYPE .

ex:AvisoSeguridad_0090 ex:mitigaRiesgo ex:Sistema_CNC .
ex:AvisoSeguridad_0091 ex:mitigaRiesgo ex:Sistema_CNC .
ex:AvisoSeguridad_0092 ex:mitigaRiesgo ex:Sistema_CNC .
ex:AvisoSeguridad_0093 ex:mitigaRiesgo ex:Sistema_CNC .