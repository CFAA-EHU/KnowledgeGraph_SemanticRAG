@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloConfiguracionEjesGantry
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en configuración de ejes gantry/tándem"@es ;
    ex:identificador "0098" ;
    ex:textoExtracto "Las parejas de ejes gantry o tándem no ocupan posiciones consecutivas en sus tablas; existe un hueco o posición sin definir en alguna de ellas. [...] 0098 'El eje maestro y el esclavo tienen diferente parámetro AXISEXCH'"@es ;
    ex:solucionaFallo [
        a               ex:Parametro ;
        rdfs:label      "AXISEXCH (parámetro de eje)"@es ;
        ex:textoExtracto "parámetro AXISEXCH"@es ;
        ex:valor         "consecutivo"@es
    ] .

ex:ParametroAXISEXCH
    a               ex:Parametro ;
    rdfs:label      "AXISEXCH"@es ;
    ex:textoExtracto "parámetro AXISEXCH"@es ;
    ex:valor         "diferente (maestro/esclavo)"@es ;
    ex:monitoreaParametro ex:FalloConfiguracionEjesGantry .