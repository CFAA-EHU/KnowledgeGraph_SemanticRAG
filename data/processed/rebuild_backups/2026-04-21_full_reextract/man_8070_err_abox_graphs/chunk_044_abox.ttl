@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0104
    a ex:Alarma ;
    rdfs:label "Time out de comunicación" ;
    ex:identificador "0104" ;
    ex:textoExtracto "0104 'Time out de comunicación' DETECCIÓN Durante la ejecución. CAUSA El CNC no finaliza con éxito la lectura o escritura de una variable externa." .

ex:Alarma_0105
    a ex:Alarma ;
    rdfs:label "No es posible validar parámetros durante la ejecución de un programa" ;
    ex:identificador "0105" ;
    ex:textoExtracto "0105 'No es posible validar parámetros durante la ejecución de un programa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar una tabla de parámetros máquina mientras hay un programa" .

ex:Parametro_CNC
    a ex:Parametro ;
    ex:textoExtracto "variable externa" ;
    ex:monitoreaParametro ex:Alarma_0104 .

ex:Tabla_ParametrosMaquina a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "tabla de parámetros máquina" ;
    ex:monitoreaParametro ex:Alarma_0105 .