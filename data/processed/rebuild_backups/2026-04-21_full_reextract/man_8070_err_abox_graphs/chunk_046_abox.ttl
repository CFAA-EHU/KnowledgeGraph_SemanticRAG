@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_0109
    a               ex:Alarma ;
    rdfs:label      "Alarma 0109: No es posible validar parámetros: cabezal en sincronización"@es ;
    ex:identificador "0109" ;
    ex:textoExtracto "0109 'No es posible validar parámetros: cabezal en sincronización'"@es ;
    ex:activaAlarma ex:sistema_cnc .

ex:sistema_cnc
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "El CNC no admite este tipo de acciones con cabezales sincronizados activos, ya que implican un reset del sistema."@es .

ex:parametros_maquina
    a               ex:Parametro ;
    rdfs:label      "Parámetros máquina"@es ;
    ex:textoExtracto "validación de los parámetros máquina"@es ;
    ex:monitoreaParametro ex:sistema_cnc .

ex:programa_plc
    a               ex:ComponenteElectrico ;
    rdfs:label      "Programa PLC"@es ;
    ex:textoExtracto "compilación del programa PLC"@es ;
    ex:controla     ex:sistema_cnc .

ex:cabezales_sincronizados
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezales sincronizados"@es ;
    ex:textoExtracto "cabezales sincronizados activos"@es ;
    ex:tieneComponente ex:sistema_cnc .

ex:diagnostico_0109
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico para alarma 0109"@es ;
    ex:textoExtracto "La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización"@es ;
    ex:solucionaFallo ex:alarma_0109 .