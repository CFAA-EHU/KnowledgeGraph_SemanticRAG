@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0114
    a                   ex:DiagnosticoFallo ;
    ex:identificador     "0114" ;
    rdfs:label          "Error 0114: Validación de parámetros durante simulación" ;
    ex:textoExtracto    "No es posible validar parámetros durante la simulación de un programa en el canal. [...] SOLUCIÓN Detener la simulación del programa para validar los parámetros."@es .

ex:Error_0115
    a                   ex:DiagnosticoFallo ;
    ex:identificador     "0115" ;
    rdfs:label          "Error 0115: Código de validación de CPU no coherente" ;
    ex:textoExtracto    "Código de validación -tipo de CPU-, NO coherente con el"@es .

ex:ParametroMaquina
    a                   ex:Parametro ;
    rdfs:label          "Parámetros máquina" ;
    ex:textoExtracto    "parámetros máquina"@es ;
    ex:monitoreaParametro ex:Error_0114 .

ex:SimulacionPrograma
    a                   ex:ModoOperacion ;
    rdfs:label          "Simulación de programa" ;
    ex:textoExtracto    "simulación de un programa en el canal"@es .