@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_0120
    a ex:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED"@es ;
    ex:textoExtracto "0120 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es ;
    ex:identificador "0120" .

ex:Alarma_0121
    a ex:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED"@es ;
    ex:textoExtracto "0121 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es ;
    ex:identificador "0121" .

ex:Alarma_0122
    a ex:Alarma ;
    rdfs:label "No es posible validar cambio de parámetro máquina"@es ;
    ex:textoExtracto "0122 No es posible validar cambio de parámetro máquina. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no puede validar los parámetros máquina porque no ha terminado de arrancar. SOLUCIÓN Esperar a que el CNC arranque para validar los parámetros máquina."@es ;
    ex:identificador "0122" .

ex:Alarma_0123
    a ex:Alarma ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error"@es ;
    ex:textoExtracto "0123 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es ;
    ex:identificador "0123" .

ex:Alarma_0124
    a ex:Alarma ;
    rdfs:label "El número de cores definidos en el código de validación NO es coherente con el hardware"@es ;
    ex:textoExtracto "0124 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido."@es ;
    ex:identificador "0124" .

ex:Sistema_SercosIII
    a ex:Sistema ;
    rdfs:label "Bus Sercos III"@es ;
    ex:textoExtracto "dispositivos conectados al bus Sercos III"@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "póngase en contacto con Fagor Automation"@es .

ex:Empresa_Fagor
    a ex:Empresa ;
    rdfs:label "Fagor"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor"@es .

ex:Parametro_CoresHardware
    a ex:Parametro ;
    rdfs:label "número de cores definidos en el código de validación"@es ;
    ex:textoExtracto "El número de cores definidos en el código de validación NO es coherente con el hardware"@es .

ex:Parametro_ParametrosMaquina
    a ex:Parametro ;
    rdfs:label "parámetros máquina"@es ;
    ex:textoExtracto "El CNC no puede validar los parámetros máquina porque no ha terminado de arrancar"@es .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "Durante el arranque del CNC"@es ;
    ex:tieneComponente ex:Sistema_SercosIII ;
    ex:monitoreaParametro ex:Parametro_CoresHardware ;
    ex:monitoreaParametro ex:Parametro_ParametrosMaquina .

ex:Alarma_0120 ex:activaAlarma ex:Maquina_CNC .
ex:Alarma_0121 ex:activaAlarma ex:Maquina_CNC .
ex:Alarma_0122 ex:activaAlarma ex:Maquina_CNC .
ex:Alarma_0123 ex:activaAlarma ex:Maquina_CNC .
