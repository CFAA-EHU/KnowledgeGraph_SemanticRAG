@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0131
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador" ;
    ex:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "0131" ;
    ex:solucionaFallo ex:Tabla_DRV .

ex:Error_0132
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0132: Error en la escritura de variable de regulador" ;
    ex:textoExtracto "0132 Error en la escritura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de escritura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la escritura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "0132" ;
    ex:solucionaFallo ex:Tabla_DRV .

ex:Error_0150_HandleEnUso
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0150: Handle de fichero en uso" ;
    ex:textoExtracto "0150 #OPEN: handle de fichero en uso. DETECCIÓN Durante la ejecución. CAUSA El handle de fichero indicado en la sentencia #OPEN está siendo usado por el #OPEN de otro fichero. SOLUCIÓN Utilizar un handle de fichero diferente." ;
    ex:identificador "0150" .

ex:Error_0150_MaxFicheros
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0150: Número máximo de ficheros abiertos sobrepasado" ;
    ex:textoExtracto "0150 'Número máximo de ficheros abiertos sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza con subrutinas globales. CAUSA El número de ficheros abiertos (programa principal más subrutinas externas) es superior a 20. SOLUCIÓN Reducir el número de subrutinas externas abiertas simultáneamente en el programa pieza." ;
    ex:identificador "0150" .

ex:Error_0151_FicheroNoEncontrado
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0151: Texto o fichero cncWrite.txt no encontrado" ;
    ex:textoExtracto "0151 #WRITE: texto o fichero cncWrite.txt no encontrado. DETECCIÓN Durante la ejecución. CAUSA No se encuentra el texto correspondiente al identificador programado. Es posible que no exista el archivo cncWrite.txt o que no esté definido el identificador. SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador." ;
    ex:identificador "0151" .

ex:Error_0151_AccesoDenegado
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 0151: Acceso de escritura denegado" ;
    ex:textoExtracto "0151 'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura." ;
    ex:identificador "0151" .

ex:Tabla_DRV a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla DRV" ;
    ex:textoExtracto "tabla DRV" ;
    ex:monitoreaParametro ex:Parametro_VariableRegulador .

ex:Parametro_VariableRegulador
    a ex:Parametro ;
    rdfs:label "Variable del regulador" ;
    ex:textoExtracto "variables del regulador" .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Fagor Automation" .