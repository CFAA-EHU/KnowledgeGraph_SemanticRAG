@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0163
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0163: #OPEN - Archivo no existe" ;
    ex:identificador "0163" ;
    ex:textoExtracto "0163 #OPEN:El fichero o path indicado no existe. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha comprobado que el archivo no existe (comando \"R\"). SOLUCIÓN La sentencia #OPEN está programada para mostrar este error. Para continuar con la ejecución sin dar error, utilizar el comando \"MUTED\"." .

ex:Error_0165
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0165: RT IT Overflow" ;
    ex:identificador "0165" ;
    ex:textoExtracto "0165 'RT IT Overflow' DETECCIÓN Durante el funcionamiento del CNC. CAUSA Las interrupciones de tiempo real superan el tiempo permitido. Algunas posibles causas pueden ser la instalación de algún dispositivo, driver o aplicación incompatible con el CNC. SOLUCIÓN Si el error se repite con frecuencia, puede ser necesario ajustar el parámetro LOOPTIME. Analice los casos en los que ocurre el error y póngase en contacto con su proveedor." .

ex:Error_0166
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0166: Límite de jerk sobrepasado" ;
    ex:identificador "0166" ;
    ex:textoExtracto "0166 'Límite de jerk sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza. CAUSA El eje está sobrepasando su límite de jerk permitido. SOLUCIÓN Analizar los casos en los que ocurre y póngase en contacto con el fabricante de la máquina." .

ex:Error_0167
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0167: No RT IT" ;
    ex:identificador "0167" ;
    ex:textoExtracto "0167 'No RT IT' DETECCIÓN Durante el funcionamiento del CNC. CAUSA No entra la interrupción de tiempo real. SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con su proveedor." .

ex:Error_0168
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0168: Position Loop Overflow" ;
    ex:identificador "0168" ;
    ex:textoExtracto "0168 Position Loop Overflow. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido. SOLUCIÓN Ajustar el parámetro LOOPTIME." .

ex:Error_0169
    a ex:Alarma ;
    rdfs:label "Error 0169: Sobrepasada temperatura de seguridad" ;
    ex:identificador "0169" ;
    ex:textoExtracto "0169 Sobrepasada temperatura de seguridad. En riesgo la integridad del equipo. Contactar con el SAT. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Está en riesgo la integridad del equipo." .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "Parámetro LOOPTIME" ;
    ex:identificador "LOOPTIME" ;
    ex:textoExtracto "Ajustar el parámetro LOOPTIME." ;
    ex:monitoreaParametro ex:Error_0165, ex:Error_0168 .

ex:CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Durante el funcionamiento del CNC." ;
    ex:activaAlarma ex:Error_0169 ;
    ex:tieneComponente ex:Ejes_Sercos .

ex:Ejes_Sercos
    a ex:ComponenteMecanico ;
    rdfs:label "Ejes Sercos" ;
    ex:textoExtracto "El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido." ;
    ex:monitoreaParametro ex:Parametro_LOOPTIME .