@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_0169
    a ex:Alarma ;
    rdfs:label "Alarma 0169: Sobrepasada temperatura de seguridad"@es ;
    ex:textoExtracto "0169 Sobrepasada temperatura de seguridad. En riesgo la integridad del equipo."@es ;
    ex:identificador "0169" ;
    ex:mitigaRiesgo ex:diagnostico_0169 .

ex:diagnostico_0169
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo por temperatura de seguridad (0169)"@es ;
    ex:textoExtracto "Está en riesgo la integridad del equipo. El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo; si en tres muestras seguidas la temperatura supera los 60ºC (140ºF)"@es ;
    ex:solucionaFallo ex:solucion_looptime .

ex:solucion_looptime
    a ex:AccionProhibida ;
    rdfs:label "Ajuste del parámetro LOOPTIME"@es ;
    ex:textoExtracto "SOLUCIÓN Ajustar el parámetro LOOPTIME."@es ;
    ex:identificador "LOOPTIME" .

ex:parametro_looptime
    a ex:Parametro ;
    rdfs:label "Parámetro LOOPTIME"@es ;
    ex:identificador "LOOPTIME" ;
    ex:textoExtracto "Ajustar el parámetro LOOPTIME"@es ;
    ex:monitoreaParametro ex:alarma_0169 .

ex:maquina_cnc
    a ex:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ex:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo"@es ;
    ex:activaAlarma ex:alarma_0169 .