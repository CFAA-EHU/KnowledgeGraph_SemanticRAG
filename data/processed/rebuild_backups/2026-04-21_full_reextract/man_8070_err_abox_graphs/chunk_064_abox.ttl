@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Ventilador_CPU_64
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Ventilador de la CPU"@es ;
    ex:textoExtracto      "El CNC ha detectado que el ventilador de la CPU está parado. Cuando la CPU dispone de ventilador, durante el régimen normal de funcionamiento del CNC, éste monitoriza y vigila que dicho ventilador esté en marcha."@es ;
    ex:monitoreaParametro ex:Temperatura_CPU_64 .

ex:Temperatura_CPU_64
    a               ex:Parametro ;
    rdfs:label      "Temperatura de la CPU"@es ;
    ex:textoExtracto "vigilancia de temperatura"@es .

ex:Alarma_Sobretemperatura_64
    a               ex:Alarma ;
    rdfs:label      "Alarma por sobretemperatura del equipo"@es ;
    ex:textoExtracto "CAUSA Riesgo de sobretemperatura del equipo."@es ;
    ex:activaAlarma  ex:Ventilador_CPU_64 .

ex:Diagnostico_FalloVentilador_64
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: Fallo en ventilador de CPU"@es ;
    ex:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado."@es ;
    ex:solucionaFallo ex:Ventilador_CPU_64 .

ex:Sistema_Monitorizacion_64
    a               ex:Sistema ;
    rdfs:label      "Sistema de monitorización del CNC"@es ;
    ex:textoExtracto "durante el régimen normal de funcionamiento del CNC, éste monitoriza y vigila que dicho ventilador esté en marcha. Dicho testeo se realizará cada minuto, al igual que la vigilancia de temperatura."@es ;
    ex:controla     ex:Ventilador_CPU_64 ;
    ex:monitoreaParametro ex:Temperatura_CPU_64 ;
    ex:tieneComponente ex:Ventilador_CPU_64 .