@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloConexionCNC_VcompciD
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de conexión: CNC no se conecta con VcompciD"@es ;
    ex:textoExtracto "CAUSA El CNC no se puede conectar con VcompciD. SOLUCIÓN Póngase en contacto con su proveedor."@es ;
    ex:identificador "0201" .

ex:FalloCorteRed_BateriaPC
    a ex:AvisoSeguridad ;
    rdfs:label "Corte en la red: PC alimentado con batería"@es ;
    ex:textoExtracto "0201 'Corte en la red. PC alimentado con batería' DETECCIÓN Al leer el estado de la batería. CAUSA Hay un corte en la alimentación del CNC y la batería de emergencia está alimentado el CNC."@es ;
    ex:identificador "0201" .

ex:BateriaEmergencia_CNC
    a ex:ComponenteElectrico ;
    rdfs:label "Batería de emergencia del CNC"@es ;
    ex:textoExtracto "la batería de emergencia está alimentado el CNC"@es ;
    ex:alimenta ex:CNC .

ex:CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "CNC no se puede conectar con VcompciD", "Hay un corte en la alimentación del CNC"@es .

ex:VcompciD
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz VcompciD"@es ;
    ex:textoExtracto "El CNC no se puede conectar con VcompciD"@es .