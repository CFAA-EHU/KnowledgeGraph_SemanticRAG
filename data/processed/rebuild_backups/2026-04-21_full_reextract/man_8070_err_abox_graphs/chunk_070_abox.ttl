@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CodigoError_1010
    a ex:DiagnosticoFallo ;
    rdfs:label "1010 'Programar G4 K'" ;
    ex:identificador "1010" ;
    ex:textoExtracto "1010 'Programar G4 K' [...] SOLUCIÓN Programar la función G4 de la forma G4 <time> ó G4 K<time>, donde el parámetro <time> será el tiempo de espera, en segundos." .

ex:CodigoError_1011
    a ex:DiagnosticoFallo ;
    rdfs:label "1011 'G4: tiempo de espera fuera de rango'" ;
    ex:identificador "1011" ;
    ex:textoExtracto "1011 'G4: tiempo de espera fuera de rango' [...] SOLUCIÓN El máximo valor admisible para el tiempo de espera es 2147483646." ;
    ex:valor "2147483646" .

ex:CodigoError_1012
    a ex:DiagnosticoFallo ;
    rdfs:label "1012 'G4: no es posible programar el tiempo de espera con K'" ;
    ex:identificador "1012" ;
    ex:textoExtracto "1012 'G4: no es posible programar el tiempo de espera con K' [...] SOLUCIÓN Si no se desea tener tercer eje en el canal se puede programar el tiempo de espera directamente con un número." .

ex:CodigoError_1013
    a ex:DiagnosticoFallo ;
    rdfs:label "1013 'G4: no se admite tiempo de espera negativo'" ;
    ex:identificador "1013" ;
    ex:textoExtracto "1013 'G4: no se admite tiempo de espera negativo' [...] SOLUCIÓN Programar un valor mayor o igual que cero." .

ex:CodigoError_1014
    a ex:DiagnosticoFallo ;
    rdfs:label "1014 'No se admite programación en diámetros con imagen espejo en el eje frontal'" ;
    ex:identificador "1014" ;
    ex:textoExtracto "1014 'No se admite programación en diámetros con imagen espejo en el eje frontal' [...] SOLUCIÓN Revisar la programación." .

ex:CodigoError_1015
    a ex:DiagnosticoFallo ;
    rdfs:label "1015 'Coordenadas del centro fuera de rango'" ;
    ex:identificador "1015" ;
    ex:textoExtracto "1015 'Coordenadas del centro fuera de rango' [...] SOLUCIÓN Programar un valor menor." .

ex:Parametro_G4_TiempoEspera
    a ex:Parametro ;
    rdfs:label "Tiempo de espera (G4)" ;
    ex:textoExtracto "Programar la función G4 de la forma G4 <time> ó G4 K<time>, donde el parámetro <time> será el tiempo de espera, en segundos." ;
    ex:valor "segundos" .

ex:Parametro_K_G4
    a ex:Parametro ;
    rdfs:label "Parámetro K (G4)" ;
    ex:textoExtracto "Programar una única vez el tiempo de espera de la función G4. 1010 'Programar G4 K' [...] La letra K va asociada al tercer eje del canal y en este caso no existe tercer eje." .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS (eje frontal)" ;
    ex:textoExtracto "El eje frontal (parámetro FACEAXIS) no puede tener activa la imagen espejo y la programación en diámetros simultáneamente." .

ex:Parametro_I_Interpolacion
    a ex:Parametro ;
    rdfs:label "Parámetro I (centro interpolación)" ;
    ex:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas." .

ex:Parametro_J_Interpolacion
    a ex:Parametro ;
    rdfs:label "Parámetro J (centro interpolación)" ;
    ex:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas." .

ex:Parametro_K_Interpolacion
    a ex:Parametro ;
    rdfs:label "Parámetro K (centro interpolación)" ;
    ex:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas." .

ex:Funcion_G4 a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Función G4 (tiempo de espera)" ;
    ex:textoExtracto "En el mismo bloque, la función G4 tiene programado dos veces el tiempo de espera, directamente con un número y con el parámetro K. [...] Programar la función G4 de la forma G4 <time> ó G4 K<time>." ;
    ex:tieneComponente ex:Parametro_G4_TiempoEspera ;
    ex:tieneComponente ex:Parametro_K_G4 .