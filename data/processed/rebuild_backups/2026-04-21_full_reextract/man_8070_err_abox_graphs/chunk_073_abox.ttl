@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1023
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1023: Número de gama no válido" ;
    ex:textoExtracto "1023 'Número de gama no válido' [...] CAUSA El número de gama (set) del eje es incorrecto." ;
    ex:identificador "1023" .

ex:DiagnosticoFallo_1024
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1024: Número de gama fuera de rango" ;
    ex:textoExtracto "1024 'Número de gama fuera de rango' [...] CAUSA El número de gama (set) del eje es demasiado alto." ;
    ex:identificador "1024" .

ex:Parametro_ACForward
    a ex:Parametro ;
    rdfs:label "Porcentaje de feed forward (AC forward)" ;
    ex:textoExtracto "El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." ;
    ex:valor "0 < AC forward < 120" .

ex:Parametro_NPARSETS
    a ex:Parametro ;
    rdfs:label "Parámetro máquina NPARSETS" ;
    ex:textoExtracto "La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." ;
    ex:identificador "NPARSETS" .

ex:Maquina_Eje
    a ex:Maquina ;
    rdfs:label "Eje de la máquina" ;
    ex:textoExtracto "El número de gama (set) del eje es incorrecto." ;
    ex:monitoreaParametro ex:Parametro_ACForward ;
    ex:monitoreaParametro ex:Parametro_NPARSETS .