@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1048
    a ex:Alarma ;
    rdfs:label "Compensación de longitud de herramienta con radio fuera de rango" ;
    ex:textoExtracto "'1048' 'Compensación de longitud de herramienta con radio fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las dimensiones de la herramienta exceden los valores máximos. SOLUCIÓN Modificar las dimensiones de la herramienta." ;
    ex:identificador "1048" .

ex:Alarma_1049
    a ex:Alarma ;
    rdfs:label "Eje frontal (FACEAXIS) definido dos veces en el plano activo" ;
    ex:textoExtracto "'1049' 'Eje frontal (FACEAXIS) definido dos veces en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes del plano principal son ejes frontales (parámetro FACEAXIS). SOLUCIÓN En el plano de trabajo sólo puede haber un eje frontal." ;
    ex:identificador "1049" .

ex:Alarma_1050
    a ex:Alarma ;
    rdfs:label "Considerados los offsets de herramientas, se excede el rango de datos" ;
    ex:textoExtracto "'1050' 'Considerados los offsets de herramientas, se excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA Las dimensiones de la herramienta exceden los valores máximos. SOLUCIÓN Modificar las dimensiones de la herramienta." ;
    ex:identificador "1050" .

ex:Alarma_1051
    a ex:Alarma ;
    rdfs:label "Eje no existente o no disponible en el canal" ;
    ex:textoExtracto "'1051' 'Eje no existente o no disponible en el canal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El CNC ha intentado ejecutar un movimiento independiente en un cabezal. • El eje programado en una variable no está disponible. SOLUCIÓN Revisar la programación. Para poder interpolar el cabezal como eje independiente, éste debe estar activo como eje C." ;
    ex:identificador "1051" .

ex:Alarma_1052
    a ex:Alarma ;
    rdfs:label "Valores resultado de la medición fuera de rango" ;
    ex:textoExtracto "'1052' 'Valores resultado de la medición fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El CNC ha realizado una medición con la función G100 y la cota o el offset obtenido es demasiado grande." ;
    ex:identificador "1052" .

ex:Alarma_1000_1999_PlanoIncompleto
    a ex:Alarma ;
    rdfs:label "Tercer eje para el plano (índice 5) faltante o incorrecto" ;
    ex:textoExtracto "'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto. SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. El parámetro no deberá coincidir ni con el primero ni con el segundo y deberá ser uno de los tres primeros ejes del canal." ;
    ex:identificador "G20_PlanoIncompleto" .

ex:Parametro_3
    a ex:Parametro ;
    rdfs:label "Eje longitudinal de la herramienta" ;
    ex:textoExtracto "eje longitudinal de la herramienta (parámetro 3)" ;
    ex:identificador "3" .

ex:Parametro_1
    a ex:Parametro ;
    rdfs:label "Primer eje del plano" ;
    ex:textoExtracto "primer eje del plano (parámetros 1)" ;
    ex:identificador "1" .

ex:Parametro_2
    a ex:Parametro ;
    rdfs:label "Segundo eje del plano" ;
    ex:textoExtracto "segundo eje del plano (parámetros 2)" ;
    ex:identificador "2" .

ex:Parametro_5
    a ex:Parametro ;
    rdfs:label "Tercer eje del plano" ;
    ex:textoExtracto "programar el tercer eje con el parámetro 5" ;
    ex:identificador "5" .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "Eje frontal (FACEAXIS)" ;
    ex:textoExtracto "parámetro FACEAXIS" ;
    ex:identificador "FACEAXIS" .

ex:Funcion_G20 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Cambio de plano (G20)" ;
    ex:textoExtracto "función G20 (cambio de plano)" ;
    ex:identificador "G20" .

ex:Funcion_G100 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Medición (G100)" ;
    ex:textoExtracto "función G100" ;
    ex:identificador "G100" .

ex:Alarma_1000_1999_PlanoIncompleto
    ex:activaAlarma ex:Funcion_G20 .

ex:Alarma_1052
    ex:activaAlarma ex:Funcion_G100 .