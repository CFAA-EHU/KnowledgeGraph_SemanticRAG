@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_G100_ValorFueraRango
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en medición G100: valor fuera de rango" ;
    ex:textoExtracto "El CNC ha realizado una medición con la función G100 y la cota o el offset obtenido es demasiado grande. [...] El valor obtenido en la palpación debe estar entre -2147483647 y 2147483646." ;
    ex:valor         "-2147483647 a 2147483646" .

ex:Fallo_GarraInexistente_1054
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1054: Garra inexistente" ;
    ex:identificador "1054" ;
    ex:textoExtracto "1054 'Garra inexistente' [...] CAUSA El número de garra programado no existe." .