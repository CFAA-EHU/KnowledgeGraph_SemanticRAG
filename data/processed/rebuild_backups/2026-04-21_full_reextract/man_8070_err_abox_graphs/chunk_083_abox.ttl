@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:alarma_1060
    a ex:Alarma ;
    rdfs:label "Valor de etiqueta N fuera de rango" ;
    ex:identificador "1060" ;
    ex:textoExtracto "1060 'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" no es válido. SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." .

ex:alarma_1061
    a ex:Alarma ;
    rdfs:label "Función G inexistente" ;
    ex:identificador "1061" ;
    ex:textoExtracto "1061 'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe. SOLUCIÓN Revisar la programación." .

ex:parametro_NumeroBloque
    a ex:Parametro ;
    rdfs:label "Número de bloque (N)" ;
    ex:textoExtracto "El número de bloque \"N\" no es válido. [...] El número de bloque debe ser un valor positivo y menor que 2147483646." ;
    ex:valor "2147483646"^^xsd:integer .

ex:parametro_FuncionG
    a ex:Parametro ;
    rdfs:label "Función G programada" ;
    ex:textoExtracto "La función G programada no existe." .

ex:alarma_1060 ex:monitoreaParametro ex:parametro_NumeroBloque .
ex:alarma_1061 ex:monitoreaParametro ex:parametro_FuncionG .