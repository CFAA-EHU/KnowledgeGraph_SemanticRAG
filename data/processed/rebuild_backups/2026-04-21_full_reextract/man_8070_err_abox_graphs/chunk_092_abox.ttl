@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1096
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1096: 'No se admite programar la velocidad con E'" ;
    ex:identificador "1096" ;
    ex:textoExtracto "1096 'No se admite programar la velocidad con E' DETECCIÓN Durante la ejecución. CAUSA El avance se ha programado con la función E. SOLUCIÓN Programar el avance con la función F." .

ex:Error_1097
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1097: 'Nombre de cabezal desconocido'" ;
    ex:identificador "1097" ;
    ex:textoExtracto "1097 'Nombre de cabezal desconocido' DETECCIÓN Durante la ejecución. CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal. SOLUCIÓN Los nombres válidos para el cabezal son S, S1, …, S9. El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal. Un canal sólo puede controlar sus cabezales." .

ex:Error_1098
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1098: 'Velocidad S doblemente programada'" ;
    ex:identificador "1098" ;
    ex:textoExtracto "1098 'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones S. SOLUCIÓN En un mismo bloque sólo puede haber una velocidad para cada cabezal." .

ex:Error_1100
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1100: 'Índice de parámetro fuera de rango'" ;
    ex:identificador "1100" ;
    ex:textoExtracto "1100 'Indice de parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." .

ex:ParametroMaquina
    a ex:Parametro ;
    rdfs:label "Parámetros máquina" ;
    ex:textoExtracto "rango permitido por los parámetros máquina" ;
    ex:textoExtracto "rango de parámetros aritméticos valido" .

ex:Funcion_F a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función F (avance)" ;
    ex:textoExtracto "Programar el avance con la función F" .

ex:Funcion_S a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función S (velocidad)" ;
    ex:textoExtracto "funciones S" ;
    ex:textoExtracto "velocidad para cada cabezal" .

ex:Cabezal_S
    a ex:Componente ;
    rdfs:label "Cabezal (nomenclatura: S, S1, ..., S9)" ;
    ex:identificador "S, S1, ..., S9" ;
    ex:textoExtracto "Los nombres válidos para el cabezal son S, S1, …, S9" .

ex:SistemaControl
    a ex:Sistema ;
    rdfs:label "Sistema de control de cabezales" ;
    ex:textoExtracto "El cabezal programado en el bloque debe existir en la configuración del sistema" ;
    ex:textoExtracto "Un canal sólo puede controlar sus cabezales" .

ex:CanalControl
    a ex:InterfazUsuario ;
    rdfs:label "Canal de control" ;
    ex:textoExtracto "configuración del canal" ;
    ex:textoExtracto "Un canal sólo puede controlar sus cabezales" .

ex:Error_1096 ex:solucionaFallo ex:Funcion_F .
ex:Error_1097 ex:solucionaFallo ex:Cabezal_S .
ex:Error_1098 ex:solucionaFallo ex:Funcion_S .
ex:Error_1100 ex:monitoreaParametro ex:ParametroMaquina .
ex:Cabezal_S ex:controla ex:Funcion_S .
ex:SistemaControl ex:tieneComponente ex:CanalControl .
ex:SistemaControl ex:tieneComponente ex:Cabezal_S .