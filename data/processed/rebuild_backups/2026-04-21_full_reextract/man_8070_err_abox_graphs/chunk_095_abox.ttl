ex:Error_1108
    a                   ex:AvisoSeguridad ;
    rdfs:label          "Error 1108: 'Eje doblemente programado'"@es ;
    ex:textoExtracto    "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución. CAUSA En alguna de las siguientes funciones hay programado algún eje más de una vez. • Movimiento de ejes en G0, G1, G2, G3, G8 o G9. • Roscado G33 o G63. • Sentencias #FACE o #CYL. • Selección de plano, G20."@es ;
    ex:identificador    "1108" .

