@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1113
    a ex:Alarma ;
    rdfs:label "Alarma 1113: 'No se espera $ELSE'" ;
    ex:textoExtracto "'No se espera $ELSE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSE sin una instrucción $IF previa. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1113" .

ex:Alarma_1114
    a ex:Alarma ;
    rdfs:label "Alarma 1114: 'La sentencia $ELSE se programa sola en el bloque'" ;
    ex:textoExtracto "'La sentencia $ELSE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1114" .

ex:Alarma_1115
    a ex:Alarma ;
    rdfs:label "Alarma 1115: 'No se espera $ELSEIF'" ;
    ex:textoExtracto "'No se espera $ELSEIF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSEIF sin" ;
    ex:identificador "1115" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha detectado una instrucción $ELSE sin una instrucción $IF previa" ;
    ex:activaAlarma ex:Alarma_1113 ;
    ex:activaAlarma ex:Alarma_1114 ;
    ex:activaAlarma ex:Alarma_1115 .