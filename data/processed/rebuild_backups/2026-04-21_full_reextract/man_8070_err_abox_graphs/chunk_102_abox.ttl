@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ErrorCNC_1134
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1134: Sentencia $ENDWHILE mal programada"@es ;
    ex:identificador      "1134" ;
    ex:textoExtracto      "'La sentencia $ENDWHILE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:ErrorCNC_1135
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1135: Sentencia $DO mal programada"@es ;
    ex:identificador      "1135" ;
    ex:textoExtracto      "'La sentencia $DO se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:ErrorCNC_1136
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1136: Instrucción $ENDDO inesperada"@es ;
    ex:identificador      "1136" ;
    ex:textoExtracto      "'No se espera $ENDDO' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDDO sin una instrucción $DO previa. SOLUCIÓN Revisar la programación."@es .

ex:ErrorCNC_1137
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1137: Sentencia $ENDDO mal programada"@es ;
    ex:identificador      "1137" ;
    ex:textoExtracto      "'La sentencia $ENDDO <expresión> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:ErrorCNC_1138
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1138: Sentencia $BREAK mal programada"@es ;
    ex:identificador      "1138" ;
    ex:textoExtracto      "'La sentencia $BREAK se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:ErrorCNC_1139
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1139: Instrucción $BREAK inesperada"@es ;
    ex:identificador      "1139" ;
    ex:textoExtracto      "'No se espera $BREAK' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $BREAK pero no hay ningún bucle de control abierto; $IF, $ELSE, $FOR, $WHILE, $DO o $CASE. SOLUCIÓN Revisar la programación. El CNC utiliza la instrucción $BREAK para finalizar un $CASE o para salir de un bucle $IF, $ELSE, $WHILE, $FOR o $DO antes de que finalice."@es .

ex:ErrorCNC_1140
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error 1140: Instrucción $CONTINUE inesperada"@es ;
    ex:identificador      "1140" ;
    ex:textoExtracto      "'No se espera $CONTINUE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $CONTINUE pero no hay ningún bucle de control abierto; $FOR, $WHILE o $DO. SOLUCIÓN Revisar la programación. El CNC utiliza la instrucción $CONTINUE para volver al punto inicial de un bucle $FOR, $WHILE o $DO."@es .

ex:ErrorCNC_General
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Error CNC: Instrucción $ENDWHILE sin $WHILE previa"@es ;
    ex:textoExtracto      "El CNC ha detectado una instrucción $ENDWHILE sin una instrucción $WHILE previa. SOLUCIÓN Revisar la programación."@es .

ex:SistemaCNC
    a                     ex:Sistema ;
    rdfs:label            "Sistema de Control Numérico Computarizado (CNC)"@es ;
    ex:textoExtracto      "El CNC ha detectado una instrucción..."@es .