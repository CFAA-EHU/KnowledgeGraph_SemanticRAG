@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1141
    a               ex:Alarma ;
    rdfs:label      "Alarma 1141: Sentencia $CONTINUE mal programada"@es ;
    ex:identificador "1141" ;
    ex:textoExtracto "1141 'La sentencia $CONTINUE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1142
    a               ex:Alarma ;
    rdfs:label      "Alarma 1142: Sentencia #TIME mal programada"@es ;
    ex:identificador "1142" ;
    ex:textoExtracto "1142 'La sentencia #TIME se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está"@es .

ex:DiagnosticoFallo_1141
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: $CONTINUE sin bucle abierto"@es ;
    ex:textoExtracto "CAUSA El CNC ha detectado una instrucción $CONTINUE pero no hay ningún bucle de control abierto; $FOR, $WHILE o $DO. SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1141 .

ex:DiagnosticoFallo_1142
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico: #TIME no programada correctamente"@es ;
    ex:textoExtracto "CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo ex:Alarma_1142 .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "El CNC utiliza la instrucción $CONTINUE para volver al punto inicial de un bucle $FOR, $WHILE o $DO."@es ;
    ex:activaAlarma ex:Alarma_1141 , ex:Alarma_1142 .