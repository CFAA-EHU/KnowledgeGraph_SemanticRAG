    a                     ex:AvisoSeguridad ;
    rdfs:label            "Demasiadas subrutinas"@es ;
    ex:identificador      "1153" ;
    ex:textoExtracto      "1153 'Demasiadas subrutinas"@es .

ex:AccionProhibida_ProgramacionEntreGYPrimerBloqueMovimiento
    a                     ex:AccionProhibida ;
    rdfs:label            "Programar entre la función G de trayectoria de empalme y el primer bloque de movimiento"@es ;
    ex:textoExtracto      "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento."@es .