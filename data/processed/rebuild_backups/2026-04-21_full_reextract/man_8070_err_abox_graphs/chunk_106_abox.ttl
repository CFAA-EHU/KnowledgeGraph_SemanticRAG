@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1153
    a ex:Alarma ;
    rdfs:label "Demasiadas subrutinas locales definidas en el programa" ;
    ex:identificador "1153" ;
    ex:textoExtracto "1153 'Demasiadas subrutinas locales definidas en el programa' [...] SOLUCIÓN Reducir el número de subrutinas locales; agrupar varias subrutinas en una o utilizar subrutinas globales. El CNC permite 130 subrutinas locales por programa." .

ex:Alarma_1154
    a ex:Alarma ;
    rdfs:label "Nombre de fichero demasiado largo" ;
    ex:identificador "1154" ;
    ex:textoExtracto "1154 'Nombre de fichero demasiado largo' [...] SOLUCIÓN Reducir el número de caracteres en el nombre de programa o subrutina. Cambiar la ubicación del programa o subrutina para reducir el número de caracteres en el path." .

ex:Alarma_1155
    a ex:Alarma ;
    rdfs:label "No se puede acceder al fichero" ;
    ex:identificador "1155" ;
    ex:textoExtracto "1155 No se puede acceder al fichero. [...] SOLUCIÓN Comprobar que el archivo existe, es válido y no está corrupto. En el caso de las llamadas a subrutinas comprobar que el nombre y el path son correctos." .

ex:Alarma_1156
    a ex:Alarma ;
    rdfs:label "Programa principal no encontrado" ;
    ex:identificador "1156" ;
    ex:textoExtracto "1156 'Programa principal no encontrado' [...] SOLUCIÓN En un programa con subrutinas locales, el programa principal debe tener un nombre (%nombre)." .

ex:Alarma_1157
    a ex:Alarma ;
    rdfs:label "Subrutina global no encontrada" ;
    ex:identificador "1157" ;
    ex:textoExtracto "1157 'Subrutina global no encontrada' [...] SOLUCIÓN Comprobar que el" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC permite 20 niveles de imbricación. [...] El CNC permite 130 subrutinas locales por programa." ;
    ex:activaAlarma ex:Alarma_1153, ex:Alarma_1154, ex:Alarma_1155, ex:Alarma_1156, ex:Alarma_1157 .

ex:Parametro_NivelesImbricacion
    a ex:Parametro ;
    rdfs:label "Niveles de imbricación permitidos" ;
    ex:valor "20" ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:textoExtracto "El CNC permite 20 niveles de imbricación." .

ex:Parametro_SubrutinasLocales
    a ex:Parametro ;
    rdfs:label "Subrutinas locales máximas por programa" ;
    ex:valor "130" ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:textoExtracto "El CNC permite 130 subrutinas locales por programa." .

ex:Parametro_LongitudNombreFichero
    a ex:Parametro ;
    rdfs:label "Longitud máxima de nombre de fichero" ;
    ex:valor "63" ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:textoExtracto "El nombre de un programa o subrutina puede tener un máximo de 63 caracteres" .

ex:Parametro_LongitudPath
    a ex:Parametro ;
    rdfs:label "Longitud máxima de path" ;
    ex:valor "120" ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:textoExtracto "el path 120 caracteres." .