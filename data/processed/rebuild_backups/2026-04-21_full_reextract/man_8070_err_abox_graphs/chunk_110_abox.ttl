ex:Error_1168
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1168: Índice de variable fuera de rango"@es ;
    ex:textoExtracto "1168 'Indice de variable fuera de rango' [...] CAUSA Alguno de los índices definidos en la variable de array es incorrecto."@es ;
    ex:identificador "1168" .

ex:Error_1169
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1169: Logaritmo de número no válido"@es ;
    ex:textoExtracto "CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero."@es ;
    ex:identificador "1169" .

ex:Parametro_G_GS
    a ex:Parametro ;
    rdfs:label "Parámetro G.GS (índice 0 admitido)"@es ;
    ex:textoExtracto "Hay algunos casos particulares en los que el índice 0 es admitido: G.GS, G.MS, G.LUP1 a G.LUP7, G.LUPACT y MTB.P."@es ;
    ex:identificador "G.GS" .

