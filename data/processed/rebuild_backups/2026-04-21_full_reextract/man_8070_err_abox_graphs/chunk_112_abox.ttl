@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error1174
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 1174: '#LINK: no se permite definir un nuevo acoplo con uno anterior activo'"@es ;
    ex:textoExtracto "1174 '#LINK: no se permite definir un nuevo acoplo con uno anterior activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero."@es ;
    ex:identificador "1174" .

ex:Error1175
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 1175: '#LINK: no [...]'"@es ;
    ex:textoExtracto "1175 '#LINK: no"@es ;
    ex:identificador "1175" .

ex:SistemaCNC
    a               ex:Sistema ;
    ex:textoExtracto "El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero."@es ;
    ex:activaAlarma  ex:Error1174 .

ex:TareaRevisarProgramacion_1174
    a               ex:TareaMantenimiento ;
    rdfs:label      "Revisar la programación para el error 1174"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Desactivar el primer acoplo antes de activar el segundo. Para tener ambos acoplos, desactivar el primer acoplo y activar ambos con una única sentencia #LINK."@es ;
    ex:solucionaFallo ex:Error1174 .