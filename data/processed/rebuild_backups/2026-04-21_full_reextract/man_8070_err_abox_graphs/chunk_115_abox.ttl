@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1181
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1181: Eje esclavo activo en G201" ;
    ex:identificador "1181" ;
    ex:textoExtracto "#LINK: no se puede definir como esclavo un eje activo en G201" ;
    ex:textoExtracto "CAUSA El eje esclavo de un acoplo está activo en modo manual aditivo (G201). SOLUCIÓN Anular el modo manual aditivo para poder acoplar el eje." .

ex:Error_1182
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1182: Exceso de acoplos programados" ;
    ex:identificador "1182" ;
    ex:textoExtracto "#LINK: demasiados acoplos programados" ;
    ex:textoExtracto "CAUSA El número de acoplos que definidos supera el máximo permitido. SOLUCIÓN El máximo número de acoplos que pueden estar activos en un canal es igual al número de ejes del canal menos tres." .

ex:Error_1183
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1183: Sentencia #LINK no programada sola" ;
    ex:identificador "1183" ;
    ex:textoExtracto "La sentencia #LINK se programa sola en el bloque" ;
    ex:textoExtracto "CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ex:Error_1184
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1184: Ejes maestro/esclavo coincidentes" ;
    ex:identificador "1184" ;
    ex:textoExtracto "#LINK: el eje maestro y esclavo coinciden" ;
    ex:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son el mismo eje. SOLUCIÓN Los ejes maestro y esclavo han de ser diferentes." .

ex:Error_1185
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1185: Eje esclavo con múltiples maestros" ;
    ex:identificador "1185" ;
    ex:textoExtracto "#LINK: un eje no puede ser esclavo de varios maestros" ;
    ex:textoExtracto "CAUSA Un eje es esclavo de varios maestros. SOLUCIÓN Un eje sólo puede ser esclavo de un maestro." .

ex:Error_1186
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1186: Eje maestro/esclavo en acoplos cruzados" ;
    ex:identificador "1186" ;
    ex:textoExtracto "#LINK: un eje maestro no puede ser esclavo en otro acoplo y viceversa" ;
    ex:textoExtracto "CAUSA Un eje no puede ser esclavo en un acoplo y mestro en otro. SOLUCIÓN Un eje no puede ser maestro en un acoplo y esclavo en otro." .

ex:Error_1187
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1187: Nombre de eje repetido" ;
    ex:identificador "1187" ;
    ex:textoExtracto "#AXIS: nombre de eje repetido" ;
    ex:textoExtracto "CAUSA El mismo eje se ha programado más de una vez en la sentencia." .

ex:DiagnosticoFallo_AcoploEjesIncompatibles
    a ex:DiagnosticoFallo ;
    rdfs:label "Acoplo con ejes de tipo incompatible" ;
    ex:textoExtracto "CAUSA Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo. SOLUCIÓN Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)." .

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:identificador "AXISMODE" ;
    ex:textoExtracto "parámetro AXISMODE" ;
    ex:valor "linearlike|modulo" .