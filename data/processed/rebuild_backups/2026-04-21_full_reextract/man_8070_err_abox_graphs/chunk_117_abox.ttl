@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1189
    a ex:AvisoSeguridad ;
    rdfs:label "Error #MPG: demasiados parámetros" ;
    ex:identificador "1189" ;
    ex:textoExtracto "la programación. 1189 '#MPG: demasiados parámetros' DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres parámetros. Cada uno de ellos representa el desplazamiento por impulso del volante en cada posición del conmutador." .

ex:AvisoSeguridad_1190
    a ex:AvisoSeguridad ;
    rdfs:label "Error #MPG: resolución de volante no válida" ;
    ex:identificador "1190" ;
    ex:textoExtracto "1190 '#MPG: no se permiten resoluciones de volante negativas o cero' DETECCIÓN Durante la ejecución. CAUSA La sentencia #MPG intenta definir una resolución de volante negativa o nula. SOLUCIÓN El desplazamiento por impulso del volante debe ser un valor positivo y no nulo." .

ex:AvisoSeguridad_1191
    a ex:AvisoSeguridad ;
    rdfs:label "Error #INCJOG: distancia incremental no válida" ;
    ex:identificador "1191" ;
    ex:textoExtracto "1191 '#INCJOG: no se permiten distancias de jog incremental negativas o cero' DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir una distancia negativa o nula. SOLUCIÓN El desplazamiento incremental del eje en cada posición del conmutador debe ser un valor positivo y no nulo." .

ex:AvisoSeguridad_1192
    a ex:AvisoSeguridad ;
    rdfs:label "Error #INCJOG: velocidad incremental no válida" ;
    ex:identificador "1192" ;
    ex:textoExtracto "1192 '#INCJOG: no se permiten velocidades de jog incremental negativas o cero' DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en cada posición del conmutador debe ser un valor positivo y no nulo." .

ex:AvisoSeguridad_1193
    a ex:AvisoSeguridad ;
    rdfs:label "Error #CONTJOG/#INCJOG: avance fuera de rango" ;
    ex:identificador "1193" ;
    ex:textoExtracto "1193 '#CONTJOG/#INCJOG: avance programado fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El avance programado es demasiado alto. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1194
    a ex:AvisoSeguridad ;
    rdfs:label "Error #INCJOG: demasiados parámetros" ;
    ex:identificador "1194" ;
    ex:textoExtracto "1194 '#INCJOG: demasiados parámetros' DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #INCJOG admite un máximo de cinco grupos de parámetros. Cada uno de ellos representa el avance y el desplazamiento del eje para cada posición del conmutador en jog incremental." .

ex:AvisoSeguridad_1195
    a ex:AvisoSeguridad ;
    rdfs:label "Error #CONTJOG: demasiados parámetros" ;
    ex:identificador "1195" ;
    ex:textoExtracto "1195 '#CONTJOG: demasiados parámetros' DETECCIÓN Durante la ejecución." .

ex:Parametro_MPG_DesplazamientoPorImpulso
    a ex:Parametro ;
    rdfs:label "Desplazamiento por impulso del volante (#MPG)" ;
    ex:textoExtracto "Cada uno de ellos representa el desplazamiento por impulso del volante en cada posición del conmutador." ;
    ex:valor "3"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_INCJOG_GruposParametros
    a ex:Parametro ;
    rdfs:label "Grupos de parámetros (#INCJOG)" ;
    ex:textoExtracto "La sentencia #INCJOG admite un máximo de cinco grupos de parámetros." ;
    ex:valor "5"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_MPG_ResolucionVolante
    a ex:Parametro ;
    rdfs:label "Resolución de volante (#MPG)" ;
    ex:textoExtracto "El desplazamiento por impulso del volante debe ser un valor positivo y no nulo." ;
    ex:valor ">0"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_INCJOG_DistanciaIncremental
    a ex:Parametro ;
    rdfs:label "Distancia incremental (#INCJOG)" ;
    ex:textoExtracto "El desplazamiento incremental del eje en cada posición del conmutador debe ser un valor positivo y no nulo." ;
    ex:valor ">0"^^<http://www.w3.org/2001/XMLSchema#string> .

ex:Parametro_INCJOG_VelocidadIncremental
    a ex:Parametro ;
    rdfs:label "Velocidad incremental (#INCJOG)" ;
    ex:textoExtracto "El avance del eje en cada posición del conmutador debe ser un valor positivo y no nulo." ;
    ex:valor ">0"^^<http://www.w3.org/2001/XMLSchema#string> .