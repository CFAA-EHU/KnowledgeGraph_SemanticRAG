@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_INCJOG
    a               ex:Parametro ;
    rdfs:label      "Parámetro #INCJOG"@es ;
    ex:textoExtracto
        "La sentencia #INCJOG admite un máximo de cinco grupos de parámetros. Cada uno de ellos representa el avance y el desplazamiento del eje para cada posición del conmutador en jog incremental."@es ;
    ex:identificador "#INCJOG" .

ex:Parametro_CONTJOG
    a               ex:Parametro ;
    rdfs:label      "Parámetro #CONTJOG"@es ;
    ex:textoExtracto
        "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo."@es ;
    ex:identificador "#CONTJOG" .

ex:AvisoSeguridad_1195
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 1195: '#CONTJOG: demasiados parámetros'"@es ;
    ex:textoExtracto
        "'#CONTJOG: demasiados parámetros' [...] CAUSA La sentencia tiene más parámetros de los permitidos."@es ;
    ex:identificador "1195" .

ex:AvisoSeguridad_1196
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas'"@es ;
    ex:textoExtracto
        "'#CONTJOG: no se permiten velocidades de jog continuo negativas o"@es ;
    ex:identificador "1196" .

ex:AvisoSeguridad_1195
    ex:mitigaRiesgo  ex:Parametro_CONTJOG .

ex:AvisoSeguridad_1196
    ex:mitigaRiesgo  ex:Parametro_CONTJOG .