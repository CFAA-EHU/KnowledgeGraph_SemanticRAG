@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_1196
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'"@es ;
    ex:textoExtracto "1196 '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero' DETECCIÓN Durante la ejecución. CAUSA La sentencia #CONTJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en jog continuo debe ser un valor positivo y no nulo."@es ;
    ex:identificador "1196" .

ex:Error_1197
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1197: '#SET OFFSET: offset inferior positivo'"@es ;
    ex:textoExtracto "1197 '#SET OFFSET: offset inferior positivo' DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido inferior del eje para el desplazamiento manual tiene un valor positivo. SOLUCIÓN El límite de recorrido inferior para el desplazamiento manual ser un valor negativo o cero."@es ;
    ex:identificador "1197" .

ex:Error_1198
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1198: '#SET OFFSET: límite negativo fuera de rango'"@es ;
    ex:textoExtracto "1198 '#SET OFFSET: límite negativo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido inferior es demasiado bajo. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1198" .

ex:Error_1199
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1199: '#SET OFFSET: offset superior negativo'"@es ;
    ex:textoExtracto "1199 '#SET OFFSET: offset superior negativo' DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido superior del eje para el desplazamiento manual tiene un valor negativo. SOLUCIÓN El límite de recorrido superior para el desplazamiento manual ser un valor positivo o cero."@es ;
    ex:identificador "1199" .

ex:Error_1200
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1200: '#SET OFFSET: límite positivo fuera de rango'"@es ;
    ex:textoExtracto "1200 '#SET OFFSET: límite positivo fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido superior es demasiado alto. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1200" .

ex:Error_1201
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1201: '#SET OFFSET: offset superior e inferior nulos'"@es ;
    ex:textoExtracto "1201 '#SET OFFSET: offset superior e inferior nulos' DETECCIÓN Durante la ejecución. CAUSA Los límites de recorrido del eje para el desplazamiento manual son nulos. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1201" .

ex:Error_1202
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1202: '#SET IPOPOS: demasiados parámetros'"@es ;
    ex:textoExtracto "1202 #SET IPOPOS: demasiados parámetros. DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene demasiados parámetros. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1202" .

ex:Error_1203
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1203: 'La sentencia #SET IPOPOS se programa sola en el bloque'"@es ;
    ex:textoExtracto "1203 'La sentencia #SET IPOPOS se programa sola en el bloque' DETECCIÓN Durante la ejecución."@es ;
    ex:identificador "1203" .

ex:Parametro_CONTJOG
    a ex:Parametro ;
    rdfs:label "Parámetro de avance en jog continuo (#CONTJOG)"@es ;
    ex:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo."@es ;
    ex:identificador "#CONTJOG" .

ex:Parametro_SETOFFSET_Inferior
    a ex:Parametro ;
    rdfs:label "Límite de recorrido inferior del eje (#SET OFFSET)"@es ;
    ex:textoExtracto "El límite de recorrido inferior del eje para el desplazamiento manual"@es ;
    ex:identificador "#SET OFFSET (inferior)" .

ex:Parametro_SETOFFSET_Superior
    a ex:Parametro ;
    rdfs:label "Límite de recorrido superior del eje (#SET OFFSET)"@es ;
    ex:textoExtracto "El límite de recorrido superior del eje para el desplazamiento manual"@es ;
    ex:identificador "#SET OFFSET (superior)" .

ex:Parametro_IPOPOS
    a ex:Parametro ;
    rdfs:label "Parámetro de posición interpolada (#SET IPOPOS)"@es ;
    ex:textoExtracto "La sentencia #SET IPOPOS"@es ;
    ex:identificador "#SET IPOPOS" .