@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1214 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1214: '#CALL AX/#SET AX: demasiados ejes requeridos'"@es ;
    ex:identificador "1214" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Demasiados ejes programados; el número de ejes supera el número de ejes del sistema. SOLUCIÓN Repasar la configuración de ejes definida para el canal. El número de ejes de un canal no puede superar el número de ejes del sistema."@es .

ex:Error_1215 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1215: 'La sentencia #CALL AX/#SET AX se programa sola en el bloque'"@es ;
    ex:identificador "1215" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:Error_1216 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1216: '#CALL AX/#CAX: nombre de eje en uso'"@es ;
    ex:identificador "1216" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El nombre de uno de los ejes está siendo utilizado por un eje C. SOLUCIÓN Revisar la programación."@es .

ex:Error_1217 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1217: '#CALL AX: índice en uso'"@es ;
    ex:identificador "1217" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Una de las posiciones está ocupada por otro eje. SOLUCIÓN Repasar la configuración de ejes definida para el canal; dos ejes no pueden estar en la misma posición. Un eje puede utilizar cualquier posición libre comprendida entre 1 y un número igual al máximo de ejes más cabezales permitido por el sistema."@es .

ex:Error_1218 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1218: 'La sentencia #FREE AX se programa sola en el bloque'"@es ;
    ex:identificador "1218" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ex:Error_1219 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1219: 'Se espera \",\" o \"]\"'"@es ;
    ex:identificador "1219" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación."@es .

ex:Error_1220 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1220: '#FREE AX: no se permite eliminar un eje activo en modo manual'"@es ;
    ex:identificador "1220" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Un eje en modo manual aditivo (G201) no se puede eliminar del canal."@es .

ex:Error_1213 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1213: '#CALL AX con la función G63 activa'"@es ;
    ex:identificador "1213" ;
    ex:textoExtracto "CAUSA No se permite programar #CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .