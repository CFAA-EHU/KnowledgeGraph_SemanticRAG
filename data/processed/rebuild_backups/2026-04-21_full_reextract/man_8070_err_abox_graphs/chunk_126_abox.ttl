@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1228
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1228: Eje longitudinal no definido" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje longitudinal. SOLUCIÓN Definir uno de los ejes del plano como eje longitudinal (parámetro LONGAXIS)." ;
    ex:identificador "1228" .

ex:Error_1229
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1229: Anidamiento de sentencias condicionales sobrepasado" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR," ;
    ex:identificador "1229" .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro LONGAXIS" ;
    ex:textoExtracto "parámetro LONGAXIS" ;
    ex:identificador "LONGAXIS" ;
    ex:solucionaFallo ex:Error_1228 .