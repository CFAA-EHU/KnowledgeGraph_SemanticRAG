@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1241
    a ex:Alarma ;
    rdfs:label "Alarma 1241: Falta el texto de sustitución de la macro"@es ;
    ex:identificador "1241" ;
    ex:textoExtracto "1241 'Falta el texto de sustitución de la macro' DETECCIÓN Durante la ejecución. CAUSA El texto de sustitución asociado a la macro es una cadena de caracteres vacía. SOLUCIÓN Asociar a la macro el texto de sustitución adecuado según la funcionalidad que se le quiera dar. El texto de sustitución debe ir escrito entre comillas."@es .

ex:Alarma_1244
    a ex:Alarma ;
    rdfs:label "Alarma 1244: Eje frontal próximo al centro"@es ;
    ex:identificador "1244" ;
    ex:textoExtracto "1244 'Eje frontal próximo al centro: la velocidad del cabezal en G96 ha sido limitada' DETECCIÓN Durante la ejecución. CAUSA Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal debido a la proximidad del eje frontal al centro de giro. SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación."@es .

ex:Alarma_1245
    a ex:Alarma ;
    rdfs:label "Alarma 1245: G96 sin eje frontal definido"@es ;
    ex:identificador "1245" ;
    ex:textoExtracto "1245 'G96: no hay eje frontal (FACEAXIS) definido en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje frontal. SOLUCIÓN Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)."@es .

ex:Alarma_1246
    a ex:Alarma ;
    rdfs:label "Alarma 1246: Roscado no admitido con G95"@es ;
    ex:identificador "1246" ;
    ex:textoExtracto "1246 'No se admite roscado con avance en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal). SOLUCIÓN Activar el avance en función del tiempo (G94)."@es .

ex:Alarma_1247
    a ex:Alarma ;
    rdfs:label "Alarma 1247: Roscado no admitido con G96"@es ;
    ex:identificador "1247" ;
    ex:textoExtracto "1247 'No se admite roscado con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). SOLUCIÓN Activar el modo de velocidad de giro constante (G97)."@es .

ex:ModoOperacion_MDI_MDA
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ex:textoExtracto "un programa o desde el modo MDI/MDA, de manera que están disponibles para todos los programas ejecutados a continuación."@es .

ex:Parametro_G96
    a ex:Parametro ;
    rdfs:label "G96 (velocidad de corte constante)"@es ;
    ex:identificador "G96" ;
    ex:textoExtracto "Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal debido a la proximidad del eje frontal al centro de giro."@es .

ex:Parametro_G95
    a ex:Parametro ;
    rdfs:label "G95 (avance por vuelta del cabezal)"@es ;
    ex:identificador "G95" ;
    ex:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)."@es .

ex:Parametro_G94
    a ex:Parametro ;
    rdfs:label "G94 (avance en función del tiempo)"@es ;
    ex:identificador "G94" ;
    ex:textoExtracto "SOLUCIÓN Activar el avance en función del tiempo (G94)."@es .

ex:Parametro_G97
    a ex:Parametro ;
    rdfs:label "G97 (velocidad de giro constante)"@es ;
    ex:identificador "G97" ;
    ex:textoExtracto "SOLUCIÓN Activar el modo de velocidad de giro constante (G97)."@es .

ex:Parametro_G63
    a ex:Parametro ;
    rdfs:label "G63 (roscado rígido)"@es ;
    ex:identificador "G63" ;
    ex:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)."@es .

ex:Parametro_G192
    a ex:Parametro ;
    rdfs:label "G192 (límite de velocidad)"@es ;
    ex:identificador "G192" ;
    ex:textoExtracto "SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación."@es .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS (eje frontal)"@es ;
    ex:identificador "FACEAXIS" ;
    ex:textoExtracto "Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)."@es .