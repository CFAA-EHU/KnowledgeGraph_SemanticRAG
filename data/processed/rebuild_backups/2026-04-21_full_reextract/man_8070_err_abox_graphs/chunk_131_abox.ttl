@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1249 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama con G96 activa"@es ;
    ex:textoExtracto "1249 'No se admite cambio de gama con G96 activa' [...] CAUSA El CNC ha intentado cambiar la gama del cabezal (G112) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para realizar el cambio de gama del cabezal."@es ;
    ex:identificador "1249" .

ex:Fallo_1251 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite modo manual con G96 activa"@es ;
    ex:textoExtracto "1251 'No se admite modo manual con G96 activa' [...] CAUSA El CNC ha intentado acceder al modo manual con la función G96 activa. SOLUCIÓN Desactivar la función G96 para acceder al modo manual."@es ;
    ex:identificador "1251" .

ex:Fallo_1252 a ex:DiagnosticoFallo ;
    rdfs:label "#FREE AX: no se permite eliminar el eje de giro frontal con G96 activa"@es ;
    ex:textoExtracto "1252 '#FREE AX: no se permite eliminar el eje de giro frontal con G96 activa' [...] CAUSA El CNC ha intentado eliminar el eje frontal de la configuración del canal (#FREE AX) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para eliminar el eje frontal de la configuración del canal."@es ;
    ex:identificador "1252" .

ex:Fallo_1254 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite G192 y M19 en el mismo bloque"@es ;
    ex:textoExtracto "1254 'No se admite G192 y M19 en el mismo bloque' [...] CAUSA El CNC no permite programar las funciones M19 (posicionamiento del cabezal) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es ;
    ex:identificador "1254" .

ex:Fallo_1255 a ex:DiagnosticoFallo ;
    rdfs:label "Porcentaje de aceleración negativo"@es ;
    ex:textoExtracto "1255 'Porcentaje de aceleración negativo' [...] CAUSA En la función G130, el porcentaje de aceleración programado es negativo. SOLUCIÓN El porcentaje de aceleración debe ser mayor o igual que cero."@es ;
    ex:identificador "1255" .

ex:Fallo_1256 a ex:DiagnosticoFallo ;
    rdfs:label "Porcentaje de aceleración fuera de rango"@es ;
    ex:textoExtracto "1256 'Porcentaje de aceleración fuera de rango' [...] CAUSA En la función G130, el porcentaje de aceleración programado es demasiado alto. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "1256" .

ex:Fallo_1257 a ex:DiagnosticoFallo ;
    rdfs:label "Doble programación del paso de husillo"@es ;
    ex:textoExtracto "1257 'Doble programación del paso de husillo' [...] CAUSA En la función G33, el paso de la rosca está programado más de una vez."@es ;
    ex:identificador "1257" .

ex:Funcion_G96 a ex:Parametro ;
    rdfs:label "Función G96 (velocidad constante de corte)"@es ;
    ex:textoExtracto "función G96 activa"@es ;
    ex:identificador "G96" .

ex:Funcion_G112 a ex:Parametro ;
    rdfs:label "Función G112 (cambio de gama del cabezal)"@es ;
    ex:textoExtracto "cambiar la gama del cabezal (G112)"@es ;
    ex:identificador "G112" .

ex:Funcion_G192 a ex:Parametro ;
    rdfs:label "Función G192 (limitación de velocidad de giro)"@es ;
    ex:textoExtracto "G192 (limitación de la velocidad de giro)"@es ;
    ex:identificador "G192" .

ex:Funcion_M19 a ex:Parametro ;
    rdfs:label "Función M19 (posicionamiento del cabezal)"@es ;
    ex:textoExtracto "M19 (posicionamiento del cabezal)"@es ;
    ex:identificador "M19" .

ex:Funcion_G130 a ex:Parametro ;
    rdfs:label "Función G130 (control de aceleración)"@es ;
    ex:textoExtracto "En la función G130, el porcentaje de aceleración programado"@es ;
    ex:identificador "G130" .

ex:Funcion_G33 a ex:Parametro ;
    rdfs:label "Función G33 (roscado)"@es ;
    ex:textoExtracto "En la función G33, el paso de la rosca"@es ;
    ex:identificador "G33" .

ex:Fallo_1249 ex:solucionaFallo ex:Funcion_G96 .
ex:Fallo_1251 ex:solucionaFallo ex:Funcion_G96 .
ex:Fallo_1252 ex:solucionaFallo ex:Funcion_G96 .
ex:Fallo_1254 ex:solucionaFallo ex:Funcion_G192 .
ex:Fallo_1254 ex:solucionaFallo ex:Funcion_M19 .