@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1264
    a               ex:Alarma ;
    rdfs:label      "Alarma 1264: Programación no permitida con CS/ACS activo"@es ;
    ex:identificador "1264" ;
    ex:textoExtracto "1264 'Programación no permitida con CS/ACS activo' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas. Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc. SOLUCIÓN Desactivar la transformación de coordenadas para poder ejecutar el resto de funciones."@es ;
    .

ex:AccionProhibida_1264_CoordenadasActivas
    a               ex:AccionProhibida ;
    rdfs:label      "Ejecución de funciones G74, G198, G199, #LINK o ciclos de palpado con transformación de coordenadas (CS/ACS) activa"@es ;
    ex:textoExtracto "El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas. Algunas funciones incompatibles son G74, G198, G199, #LINK, ciclos de palpado, etc."@es ;
    ex:activaAlarma  ex:Alarma_1264 ;
    .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "El CNC no permite ejecutar la función programada si está activa la transformación de coordenadas."@es ;
    .