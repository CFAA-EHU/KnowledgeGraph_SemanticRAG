@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloTransformacionCoordenadas_1270
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en transformación de coordenadas (pieza-máquina)"@es ;
    ex:textoExtracto "El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés."@es ;
    ex:identificador "1270" ;
    ex:solucionaFallo [
        a               ex:AccionProhibida ;
        rdfs:label      "Reconfiguración manual de transformación de ejes"@es ;
        ex:textoExtracto "Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación."@es
    ] .

ex:FalloModificacionEjesCinematica_1271
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Ejes de cinemática activa no modificables (1271)"@es ;
    ex:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados' [...] Durante la ejecución. El CNC ha intentado modificar la configuración de ejes de una cinemática mientras ésta"@es ;
    ex:identificador "1271" .