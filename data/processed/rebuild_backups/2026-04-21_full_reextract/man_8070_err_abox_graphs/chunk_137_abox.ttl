@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1272
    a               ex:Alarma ;
    rdfs:label      "Alarma 1272: Ejes de cinemática activa"@es ;
    ex:identificador "1272" ;
    ex:textoExtracto "Los ejes de la cinemática activa no pueden excluirse o ser modificados. [...] SOLUCIÓN Desactivar la cinemática para modificar la configuración de ejes del canal."@es .

ex:Alarma_1275
    a               ex:Alarma ;
    rdfs:label      "Alarma 1275: Posición calculada por transformada cinemática inversa fuera de rango"@es ;
    ex:identificador "1275" ;
    ex:textoExtracto "Posición calculada por la transformada cinemática inversa fuera de rango. [...] SOLUCIÓN Desactivar la transformación, cambiar la posición a la que se quiere acceder y volver a activar la transformación."@es .

ex:Alarma_1277
    a               ex:Alarma ;
    rdfs:label      "Alarma 1277: Traslado resultante excede rango de datos"@es ;
    ex:identificador "1277" ;
    ex:textoExtracto "El traslado resultante excede el rango de datos. [...] SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1278
    a               ex:Alarma ;
    rdfs:label      "Alarma 1278: Valor no válido en G131/G133"@es ;
    ex:identificador "1278" ;
    ex:textoExtracto "G131/G133: valor no válido. [...] SOLUCIÓN Programar un porcentaje de aceleración o jerk positivo y menor o igual a 100."@es .

ex:Alarma_1279
    a               ex:Alarma ;
    rdfs:label      "Alarma 1279: Falta comillas en programación"@es ;
    ex:identificador "1279" ;
    ex:textoExtracto "Se espera \". [...] SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1281
    a               ex:Alarma ;
    rdfs:label      "Alarma 1281: Parámetros y especificadores de formato no coinciden"@es ;
    ex:identificador "1281" ;
    ex:textoExtracto "No coincide el número de parámetros y de especificadores de formato. [...]"@es .

ex:Parametro_G131
    a               ex:Parametro ;
    rdfs:label      "Parámetro G131: Porcentaje de aceleración/jerk"@es ;
    ex:textoExtracto "En la función G131 [...] el porcentaje de aceleración o jerk programado no es válido."@es .

ex:Parametro_G133
    a               ex:Parametro ;
    rdfs:label      "Parámetro G133: Porcentaje de aceleración/jerk"@es ;
    ex:textoExtracto "En la función [...] G133, el porcentaje de aceleración o jerk programado no es válido."@es .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "El CNC ha intentado modificar la configuración de ejes [...]"@es ;
    ex:activaAlarma ex:Alarma_1272, ex:Alarma_1275, ex:Alarma_1277, ex:Alarma_1278, ex:Alarma_1279, ex:Alarma_1281 .