@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1310
    a ex:AvisoSeguridad ;
    rdfs:label "Línea de programa demasiado larga" ;
    ex:textoExtracto "1310 'Línea de programa demasiado larga' [...] El máximo número de caracteres permitido es 128." ;
    ex:identificador "1310" .

ex:AvisoSeguridad_1311
    a ex:AvisoSeguridad ;
    rdfs:label "Offset de medición no incluido en eje(s) programado" ;
    ex:textoExtracto "1311 'Offset de medición no incluido en eje(s) programado' [...] La función G102 no tiene sentido para un eje sin offset de medición." ;
    ex:identificador "1311" .

ex:AvisoSeguridad_1314
    a ex:AvisoSeguridad ;
    rdfs:label "#CS ON/#ACS ON: identificador no válido" ;
    ex:textoExtracto "1314 '#CS ON/#ACS ON: identificador no válido' [...] Programar un valor entre 1 y 5." ;
    ex:identificador "1314" .

ex:AvisoSeguridad_1315
    a ex:AvisoSeguridad ;
    rdfs:label "#CS ON/#ACS ON: sistema no definido" ;
    ex:textoExtracto "1315 '#CS ON/#ACS ON: sistema no definido' [...] Definir y almacenar algún sistema de coordenadas." ;
    ex:identificador "1315" .

ex:AvisoSeguridad_1316
    a ex:AvisoSeguridad ;
    rdfs:label "#CS/#ACS DEF: faltan parámetros" ;
    ex:textoExtracto "1316 '#CS/#ACS DEF: faltan parámetros' [...] Estas sentencias exigen programar el número del sistema de coordenadas, el modo de definición, las componentes del vector de traslación y los ángulos de rotación." ;
    ex:identificador "1316" .

ex:AvisoSeguridad_1318
    a ex:AvisoSeguridad ;
    rdfs:label "#CS ON/#ACS ON: no se admiten cambios con el sistema de coordenadas activo" ;
    ex:textoExtracto "1318 '#CS ON/#ACS ON: no se admiten cambios con el sistema de coordenadas activo' [...] El CNC no permite modificar los parámetros de un sistema de coordenadas activo." ;
    ex:identificador "1318" .

ex:Parametro_G102
    a ex:Parametro ;
    rdfs:label "Función G102" ;
    ex:textoExtracto "La función G102 intenta excluir el offset de medición de un eje que no tiene incluido ningún offset de medición." ;
    ex:identificador "G102" .

ex:Parametro_CS_ACS
    a ex:Parametro ;
    rdfs:label "Sistema de coordenadas (#CS/#ACS)" ;
    ex:textoExtracto "El número del sistema de coordenadas no es válido. [...] Definir y almacenar algún sistema de coordenadas." ;
    ex:identificador "#CS/#ACS" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha intentado cambiar los parámetros de un sistema de coordenadas activo. [...] El CNC no permite modificar los parámetros de un sistema de coordenadas activo." ;
    ex:tieneComponente ex:Parametro_CS_ACS ;
    ex:tieneComponente ex:Parametro_G102 .