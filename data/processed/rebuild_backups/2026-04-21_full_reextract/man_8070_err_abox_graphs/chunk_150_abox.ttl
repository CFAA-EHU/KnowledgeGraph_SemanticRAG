ex:Alarma_1334
    a ex:Alarma ;
    rdfs:label "Alarma 1334: G200 no admite movimiento en el mismo bloque"@es ;
    ex:identificador "1334" ;
    ex:textoExtracto "'G200: no admite movimiento en el mismo bloque'"@es ;
    ex:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: Hay programado un movimiento de ejes en el mismo bloque que la función G200. SOLUCIÓN: Revisar la programación."@es .

ex:Alarma_1336
    a ex:Alarma ;
    rdfs:label "Alarma 1336: Configuración errónea con dos ejes CAXIS"@es ;
    ex:identificador "1336" ;
    ex:textoExtracto "'Configuración errónea: dos ejes CAXIS'"@es ;
    ex:textoExtracto "DETECCIÓN: Durante la ejecución. CAUSA: Los dos ejes..."@es .

ex:AccionProhibida_CompensacionRadioActiva
    a ex:AccionProhibida ;
    rdfs:label "Realizar cambios en configuración de ejes con compensación de radio activa"@es ;
    ex:textoExtracto "Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo."@es ;
    ex:activaAlarma ex:Alarma_1334 .