@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1351
    a ex:Alarma ;
    rdfs:label "Alarma 1351: Tipo de variable no permitida"@es ;
    ex:identificador "1351" ;
    ex:textoExtracto "#VAR/#ENDVAR/#DELETE: tipo de variable no permitida. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir o borrar una variable que no es de usuario. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1352
    a ex:Alarma ;
    rdfs:label "Alarma 1352: Variable de usuario duplicada"@es ;
    ex:identificador "1352" ;
    ex:textoExtracto "#VAR/#ENDVAR: la variable definida ya existe. DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación."@es .