@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1352
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1352: Variable duplicada" ;
    ex:identificador "1352" ;
    ex:textoExtracto "#VAR/#ENDVAR: la variable definida ya existe. DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1353
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1353: Exceso de valores en inicialización de array" ;
    ex:identificador "1353" ;
    ex:textoExtracto "'Demasiados valores para inicializar el array' DETECCIÓN Durante la ejecución. CAUSA En la inicialización de una variable de array de usuario, el CNC inicializa más posiciones de las que tiene. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1354
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1354: Fallo en lectura de variable" ;
    ex:identificador "1354" ;
    ex:textoExtracto "'Error en la lectura de la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede leer la variable. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1355
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1355: Borrado de variable no permitido" ;
    ex:identificador "1355" ;
    ex:textoExtracto "'No se puede borrar la variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado borrar una variable del sistema. SOLUCIÓN El CNC sólo puede borrar variables de usuario (prefijos P y S)." .

ex:AvisoSeguridad_1356
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1356: Sintaxis incorrecta en $IF EXIST" ;
    ex:identificador "1356" ;
    ex:textoExtracto "'Se espera variable o parámetro' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la sentencia $IF EXIST. SOLUCIÓN La instrucción $IF EXIST sólo permite parámetros aritméticos o variables." .

ex:AvisoSeguridad_1357
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1357: Carácter inválido en #DELETE" ;
    ex:identificador "1357" ;
    ex:textoExtracto "'#DELETE: carácter no válido' DETECCIÓN Durante la ejecución. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque. La sentencia se debe programar sola en el bloque o junto a la etiqueta del bloque. Este sentencia sólo permite variables de usuario." .

ex:AvisoSeguridad_1358
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1358: Variable inexistente en #DELETE" ;
    ex:identificador "1358" ;
    ex:textoExtracto "'#DELETE: la variable a borrar no existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario no existe. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1359
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1359: Operación no permitida en variables del sistema" ;
    ex:identificador "1359" ;
    ex:textoExtracto "Los comandos #VAR/#ENDVAR/#DELETE no permiten este tipo de variable. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC. SOLUCIÓN No se pueden borrar las variables predefinidas del CNC." .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación CNC" ;
    ex:textoExtracto "Sistema de control numérico (CNC) que gestiona variables de usuario (prefijos P y S) y variables del sistema, con comandos como #VAR, #ENDVAR y #DELETE." ;
    ex:activaAlarma ex:AvisoSeguridad_1352 , ex:AvisoSeguridad_1353 , ex:AvisoSeguridad_1354 ,
                    ex:AvisoSeguridad_1355 , ex:AvisoSeguridad_1356 , ex:AvisoSeguridad_1357 ,
                    ex:AvisoSeguridad_1358 , ex:AvisoSeguridad_1359 .