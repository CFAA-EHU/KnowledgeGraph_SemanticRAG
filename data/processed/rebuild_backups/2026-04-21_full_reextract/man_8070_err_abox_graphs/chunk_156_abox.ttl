@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1360
    a ex:Alarma ;
    rdfs:label "Alarma 1360: Conflicto de funciones G con eje C activo" ;
    ex:identificador "1360" ;
    ex:textoExtracto "'No se admite G33/G63/G95/G96/G97 con eje C activo'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una función G33/G63/G95/G96/G97 con el eje C activo." .

ex:DiagnosticoFallo_1360
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 1360" ;
    ex:textoExtracto "SOLUCIÓN Desactivar el eje C para ejecutar la [función conflictiva]." ;
    ex:solucionaFallo ex:Alarma_1360 .

ex:Alarma_VariablesCNC
    a ex:Alarma ;
    rdfs:label "Alarma: Intento de modificación de variables predefinidas del CNC" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una variable del CNC o se ha intentado crear una nueva variable con uno de los prefijos predefinidos por el CNC." ;
    ex:textoExtracto "SOLUCIÓN No se pueden borrar las variables predefinidas del CNC. Estos comandos sólo son aplicables a variables con prefijo P y S." .

ex:DiagnosticoFallo_VariablesCNC
    a ex:DiagnosticoFallo ;
    rdfs:label "Restricción de variables CNC" ;
    ex:textoExtracto "No se pueden borrar las variables predefinidas del CNC. Estos comandos sólo son aplicables a variables con prefijo P y S." ;
    ex:solucionaFallo ex:Alarma_VariablesCNC .