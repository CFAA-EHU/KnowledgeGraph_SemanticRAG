@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MINLOCP
    a ex:Parametro ;
    rdfs:label "MINLOCP" ;
    ex:textoExtracto "MINLOCP - MAXLOCP | Parámetros aritméticos locales." ;
    ex:valor "Rango mínimo de parámetros aritméticos locales" .

ex:Parametro_MAXLOCP
    a ex:Parametro ;
    rdfs:label "MAXLOCP" ;
    ex:textoExtracto "MINLOCP - MAXLOCP | Parámetros aritméticos locales." ;
    ex:valor "Rango máximo de parámetros aritméticos locales" .

ex:Parametro_MINGLBP
    a ex:Parametro ;
    rdfs:label "MINGLBP" ;
    ex:textoExtracto "MINGLBP - MAXGLBP | Parámetros aritméticos globales." ;
    ex:valor "Rango mínimo de parámetros aritméticos globales" .

ex:Parametro_MAXGLBP
    a ex:Parametro ;
    rdfs:label "MAXGLBP" ;
    ex:textoExtracto "MINGLBP - MAXGLBP | Parámetros aritméticos globales." ;
    ex:valor "Rango máximo de parámetros aritméticos globales" .

ex:Parametro_MINCOMP
    a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:textoExtracto "MINCOMP - MAXCOMP | Parámetros aritméticos comunes." ;
    ex:valor "Rango mínimo de parámetros aritméticos comunes" .

ex:Parametro_MAXCOMP
    a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:textoExtracto "MINCOMP - MAXCOMP | Parámetros aritméticos comunes." ;
    ex:valor "Rango máximo de parámetros aritméticos comunes" .

ex:Parametro_ROPARMIN
    a ex:Parametro ;
    rdfs:label "ROPARMIN" ;
    ex:textoExtracto "Los parámetros globales protegidos contra escritura son aquellos definidos por los parámetros máquina ROPARMIN - ROPARMAX." ;
    ex:valor "Límite inferior de parámetros globales protegidos" .

ex:Parametro_ROPARMAX
    a ex:Parametro ;
    rdfs:label "ROPARMAX" ;
    ex:textoExtracto "Los parámetros globales protegidos contra escritura son aquellos definidos por los parámetros máquina ROPARMIN - ROPARMAX." ;
    ex:valor "Límite superior de parámetros globales protegidos" .

ex:Alarma_1378
    a ex:Alarma ;
    rdfs:label "Alarma 1378" ;
    ex:identificador "1378" ;
    ex:textoExtracto "'Lectura de parámetro con índice no válido' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido." .

ex:Tabla_ParametrosMaquina a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ex:textoExtracto "| Parámetros máquina. | Rango válido. | --- | --- | MINLOCP - MAXLOCP | Parámetros aritméticos locales. | MINGLBP - MAXGLBP | Parámetros aritméticos globales. | MINCOMP - MAXCOMP | Parámetros aritméticos comunes." ;
    ex:documentadoEn ex:Manual ;
    ex:tieneComponente ex:Parametro_MINLOCP, ex:Parametro_MAXLOCP, ex:Parametro_MINGLBP, ex:Parametro_MAXGLBP, ex:Parametro_MINCOMP, ex:Parametro_MAXCOMP .