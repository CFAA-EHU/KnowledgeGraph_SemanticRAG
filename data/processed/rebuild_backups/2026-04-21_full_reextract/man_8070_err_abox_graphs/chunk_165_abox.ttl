ex:Herramienta_Cabezal_1394
    a               ex:Herramienta ;
    rdfs:label      "Herramienta del cabezal"@es ;
    ex:textoExtracto "Si la herramienta que hay en el cabezal es distinta y en el programa no está compensando el radio de la herramienta, el CNC va a mecanizar una pieza distinta."@es .

ex:DiagnosticoFallo_1394
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1394: No existe la subrutina asociada a la función G"@es ;
    ex:identificador "1394" ;
    ex:textoExtracto "1394 'No existe la subrutina asociada a la función G'"@es ;
    ex:solucionaFallo ex:Herramienta_Cabezal_1394 .

ex:TareaMantenimiento_CambioHerramienta_1394
    a               ex:TareaMantenimiento ;
    rdfs:label      "Cambiar herramienta del cabezal para coincidir con la programada"@es ;
    ex:textoExtracto "SOLUCIÓN Cambiar la herramienta del cabezal para que coincida con la programada."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_1394 .