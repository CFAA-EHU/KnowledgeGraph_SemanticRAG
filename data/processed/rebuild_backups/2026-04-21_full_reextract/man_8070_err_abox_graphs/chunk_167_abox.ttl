PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1399
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "No puede activarse el eje como Hirth"@es ;
    ex:identificador       "1399" ;
    ex:textoExtracto       "1399 'No puede activarse el eje como Hirth' DETECCIÓN Durante la ejecución."@es .

ex:ComponenteMecanico_EjeHirth
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Eje Hirth"@es ;
    ex:textoExtracto       "El eje hirth es uno de los ejes del plano y está activa la compensación de radio y/o la detección de colisiones."@es .

ex:AvisoSeguridad_1399_Causa1
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Compensación de radio o detección de colisiones activa en eje Hirth"@es ;
    ex:textoExtracto       "El eje hirth es uno de los ejes del plano y está activa la compensación de radio y/o la detección de colisiones."@es ;
    ex:mitigaRiesgo        ex:ComponenteMecanico_EjeHirth .

ex:AvisoSeguridad_1399_Causa2
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Eje Hirth en transformación de coordenadas activa"@es ;
    ex:textoExtracto       "El eje hirth forma parte de la transformación de coordenadas activa."@es ;
    ex:mitigaRiesgo        ex:ComponenteMecanico_EjeHirth .

ex:AvisoSeguridad_1399_Causa3
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Eje Hirth en cinemática activa con sentencias #RTCP, #TLC o #TOOL ORI"@es ;
    ex:textoExtracto       "El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI."@es ;
    ex:mitigaRiesgo        ex:ComponenteMecanico_EjeHirth .

ex:TareaMantenimiento_RevisarProgramacion1399
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar programación para fallo 1399"@es ;
    ex:textoExtracto       "SOLUCIÓN Revisar la programación."@es ;
    ex:solucionaFallo      ex:Fallo_1399 .