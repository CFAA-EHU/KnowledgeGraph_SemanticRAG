@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AUTOGEAR
    a ex:Parametro ;
    rdfs:label "Parámetro AUTOGEAR (cambio de gama automático)"@es ;
    ex:textoExtracto "El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal."@es .

ex:DiagnosticoFallo_1406
    a ex:DiagnosticoFallo ;
    ex:identificador "1406" ;
    rdfs:label "'#CALL: no admite programación de parámetros'"@es ;
    ex:textoExtracto "La sentencia #CALL no admite programación de parámetros."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Programación de parámetros en sentencia #CALL"@es ;
        ex:textoExtracto "Revisar la programación."@es
    ] .

ex:DiagnosticoFallo_1407
    a ex:DiagnosticoFallo ;
    ex:identificador "1407" ;
    rdfs:label "'Error en la lectura de datos de la cajera'"@es ;
    ex:textoExtracto "Al ejecutar una cajera 2D ó 3D, el CNC no ha podido decodificar alguno de los datos. Esto puede suceder cuando se han editado manualmente los datos de la cajera y se ha sustituido un valor numérico por una variable, se ha eliminado el corchete final de las instrucciones #DATAP2D, #DATAP3D, etc."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Edición manual incorrecta de cajeras 2D/3D"@es ;
        ex:textoExtracto "Volver a editar la cajera con el editor de ciclos."@es
    ] .

ex:DiagnosticoFallo_1408
    a ex:DiagnosticoFallo ;
    ex:identificador "1408" ;
    rdfs:label "'G63/G74/M19/CAX: Programación no permitida si no hay encóder en el cabezal'"@es ;
    ex:textoExtracto "El CNC no puede ejecutar la función o sentencia programada si el cabezal no está controlado en posición."@es ;
    ex:solucionaFallo [
        a ex:ComponenteElectrico ;
        rdfs:label "Encoder del cabezal"@es ;
        ex:textoExtracto "Es necesario que haya encoder en el cabezal."@es
    ] .

ex:DiagnosticoFallo_1409
    a ex:DiagnosticoFallo ;
    ex:identificador "1409" ;
    rdfs:label "'Anidamiento de funciones T con subrutina no permitido'"@es ;
    ex:textoExtracto "El CNC ha intentado ejecutar un cambio de herramienta y en la subrutina asociada a la función T (parámetro TOOLSUB) hay programado otro cambio de herramienta."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Anidamiento de funciones T en subrutinas TOOLSUB"@es ;
        ex:textoExtracto "No es posible programar una función T dentro de la subrutina asociada al cambio de herramienta."@es
    ] .

ex:DiagnosticoFallo_1411
    a ex:DiagnosticoFallo ;
    ex:identificador "1411" ;
    rdfs:label "'#CD: número de bloques no válido'"@es ;
    ex:textoExtracto "El número de bloques programado en la sentencia es incorrecto."@es .