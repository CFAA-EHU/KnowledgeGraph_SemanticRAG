@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1432
    a ex:Alarma ;
    rdfs:label "Alarma 1432: Eje esclavo de acoplo/Gantry" ;
    ex:identificador "1432" ;
    ex:textoExtracto "'No se puede programar un eje esclavo de un acoplo o Gantry' DETECCIÓN Durante la ejecución. CAUSA En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." ;
    ex:textoExtracto "SOLUCIÓN Para poder operar con el eje en esas sentencias es necesario desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)." .

ex:Alarma_1433
    a ex:Alarma ;
    rdfs:label "Alarma 1433: Configuración de eje aparcado" ;
    ex:identificador "1433" ;
    ex:textoExtracto "No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución." .

ex:AccionProhibida_ModificarEjeAparcado
    a ex:AccionProhibida ;
    rdfs:label "Modificar configuración de eje aparcado" ;
    ex:textoExtracto "No se puede modificar la configuración de un eje aparcado." ;
    ex:activaAlarma ex:Alarma_1433 .

ex:AccionProhibida_ProgramarEjeEsclavoAcoplo
    a ex:AccionProhibida ;
    rdfs:label "Programar eje esclavo de acoplo activo o Gantry" ;
    ex:textoExtracto "No se puede programar un eje esclavo de un acoplo o Gantry" ;
    ex:activaAlarma ex:Alarma_1432 .

ex:Parametro_DesacoploGantry
    a ex:Parametro ;
    rdfs:label "Parámetro máquina para deshacer pareja Gantry" ;
    ex:textoExtracto "deshacer la pareja Gantry (por parámetro máquina)" .

ex:Parametro_ComandoUNLINK
    a ex:Parametro ;
    rdfs:label "Comando #UNLINK para desactivar acoplo" ;
    ex:textoExtracto "desactivar el acoplo activo (#UNLINK)" .