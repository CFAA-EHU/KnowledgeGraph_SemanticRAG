@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1433
    a ex:Alarma ;
    rdfs:label "Alarma 1433: Configuración de eje aparcado"@es ;
    ex:textoExtracto "1433 No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado. SOLUCIÓN Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)."@es ;
    ex:identificador "1433" .

ex:Alarma_1434
    a ex:Alarma ;
    rdfs:label "Alarma 1434: Inclusión de eje esclavo asociado"@es ;
    ex:textoExtracto "1434 'No se ha podido incluir en la configuración un eje esclavo asociado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque no existe una posición libre para el eje esclavo distinta de las tres principales. SOLUCIÓN Para poder incluir únicamente el eje maestro hay que desactivar primero el acoplo activo (#UNLINK) o deshacer la pareja Gantry. Para poder incluir los ejes maestro y esclavo hay que eliminar del canal algún otro eje o bien aumentar el número de ejes del canal."@es ;
    ex:identificador "1434" .

ex:Alarma_1435
    a ex:Alarma ;
    rdfs:label "Alarma 1435: Nombre de eje esclavo repetido"@es ;
    ex:textoExtracto "1435 'No se ha podido asignar nombre a un eje esclavo asociado por estar repetido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal. SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración."@es ;
    ex:identificador "1435" .

ex:Parametro_UNLINK
    a ex:Parametro ;
    rdfs:label "Parámetro #UNLINK (desactivar acoplo activo)"@es ;
    ex:textoExtracto "es necesario desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)."@es ;
    ex:identificador "#UNLINK" .

ex:Parametro_UNPARK
    a ex:Parametro ;
    rdfs:label "Parámetro #UNPARK (desaparcar eje)"@es ;
    ex:textoExtracto "Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)."@es ;
    ex:identificador "#UNPARK" .

ex:Parametro_CALL
    a ex:Parametro ;
    rdfs:label "Parámetro #CALL (inclusión en configuración)"@es ;
    ex:textoExtracto "El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado."@es ;
    ex:identificador "#CALL" .

ex:Parametro_SET
    a ex:Parametro ;
    rdfs:label "Parámetro #SET (inclusión en configuración)"@es ;
    ex:textoExtracto "El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado."@es ;
    ex:identificador "#SET" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (control numérico)"@es ;
    ex:textoExtracto "El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry."@es ;
    ex:activaAlarma ex:Alarma_1433, ex:Alarma_1434, ex:Alarma_1435 ;
    ex:monitoreaParametro ex:Parametro_UNLINK, ex:Parametro_UNPARK, ex:Parametro_CALL, ex:Parametro_SET .