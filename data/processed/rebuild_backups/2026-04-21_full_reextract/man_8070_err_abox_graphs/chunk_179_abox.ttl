@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorCNC_1436
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error 1436: 'No se ha programado bloque de parada en búsqueda de bloque'"@es ;
    ex:textoExtracto      "1436 'No se ha programado bloque de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque."@es ;
    ex:identificador      "1436" .

ex:ErrorCNC_EjeEsclavoDuplicado
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Error: Nombre de eje esclavo duplicado en configuración de canal"@es ;
    ex:textoExtracto      "El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal. SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración."@es .