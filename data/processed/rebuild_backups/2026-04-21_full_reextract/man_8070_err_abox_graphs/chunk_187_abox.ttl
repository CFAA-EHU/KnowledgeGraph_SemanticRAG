@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1457
    a ex:Alarma ;
    rdfs:label "Alarma #POLY: Valor de parámetro no válido" ;
    ex:identificador "1457" ;
    ex:textoExtracto "#POLY: Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los parámetros de interpolación del polinomio no son correctos. • El radio de curvatura es menor o igual que cero. SOLUCIÓN Los parámetros de interpolación del polinomio deben ser positivos, el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP) y el radio de curvatura debe ser mayor que cero." .

ex:Alarma_1458
    a ex:Alarma ;
    rdfs:label "Alarma #POLY: Demasiados ejes programados" ;
    ex:identificador "1458" ;
    ex:textoExtracto "#POLY: Demasiados ejes programados' DETECCIÓN Durante la ejecución. CAUSA Hay más de tres ejes en el polinomio. SOLUCIÓN En la interpolación polinómica sólo pueden intervenir tres ejes." .

ex:Alarma_1459
    a ex:Alarma ;
    rdfs:label "Alarma #POLY: Punto inicial no válido" ;
    ex:identificador "1459" ;
    ex:textoExtracto "#POLY: Punto inicial no válido' DETECCIÓN Durante" .

ex:Parametro_SP
    a ex:Parametro ;
    rdfs:label "Parámetro inicial de interpolación (SP)" ;
    ex:textoExtracto "el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ex:Parametro_EP
    a ex:Parametro ;
    rdfs:label "Parámetro final de interpolación (EP)" ;
    ex:textoExtracto "el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ex:Parametro_RadioCurvatura
    a ex:Parametro ;
    rdfs:label "Radio de curvatura" ;
    ex:textoExtracto "el radio de curvatura es menor o igual que cero" ,
                    "el radio de curvatura debe ser mayor que cero" .