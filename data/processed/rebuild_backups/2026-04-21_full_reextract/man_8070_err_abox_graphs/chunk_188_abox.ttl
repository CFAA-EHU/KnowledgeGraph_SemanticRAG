@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1459
    a ex:Alarma ;
    rdfs:label "'#POLY: Punto inicial no válido'" ;
    ex:identificador "1459" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El punto inicial del polinomio no coincide con la posición actual. SOLUCIÓN Modificar el término independiente del polinomio para cada eje, de manera que el punto inicial del polinomio coincida con la posición final del bloque anterior." .

ex:Alarma_1461
    a ex:Alarma ;
    rdfs:label "'G9: Programación incorrecta del punto intermedio del arco'" ;
    ex:identificador "1461" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta programar una o las dos coordenadas del punto intermedio del arco. SOLUCIÓN La función G9 exige la programación de las dos coordenadas del punto intermedio del arco." .

ex:Alarma_1462
    a ex:Alarma ;
    rdfs:label "'G8: Cálculo de la trayectoria tangente imposible'" ;
    ex:identificador "1462" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se puede realizar un arco tangente a la trayectoria anterior con el radio y punto final programados. SOLUCIÓN Revisar la programación." .

ex:Alarma_1463
    a ex:Alarma ;
    rdfs:label "'G9: Trayectoria circular mal programada'" ;
    ex:identificador "1463" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Es imposible realizar un arco que pase por los tres puntos disponibles. SOLUCIÓN Definir dos puntos en el bloque junto a G9, que junto con el punto final del movimiento anterior definan un arco. Hay que tener en cuenta que los tres puntos han de ser diferentes y no deben estar alineados." .

ex:Alarma_1464
    a ex:Alarma ;
    rdfs:label "'Eje rotativo programado fuera del rango del módulo'" ;
    ex:identificador "1464" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La cota absoluta (G90) programada para el eje rotativo tipo MODULO no es válida. SOLUCIÓN La cota programada para el eje debe encontrarse entre los límites fijados por sus parámetros máquina MODUPLIM y MODLOWLIM." .

ex:Alarma_1465
    a ex:Alarma ;
    rdfs:label "'Las funciones RTCP y TLC son incompatibles'" ;
    ex:identificador "1465" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las funciones estando la otra activa." .

ex:DiagnosticoFallo_InterpolacionPolinomica
    a ex:DiagnosticoFallo ;
    rdfs:label "Exceso de ejes en interpolación polinómica" ;
    ex:textoExtracto "CAUSA Hay más de tres ejes en el polinomio. SOLUCIÓN En la interpolación polinómica sólo pueden intervenir tres ejes." ;
    ex:solucionaFallo ex:Alarma_1459 .

ex:DiagnosticoFallo_ProgramacionG9
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta de coordenadas en programación G9" ;
    ex:textoExtracto "CAUSA Falta programar una o las dos coordenadas del punto intermedio del arco. SOLUCIÓN La función G9 exige la programación de las dos coordenadas del punto intermedio del arco." ;
    ex:solucionaFallo ex:Alarma_1461 .

ex:DiagnosticoFallo_TrayectoriaTangente
    a ex:DiagnosticoFallo ;
    rdfs:label "Trayectoria tangente no calculable" ;
    ex:textoExtracto "CAUSA No se puede realizar un arco tangente a la trayectoria anterior con el radio y punto final programados. SOLUCIÓN Revisar la programación." ;
    ex:solucionaFallo ex:Alarma_1462 .

ex:DiagnosticoFallo_TrayectoriaCircular
    a ex:DiagnosticoFallo ;
    rdfs:label "Trayectoria circular mal definida" ;
    ex:textoExtracto "CAUSA Es imposible realizar un arco que pase por los tres puntos disponibles. SOLUCIÓN Definir dos puntos en el bloque junto a G9, que junto con el punto final del movimiento anterior definan un arco. Hay que tener en cuenta que los tres puntos han de ser diferentes y no deben estar alineados." ;
    ex:solucionaFallo ex:Alarma_1463 .

ex:DiagnosticoFallo_RangoEjeRotativo
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje rotativo fuera de rango" ;
    ex:textoExtracto "CAUSA La cota absoluta (G90) programada para el eje rotativo tipo MODULO no es válida. SOLUCIÓN La cota programada para el eje debe encontrarse entre los límites fijados por sus parámetros máquina MODUPLIM y MODLOWLIM." ;
    ex:solucionaFallo ex:Alarma_1464 .

ex:DiagnosticoFallo_IncompatibilidadRTCP_TLC
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre funciones RTCP y TLC" ;
    ex:textoExtracto "CAUSA El CNC ha intentado activar una de las funciones estando la otra activa." ;
    ex:solucionaFallo ex:Alarma_1465 .