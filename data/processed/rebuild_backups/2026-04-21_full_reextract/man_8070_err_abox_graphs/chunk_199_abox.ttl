@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1500
    a ex:Alarma ;
    rdfs:label "Error de ejecución en canal CNC"@es ;
    ex:identificador "1500" ;
    ex:textoExtracto "Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático."@es .

ex:Alarma_1501
    a ex:Alarma ;
    rdfs:label "Etiquetas repetidas en #RPT"@es ;
    ex:identificador "1501" ;
    ex:textoExtracto "Durante la ejecución. En la sentencia #RPT la etiqueta inicial y final es la misma."@es .

ex:AvisoSeguridad_1500_Solucion
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Esperar a que finalice el programa en el otro canal o hacerle un reset."@es ;
    ex:mitigaRiesgo ex:Alarma_1500 .

ex:AvisoSeguridad_1501_Solucion
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Definir etiquetas inicial y final diferentes."@es ;
    ex:mitigaRiesgo ex:Alarma_1501 .

ex:Sistema_CNC
    a ex:Sistema ;
    ex:textoExtracto "CNC"@es ;
    ex:activaAlarma ex:Alarma_1500, ex:Alarma_1501 .