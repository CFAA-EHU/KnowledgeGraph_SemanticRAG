@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1523
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta programar T en el bloque" ;
    ex:identificador "1523" ;
    ex:textoExtracto "1523 Falta programar T en el bloque. DETECCIÓN Durante la ejecución." .

ex:Fallo_1525
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de comandos POS/MZ sin herramienta" ;
    ex:identificador "1525" ;
    ex:textoExtracto "CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta." .

ex:Fallo_NR_Negativo
    a ex:DiagnosticoFallo ;
    rdfs:label "Número negativo de repeticiones de bloque (NR)" ;
    ex:textoExtracto "CAUSA Se ha programado un número negativo de repeticiones de bloque (NR). SOLUCIÓN Revisar la programación." .