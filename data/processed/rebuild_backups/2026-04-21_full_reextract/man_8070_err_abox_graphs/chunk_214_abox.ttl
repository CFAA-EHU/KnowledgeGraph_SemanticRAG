@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1545 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de gama de cabezal con G63 o #CAX activos"@es ;
    ex:identificador "1545" ;
    ex:textoExtracto "El CNC no puede cambiar la gama del cabezal si está activo el roscado G63 o el cabezal está trabajando como eje C. SOLUCIÓN Para cambiar la gama del cabezal, desactivar el roscado y el eje C."@es .

ex:Fallo_1546 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite G63 sin gama previa en el cabezal"@es ;
    ex:identificador "1546" ;
    ex:textoExtracto "Esta situación sólo es posible si tras el arranque del sistema o un reset, el PLC no indica ninguna gama con GEAR1 a GEAR4 para el cabezal. SOLUCIÓN Antes de iniciar un roscado G63 el cabezal debe tener una gama activada."@es .

ex:Fallo_1547 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite #CAX con G63 activa"@es ;
    ex:identificador "1547" ;
    ex:textoExtracto "No se puede activar un cabezal como eje C si éste mismo está siendo usado por la función G63. SOLUCIÓN Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C."@es .

ex:Fallo_1548 a ex:DiagnosticoFallo ;
    rdfs:label "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas"@es ;
    ex:identificador "1548" ;
    ex:textoExtracto "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas. DETECCIÓN Durante la ejecución."@es .

ex:Parametro_AUTOGEAR a ex:Parametro ;
    rdfs:label "Cambio de gama automático (AUTOGEAR)"@es ;
    ex:textoExtracto "Si el cabezal tiene cambio de gama automático (parámetro AUTOGEAR), el CNC genera la gama al programar una velocidad; en caso contrario, hay que programar la gama (M41-M44) junto a la velocidad."@es .

ex:Funcion_G63 a ex:ModoOperacion ;
    rdfs:label "Roscado rígido (G63)"@es ;
    ex:textoExtracto "Si se hace en el siguiente, estas funciones M desactivan el roscado modal G63 y si se desea seguir roscando hay que volver a programar la G63 en el siguiente movimiento."@es .

ex:Funcion_M41 a ex:ModoOperacion ;
    ex:identificador "M41" ;
    ex:textoExtracto "Programar la gama (M41-M44) junto a la velocidad."@es .

ex:Funcion_M42 a ex:ModoOperacion ;
    ex:identificador "M42" ;
    ex:textoExtracto "Programar la gama (M41-M44) junto a la velocidad."@es .

ex:Funcion_M43 a ex:ModoOperacion ;
    ex:identificador "M43" ;
    ex:textoExtracto "Programar la gama (M41-M44) junto a la velocidad."@es .

ex:Funcion_M44 a ex:ModoOperacion ;
    ex:identificador "M44" ;
    ex:textoExtracto "Programar la gama (M41-M44) junto a la velocidad."@es .

ex:Funcion_CAX a ex:ModoOperacion ;
    rdfs:label "Eje C (#CAX)"@es ;
    ex:textoExtracto "No se puede activar un cabezal como eje C si éste mismo está siendo usado por la función G63."@es .