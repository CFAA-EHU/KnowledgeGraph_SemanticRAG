@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1548
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1548: No se admite cambiar el cabezal master con G33/G63/G95/G96 activas"@es ;
    ex:textoExtracto "1548 'No se admite cambiar el cabezal master con G33/G63/G95/G96 activas'"@es ;
    ex:identificador "1548" .

ex:AvisoSeguridad_1549
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1549: Nombre de cajera nulo o incorrecto"@es ;
    ex:textoExtracto "1549 'Nombre de cajera nulo o incorrecto'"@es ;
    ex:identificador "1549" .

ex:Parametro_G63
    a ex:Parametro ;
    rdfs:label "Función G63 (modo de operación)"@es ;
    ex:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal. El canal no puede eliminar este cabezal mientras las funciones estén activas."@es ;
    ex:identificador "G63" .

ex:Parametro_G96
    a ex:Parametro ;
    rdfs:label "Función G96 (modo de operación)"@es ;
    ex:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal. El canal no puede eliminar este cabezal mientras las funciones estén activas."@es ;
    ex:identificador "G96" .

ex:ModoOperacion_CabezalMaster
    a ex:ModoOperacion ;
    rdfs:label "Cabezal master del canal"@es ;
    ex:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal."@es .

ex:Parametro_G63
    ex:controla ex:ModoOperacion_CabezalMaster .

ex:Parametro_G96
    ex:controla ex:ModoOperacion_CabezalMaster .

ex:AvisoSeguridad_1548
    ex:mitigaRiesgo ex:Parametro_G63 ,
        ex:Parametro_G96 .