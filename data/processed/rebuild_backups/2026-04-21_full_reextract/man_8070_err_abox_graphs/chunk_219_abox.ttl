@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1560 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #FOLLOW"@es ;
    ex:identificador "1560" ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. 1560 'Programar #FOLLOW ON/OFF[...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #FOLLOW es incorrecta. SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON/OFF y a continuación los parámetros de llamada entre corchetes."@es .

ex:Fallo_1561 a ex:DiagnosticoFallo ;
    rdfs:label "Eje maestro no válido"@es ;
    ex:identificador "1561" ;
    ex:textoExtracto "1561 'Eje maestro no válido' DETECCIÓN Durante la ejecución. CAUSA En las sentencias #CAM o #FOLLOW, el eje maestro es incorrecto. SOLUCIÓN El eje debe pertenecer al canal."@es .

ex:Fallo_1562 a ex:DiagnosticoFallo ;
    rdfs:label "Eje esclavo no válido"@es ;
    ex:identificador "1562" ;
    ex:textoExtracto "1562 'Eje esclavo no válido' DETECCIÓN Durante la ejecución."@es .