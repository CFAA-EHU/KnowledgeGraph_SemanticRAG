@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_ProgramacionMultialmacen
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en programación de sistema multialmacén" ;
    ex:textoExtracto "En un sistema con varios almacenes, hay programado en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta. SOLUCIÓN En un sistema multialmacén, hay que programar en el mismo bloque la herramienta, la posición y el almacén." ;
    ex:solucionaFallo ex:AccionProhibida_ProgramacionIncompletaMultialmacen .

ex:AccionProhibida_ProgramacionIncompletaMultialmacen
    a               ex:AccionProhibida ;
    rdfs:label      "Programar herramienta y posición sin especificar almacén en sistema multialmacén" ;
    ex:textoExtracto "hay programado en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta" .

ex:Parametro_1587
    a               ex:Parametro ;
    rdfs:label      "Parámetro 1587" ;
    ex:identificador "1587" ;
    ex:textoExtracto "'Parámetro no modificable desde la puesta a punto'" .

ex:Diagnostico_ParametroNoModificable
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Parámetro máquina sin permiso de escritura" ;
    ex:textoExtracto "El parámetro máquina no tiene permiso de escritura desde el entorno de la puesta a punto" ;
    ex:monitoreaParametro ex:Parametro_1587 .