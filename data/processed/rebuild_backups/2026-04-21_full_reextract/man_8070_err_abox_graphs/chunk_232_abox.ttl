@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1601
    a ex:Alarma ;
    rdfs:label "No se admite liberar un cabezal sincronizado"@es ;
    ex:identificador "1601" ;
    ex:textoExtracto "1601 'No se admite liberar un cabezal sincronizado' [...] CAUSA Las sentencias #SET SP y #FREE SP no pueden eliminar un cabezal si éste está sincronizado. SOLUCIÓN Cancelar la sincronización para eliminar el cabezal de la configuración."@es .

ex:Alarma_1602
    a ex:Alarma ;
    rdfs:label "Para aparcar un cabezal debe de estar parado (M5)"@es ;
    ex:identificador "1602" ;
    ex:textoExtracto "1602 'Para aparcar un cabezal debe de estar parado (M5)' [...] CAUSA El CNC ha intentado aparcar un cabezal que no está parado. SOLUCIÓN Detener el cabezal antes de aparcarlo."@es .

ex:Alarma_1603
    a ex:Alarma ;
    rdfs:label "FOLLOW OFF: Programar eje esclavo"@es ;
    ex:identificador "1603" ;
    ex:textoExtracto "1603 'FOLLOW OFF: Programar eje esclavo' [...] CAUSA El eje programado no es esclavo en ninguna sincronización. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1604
    a ex:Alarma ;
    rdfs:label "G31 requiere G02/G03 activa"@es ;
    ex:identificador "1604" ;
    ex:textoExtracto "1604 'G31 requiere G02/G03 activa' [...] CAUSA La función G31 sólo se puede programar si existe una interpolación circular activa. SOLUCIÓN Programar G02/G03 en el bloque de G31."@es .

ex:Alarma_1605
    a ex:Alarma ;
    rdfs:label "G31 requiere programación de ángulo polar y centro de interpolación"@es ;
    ex:identificador "1605" ;
    ex:textoExtracto "1605 'G31 requiere programación de ángulo polar y centro de interpolación' [...] CAUSA En la función G31 falta programar el ángulo polar o alguna coordenadas del centro. SOLUCIÓN Revisar la programación."@es .

ex:Alarma_1606
    a ex:Alarma ;
    rdfs:label "#ANGAX: Los ejes angular y ortogonal deben pertenecer al mismo canal"@es ;
    ex:identificador "1606" ;
    ex:textoExtracto "1606 '#ANGAX: Los ejes angular y ortogonal deben pertenecer al mismo canal' [...] CAUSA El CNC ha intentando activar una transformación angular con dos ejes que no pertenecen al mismo canal."@es .

ex:AvisoSeguridad_SincronizacionCabezales
    a ex:AvisoSeguridad ;
    rdfs:label "Conflicto de sincronización de cabezales con eje C o función G63"@es ;
    ex:textoExtracto "CAUSA El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa. [...] SOLUCIÓN Desactivar el eje C o la función G63 para sincronizar los cabezales. Para trabajar con el eje C o la función G63, cancelar la sincronización de cabezales."@es .

ex:Parametro_G63
    a ex:Parametro ;
    rdfs:label "Función G63"@es ;
    ex:identificador "G63" ;
    ex:textoExtracto "El CNC ha intentado activar el cabezal como eje C o la función G63 y el cabezal está sincronizado."@es .

ex:Parametro_G31
    a ex:Parametro ;
    rdfs:label "Función G31"@es ;
    ex:identificador "G31" ;
    ex:textoExtracto "La función G31 sólo se puede programar si existe una interpolación circular activa."@es .

ex:Parametro_G02
    a ex:Parametro ;
    rdfs:label "Interpolación circular (G02)"@es ;
    ex:identificador "G02" ;
    ex:textoExtracto "Programar G02/G03 en el bloque de G31."@es .

ex:Parametro_G03
    a ex:Parametro ;
    rdfs:label "Interpolación circular (G03)"@es ;
    ex:identificador "G03" ;
    ex:textoExtracto "Programar G02/G03 en el bloque de G31."@es .

ex:Parametro_ANGAX
    a ex:Parametro ;
    rdfs:label "Transformación angular (#ANGAX)"@es ;
    ex:identificador "#ANGAX" ;
    ex:textoExtracto "El CNC ha intentando activar una transformación angular con dos ejes que no pertenecen al mismo canal."@es .

ex:Componente_EjeC
    a ex:ComponenteMecanico ;
    rdfs:label "Eje C"@es ;
    ex:identificador "Eje C" ;
    ex:textoExtracto "El CNC ha intentado sincronizar un cabezal y éste está trabajando como eje C o tiene la función G63 activa."@es .