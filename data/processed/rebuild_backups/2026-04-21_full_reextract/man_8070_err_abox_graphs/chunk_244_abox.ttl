@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1637
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1637: Sentido de giro del cabezal incompatible con la herramienta"@es ;
    ex:identificador "1637" ;
    ex:textoExtracto "1637 'Sentido de giro del cabezal incompatible con la herramienta' DETECCIÓN Durante la ejecución. CAUSA El sentido de giro predeterminado de la herramienta es incompatible con el sentido de giro actual del cabezal. SOLUCIÓN Cambiar sentido de giro del cabezal o corregir el sentido de giro definido para la herramienta."@es .

ex:AvisoSeguridad_1638
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1638: Los ejes de la transformación angular (#ANGAX) deben ser lineales"@es ;
    ex:identificador "1638" ;
    ex:textoExtracto "1638 'Los ejes de la transformación angular, #ANGAX, deben ser lineales' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación angular con un eje rotativo. SOLUCIÓN Los ejes de la transformación angular deben ser lineales."@es .

ex:AvisoSeguridad_1639
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1639: El cabezal programado no pertenece al canal"@es ;
    ex:identificador "1639" ;
    ex:textoExtracto "1639 'El cabezal programado no pertenece al canal' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado utilizar un cabezal de otro canal. SOLUCIÓN Un canal sólo puede controlar sus cabezales. Utilizar un cabezal que pertenezca al canal o incluir en la configuración del canal el cabezal que da error."@es .

ex:AvisoSeguridad_1640
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1640: No se admite programar cabezales aparcados"@es ;
    ex:identificador "1640" ;
    ex:textoExtracto "1640 'No se admite programar cabezales aparcados' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado utilizar un cabezal aparcado. SOLUCIÓN Utilizar un cabezal que no esté aparcado o desaparcar el cabezal."@es .

ex:AvisoSeguridad_1641
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1641: Falta radio de desarrollo en programación #CYL"@es ;
    ex:identificador "1641" ;
    ex:textoExtracto "1641 '#CYL: Se espera la programación del radio de desarrollo del cilindro' DETECCIÓN Durante la ejecución. CAUSA Falta el valor del radio de desarrollo en la sentencia #CYL. SOLUCIÓN Revisar la programación. Para un radio variable, definir valor cero para que el CNC calcule el radio en función de donde se encuentre la herramienta."@es .

ex:AvisoSeguridad_1642
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1642: No se admite programar cabezales esclavos TANDEM"@es ;
    ex:identificador "1642" ;
    ex:textoExtracto "1642 'No se admite programar cabezales esclavos TANDEM' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado mover o hacer referencia al cabezal esclavo de una pareja tándem. SOLUCIÓN El cabezal esclavo de una pareja tándem es controlado por el CNC, no se puede desplazar individualmente."@es .

ex:Parametro_ANGAX
    a ex:Parametro ;
    rdfs:label "Parámetro #ANGAX (transformación angular)"@es ;
    ex:identificador "#ANGAX" ;
    ex:textoExtracto "Los ejes de la transformación angular, #ANGAX, deben ser lineales"@es ;
    ex:monitoreaParametro ex:AvisoSeguridad_1638 .

ex:Parametro_CYL_Radio
    a ex:Parametro ;
    rdfs:label "Parámetro radio de desarrollo (#CYL)"@es ;
    ex:identificador "#CYL" ;
    ex:textoExtracto "Falta el valor del radio de desarrollo en la sentencia #CYL"@es ;
    ex:monitoreaParametro ex:AvisoSeguridad_1641 .