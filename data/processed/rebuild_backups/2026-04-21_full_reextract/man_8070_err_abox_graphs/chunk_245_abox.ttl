@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alerta_1643
    a ex:AvisoSeguridad ;
    rdfs:label "Alerta 1643: 'No se permite aparcar cabezales TANDEM'"@es ;
    ex:textoExtracto "1643 'No se permite aparcar cabezales TANDEM'"@es ;
    ex:identificador "1643" .

ex:CabezalTandemEsclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo de pareja tándem"@es ;
    ex:textoExtracto "El cabezal esclavo de una pareja tándem es controlado por el CNC, no se puede desplazar individualmente."@es .

ex:CabezalTandemMaestro
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal maestro de pareja tándem"@es ;
    ex:textoExtracto "Para desplazar un cabezal esclavo, hay que desplazar el cabezal maestro al que se encuentra asociado."@es ;
    ex:controla ex:CabezalTandemEsclavo .

ex:AccionProhibida_DesplazarCabezalEsclavo
    a ex:AccionProhibida ;
    rdfs:label "Desplazamiento individual de cabezal esclavo tándem"@es ;
    ex:textoExtracto "El cabezal esclavo de una pareja tándem [...] no se puede desplazar individualmente."@es ;
    ex:activaAlarma ex:Alerta_1643 .

ex:AccionProhibida_AparcarCabezalTandem
    a ex:AccionProhibida ;
    rdfs:label "Aparcamiento de cabezales TANDEM"@es ;
    ex:textoExtracto "No se permite aparcar cabezales TANDEM"@es ;
    ex:activaAlarma ex:Alerta_1643 .