ex:Alarma_1660
    a ex:Alarma ;
    rdfs:label "Alarma 1660: Índice de array incorrecto"@es ;
    ex:identificador "1660" ;
    ex:textoExtracto "'Indice de array incorrecto' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR. Algún índice de array programado en la variable está fuera de rango."@es .

ex:Alarma_1661
    a ex:Alarma ;
    rdfs:label "Alarma 1661: Falta programar \".\" tras [númeroCanal]"@es ;
    ex:identificador "1661" ;
    ex:textoExtracto "'Falta programar \".\" tras [númeroCanal]' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR."@es .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "Comandos CNCRD o CNCWR"@es ;
    ex:activaAlarma ex:Alarma_1660 , ex:Alarma_1661 .