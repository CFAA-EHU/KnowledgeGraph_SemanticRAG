@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1661
    a ex:Alarma ;
    rdfs:label "Falta programar '.' tras [númeroCanal]"@es ;
    ex:identificador "1661" ;
    ex:textoExtracto "1661 'Falta programar \".\" tras [númeroCanal]' [...] CAUSA Comandos CNCRD o CNCWR. El número de canal debe ir entre corchetes y seguido del carácter \".\"."@es .

ex:Alarma_1662
    a ex:Alarma ;
    rdfs:label "Tipo de variable desconocido"@es ;
    ex:identificador "1662" ;
    ex:textoExtracto "1662 'Tipo de variable desconocido' [...] CAUSA Comandos CNCRD o CNCWR. No existe el tipo de variable programado."@es .

ex:Alarma_1663
    a ex:Alarma ;
    rdfs:label "#DELETE: falta indicar variable(s) a borrar"@es ;
    ex:identificador "1663" ;
    ex:textoExtracto "1663 '#DELETE: falta indicar variable(s) a borrar' [...] CAUSA En la sentencia #DELETE falta indicar las variables a borrar."@es .

ex:Alarma_1664
    a ex:Alarma ;
    rdfs:label "Herramienta en uso en otro canal"@es ;
    ex:identificador "1664" ;
    ex:textoExtracto "1664 La herramienta pedida está siendo utilizada en otro canal. [...] CAUSA La herramienta programada está activa en otro canal."@es .

ex:Alarma_1665
    a ex:Alarma ;
    rdfs:label "G174: solo admite un eje o cabezal"@es ;
    ex:identificador "1665" ;
    ex:textoExtracto "1665 'La función G174 sólo admite un eje o cabezal' [...] CAUSA En la función G174 hay programado más de un eje o cabezal."@es .

ex:Alarma_1666
    a ex:Alarma ;
    rdfs:label "G174: ejes acoplados (GANTRY/TANDEM) no admitidos"@es ;
    ex:identificador "1666" ;
    ex:textoExtracto "1666 'G174: no se admiten ejes acoplados, GANTRY o TANDEM' [...] CAUSA El CNC ha intentado inicializar cota máquina (G174) de un eje que forma parte de una pareja de ejes gantry, tándem o de un acoplo activo (#LINK)."@es .

ex:Alarma_1667
    a ex:Alarma ;
    rdfs:label "G174: ejes de cinemática/transformadas activas no admitidos"@es ;
    ex:identificador "1667" ;
    ex:textoExtracto "1667 'G174: no se admiten ejes de la cinemática o transformadas activas' [...] DETECCIÓN Durante la ejecución."@es .

ex:Parametro_G174
    a ex:Parametro ;
    rdfs:label "Función G174 (inicialización de cota máquina)"@es ;
    ex:textoExtracto "La función G174 sólo admite un eje o cabezal [...] inicializar cota máquina (G174) de un eje que forma parte de una pareja de ejes gantry, tándem o de un acoplo activo (#LINK)."@es .

ex:ComponenteElectrico_CNC
    a ex:ComponenteElectrico ;
    rdfs:label "Sistema CNC (control numérico)"@es ;
    ex:textoExtracto "Comandos CNCRD o CNCWR [...] El CNC ha intentado inicializar cota máquina (G174) [...] desactivar el acoplo."@es .

ex:Alarma_1661 ex:activaAlarma ex:ComponenteElectrico_CNC .
ex:Alarma_1662 ex:activaAlarma ex:ComponenteElectrico_CNC .
ex:Alarma_1663 ex:activaAlarma ex:ComponenteElectrico_CNC .
ex:Alarma_1664 ex:activaAlarma ex:ComponenteElectrico_CNC .
ex:Alarma_1665 ex:activaAlarma ex:ComponenteElectrico_CNC .
ex:Alarma_1666 ex:activaAlarma ex:ComponenteElectrico_CNC .
