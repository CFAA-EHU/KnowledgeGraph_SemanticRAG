@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1668
    a ex:Alarma ;
    rdfs:label "Grupo multieje fuera de rango"@es ;
    ex:identificador "1668" ;
    ex:textoExtracto "1668 'Grupo multieje fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]. El índice (grupo) no corresponde a ningún grupo multieje definido en los parámetros máquina. SOLUCIÓN Revisar la programación. Programar adecuadamente el número del grupo multieje."@es .

ex:Alarma_1669
    a ex:Alarma ;
    rdfs:label "'Programar #ROTATEMZ1-4 Pn/+n/-n'"@es ;
    ex:identificador "1669" ;
    ex:textoExtracto "1669 'Programar #ROTATEMZ1-4 Pn/+n/-n' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Programar la posición a seleccionar en la torreta o el número de posiciones a girar."@es .

ex:Alarma_1670
    a ex:Alarma ;
    rdfs:label "'El almacén indicado debe ser de tipo TORRETA'"@es ;
    ex:identificador "1670" ;
    ex:textoExtracto "1670 'El almacén indicado debe ser de tipo TORRETA' DETECCIÓN Durante la ejecución. CAUSA La sentencia #ROTATEMZ sólo es válida para un almacén de tipo torreta. SOLUCIÓN Revisar la programación. Comprobar que el almacén es de tipo torreta."@es .

ex:Alarma_1671
    a ex:Alarma ;
    rdfs:label "Demasiadas subrutinas locales en el fichero"@es ;
    ex:identificador "1671" ;
    ex:textoExtracto "1671 Demasiadas subrutinas locales en el fichero. DETECCIÓN Durante la ejecución. CAUSA El programa tiene más subrutinas locales que las permitidas por el CNC. SOLUCIÓN Reducir el número de subrutinas locales; agrupar varias subrutinas en una o utilizar subrutinas globales. El CNC permite 130 subrutinas locales por programa."@es .

ex:Alarma_1672
    a ex:Alarma ;
    rdfs:label "'No se admite G74-G174 para cabezales sincronizados'"@es ;
    ex:identificador "1672" ;
    ex:textoExtracto "1672 'No se admite G74-G174 para cabezales sincronizados' DETECCIÓN Durante la ejecución. CAUSA Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos. SOLUCIÓN El CNC referencia los cabezales antes de sincronizarlos. Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es .

ex:Componente_GrupoMultieje
    a ex:Componente ;
    rdfs:label "Grupo multieje"@es ;
    ex:textoExtracto "Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]. El índice (grupo) no corresponde a ningún grupo multieje definido en los parámetros máquina."@es .

ex:Componente_Torreta
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén tipo torreta"@es ;
    ex:textoExtracto "La sentencia #ROTATEMZ sólo es válida para un almacén de tipo torreta."@es .

ex:Componente_CabezalesSincronizados
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezales sincronizados"@es ;
    ex:textoExtracto "Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos."@es .

ex:AvisoSeguridad_1668
    a ex:AvisoSeguridad ;
    rdfs:label "Revisión de programación para grupo multieje"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Programar adecuadamente el número del grupo multieje."@es ;
    ex:mitigaRiesgo ex:Alarma_1668 .

ex:AvisoSeguridad_1669
    a ex:AvisoSeguridad ;
    rdfs:label "Revisión de sintaxis para #ROTATEMZ"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Programar la posición a seleccionar en la torreta o el número de posiciones a girar."@es ;
    ex:mitigaRiesgo ex:Alarma_1669 .

ex:AvisoSeguridad_1670
    a ex:AvisoSeguridad ;
    rdfs:label "Verificación de tipo de almacén para #ROTATEMZ"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación. Comprobar que el almacén es de tipo torreta."@es ;
    ex:mitigaRiesgo ex:Alarma_1670 .

ex:AvisoSeguridad_1671
    a ex:AvisoSeguridad ;
    rdfs:label "Reducción de subrutinas locales"@es ;
    ex:textoExtracto "SOLUCIÓN Reducir el número de subrutinas locales; agrupar varias subrutinas en una o utilizar subrutinas globales. El CNC permite 130 subrutinas locales por programa."@es ;
    ex:mitigaRiesgo ex:Alarma_1671 .

ex:AvisoSeguridad_1672
    a ex:AvisoSeguridad ;
    rdfs:label "Desactivación de sincronización para búsqueda de referencia"@es ;
    ex:textoExtracto "SOLUCIÓN El CNC referencia los cabezales antes de sincronizarlos. Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es ;
    ex:mitigaRiesgo ex:Alarma_1672 .