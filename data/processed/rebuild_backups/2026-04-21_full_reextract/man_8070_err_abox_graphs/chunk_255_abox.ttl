@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:FalloSincronizacionCabezales
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo al sincronizar cabezales (búsqueda de cero/forzar cota bloqueada)"@es ;
    ex:textoExtracto "Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos. [...] Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es ;
    ex:identificador "1673" .

ex:FalloAccesoVariableCNC
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Variable no accesible por programa o MDI"@es ;
    ex:textoExtracto "La variable programada existe, pero no tiene permiso de acceso desde el programa o MDI, o es una variable de texto. [...] Consultar en los manuales los permisos de acceso de las variables."@es ;
    ex:identificador "1674" .

ex:SistemaCNC
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC"@es ;
    ex:textoExtracto "el CNC no permite programar una búsqueda de cero ni forzar cota [...] el CNC referencia los cabezales antes de sincronizarlos"@es .

ex:TareaDesactivarSincronizacion
    a               ex:TareaMantenimiento ;
    rdfs:label      "Desactivar sincronización de cabezales"@es ;
    ex:textoExtracto "Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es ;
    ex:solucionaFallo ex:FalloSincronizacionCabezales .

ex:TareaConsultarPermisosVariables
    a               ex:TareaMantenimiento ;
    rdfs:label      "Consultar permisos de acceso de variables CNC"@es ;
    ex:textoExtracto "Consultar en los manuales los permisos de acceso de las variables."@es ;
    ex:solucionaFallo ex:FalloAccesoVariableCNC .