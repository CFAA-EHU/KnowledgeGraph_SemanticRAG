@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_1674
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1674: Programar #SELECT PROBE" ;
    ex:identificador "1674" ;
    ex:textoExtracto "'Programar #SELECT PROBE [ Nº palpador, POS/NEG]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_1675
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1675: Variable no accesible para su canal" ;
    ex:identificador "1675" ;
    ex:textoExtracto "1675 'Variable no accesible para su canal.' DETECCIÓN Durante la ejecución. CAUSA La variable no es accesible desde el canal. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables." .

ex:AvisoSeguridad_1676
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1676: Plano inclinado activo recuperado" ;
    ex:identificador "1676" ;
    ex:textoExtracto "'Se ha recuperado el plano inclinado activo' DETECCIÓN Durante la ejecución. CAUSA Tras el encendido, el CNC ha recuperado el plano inclinado que se encontraba activo al apagarlo. SOLUCIÓN El plano inclinado se puede desactivar con la sentencia #CS OFF." .

ex:AvisoSeguridad_1677
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1677: #RTCP/TLC desactivado" ;
    ex:identificador "1677" ;
    ex:textoExtracto "'Se ha desactivado #RTCP/TLC' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer una búsqueda de referencia con la función #RTCP ó #TLC activa. SOLUCIÓN Para ejecutar un búsqueda de referencia hay que desactivar las funciones #RTCP/TLC." .

ex:AvisoSeguridad_1678
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1678: Variable para captación externa analógica" ;
    ex:identificador "1678" ;
    ex:textoExtracto "'Variable existente sólo para captación externa analógica' DETECCIÓN Durante la ejecución. CAUSA La variable programada sólo existe para ejes con captación externa analógica y el eje indicado no cumple esa condición. SOLUCIÓN Revisar la programación. Consultar en los manuales las variables accesibles según el tipo de eje." .

ex:AvisoSeguridad_1679
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1679: #CAM SELECT no admitido" ;
    ex:identificador "1679" ;
    ex:textoExtracto "'No se admite #CAM SELECT con la leva en ejecución o en proceso de carga' DETECCIÓN Durante la ejecución. CAUSA El CNC ha solicitado la carga de una leva que está en ejecución o en un proceso previo de carga. SOLUCIÓN Esperar a que finalice la ejecución o la carga de la leva." .

ex:AvisoSeguridad_1680
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1680: Número de pieza no válido" ;
    ex:identificador "1680" ;
    ex:textoExtracto "'Número de pieza no válido' DETECCIÓN Durante la ejecución." .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ex:textoExtracto "Consultar en los manuales los permisos de acceso de las variables." ;
    ex:activaAlarma ex:AvisoSeguridad_1674, ex:AvisoSeguridad_1675, ex:AvisoSeguridad_1676, ex:AvisoSeguridad_1677, ex:AvisoSeguridad_1678, ex:AvisoSeguridad_1679, ex:AvisoSeguridad_1680 .