@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_1686
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de longitud de path" ;
    ex:identificador "1686" ;
    ex:textoExtracto "El path del fichero es demasiado largo. [...] La longitud máxima permitida para el path es de 120 caracteres." .

ex:Fallo_1687
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación en sentencia #REPOS" ;
    ex:identificador "1687" ;
    ex:textoExtracto "'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' [...] La sentencia #REPOS está mal programada." .

ex:Parametro_INT
    a ex:Parametro ;
    rdfs:label "Parámetro INT en #REPOS" ;
    ex:textoExtracto "La sentencia #REPOS puede incluir un parámetro opcional INT o INI" .

ex:Parametro_INI
    a ex:Parametro ;
    rdfs:label "Parámetro INI en #REPOS" ;
    ex:textoExtracto "La sentencia #REPOS puede incluir un parámetro opcional INT o INI" .

ex:AccionProhibida_SaltoEnBucle
    a ex:AccionProhibida ;
    rdfs:label "Salto al interior de un bucle" ;
    ex:textoExtracto "No se permite realizar saltos al interior de un bucle." .