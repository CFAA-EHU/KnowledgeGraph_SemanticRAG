@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1688 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1688: Sentencias #REPOS de distinto tipo"@es ;
    ex:identificador "1688" ;
    ex:textoExtracto "No se admiten sentencias #REPOS de distinto tipo. [...] Todas las sentencias #REPOS deben ser del mismo tipo."@es .

ex:Fallo_1689 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1689: Bloques tras #REPOS"@es ;
    ex:identificador "1689" ;
    ex:textoExtracto "No se admiten bloques tras #REPOS. [...] Las sentencia #REPOS deben ser los últimos bloques de la subrutina de interrupción, excepto el bloque de fin de subrutina."@es .

ex:Fallo_1690 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1690: Eje múltiple doblemente programado"@es ;
    ex:identificador "1690" ;
    ex:textoExtracto "No se permite programar en el mismo bloque más de un eje del mismo grupo multieje. [...] Programar únicamente el eje activo del grupo múltiple."@es .

ex:Fallo_1691 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1691: Subrutina de G anidada"@es ;
    ex:identificador "1691" ;
    ex:textoExtracto "En una subrutina asociada a una función G no se puede programar la función G que llama a esa misma subrutina. [...] En el caso de G74, sí se permite programar la función dentro de la subrutina siempre que vaya seguida de los ejes a referenciar."@es .

ex:Fallo_1692 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1692: Programación incorrecta de #VOLCOMP"@es ;
    ex:identificador "1692" ;
    ex:textoExtracto "La sentencia #VOLCOMP ON/OFF [n] y/o alguno de sus parámetros están mal programados."@es .

ex:Fallo_1693 a ex:DiagnosticoFallo ;
    rdfs:label "Error 1693: Cinemática no compatible con #RTCP"@es ;
    ex:identificador "1693" ;
    ex:textoExtracto "No se permite programar #RTCP con la actual cinemática. Programar #FACE o #CYL."@es .

ex:Parametro_REPOS_INT a ex:Parametro ;
    rdfs:label "Parámetro INT de #REPOS"@es ;
    ex:textoExtracto "La sentencia #REPOS puede incluir un parámetro opcional INT o INI, seguido de una secuencia de ejes y/o cabezales del canal sin un orden determinado."@es ;
    ex:valor "INT" .

ex:Parametro_REPOS_INI a ex:Parametro ;
    rdfs:label "Parámetro INI de #REPOS"@es ;
    ex:textoExtracto "La sentencia #REPOS puede incluir un parámetro opcional INT o INI, seguido de una secuencia de ejes y/o cabezales del canal sin un orden determinado."@es ;
    ex:valor "INI" .

ex:Parametro_VOLCOMP_ON a ex:Parametro ;
    rdfs:label "Parámetro ON de #VOLCOMP"@es ;
    ex:textoExtracto "Programar #VOLCOMP ON/OFF [n]."@es ;
    ex:valor "ON" .

ex:Parametro_VOLCOMP_OFF a ex:Parametro ;
    rdfs:label "Parámetro OFF de #VOLCOMP"@es ;
    ex:textoExtracto "Programar #VOLCOMP ON/OFF [n]."@es ;
    ex:valor "OFF" .

ex:Sentencia_REPOS a ex:InterfazUsuario ;
    rdfs:label "Sentencia #REPOS"@es ;
    ex:textoExtracto "La sentencia #REPOS puede incluir un parámetro opcional INT o INI, seguido de una secuencia de ejes y/o cabezales del canal sin un orden determinado."@es ;
    ex:tieneFrecuencia ex:Frecuencia_EjecucionSubrutina .

ex:Frecuencia_EjecucionSubrutina a ex:Frecuencia ;
    rdfs:label "Frecuencia de ejecución en subrutina de interrupción"@es ;
    ex:textoExtracto "Detección durante la ejecución [en subrutinas de interrupción]."@es .