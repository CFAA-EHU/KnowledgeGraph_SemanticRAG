ex:Alarma_1703
    a ex:Alarma ;
    rdfs:label "PUNTEADO: P = 0"@es ;
    ex:identificador "1703" ;
    ex:textoExtracto "1703 'PUNTEADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_P_Profundidad .

