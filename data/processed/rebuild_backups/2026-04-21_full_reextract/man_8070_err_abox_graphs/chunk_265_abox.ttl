@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_Profundidad_Taladrado2
    a ex:Parametro ;
    rdfs:label "Parámetro P (Profundidad)"@es ;
    ex:identificador "P" ;
    ex:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ex:valor "0" .

ex:Parametro_Avance_Taladrado2
    a ex:Parametro ;
    rdfs:label "Parámetro F (Avance)"@es ;
    ex:identificador "F" ;
    ex:textoExtracto "El parámetro F tiene valor 0. No hay avance programado."@es ;
    ex:valor "0" .

ex:Parametro_Velocidad_Taladrado2
    a ex:Parametro ;
    rdfs:label "Parámetro S (Velocidad)"@es ;
    ex:identificador "S" ;
    ex:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada."@es ;
    ex:valor "0" .

ex:Parametro_Herramienta_Taladrado2
    a ex:Parametro ;
    rdfs:label "Parámetro T (Herramienta)"@es ;
    ex:identificador "T" ;
    ex:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada."@es ;
    ex:valor "0" .

ex:AvisoSeguridad_1710_Taladrado2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1710: 'TALADRADO 2: F = 0'"@es ;
    ex:identificador "1710" ;
    ex:textoExtracto "1710 'TALADRADO 2: F = 0' [...] CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Avance_Taladrado2 .

ex:AvisoSeguridad_1711_Taladrado2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1711: 'TALADRADO 2: S = 0'"@es ;
    ex:identificador "1711" ;
    ex:textoExtracto "1711 'TALADRADO 2: S = 0' [...] CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Velocidad_Taladrado2 .

ex:AvisoSeguridad_1712_Taladrado2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1712: 'TALADRADO 2: T = 0'"@es ;
    ex:identificador "1712" ;
    ex:textoExtracto "1712 'TALADRADO 2: T = 0' [...] CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Herramienta_Taladrado2 .

ex:AvisoSeguridad_1713_Taladrado2
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1713: 'TALADRADO 2: P = 0'"@es ;
    ex:identificador "1713" ;
    ex:textoExtracto "1713 'TALADRADO 2: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ex:monitoreaParametro ex:Parametro_Profundidad_Taladrado2 .

ex:ModoOperacion_Taladrado2
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de Taladrado 2"@es ;
    ex:textoExtracto "Durante la ejecución del ciclo [de taladrado 2]."@es ;
    ex:monitoreaParametro ex:Parametro_Profundidad_Taladrado2 ;
    ex:monitoreaParametro ex:Parametro_Avance_Taladrado2 ;
    ex:monitoreaParametro ex:Parametro_Velocidad_Taladrado2 ;
    ex:monitoreaParametro ex:Parametro_Herramienta_Taladrado2 .