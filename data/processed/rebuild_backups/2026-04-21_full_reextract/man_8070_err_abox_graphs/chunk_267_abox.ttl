ex:DiagnosticoFallo_1720
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1720: ESCARIADO: S = 0"@es ;
    ex:identificador "1720" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:solucionaFallo ex:Parametro_S_1720 .

