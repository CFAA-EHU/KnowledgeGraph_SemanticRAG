@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_1745
    a ex:AvisoSeguridad ;
    rdfs:label "CAJERA PREVACIADA: P = 0" ;
    ex:textoExtracto "1745 'CAJERA PREVACIADA: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada." ;
    ex:mitigaRiesgo [
        a ex:Parametro ;
        rdfs:label "Parámetro P (profundidad)" ;
        ex:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." ;
        ex:valor "0" ;
        ex:monitoreaParametro ex:Sistema_CicloOperacion
    ] .

ex:AvisoSeguridad_1746
    a ex:AvisoSeguridad ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA" ;
    ex:textoExtracto "1746 'CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA' [...] CAUSA En la operación de" ;
    ex:mitigaRiesgo [
        a ex:Herramienta ;
        rdfs:label "Herramienta de desbaste/acabado" ;
        ex:textoExtracto "Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."
    ] .

ex:Sistema_CicloOperacion
    a ex:Sistema ;
    rdfs:label "Sistema de ejecución de ciclo" ;
    ex:textoExtracto "Durante la ejecución del ciclo. [...] Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." ;
    ex:controla [
        a ex:Parametro ;
        rdfs:label "Parámetro P (profundidad)" ;
        ex:valor "0" ;
        ex:textoExtracto "El parámetro P tiene valor 0."
    ] ;
    ex:requiereMantenimiento [
        a ex:TareaMantenimiento ;
        rdfs:label "Programación de herramienta" ;
        ex:textoExtracto "Programar una herramienta para la operación de desbaste o acabado."
    ] .

ex:TareaMantenimiento_AsignarParametroP
    a ex:TareaMantenimiento ;
    rdfs:label "Asignar valor > 0 al parámetro P" ;
    ex:textoExtracto "SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:AvisoSeguridad_1745 .