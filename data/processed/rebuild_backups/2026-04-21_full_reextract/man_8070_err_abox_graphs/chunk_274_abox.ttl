@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de fallo (cajera prevaciada)
ex:Fallo_1746
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA"@es ;
    ex:identificador "1746" ;
    ex:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN: Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ex:Fallo_1747
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera"@es ;
    ex:identificador "1747" ;
    ex:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN: Elegir una herramienta de menor diámetro."@es .

ex:Fallo_1748
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta ACABADO menor que delta"@es ;
    ex:identificador "1748" ;
    ex:textoExtracto "Durante la ejecución del ciclo. CAUSA: El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN: Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ex:Fallo_1749
    a ex:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: R < r"@es ;
    ex:identificador "1749" ;
    ex:textoExtracto "Durante la ejecución del ciclo. CAUSA: El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r). SOLUCIÓN: El radio de la cajera (radio exterior) debe ser mayor que el radio de prevaciado (radio interior)."@es .

### Diagnósticos de fallo (moyú rectangular)
ex:Fallo_1750
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: F = 0"@es ;
    ex:identificador "1750" ;
    ex:textoExtracto "Durante la ejecución del ciclo. CAUSA: Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN: Asignar al parámetro un valor mayor que 0."@es .

ex:Fallo_1751
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: S = 0"@es ;
    ex:identificador "1751" ;
    ex:textoExtracto "Durante la ejecución del ciclo."@es .

### Parámetros críticos (implícitos en diagnósticos)
ex:Parametro_DeltaPasoFresado
    a ex:Parametro ;
    rdfs:label "Paso de fresado (Δ)"@es ;
    ex:identificador "Δ" ;
    ex:textoExtracto "parámetro Δ [...] el paso de fresado"@es ;
    ex:monitoreaParametro ex:Fallo_1746 .

ex:Parametro_DiametroHerramienta
    a ex:Parametro ;
    rdfs:label "Diámetro de herramienta"@es ;
    ex:textoExtracto "diámetro de la herramienta"@es ;
    ex:monitoreaParametro ex:Fallo_1746, ex:Fallo_1747, ex:Fallo_1748 .

ex:Parametro_DimensionCajera_L
    a ex:Parametro ;
    rdfs:label "Dimensión de cajera (L)"@es ;
    ex:identificador "L" ;
    ex:textoExtracto "dimensiones de la cajera (parámetros L ó H)"@es ;
    ex:monitoreaParametro ex:Fallo_1747 .

ex:Parametro_DimensionCajera_H
    a ex:Parametro ;
    rdfs:label "Dimensión de cajera (H)"@es ;
    ex:identificador "H" ;
    ex:textoExtracto "dimensiones de la cajera (parámetros L ó H)"@es ;
    ex:monitoreaParametro ex:Fallo_1747 .

ex:Parametro_DemasiasParedes
    a ex:Parametro ;
    rdfs:label "Demasías en paredes laterales (δ)"@es ;
    ex:identificador "δ" ;
    ex:textoExtracto "demasías en las paredes laterales (parámetro δ)"@es ;
    ex:monitoreaParametro ex:Fallo_1748 .

ex:Parametro_RadioCajera_R
    a ex:Parametro ;
    rdfs:label "Radio de cajera (R)"@es ;
    ex:identificador "R" ;
    ex:textoExtracto "radio de la cajera (parámetro R)"@es ;
    ex:monitoreaParametro ex:Fallo_1749 .

ex:Parametro_RadioPrevaciado_r
    a ex:Parametro ;
    rdfs:label "Radio de prevaciado (r)"@es ;
    ex:identificador "r" ;
    ex:textoExtracto "radio de prevaciado (parámetro r)"@es ;
    ex:monitoreaParametro ex:Fallo_1749 .

ex:Parametro_Avance_F
    a ex:Parametro ;
    rdfs:label "Avance (F)"@es ;
    ex:identificador "F" ;
    ex:textoExtracto "parámetro F [...] avance de desbaste, acabado o profundización en Z"@es ;
    ex:monitoreaParametro ex:Fallo_1750 .

ex:Parametro_Velocidad_S
    a ex:Parametro ;
    rdfs:label "Velocidad (S)"@es ;
    ex:identificador "S" ;
    ex:textoExtracto "parámetro S"@es ;
    ex:monitoreaParametro ex:Fallo_1751 .