@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_F_1751
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance en Z)"@es ;
    ex:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ex:valor "0" .

ex:Parametro_S_1751
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ex:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ex:valor "0" ;
    ex:identificador "1751" .

ex:Parametro_T_1752
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ex:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es ;
    ex:valor "0" ;
    ex:identificador "1752" .

ex:AvisoSeguridad_1751
    a ex:AvisoSeguridad ;
    rdfs:label "MOYU RECTANGULAR: S = 0"@es ;
    ex:textoExtracto "1751 'MOYU RECTANGULAR: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_S_1751 .

ex:AvisoSeguridad_1752
    a ex:AvisoSeguridad ;
    rdfs:label "MOYU RECTANGULAR: T = 0"@es ;
    ex:textoExtracto "1752 'MOYU RECTANGULAR: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es ;
    ex:monitoreaParametro ex:Parametro_T_1752 .

ex:DiagnosticoFallo_ParametroF
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro F no configurado"@es ;
    ex:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:solucionaFallo ex:Parametro_F_1751 .

ex:DiagnosticoFallo_ParametroS
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro S no configurado"@es ;
    ex:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:solucionaFallo ex:Parametro_S_1751 .

ex:DiagnosticoFallo_ParametroT
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro T no configurado"@es ;
    ex:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es ;
    ex:solucionaFallo ex:Parametro_T_1752 .