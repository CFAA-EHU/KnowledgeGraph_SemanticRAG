@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_S_1758
    a                  ex:Parametro ;
    rdfs:label         "Parámetro S (velocidad)"@es ;
    ex:textoExtracto   "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ex:valor           "0" ;
    ex:monitoreaParametro  ex:Alarma_1758 .

ex:Alarma_1758
    a                  ex:Alarma ;
    rdfs:label         "MOYU CIRCULAR: T = 0"@es ;
    ex:identificador    "1758" ;
    ex:textoExtracto   "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es .

ex:Parametro_T_1758
    a                  ex:Parametro ;
    rdfs:label         "Parámetro T (herramienta)"@es ;
    ex:textoExtracto   "El parámetro T de las operaciones de desbaste y acabado tiene valor 0."@es ;
    ex:valor           "0" ;
    ex:monitoreaParametro  ex:Alarma_1758 .

ex:DiagnosticoFallo_1758
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "Fallo 1758: Herramienta no programada"@es ;
    ex:textoExtracto   "SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es ;
    ex:solucionaFallo  ex:Alarma_1758 .

ex:Alarma_1759
    a                  ex:Alarma ;
    rdfs:label         "MOYU CIRCULAR: P = 0"@es ;
    ex:identificador    "1759" ;
    ex:textoExtracto   "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P"@es .

ex:Parametro_P_1759
    a                  ex:Parametro ;
    rdfs:label         "Parámetro P"@es ;
    ex:textoExtracto   "El parámetro P"@es ;
    ex:valor           "0" ;
    ex:monitoreaParametro  ex:Alarma_1759 .