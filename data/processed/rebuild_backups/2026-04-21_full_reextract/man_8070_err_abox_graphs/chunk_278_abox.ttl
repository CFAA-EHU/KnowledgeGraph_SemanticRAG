@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1759
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: P = 0"@es ;
    ex:identificador "1759" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Profundidad_P .

ex:Error_1760
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: R = 0"@es ;
    ex:identificador "1760" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro R tiene valor 0. No hay radio programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Radio_R .

ex:Error_1761
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta menor que DELTA"@es ;
    ex:identificador "1761" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es ;
    ex:monitoreaParametro ex:Parametro_PasoFresado_Delta .

ex:Error_1762
    a ex:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ex:identificador "1762" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es ;
    ex:monitoreaParametro ex:Parametro_DemasiasParedes_delta .

ex:Error_1763
    a ex:DiagnosticoFallo ;
    rdfs:label "PLANEADO: F = 0"@es ;
    ex:identificador "1763" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Avance_F .

ex:Error_1764
    a ex:DiagnosticoFallo ;
    rdfs:label "PLANEADO: S = 0"@es ;
    ex:identificador "1764" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Velocidad_S .

ex:Error_1765
    a ex:DiagnosticoFallo ;
    rdfs:label "PLANEADO: T = 0"@es ;
    ex:identificador "1765" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo."@es .

### Parámetros monitoreados
ex:Parametro_Profundidad_P
    a ex:Parametro ;
    rdfs:label "Parámetro P (Profundidad)"@es ;
    ex:identificador "P" ;
    ex:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada"@es .

ex:Parametro_Radio_R
    a ex:Parametro ;
    rdfs:label "Parámetro R (Radio)"@es ;
    ex:identificador "R" ;
    ex:textoExtracto "parámetro R tiene valor 0. No hay radio programado"@es .

ex:Parametro_PasoFresado_Delta
    a ex:Parametro ;
    rdfs:label "Parámetro Δ (Paso de fresado)"@es ;
    ex:identificador "Δ" ;
    ex:textoExtracto "el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ)"@es .

ex:Parametro_DemasiasParedes_delta
    a ex:Parametro ;
    rdfs:label "Parámetro δ (Demasías en paredes laterales)"@es ;
    ex:identificador "δ" ;
    ex:textoExtracto "el diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ)"@es .

ex:Parametro_Avance_F
    a ex:Parametro ;
    rdfs:label "Parámetro F (Avance)"@es ;
    ex:identificador "F" ;
    ex:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z"@es .

ex:Parametro_Velocidad_S
    a ex:Parametro ;
    rdfs:label "Parámetro S (Velocidad)"@es ;
    ex:identificador "S" ;
    ex:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado"@es .

ex:Parametro_Herramienta_T
    a ex:Parametro ;
    rdfs:label "Parámetro T (Herramienta)"@es ;
    ex:identificador "T" ;
    ex:textoExtracto "parámetro T tiene valor 0"@es .