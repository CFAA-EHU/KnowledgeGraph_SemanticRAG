@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1765
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1765: 'PLANEADO: T = 0'" ;
    ex:textoExtracto "CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." ;
    ex:identificador "1765" ;
    ex:solucionaFallo ex:Parametro_T .

ex:DiagnosticoFallo_1766
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1766: 'PLANEADO: P = 0'" ;
    ex:textoExtracto "CAUSA El parámetro P tiene valor 0." ;
    ex:identificador "1766" ;
    ex:solucionaFallo ex:Parametro_P .

ex:DiagnosticoFallo_Parametro_S
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro S = 0" ;
    ex:textoExtracto "CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_S .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)" ;
    ex:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado" ;
    ex:valor "0" .

ex:Parametro_T
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)" ;
    ex:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." ;
    ex:valor "0" .

ex:Parametro_P
    a ex:Parametro ;
    rdfs:label "Parámetro P" ;
    ex:textoExtracto "El parámetro P tiene valor 0." ;
    ex:valor "0" .