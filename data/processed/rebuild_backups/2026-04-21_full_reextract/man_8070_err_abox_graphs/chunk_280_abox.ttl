@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Profundidad_Planeado_P
    a ex:Parametro ;
    rdfs:label "Parámetro P (Profundidad de planeado)"@es ;
    ex:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ex:valor "0" .

ex:Parametro_Longitud_Planeado_L
    a ex:Parametro ;
    rdfs:label "Parámetro L (Longitud de planeado)"@es ;
    ex:textoExtracto "La longitud (parámetro L) [...] son 0."@es ;
    ex:valor "0" .

ex:Parametro_Anchura_Planeado_H
    a ex:Parametro ;
    rdfs:label "Parámetro H (Anchura de planeado)"@es ;
    ex:textoExtracto "La [...] anchura del planeado (parámetro H) son 0."@es ;
    ex:valor "0" .

ex:Parametro_Avance_PerfilPuntos_F
    a ex:Parametro ;
    rdfs:label "Parámetro F (Avance en perfil de puntos)"@es ;
    ex:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ex:valor "0" .

ex:Parametro_Velocidad_PerfilPuntos_S
    a ex:Parametro ;
    rdfs:label "Parámetro S (Velocidad en perfil de puntos)"@es ;
    ex:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ex:valor "0" .

ex:Parametro_Herramienta_PerfilPuntos_T
    a ex:Parametro ;
    rdfs:label "Parámetro T (Herramienta en perfil de puntos)"@es ;
    ex:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es ;
    ex:valor "0" .

ex:AvisoSeguridad_1766
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1766: PLANEADO: P = 0"@es ;
    ex:textoExtracto "1766 'PLANEADO: P = 0' [...] SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Profundidad_Planeado_P .

ex:AvisoSeguridad_1767
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1767: PLANEADO: L = 0 y H = 0"@es ;
    ex:textoExtracto "1767 'PLANEADO: L = 0 y H = 0' [...] SOLUCIÓN Definir ambas dimensiones del planeado con un valor distinto de cero."@es ;
    ex:monitoreaParametro ex:Parametro_Longitud_Planeado_L , ex:Parametro_Anchura_Planeado_H .

ex:AvisoSeguridad_1768
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1768: PERFIL DE PUNTOS: F = 0"@es ;
    ex:textoExtracto "1768 'PERFIL DE PUNTOS: F = 0' [...] SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Avance_PerfilPuntos_F .

ex:AvisoSeguridad_1769
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1769: PERFIL DE PUNTOS: S = 0"@es ;
    ex:textoExtracto "1769 'PERFIL DE PUNTOS: S = 0' [...] SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Velocidad_PerfilPuntos_S .

ex:AvisoSeguridad_1770
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1770: PERFIL DE PUNTOS: T = 0"@es ;
    ex:textoExtracto "1770 'PERFIL DE PUNTOS: T = 0' [...] SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es ;
    ex:monitoreaParametro ex:Parametro_Herramienta_PerfilPuntos_T .

ex:AvisoSeguridad_1771
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 1771: PERFIL DE PUNTOS: P = 0"@es ;
    ex:textoExtracto "1771 'PERFIL DE PUNTOS: P = 0' [...] SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es ;
    ex:monitoreaParametro ex:Parametro_Profundidad_Planeado_P .

ex:Herramienta_DesbasteAcabado
    a ex:Herramienta ;
    rdfs:label "Herramienta para desbaste o acabado"@es ;
    ex:textoExtracto "Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .