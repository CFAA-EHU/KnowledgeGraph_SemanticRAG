@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1773
    a ex:Alarma ;
    rdfs:label "PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial"@es ;
    ex:identificador "1773" ;
    ex:textoExtracto "1773 'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de una de las herramientas usadas en el ciclo es igual o mayor que el radio de la entrada tangencial (radio del punto P1) o de la salida tangencial (radio del punto P12)."@es .

ex:Alarma_1774
    a ex:Alarma ;
    rdfs:label "PERFIL: F = 0"@es ;
    ex:identificador "1774" ;
    ex:textoExtracto "1774 'PERFIL: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es .

ex:Parametro_F
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ex:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z"@es ;
    ex:valor "0" .

ex:Alarma_1775
    a ex:Alarma ;
    rdfs:label "PERFIL: S = 0"@es ;
    ex:identificador "1775" ;
    ex:textoExtracto "1775 'PERFIL: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ex:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado"@es ;
    ex:valor "0" .

ex:Alarma_1776
    a ex:Alarma ;
    rdfs:label "PERFIL: T = 0"@es ;
    ex:identificador "1776" ;
    ex:textoExtracto "1776 'PERFIL: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es .

ex:Parametro_T
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ex:textoExtracto "parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada"@es ;
    ex:valor "0" .

ex:Alarma_1777
    a ex:Alarma ;
    rdfs:label "PERFIL: P = 0"@es ;
    ex:identificador "1777" ;
    ex:textoExtracto "1777 'PERFIL: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada."@es .

ex:Parametro_P
    a ex:Parametro ;
    rdfs:label "Parámetro P (profundidad)"@es ;
    ex:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada"@es ;
    ex:valor "0" .

ex:Alarma_1778
    a ex:Alarma ;
    rdfs:label "PERFIL: (ACABADO): Longitud de corte de herramienta < P"@es ;
    ex:identificador "1778" ;
    ex:textoExtracto "1778 'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)."@es .

ex:Herramienta_Acabado
    a ex:Herramienta ;
    rdfs:label "Herramienta de acabado"@es ;
    ex:textoExtracto "longitud de corte de la herramienta de acabado es menor que la profundidad del perfil"@es .