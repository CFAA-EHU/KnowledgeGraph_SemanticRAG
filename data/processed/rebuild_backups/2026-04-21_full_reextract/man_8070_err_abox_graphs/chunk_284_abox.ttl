@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1780
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: S = 0" ;
    ex:identificador "1780" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_S_1780 .

ex:DiagnosticoFallo_1781
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: T = 0" ;
    ex:identificador "1781" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." ;
    ex:solucionaFallo ex:Parametro_T_1781 .

ex:DiagnosticoFallo_1782
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: P = 0" ;
    ex:identificador "1782" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_P_1782 .

ex:DiagnosticoFallo_1783
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: L = 0" ;
    ex:identificador "1783" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro L tiene valor 0. La ranura no tiene longitud. SOLUCIÓN Asignar al parámetro un valor mayor que 0." ;
    ex:solucionaFallo ex:Parametro_L_1783 .

ex:DiagnosticoFallo_1784
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta menor que DELTA" ;
    ex:identificador "1784" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor." ;
    ex:solucionaFallo ex:Parametro_Delta_1784 .

ex:DiagnosticoFallo_1785
    a ex:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta mayor que cajera" ;
    ex:identificador "1785" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo." .

ex:Parametro_S_1780
    a ex:Parametro ;
    rdfs:label "Parámetro S (velocidad)" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado" .

ex:Parametro_T_1781
    a ex:Parametro ;
    rdfs:label "Parámetro T (herramienta)" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada" .

ex:Parametro_P_1782
    a ex:Parametro ;
    rdfs:label "Parámetro P (profundidad)" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada" .

ex:Parametro_L_1783
    a ex:Parametro ;
    rdfs:label "Parámetro L (longitud de ranura)" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro L tiene valor 0. La ranura no tiene longitud" .

ex:Parametro_Delta_1784
    a ex:Parametro ;
    rdfs:label "Parámetro Δ (paso de fresado)" ;
    ex:textoExtracto "paso de fresado (parámetro Δ)" .

ex:Parametro_F_General
    a ex:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ex:valor "0" ;
    ex:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z" .