@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_1799
    a ex:Alarma ;
    rdfs:label "Alarma 1799: PLANEADO - Diámetro de herramienta = 0" ;
    ex:identificador "1799" ;
    ex:textoExtracto "'PLANEADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0." .

ex:Alarma_1800
    a ex:Alarma ;
    rdfs:label "Alarma 1800: RANURADO - Diámetro de herramienta = 0" ;
    ex:identificador "1800" ;
    ex:textoExtracto "'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0." .

ex:Parametro_RadioHerramienta
    a ex:Parametro ;
    rdfs:label "Radio de herramienta" ;
    ex:valor "0" ;
    ex:textoExtracto "radio 0" ;
    ex:monitoreaParametro ex:Alarma_1799, ex:Alarma_1800 .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ex:textoExtracto "tabla de herramientas" ;
    ex:documentadoEn ex:Manual .