@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_1800
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1800: Ranurado - Diámetro de herramienta = 0"@es ;
    ex:identificador "1800" ;
    ex:textoExtracto "1800 'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "radio de herramienta"@es ;
        ex:valor "0" ;
        ex:textoExtracto "La herramienta de desbaste o acabado tiene radio 0."@es
    ] .

ex:Error_1801
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1801: Cajera rectangular - Beta/Theta fuera de rango"@es ;
    ex:identificador "1801" ;
    ex:textoExtracto "1801 'CAJERA RECTANGULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "ángulo de profundización lateral (β/θ)"@es ;
        ex:valor "<0" , ">90" ;
        ex:textoExtracto "el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º."@es
    ] .

ex:Error_1802
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1802: Cajera circular - Beta/Theta fuera de rango"@es ;
    ex:identificador "1802" ;
    ex:textoExtracto "1802 'CAJERA CIRCULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º."@es ;
    ex:solucionaFallo ex:Error_1801 .

ex:Error_1803
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1803: Cajera prevaciada - Beta/Theta fuera de rango"@es ;
    ex:identificador "1803" ;
    ex:textoExtracto "1803 'CAJERA PREVACIADA: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro ) o para el acabado (parámetro ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º."@es ;
    ex:solucionaFallo ex:Error_1801 .

ex:Error_1804
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1804: Ciclo G87 - Profundidad = 0"@es ;
    ex:identificador "1804" ;
    ex:textoExtracto "1804 'G87: Profundidad = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad resultante de la cajera es cero."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "profundidad de cajera (G87)"@es ;
        ex:valor "0" ;
        ex:textoExtracto "La profundidad resultante de la cajera es cero."@es
    ] .

ex:Parametro_Beta
    a ex:Parametro ;
    rdfs:label "parámetro β (ángulo de profundización lateral - desbaste)"@es ;
    ex:textoExtracto "el ángulo de profundización lateral para el desbaste (parámetro )"@es .

ex:Parametro_Theta
    a ex:Parametro ;
    rdfs:label "parámetro θ (ángulo de profundización lateral - acabado)"@es ;
    ex:textoExtracto "el ángulo de profundización lateral para el acabado (parámetro )"@es .