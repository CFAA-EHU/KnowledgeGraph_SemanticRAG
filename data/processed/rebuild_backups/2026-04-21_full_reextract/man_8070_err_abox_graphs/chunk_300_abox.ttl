@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1834
    a ex:DiagnosticoFallo ;
    rdfs:label "ACABADO: Delta z mayor que longitud de corte de herramienta" ;
    ex:identificador "1834" ;
    ex:textoExtracto "1834 'ACABADO: Delta z mayor que longitud de corte de herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro δz (demasía de acabado en el fondo) supera la longitud de corte de la herramienta de acabado. SOLUCIÓN Programar una demasía de acabado menor (parámetro δz) o utilizar otra herramienta." .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    rdfs:label "δz (demasía de acabado en el fondo)" ;
    ex:textoExtracto "El parámetro δz (demasía de acabado en el fondo) supera la longitud de corte de la herramienta de acabado." ;
    ex:valor "δz" .

ex:Herramienta_Acabado
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta de acabado" ;
    ex:textoExtracto "longitud de corte de la herramienta de acabado" .

ex:Fallo_1835
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Z de seguridad no válida" ;
    ex:identificador "1835" ;
    ex:textoExtracto "1835 'Cajera con islas: Z de seguridad no válida' DETECCIÓN Durante la ejecución del ciclo. de la pieza. CAUSA El plano de seguridad (parámetro Zs) se encuentra dentro SOLUCIÓN Asignar un valor correcto al parámetro." .

ex:Parametro_Zs
    a ex:Parametro ;
    rdfs:label "Zs (plano de seguridad)" ;
    ex:textoExtracto "El plano de seguridad (parámetro Zs) se encuentra dentro" ;
    ex:valor "Zs" .

ex:Fallo_1836
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en Z no válido" ;
    ex:identificador "1836" ;
    ex:textoExtracto "1836 'Cajera con islas: Perfil en Z no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada. SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ex:Fallo_1837
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY se corta a si mismo" ;
    ex:identificador "1837" ;
    ex:textoExtracto "1837 'Cajera con islas: Perfil en XY se corta a si mismo' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie forma más de un perfil cerrado. SOLUCIÓN Comprobar que los perfiles de superficie no se cortan a sí mismos y que sólo tienen el punto inicial en común." .

ex:Fallo_1838
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no es cerrado" ;
    ex:identificador "1838" ;
    ex:textoExtracto "1838 'Cajera con islas: Perfil en XY no es cerrado' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo. SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ex:Fallo_1839
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Intersección de perfiles en XY no válida" ;
    ex:identificador "1839" ;
    ex:textoExtracto "1839 'Cajera con islas: Intersección de perfiles en XY no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común." .

ex:Parametro_N
    a ex:Parametro ;
    rdfs:label "N (número de pasadas de profundización)" ;
    ex:textoExtracto "Programar el número de pasadas de profundización (parámetro N) o definir la longitud de corte en la tabla de herramientas." ;
    ex:valor "N" .

ex:Tabla_Herramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ex:textoExtracto "definir la longitud de corte en la tabla de herramientas" .