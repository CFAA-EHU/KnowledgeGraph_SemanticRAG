@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1851
    a ex:DiagnosticoFallo ;
    ex:identificador "1851" ;
    rdfs:label "Error 1851: 'Ly ha de ser múltiplo de Iy'"@es ;
    ex:textoExtracto "1851 'Ly ha de ser múltiplo de Iy' [...] La longitud del mecanizado (parámetro Ly) ha de ser múltiplo de la distancia entre mecanizados (parámetro Iy)."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Asignar valor incorrecto a parámetros Ly/Iy"@es ;
        ex:textoExtracto "SOLUCIÓN Asignar un valor correcto a los parámetros."@es
    ] ;
    ex:monitoreaParametro ex:Parametro_Ly, ex:Parametro_Iy .

ex:Parametro_Ly
    a ex:Parametro ;
    rdfs:label "Ly (Longitud del mecanizado)"@es ;
    ex:textoExtracto "parámetro Ly [...] longitud del mecanizado"@es .

ex:Parametro_Iy
    a ex:Parametro ;
    rdfs:label "Iy (Distancia entre mecanizados)"@es ;
    ex:textoExtracto "parámetro Iy [...] distancia entre mecanizados"@es .

ex:DiagnosticoFallo_1852
    a ex:DiagnosticoFallo ;
    ex:identificador "1852" ;
    rdfs:label "Error 1852: 'No hay herramienta programada'"@es ;
    ex:textoExtracto "1852 'No hay herramienta programada' [...] No hay herramienta o palpador en el cabezal para poder ejecutar el ciclo fijo."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Colocar herramienta/palpador en cabezal"@es ;
        ex:textoExtracto "SOLUCIÓN Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo."@es ;
        ex:requiereConsumible ex:Herramienta_Cabezal, ex:Palpador_Cabezal
    ] .

ex:Herramienta_Cabezal
    a ex:Herramienta ;
    rdfs:label "Herramienta para ciclo fijo (cabezal)"@es ;
    ex:textoExtracto "herramienta [...] en el cabezal para poder ejecutar el ciclo fijo"@es .

ex:Palpador_Cabezal
    a ex:Herramienta ;
    rdfs:label "Palpador para ciclo fijo (cabezal)"@es ;
    ex:textoExtracto "palpador en el cabezal para poder ejecutar el ciclo fijo"@es .

ex:DiagnosticoFallo_1853
    a ex:DiagnosticoFallo ;
    ex:identificador "1853" ;
    rdfs:label "Error 1853: 'No se ha recibido señal del palpador'"@es ;
    ex:textoExtracto "1853 'No se ha recibido señal del palpador' [...] Durante la"@es .