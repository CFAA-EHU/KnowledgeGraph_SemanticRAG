@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_1860
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1860: Programar K = 0/1/2"@es ;
    ex:identificador "1860" ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 3. El parámetro K (eje de palpación) tiene un valor incorrecto. El parámetro K sólo admite los valores 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)."@es .

ex:Error_1861
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1861: La distancia de seguridad B debe ser mayor que cero"@es ;
    ex:identificador "1861" ;
    ex:textoExtracto "Durante la ejecución de un ciclo de palpador #PROBE. El parámetro B tiene valor negativo. Asignar al parámetro un valor positivo."@es .

ex:Error_1862
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1862: #PROBE 1 no admitido con G20 activa"@es ;
    ex:identificador "1862" ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ex:Error_1863
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1863: Herramienta gastada por desgaste de radio"@es ;
    ex:identificador "1863" ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. El ciclo ha detectado que la herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M). Cambiar de herramienta y volver a ejecutar el ciclo."@es ;
    ex:solucionaFallo ex:TareaMantenimiento_CambioHerramienta .

ex:Error_1864
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 1864: Parámetros U, V, W deben ser mayores que X, Y, Z"@es ;
    ex:identificador "1864" ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1. En el ciclo está mal definida la posición del palpador de sobremesa. Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W. Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas."@es .

ex:TareaMantenimiento_CambioHerramienta
    a ex:TareaMantenimiento ;
    rdfs:label "Cambiar herramienta gastada"@es ;
    ex:textoExtracto "Cambiar de herramienta y volver a ejecutar el ciclo."@es .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K (eje de palpación)"@es ;
    ex:textoExtracto "El parámetro K (eje de palpación) tiene un valor incorrecto. El parámetro K sólo admite los valores 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)."@es ;
    ex:valor "0, 1, 2" .

ex:Parametro_B
    a ex:Parametro ;
    rdfs:label "Parámetro B (distancia de seguridad)"@es ;
    ex:textoExtracto "El parámetro B tiene valor negativo. Asignar al parámetro un valor positivo."@es ;
    ex:valor "> 0" .

ex:Parametro_M
    a ex:Parametro ;
    rdfs:label "Parámetro M (tolerancia de desgaste)"@es ;
    ex:textoExtracto "El desgaste medido es mayor que la tolerancia permitida (parámetro M)."@es .

ex:Parametro_UVW
    a ex:Parametro ;
    rdfs:label "Parámetros U, V, W (cotas máximas del palpador)"@es ;
    ex:textoExtracto "Los parámetros U V W hacen referencia a las cotas máximas del palpador."@es .

ex:Parametro_XYZ
    a ex:Parametro ;
    rdfs:label "Parámetros X, Y, Z (cotas mínimas del palpador)"@es ;
    ex:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador."@es .

ex:CicloPalpador_PROBE1
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 1"@es ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 1."@es ;
    ex:monitoreaParametro ex:Parametro_M, ex:Parametro_UVW, ex:Parametro_XYZ .

ex:CicloPalpador_PROBE2
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 2"@es ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 2."@es .

ex:CicloPalpador_PROBE3
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 3"@es ;
    ex:textoExtracto "Durante la ejecución del ciclo de palpador #PROBE 3."@es ;
    ex:monitoreaParametro ex:Parametro_K .

ex:Herramienta_Gastada
    a ex:Consumible ;
    rdfs:label "Herramienta con desgaste de radio"@es ;
    ex:textoExtracto "El ciclo ha detectado que la herramienta está gastada."@es .