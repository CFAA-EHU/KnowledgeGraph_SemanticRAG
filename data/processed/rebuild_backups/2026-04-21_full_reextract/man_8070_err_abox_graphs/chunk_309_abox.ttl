@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_X
    a ex:Parametro ;
    rdfs:label "Parámetro X (cota mínima del palpador)"@es ;
    ex:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:Parametro_Y
    a ex:Parametro ;
    rdfs:label "Parámetro Y (cota mínima del palpador)"@es ;
    ex:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:Parametro_Z
    a ex:Parametro ;
    rdfs:label "Parámetro Z (cota mínima del palpador)"@es ;
    ex:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:Parametro_U
    a ex:Parametro ;
    rdfs:label "Parámetro U (cota máxima del palpador)"@es ;
    ex:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:Parametro_V
    a ex:Parametro ;
    rdfs:label "Parámetro V (cota máxima del palpador)"@es ;
    ex:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:Parametro_W
    a ex:Parametro ;
    rdfs:label "Parámetro W (cota máxima del palpador)"@es ;
    ex:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ex:monitoreaParametro ex:DiagnosticoFallo_1865 .

ex:DiagnosticoFallo_1865
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1865: Cotas del palpador excedidas"@es ;
    ex:identificador "1865" ;
    ex:textoExtracto "Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W. [...] SOLUCIÓN Definir la posición del palpador de manera que U > X, V > Y, W > Z."@es ;
    ex:solucionaFallo ex:ComponenteMecanico_Palpador .

ex:ComponenteMecanico_Palpador
    a ex:ComponenteMecanico ;
    rdfs:label "Palpador"@es ;
    ex:textoExtracto "parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es .

ex:DiagnosticoFallo_1866
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1866: Herramienta de desbaste no definida"@es ;
    ex:identificador "1866" ;
    ex:textoExtracto "1865 'Cajera con islas: No existe T de desbaste' [...] CAUSA La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta."@es ;
    ex:solucionaFallo ex:Herramienta_T .

ex:Herramienta_T
    a ex:Herramienta ;
    rdfs:label "Herramienta de desbaste (T)"@es ;
    ex:textoExtracto "No existe T de desbaste"@es .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ex:textoExtracto "La herramienta programada no existe en la tabla de herramientas"@es ;
    ex:documentadoEn ex:Manual_Principal .