ex:Alarma_1868
    a ex:Alarma ;
    rdfs:label "Cajera con islas: No existe T de acabado" ;
    ex:identificador "1868" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." ;
    ex:mitigaRiesgo ex:AccionProhibida_HerramientaNoDefinida_1868 .

ex:AccionProhibida_HerramientaNoDefinida_1868
    a ex:AccionProhibida ;
    rdfs:label "Uso de herramienta no definida en tabla" ;
    ex:textoExtracto "La herramienta programada no existe en la tabla de herramientas." .

