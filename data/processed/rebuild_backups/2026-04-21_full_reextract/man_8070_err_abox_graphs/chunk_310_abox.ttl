ex:Alarma_1866
    a ex:Alarma ;
    rdfs:label "Cajera con islas: F de desbaste no válida" ;
    ex:identificador "1866" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de desbaste tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." ;
    ex:monitoreaParametro ex:Parametro_FDesbaste_1866 .

ex:Parametro_FDesbaste_1866
    a ex:Parametro ;
    rdfs:label "Avance de desbaste (F)" ;
    ex:valor "0" ;
    ex:textoExtracto "El avance para la operación de desbaste tiene valor 0." .

