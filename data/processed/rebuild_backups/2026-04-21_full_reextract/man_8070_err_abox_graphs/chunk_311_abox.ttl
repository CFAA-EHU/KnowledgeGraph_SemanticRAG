@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1872
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Paso de acabado no válido" ;
    ex:identificador "1872" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En una cajera 2D, el paso de mecanizado para el acabado (parámetro ) es mayor que el diámetro de la herramienta. En una cajera 3D, el paso de mecanizado para el acabado (parámetro ) es cero. SOLUCIÓN Corregir el paso de mecanizado." .

ex:DiagnosticoFallo_1873
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Demasía lateral no válida" ;
    ex:identificador "1873" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía lateral para el acabado (parámetro ) es mayor que el diámetro de la herramienta." .

ex:Parametro_Delta
    a ex:Parametro ;
    rdfs:label "Paso de mecanizado para acabado (2D)" ;
    ex:identificador "Δ" ;
    ex:textoExtracto "parámetro " .

ex:Parametro_Epsilon
    a ex:Parametro ;
    rdfs:label "Paso de mecanizado para acabado (3D)" ;
    ex:identificador "ε" ;
    ex:textoExtracto "parámetro " .

ex:Parametro_DeltaLateral
    a ex:Parametro ;
    rdfs:label "Demasía lateral para acabado" ;
    ex:identificador "δ" ;
    ex:textoExtracto "parámetro " .

ex:Herramienta_Generica
    a ex:Herramienta ;
    rdfs:label "Herramienta de mecanizado" ;
    ex:textoExtracto "diámetro de la herramienta" .