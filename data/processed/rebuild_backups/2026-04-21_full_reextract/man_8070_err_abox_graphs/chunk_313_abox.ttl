@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1880
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: No existe T de semiacabado" ;
    ex:identificador "1880" ;
    ex:textoExtracto "CAUSA El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta. 1880 'Cajera con islas: No existe T de semiacabado' DETECCIÓN Durante la ejecución del ciclo." ;
    ex:solucionaFallo [
        a ex:Herramienta ;
        rdfs:label "Herramienta de semiacabado (T)" ;
        ex:textoExtracto "Definir la herramienta en la tabla o seleccionar otra herramienta."
    ] .

ex:DiagnosticoFallo_1881
    a ex:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: F de semiacabado no válida" ;
    ex:identificador "1881" ;
    ex:textoExtracto "CAUSA La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta. 1881 'Cajera con islas: F de semiacabado no válida' DETECCIÓN" ;
    ex:solucionaFallo [
        a ex:Herramienta ;
        rdfs:label "Herramienta de semiacabado (F)" ;
        ex:textoExtracto "Definir la herramienta en la tabla o seleccionar otra herramienta."
    ] .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ex:textoExtracto "Definir la herramienta en la tabla o seleccionar otra herramienta." .