@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1901
    a ex:Alarma ;
    rdfs:label "Dato no válido" ;
    ex:identificador "1901" ;
    ex:textoExtracto "1901 'Dato no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro del ciclo tiene un valor incorrecto. El parámetro incorrecto estará indicado en el mensaje de error. SOLUCIÓN Corregir la programación." .

ex:Alarma_1902
    a ex:Alarma ;
    rdfs:label "Posición inicial y factor de forma de la herramienta incompatibles" ;
    ex:identificador "1902" ;
    ex:textoExtracto "1902 'Posición inicial y factor de forma de la herramienta incompatibles' DETECCIÓN Durante la ejecución del ciclo. CAUSA La posición inicial de la herramienta no es compatible con el factor de forma y la geometría de la herramienta. SOLUCIÓN Posicionar la herramienta adecuadamente o" .

ex:Parametro_Ciclo
    a ex:Parametro ;
    ex:textoExtracto "Algún parámetro del ciclo tiene un valor incorrecto."@es .

ex:Herramienta
    a ex:Herramienta ;
    ex:textoExtracto "La posición inicial de la herramienta no es compatible con el factor de forma y la geometría de la herramienta."@es .

ex:Alarma_1901 ex:monitoreaParametro ex:Parametro_Ciclo .
ex:Alarma_1902 ex:mitigaRiesgo ex:Herramienta .