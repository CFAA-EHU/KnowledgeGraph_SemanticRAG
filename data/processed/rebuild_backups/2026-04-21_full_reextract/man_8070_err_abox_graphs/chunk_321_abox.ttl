@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1919
    a ex:DiagnosticoFallo ;
    rdfs:label "Perfil programado se corta a si mismo" ;
    ex:identificador "1919" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil definido en el ciclo fijo no es válido porque se corta a si mismo. SOLUCIÓN Programar un perfil que no se corte a si mismo." .

ex:DiagnosticoFallo_1920
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha programado perfil" ;
    ex:identificador "1920" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el perfil que define la geometría del ciclo fijo. SOLUCIÓN" .

ex:DiagnosticoFallo_1918
    a ex:DiagnosticoFallo ;
    rdfs:label "Perfil definido en ciclo fijo no válido (perfil cerrado)" ;
    ex:textoExtracto "CAUSA El perfil definido en el ciclo fijo no es válido porque es un perfil cerrado. SOLUCIÓN Programar un perfil que no sea cerrado." .