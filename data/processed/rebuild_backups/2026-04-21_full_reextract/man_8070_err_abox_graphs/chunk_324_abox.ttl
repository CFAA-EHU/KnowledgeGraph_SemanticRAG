@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1928
    a ex:DiagnosticoFallo ;
    rdfs:label "Paso de ranurado mayor que la anchura de la cuchilla" ;
    ex:textoExtracto "'Paso de ranurado mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de ranurado es mayor que la anchura de la cuchilla. SOLUCIÓN Programar un paso de ranurado menor o igual que la anchura de la cuchilla." ;
    ex:identificador "1928" .

ex:Fallo_1929
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha programado avance del cabezal" ;
    ex:textoExtracto "'No se ha programado avance del cabezal' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad del cabezal tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." ;
    ex:identificador "1929" .

ex:Fallo_1930
    a ex:DiagnosticoFallo ;
    rdfs:label "Programado paso de taladrado nulo" ;
    ex:textoExtracto "'Programado paso de taladrado nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de taladrado tiene valor 0. SOLUCIÓN Definir un paso de taladrado diferente de 0." ;
    ex:identificador "1930" .

ex:Fallo_1931
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha programado profundidad" ;
    ex:textoExtracto "'No se ha programado profundidad' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad de mecanizado tiene valor 0. SOLUCIÓN Definir una profundidad de mecanizado diferente de 0." ;
    ex:identificador "1931" .

ex:Fallo_1932
    a ex:DiagnosticoFallo ;
    rdfs:label "No hay cabezal para ejecutar el ciclo" ;
    ex:textoExtracto "'No hay cabezal para ejecutar el ciclo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal. SOLUCIÓN Ceder un cabezal al canal o ejecutar el ciclo en un canal con cabezal." ;
    ex:identificador "1932" .

ex:Fallo_1933
    a ex:DiagnosticoFallo ;
    rdfs:label "No hay herramienta motorizada para ejecutar el ciclo" ;
    ex:textoExtracto "'No hay herramienta motorizada para ejecutar el ciclo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal para la herramienta motorizada. SOLUCIÓN Ceder una herramienta motorizada al canal o ejecutar el ciclo en un canal con herramienta motorizada." ;
    ex:identificador "1933" .

ex:Fallo_1934
    a ex:DiagnosticoFallo ;
    rdfs:label "Anchura de la cuchilla no válida" ;
    ex:textoExtracto "'Anchura de la cuchilla no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada. SOLUCIÓN Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada." ;
    ex:identificador "1934" .

ex:Herramienta
    a ex:Herramienta ;
    ex:textoExtracto "Seleccionar otra herramienta."@es .

ex:Parametro_PasoRanurado
    a ex:Parametro ;
    ex:textoExtracto "El paso de ranurado es mayor que la anchura de la cuchilla."@es .

ex:Parametro_AvanceCabezal
    a ex:Parametro ;
    ex:textoExtracto "La velocidad del cabezal tiene valor 0."@es ;
    ex:valor "0" .

ex:Parametro_PasoTaladrado
    a ex:Parametro ;
    ex:textoExtracto "El paso de taladrado tiene valor 0."@es ;
    ex:valor "0" .

ex:Parametro_ProfundidadMecanizado
    a ex:Parametro ;
    ex:textoExtracto "La profundidad de mecanizado tiene valor 0."@es ;
    ex:valor "0" .

ex:Componente_Cabezal
    a ex:ComponenteMecanico ;
    ex:textoExtracto "El canal que ejecuta el ciclo no dispone de cabezal."@es .

ex:HerramientaMotorizada
    a ex:Herramienta ;
    ex:textoExtracto "El canal que ejecuta el ciclo no dispone de cabezal para la herramienta motorizada."@es .

ex:Componente_Cuchilla
    a ex:ComponenteMecanico ;
    ex:textoExtracto "La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada."@es .

ex:Fallo_1934 ex:solucionaFallo ex:Herramienta .
ex:Fallo_1929 ex:solucionaFallo ex:Parametro_AvanceCabezal .
ex:Fallo_1930 ex:solucionaFallo ex:Parametro_PasoTaladrado .
ex:Fallo_1931 ex:solucionaFallo ex:Parametro_ProfundidadMecanizado .
ex:Fallo_1932 ex:solucionaFallo ex:Componente_Cabezal .
ex:Fallo_1933 ex:solucionaFallo ex:HerramientaMotorizada .