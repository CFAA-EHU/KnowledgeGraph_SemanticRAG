@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo_1935
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "Error 1935: No se ha definido ningún eje como LONGAXIS en ciclo de eje C"@es ;
    ex:textoExtracto   "1935 'No se ha definido ningún eje como LONGAXIS en ciclo de eje C' [...] CAUSA No hay definido ningún eje longitudinal en el canal. SOLUCIÓN Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal."@es ;
    ex:identificador   "1935" .

ex:Parametro_LONGAXIS
    a                  ex:Parametro ;
    rdfs:label         "Parámetro máquina LONGAXIS"@es ;
    ex:textoExtracto   "Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal."@es ;
    ex:valor            "TRUE" ;
    ex:solucionaFallo   ex:DiagnosticoFallo_1935 .

ex:DiagnosticoFallo_1936
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "Error 1936: Parámetro no definido (fragmento incompleto)"@es ;
    ex:textoExtracto   "1936 'No se ha definido ningún"@es ;
    ex:identificador   "1936" .

ex:DiagnosticoFallo_AnchuraCuchilla
    a                  ex:DiagnosticoFallo ;
    rdfs:label         "Error de mecanizado: Anchura de cuchilla mayor que la ranura"@es ;
    ex:textoExtracto   "CAUSA La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada. SOLUCIÓN Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada."@es .

ex:Herramienta_Seleccionada
    a                  ex:Herramienta ;
    rdfs:label         "Herramienta de mecanizado (genérica)"@es ;
    ex:textoExtracto   "Comprobar que la herramienta seleccionada puede mecanizar la ranura programada"@es ;
    ex:solucionaFallo   ex:DiagnosticoFallo_AnchuraCuchilla .