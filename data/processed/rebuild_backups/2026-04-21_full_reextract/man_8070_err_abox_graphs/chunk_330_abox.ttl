@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_1960
    a ex:Alarma ;
    rdfs:label "Alarma 1960: Radio de herramienta de semiacabado demasiado grande"@es ;
    ex:identificador "1960" ;
    ex:textoExtracto "1960 'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ex:Alarma_1961
    a ex:Alarma ;
    rdfs:label "Alarma 1961: Radio de la punta de la herramienta de acabado no válido"@es ;
    ex:identificador "1961" ;
    ex:textoExtracto "1961 'Radio de la punta de la herramienta de acabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R). SOLUCIÓN Corregir el valor del radio de la punta."@es .

ex:Alarma_1962
    a ex:Alarma ;
    rdfs:label "Alarma 1962: Ángulo de profundización en el desbaste no válido"@es ;
    ex:identificador "1962" ;
    ex:textoExtracto "1962 'Angulo de profundización en el desbaste no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º."@es .

ex:Alarma_1963
    a ex:Alarma ;
    rdfs:label "Alarma 1963: Ángulo de profundización en el semiacabado no válido"@es ;
    ex:identificador "1963" ;
    ex:textoExtracto "1963 'Angulo de profundización en el semiacabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el semiacabado no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º."@es .

ex:Alarma_1964
    a ex:Alarma ;
    rdfs:label "Alarma 1964: Paso de desbaste mayor que el diámetro de la herramienta"@es ;
    ex:identificador "1964" ;
    ex:textoExtracto "1964 'Programado paso de desbaste mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el desbaste es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta."@es .

ex:Alarma_1965
    a ex:Alarma ;
    rdfs:label "Alarma 1965: Paso de acabado mayor que el diámetro de la herramienta"@es ;
    ex:identificador "1965" ;
    ex:textoExtracto "1965 'Programado paso de acabado mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta."@es .

ex:Alarma_1966
    a ex:Alarma ;
    rdfs:label "Alarma 1966: Tipo de acabado no válido"@es ;
    ex:identificador "1966" ;
    ex:textoExtracto "1966 'Tipo de acabado no válido' DETECCIÓN Durante la ejecución del ciclo."@es .

ex:Parametro_RadioHerramientaSemiacabado
    a ex:Parametro ;
    rdfs:label "Radio de herramienta de semiacabado"@es ;
    ex:textoExtracto "El radio de la herramienta de semiacabado es demasiado grande para la geometría de la cajera."@es ;
    ex:monitoreaParametro ex:Alarma_1960 .

ex:Parametro_RadioPuntaAcabado
    a ex:Parametro ;
    rdfs:label "Radio de punta (Rp) de herramienta de acabado"@es ;
    ex:textoExtracto "El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R)."@es ;
    ex:monitoreaParametro ex:Alarma_1961 .

ex:Parametro_AnguloProfundizacionDesbaste
    a ex:Parametro ;
    rdfs:label "Ángulo de profundización para el desbaste"@es ;
    ex:valor "0º-90º" ;
    ex:textoExtracto "El ángulo de profundización para el desbaste no está comprendido entre 0º y 90º."@es ;
    ex:monitoreaParametro ex:Alarma_1962 .

ex:Parametro_AnguloProfundizacionSemiacabado
    a ex:Parametro ;
    rdfs:label "Ángulo de profundización para el semiacabado"@es ;
    ex:valor "0º-90º" ;
    ex:textoExtracto "El ángulo de profundización para el semiacabado no está comprendido entre 0º y 90º."@es ;
    ex:monitoreaParametro ex:Alarma_1963 .

ex:Parametro_PasoMecanizadoDesbaste
    a ex:Parametro ;
    rdfs:label "Paso de mecanizado para el desbaste"@es ;
    ex:textoExtracto "El paso de mecanizado para el desbaste es mayor que el diámetro de la herramienta."@es ;
    ex:monitoreaParametro ex:Alarma_1964 .

ex:Parametro_PasoMecanizadoAcabado
    a ex:Parametro ;
    rdfs:label "Paso de mecanizado para el acabado"@es ;
    ex:textoExtracto "El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta."@es ;
    ex:monitoreaParametro ex:Alarma_1965 .