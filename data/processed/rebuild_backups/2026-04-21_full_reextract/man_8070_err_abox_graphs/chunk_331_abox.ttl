@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_1966
    a ex:DiagnosticoFallo ;
    ex:identificador "1966" ;
    rdfs:label "'Tipo de acabado no válido'" ;
    ex:textoExtracto "1966 'Tipo de acabado no válido' [...] CAUSA El tipo de acabado no es válido. SOLUCIÓN Asignar un valor correcto a los parámetros." ;
    ex:solucionaFallo ex:AccionProhibida_ParametroAcabadoInvalido .

ex:AccionProhibida_ParametroAcabadoInvalido
    a ex:AccionProhibida ;
    ex:textoExtracto "El tipo de acabado no es válido." .

ex:DiagnosticoFallo_1967
    a ex:DiagnosticoFallo ;
    ex:identificador "1967" ;
    rdfs:label "'Cota Z del plano de partida no valida'" ;
    ex:textoExtracto "1967 'Cota Z del plano de partida no valida' [...] CAUSA La cota Z de comienzo del ciclo se encuentra dentro" .

ex:DiagnosticoFallo_PasoMecanizadoExcesivo
    a ex:DiagnosticoFallo ;
    ex:textoExtracto "CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta." ;
    ex:solucionaFallo ex:AccionProhibida_PasoMecanizadoInvalido .

ex:AccionProhibida_PasoMecanizadoInvalido
    a ex:AccionProhibida ;
    ex:textoExtracto "El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta." .

ex:Parametro_CotaZ
    a ex:Parametro ;
    rdfs:label "Cota Z del plano de partida" ;
    ex:textoExtracto "La cota Z de comienzo del ciclo se encuentra dentro" .

ex:Parametro_TipoAcabado
    a ex:Parametro ;
    rdfs:label "Tipo de acabado" ;
    ex:textoExtracto "El tipo de acabado no es válido." .