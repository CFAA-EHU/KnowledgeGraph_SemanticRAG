@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1988
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1988: Tipo de palpador no válido"@es ;
    ex:identificador "1988" ;
    ex:textoExtracto "1988 'El tipo de palpador no es válido (P6)' DETECCIÓN Durante la ejecución. CAUSA El tipo de palpador seleccionado no es válido. SOLUCIÓN El parámetro P6 sólo admite valores 0 y 1."@es .

ex:Fallo_1989
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1989: Cinemática no calibrable"@es ;
    ex:identificador "1989" ;
    ex:textoExtracto "1989 'No se puede calibrar este tipo de cinemática' DETECCIÓN Durante la ejecución. CAUSA La calibración de este tipo de cinemática no está implementada."@es .

ex:Fallo_1990
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1990: Falta contacto con esfera de calibración"@es ;
    ex:identificador "1990" ;
    ex:textoExtracto "1990 'No hay contacto con la esfera. Asegúrese que el palpador está encima de la bola a una distancia máxima del doble de la distancia de seguridad' DETECCIÓN Durante la ejecución. CAUSA El palpador no está colocado encima de la bola o está muy lejos."@es .

ex:Fallo_1991
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1991: Posiciones inicial y final iguales en ejes rotativos"@es ;
    ex:identificador "1991" ;
    ex:textoExtracto "1991 'Error de parametrización. La posición inicial y final no pueden ser iguales' DETECCIÓN Durante la ejecución. CAUSA La posición inicial y final de los ejes rotativos es la misma."@es .

ex:Fallo_1992
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1992: Ejes rotativos no en posición de reposo"@es ;
    ex:identificador "1992" ;
    ex:textoExtracto "1992 'Los ejes rotativos de la cinemática tienen que estar en su posición de reposo' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos no están en su posición de reposo."@es .

ex:Fallo_1993
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1993: Posición de reposo de ejes rotativos no es cero"@es ;
    ex:identificador "1993" ;
    ex:textoExtracto "1993 'La posición de reposo de los ejes rotativos de la cinemática tiene que ser cero' DETECCIÓN Durante la ejecución. CAUSA En los parámetros máquina de la cinemática la posición de reposo de los ejes tiene que ser 0."@es .

ex:Fallo_SinSignalPalpado
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo: Señal de palpado no detectada"@es ;
    ex:textoExtracto "No ha llegado señal de palpado cuando se esperaba tocar la esfera. SOLUCIÓN Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es .

ex:Fallo_1994
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 1994: Posición de ejes rotativos manuales no es cero"@es ;
    ex:identificador "1994" ;
    ex:textoExtracto "1994 La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es .

ex:Parametro_P6
    a               ex:Parametro ;
    rdfs:label      "Parámetro P6 (tipo de palpador)"@es ;
    ex:identificador "P6" ;
    ex:valor         "0,1" ;
    ex:textoExtracto "El parámetro P6 sólo admite valores 0 y 1."@es .

ex:Parametro_ErrorMaximoCinematica
    a               ex:Parametro ;
    rdfs:label      "Error máximo de cinemática"@es ;
    ex:valor         "1 mm" ;
    ex:textoExtracto "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es .

ex:Variable_VGPOSROTx
    a               ex:Parametro ;
    rdfs:label      "Variable V.G.POSROTx (posición ejes rotativos manuales)"@es ;
    ex:identificador "V.G.POSROTx" ;
    ex:valor         "0" ;
    ex:textoExtracto "La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es .

ex:Fallo_1990
    ex:solucionaFallo ex:Parametro_ErrorMaximoCinematica .

ex:Fallo_1988
    ex:solucionaFallo ex:Parametro_P6 .