@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VGPOSROTx a ex:Parametro ;
    rdfs:label "Variable V.G.POSROTx"@es ;
    ex:textoExtracto "la posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx"@es ;
    ex:identificador "V.G.POSROTx" .

ex:Parametro_VGPOSROTF a ex:Parametro ;
    rdfs:label "Variable V.G.POSROTF"@es ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero"@es ;
    ex:identificador "V.G.POSROTF" .

ex:Parametro_VGPOSROTS a ex:Parametro ;
    rdfs:label "Variable V.G.POSROTS"@es ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero"@es ;
    ex:identificador "V.G.POSROTS" .

ex:Parametro_VGPOSROTT a ex:Parametro ;
    rdfs:label "Variable V.G.POSROTT"@es ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero"@es ;
    ex:identificador "V.G.POSROTT" .

ex:Parametro_VGPOSROTO a ex:Parametro ;
    rdfs:label "Variable V.G.POSROTO"@es ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero"@es ;
    ex:identificador "V.G.POSROTO" .

ex:DiagnosticoFallo_1994 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 1994: Posición de reposo de ejes rotativos no es cero"@es ;
    ex:textoExtracto "SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina. 1994 La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx. DETECCIÓN Durante la ejecución. CAUSA Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero. SOLUCIÓN El valor de estas variables debe ser"@es ;
    ex:identificador "1994" ;
    ex:monitoreaParametro ex:Parametro_VGPOSROTx ;
    ex:monitoreaParametro ex:Parametro_VGPOSROTF ;
    ex:monitoreaParametro ex:Parametro_VGPOSROTS ;
    ex:monitoreaParametro ex:Parametro_VGPOSROTT ;
    ex:monitoreaParametro ex:Parametro_VGPOSROTO .