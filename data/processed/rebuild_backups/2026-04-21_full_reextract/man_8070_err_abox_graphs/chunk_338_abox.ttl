@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_1995
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha elegido ningún eje para la calibración"@es ;
    ex:textoExtracto "1995 No se ha elegido ningún eje para la calibración. DETECCIÓN Durante la ejecución. CAUSA No se ha elegido ningún eje para la calibración. SOLUCIÓN Elegir un eje."@es ;
    ex:identificador "1995" .

ex:Fallo_1996
    a ex:DiagnosticoFallo ;
    rdfs:label "El COMPID está siendo utilizado por otro KINID"@es ;
    ex:textoExtracto "1996 El COMPID está siendo utilizado por otro KINID. DETECCIÓN Durante la ejecución. CAUSA El COMPID está siendo utilizado por otro KINID. SOLUCIÓN Seleccionar otro COMPID."@es ;
    ex:identificador "1996" .

ex:Fallo_VariablesPosicionRotacion
    a ex:DiagnosticoFallo ;
    rdfs:label "Variables de posición de ejes rotativos no son cero"@es ;
    ex:textoExtracto "Durante la ejecución. CAUSA Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero. SOLUCIÓN El valor de estas variables debe ser cero."@es .

ex:Parametro_VG_POSROTF
    a ex:Parametro ;
    rdfs:label "V.G.POSROTF" ;
    ex:identificador "V.G.POSROTF" ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ex:Parametro_VG_POSROTS
    a ex:Parametro ;
    rdfs:label "V.G.POSROTS" ;
    ex:identificador "V.G.POSROTS" ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ex:Parametro_VG_POSROTT
    a ex:Parametro ;
    rdfs:label "V.G.POSROTT" ;
    ex:identificador "V.G.POSROTT" ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ex:Parametro_VG_POSROTO
    a ex:Parametro ;
    rdfs:label "V.G.POSROTO" ;
    ex:identificador "V.G.POSROTO" ;
    ex:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ex:Fallo_VariablesPosicionRotacion
    ex:solucionaFallo ex:Parametro_VG_POSROTF , ex:Parametro_VG_POSROTS , ex:Parametro_VG_POSROTT , ex:Parametro_VG_POSROTO .