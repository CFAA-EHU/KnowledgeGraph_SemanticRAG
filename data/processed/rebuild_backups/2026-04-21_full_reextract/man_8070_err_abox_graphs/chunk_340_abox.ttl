@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_CompensacionRadio_G40
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en compensación de radio (G40)"@es ;
    ex:identificador "G40" ;
    ex:textoExtracto "Después de desactivar la compensación de radio (G40), el siguiente bloque de movimiento es un bloque circular. La compensación de radio no puede acabar en un bloque circular."@es .

ex:Aviso_2005_CompensacionRadioLineal
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso 2005: El último bloque de compensación de radio debe ser lineal"@es ;
    ex:identificador "2005" ;
    ex:textoExtracto "2005 'El último bloque de compensación de radio debe ser lineal' DETECCIÓN Durante la ejecución."@es ;
    ex:mitigaRiesgo  ex:Fallo_CompensacionRadio_G40 .