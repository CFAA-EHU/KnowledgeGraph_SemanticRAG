@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2009
    a ex:Alarma ;
    rdfs:label "Diferencia entre el radio inicial y final del arco demasiado grande"@es ;
    ex:identificador "2009" ;
    ex:textoExtracto "2009 'Diferencia entre el radio inicial y final del arco demasiado grande' [...] SOLUCIÓN Revisar la programación del arco."@es .

ex:Alarma_2010
    a ex:Alarma ;
    rdfs:label "Radio de herramienta demasiado grande al calcular compensación entre arcos"@es ;
    ex:identificador "2010" ;
    ex:textoExtracto "2010 'Radio de herramienta demasiado grande al calcular compensación entre arcos' [...] SOLUCIÓN Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande."@es .

ex:Alarma_2011
    a ex:Alarma ;
    rdfs:label "Movimiento de compensación en trayectoria circular (perfil dañado)"@es ;
    ex:identificador "2011" ;
    ex:textoExtracto "2011 'Movimiento de compensación en trayectoria circular (perfil dañado)' [...] SOLUCIÓN Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande."@es .

ex:Alarma_2012
    a ex:Alarma ;
    rdfs:label "Bloque de transición no relevante eliminado"@es ;
    ex:identificador "2012" ;
    ex:textoExtracto "2012 Se ha eliminado un bloque de transición no relevante. [...] SOLUCIÓN Aceptar la modificación propuesta y continuar con la ejecución."@es .

ex:Alarma_2013
    a ex:Alarma ;
    rdfs:label "Diferente radio de herramienta entre la trayectoria anterior y una circular"@es ;
    ex:identificador "2013" ;
    ex:textoExtracto "2013 'Diferente radio de herramienta entre la trayectoria anterior y una circular' [...] SOLUCIÓN Con la compensación de radio activa, no cambiar el radio de la herramienta durante la ejecución de un arco."@es .

ex:Alarma_2014
    a ex:Alarma ;
    rdfs:label "No hay intersección entre línea y arco: radio de herramienta demasiado grande"@es ;
    ex:identificador "2014" ;
    ex:textoExtracto "2014 No hay intersección entre línea y arco: radio de herramienta demasiado grande. [...] SOLUCIÓN Usar una herramienta de menor"@es .

ex:ModoOperacion_G139
    a ex:ModoOperacion ;
    rdfs:label "Modo indirecto de compensación de radio"@es ;
    ex:identificador "G139" ;
    ex:textoExtracto "utiliza el modo indirecto (G139) para activar la compensación de radio."@es .

ex:Parametro_RadioHerramienta
    a ex:Parametro ;
    rdfs:label "Radio de herramienta"@es ;
    ex:textoExtracto "El radio de la herramienta es demasiado grande para el arco programado."@es .

ex:Parametro_ToleranciaRadio
    a ex:Parametro ;
    rdfs:label "Tolerancia permitida de diferencia de radio"@es ;
    ex:textoExtracto "la diferencia entre el radio inicial y el radio final es mayor que la tolerancia permitida."@es .

ex:DiagnosticoFallo_CompensacionRadio
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en compensación de radio durante trayectoria circular"@es ;
    ex:textoExtracto "Si no es posible programar este bloque, utiliza el modo indirecto (G139) para activar la compensación de radio."@es ;
    ex:solucionaFallo ex:Alarma_2009, ex:Alarma_2010, ex:Alarma_2011, ex:Alarma_2013, ex:Alarma_2014 ;
    ex:requiereMantenimiento ex:TareaMantenimiento_RevisionProgramacion .

ex:TareaMantenimiento_RevisionProgramacion
    a ex:TareaMantenimiento ;
    rdfs:label "Revisión de programación de arcos y compensación de radio"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la programación del arco."@es .