@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_2100
    a ex:AvisoSeguridad ;
    ex:identificador "2100" ;
    rdfs:label "Límite software positivo sobrepasado en G5, G60 o HSC"@es ;
    ex:textoExtracto "2100 'Límite software positivo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC en G05, G60 o HSC queda fuera de los límites de recorrido activos."@es ;
    ex:mitigaRiesgo ex:AccionProhibida_SplinesYControlTangencial .

ex:AccionProhibida_SplinesYControlTangencial
    a ex:AccionProhibida ;
    rdfs:label "Activar/desactivar splines y control tangencial simultáneamente"@es ;
    ex:textoExtracto "SOLUCIÓN Desactivar los splines antes activar el control tangencial o viceversa."@es .