@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2100
    a ex:Alarma ;
    rdfs:label "Alarma 2100: HSC' DETECCIÓN"@es ;
    ex:identificador "2100" ;
    ex:textoExtracto "o HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC en G05, G60 o HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Comprobar que la trayectoria programada está dentro de los límites de software y ejecutarla en G7 ó G50 para evitar el sobrepasamiento. En caso necesario, desactivar el modo HSC (#HSC OFF)."@es .

ex:Alarma_2101
    a ex:Alarma ;
    rdfs:label "Alarma 2101: Límite software negativo sobrepasado en G5, G60 o HSC"@es ;
    ex:identificador "2101" ;
    ex:textoExtracto "2101 'Límite software negativo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC en G05, G60 o HSC queda fuera de los límites de recorrido activos. SOLUCIÓN Comprobar que la trayectoria programada está dentro de los límites de software y ejecutarla en G7 ó G50 para evitar el sobrepasamiento. En caso necesario, desactivar el modo HSC (#HSC OFF)."@es .

ex:Alarma_2102
    a ex:Alarma ;
    rdfs:label "Alarma 2102: #ROUNDPAR: parámetro demasiado pequeño"@es ;
    ex:identificador "2102" ;
    ex:textoExtracto "2102 #ROUNDPAR:parámetro demasiado pequeño. DETECCIÓN Durante la ejecución. CAUSA El error de contorno programado es demasiado pequeño para ser tratado. SOLUCIÓN Programar la sentencia con un error de contorno superior a 20 micras."@es .

ex:Alarma_2103
    a ex:Alarma ;
    rdfs:label "Alarma 2103: #ROUNDPAR: parámetro incorrecto"@es ;
    ex:identificador "2103" ;
    ex:textoExtracto "2103 #ROUNDPAR:parámetro incorrecto. DETECCIÓN Durante la ejecución. CAUSA El tipo de redondeo programado no es válido. SOLUCIÓN Consultar en el manual de programación el formato de esta sentencia."@es .

ex:Alarma_2104
    a ex:Alarma ;
    rdfs:label "Alarma 2104: #HSC: tangente inicial indeterminada"@es ;
    ex:identificador "2104" ;
    ex:textoExtracto "2104 #HSC: tangente inicial indeterminada. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El punto para iniciar el #HSC coincide con el punto anterior y la tangente queda indeterminada. • Se ha programado sólo un eje de la tangente. SOLUCIÓN Programar un punto previo diferente al punto de entrada del #HSC y ambos ejes de la tangente."@es .

ex:Alarma_2105
    a ex:Alarma ;
    rdfs:label "Alarma 2105: #HSC: tangente final indeterminada"@es ;
    ex:identificador "2105" ;
    ex:textoExtracto "2105 #HSC: tangente final indeterminada. DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El punto para finalizar el #HSC coincide con el punto anterior y la tangente queda indeterminada. •"@es .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación HSC"@es ;
    ex:identificador "HSC" ;
    ex:textoExtracto "desactivar el modo HSC (#HSC OFF)"@es .

ex:ModoOperacion_G5
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación G5"@es ;
    ex:identificador "G5" ;
    ex:textoExtracto "ejecutarla en G7 ó G50 para evitar el sobrepasamiento"@es .

ex:ModoOperacion_G50
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación G50"@es ;
    ex:identificador "G50" ;
    ex:textoExtracto "ejecutarla en G7 ó G50 para evitar el sobrepasamiento"@es .

ex:ModoOperacion_G7
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación G7"@es ;
    ex:identificador "G7" ;
    ex:textoExtracto "ejecutarla en G7 ó G50 para evitar el sobrepasamiento"@es .

ex:Parametro_ROUNDPAR
    a ex:Parametro ;
    rdfs:label "Parámetro ROUNDPAR"@es ;
    ex:identificador "ROUNDPAR" ;
    ex:textoExtracto "2102 #ROUNDPAR:parámetro demasiado pequeño. [...] 2103 #ROUNDPAR:parámetro incorrecto."@es ;
    ex:valor "20" ;
    ex:monitoreaParametro ex:Alarma_2102, ex:Alarma_2103 .