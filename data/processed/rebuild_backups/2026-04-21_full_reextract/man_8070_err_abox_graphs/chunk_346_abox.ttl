@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_2105_HSC_TangenteFinalIndeterminada
    a ex:Alarma ;
    rdfs:label "Alarma 2105: HSC - Tangente final indeterminada" ;
    ex:identificador "2105" ;
    ex:textoExtracto "#HSC: tangente final indeterminada. DETECCIÓN Durante la ejecución." .

ex:Alarma_2106_HSC_ErrorInterno
    a ex:Alarma ;
    rdfs:label "Alarma 2106: HSC - Error interno en modo HSC" ;
    ex:identificador "2106" ;
    ex:textoExtracto "2106 HSC:Error interno en modo HSC. DETECCIÓN Durante la ejecución." .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación HSC" ;
    ex:textoExtracto "modo HSC" ;
    ex:activaAlarma ex:Alarma_2105_HSC_TangenteFinalIndeterminada ;
    ex:activaAlarma ex:Alarma_2106_HSC_ErrorInterno .