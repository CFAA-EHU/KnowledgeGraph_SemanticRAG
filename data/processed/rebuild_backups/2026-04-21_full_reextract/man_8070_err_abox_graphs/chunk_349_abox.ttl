@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2114
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE: Activación no permitida" ;
    ex:textoExtracto "2114 SPLINE:Activación no permitida. DETECCIÓN Durante la ejecución. CAUSA No se puede activar el modo spline sin terminar un spline previo. SOLUCIÓN Desactivar el modo spline activo antes de definir uno nuevo." ;
    ex:identificador "2114" .

ex:Error_2115
    a ex:DiagnosticoFallo ;
    rdfs:label "#ASPLINE: parámetro no válido" ;
    ex:textoExtracto "2115 #ASPLINE:parámetro no válido. DETECCIÓN Durante la ejecución. CAUSA El tipo de tangencia no es válido. SOLUCIÓN Consultar en el manual de programación el formato correcto." ;
    ex:identificador "2115" .

ex:Error_2116
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE: Error en la activación" ;
    ex:textoExtracto "2116 SPLINE: Error en la activación. DETECCIÓN Durante la ejecución. CAUSA No se puede activar un modo spline sin desactivar el modo anterior. SOLUCIÓN Desactivar el modo spline activo antes de activar otro." ;
    ex:identificador "2116" .

ex:Error_2118
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE: Tipo de spline no válido" ;
    ex:textoExtracto "2118 'SPLINE: Tipo de spline no válido' DETECCIÓN Durante la ejecución. CAUSA Hay programado un tipo de spline no permitido. SOLUCIÓN Consultar en el manual de programación el formato correcto." ;
    ex:identificador "2118" .

ex:Error_2119
    a ex:DiagnosticoFallo ;
    rdfs:label "SPLINE: No se admite cambiar el tipo con splines activados" ;
    ex:textoExtracto "2119 'SPLINE: No se admite cambiar el tipo con splines activados' DETECCIÓN Durante la ejecución. CAUSA Hay programado un cambio de tipo de spline sin anular el spline. SOLUCIÓN Desactivar el modo spline activo antes de activar otro." ;
    ex:identificador "2119" .

ex:Error_2121
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admiten trayectorias circulares con splines activos" ;
    ex:textoExtracto "2121 'No se admiten trayectorias circulares con splines activos' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento circular con el modo spline activo. SOLUCIÓN Desactivar el modo spline antes de programar el arco." ;
    ex:identificador "2121" .

ex:Error_2122
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admiten bloques polinómicos con splines activos" ;
    ex:textoExtracto "2122 'No se admiten bloques polinómicos con splines activos' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento polinómico con el modo spline activo. SOLUCIÓN Desactivar el modo spline antes de programar el polinomio." ;
    ex:identificador "2122" .

ex:Error_2123
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con splines activos" ;
    ex:textoExtracto "2123 'Programación no permitida con splines activos' DETECCIÓN Durante la ejecución. CAUSA Con el modo spline activo, hay programado un cambio de sistema de coordenadas o sentencias que detienen la preparación de bloques." ;
    ex:identificador "2123" .

ex:ModoSpline
    a ex:ModoOperacion ;
    rdfs:label "Modo spline" ;
    ex:textoExtracto "modo spline activo" .

ex:Error_2114 ex:solucionaFallo ex:ModoSpline .
ex:Error_2115 ex:solucionaFallo ex:ModoSpline .
ex:Error_2116 ex:solucionaFallo ex:ModoSpline .
ex:Error_2118 ex:solucionaFallo ex:ModoSpline .
ex:Error_2119 ex:solucionaFallo ex:ModoSpline .
ex:Error_2121 ex:solucionaFallo ex:ModoSpline .
ex:Error_2122 ex:solucionaFallo ex:ModoSpline .
ex:Error_2123 ex:solucionaFallo ex:ModoSpline .