@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2123
    a ex:AvisoSeguridad ;
    rdfs:label "Programación no permitida con splines activos" ;
    ex:identificador "2123" ;
    ex:textoExtracto "2123 'Programación no permitida con splines activos' [...] SOLUCIÓN Desactivar el modo spline antes de programar el polinomio."@es ,
                      "SOLUCIÓN Desactivar el modo spline antes de cambiar el sistema de coordenadas o programar sentencias que detienen la preparación de bloques."@es ;
    ex:mitigaRiesgo ex:AccionProhibida_ProgramarConSplinesActivos .

ex:AccionProhibida_ProgramarConSplinesActivos
    a ex:AccionProhibida ;
    rdfs:label "Programar con modo spline activo" ;
    ex:textoExtracto "Con el modo spline activo, hay programado un cambio de sistema de coordenadas o sentencias que detienen la preparación de bloques."@es .

ex:ModoOperacion_Spline
    a ex:ModoOperacion ;
    rdfs:label "Modo spline" ;
    ex:textoExtracto "modo spline activo"@es .