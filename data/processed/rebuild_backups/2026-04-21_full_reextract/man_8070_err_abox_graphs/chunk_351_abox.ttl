@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2124
    a ex:Alarma ;
    rdfs:label "SPLINE: Son necesarios al menos dos ejes principales"@es ;
    ex:identificador "2124" ;
    ex:textoExtracto "2124 'SPLINE: Son necesarios al menos dos ejes principales' DETECCIÓN Durante la ejecución. CAUSA No se puede activar el modo spline con sólo un eje en el canal. SOLUCIÓN Configurar el canal con dos ejes o programar los movimientos sin modo spline."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_ModoSpline_EjesInsuficientes .

ex:DiagnosticoFallo_ModoSpline_EjesInsuficientes
    a ex:DiagnosticoFallo ;
    rdfs:label "Modo spline con eje único en canal"@es ;
    ex:textoExtracto "No se puede activar el modo spline con sólo un eje en el canal."@es .

ex:Alarma_2125
    a ex:Alarma ;
    rdfs:label "SPLINE: Error en el cálculo de la tangente"@es ;
    ex:identificador "2125" ;
    ex:textoExtracto "2125 'SPLINE: Error en el cálculo de la tangente' DETECCIÓN Durante la ejecución. CAUSA Hay programado puntos repetidos. SOLUCIÓN Programar puntos distintos."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_ModoSpline_PuntosRepetidos .

ex:DiagnosticoFallo_ModoSpline_PuntosRepetidos
    a ex:DiagnosticoFallo ;
    rdfs:label "Puntos repetidos en trayectoria spline"@es ;
    ex:textoExtracto "Hay programado puntos repetidos."@es .

ex:Alarma_2126
    a ex:Alarma ;
    rdfs:label "Límite software positivo sobrepasado en el spline"@es ;
    ex:identificador "2126" ;
    ex:textoExtracto "2126 'Límite software positivo sobrepasado en el spline' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo spline en el bloque o bloques que provocan el error."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_ModoSpline_LimitePositivoExcedido .

ex:DiagnosticoFallo_ModoSpline_LimitePositivoExcedido
    a ex:DiagnosticoFallo ;
    rdfs:label "Trayectoria spline fuera de límite software positivo"@es ;
    ex:textoExtracto "La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos."@es .

ex:Alarma_2127
    a ex:Alarma ;
    rdfs:label "Límite software negativo sobrepasado en el spline"@es ;
    ex:identificador "2127" ;
    ex:textoExtracto "2127 'Límite software negativo sobrepasado en el spline' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos. SOLUCIÓN Desactivar el modo spline en el bloque o bloques que provocan el error."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_ModoSpline_LimiteNegativoExcedido .

ex:DiagnosticoFallo_ModoSpline_LimiteNegativoExcedido
    a ex:DiagnosticoFallo ;
    rdfs:label "Trayectoria spline fuera de límite software negativo"@es ;
    ex:textoExtracto "La trayectoria que genera el CNC para trabajar en modo spline queda fuera de los límites de recorrido activos."@es .

ex:Alarma_2128
    a ex:Alarma ;
    rdfs:label "Trayectoria helicoidal mal programada"@es ;
    ex:identificador "2128" ;
    ex:textoExtracto "2128 'Trayectoria helicoidal mal programada' DETECCIÓN Durante la ejecución. CAUSA Falta algún parámetro de la trayectoria helicoidal o bien es incorrecto. Está programado el paso y falta la profundidad, falta el paso y el punto final o bien no son compatibles la profundidad, el paso y el punto final. SOLUCIÓN Programar el punto final compatible con el paso y la profundidad. Si la trayectoria helicoidal son vueltas enteras, programar el paso y la profundidad."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_TrayectoriaHelicoidal_Incompleta .

ex:DiagnosticoFallo_TrayectoriaHelicoidal_Incompleta
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetros incompletos o incompatibles en trayectoria helicoidal"@es ;
    ex:textoExtracto "Falta algún parámetro de la trayectoria helicoidal o bien es incorrecto. Está programado el paso y falta la profundidad, falta el paso y el punto final o bien no son compatibles la profundidad, el paso y el punto final."@es .

ex:Alarma_2129
    a ex:Alarma ;
    rdfs:label "Error en la transformación de RTCP"@es ;
    ex:identificador "2129" ;
    ex:textoExtracto "2129 'Error en la transformación de RTCP' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una transformación RTCP y no están en el canal todos los ejes necesarios."@es ;
    ex:solucionaFallo ex:DiagnosticoFallo_TransformacionRTCP_EjesFaltantes .

ex:DiagnosticoFallo_TransformacionRTCP_EjesFaltantes
    a ex:DiagnosticoFallo ;
    rdfs:label "Ejes insuficientes para transformación RTCP"@es ;
    ex:textoExtracto "Se ha programado una transformación RTCP y no están en el canal todos los ejes necesarios."@es .

ex:ModoOperacion_Spline
    a ex:ModoOperacion ;
    rdfs:label "Modo spline"@es ;
    ex:textoExtracto "modo spline"@es ;
    ex:activaAlarma ex:Alarma_2124, ex:Alarma_2125, ex:Alarma_2126, ex:Alarma_2127 .