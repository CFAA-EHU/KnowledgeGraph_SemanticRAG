@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2130
    a ex:AvisoSeguridad ;
    rdfs:label "Error en la transformación de plano inclinado (2130)" ;
    ex:textoExtracto "2130 'Error en la transformación de plano inclinado' [...] CAUSA Hay programado un plano inclinado y no hay tres ejes en el canal. SOLUCIÓN Antes de activar el plano inclinado, configurar el canal con los ejes necesarios." ;
    ex:identificador "2130" .

ex:Error_2131
    a ex:AvisoSeguridad ;
    rdfs:label "Error interno en modo eje C (2131)" ;
    ex:textoExtracto "2131 'Error interno en modo eje C' [...] CAUSA No es posible la transformación de eje C para el bloque. SOLUCIÓN Eliminar el bloque o bloques que provocan el error." ;
    ex:identificador "2131" .

ex:Error_2132
    a ex:AvisoSeguridad ;
    rdfs:label "Parámetro máquina PROBERANGE no programado (2132)" ;
    ex:textoExtracto "2132 Parámetro máquina PROBERANGE no programado. [...] CAUSA No se ha definido el parámetro PROBERANGE. SOLUCIÓN Definir el parámetro PROBERANGE." ;
    ex:identificador "2132" .

ex:Parametro_PROBERANGE
    a ex:Parametro ;
    rdfs:label "PROBERANGE" ;
    ex:textoExtracto "Parámetro máquina PROBERANGE no programado." ;
    ex:identificador "PROBERANGE" .

ex:Error_2133
    a ex:AvisoSeguridad ;
    rdfs:label "El eje maestro no existe (2133)" ;
    ex:textoExtracto "2133 El eje maestro no existe. [...] CAUSA El eje maestro del acoplo no está disponible en el canal." ;
    ex:identificador "2133" .

ex:Error_2134
    a ex:AvisoSeguridad ;
    rdfs:label "El eje esclavo no existe (2134)" ;
    ex:textoExtracto "2134 El eje esclavo no existe. [...] CAUSA El eje esclavo del acoplo no está disponible en el canal." ;
    ex:identificador "2134" .

ex:Error_2135
    a ex:AvisoSeguridad ;
    rdfs:label "Velocidad máxima de cabezal nula (2135)" ;
    ex:textoExtracto "2135 'Programada velocidad máxima de cabezal nula' [...] CAUSA En velocidad de corte constante no se ha programado la velocidad máxima de cabezal." ;
    ex:identificador "2135" .

ex:Parametro_VelocidadMaximaCabezal
    a ex:Parametro ;
    rdfs:label "Velocidad máxima de cabezal" ;
    ex:textoExtracto "velocidad máxima de cabezal" .

ex:Error_2136
    a ex:AvisoSeguridad ;
    rdfs:label "Velocidad máxima de corte nula (2136)" ;
    ex:textoExtracto "2136 'Programada velocidad máxima de corte nula' [...] CAUSA En velocidad de corte constante no se ha programado la velocidad de corte." ;
    ex:identificador "2136" .

ex:Parametro_VelocidadMaximaCorte
    a ex:Parametro ;
    rdfs:label "Velocidad máxima de corte" ;
    ex:textoExtracto "velocidad de corte" .

ex:Error_2137
    a ex:AvisoSeguridad ;
    rdfs:label "FACEAXIS no definido (2137)" ;
    ex:textoExtracto "2137 No se ha definido FACEAXIS. [...] CAUSA No hay definido un eje frontal." ;
    ex:identificador "2137" .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "eje frontal" ;
    ex:identificador "FACEAXIS" .

ex:Error_RTCP
    a ex:AvisoSeguridad ;
    rdfs:label "Error en transformación RTCP" ;
    ex:textoExtracto "Antes de activar la transformación RTCP, configurar el canal con los ejes necesarios." .