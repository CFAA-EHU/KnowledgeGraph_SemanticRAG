@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_2139
    a ex:DiagnosticoFallo ;
    rdfs:label "Movimiento nulo en roscado" ;
    ex:identificador "2139" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El eje de roscado no se encuentra en el canal. SOLUCIÓN Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar la rosca." .

ex:DiagnosticoFallo_2140
    a ex:DiagnosticoFallo ;
    rdfs:label "SLOPE: Parámetro no válido" ;
    ex:identificador "2140" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Algún parámetro de la sentencia de programación #SLOPE es incorrecto. SOLUCIÓN Consultar en el manual de programación el formato correcto." .

ex:Parametro_SLOPE
    a ex:Parametro ;
    rdfs:label "Parámetro SLOPE" ;
    ex:textoExtracto "parámetro de la sentencia de programación #SLOPE" ;
    ex:monitoreaParametro ex:DiagnosticoFallo_2140 .

ex:DiagnosticoFallo_2141
    a ex:DiagnosticoFallo ;
    rdfs:label "Trayectoria circular no permitida sin dos ejes en el plano principal" ;
    ex:identificador "2141" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se permiten trayectorias circulares si no hay al menos dos ejes en el canal. SOLUCIÓN Configurar el canal con al menos dos ejes." .

ex:DiagnosticoFallo_2142
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación no permitida con eje(s) Hirth" ;
    ex:identificador "2142" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha programado un comando incompatible con un eje hirth. SOLUCIÓN Revisar programación." .

ex:ComponenteMecanico_EjeHirth
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Hirth" ;
    ex:textoExtracto "eje(s) Hirth" ;
    ex:tieneComponente ex:Maquina_CNC .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC ha alcanzado el final del programa con el modo spline activo." .

ex:DiagnosticoFallo_2143
    a ex:DiagnosticoFallo ;
    rdfs:label "No se puede calcular la tangente al spline" ;
    ex:identificador "2143" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se puede calcular la tangente para deseleccionar el spline. SOLUCIÓN Deseleccionar el spline en otro punto o programar otra tangente." .

ex:DiagnosticoFallo_2144
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la generación del spline" ;
    ex:identificador "2144" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se ha programado el primer bloque para activar el spline. SOLUCIÓN Programar un movimiento antes de activar el spline." .

ex:DiagnosticoFallo_2145
    a ex:DiagnosticoFallo ;
    rdfs:label "Final del programa sin desactivar splines" ;
    ex:identificador "2145" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha alcanzado el final del programa con el modo spline activo. SOLUCIÓN Anular el spline antes de finalizar el programa." ;
    ex:documentadoEn ex:Maquina_CNC .

ex:DiagnosticoFallo_2146
    a ex:DiagnosticoFallo ;
    rdfs:label "No es posible la desactivación del spline" ;
    ex:identificador "2146" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Número insuficiente de bloques para desactivar el spline." .