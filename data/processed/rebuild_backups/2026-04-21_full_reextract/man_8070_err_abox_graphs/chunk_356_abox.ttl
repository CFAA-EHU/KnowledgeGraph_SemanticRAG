@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2145
    a               ex:Alarma ;
    rdfs:label      "Alarma 2145: Final de programa con modo spline activo"@es ;
    ex:textoExtracto "CAUSA El CNC ha alcanzado el final del programa con el modo spline activo. SOLUCIÓN Anular el spline antes de finalizar el programa."@es ;
    ex:identificador "2145" .

ex:Alarma_2146
    a               ex:Alarma ;
    rdfs:label      "Alarma 2146: Desactivación de spline no posible"@es ;
    ex:textoExtracto "2146 'No es posible la desactivación del spline' DETECCIÓN Durante la ejecución. CAUSA Número insuficiente de bloques para desactivar el spline. SOLUCIÓN No programar el spline para ejecutar un solo bloque."@es ;
    ex:identificador "2146" .

ex:Alarma_2147
    a               ex:Alarma ;
    rdfs:label      "Alarma 2147: Spline no permitido en modo HSC"@es ;
    ex:textoExtracto "2147 'Programación de splines no permitida en modo HSC' DETECCIÓN Durante la ejecución. CAUSA No se permite activar el spline con el"@es ;
    ex:identificador "2147" .

ex:ModoOperacion_Spline
    a               ex:ModoOperacion ;
    rdfs:label      "Modo spline"@es ;
    ex:textoExtracto "modo spline activo"@es .

ex:ModoOperacion_HSC
    a               ex:ModoOperacion ;
    rdfs:label      "Modo HSC"@es ;
    ex:textoExtracto "modo HSC"@es .

ex:Alarma_2147 ex:activaAlarma ex:ModoOperacion_Spline .