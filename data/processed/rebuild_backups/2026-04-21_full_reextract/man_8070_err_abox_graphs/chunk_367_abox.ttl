ex:Alarma_2325
    a ex:Alarma ;
    rdfs:label "Alarma 2325: 'El punto final no pertenece al círculo'" ;
    ex:identificador "2325" ;
    ex:textoExtracto "2325 'El punto final no pertenece al círculo' [...] SOLUCIÓN Revisar la programación." ;
    ex:solucionaFallo ex:DiagnosticoFallo_2325 .

ex:DiagnosticoFallo_2325
    a ex:DiagnosticoFallo ;
    rdfs:label "Punto final fuera del círculo en programación" ;
    ex:textoExtracto "CAUSA El punto final no pertenece al círculo. SOLUCIÓN Revisar la programación." .

