ex:Alarma_2333
    a ex:Alarma ;
    rdfs:label "Alarma 2333: 'Programación no permitida fuera de una macro G8736'" ;
    ex:identificador "2333" ;
    ex:textoExtracto "2333 'Programación no permitida fuera de una macro G8736' [...] SOLUCIÓN Revisar la programación. Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." ;
    ex:solucionaFallo ex:DiagnosticoFallo_2333 .

ex:DiagnosticoFallo_2333
    a ex:DiagnosticoFallo ;
    rdfs:label "Funciones G8737/G8738 fuera de macro G8736" ;
    ex:textoExtracto "CAUSA Hay alguna función G8737 o G8738 programada fuera de una macro G8736. SOLUCIÓN [...] Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736." .