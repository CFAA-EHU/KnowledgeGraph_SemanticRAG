@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2335
    a ex:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8725" ;
    ex:identificador "2335" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8724 programada fuera de una macro G8725. SOLUCIÓN Revisar la programación. La función G8724 se debe programar a continuación de la macro G8725." .

ex:Alarma_2336
    a ex:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8726" ;
    ex:identificador "2336" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8727 o G8728 programada fuera de una macro G8726. SOLUCIÓN Revisar la programación. Las funciones G8727 o G8728 se deben programar a continuación de la macro G8726." .

ex:Alarma_2337
    a ex:Alarma ;
    rdfs:label "Programación PROGTL3 no permitida en un perfil ISO" ;
    ex:identificador "2337" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El perfil de la macro está escrito en dos lenguajes, ProGTL3 e ISO. SOLUCIÓN Los perfiles de las macros se pueden definir en lenguaje ProGTL3 o ISO, pero no se permite mezclar ambos en un mismo perfil." .

ex:Alarma_2338
    a ex:Alarma ;
    rdfs:label "No se admite programar sección H" ;
    ex:identificador "2338" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Sólo se permite programar H en los bloques del perfil plano definido en G8736 o como parámetro de G8737. SOLUCIÓN Revisar la programación. No programar H en otros bloques." .

ex:Alarma_2339
    a ex:Alarma ;
    rdfs:label "No es compatible la compensación de radio activa y la 3D" ;
    ex:identificador "2339" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa. SOLUCIÓN Revisar la programación. Ambos tipos de compensación son incompatibles." .

ex:Alarma_G8734
    a ex:Alarma ;
    rdfs:label "Programación no permitida fuera de una macro G8735" ;
    ex:identificador "G8734" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8734 programada fuera de una macro G8735. SOLUCIÓN Revisar la programación. La función G8734 se debe programar a continuación de la macro G8735." .