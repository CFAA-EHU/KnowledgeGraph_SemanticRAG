@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2340
    a ex:DiagnosticoFallo ;
    rdfs:label "Vector doblemente definido" ;
    ex:identificador "2340" ;
    ex:textoExtracto "CAUSA Compensación de herramienta 3D. En el mismo bloque hay programados dos vectores N[a,b,c]. SOLUCIÓN Revisar la programación. Programar un único vector por bloque." .

ex:Fallo_2341
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación de vector incorrecta" ;
    ex:identificador "2341" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución." .

ex:Fallo_CompensacionIncompatible
    a ex:DiagnosticoFallo ;
    rdfs:label "Compensación de radio y 3D incompatibles" ;
    ex:textoExtracto "CAUSA El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa. SOLUCIÓN Revisar la programación. Ambos tipos de compensación son incompatibles." .