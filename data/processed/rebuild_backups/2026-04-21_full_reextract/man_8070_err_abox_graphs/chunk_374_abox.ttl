@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2355
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en proceso #LSFIT" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT. SOLUCIÓN Revisar la programación. 2355 'Error en proceso #LSFIT'" ;
    ex:identificador "2355" .

ex:Error_2356
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SELECT ORI" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. 2356 'Programar #SELECT ORI [HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]'" ;
    ex:identificador "2356" .

ex:Parametro_TIPO_LSFIT
    a ex:Parametro ;
    rdfs:label "Parámetro TIPO de la sentencia #LSFIT" ;
    ex:textoExtracto "CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido." ;
    ex:identificador "TIPO" .

ex:Diagnostico_2354
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en parámetro TIPO de #LSFIT" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido. SOLUCIÓN Revisar la programación." ;
    ex:identificador "2354" ;
    ex:monitoreaParametro ex:Parametro_TIPO_LSFIT .