@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_G34_PasoNegativo
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en programación de paso de husillo (G34)"@es ;
    ex:identificador "G34" ;
    ex:textoExtracto "Con el paso de husillo y el decremento de paso de husillo programados en G34, el paso final de rosca calculado por el control es negativo o cero."@es ;
    ex:solucionaFallo [
        a           ex:TareaMantenimiento ;
        rdfs:label  "Reprogramación de parámetros G34"@es ;
        ex:textoExtracto "Programar correctamente el paso y el decremento de paso de husillo en G34"@es
    ] .

ex:Fallo_2370_EjeRoscadoInexistente
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 2370: Eje para roscar inexistente"@es ;
    ex:identificador "2370" ;
    ex:textoExtracto "Eje para roscar inexistente. [...] El eje de roscado viene definido por la letra con la que se programa el paso de husillo en el bloque."@es .