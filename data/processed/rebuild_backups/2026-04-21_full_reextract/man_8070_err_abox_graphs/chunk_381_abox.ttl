@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2377
    a ex:Alarma ;
    rdfs:label "#LSFIT, la instrucción no es válida" ;
    ex:identificador "2377" ;
    ex:textoExtracto "2377 #LSFIT, la instrucción no es válida. DETECCIÓN Durante la ejecución. CAUSA La sentencia #LSFIT no se ha programado correctamente. SOLUCIÓN Revisar la programación." .

ex:Alarma_2378
    a ex:Alarma ;
    rdfs:label "#GAPCTRL: Falta programar el eje o el GAP" ;
    ex:identificador "2378" ;
    ex:textoExtracto "2378 #GAPCTRL: Falta programar el eje o el GAP. DETECCIÓN Durante la ejecución. CAUSA En el comando #GAPCTRL no se ha programado el eje o la distancia (gap). SOLUCIÓN Programar el eje y/o el GAP." .

ex:Alarma_2379
    a ex:Alarma ;
    rdfs:label "#GAPCTRL: Parámetro máquina GAPANAINID nulo o sin asignar" ;
    ex:identificador "2379" ;
    ex:textoExtracto "2379 #GAPCTRL: Parámetro máquina GAPANAINID nulo o sin asignar. DETECCIÓN Durante la ejecución. CAUSA No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID). SOLUCIÓN Asignar el valor correcto al parámetro máquina GAPANAINID." ;
    ex:activaAlarma ex:Sensor_GAP .

ex:Sensor_GAP
    a ex:Sensor ;
    rdfs:label "Sensor del gap" ;
    ex:textoExtracto "No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." ;
    ex:monitoreaParametro ex:Parametro_GAPANAINID .

ex:Parametro_GAPANAINID
    a ex:Parametro ;
    rdfs:label "GAPANAINID" ;
    ex:identificador "GAPANAINID" ;
    ex:textoExtracto "parámetro máquina GAPANAINID" ;
    ex:valor "nulo o sin asignar" .

ex:Alarma_2380
    a ex:Alarma ;
    rdfs:label "#LSFIT, error interno" ;
    ex:identificador "2380" ;
    ex:textoExtracto "2380 #LSFIT, error interno. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. Datos incoherentes en el ciclo. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ex:Alarma_2381
    a ex:Alarma ;
    rdfs:label "#ABORT OFF no programado en la misma subrutina que #ABORT" ;
    ex:identificador "2381" ;
    ex:textoExtracto "2381 #ABORT OFF no programado en la misma subrutina que #ABORT. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el comando #ABORT OFF. Si se programa el comando #ABORT solo en el bloque, al abortar el programa la ejecución continúa en el comando #ABORT OFF. SOLUCIÓN Programar #ABORT OFF." .

ex:Alarma_2382
    a ex:Alarma ;
    rdfs:label "#ISO ON[]. Sintaxis incorrecta" ;
    ex:identificador "2382" ;
    ex:textoExtracto "2382 #ISO ON[]. Sintaxis incorrecta. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Alarma_2383
    a ex:Alarma ;
    rdfs:label "#ISO ON[]. Nombre de fichero no válido" ;
    ex:identificador "2383" ;
    ex:textoExtracto "2383 #ISO ON[]. Nombre de fichero no valido. DETECCIÓN Durante la ejecución." .