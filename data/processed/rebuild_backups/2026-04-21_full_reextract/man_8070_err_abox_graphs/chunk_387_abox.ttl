@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_E
    a ex:Parametro ;
    rdfs:label "Parámetro 'E' (estado de zona de trabajo)" ;
    ex:textoExtracto "el parámetro 'E' una sola vez en el bloque. [...] Programar el estado de la zona de trabajo en el parámetro 'E'; de 0 a 2." ;
    ex:valor "0-2" .

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro NAXIS (número máximo de ejes)" ;
    ex:textoExtracto "Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)." .

ex:DiagnosticoFallo_2394
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2394: Estado de zona de trabajo no programado" ;
    ex:identificador "2394" ;
    ex:textoExtracto "2394 Estado de la zona de trabajo no programado. [...] SOLUCIÓN Programar el estado de la zona de trabajo en el parámetro 'E'; de 0 a 2." ;
    ex:solucionaFallo ex:Parametro_E .

ex:DiagnosticoFallo_2395
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2395: Ejes rotativos tipo módulo no permitidos" ;
    ex:identificador "2395" ;
    ex:textoExtracto "2395 'No se permite programar el centro con ejes rotativos tipo módulo' [...] SOLUCIÓN No se permite definir el centro con ejes rotativos tipo módulo." .

ex:DiagnosticoFallo_2396
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2396: #GAPCTRL programado en otro canal" ;
    ex:identificador "2396" ;
    ex:textoExtracto "2396 #GAPCTRL programado en otro canal. [...] SOLUCIÓN Sólo puede haber activo un control de gap en el CNC." .

ex:DiagnosticoFallo_2397
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2397: Modificación de parámetros con #GAPCTRL activo" ;
    ex:identificador "2397" ;
    ex:textoExtracto "2397 #GAPCTRL ON activo.#GAPCTRL OFF necesario para cambiar parámetros. [...] SOLUCIÓN Desactivar #GAPCTRL antes de modificar sus parámetros." .

ex:DiagnosticoFallo_2398
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2398: Falta programación de POSLIMIT en #LEAP" ;
    ex:identificador "2398" ;
    ex:textoExtracto "2398 #LEAP:falta programación de POSLIMIT. [...] SOLUCIÓN La primera vez que se programa #LEAP es obligatorio programar el comando POSLIMIT." .

ex:DiagnosticoFallo_2399
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2399: Intento de alterar POS con #LEAP activo" ;
    ex:identificador "2399" ;
    ex:textoExtracto "2399 #LEAP activo. No se puede alterar POS, posición final del salto. [...] SOLUCIÓN Revisar la programación." .

ex:DiagnosticoFallo_2400
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 2400: Número lógico de eje fuera de rango" ;
    ex:identificador "2400" ;
    ex:textoExtracto "2400 Número lógico de eje fuera de rango. [...] SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)." ;
    ex:solucionaFallo ex:Parametro_NAXIS .

ex:Componente_GAPCTRL
    a ex:Componente ;
    rdfs:label "Control de gap (#GAPCTRL)" ;
    ex:textoExtracto "#GAPCTRL programado en otro canal. [...] Sólo puede haber activo un control de gap en el CNC." .

ex:Componente_LEAP
    a ex:Componente ;
    rdfs:label "Función de salto (#LEAP)" ;
    ex:textoExtracto "#LEAP:falta programación de POSLIMIT. [...] #LEAP activo. No se puede alterar POS, posición final del salto." .