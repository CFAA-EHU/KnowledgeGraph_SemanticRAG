@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_2406_GAPCTRL_LEAP
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Fallo 2406: #LEAP con #GAPCTRL ON"@es ;
    ex:textoExtracto       "2406 #LEAP con #GAPCTRL ON: El salto debe empezar y acabar en la misma cota. DETECCIÓN Durante la preparación de bloques. CAUSA Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación se ha programado la instrucción #LEAP para ejecutar un salto cuya cota inicial y final"@es ;
    ex:identificador       "2406" .

ex:Fallo_MDI_GAPCTRL
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Fallo: Movimiento en MDI con eje controlado por #GAPCTRL"@es ;
    ex:textoExtracto       "CAUSA Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL. SOLUCIÓN Programar #GAPCTRL OFF."@es .

ex:Comando_GAPCTRL
    a                     ex:Parametro ;
    rdfs:label            "Parámetro #GAPCTRL (control de eje)"@es ;
    ex:textoExtracto       "comando #GAPCTRL", "instrucción #GAPCTRL ON", "Programar #GAPCTRL OFF"@es ;
    ex:valor               "ON", "OFF" .

ex:Comando_LEAP
    a                     ex:Parametro ;
    rdfs:label            "Parámetro #LEAP (salto en cota)"@es ;
    ex:textoExtracto       "instrucción #LEAP para ejecutar un salto cuya cota inicial y final"@es .

ex:ModoOperacion_MDI
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo MDI (Manual Data Input)"@es ;
    ex:textoExtracto       "mover en MDI"@es .