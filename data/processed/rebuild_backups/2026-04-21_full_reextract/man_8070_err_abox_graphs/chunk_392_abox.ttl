@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2410
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2410: Sintaxis incorrecta en #PWRCTRL ON/OFF"@es ;
    ex:textoExtracto "2410 #PWRCTRL ON/OFF [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "2410" .

ex:AvisoSeguridad_2411
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2411: Sintaxis incorrecta en #PWRCTRL OFF"@es ;
    ex:textoExtracto "2411 #PWRCTRL OFF<[DUTY/D/OUT/O]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador "2411" .

ex:AvisoSeguridad_2412
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2412: Parámetro PWRCTRL fuera de rango"@es ;
    ex:textoExtracto "2412 Parámetro PWRCTRL fuera de rango. DETECCIÓN Durante la edición y"@es ;
    ex:identificador "2412" .

ex:Parametro_PWRCTRL
    a ex:Parametro ;
    rdfs:label "Parámetro PWRCTRL"@es ;
    ex:textoExtracto "Parámetro PWRCTRL fuera de rango"@es ;
    ex:identificador "PWRCTRL" .

ex:AvisoSeguridad_2412 ex:monitoreaParametro ex:Parametro_PWRCTRL .