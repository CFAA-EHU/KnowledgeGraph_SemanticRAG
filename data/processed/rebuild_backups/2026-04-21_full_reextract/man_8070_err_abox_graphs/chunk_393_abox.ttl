@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error2412
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Parámetro PWRCTRL fuera de rango"@es ;
    ex:textoExtracto      "2412 Parámetro PWRCTRL fuera de rango. DETECCIÓN Durante la edición y ejecución. CAUSA Algún comando de la sentencia #PERCTRL tiene un valor no válido. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador      "2412" .

ex:Error2413
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Es obligatorio programar DUTY/OUT"@es ;
    ex:textoExtracto      "2413 Es obligatorio programar DUTY/OUT. DETECCIÓN Durante la edición y ejecución. CAUSA Falta programar el comando DUTY/OUT en la función #PWRCTRL. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Para activar el control de potencia (#PWRCTRL) es obligatorio programar uno de los comandos DUTY o OUT."@es ;
    ex:identificador      "2413" .

ex:Error2414
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "PWCTRL DUTY no permitido si no hay opción de software PWM"@es ;
    ex:textoExtracto      "2414 PWCTRL DUTY no permitido si no hay opción de software PWM. DETECCIÓN Durante la ejecución. CAUSA Para activar el control del duty del PWM, es necesario disponer de la opción de software 'PWM'. SOLUCIÓN Activar el control de potencia (comando OUT) o adquirir la opción de software correspondiente."@es ;
    ex:identificador      "2414" .

ex:Error2415
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "PWCTRL OUT no permitido sin cabezal master en el canal"@es ;
    ex:textoExtracto      "2415 PWCTRL OUT no permitido sin cabezal master en el canal. DETECCIÓN Durante la ejecución. CAUSA El control de potencia se aplica al cabezal master. Se ha intentado activar el control de potencia y no hay un cabezal master activo. SOLUCIÓN Seleccionar un cabezal master (#MASTER) antes de activar el control de potencia."@es ;
    ex:identificador      "2415" .

ex:Error2416
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Sintaxis incorrecta en #PWRCTRL ON"@es ;
    ex:textoExtracto      "2416 #PWRCTRL ON [<DUTY/D/OUT/O> <,OVRMINvalue> <,OVRMAXvalue> <,FMINvalue> <,FMAXvalue>]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:identificador      "2416" .

ex:Error2417
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "#PWRCTRL ON: FMIN debe ser menor que FMAX"@es ;
    ex:textoExtracto      "2417 #PWRCTRL ON: FMIN debe ser menor que FMAX. DETECCIÓN Durante la ejecución. CAUSA En la función #PWRCTRL, el avance mínimo es mayor que el avance máximo."@es ;
    ex:identificador      "2417" .

ex:ParametroPWRCTRL
    a                     ex:Parametro ;
    rdfs:label            "Parámetro PWRCTRL"@es ;
    ex:textoExtracto      "Parámetro PWRCTRL fuera de rango"@es .

ex:ParametroFMIN
    a                     ex:Parametro ;
    rdfs:label            "FMIN"@es ;
    ex:textoExtracto      "FMIN debe ser menor que FMAX"@es .

ex:ParametroFMAX
    a                     ex:Parametro ;
    rdfs:label            "FMAX"@es ;
    ex:textoExtracto      "FMIN debe ser menor que FMAX"@es .

ex:ComandoDUTY
    a                     ex:Parametro ;
    rdfs:label            "DUTY"@es ;
    ex:textoExtracto      "comando DUTY/OUT en la función #PWRCTRL", "Para activar el control del duty del PWM"@es .

ex:ComandoOUT
    a                     ex:Parametro ;
    rdfs:label            "OUT"@es ;
    ex:textoExtracto      "comando DUTY/OUT en la función #PWRCTRL", "Activar el control de potencia (comando OUT)"@es .

ex:OpcionSoftwarePWM
    a                     ex:Sistema ;
    rdfs:label            "Opción de software PWM"@es ;
    ex:textoExtracto      "opción de software 'PWM'"@es .

ex:CabezalMaster
    a                     ex:Componente ;
    rdfs:label            "Cabezal master"@es ;
    ex:textoExtracto      "El control de potencia se aplica al cabezal master", "Seleccionar un cabezal master (#MASTER)"@es .

ex:ManualProgramacion
    a                     ex:Manual ;
    rdfs:label            "Manual de programación"@es ;
    ex:textoExtracto      "Revisar en el manual de programación la sintaxis de la sentencia"@es .

ex:Error2412
    ex:solucionaFallo      ex:ManualProgramacion .

ex:Error2413
    ex:solucionaFallo      ex:ManualProgramacion .

ex:Error2414
    ex:solucionaFallo      ex:OpcionSoftwarePWM .

ex:Error2415
    ex:solucionaFallo      ex:CabezalMaster .

ex:Error2416
    ex:solucionaFallo      ex:ManualProgramacion .

ex:Error2417
    ex:solucionaFallo      ex:ManualProgramacion .