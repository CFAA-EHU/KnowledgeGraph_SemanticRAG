@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2429
    a ex:Alarma ;
    rdfs:label "Parámetro DMC fuera de rango" ;
    ex:identificador "2429" ;
    ex:textoExtracto "2429 Parámetro DMC fuera de rango [...] Algún comando de la sentencia #DMC tiene un valor no válido." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de sintaxis #DMC" ;
        ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."
    ] .

ex:Alarma_2430
    a ex:Alarma ;
    rdfs:label "#DMC ON: FZMIN debe ser menor que FZMAX" ;
    ex:identificador "2430" ;
    ex:textoExtracto "2430 #DMC ON: FZMIN debe ser menor que FZMAX. [...] En la función #DMC, el avance mínimo es mayor que el avance máximo." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Ajuste de parámetros FZMIN/FZMAX" ;
        ex:textoExtracto "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)."
    ] .

ex:Alarma_2431
    a ex:Alarma ;
    rdfs:label "#DMC ON: Error de configuración" ;
    ex:identificador "2431" ;
    ex:textoExtracto "2431 #DMC ON:" .

ex:Parametro_FZMIN
    a ex:Parametro ;
    rdfs:label "FZMIN (Avance mínimo en #DMC)" ;
    ex:textoExtracto "FZMIN debe ser menor que FZMAX" ;
    ex:monitoreaParametro ex:Alarma_2430 .

ex:Parametro_FZMAX
    a ex:Parametro ;
    rdfs:label "FZMAX (Avance máximo en #DMC)" ;
    ex:textoExtracto "FZMAX debe ser mayor que FZMIN" ;
    ex:monitoreaParametro ex:Alarma_2430 .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "Sistema de Control DMC" ;
    ex:textoExtracto "función #DMC" ;
    ex:tieneComponente ex:Parametro_FZMIN, ex:Parametro_FZMAX ;
    ex:activaAlarma ex:Alarma_2429, ex:Alarma_2430, ex:Alarma_2431 .