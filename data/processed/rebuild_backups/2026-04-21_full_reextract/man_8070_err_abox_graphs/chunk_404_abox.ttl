@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_2449
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 2449: Eje Hirth en transformación #PARALAX"@es ;
    ex:textoExtracto "No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. [...] SOLUCIÓN Los ejes programados no pueden ser Hirth."@es ;
    ex:identificador "2449" .

ex:AvisoSeguridad_2450
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 2450: Exclusión de ejes en transformación #PARALAX"@es ;
    ex:textoExtracto "#PARALAX: Los ejes de la transformación activa, no pueden excluirse. [...] CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una"@es ;
    ex:identificador "2450" .

ex:AccionProhibida_2449_Hirth
    a ex:AccionProhibida ;
    rdfs:label "Programación de ejes Hirth en #PARALAX"@es ;
    ex:textoExtracto "Los ejes programados no pueden ser Hirth."@es ;
    ex:activaAlarma ex:AvisoSeguridad_2449 .

ex:AccionProhibida_2450_ExclusionEjes
    a ex:AccionProhibida ;
    rdfs:label "Exclusión de ejes activos en transformación #PARALAX"@es ;
    ex:textoExtracto "Los ejes de la transformación activa, no pueden excluirse."@es ;
    ex:activaAlarma ex:AvisoSeguridad_2450 .