ex:Alarma_2469
    a ex:Alarma ;
    rdfs:label "Alarma 2469: Programación HEAD no permitida"@es ;
    ex:identificador "2469" ;
    ex:textoExtracto "2469 Programación HEAD no permitida en cinemáticas sin cabezal. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal. SOLUCIÓN Revisar la programación."@es .

