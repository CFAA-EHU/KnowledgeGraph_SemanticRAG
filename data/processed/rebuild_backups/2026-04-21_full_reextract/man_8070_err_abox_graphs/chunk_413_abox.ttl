@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2476
    a ex:DiagnosticoFallo ;
    rdfs:label "Tabla inexistente en el fichero de material activo" ;
    ex:identificador "2476" ;
    ex:textoExtracto "Tabla inexistente en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una tabla tecnológica que no existe en el fichero de material activo. SOLUCIÓN Revisar la programación y qué tablas existen." .

ex:Error_2477
    a ex:DiagnosticoFallo ;
    rdfs:label "Nombre de tabla no permitido" ;
    ex:identificador "2477" ;
    ex:textoExtracto "Nombre de tabla no permitido. DETECCIÓN Durante la ejecución. CAUSA La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting. SOLUCIÓN La sentencia #TECHTABLE permite activar una tabla tecnológica genérica. Esta sentencia no permite cargar las tablas de Piercing y Cutting, las cuales se gestionan con las sentencias #PIERCING y #CUTTING." .

ex:Error_2478
    a ex:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida sin tabla PIERCING en el fichero de material activo" ;
    ex:identificador "2478" ;
    ex:textoExtracto "Sentencia no permitida sin tabla PIERCING en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #PIERCING pero el fichero de material activo no tiene tabla de Piercing. SOLUCIÓN Cargar un fichero de material con tabla de Piercing." .

ex:Error_2479
    a ex:DiagnosticoFallo ;
    rdfs:label "Sentencia no permitida sin tabla CUTTING en el fichero de material activo" ;
    ex:identificador "2479" ;
    ex:textoExtracto "Sentencia no permitida sin tabla CUTTING en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #CUTTING pero el fichero de material activo no tiene tabla de Cutting. SOLUCIÓN Cargar un fichero de material con tabla de Cutting." .

ex:Error_2480
    a ex:DiagnosticoFallo ;
    rdfs:label "No se admite START para continuar perfil por datos no válidos" ;
    ex:identificador "2480" ;
    ex:textoExtracto "No se admite START para continuar perfil por datos no válidos. DETECCIÓN Al pulsar [START] después de seleccionar un modo de continuación parcial del mecanizado anterior; \"Punto de reinicio\", \"Restart PP\", \"PP interrumpido\" o \"BreakPP\". CAUSA Error en el fichero que guardan los datos para continuar. SOLUCIÓN Repetir el proceso (interrupción del programa y seleccionar tipo de continuación). Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error_2481
    a ex:DiagnosticoFallo ;
    rdfs:label "Valor de TIP no válido" ;
    ex:identificador "2481" ;
    ex:textoExtracto "Valor de TIP no válido. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #KINID con un valor de TIP no válido." .

ex:TablaPiercing a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de Piercing" ;
    ex:textoExtracto "tabla de Piercing" .

ex:TablaCutting a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de Cutting" ;
    ex:textoExtracto "tabla de Cutting" .

ex:TablaTecnologicaGenerica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla tecnológica genérica" ;
    ex:textoExtracto "tabla tecnológica genérica" .

ex:Sentencia_TECHTABLE
    a ex:Parametro ;
    rdfs:label "Sentencia #TECHTABLE" ;
    ex:textoExtracto "La sentencia #TECHTABLE permite activar una tabla tecnológica genérica" ;
    ex:monitoreaParametro ex:TablaTecnologicaGenerica .

ex:Sentencia_PIERCING
    a ex:Parametro ;
    rdfs:label "Sentencia #PIERCING" ;
    ex:textoExtracto "sentencia #PIERCING" ;
    ex:monitoreaParametro ex:TablaPiercing .

ex:Sentencia_CUTTING
    a ex:Parametro ;
    rdfs:label "Sentencia #CUTTING" ;
    ex:textoExtracto "sentencia #CUTTING" ;
    ex:monitoreaParametro ex:TablaCutting .

ex:Sentencia_KINID
    a ex:Parametro ;
    rdfs:label "Sentencia #KINID" ;
    ex:textoExtracto "sentencia #KINID con un valor de TIP" .

ex:FicheroMaterialActivo
    a ex:Sistema ;
    rdfs:label "Fichero de material activo" ;
    ex:textoExtracto "fichero de material activo" ;
    ex:tieneComponente ex:TablaPiercing , ex:TablaCutting , ex:TablaTecnologicaGenerica .

ex:Error_2476 ex:solucionaFallo ex:FicheroMaterialActivo .
ex:Error_2477 ex:solucionaFallo ex:Sentencia_TECHTABLE .
ex:Error_2478 ex:solucionaFallo ex:FicheroMaterialActivo .
ex:Error_2479 ex:solucionaFallo ex:FicheroMaterialActivo .