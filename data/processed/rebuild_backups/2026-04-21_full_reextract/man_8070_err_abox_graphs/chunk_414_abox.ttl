@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_2481
    a ex:DiagnosticoFallo ;
    rdfs:label "Valor de TIP no válido" ;
    ex:identificador "2481" ;
    ex:textoExtracto "2481 Valor de TIP no válido. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #KINID con un valor de TIP no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para TIP es 0/1." .

ex:Parametro_TIP
    a ex:Parametro ;
    rdfs:label "Parámetro TIP" ;
    ex:valor "0/1" ;
    ex:textoExtracto "El rango de valores admitido para TIP es 0/1." ;
    ex:monitoreaParametro ex:Error_2481 .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .