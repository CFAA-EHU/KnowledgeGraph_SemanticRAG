@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_2482
    a ex:Alarma ;
    rdfs:label "Alarma 2482: Número de origen no válido" ;
    ex:identificador "2482" ;
    ex:textoExtracto "2482 Número de origen no válido. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #KINORG con un origen no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para el origen es 1..99." .

ex:Alarma_2483
    a ex:Alarma ;
    rdfs:label "Alarma 2483: #KINORG no admite origen activo" ;
    ex:identificador "2483" ;
    ex:textoExtracto "2483 #KINORG: no se admite el origen activo. DETECCIÓN Durante la ejecución. CAUSA En la sentencia #KINORG no se permite programar el origen activo. SOLUCIÓN Revisar la programación. Programar un origen distinto del activo. El rango de valores admitido para el origen es 1..99." .

ex:Alarma_2484
    a ex:Alarma ;
    rdfs:label "Alarma 2484: Movimiento de eje rotativo no permitido con compensación de radio activa" ;
    ex:identificador "2484" ;
    ex:textoExtracto "2484 Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42). DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP] y la compensación de radio (G41/G42). SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo." .

ex:Alarma_2485
    a ex:Alarma ;
    rdfs:label "Alarma 2485: Programación conjunta de eje lineal y rotativo no permitida" ;
    ex:identificador "2485" ;
    ex:textoExtracto "2485 No se permite programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP]. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ex:Alarma_2486
    a ex:Alarma ;
    rdfs:label "Alarma 2486: Renombrado de cabezal en modo eje C no permitido" ;
    ex:identificador "2486" ;
    ex:textoExtracto "2486 No se admite #RENAME del cabezal en modo eje C. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C." .

ex:Alarma_2487
    a ex:Alarma ;
    rdfs:label "Alarma 2487: Activación de #FACE/#CYL con cinemática incompatible" ;
    ex:identificador "2487" ;
    ex:textoExtracto "2487 El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde." .

ex:Parametro_TIP
    a ex:Parametro ;
    rdfs:label "Parámetro TIP en #KINID" ;
    ex:textoExtracto "El rango de valores admitido para TIP es 0/1." ;
    ex:valor "0/1" .

ex:Parametro_ORIGEN_KINORG
    a ex:Parametro ;
    rdfs:label "Parámetro ORIGEN en #KINORG" ;
    ex:textoExtracto "El rango de valores admitido para el origen es 1..99." ;
    ex:valor "1..99" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde." ;
    ex:activaAlarma ex:Alarma_2482, ex:Alarma_2483, ex:Alarma_2484, ex:Alarma_2485, ex:Alarma_2486, ex:Alarma_2487 .