@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_2502
    a ex:AvisoSeguridad ;
    rdfs:label "Movimiento de eje rotativo no permitido (RTCP STATIC)" ;
    ex:identificador "2502" ;
    ex:textoExtracto "2502 Movimiento de eje rotativo no permitido, en inspección, con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA Durante la inspección de herramienta, se ha intentado mover un eje rotativo de la cinemática RTCP STATIC activo. SOLUCIÓN Desactivar la funcionalidad de RTCP STATIC para poder mover el eje rotativo." .

ex:AvisoSeguridad_2501
    a ex:AvisoSeguridad ;
    rdfs:label "Conflicto de movimiento eje lineal/rotativo (RTCP STATIC)" ;
    ex:identificador "2501" ;
    ex:textoExtracto "Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente." .

ex:AvisoSeguridad_2503
    a ex:AvisoSeguridad ;
    rdfs:label "Error de programación de radio en G36/37/38/39" ;
    ex:identificador "2503" ;
    ex:textoExtracto "2503 G36/37/38/39: El radio se programa con I. DETECCIÓN Durante la ejecución. CAUSA Se ha programado incorrectamente el radio del redondeo (G36), chaflán (G39) o entrada/salida tangencial (G37/G38). SOLUCIÓN Revisar la programación. Programar el radio o chaflán con el comando \"I\"." .

ex:AvisoSeguridad_2504
    a ex:AvisoSeguridad ;
    rdfs:label "Falta segundo punto (XYZ) en G107" ;
    ex:identificador "2504" ;
    ex:textoExtracto "2504 G107: Falta programar el segundo punto (XYZ). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2505
    a ex:AvisoSeguridad ;
    rdfs:label "Falta primer punto (IJK) en G107" ;
    ex:identificador "2505" ;
    ex:textoExtracto "2505 G107: Falta programar el primer punto (IJK). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2506
    a ex:AvisoSeguridad ;
    rdfs:label "Incompatibilidad G107 con G106/#SPLINE ON" ;
    ex:identificador "2506" ;
    ex:textoExtracto "2506 G107 incompatible con G106 y #SPLINE ON. DETECCIÓN Durante la ejecución. CAUSA No es posible programar splines con G107 activa. Tampoco es posible programar G107 sin desactivar previamente G106 mediante una G0, G1. SOLUCIÓN Revisar la programación." .

ex:AvisoSeguridad_2507
    a ex:AvisoSeguridad ;
    rdfs:label "Coordenadas no permitidas en G107" ;
    ex:identificador "2507" ;
    ex:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución." .

ex:ModoOperacion_RTCP_STATIC
    a ex:ModoOperacion ;
    rdfs:label "RTCP STATIC" ;
    ex:textoExtracto "RTCP STATIC activo" ;
    ex:activaAlarma ex:AvisoSeguridad_2501, ex:AvisoSeguridad_2502 .

ex:Parametro_G107
    a ex:Parametro ;
    rdfs:label "G107" ;
    ex:identificador "G107" ;
    ex:textoExtracto "G107: Falta programar el segundo punto (XYZ)... G107: Falta programar el primer punto (IJK)... G107 incompatible con G106 y #SPLINE ON" ;
    ex:activaAlarma ex:AvisoSeguridad_2504, ex:AvisoSeguridad_2505, ex:AvisoSeguridad_2506, ex:AvisoSeguridad_2507 .

ex:Parametro_G106
    a ex:Parametro ;
    rdfs:label "G106" ;
    ex:identificador "G106" ;
    ex:textoExtracto "G107 incompatible con G106" .

ex:Parametro_SPLINE_ON
    a ex:Parametro ;
    rdfs:label "#SPLINE ON" ;
    ex:identificador "#SPLINE ON" ;
    ex:textoExtracto "G107 incompatible con ... #SPLINE ON" .