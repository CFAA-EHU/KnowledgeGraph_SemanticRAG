@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error2515_G0_OrbitActivo
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2515: #ORBIT ON con movimiento G0"@es ;
    ex:textoExtracto "CAUSA Se ha programado un movimiento en G0 con #ORBIT activo. SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT."@es ;
    ex:identificador "2515" ;
    ex:mitigaRiesgo ex:AccionProhibida_G0_Con_Orbit .

ex:Error2515_EjePerpendicular_OrbitActivo
    a ex:AvisoSeguridad ;
    rdfs:label "Error 2515: Movimiento en eje perpendicular con #ORBIT activo"@es ;
    ex:textoExtracto "2515 #ORBIT ON: movimiento del eje perpendicular al plano no permitido. DETECCIÓN Durante la edición o preparación de bloques. CAUSA Se ha programado un movimiento en el eje perpendicular al plano de trabajo con #ORBIT activo. SOLUCIÓN Eliminar el movimiento en el eje perpendicular o desactivar #ORBIT."@es ;
    ex:identificador "2515" ;
    ex:mitigaRiesgo ex:AccionProhibida_EjePerpendicular_Con_Orbit .

ex:AccionProhibida_G0_Con_Orbit
    a ex:AccionProhibida ;
    rdfs:label "Movimiento en G0 con #ORBIT activo"@es ;
    ex:textoExtracto "movimiento en G0 con #ORBIT activo"@es .

ex:AccionProhibida_EjePerpendicular_Con_Orbit
    a ex:AccionProhibida ;
    rdfs:label "Movimiento en eje perpendicular al plano con #ORBIT activo"@es ;
    ex:textoExtracto "movimiento en el eje perpendicular al plano de trabajo con #ORBIT activo"@es .