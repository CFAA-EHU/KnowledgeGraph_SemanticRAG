@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3007
    a ex:Alarma ;
    rdfs:label "Alarma 3007: Señal de palpador prematura" ;
    ex:textoExtracto "'Se ha recibido señal del palpador antes del movimiento' DETECCIÓN Tras detectar la señal de palpador. CAUSA Proceso de palpado habilitado sin G100 programada. SOLUCIÓN Póngase en contacto con su proveedor." ;
    ex:identificador "3007" .

ex:Alarma_3008
    a ex:Alarma ;
    rdfs:label "Alarma 3008: Error en proceso de palpador" ;
    ex:textoExtracto "'Error en el proceso de palpador' DETECCIÓN Tras detectar la señal de palpador. CAUSA Es una seguridad de habilitación del proceso de palpado. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados." ;
    ex:identificador "3008" .

ex:Alarma_3009
    a ex:Alarma ;
    rdfs:label "Alarma 3009: Falta señal de palpador" ;
    ex:textoExtracto "3009 No se ha recibido señal del palpador. DETECCIÓN Durante la ejecución. CAUSA No ha llegado la señal del palpador tras un movimiento de palpado. SOLUCIÓN Revisar la parametrización del palpador y señales físicas." ;
    ex:identificador "3009" .

ex:Alarma_3010
    a ex:Alarma ;
    rdfs:label "Alarma 3010: Eje no definido como palpador" ;
    ex:textoExtracto "'El eje no se ha definido como palpador (PROBEAXIS)' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de palpado en un eje que no está definido como eje participante en un movimiento con palpador. SOLUCIÓN El parámetro PROBEAXIS establece si el eje puede participar en movimientos con palpador." ;
    ex:identificador "3010" .

ex:Alarma_3011
    a ex:Alarma ;
    rdfs:label "Alarma 3011: Exceso de ejes programados como palpador" ;
    ex:textoExtracto "'Demasiados ejes programados como palpador' DETECCIÓN Durante la ejecución. CAUSA El número de ejes programados en el movimiento de palpación supera el máximo de ejes del canal. SOLUCIÓN Corregir la programación del bloque de palpado." ;
    ex:identificador "3011" .

ex:Alarma_3013
    a ex:Alarma ;
    rdfs:label "Alarma 3013: Distancia de frenado excesiva" ;
    ex:textoExtracto "'Distancia de frenado mayor que el parámetro PROBERANGE' DETECCIÓN Durante la ejecución. CAUSA La distancia necesaria para frenar con el avance activo es mayor que la distancia máxima admisible (parámetro PROBERANGE), probablemente debido al error de seguimiento. SOLUCIÓN Disminuir el avance de palpado o disminuir el error de seguimiento." ;
    ex:identificador "3013" .

ex:Alarma_3015
    a ex:Alarma ;
    rdfs:label "Alarma 3015: Búsqueda de referencia omitida" ;
    ex:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida' DETECCIÓN Durante la ejecución." ;
    ex:identificador "3015" .

ex:Parametro_PROBEAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro PROBEAXIS" ;
    ex:textoExtracto "El parámetro PROBEAXIS establece si el eje puede participar en movimientos con palpador." ;
    ex:identificador "PROBEAXIS" .

ex:Parametro_PROBERANGE
    a ex:Parametro ;
    rdfs:label "Parámetro PROBERANGE" ;
    ex:textoExtracto "parámetro PROBERANGE [...] distancia máxima admisible" ;
    ex:identificador "PROBERANGE" .

ex:DiagnosticoFallo_3007
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3007" ;
    ex:textoExtracto "Proceso de palpado habilitado sin G100 programada." ;
    ex:solucionaFallo ex:Alarma_3007 .

ex:DiagnosticoFallo_3009
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3009" ;
    ex:textoExtracto "Revisar la parametrización del palpador y señales físicas." ;
    ex:solucionaFallo ex:Alarma_3009 .

ex:DiagnosticoFallo_3013
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3013" ;
    ex:textoExtracto "Disminuir el avance de palpado o disminuir el error de seguimiento." ;
    ex:solucionaFallo ex:Alarma_3013 .