@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3062
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "El cabezal master de la sincronización pasa a lazo abierto"@es ;
    ex:identificador    "3062" ;
    ex:textoExtracto    "3062 'El cabezal master de la sincronización pasa a lazo abierto' DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una sincronización en lazo abierto (OLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo cerrado."@es .

ex:Fallo_SincronizacionSinReferencia
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Fallo de sincronización por cabezal master no referenciado"@es ;
    ex:textoExtracto    "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede sincronizar en lazo cerrado un cabezal master, si éste no ha sido previamente referenciado. SOLUCIÓN Realizar una búsqueda de referencia del cabezal master antes de sincronizar los cabezales."@es .

ex:SistemaCNC
    a                   ex:Sistema ;
    rdfs:label          "Sistema CNC de control de cabezales"@es ;
    ex:textoExtracto    "El CNC no puede sincronizar en lazo cerrado un cabezal master"@es ;
    ex:activaAlarma      ex:Fallo_3062 , ex:Fallo_SincronizacionSinReferencia .

ex:CabezalMaster
    a                   ex:ComponenteMecanico ;
    rdfs:label          "Cabezal master de sincronización"@es ;
    ex:textoExtracto    "cabezal master de la sincronización"@es , "sincronizar en lazo cerrado un cabezal master"@es ;
    ex:monitoreaParametro  [
        a                   ex:Parametro ;
        rdfs:label          "Modo de sincronización (lazo abierto/cerrado)"@es ;
        ex:valor            "OLOOP (lazo abierto)"@es , "lazo cerrado"@es ;
        ex:textoExtracto    "sincronización en lazo abierto (OLOOP)"@es , "trabajando en lazo cerrado"@es
    ] .