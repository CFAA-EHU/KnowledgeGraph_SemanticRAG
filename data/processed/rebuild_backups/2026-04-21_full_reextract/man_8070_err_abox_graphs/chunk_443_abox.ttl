@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_3063
    a ex:DiagnosticoFallo ;
    rdfs:label "Cambio a lazo cerrado en sincronización"@es ;
    ex:identificador "3063" ;
    ex:textoExtracto "El cabezal master de la sincronización pasa a lazo cerrado. DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una sincronización en lazo cerrado (CLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo abierto. SOLUCIÓN El CNC informa del cambio; no es necesaria ninguna acción."@es .

ex:DiagnosticoFallo_3064
    a ex:DiagnosticoFallo ;
    rdfs:label "Cabezal no referenciado para roscado G33/G34"@es ;
    ex:identificador "3064" ;
    ex:textoExtracto "El cabezal para roscar con G33/G34 debe de estar referenciado. DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado en el roscado G33/G34 no está referenciado. SOLUCIÓN Si el CNC utiliza el cabezal master del canal, siempre realiza una búsqueda de referencia antes de G33/G34. Si el PLC selecciona otro cabezal (marca SYNC), realizar una búsqueda de referencia del cabezal."@es .

ex:DiagnosticoFallo_3065
    a ex:DiagnosticoFallo ;
    rdfs:label "Velocidad de giro supera umbral del encóder en G33/G34"@es ;
    ex:identificador "3065" ;
    ex:textoExtracto "Velocidad de giro de cabezal programada para G33/G34 supera el umbral del encóder. DETECCIÓN Durante la ejecución. CAUSA La velocidad programada para la función G33/G34 superó el umbral permitido por el encóder instalado en el cabezal. SOLUCIÓN El CNC no permite ejecutar la G33/G34 con la velocidad programada, ya que no puede garantizar la validez de la rosca. Si el cabezal ha superado la velocidad umbral, el CNC necesita referenciar el cabezal para recuperar la cota."@es .

ex:DiagnosticoFallo_3066
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en seguimiento del eje tangencial"@es ;
    ex:identificador "3066" ;
    ex:textoExtracto "Error en el seguimiento del eje tangencial sobre la trayectoria. DETECCIÓN Durante la ejecución. CAUSA El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo. SOLUCIÓN Póngase en contacto con FAGOR."@es .

ex:ComponenteMecanico_CabezalMaster
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal master de sincronización"@es ;
    ex:textoExtracto "El cabezal master de la sincronización pasa a lazo cerrado"@es .

ex:ComponenteMecanico_CabezalRoscado
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal para roscado G33/G34"@es ;
    ex:textoExtracto "El cabezal utilizado en el roscado G33/G34 no está referenciado"@es .

ex:Sensor_EncoderCabezal
    a ex:Sensor ;
    rdfs:label "Encóder del cabezal"@es ;
    ex:textoExtracto "umbral permitido por el encóder instalado en el cabezal"@es .

ex:ComponenteMecanico_EjeTangencial
    a ex:ComponenteMecanico ;
    rdfs:label "Eje tangencial"@es ;
    ex:textoExtracto "El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo"@es .

ex:DiagnosticoFallo_3063
    ex:solucionaFallo ex:ComponenteMecanico_CabezalMaster .

ex:DiagnosticoFallo_3064
    ex:solucionaFallo ex:ComponenteMecanico_CabezalRoscado .

ex:DiagnosticoFallo_3065
    ex:solucionaFallo ex:ComponenteMecanico_CabezalRoscado ;
    ex:monitoreaParametro ex:Sensor_EncoderCabezal .

ex:DiagnosticoFallo_3066
    ex:solucionaFallo ex:ComponenteMecanico_EjeTangencial .