@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3082
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "No es posible tanta anticipación para activar la salida digital"@es ;
    ex:identificador      "3082" ;
    ex:textoExtracto      "3082 'No es posible tanta anticipación para activar la salida digital' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA El retardo calculado para el láser es negativo; es decir, no queda margen suficiente de ciclos para la anticipación. SOLUCIÓN Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación."@es .

ex:Fallo_3083
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "No es posible tanto retardo para..."@es ;
    ex:identificador      "3083" ;
    ex:textoExtracto      "3083 'No es posible tanto retardo para"@es .

ex:Parametro_VelocidadCorte
    a                     ex:Parametro ;
    rdfs:label            "Velocidad de corte"@es ;
    ex:textoExtracto      "CAUSA La velocidad de corte es demasiado alta para el tamaño de la rejilla."@es .

ex:Parametro_TiempoCiclo
    a                     ex:Parametro ;
    rdfs:label            "Tiempo de ciclo"@es ;
    ex:textoExtracto      "SOLUCIÓN Disminuir la velocidad o el tiempo de ciclo."@es .

ex:Parametro_AnticipacionLaser
    a                     ex:Parametro ;
    rdfs:label            "Parámetros de anticipación del láser"@es ;
    ex:textoExtracto      "SOLUCIÓN Disminuir [...] el valor de los parámetros de anticipación."@es .

ex:Parametro_RetardoLaser
    a                     ex:Parametro ;
    rdfs:label            "Retardo calculado para el láser"@es ;
    ex:textoExtracto      "CAUSA El retardo calculado para el láser es negativo; es decir, no queda margen suficiente de ciclos para la anticipación."@es .

ex:Fallo_3082
    ex:solucionaFallo      ex:Parametro_TiempoCiclo , ex:Parametro_AnticipacionLaser .

ex:Fallo_3083
    ex:solucionaFallo      ex:Parametro_TiempoCiclo .