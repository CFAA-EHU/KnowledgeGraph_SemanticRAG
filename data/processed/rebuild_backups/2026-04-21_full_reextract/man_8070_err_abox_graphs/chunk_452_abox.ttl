@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PlacaExpansion_Sercos_3089
    a               ex:ComponenteElectrico ;
    rdfs:label      "Placa de expansión tipo Sercos"@es ;
    ex:identificador "ID software >= 1.2" ;
    ex:textoExtracto "Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2."@es .

ex:Parametro_NLOCOUT_3089
    a               ex:Parametro ;
    rdfs:label      "NLOCOUT" ;
    ex:valor        "8" ;
    ex:textoExtracto "El parámetro NLOCOUT debe ser 8."@es .

ex:Parametro_PWMOUTPUT_3089
    a               ex:Parametro ;
    rdfs:label      "PWMOUTPUT" ;
    ex:valor        "0, 1, 2" ;
    ex:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)."@es .

ex:Error_VIRTAX_3089
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error en el cálculo de la transformada inversa del eje virtual de la herramienta (#VIRTAX)"@es ;
    ex:identificador "3089" ;
    ex:textoExtracto "Error en el cálculo de la transformada inversa del eje virtual de la herramienta, #VIRTAX"@es .