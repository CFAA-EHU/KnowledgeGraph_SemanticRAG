@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NLOCOUT
    a ex:Parametro ;
    rdfs:label "Parámetro NLOCOUT" ;
    ex:textoExtracto "parámetro NLOCOUT debe ser 8." ;
    ex:valor "8" .

ex:Parametro_PWMOUTPUT
    a ex:Parametro ;
    rdfs:label "Parámetro PWMOUTPUT" ;
    ex:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)." ;
    ex:valor "0, 1, 2" .

ex:Sensor_GAPCTRL
    a ex:Sensor ;
    rdfs:label "Sensor de aproximación (#GAPCTRL)" ;
    ex:textoExtracto "Durante el bloque de aproximación a la distancia (GAP) programada en la sentencia #GAPCTRL, el CNC no ha recibido la señal del sensor." .

ex:AvisoSeguridad_3091
    a ex:AvisoSeguridad ;
    rdfs:label "Error 3091: No se ha detectado señal del sensor" ;
    ex:textoExtracto "3091 No se ha detectado señal del sensor. [...] SOLUCIÓN El punto final del movimiento de aproximación indicado en la sentencia #GAPCTRL debe estar a una distancia detectable por el sensor. Comprobar también que la sonda está bien conectada." ;
    ex:mitigaRiesgo ex:Sensor_GAPCTRL .

ex:DiagnosticoFallo_3089
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3089: Transformada inversa del eje virtual (#VIRTAX)" ;
    ex:identificador "3089" ;
    ex:textoExtracto "3089 'Error en el cálculo de la transformada inversa del eje virtual de la herramienta, #VIRTAX' [...] CAUSA La transformación de coordenadas pieza a máquina es imposible de ejecutar." .

ex:DiagnosticoFallo_3090
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3090: Transformada directa del eje virtual (#VIRTAX)" ;
    ex:identificador "3090" ;
    ex:textoExtracto "3090 'Error en el cálculo de la transformada directa del eje virtual de la herramienta, #VIRTAX' [...] CAUSA La transformación de coordenadas máquina a pieza es imposible de ejecutar." .

ex:DiagnosticoFallo_3092
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3092: Límite de zona de trabajo sobrepasado" ;
    ex:identificador "3092" ;
    ex:textoExtracto "3092 'Límite de zona de trabajo sobrepasado' [...] CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra fuera de una zona de trabajo de no salida." .

ex:DiagnosticoFallo_3093
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 3093: Punto dentro de zona prohibida" ;
    ex:identificador "3093" ;
    ex:textoExtracto "3093 'Punto dentro de zona prohibida' [...] CAUSA El CNC ha intentado desplazar un eje a una cota que se encuentra dentro de una zona de trabajo de no entrada." .