@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3099
    a               ex:DiagnosticoFallo ;
    rdfs:label      "LEAP no activado por altura de salto inferior a un mínimo"@es ;
    ex:identificador "3099" ;
    ex:textoExtracto "LEAP no activado por altura de salto inferior a un mínimo. DETECCIÓN Durante la ejecución. CAUSA La altura máxima del salto es muy cercana a la posición inicial. SOLUCIÓN Revisar la programación."@es .

ex:Fallo_3100
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Potencia excesiva en el cabezal detectada durante DMC"@es ;
    ex:identificador "3100" ;
    ex:textoExtracto "'Potencia excesiva en el cabezal detectada durante DMC' DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo. Esto puede indicar que la herramienta está gastada, deteriorada o que ha colisionado con la pieza."@es .

ex:Parametro_TV51
    a               ex:Parametro ;
    rdfs:label      "TV51 (variable del regulador)"@es ;
    ex:textoExtracto "variable TV51 del regulador"@es ;
    ex:monitoreaParametro ex:Fallo_3100 .

ex:Sistema_DMC
    a               ex:Sistema ;
    rdfs:label      "DMC (sistema de control)"@es ;
    ex:textoExtracto "El DMC ha detectado un consumo de potencia"@es ;
    ex:controla     ex:Parametro_TV51 ;
    ex:activaAlarma ex:Fallo_3100 .