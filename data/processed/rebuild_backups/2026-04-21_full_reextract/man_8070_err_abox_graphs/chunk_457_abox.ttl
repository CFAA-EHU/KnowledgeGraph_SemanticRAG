@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3101
    a ex:Alarma ;
    rdfs:label "Potencia excesiva en el cabezal detectada durante DMC"@es ;
    ex:identificador "3101" ;
    ex:textoExtracto "3101 'Potencia excesiva en el cabezal detectada durante DMC.Pulse MARCHA para continuar' DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado. Esto puede indicar que la herramienta ha colisionado con la pieza, por lo que el CNC detiene los ejes manteniendo el giro del cabezal."@es ;
    ex:monitoreaParametro ex:Parametro_TV51 .

ex:Alarma_3102
    a ex:Alarma ;
    rdfs:label "Sentencia no compatible con movimiento independiente activo"@es ;
    ex:identificador "3102" ;
    ex:textoExtracto "3102 Sentencia no compatible con movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado ejecutar la sentencia #HSC o #SWT en un eje con movimiento independiente."@es .

ex:Alarma_3103
    a ex:Alarma ;
    rdfs:label "Potencia objetivo insuficiente para el funcionamiento correcto con DMC"@es ;
    ex:identificador "3103" ;
    ex:textoExtracto "3103 Potencia objetivo insuficiente para el funcionamiento correcto con DMC. DETECCIÓN Durante la ejecución. CAUSA Los valores de la potencia en vacío y la potencia objetivo durante el mecanizado son similares. Es posible que el DMC no pueda distinguir con exactitud las entradas y salidas de la pieza."@es ;
    ex:monitoreaParametro ex:Parametro_TV51 .

ex:Alarma_3104
    a ex:Alarma ;
    rdfs:label "Colisión detectada"@es ;
    ex:identificador "3104" ;
    ex:textoExtracto "3104 Se ha detectado una colisión."@es .

ex:Parametro_TV51
    a ex:Parametro ;
    rdfs:label "Variable TV51 del regulador (potencia instantánea)"@es ;
    ex:identificador "TV51" ;
    ex:textoExtracto "un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo. [...] la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado."@es .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "Dynamic Machining Control (DMC)"@es ;
    ex:textoExtracto "El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado. [...] La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío. En este caso se recomienda desactivar la función DMC en este mecanizado."@es ;
    ex:monitoreaParametro ex:Parametro_TV51 ;
    ex:activaAlarma ex:Alarma_3101, ex:Alarma_3103, ex:Alarma_3104 .

ex:Componente_Herramienta
    a ex:ComponenteMecanico ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ex:textoExtracto "Esto puede indicar que la herramienta está gastada, deteriorada o que ha colisionado con la pieza. [...] Comprobar el estado de la herramienta y del mecanizado."@es .