@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3403
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "3403" ;
    rdfs:label            "No se admiten más operaciones con ejes independientes. En sincronización"@es ;
    ex:textoExtracto      "3403 'No se admiten mas operaciones con ejes independientes. En sincronización'"@es ;
    ex:textoExtracto      "DETECCIÓN: Durante la ejecución. CAUSA: El CNC intenta ejecutar una operación de eje"@es .

ex:Marca_ABORT
    a                     ex:Parametro ;
    ex:identificador      "ABORT" ;
    rdfs:label            "Marca ABORT (abortar sentencias pendientes)"@es ;
    ex:textoExtracto      "abortar las sentencias pendientes (marca ABORT)"@es ;
    ex:mitigaRiesgo        ex:Fallo_3403 .

ex:Marca_FREE
    a                     ex:Parametro ;
    ex:identificador      "FREE" ;
    rdfs:label            "Marca FREE (espacio disponible para almacenar operaciones)"@es ;
    ex:textoExtracto      "esperar a que haya espacio para almacenarla (marca FREE)"@es ;
    ex:mitigaRiesgo        ex:Fallo_3403 .

ex:Marca_BUSY
    a                     ex:Parametro ;
    ex:identificador      "BUSY" ;
    rdfs:label            "Marca BUSY (estado de interpolador independiente)"@es ;
    ex:textoExtracto      "consultar la marca BUSY [para saber si el interpolador independiente ha terminado todas las operaciones]"@es ;
    ex:monitoreaParametro ex:Fallo_3403 .