@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_3408
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Cota programada para eje independiente inferior al límite negativo"@es ;
    ex:identificador      "3408" ;
    ex:textoExtracto      "3408 'Cota programada para eje independiente inferior al límite negativo' [...] La cota programada en la sentencia #MOVE está fuera de los límites de software."@es .

ex:Aviso_SoftwareEjes
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Límites de software de ejes"@es ;
    ex:textoExtracto      "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es ;
    ex:mitigaRiesgo        ex:Fallo_3408 .

ex:Parametro_LimiteSoftwareEje
    a                     ex:Parametro ;
    rdfs:label            "Límite de software para ejes"@es ;
    ex:textoExtracto      "límites de software"@es ;
    ex:monitoreaParametro ex:Aviso_SoftwareEjes .