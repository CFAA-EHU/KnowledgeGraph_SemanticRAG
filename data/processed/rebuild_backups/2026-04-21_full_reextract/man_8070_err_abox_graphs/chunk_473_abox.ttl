ex:ModoOperacion_M19
    a ex:ModoOperacion ;
    rdfs:label "M19" ;
    ex:textoExtracto "en M19, la sentencia #SERVO OFF no puede abrir el lazo; para abrir el lazo, programar M3, M4, M5 o hacer un reset"@es ;
    ex:identificador "M19" .

