@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3702
    a               ex:Alarma ;
    rdfs:label      "Error de seguimiento del eje fuera de límite"@es ;
    ex:identificador "3702" ;
    ex:textoExtracto "3702 'Error de seguimiento del eje fuera de límite' DETECCIÓN Durante la ejecución. CAUSA El eje ha superado el error de seguimiento permitido, definido en los parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY). Puede ser debido a un ajuste inadecuado del eje, a que falta habilitar el eje, a algún fallo en el motor, en el regulador, en el sistema de captación y/o en la mecánica."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_3702 .

ex:Alarma_3703
    a               ex:Alarma ;
    rdfs:label      "Límite de software positivo sobrepasado"@es ;
    ex:identificador "3703" ;
    ex:textoExtracto "3703 'Límite de software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_3703 .

ex:DiagnosticoFallo_3702
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Revisión de parámetros y componentes para error de seguimiento del eje 3702"@es ;
    ex:textoExtracto "Revisar los parámetros máquina, el ajuste del eje, el conexionado, el estado del regulador y el sistema captación-motor."@es ;
    ex:solucionaFallo ex:ComponenteMecanico_Eje ,
                     ex:ComponenteElectrico_Motor ,
                     ex:ComponenteElectrico_Regulador ,
                     ex:ComponenteElectrico_SistemaCaptacion .

ex:DiagnosticoFallo_3703
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Revisión de parámetros para límite de software positivo 3703"@es ;
    ex:textoExtracto "Revisar"@es ;
    ex:solucionaFallo ex:Parametro_LIMIT ,
                     ex:Parametro_VARTPOSLIMIT .

ex:ComponenteMecanico_Eje
    a               ex:ComponenteMecanico ;
    rdfs:label      "Eje"@es ;
    ex:textoExtracto "el ajuste del eje"@es .

ex:ComponenteElectrico_Motor
    a               ex:ComponenteElectrico ;
    rdfs:label      "Motor"@es ;
    ex:textoExtracto "fallo en el motor"@es .

ex:ComponenteElectrico_Regulador
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador"@es ;
    ex:textoExtracto "el estado del regulador"@es .

ex:ComponenteElectrico_SistemaCaptacion
    a               ex:ComponenteElectrico ;
    rdfs:label      "Sistema de captación"@es ;
    ex:textoExtracto "sistema de captación"@es .

ex:Parametro_MAXFLWE
    a               ex:Parametro ;
    rdfs:label      "MAXFLWE" ;
    ex:identificador "MAXFLWE" ;
    ex:textoExtracto "parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)"@es .

ex:Parametro_MINFLWE
    a               ex:Parametro ;
    rdfs:label      "MINFLWE" ;
    ex:identificador "MINFLWE" ;
    ex:textoExtracto "parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)"@es .

ex:Parametro_FEDYNFAC
    a               ex:Parametro ;
    rdfs:label      "FEDYNFAC" ;
    ex:identificador "FEDYNFAC" ;
    ex:textoExtracto "parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)"@es .

ex:Parametro_ESTDELAY
    a               ex:Parametro ;
    rdfs:label      "ESTDELAY" ;
    ex:identificador "ESTDELAY" ;
    ex:textoExtracto "parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)"@es .

ex:Parametro_LIMIT
    a               ex:Parametro ;
    rdfs:label      "LIMIT+" ;
    ex:identificador "LIMIT+" ;
    ex:textoExtracto "cota definida por el parámetro máquina LIMIT+"@es .

ex:Parametro_VARTPOSLIMIT
    a               ex:Parametro ;
    rdfs:label      "V.A.RTPOSLIMIT.xn" ;
    ex:identificador "V.A.RTPOSLIMIT.xn" ;
    ex:textoExtracto "variable V.A.RTPOSLIMIT.xn"@es .