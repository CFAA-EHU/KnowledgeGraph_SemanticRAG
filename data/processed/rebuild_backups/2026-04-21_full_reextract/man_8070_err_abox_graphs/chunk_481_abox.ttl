@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3719
    a ex:Alarma ;
    rdfs:label "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo" ;
    ex:identificador "3719" ;
    ex:textoExtracto "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática activa, de un eje angular activo, del control tangencial activo o de una transformación de coordenadas #CS o #ACS. SOLUCIÓN: El PLC no puede aparcar el eje en esa situación. Pulsar reset para detener el movimiento o desactivar la cinemática activa, el eje angular activo, el control tangencial activo o la transformación de coordenadas #CS o #ACS." .

ex:Alarma_3720
    a ex:Alarma ;
    rdfs:label "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC" ;
    ex:identificador "3720" ;
    ex:textoExtracto "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa. SOLUCIÓN: El PLC no puede aparcar el cabezal en esa situación. Pulsar reset para detener el movimiento, la sincronización, desactivar el eje C o desactivar las funciones G33, G34, G63, G95 o G96." .

ex:Alarma_3721
    a ex:Alarma ;
    rdfs:label "Palpador no disponible. Ocupado por otro proceso" ;
    ex:identificador "3721" ;
    ex:textoExtracto "Palpador no disponible. Ocupado por otro proceso. DETECCIÓN: Durante la ejecución. CAUSA: El CNC ha intentado ejecutar una palpación pero el palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE). SOLUCIÓN: Esperar a que finalice una palpación antes de ejecutar la siguiente." .

ex:Alarma_3722
    a ex:Alarma ;
    rdfs:label "Error en la inicialización del palpador" ;
    ex:identificador "3722" ;
    ex:textoExtracto "Error en la inicialización del palpador. DETECCIÓN: Durante la ejecución. CAUSA: Los parámetros del palpador no son coherentes. SOLUCIÓN: Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ex:Alarma_3723
    a ex:Alarma ;
    rdfs:label "Error en los límites de la ventana de palpado desde PLC" ;
    ex:identificador "3723" ;
    ex:textoExtracto "Error en los límites de la ventana de palpado desde PLC. DETECCIÓN: Durante la ejecución. CAUSA: En el palpado desde PLC están mal definidos los límites de la ventana de palpado (límite inferior > límite superior)." .

ex:Sensor_Palpador
    a ex:Sensor ;
    rdfs:label "Palpador" ;
    ex:textoExtracto "El CNC ha intentado ejecutar una palpación pero el palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE)." ;
    ex:monitoreaParametro ex:Parametro_PROBETYPE, ex:Parametro_PRBDI, ex:Parametro_PRBPULSE .

ex:Parametro_PROBETYPE
    a ex:Parametro ;
    rdfs:label "PROBETYPE" ;
    ex:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ex:Parametro_PRBDI
    a ex:Parametro ;
    rdfs:label "PRBDI" ;
    ex:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ex:Parametro_PRBPULSE
    a ex:Parametro ;
    rdfs:label "PRBPULSE" ;
    ex:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .