@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3728
    a ex:Alarma ;
    rdfs:label "Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido" ;
    ex:identificador "3728" ;
    ex:textoExtracto "3728 'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido' DETECCIÓN Al desactivar la marca SWITCH del eje. CAUSA El CNC ha intentado desactivar un eje de un grupo múltiple, antes de que termine un comando Sercos de aparcar, desaparcar o cambio de gama o set." .

ex:Alarma_3729
    a ex:Alarma ;
    rdfs:label "No se permite más de un eje del grupo múltiple activo" ;
    ex:identificador "3729" ;
    ex:textoExtracto "3729 'No se permite más de un eje del grupo múltiple activo' DETECCIÓN Al activar la marca SWITCH del eje. CAUSA El CNC ha intentado activar un eje de un grupo múltiple, antes de desactivar el eje anterior." .

ex:Alarma_3730
    a ex:Alarma ;
    rdfs:label "TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo" ;
    ex:identificador "3730" ;
    ex:textoExtracto "3730 'TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo' DETECCIÓN Al ejecutar el PLC un comando TOUCHPROBE. CAUSA El PLC ha intentado activar un palpado, pero el palpador está siendo utilizado por un comando TOUCHPROBE previo y ambos comandos utilizan flancos diferentes." .

ex:Alarma_3731
    a ex:Alarma ;
    rdfs:label "G174: Desplazamiento no válido, valor demasiado grande" ;
    ex:identificador "3731" ;
    ex:textoExtracto "3731 'G174: Desplazamiento no válido, valor demasiado grande' DETECCIÓN Al ejecutar G174 CAUSA Al calcular el desplazamiento programado en unidades del regulador, se obtiene un valor fuera del rango admitido por el regulador." .

ex:Alarma_3732
    a ex:Alarma ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ex:identificador "3732" ;
    ex:textoExtracto "3732 Error en el refresco de contajes locales. DETECCIÓN En la lectura de los contajes analógicos locales desde el lazo de posición. CAUSA Alarma en alguna de las entradas de captación locales." .

ex:Sensor_ContajesLocales
    a ex:Sensor ;
    rdfs:label "Entradas de captación locales" ;
    ex:textoExtracto "Alarma en alguna de las entradas de captación locales." ;
    ex:monitoreaParametro ex:Parametro_ContajesAnalogicos .

ex:Parametro_ContajesAnalogicos
    a ex:Parametro ;
    rdfs:label "Contajes analógicos locales" ;
    ex:textoExtracto "lectura de los contajes analógicos locales desde el lazo de posición" .

ex:ComponenteElectrico_SWITCH
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SWITCH del eje" ;
    ex:textoExtracto "Al desactivar la marca SWITCH del eje" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC ha intentado desactivar un eje de un grupo múltiple" ;
    ex:activaAlarma ex:Alarma_3728, ex:Alarma_3729, ex:Alarma_3731 .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "En la maniobra del PLC, condicionar la desactivación del eje" ;
    ex:activaAlarma ex:Alarma_3730 .