@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3743
    a               ex:Alarma ;
    rdfs:label      "Colisión de palpador"@es ;
    ex:identificador "3743" ;
    ex:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba."@es ;
    ex:activaAlarma ex:Sensor_SondaPalpado .

ex:Alarma_3744
    a               ex:Alarma ;
    rdfs:label      "#GAPCTRL: No hay señal de la sonda"@es ;
    ex:identificador "3744" ;
    ex:textoExtracto "3744 #GAPCTRL: No hay señal de la sonda. DETECCIÓN Durante la ejecución. CAUSA No hay señal del sensor, a partir de la cual el CNC calcula la distancia."@es ;
    ex:activaAlarma ex:Sensor_SondaPalpado .

ex:Sensor_SondaPalpado
    a               ex:Sensor ;
    rdfs:label      "Sonda de palpado"@es ;
    ex:textoExtracto "señal de la sonda de palpado"@es, "señal del sensor"@es .

ex:DiagnosticoFallo_3743
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico alarma 3743: Colisión de palpador"@es ;
    ex:textoExtracto "Comprobar que no hay ningún obstáculo en el recorrido de los ejes."@es ;
    ex:solucionaFallo ex:Alarma_3743 .

ex:DiagnosticoFallo_3744
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico alarma 3744: #GAPCTRL"@es ;
    ex:textoExtracto "Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda"@es ;
    ex:solucionaFallo ex:Alarma_3744 .