@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_3802
    a ex:Alarma ;
    rdfs:label "Velocidad en jog incremental demasiado pequeña" ;
    ex:textoExtracto "3802 'Velocidad en jog incremental demasiado pequeña' DETECCIÓN Durante la ejecución. CAUSA El incremento de posición calculado para un ciclo de PLC es demasiado pequeño." ;
    ex:identificador "3802" .

ex:Alarma_3803
    a ex:Alarma ;
    rdfs:label "No se admite resolución de volante cero" ;
    ex:textoExtracto "3803 'No se admite resolución de volante cero' DETECCIÓN Durante un cambio en la resolución del volante desde el panel de mando. CAUSA La posición de volante seleccionada desde el conmutador o PLC tiene asociada una resolución de cero." ;
    ex:identificador "3803" .

ex:Alarma_3804
    a ex:Alarma ;
    rdfs:label "Índice de volante fuera de rango (posiciones del conmutador 1-3)" ;
    ex:textoExtracto "3804 'Índice de volante fuera de rango (posiciones del conmutador 1-3)' DETECCIÓN Durante un cambio en la resolución de volante. CAUSA El PLC ha intentado seleccionar una posición de volante que está fuera rango permitido." ;
    ex:identificador "3804" .

ex:Alarma_3805
    a ex:Alarma ;
    rdfs:label "Velocidad o distancia cero en modo jog incremental" ;
    ex:textoExtracto "3805 'Velocidad o distancia cero en modo jog incremental' DETECCIÓN Durante un cambio en el avance o en la distancia a recorrer en jog incremental. CAUSA La posición de jog incremental seleccionada desde el conmutador o PLC es cero." ;
    ex:identificador "3805" .

ex:Alarma_3806
    a ex:Alarma ;
    rdfs:label "Velocidad de jog incremental mayor que valor máximo" ;
    ex:textoExtracto "3806 'Velocidad de jog incremental mayor que valor máximo' DETECCIÓN Durante la ejecución. CAUSA La velocidad definida en parámetros máquina para jog incremental es mayor que la máxima permitida" ;
    ex:identificador "3806" .

ex:Alarma_3807
    a ex:Alarma ;
    rdfs:label "Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)" ;
    ex:textoExtracto "3807 'Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución." ;
    ex:identificador "3807" .

ex:Parametro_INCJOGFEED
    a ex:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ex:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED e INCJOGDIST." ;
    ex:identificador "INCJOGFEED" .

ex:Parametro_INCJOGDIST
    a ex:Parametro ;
    rdfs:label "INCJOGDIST" ;
    ex:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED e INCJOGDIST." ;
    ex:identificador "INCJOGDIST" .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "Revisar los parámetros máquina de ejes INCJOGFEED y LOOPTIME." ;
    ex:identificador "LOOPTIME" .

ex:Parametro_MPGRESOL
    a ex:Parametro ;
    rdfs:label "MPGRESOL" ;
    ex:textoExtracto "Revisar el parámetro máquina de ejes MPGRESOL." ;
    ex:identificador "MPGRESOL" .

ex:Parametro_MAXMANFEED
    a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:textoExtracto "Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." ;
    ex:identificador "MAXMANFEED" .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." ;
    ex:identificador "G00FEED" .

ex:ModoOperacion_JogIncremental
    a ex:ModoOperacion ;
    rdfs:label "Modo jog incremental" ;
    ex:textoExtracto "Definir un nuevo avance desde el modo manual. Revisar los parámetros máquina de ejes INCJOGFEED e INCJOGDIST." .

ex:DiagnosticoFallo_3802
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3802" ;
    ex:textoExtracto "SOLUCIÓN Revisar los parámetros máquina de ejes INCJOGFEED y LOOPTIME." ;
    ex:solucionaFallo ex:Alarma_3802 ;
    ex:monitoreaParametro ex:Parametro_INCJOGFEED, ex:Parametro_LOOPTIME .

ex:DiagnosticoFallo_3803
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3803" ;
    ex:textoExtracto "SOLUCIÓN Revisar el parámetro máquina de ejes MPGRESOL." ;
    ex:solucionaFallo ex:Alarma_3803 ;
    ex:monitoreaParametro ex:Parametro_MPGRESOL .

ex:DiagnosticoFallo_3805
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3805" ;
    ex:textoExtracto "SOLUCIÓN Revisar los parámetros máquina de ejes INCJOGDIST e INCJOGFEED." ;
    ex:solucionaFallo ex:Alarma_3805 ;
    ex:monitoreaParametro ex:Parametro_INCJOGDIST, ex:Parametro_INCJOGFEED .

ex:DiagnosticoFallo_3806
    a ex:DiagnosticoFallo ;
    rdfs:label "Solución para alarma 3806" ;
    ex:textoExtracto "SOLUCIÓN Repasar los parámetros máquina MAXMANFEED, INCJOGFEED y G00FEED." ;
    ex:solucionaFallo ex:Alarma_3806 ;
    ex:monitoreaParametro ex:Parametro_MAXMANFEED, ex:Parametro_INCJOGFEED, ex:Parametro_G00FEED .