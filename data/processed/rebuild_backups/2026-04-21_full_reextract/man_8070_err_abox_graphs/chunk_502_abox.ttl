@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_3812
    a ex:AvisoSeguridad ;
    rdfs:label "Error en refresco de volantes" ;
    ex:identificador "3812" ;
    ex:textoExtracto "3812 'Error en refresco de volantes' DETECCIÓN En modo manual, durante la lectura del contaje de un volante. CAUSA Lectura incorrecta del volante." .

ex:Diagnostico_3812
    a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error 3812" ;
    ex:textoExtracto "SOLUCIÓN Revisar la captación conectada en la entrada de volante; niveles de señal, frecuencia, etc." ;
    ex:solucionaFallo ex:Error_3812 .

ex:Volante_TecladoCAN
    a ex:ComponenteElectrico ;
    rdfs:label "Volante (teclado CAN)" ;
    ex:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ex:Volante_ContadoraCAN
    a ex:ComponenteElectrico ;
    rdfs:label "Volante (contadora CAN)" ;
    ex:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ex:Volante_Local
    a ex:ComponenteElectrico ;
    rdfs:label "Volante (local)" ;
    ex:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ex:Volante_ModuloRCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Volante (módulo RCS-S)" ;
    ex:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ex:Bus_CAN
    a ex:ComponenteElectrico ;
    rdfs:label "Bus CAN" ;
    ex:textoExtracto "revisar la coherencia y el nivel de comunicación del bus correspondiente" .

ex:Parametrizacion_EntradaVolante
    a ex:Parametro ;
    rdfs:label "Parametrización de entrada de volante" ;
    ex:textoExtracto "revisar la parametrización y conexión de la entrada de" ;
    ex:monitoreaParametro ex:Bus_CAN .