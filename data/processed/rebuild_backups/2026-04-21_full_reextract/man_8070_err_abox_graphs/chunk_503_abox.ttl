@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaComunicacionBus_503
    a               ex:Sistema ;
    rdfs:label      "Sistema de comunicación del bus"@es ;
    ex:textoExtracto
        "revisar la coherencia y el nivel de comunicación del bus correspondiente, así como la parametrización y conexión de la entrada de captación."@es .

ex:InterfazTecladoCAN_503
    a               ex:InterfazUsuario ;
    rdfs:label      "Teclado CAN"@es ;
    ex:textoExtracto
        "de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)"@es ;
    ex:compuestoPor ex:SistemaComunicacionBus_503 .

ex:InterfazContadoraCAN_503
    a               ex:InterfazUsuario ;
    rdfs:label      "Contadora CAN"@es ;
    ex:textoExtracto
        "de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)"@es ;
    ex:compuestoPor ex:SistemaComunicacionBus_503 .

ex:ModuloRCS_S_503
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo RCS-S"@es ;
    ex:textoExtracto
        "de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)"@es ;
    ex:compuestoPor ex:SistemaComunicacionBus_503 .

ex:EntradaCaptacion_503
    a               ex:Sensor ;
    rdfs:label      "Entrada de captación"@es ;
    ex:textoExtracto
        "parametrización y conexión de la entrada de captación"@es ;
    ex:monitoreaParametro ex:SistemaComunicacionBus_503 .