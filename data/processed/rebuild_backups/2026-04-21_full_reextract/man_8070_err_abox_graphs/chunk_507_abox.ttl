@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosError_55_60 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de error (55-60)"@es ;
    ex:textoExtracto """
| 55 | Error en lectura de Checksum. |
| 56 | Error en lectura de MP44. |
| 57 | Error en lectura de RP77. |
| 58 | Error en lectura de PP76. |
| 59 | Error en lectura de GV9. |
| 60 | Error en lectura de SP10. |
""" .

ex:Tabla_CodigosError_Sercos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de error del driver de Sercos"@es ;
    ex:textoExtracto """
| VALOR | Error. | Significado. |
| --- | --- |
| 0 | SERC_NO_ERROR |
| 1 | ERROR_PHASE_CHANGE |
| 5 | Petición de Abort/Suspend/Resume de un comando no activo. |
| 7 | Número de eje lógico incorrecto. |
| 0x0040 | READY_FOR_SCDATA |
| 0x0080 | ERROR_DEFAULT |
| 0x0101 | NOT_READY |
""" .

ex:Error_55
    a ex:AvisoSeguridad ;
    rdfs:label "Error 55"@es ;
    ex:identificador "55" ;
    ex:textoExtracto "Error en lectura de Checksum."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_56
    a ex:AvisoSeguridad ;
    rdfs:label "Error 56"@es ;
    ex:identificador "56" ;
    ex:textoExtracto "Error en lectura de MP44."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_57
    a ex:AvisoSeguridad ;
    rdfs:label "Error 57"@es ;
    ex:identificador "57" ;
    ex:textoExtracto "Error en lectura de RP77."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_58
    a ex:AvisoSeguridad ;
    rdfs:label "Error 58"@es ;
    ex:identificador "58" ;
    ex:textoExtracto "Error en lectura de PP76."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_59
    a ex:AvisoSeguridad ;
    rdfs:label "Error 59"@es ;
    ex:identificador "59" ;
    ex:textoExtracto "Error en lectura de GV9."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_60
    a ex:AvisoSeguridad ;
    rdfs:label "Error 60"@es ;
    ex:identificador "60" ;
    ex:textoExtracto "Error en lectura de SP10."@es ;
    ex:documentadoEn ex:Tabla_CodigosError_55_60 .

ex:Error_SERC_NO_ERROR
    a ex:AvisoSeguridad ;
    rdfs:label "SERC_NO_ERROR"@es ;
    ex:identificador "0" ;
    ex:valor "0" ;
    ex:textoExtracto "SERC_NO_ERROR" ;
    ex:documentadoEn ex:Tabla_CodigosError_Sercos .

ex:Error_ERROR_PHASE_CHANGE
    a ex:AvisoSeguridad ;
    rdfs:label "ERROR_PHASE_CHANGE"@es ;
    ex:identificador "1" ;
    ex:valor "1" ;
    ex:textoExtracto "ERROR_PHASE_CHANGE" ;
