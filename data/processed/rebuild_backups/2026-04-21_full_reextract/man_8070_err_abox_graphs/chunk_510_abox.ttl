ex:Alarma_4000_4
    a               ex:Alarma ;
    rdfs:label      "Error en la inicialización del anillo Sercos (4000-4)" ;
    ex:identificador "4000(4)" ;
    ex:textoExtracto "4000(4) 'Error en la inicialización del anillo Sercos' CAUSA Timeout en el reset de errores tras inicializar el anillo Sercos." ;
    ex:solucionaFallo ex:DiagnosticoFallo_4000_4 .

ex:DiagnosticoFallo_4000_4
    a               ex:DiagnosticoFallo ;
    ex:textoExtracto "Timeout en el reset de errores tras inicializar el anillo Sercos. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica." .

ex:Alarma_4000_5
    a               ex:Alarma ;
    rdfs:label      "Error en la inicialización del anillo Sercos (4000-5)" ;
    ex:identificador "4000(5)" ;
    ex:textoExtracto "4000(5) 'Error en la inicialización del anillo Sercos' VALOR 5. TRANSICIÓN 3. VALOR 35. CAUSA Error en el reset de errores tras inicializar el anillo Sercos." ;
    ex:solucionaFallo ex:DiagnosticoFallo_4000_5 .

ex:DiagnosticoFallo_4000_5
    a               ex:DiagnosticoFallo ;
    ex:textoExtracto "Error en el reset de errores tras inicializar el anillo Sercos. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica." .

