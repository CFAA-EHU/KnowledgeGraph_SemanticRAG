@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_4003
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro AXISMODE diferente en CNC y regulador"@es ;
    ex:textoExtracto "4003 'Parámetro AXISMODE diferente en CNC y regulador' [...] CAUSA Valor del parámetro AXISTYPE diferente en el CNC y en el regulador."@es ;
    ex:identificador "4003" ;
    ex:solucionaFallo ex:Parametro_AXISMODE_CNC, ex:Parametro_AXISMODE_Regulador ;
    .

ex:Fallo_4004
    a ex:DiagnosticoFallo ;
    rdfs:label "Parámetro G00FEED mayor en CNC que en Regulador"@es ;
    ex:textoExtracto "4004 'Parámetro G00FEED mayor en CNC que en Regulador' VALOR Valor del parámetro en el CNC. VALOR Valor del parámetro en el regulador."@es ;
    ex:identificador "4004" ;
    ex:solucionaFallo ex:Parametro_G00FEED_CNC, ex:Parametro_G00FEED_Regulador ;
    .

ex:Parametro_AXISMODE_CNC
    a ex:Parametro ;
    rdfs:label "AXISMODE (CNC)"@es ;
    ex:textoExtracto "Valor del parámetro AXISMODE en el CNC"@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    .

ex:Parametro_AXISMODE_Regulador
    a ex:Parametro ;
    rdfs:label "AXISMODE (Regulador)"@es ;
    ex:textoExtracto "Valor del parámetro AXISMODE en el regulador"@es ;
    ex:monitoreaParametro ex:Sistema_Regulador ;
    .

ex:Parametro_G00FEED_CNC
    a ex:Parametro ;
    rdfs:label "G00FEED (CNC)"@es ;
    ex:textoExtracto "Valor del parámetro G00FEED en el CNC"@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    .

ex:Parametro_G00FEED_Regulador
    a ex:Parametro ;
    rdfs:label "G00FEED (Regulador)"@es ;
    ex:textoExtracto "Valor del parámetro G00FEED en el regulador"@es ;
    ex:monitoreaParametro ex:Sistema_Regulador ;
    .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "Parámetros configurados en el CNC (ej. AXISMODE, G00FEED)"@es ;
    .

ex:Sistema_Regulador
    a ex:Sistema ;
    rdfs:label "Sistema Regulador"@es ;
    ex:textoExtracto "Parámetros configurados en el regulador (ej. AXISMODE, G00FEED)"@es ;
    .