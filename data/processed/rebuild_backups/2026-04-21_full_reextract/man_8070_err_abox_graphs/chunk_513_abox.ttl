@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_4009
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Error 4009: Superado el número de variables permitidas en un telegrama Sercos"@es ;
    ex:identificador        "4009" ;
    ex:textoExtracto         "4009 'Superado el número de variables permitidas en un telegrama Sercos' [...] El número máximo de variables Sercos a procesar cíclicamente en un telegrama está limitado a 8. En la tabla de variables Sercos hay definidas más de 6/7 variables de lectura escritura síncrona para un mismo eje."@es .

ex:Error_4010
    a                       ex:DiagnosticoFallo ;
    rdfs:label              "Error 4010: No se puede escribir parámetro"@es ;
    ex:identificador        "4010" ;
    ex:textoExtracto         "4010 'No se puede escribir parámetro"@es .

ex:Parametro_Sercos
    a                       ex:Parametro ;
    rdfs:label              "Variables Sercos"@es ;
    ex:textoExtracto         "variables Sercos [...] variables de lectura escritura síncrona [...] variables de acceso asíncrono"@es ;
    ex:valor                 "8"^^<http://www.w3.org/2001/XMLSchema#integer> .