@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de fallo (Alarmas)
ex:Fallo_4025
    a ex:DiagnosticoFallo ;
    rdfs:label "No se ha identificado Multi-Axis Box (MAB) en el anillo Sercos" ;
    ex:identificador "4025" ;
    ex:textoExtracto "No se ha identificado Multi-Axis Box (MAB) en el anillo Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA No se ha detectado un regulador MAB en el sistema. SOLUCIÓN Con la opción MABSYSTEM y más de un regulador en el anillo Sercos, es preciso que exista un regulador MAB." .

ex:Fallo_4026
    a ex:DiagnosticoFallo ;
    rdfs:label "Incoherencia en datos de encoder FeeDat/EnDat" ;
    ex:identificador "4026" ;
    ex:textoExtracto "Incoherencia en datos de encoder FeeDat/EnDat. Es necesario validar la nueva configuración. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Los datos leídos de un encoder FeeDat/EnDat son diferentes a los guardados en el CNC. El encoder es diferente del que se validó durante la puesta a punto." .

ex:Fallo_4027
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación FeeDat/EnDat parametrizada en contadora Sercos que no soporta el protocolo" ;
    ex:identificador "4027" ;
    ex:textoExtracto "Captación FeeDat/EnDat parametrizada en contadora Sercos que no soporta el protocolo. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha parametrizado una captación FeeDat/EnDat en un módulo RCS-S que no lo permite." .

ex:Fallo_4028
    a ex:DiagnosticoFallo ;
    rdfs:label "Variable DRV cuyo IDN no existe en el nodo Sercos" ;
    ex:identificador "4028" ;
    ex:textoExtracto "Variable DRV cuyo IDN no existe en el nodo Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset." .

### Componentes y sistemas implicados
ex:Regulador_MAB
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador Multi-Axis Box (MAB)" ;
    ex:textoExtracto "regulador MAB en el sistema" .

ex:Encoder_FeeDat_EnDat
    a ex:Sensor ;
    rdfs:label "Encoder con protocolo FeeDat/EnDat" ;
    ex:textoExtracto "encoder FeeDat/EnDat" .

ex:Modulo_RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)" ;
    ex:textoExtracto "módulo RCS-S" .

ex:Bus_Sercos
    a ex:Sistema ;
    rdfs:label "Bus Sercos" ;
    ex:textoExtracto "bus Sercos" .

### Relaciones entre fallos y componentes
ex:Fallo_4025
    ex:solucionaFallo [
        a ex:AvisoSeguridad ;
        rdfs:label "Incluir regulador MAB o eliminar opción MABSYSTEM" ;
        ex:textoExtracto "Eliminar la opción MABSYSTEM o incluir un regulador MAB en la configuración Sercos."
    ] ;
    ex:activaAlarma ex:Bus_Sercos .

ex:Fallo_4026
    ex:solucionaFallo [
        a ex:AvisoSeguridad ;
        rdfs:label "Revalidar encoder o reconectar el original" ;
        ex:textoExtracto "Volver a conectar el encoder que se validó en la puesta a punto o validar el nuevo encoder."
    ] ;
    ex:monitoreaParametro ex:Encoder_FeeDat_EnDat .

ex:Fallo_4027
    ex:solucionaFallo [
        a ex:AvisoSeguridad ;
        rdfs:label "Actualizar módulo RCS-S o reemplazarlo" ;
        ex:textoExtracto "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat."
    ] ;
    ex:tieneComponente ex:Modulo_RCS_S .

ex:Fallo_4028
    ex:activaAlarma ex:Bus_Sercos .

### Versiones de firmware
ex:Version_Firmware_v6.28
    a ex:Parametro ;
    rdfs:label "Versión de firmware v6.28" ;
    ex:identificador "v6.28" ;
    ex:textoExtracto "versión posterior a la v6.28" ;
    ex:valor "6.28" .

ex:Version_Firmware_v8.08
    a ex:Parametro ;
    rdfs:label "Versión de firmware v8.08" ;
    ex:identificador "v8.08" ;
    ex:textoExtracto "versión posterior a la v8.08" ;
    ex:valor "8.08" .