@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:_4032_AjusteTimeSchedulingSercos
    a               ex:TareaMantenimiento ;
    rdfs:label      "Reajuste del time-scheduling de Sercos (modo Diagnosis)"@es ;
    ex:textoExtracto "Se recomienda reajustar el time-scheduling de Sercos (modo Diagnosis)."@es ;
    ex:requiereMantenimiento ex:SistemaSercos ;
    ex:ejecutadoPor ex:PersonalTecnico .

ex:SistemaSercos
    a               ex:Sistema ;
    rdfs:label      "Sistema Sercos"@es ;
    ex:textoExtracto "El diagrama de tiempos de Sercos no es bastante óptimo para garantizar el sincronismo del sistema."@es ;
    ex:monitoreaParametro ex:ParametroTimeScheduling .

ex:ParametroTimeScheduling
    a               ex:Parametro ;
    rdfs:label      "Time-scheduling de Sercos"@es ;
    ex:textoExtracto "time-scheduling de Sercos"@es ;
    ex:valor         "modo Diagnosis"@es .

ex:PaginaDiagnosisSercos
    a               ex:Pagina ;
    rdfs:label      "Página de diagnosis Sercos"@es ;
    ex:textoExtracto "Desde la página de diagnosis Sercos, realizar el reajuste de tiempos y aceptar."@es ;
    ex:documentadoEn ex:ManualMaquina .

ex:ModoSetup
    a               ex:ModoOperacion ;
    rdfs:label      "Modo Setup"@es ;
    ex:textoExtracto "Sólo en modo Setup."@es ;
    ex:habilitadoPor ex:PersonalTecnico .

ex:PersonalTecnico
    a               ex:Personal ;
    rdfs:label      "Personal técnico"@es ;
    ex:textoExtracto "Desde la página de diagnosis Sercos, realizar el reajuste de tiempos y aceptar."@es .