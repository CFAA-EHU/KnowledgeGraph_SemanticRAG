@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4200_Sercos
    a ex:AvisoSeguridad ;
    rdfs:label "Error en el canal cíclico de Sercos"@es ;
    ex:identificador "4200" ;
    ex:textoExtracto "4200 'Error en el canal cíclico de Sercos' [...] Error en los procesos de lectura o escritura del canal cíclico"@es .

ex:Tabla_DRVVAR a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla DRVVAR"@es ;
    ex:textoExtracto "En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona"@es .

ex:Parametro_IDN296_FFGAIN
    a ex:Parametro ;
    rdfs:label "IDN296 (FFGAIN)"@es ;
    ex:identificador "IDN296" ;
    ex:textoExtracto "IDN296 (FFGAIN) como de escritura síncrona"@es ;
    ex:documentadoEn ex:Tabla_DRVVAR .

ex:Regulador_AXD
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador AXD"@es ;
    ex:textoExtracto "el regulador no es AXD o la versión de software es incompatible"@es ;
    ex:identificador "AXD" .

ex:Sistema_Sercos
    a ex:Sistema ;
    rdfs:label "Bus Sercos"@es ;
    ex:textoExtracto "Al inicializar el bus Sercos"@es ;
    ex:tieneComponente ex:Regulador_AXD ;
    ex:monitoreaParametro ex:Parametro_IDN296_FFGAIN .

ex:VersionSoftware_9_10
    a ex:Parametro ;
    rdfs:label "Versión de software v9.10"@es ;
    ex:identificador "v9.10" ;
    ex:valor "9.10" ;
    ex:textoExtracto "versión de software v9.10 o superior"@es .