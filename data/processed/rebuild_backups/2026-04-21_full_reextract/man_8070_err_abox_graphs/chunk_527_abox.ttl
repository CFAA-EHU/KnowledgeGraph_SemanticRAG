@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_4204
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4204: 'Error al resetear el driver de SERCOS'"@es ;
    ex:identificador "4204" ;
    ex:textoExtracto "4204 'Error al resetear el driver de SERCOS' [...] CAUSA Error al ejecutar el comando reset de errores de un regulador (ID 99)."@es ;
    ex:solucionaFallo ex:AnalisisManiobraPLC_4204 .

ex:AnalisisManiobraPLC_4204
    a ex:TareaMantenimiento ;
    rdfs:label "Análisis de maniobra de PLC para señal SPENA"@es ;
    ex:textoExtracto "SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA."@es .

ex:DriverSERCOS
    a ex:ComponenteElectrico ;
    rdfs:label "Driver de SERCOS"@es ;
    ex:textoExtracto "Error al resetear el driver de SERCOS [...] Errores en el driver de Sercos."@es ;
    ex:activaAlarma ex:Error_4204 .

ex:Regulador_ID99
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador (ID 99)"@es ;
    ex:identificador "99" ;
    ex:textoExtracto "Error al ejecutar el comando reset de errores de un regulador (ID 99)."@es ;
    ex:activaAlarma ex:Error_4204 .

ex:CodigoError_4000
    a ex:DiagnosticoFallo ;
    rdfs:label "Códigos de error 4000 (referencia para SERCOS)"@es ;
    ex:identificador "4000" ;
    ex:textoExtracto "Ver códigos de error descritos en el error 4000."@es ;
    ex:solucionaFallo ex:AnalisisCodigosError_4204 .

ex:AnalisisCodigosError_4204
    a ex:TareaMantenimiento ;
    rdfs:label "Análisis de códigos de error para fuente del fallo (Error 4204)"@es ;
    ex:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente."@es .

ex:EjeLogico_Valor1
    a ex:Parametro ;
    rdfs:label "Eje lógico (Valor = 1)"@es ;
    ex:valor "1" ;
    ex:textoExtracto "EJE Número lógico del eje. VALOR 1 Errores en el driver de Sercos."@es ;
    ex:monitoreaParametro ex:DriverSERCOS .

ex:EjeLogico_Valor2
    a ex:Parametro ;
    rdfs:label "Eje lógico (Valor = 2)"@es ;
    ex:valor "2" ;
    ex:textoExtracto "VALOR 2 Errores en el driver de Sercos."@es ;
    ex:monitoreaParametro ex:DriverSERCOS .