@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_4205_SERCOS
    a               ex:AvisoSeguridad ;
    ex:identificador "4205" ;
    rdfs:label      "Error en el anillo SERCOS"@es ;
    ex:textoExtracto
        "4205 'Error en el anillo SERCOS' VALOR Códigos de error que identifican la fuente o fuentes del problema."@es ;
    ex:solucionaFallo ex:Diagnostico_4205 .

ex:Diagnostico_4205
    a               ex:DiagnosticoFallo ;
    ex:textoExtracto
        "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error. Póngase en contacto con el servicio de asistencia técnica."@es .