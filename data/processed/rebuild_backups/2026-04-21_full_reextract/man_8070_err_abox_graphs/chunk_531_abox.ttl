@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_0x00000100
    a ex:DiagnosticoFallo ;
    rdfs:label "Pérdida de ATs" ;
    ex:identificador "0x00000100" ;
    ex:textoExtracto "Pérdida de ATs. CAUSA Pérdida de respuestas de algún regulador, que provoca pérdida de fase 4." ;
    ex:solucionaFallo ex:TareaMantenimiento_ReemplazoPlacaSercos .

ex:TareaMantenimiento_ReemplazoPlacaSercos
    a ex:TareaMantenimiento ;
    rdfs:label "Reemplazo de placa Sercos o regulador defectuoso" ;
    ex:textoExtracto "Determinar el regulador defectuoso y cambiar la placa Sercos o el mismo regulador." ;
    ex:requiereMantenimiento ex:ComponenteElectrico_PlacaSercos .

ex:ComponenteElectrico_PlacaSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Placa Sercos" ;
    ex:textoExtracto "placa Sercos" .

ex:AvisoSeguridad_AsistenciaTecnica
    a ex:AvisoSeguridad ;
    rdfs:label "Contactar con asistencia técnica" ;
    ex:textoExtracto "Póngase en contacto con el servicio de asistencia técnica." .

ex:Tabla_CodigosErrorSercos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Códigos de error del anillo Sercos" ;
    ex:identificador "4212" ;
    ex:textoExtracto "'Error en el anillo Sercos (recepción de AT)' EJE Número lógico del eje. VALOR Códigos de error que identifican la fuente o fuentes del problema." ;
    ex:documentadoEn ex:Pagina_162_179 .