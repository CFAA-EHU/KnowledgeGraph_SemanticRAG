@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error4217
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 4217: Error en el anillo Sercos (Escritura de MDT, buffer 0)"@es ;
    ex:identificador "4217" ;
    ex:textoExtracto "4217 Error en el anillo Sercos (Escritura de MDT, buffer 0). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es ;
    ex:solucionaFallo ex:Accion_RevisarConexionBusSercosIII_4217 .

ex:Error4218
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 4218: Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ex:identificador "4218" ;
    ex:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o"@es ;
    ex:solucionaFallo ex:Accion_RevisarConexionBusSercosIII_4218 .

ex:Accion_RevisarConexionBusSercosIII_4217
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar conexión del bus Sercos III (para error 4217)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la conexión del bus Sercos III."@es .

ex:Accion_RevisarConexionBusSercosIII_4218
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar conexión del bus Sercos III (para error 4218)"@es ;
    ex:textoExtracto "SOLUCIÓN Revisar la conexión del bus Sercos III."@es .

ex:SistemaBusSercosIII
    a ex:Sistema ;
    rdfs:label "Bus Sercos III"@es ;
    ex:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .