ex:Error4218_SercosIII
    a ex:AvisoSeguridad ;
    rdfs:label "Error 4218: Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ex:identificador "4218" ;
    ex:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es ;
    ex:mitigaRiesgo ex:SistemaBusSercosIII .

