ex:SistemaBusSercosIII
    a ex:Sistema ;
    rdfs:label "Sistema de bus Sercos III"@es ;
    ex:textoExtracto "Revisar la conexión del bus Sercos III. [...] Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es ;
    ex:compuestoPor ex:PlacasSercosIII .

ex:PlacasSercosIII
    a ex:ComponenteElectrico ;
    rdfs:label "Placas de Sercos III"@es ;
    ex:textoExtracto "problemas en las placas de Sercos"@es .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation"@es .