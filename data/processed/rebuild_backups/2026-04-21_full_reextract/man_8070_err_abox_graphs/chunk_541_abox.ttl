@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_4507
    a ex:DiagnosticoFallo ;
    rdfs:label "Alarma en subcomando Mechatrolink" ;
    ex:identificador "4507" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del CNC. CAUSA La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de alarma en dicho dispositivo. SOLUCIÓN Identificar el código de la alarma reportada y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ex:Fallo_4508
    a ex:DiagnosticoFallo ;
    rdfs:label "Aviso en subcomando Mechatrolink" ;
    ex:identificador "4508" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución del CNC. CAUSA La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo. SOLUCIÓN Identificar el código del warning reportado y consultar el manual del esclavo Mechatrolink para obtener información más específica." .

ex:Fallo_4600
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del hardware del bus" ;
    ex:identificador "4600" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en la inicialización del hardware del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ex:Fallo_4601
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la conexión de nodos del bus" ;
    ex:identificador "4601" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA No se puede establecer comunicación durante la fase de arranque de buses. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ex:Fallo_4602
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la detección de nodos" ;
    ex:identificador "4602" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Durante el arranque de bus de comunicaciones no se han podido detectar todos los esclavos que se esperaban detectar. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración." .

ex:Fallo_4603
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la fase de configuración del bus" ;
    ex:identificador "4603" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del CNC." .

ex:Fallo_EsclavosMechatrolink
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo de potencia en esclavos Mechatrolink" ;
    ex:textoExtracto "de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia. SOLUCIÓN Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los reguladores." .

ex:SistemaMechatrolink
    a ex:Sistema ;
    rdfs:label "Sistema de comunicación Mechatrolink" ;
    ex:textoExtracto "subcomando Mechatrolink desde el master a un determinado esclavo" ;
    ex:tieneComponente ex:BusEtherCAT .

ex:BusEtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Bus EtherCAT" ;
    ex:textoExtracto "En el caso del bus EtherCAT, revisar el archivo de configuración." .