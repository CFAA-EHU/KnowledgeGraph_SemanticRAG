@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_4606
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 4606: Error en comando de preparación del bus"@es ;
    ex:identificador "4606" ;
    ex:textoExtracto "4606 Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la preparación de los parámetros del bus"@es .

ex:Accion_DetachMaster
    a               ex:TareaMantenimiento ;
    rdfs:label      "Realizar 'Detach Master' en el configurador KPA"@es ;
    ex:textoExtracto "Realizar un 'Detach Master' en el configurador KPA antes de exportar el fichero ENI."@es ;
    ex:solucionaFallo ex:Error_4606 .

ex:Empresa_FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation"@es ;
    ex:textoExtracto "Si el error se repite, póngase en contacto con Fagor Automation."@es .