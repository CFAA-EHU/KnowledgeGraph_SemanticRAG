@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Warning_4684
    a ex:AvisoSeguridad ;
    rdfs:label "Warning 4684" ;
    ex:identificador "4684" ;
    ex:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." ;
    ex:textoExtracto "Durante la puesta en marcha, asignación de conexiones y/o cambio en los tipos de motor o fuente RPS." .

ex:Motor_Incompatible
    a ex:ComponenteElectrico ;
    rdfs:label "Motor conectado (tipo incompatible)" ;
    ex:textoExtracto "el tipo de motor conectado" .

ex:Regulador_Asociado
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador (SW no coincidente)" ;
    ex:textoExtracto "SW de regulador asociado a la referencia" ;
    ex:activaAlarma ex:Warning_4684 ;
    ex:controla ex:Motor_Incompatible .