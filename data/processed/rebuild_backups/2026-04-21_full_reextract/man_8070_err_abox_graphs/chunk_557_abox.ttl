@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_4703
    a ex:DiagnosticoFallo ;
    ex:identificador "4703" ;
    rdfs:label "No se encuentra la referencia del eje"@es ;
    ex:textoExtracto "No se encuentra la referencia del eje. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA No se ha definido correctamente la referencia del eje (identificador del nodo). SOLUCIÓN Revisar la definición de la referencia y el identificador del nodo."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Revisión incorrecta de referencia/nodo"@es ;
        ex:textoExtracto "Revisar la definición de la referencia y el identificador del nodo."@es
    ] .

ex:DiagnosticoFallo_4704
    a ex:DiagnosticoFallo ;
    ex:identificador "4704" ;
    rdfs:label "No se encuentra el feedback del eje"@es ;
    ex:textoExtracto "No se encuentra el feedback del eje. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA El feedback del eje no se ha definido correctamente (identificador del nodo). SOLUCIÓN Revisar la definición de la referencia y el identificador del nodo."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Definición incorrecta de feedback"@es ;
        ex:textoExtracto "Revisar la definición de la referencia y el identificador del nodo."@es
    ] .

ex:DiagnosticoFallo_4705
    a ex:DiagnosticoFallo ;
    ex:identificador "4705" ;
    rdfs:label "No se encuentra una variable de bus"@es ;
    ex:textoExtracto "No se encuentra una variable de bus. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA La variable de bus no se ha definido correctamente. SOLUCIÓN Revisar la definición de la variable."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Definición incorrecta de variable de bus"@es ;
        ex:textoExtracto "Revisar la definición de la variable."@es
    ] .

ex:DiagnosticoFallo_4706
    a ex:DiagnosticoFallo ;
    ex:identificador "4706" ;
    rdfs:label "Tipo de nodo no permitido"@es ;
    ex:textoExtracto "Tipo de nodo no permitido. DETECCIÓN Durante la detección nodos bus. CAUSA El control no dispone de la opción de software necesaria para inicializar ese tipo de nodo. SOLUCIÓN En diagnosis se puede comprobar las opciones de software activas."@es .

ex:DiagnosticoFallo_4707
    a ex:DiagnosticoFallo ;
    ex:identificador "4707" ;
    rdfs:label "Superado máximo número de nodos"@es ;
    ex:textoExtracto "Superado máximo número de nodos. DETECCIÓN Durante el arranque o la validación de parámetros máquina. CAUSA Hay definidos más nodos que los permitidos. SOLUCIÓN Eliminar nodos en la parametrización."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Exceso de nodos parametrizados"@es ;
        ex:textoExtracto "Eliminar nodos en la parametrización."@es
    ] .

ex:DiagnosticoFallo_4708
    a ex:DiagnosticoFallo ;
    ex:identificador "4708" ;
    rdfs:label "Fichero de configuración del bus erróneo"@es ;
    ex:textoExtracto "Fichero de configuración del bus erróneo. DETECCIÓN Durante el arranque del CNC. CAUSA La topología real del bus no coincide con el archivo de configuración. SOLUCIÓN Comprobar topología bus y las conexiones."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Inconsistencia topología/configuración"@es ;
        ex:textoExtracto "Comprobar topología bus y las conexiones."@es
    ] .

ex:DiagnosticoFallo_4709
    a ex:DiagnosticoFallo ;
    ex:identificador "4709" ;
    rdfs:label "Problemas de comunicación entre nodos"@es ;
    ex:textoExtracto "El nodo tiene problemas de comunicación con el nodo anterior. DETECCIÓN Durante el arranque del CNC. CAUSA La conexión entre nodos no es correcta. SOLUCIÓN Comprobar conexiones físicas."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Conexión física defectuosa"@es ;
        ex:textoExtracto "Comprobar conexiones físicas."@es
    ] .

ex:DiagnosticoFallo_IncompatibilidadMotor
    a ex:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad tipo motor/control"@es ;
    ex:textoExtracto "no coincide con el tipo de motor conectado. DETECCIÓN Durante la puesta en marcha, asignación de conexiones y/o cambio en los tipos de motor o fuente RPS. CAUSA El tipo motor conectado a la referencia no coincide con el tipo de control del regulador asociado. SOLUCIÓN Validar la topología."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Topología no validada"@es ;
        ex:textoExtracto "Validar la topología."@es
    ] .