@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_5026
    a ex:Alarma ;
    rdfs:label "Alarma 5026: CNCWR - Valor no permitido" ;
    ex:identificador "5026" ;
    ex:textoExtracto "'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable que sólo admite valor 0 (cero)." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de programa PLC para variable CNCWR" ;
        ex:textoExtracto "Revisar el programa de PLC. Escribir el valor 0 en la variable o eliminar el comando CNCWR."
    ] .

ex:Alarma_5027
    a ex:Alarma ;
    rdfs:label "Alarma 5027: Cortocircuito en salida analógica local" ;
    ex:identificador "5027" ;
    ex:textoExtracto "'Cortocircuito en salida analógica local (report desde PLC)' DETECCIÓN El PLC ha detectado una alarma de sobrecorriente a la hora de escribir la salida analógica local. CAUSA Cortocircuito en la salida analógica local del CNC." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de conexionado de salida analógica CNC" ;
        ex:textoExtracto "Revisar el conexionado de la salida analógica del CNC."
    ] .

ex:Alarma_5028
    a ex:Alarma ;
    rdfs:label "Alarma 5028: Error en recurso remoto (lectura)" ;
    ex:identificador "5028" ;
    ex:textoExtracto "DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de leer datos." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de conexionado de módulos remotos (lectura)" ;
        ex:textoExtracto "Revisar el conexionado de los módulos remotos."
    ] .

ex:Alarma_5029
    a ex:Alarma ;
    rdfs:label "Alarma 5029: Error en recurso remoto (escritura)" ;
    ex:identificador "5029" ;
    ex:textoExtracto "DETECCIÓN Al acceder a los recursos del módulo remoto. CAUSA Alarma en un módulo remoto a la hora de escribir datos." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de conexionado de módulos remotos (escritura)" ;
        ex:textoExtracto "Revisar el conexionado de los módulos remotos."
    ] .

ex:Alarma_5030
    a ex:Alarma ;
    rdfs:label "Alarma 5030: Error de configuración de recursos remotos" ;
    ex:identificador "5030" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de configuración de módulos remotos" ;
        ex:textoExtracto "Revisar la configuración de los módulos remotos."
    ] .

ex:Alarma_5031
    a ex:Alarma ;
    rdfs:label "Alarma 5031: Error interno en configuración de recursos remotos" ;
    ex:identificador "5031" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error al configurar los módulos remotos." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de configuración de módulos remotos (error interno)" ;
        ex:textoExtracto "Revisar la configuración de los módulos remotos."
    ] .

ex:Alarma_5032
    a ex:Alarma ;
    rdfs:label "Alarma 5032: Orden incorrecto en comandos de router de recursos" ;
    ex:identificador "5032" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto." ;
    ex:mitigaRiesgo [
        a ex:DiagnosticoFallo ;
        rdfs:label "Revisión de secuencia de inicialización del router" ;
        ex:textoExtracto "Revisar la configuración de los módulos remotos."
    ] .