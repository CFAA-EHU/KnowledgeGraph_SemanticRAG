@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_5034 a ex:DiagnosticoFallo ;
    ex:identificador "5034" ;
    rdfs:label "Error en la parametrización de algún recurso remoto" ;
    ex:textoExtracto "5034 Error en la parametrización de algún recurso remoto. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún parámetro de los recursos remotos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos." .

ex:Error_5035 a ex:DiagnosticoFallo ;
    ex:identificador "5035" ;
    rdfs:label "Error de circuito abierto en una salida analógica remota" ;
    ex:textoExtracto "5035 Error de circuito abierto en una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Se ha abierto el circuito conectado a una salida analógica remota. SOLUCIÓN Revisar el conexionado de la salida analógica remota." .

ex:Error_5036 a ex:DiagnosticoFallo ;
    ex:identificador "5036" ;
    rdfs:label "Error de corto circuito en una salida analógica remota" ;
    ex:textoExtracto "5036 Error de corto circuito en una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Se ha producido un cortocircuito en una salida analógica remota. SOLUCIÓN Revisar el conexionado de la salida analógica remota." .

ex:Error_5037 a ex:DiagnosticoFallo ;
    ex:identificador "5037" ;
    rdfs:label "Salida analógica remota configurada incorrectamente" ;
    ex:textoExtracto "5037 Una salida analógica remota esta configurada incorrectamente. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La configuración de una salida analógica remota no es correcta. SOLUCIÓN Revisar configuración de la salida analógica remota." .

ex:Error_5038 a ex:DiagnosticoFallo ;
    ex:identificador "5038" ;
    rdfs:label "Error de alimentación en salida analógica remota" ;
    ex:textoExtracto "5038 Una salida analógica remota ha detectado un error de alimentación. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La alimentación de la salida analógica remota no es correcta. SOLUCIÓN Revisar la alimentación de la salida analógica remota." .

ex:Error_5039 a ex:DiagnosticoFallo ;
    ex:identificador "5039" ;
    rdfs:label "Error en módulo de salidas analógicas remotas" ;
    ex:textoExtracto "5039 Una salida analógica remota ha detectado un error en el módulo. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de salidas analógicas no funciona correctamente. SOLUCIÓN Revisar módulo remoto." .

ex:Error_5040 a ex:DiagnosticoFallo ;
    ex:identificador "5040" ;
    rdfs:label "Error desconocido en salida analógica remota" ;
    ex:textoExtracto "5040 Una salida analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC." .

ex:ModuloRemoto a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto" ;
    ex:textoExtracto "módulos remotos"@es .

ex:SalidaAnalogicaRemota a ex:ComponenteElectrico ;
    rdfs:label "Salida analógica remota" ;
    ex:textoExtracto "salida analógica remota"@es .

ex:Error_5034 ex:solucionaFallo ex:ModuloRemoto .
ex:Error_5035 ex:solucionaFallo ex:SalidaAnalogicaRemota .
ex:Error_5036 ex:solucionaFallo ex:SalidaAnalogicaRemota .
ex:Error_5037 ex:solucionaFallo ex:SalidaAnalogicaRemota .
ex:Error_5038 ex:solucionaFallo ex:SalidaAnalogicaRemota .
ex:Error_5039 ex:solucionaFallo ex:ModuloRemoto .