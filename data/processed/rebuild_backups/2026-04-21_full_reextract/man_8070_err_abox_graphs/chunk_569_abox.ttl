@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_5040
    a ex:DiagnosticoFallo ;
    ex:identificador "5040" ;
    rdfs:label "Salida analógica remota con error desconocido"@es ;
    ex:textoExtracto "5040 Una salida analógica remota ha detectado un error desconocido."@es ;
    ex:monitoreaParametro ex:Parametro_SalidaAnalogicaRemota .

ex:Fallo_5041
    a ex:DiagnosticoFallo ;
    ex:identificador "5041" ;
    rdfs:label "Entrada analógica remota con error de rango excedido"@es ;
    ex:textoExtracto "5041 Una entrada analógica remota ha detectado un error de rango excedido."@es ;
    ex:monitoreaParametro ex:Parametro_EntradaAnalogicaRemota .

ex:Parametro_SalidaAnalogicaRemota
    a ex:Parametro ;
    rdfs:label "Salida analógica remota"@es ;
    ex:textoExtracto "salida analógica remota"@es .

ex:Parametro_EntradaAnalogicaRemota
    a ex:Parametro ;
    rdfs:label "Entrada analógica remota"@es ;
    ex:textoExtracto "entrada analógica remota"@es .

ex:ModuloRemoto_SalidasAnalogicas
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto de salidas analógicas"@es ;
    ex:textoExtracto "módulo remoto de salidas analógicas"@es ;
    ex:solucionaFallo ex:Fallo_5040 .

ex:ModuloRemoto_EntradasAnalogicas
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas analógicas"@es ;
    ex:textoExtracto "módulo remoto de entradas analógicas"@es ;
    ex:solucionaFallo ex:Fallo_5041 .

ex:Tarea_RevisionModuloRemoto
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto"@es ;
    ex:textoExtracto "Revisar módulo remoto."@es ;
    ex:requiereMantenimiento ex:ModuloRemoto_SalidasAnalogicas ;
    ex:requiereMantenimiento ex:ModuloRemoto_EntradasAnalogicas .