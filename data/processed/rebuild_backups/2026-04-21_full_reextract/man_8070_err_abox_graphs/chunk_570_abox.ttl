@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_5041
    a ex:Alarma ;
    ex:identificador "5041" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error de rango excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La tensión aplicada a la entrada analógica es mayor que el rango permitido. SOLUCIÓN Revisar el circuito conectado a la entrada analógica remota." ;
    rdfs:label "Alarma 5041: Error de rango excedido en entrada analógica remota" .

ex:Alarma_5042
    a ex:Alarma ;
    ex:identificador "5042" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error de rango mínimo excedido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La tensión aplicada a la entrada analógica es menor que el rango permitido. SOLUCIÓN Revisar el circuito conectado a la entrada analógica remota." ;
    rdfs:label "Alarma 5042: Error de rango mínimo excedido en entrada analógica remota" .

ex:Alarma_5043
    a ex:Alarma ;
    ex:identificador "5043" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error conversión. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La entrada analógica indica que no puede realizar la lectura correctamente. SOLUCIÓN Revisar módulo remoto." ;
    rdfs:label "Alarma 5043: Error de conversión en entrada analógica remota" .

ex:Alarma_5044
    a ex:Alarma ;
    ex:identificador "5044" ;
    ex:textoExtracto "Una entrada analógica remota esta configurada incorrectamente. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La configuración de una entrada analógica remota no es correcta. SOLUCIÓN Revisar configuración de la entrada analógica remota." ;
    rdfs:label "Alarma 5044: Configuración incorrecta en entrada analógica remota" .

ex:Alarma_5045
    a ex:Alarma ;
    ex:identificador "5045" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error de alimentación. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La alimentación de la entrada analógica remota no es correcta. SOLUCIÓN Revisar la alimentación de la entrada analógica remota." ;
    rdfs:label "Alarma 5045: Error de alimentación en entrada analógica remota" .

ex:Alarma_5046
    a ex:Alarma ;
    ex:identificador "5046" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error en el módulo. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas no funciona correctamente. SOLUCIÓN Revisar módulo remoto." ;
    rdfs:label "Alarma 5046: Error en módulo de entradas analógicas remotas" .

ex:Alarma_5047
    a ex:Alarma ;
    ex:identificador "5047" ;
    ex:textoExtracto "Una entrada analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas tiene un error. SOLUCIÓN Revisar módulo remoto." ;
    rdfs:label "Alarma 5047: Error desconocido en módulo de entradas analógicas remotas" .

ex:Alarma_ModuloSalidasAnalogicas
    a ex:Alarma ;
    ex:textoExtracto "el funcionamiento del PLC. CAUSA El módulo remoto de salidas analógicas tiene un error. SOLUCIÓN Revisar módulo remoto." ;
    rdfs:label "Alarma: Error en módulo remoto de salidas analógicas" .

ex:ComponenteElectrico_ModuloSalidasAnalogicas
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto de salidas analógicas" ;
    ex:textoExtracto "El módulo remoto de salidas analógicas tiene un error." .

ex:ComponenteElectrico_ModuloEntradasAnalogicas
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas analógicas" ;
    ex:textoExtracto "El módulo remoto de entradas analógicas no funciona correctamente." .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "el funcionamiento del PLC" ;
    ex:tieneComponente ex:ComponenteElectrico_ModuloSalidasAnalogicas ;
    ex:tieneComponente ex:ComponenteElectrico_ModuloEntradasAnalogicas .

ex:Alarma_5041 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5042 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5043 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5044 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5045 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5046 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_5047 ex:activaAlarma ex:Sistema_PLC .
ex:Alarma_ModuloSalidasAnalogicas ex:activaAlarma ex:Sistema_PLC .