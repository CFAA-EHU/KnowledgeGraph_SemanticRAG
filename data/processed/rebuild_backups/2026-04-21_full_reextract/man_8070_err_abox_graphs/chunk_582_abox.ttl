@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ModulosIO a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de módulos de E/S"@es ;
    ex:textoExtracto """
| Módulo. | Significado. |
| --- | --- |
| 1 | Salidas analógicas. |
| 2 | Contadoras. |
| 3 | Salidas digitales. |
| 4 | Entradas digitales. |
| 5 | Entradas analógicas. |
| 7 | Entradas PT100. |
| 8 | Volante de teclado CAN. |
| 9 | Palpadores. |
| 10 | Teclado jog. |
| 11 | Teclado alfanumérico. |
| 12 | Fallo en algún nodo de I/Os"""@es ;
    ex:tieneComponente ex:Modulo_1, ex:Modulo_2, ex:Modulo_3, ex:Modulo_4,
                       ex:Modulo_5, ex:Modulo_7, ex:Modulo_8, ex:Modulo_9,
                       ex:Modulo_10, ex:Modulo_11, ex:Modulo_12 .

ex:Modulo_1
    a ex:ComponenteElectrico ;
    ex:identificador "1" ;
    rdfs:label "Módulo 1: Salidas analógicas"@es ;
    ex:textoExtracto "Salidas analógicas."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_2
    a ex:ComponenteElectrico ;
    ex:identificador "2" ;
    rdfs:label "Módulo 2: Contadoras"@es ;
    ex:textoExtracto "Contadoras."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_3
    a ex:ComponenteElectrico ;
    ex:identificador "3" ;
    rdfs:label "Módulo 3: Salidas digitales"@es ;
    ex:textoExtracto "Salidas digitales."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_4
    a ex:ComponenteElectrico ;
    ex:identificador "4" ;
    rdfs:label "Módulo 4: Entradas digitales"@es ;
    ex:textoExtracto "Entradas digitales."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_5
    a ex:ComponenteElectrico ;
    ex:identificador "5" ;
    rdfs:label "Módulo 5: Entradas analógicas"@es ;
    ex:textoExtracto "Entradas analógicas."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_7
    a ex:Sensor ;
    ex:identificador "7" ;
    rdfs:label "Módulo 7: Entradas PT100"@es ;
    ex:textoExtracto "Entradas PT100."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_8
    a ex:InterfazUsuario ;
    ex:identificador "8" ;
    rdfs:label "Módulo 8: Volante de teclado CAN"@es ;
    ex:textoExtracto "Volante de teclado CAN."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_9
    a ex:Sensor ;
    ex:identificador "9" ;
    rdfs:label "Módulo 9: Palpadores"@es ;
    ex:textoExtracto "Palpadores."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_10
    a ex:InterfazUsuario ;
    ex:identificador "10" ;
    rdfs:label "Módulo 10: Teclado jog"@es ;
    ex:textoExtracto "Teclado jog."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_11
    a ex:InterfazUsuario ;
    ex:identificador "11" ;
    rdfs:label "Módulo 11: Teclado alfanumérico"@es ;
    ex:textoExtracto "Teclado alfanumérico."@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .

ex:Modulo_12
    a ex:AvisoSeguridad ;
    ex:identificador "12" ;
    rdfs:label "Módulo 12: Fallo en nodo de I/Os"@es ;
    ex:textoExtracto "Fallo en algún nodo de I/Os"@es ;
    ex:documentadoEn ex:Tabla_ModulosIO .