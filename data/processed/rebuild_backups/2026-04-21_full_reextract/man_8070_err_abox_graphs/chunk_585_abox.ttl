@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosErrorCANopen a ex:Tabla ;
     a ex:Tabla ;
    ex:identificador "Tabla de emergencias para el bus CANopen (codificación en base a bits)" ;
    ex:textoExtracto "VALOR 3 Tabla de emergencias para el bus CANopen (codificación en base a bits)." .

### Códigos de error genéricos (bits)
ex:Error_0x01
    a ex:DiagnosticoFallo ;
    ex:identificador "0x01" ;
    ex:textoExtracto "0x01 | Error genérico." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x02
    a ex:DiagnosticoFallo ;
    ex:identificador "0x02" ;
    ex:textoExtracto "0x02 | Error de corriente." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x04
    a ex:DiagnosticoFallo ;
    ex:identificador "0x04" ;
    ex:textoExtracto "0x04 | Error de tensión." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x08
    a ex:DiagnosticoFallo ;
    ex:identificador "0x08" ;
    ex:textoExtracto "0x08 | Error de temperatura." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x10
    a ex:DiagnosticoFallo ;
    ex:identificador "0x10" ;
    ex:textoExtracto "0x10 | Error de comunicaciones." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x20
    a ex:DiagnosticoFallo ;
    ex:identificador "0x20" ;
    ex:textoExtracto "0x20 | Error de dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Error_0x80
    a ex:DiagnosticoFallo ;
    ex:identificador "0x80" ;
    ex:textoExtracto "0x80 | Error específico del fabricante." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

### Códigos de emergencia específicos (16 bits)
ex:Emergencia_0x0000
    a ex:DiagnosticoFallo ;
    ex:identificador "0x0000" ;
    ex:textoExtracto "0x0000 | Error corregido." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen ;
    ex:solucionaFallo ex:Error_0x01 .  # Relación implícita: "corregido" mitiga el error genérico

ex:Emergencia_0x1000
    a ex:DiagnosticoFallo ;
    ex:identificador "0x1000" ;
    ex:textoExtracto "0x1000 | Error genérico." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x2000
    a ex:DiagnosticoFallo ;
    ex:identificador "0x2000" ;
    ex:textoExtracto "0x2000 | Corriente." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen ;
    ex:mitigaRiesgo ex:Error_0x02 .  # Relación jerárquica con error de corriente genérico

ex:Emergencia_0x2100
    a ex:DiagnosticoFallo ;
    ex:identificador "0x2100" ;
    ex:textoExtracto "0x2100 | Corriente, lado de entrada del dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x2200
    a ex:DiagnosticoFallo ;
    ex:identificador "0x2200" ;
    ex:textoExtracto "0x2200 | Corriente dentro del dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x2300
    a ex:DiagnosticoFallo ;
    ex:identificador "0x2300" ;
    ex:textoExtracto "0x2300 | Corriente, lado de salida del dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x2310
    a ex:DiagnosticoFallo ;
    ex:identificador "0x2310" ;
    ex:textoExtracto "0x2310 | Sobrecorriente en las salidas." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen ;
    ex:mitigaRiesgo ex:Emergencia_0x2300 .  # Especialización de 0x2300

ex:Emergencia_0x3000
    a ex:DiagnosticoFallo ;
    ex:identificador "0x3000" ;
    ex:textoExtracto "0x3000 | Tensión." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen ;
    ex:mitigaRiesgo ex:Error_0x04 .  # Relación con error de tensión genérico

ex:Emergencia_0x3100
    a ex:DiagnosticoFallo ;
    ex:identificador "0x3100" ;
    ex:textoExtracto "0x3100 | Tensión de red." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x3200
    a ex:DiagnosticoFallo ;
    ex:identificador "0x3200" ;
    ex:textoExtracto "0x3200 | Tensión dentro del dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x3300
    a ex:DiagnosticoFallo ;
    ex:identificador "0x3300" ;
    ex:textoExtracto "0x3300 | Tensión de salida." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x4000
    a ex:DiagnosticoFallo ;
    ex:identificador "0x4000" ;
    ex:textoExtracto "0x4000 | Temperatura." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen ;
    ex:mitigaRiesgo ex:Error_0x08 .  # Relación con error de temperatura genérico

ex:Emergencia_0x4100
    a ex:DiagnosticoFallo ;
    ex:identificador "0x4100" ;
    ex:textoExtracto "0x4100 | Temperatura ambiente." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .

ex:Emergencia_0x4200
    a ex:DiagnosticoFallo ;
    ex:identificador "0x4200" ;
    ex:textoExtracto "0x4200 | Temperatura dentro del dispositivo." ;
    ex:documentadoEn ex:Tabla_CodigosErrorCANopen .