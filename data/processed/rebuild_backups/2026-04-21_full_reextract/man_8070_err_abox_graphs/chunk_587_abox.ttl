@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosError a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de error"@es ;
    ex:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 0 | Error de sistema. |
| 1 | Error de CAN. |
| 2 | Error en las colas Tx/Rx.
"""@es ;
    ex:documentadoEn ex:Pagina_186 .

ex:ErrorSistema
    a ex:AvisoSeguridad ;
    ex:identificador "0" ;
    rdfs:label "Error de sistema"@es ;
    ex:textoExtracto "Error de sistema."@es ;
    ex:documentadoEn ex:Tabla_CodigosError .

ex:ErrorCAN
    a ex:AvisoSeguridad ;
    ex:identificador "1" ;
    rdfs:label "Error de CAN"@es ;
    ex:textoExtracto "Error de CAN."@es ;
    ex:documentadoEn ex:Tabla_CodigosError .

ex:ErrorColasTxRx
    a ex:AvisoSeguridad ;
    ex:identificador "2" ;
    rdfs:label "Error en las colas Tx/Rx"@es ;
    ex:textoExtracto "Error en las colas Tx/Rx."@es ;
    ex:documentadoEn ex:Tabla_CodigosError .