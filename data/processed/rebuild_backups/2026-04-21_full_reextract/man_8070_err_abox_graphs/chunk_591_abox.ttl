@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_6020
    a ex:DiagnosticoFallo ;
    rdfs:label "Solapamiento del ciclo de CAN"@es ;
    ex:identificador "6020" ;
    ex:textoExtracto "6020 'Solapamiento del ciclo de CAN' DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos cíclicos de lectura de las entradas digitales, analógicas, contadores y volantes de teclado. Alguno de los nodos no envió el mensaje a tiempo."@es .

ex:ModoDiagnosis_CNC
    a ex:ModoOperacion ;
    rdfs:label "Modo diagnosis del CNC"@es ;
    ex:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN"@es ;
    ex:solucionaFallo ex:Fallo_6020 .

ex:Sistema_CAN
    a ex:Sistema ;
    rdfs:label "Sistema CAN"@es ;
    ex:textoExtracto "contador de errores CAN"@es ;
    ex:monitoreaParametro ex:Parametro_ErroresCAN .

ex:Parametro_ErroresCAN
    a ex:Parametro ;
    rdfs:label "Contador de errores CAN"@es ;
    ex:textoExtracto "contador de errores CAN"@es .