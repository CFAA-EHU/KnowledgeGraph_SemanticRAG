@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorChecksum_COMPCI
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error de checksum en la COMPCI"@es ;
    ex:identificador "6025" ;
    ex:textoExtracto "6025 'Error de checksum en la COMPCI' [...] Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es .

ex:SistemaCANfagor
    a               ex:Sistema ;
    rdfs:label      "Bus CANfagor"@es ;
    ex:textoExtracto "Códigos de error para el bus CANfagor."@es ;
    ex:tieneComponente ex:COMPCI .

ex:COMPCI
    a               ex:ComponenteElectrico ;
    rdfs:label      "COMPCI"@es ;
    ex:textoExtracto "Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es ;
    ex:monitoreaParametro ex:ParametroChecksum .

ex:ParametroChecksum
    a               ex:Parametro ;
    rdfs:label      "Checksum de salidas digitales/analógicas"@es ;
    ex:textoExtracto "Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI"@es .