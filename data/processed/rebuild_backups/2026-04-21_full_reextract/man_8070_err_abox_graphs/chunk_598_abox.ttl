@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_6031
    a ex:DiagnosticoFallo ;
    ex:identificador "6031" ;
    rdfs:label "'Versión de soft incompatible en COMPCI/Nodos remotos'" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Versión de software incompatible en CNC y COMPCI o módulos remotos. SOLUCIÓN Actualizar el software de la COMPCI y módulos remotos." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Actualización no autorizada de software" ;
        ex:textoExtracto "Actualizar el software de la COMPCI y módulos remotos."
    ] .

ex:Fallo_6032
    a ex:DiagnosticoFallo ;
    ex:identificador "6032" ;
    rdfs:label "'Error en la configuración del teclado CAN'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El 165 no responde o hay problemas en la comunicación CAN. SOLUCIÓN Revisar la conexión a través del bus CAN y la versión de la COMPCI." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de bus CAN y versión COMPCI" ;
        ex:textoExtracto "Revisar la conexión a través del bus CAN y la versión de la COMPCI."
    ] .

ex:Fallo_6033
    a ex:DiagnosticoFallo ;
    ex:identificador "6033" ;
    rdfs:label "'La configuración hardware no coincide con la configuración guardada en fichero'" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema o durante la ejecución. CAUSA La configuración hardware guardada en disco no coincide con la detectada en el arranque. Posibles cambios en la configuración CAN que no se han salvado, cambios no deseados en los parámetros máquina, etc. SOLUCIÓN En el modo diagnosis comprobar si la configuración CAN detectada coincide con la real; si es así, salvar la configuración. En caso contrario comprobar si es un error en la parametrización o hay algún error en la detección de los nodos." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación y salvado de configuración CAN" ;
        ex:textoExtracto "En el modo diagnosis comprobar si la configuración CAN detectada coincide con la real; si es así, salvar la configuración."
    ] .

ex:Fallo_6034
    a ex:DiagnosticoFallo ;
    ex:identificador "6034" ;
    rdfs:label "'Reset en nodo CAN'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Un nodo CAN se ha reseteado. La ventana de error indica el número de nodo. SOLUCIÓN Comprobar que la alimentación del nodo es correcta. Si no hay problemas en el bus, sustituir el nodo. Consultar con el servicio de asistencia técnica." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Comprobación de alimentación y sustitución de nodo CAN" ;
        ex:textoExtracto "Comprobar que la alimentación del nodo es correcta. Si no hay problemas en el bus, sustituir el nodo."
    ] .

ex:Fallo_6035
    a ex:DiagnosticoFallo ;
    ex:identificador "6035" ;
    rdfs:label "'Error en la inicialización de IOs locales'" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA En el CNC hay configuradas más salidas digitales locales que las que existentes. SOLUCIÓN Definir un máximo de 8 salidas digitales locales." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Límite de salidas digitales locales" ;
        ex:valor "8" ;
        ex:textoExtracto "Definir un máximo de 8 salidas digitales locales."
    ] .

ex:Fallo_6036
    a ex:DiagnosticoFallo ;
    ex:identificador "6036" ;
    rdfs:label "'Falta alimentación de IOs locales'" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU)." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de alimentación en I/Os locales (ICU/MCU)" ;
        ex:textoExtracto "Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU)."
    ] .

ex:Fallo_Hardware_Contadora
    a ex:DiagnosticoFallo ;
    rdfs:label "Incremento de posición excesivo en eje analógico / Fallo de hardware del nodo contadora" ;
    ex:textoExtracto "CAUSA Incremento de posición excesivo en un eje analógico. Fallo de hardware del nodo contadora. SOLUCIÓN Consultar con el servicio de asistencia técnica." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Intervención no autorizada en nodo contadora" ;
        ex:textoExtracto "Consultar con el servicio de asistencia técnica."
    ] .

ex:SistemaCAN
    a ex:Sistema ;
    rdfs:label "Bus CAN y nodos remotos" ;
    ex:textoExtracto "configuración CAN, comunicación CAN, nodos CAN, bus CAN" ;
    ex:tieneComponente [
        a ex:ComponenteElectrico ;
        rdfs:label "Nodo CAN genérico" ;
        ex:textoExtracto "nodo CAN, nodos remotos, módulos remotos"
    ] .

ex:UnidadCentral_ICU
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad central ICU" ;
    ex:textoExtracto "I/Os locales (unidades centrales ICU)" .

ex:UnidadCentral_MCU
    a ex:ComponenteElectrico ;
    rdfs:label "Unidad central MCU" ;
    ex:textoExtracto "I/Os locales (unidades centrales MCU)" .