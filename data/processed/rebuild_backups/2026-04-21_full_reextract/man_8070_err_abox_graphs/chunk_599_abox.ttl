@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FaltaAlimentacionIOsLocales_6036
    a ex:AvisoSeguridad ;
    ex:identificador "6036" ;
    rdfs:label "Falta alimentación de IOs locales"@es ;
    ex:textoExtracto "6036 'Falta alimentación de IOs locales' DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU)."@es ;
    ex:solucionaFallo ex:AlimentacionIOsLocales_24V .

ex:AlimentacionIOsLocales_24V
    a ex:AccionProhibida ;
    rdfs:label "Alimentar las I/Os locales con 24 V"@es ;
    ex:textoExtracto "SOLUCIÓN Alimentar las I/Os locales con 24 V."@es .

ex:ParametroLoopTimeInvalido_6037
    a ex:AvisoSeguridad ;
    ex:identificador "6037" ;
    rdfs:label "Parámetro LOOPTIME no es válido"@es ;
    ex:textoExtracto "6037 'Parámetro LOOPTIME no es válido'"@es .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "Parámetro LOOPTIME"@es ;
    ex:monitoreaParametro ex:ParametroLoopTimeInvalido_6037 .