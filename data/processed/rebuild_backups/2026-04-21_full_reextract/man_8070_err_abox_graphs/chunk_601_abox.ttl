@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloConfiguracionTeclado_6000
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo de configuración en teclado 8065"@es ;
    ex:textoExtracto "El CNC ha detectado un teclado 8065 (qwerty o jog) configurado para comunicarse con versiones anteriores a la V04.10."@es ;
    ex:identificador "6000" ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Configuración de teclados 8065"@es ;
        ex:textoExtracto "Identificar los teclados 8065 (qwerty y jog) y configurarlos correctamente."@es ;
        ex:ejecutadoPor ex:ServicioAsistenciaTecnica
    ] .

ex:ServicioAsistenciaTecnica
    a               ex:Personal ;
    rdfs:label      "Servicio de asistencia técnica"@es ;
    ex:textoExtracto "Póngase en contacto con el servicio de asistencia técnica."@es .

ex:AlarmaSobrecorriente_6042
    a               ex:Alarma , ex:DiagnosticoFallo ;
    rdfs:label      "Alarma de sobrecorriente (6042)"@es ;
    ex:identificador "6042" ;
    ex:textoExtracto "Alarma de sobrecorriente en la lectura de la entrada local de captación."@es ;
    ex:textoExtracto "Cortocircuito en el contaje local del CNC."@es ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Revisión de conexionado y niveles de señal"@es ;
        ex:textoExtracto "Revisar el correcto conexionado y niveles de señal de la captación local del CNC."@es
    ] .

ex:AlarmaCableRoto_6043
    a               ex:Alarma , ex:DiagnosticoFallo ;
    rdfs:label      "Alarma de cable roto (6043)"@es ;
    ex:identificador "6043" ;
    ex:textoExtracto "El lazo ha detectado una alarma de cable roto."@es .