@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_6056
    a ex:Alarma ;
    rdfs:label "Cortocircuito en volante de jog (alarma de sobrecorriente)" ;
    ex:identificador "6056" ;
    ex:textoExtracto "6056 'Cortocircuito en volante de jog (alarma de sobrecorriente)' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de sobrecorriente en el volante conectado al jog local." ;
    ex:mitigaRiesgo ex:diagnostico_6056 .

ex:diagnostico_6056
    a ex:DiagnosticoFallo ;
    rdfs:label "Revisión de conexionado y alimentación de volantes locales (alarma 6056)" ;
    ex:textoExtracto "SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." ;
    ex:solucionaFallo ex:alarma_6056 .

ex:componente_volante_jog
    a ex:ComponenteElectrico ;
    rdfs:label "Volante de jog local" ;
    ex:textoExtracto "Alarma de sobrecorriente en el volante conectado al jog local." ;
    ex:activaAlarma ex:alarma_6056 .

ex:alarma_6057
    a ex:Alarma ;
    rdfs:label "Alarma de Captación en volante" ;
    ex:identificador "6057" ;
    ex:textoExtracto "6057 'Alarma de Captación en volante' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de captación en volante conectado al contaje local." ;
    ex:mitigaRiesgo ex:diagnostico_6057 .

ex:diagnostico_6057
    a ex:DiagnosticoFallo ;
    rdfs:label "Revisión de conexionado y alimentación de volantes locales (alarma 6057)" ;
    ex:textoExtracto "SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales." ;
    ex:solucionaFallo ex:alarma_6057 .

ex:componente_volante_contaje
    a ex:ComponenteElectrico ;
    rdfs:label "Volante conectado al contaje local" ;
    ex:textoExtracto "Alarma de captación en volante conectado al contaje local." ;
    ex:activaAlarma ex:alarma_6057 .