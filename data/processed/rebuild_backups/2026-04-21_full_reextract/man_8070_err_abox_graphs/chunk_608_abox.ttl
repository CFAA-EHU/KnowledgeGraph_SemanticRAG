@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_608_1
    a ex:Alarma ;
    rdfs:label "Alarma por relé de emergencia abierto tras error en bus CAN/Sercos" ;
    ex:textoExtracto "ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos. Como consecuencia, el relé de emergencia ha quedado abierto." ;
    ex:identificador "VALOR 1; VALOR 2; VALOR 3; VALOR 4; VALOR 8; VALOR 12" .

ex:ComponenteElectrico_608_1
    a ex:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ex:textoExtracto "el relé de emergencia ha quedado abierto" ;
    ex:activaAlarma ex:Alarma_608_1 .

ex:DiagnosticoFallo_608_1
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en bus CAN durante reset CNC" ;
    ex:textoExtracto "Error en CAN durante un proceso de reset CNC" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 2" .

ex:DiagnosticoFallo_608_2
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos durante reset CNC" ;
    ex:textoExtracto "Error en Sercos durante un proceso de reset CNC" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 1" .

ex:DiagnosticoFallo_608_3
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en bus CAN y Sercos durante reset CNC" ;
    ex:textoExtracto "Error en Sercos y CAN durante un proceso de reset CNC" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 3" .

ex:DiagnosticoFallo_608_4
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en Sercos durante validación de parámetros máquina" ;
    ex:textoExtracto "Error en Sercos durante un proceso de validación de parámetros máquina" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 4" .

ex:DiagnosticoFallo_608_5
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en CAN durante validación de parámetros máquina" ;
    ex:textoExtracto "Error en CAN durante un proceso de validación de parámetros máquina" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 8" .

ex:DiagnosticoFallo_608_6
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en Sercos y CAN durante validación de parámetros máquina" ;
    ex:textoExtracto "Error en Sercos y CAN durante un proceso de validación de parámetros máquina" ;
    ex:solucionaFallo ex:Alarma_608_1 ;
    ex:identificador "VALOR 12" .

ex:TareaMantenimiento_608_1
    a ex:TareaMantenimiento ;
    rdfs:label "Corrección de error en bus CAN/Sercos" ;
    ex:textoExtracto "Corregir el problema en CAN o Sercos que impide que se cierre el relé de emergencia" ;
    ex:solucionaFallo ex:Alarma_608_1 .