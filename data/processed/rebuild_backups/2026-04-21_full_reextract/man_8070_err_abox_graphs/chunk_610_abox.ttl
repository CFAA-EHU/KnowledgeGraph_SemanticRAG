@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_7006
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7006: 'D no admitida para esta herramienta'"@es ;
    ex:identificador "7006" ;
    ex:textoExtracto "'D no admitida para esta herramienta' DETECCIÓN Durante la ejecución. CAUSA Corrector de herramienta no válido. La herramienta tiene menos correctores que el programado. SOLUCIÓN Programar un corrector existente o añadir nuevos correctores a la herramienta."@es .

ex:AvisoSeguridad_7007
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7007: 'En modo carga: T0 no admitida'"@es ;
    ex:identificador "7007" ;
    ex:textoExtracto "'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0."@es .

ex:ModoOperacion_Carga
    a ex:ModoOperacion ;
    rdfs:label "Modo carga"@es ;
    ex:textoExtracto "Almacén en modo carga"@es ;
    ex:activaAlarma ex:AvisoSeguridad_7007 .