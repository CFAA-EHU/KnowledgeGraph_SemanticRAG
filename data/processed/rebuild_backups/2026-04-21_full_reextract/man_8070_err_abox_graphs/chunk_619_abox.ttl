@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de fallo (Alarmas)
ex:Fallo_7039 a ex:DiagnosticoFallo ;
    rdfs:label "No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente"@es ;
    ex:textoExtracto "7039 'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente' [...] SOLUCIÓN Devolver la herramienta del brazo al almacén y proseguir normalmente con el cambio de herramienta."@es ;
    ex:identificador "7039" .

ex:Fallo_7040 a ex:DiagnosticoFallo ;
    rdfs:label "Error en operación: Vaciar primero el brazo 1"@es ;
    ex:textoExtracto "7040 'Error en operación: Vaciar primero el brazo 1' [...] SOLUCIÓN Devolver la herramienta del brazo al almacén y proseguir normalmente con el cambio de herramienta."@es ;
    ex:identificador "7040" .

ex:Fallo_7041 a ex:DiagnosticoFallo ;
    rdfs:label "No hay herramienta activa"@es ;
    ex:textoExtracto "7041 'No hay herramienta activa' [...] SOLUCIÓN Poner una herramienta en el cabezal."@es ;
    ex:identificador "7041" .

ex:Fallo_7042 a ex:DiagnosticoFallo ;
    rdfs:label "Programada POS y el almacén no está en modo CARGA"@es ;
    ex:textoExtracto "7042 'Programada POS y el almacén no está en modo CARGA' [...] SOLUCIÓN La programación de la posición de carga sólo se admite en modo carga."@es ;
    ex:identificador "7042" .

ex:Fallo_7043 a ex:DiagnosticoFallo ;
    rdfs:label "La herramienta pedida es la herramienta activa de otro canal"@es ;
    ex:textoExtracto "7043 'La herramienta pedida es la herramienta activa de otro canal' [...] SOLUCIÓN Descargar la herramienta del otro canal."@es ;
    ex:identificador "7043" .

ex:Fallo_7044 a ex:DiagnosticoFallo ;
    rdfs:label "No se puede modificar el número de filos de la herramienta activa"@es ;
    ex:textoExtracto "7044 'No se puede modificar el número de filos de la herramienta activa' [...] CAUSA Ha intentado cambiar el numero de filos de una herramienta y esa herramienta está activa en algún canal."@es ;
    ex:identificador "7044" .

### Modos de operación (relacionados con fallos)
ex:ModoCarga a ex:ModoOperacion ;
    rdfs:label "Modo CARGA"@es ;
    ex:textoExtracto "Para cambiar el modo del almacén a modo carga o descarga [...] SOLUCIÓN Vaciar el cabezal y los brazos."@es .

ex:ModoDescarga a ex:ModoOperacion ;
    rdfs:label "Modo DESCARGA"@es ;
    ex:textoExtracto "Para cambiar el modo del almacén a modo carga o descarga [...] SOLUCIÓN Vaciar el cabezal y los brazos."@es .

### Componentes mecánicos (genéricos)
ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ex:textoExtracto "hay que tener el cabezal (y los brazos en los almacenes donde proceda) vacíos."@es .

ex:Brazo1 a ex:ComponenteMecanico ;
    rdfs:label "Brazo 1"@es ;
    ex:textoExtracto "7040 'Error en operación: Vaciar primero el brazo 1' [...] El almacén pide la misma herramienta que está en el brazo 1."@es .

ex:Brazo2 a ex:ComponenteMecanico ;
    rdfs:label "Brazo 2"@es ;
    ex:textoExtracto "7039 'No puede haber una herramienta en el cabezal y en el brazo 2 simultáneamente' [...] El almacén pide la misma herramienta que está en el brazo 2."@es .

### Relaciones entre fallos y componentes
ex:Fallo_7039 ex:solucionaFallo ex:Cabezal, ex:Brazo2 .
ex:Fallo_7040 ex:solucionaFallo ex:Brazo1 .
ex:Fallo_7041 ex:solucionaFallo ex:Cabezal .
ex:Fallo_7042 ex:requiereMantenimiento ex:ModoCarga .