@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_7044 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 7044: Herramienta activa con número de filos no modificable"@es ;
    ex:identificador "7044" ;
    ex:textoExtracto "'No se puede modificar el número de filos de la herramienta activa' DETECCIÓN Durante la ejecución. CAUSA Ha intentado cambiar el numero de filos de una herramienta y esa herramienta está activa en algún canal."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Modificar número de filos de herramienta activa"@es ;
        ex:textoExtracto "Colocar la herramienta en el almacén o en tierra para modificar el número de filos."@es
    ] .

ex:Fallo_7045 a ex:DiagnosticoFallo ;
    rdfs:label "Fallo 7045: Información insuficiente para operación (almacén no determinado)"@es ;
    ex:identificador "7045" ;
    ex:textoExtracto "No hay suficiente información para la operación, el almacén no esta determinado. DETECCIÓN Durante la ejecución. CAUSA La herramienta programada no está en el almacén."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de ubicación de herramienta programada"@es ;
        ex:textoExtracto "Revisar"@es
    ] .

ex:Herramienta_Activa a ex:Herramienta ;
    rdfs:label "Herramienta activa en canal"@es ;
    ex:textoExtracto "esa herramienta está activa en algún canal"@es ;
    ex:requiereMantenimiento ex:Fallo_7044 .

ex:Herramienta_Programada a ex:Herramienta ;
    rdfs:label "Herramienta programada no ubicada"@es ;
    ex:textoExtracto "La herramienta programada no está en el almacén"@es ;
    ex:requiereMantenimiento ex:Fallo_7045 .