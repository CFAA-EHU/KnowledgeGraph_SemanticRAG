@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_7045
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7045: Herramienta no disponible en almacén" ;
    ex:identificador "7045" ;
    ex:textoExtracto "No hay suficiente información para la operación, el almacén no esta determinado. DETECCIÓN Durante la ejecución. CAUSA La herramienta programada no está en el almacén. SOLUCIÓN Revisar la tabla de herramientas y almacén." .

ex:AvisoSeguridad_7046
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7046: Acceso denegado a variable (V.)G.CAM" ;
    ex:identificador "7046" ;
    ex:textoExtracto "No se puede acceder a la variable. DETECCIÓN Durante la validación de los parámetros máquina o la ejecución. CAUSA Las posibles causas son las siguientes: • La herramienta programada no es accesible. • Se ha intentado leer la variable (V.)G.CAM durante la validación de la tabla que define la leva. • Se ha intentado leer o escribir la variable (V.)G.CAM antes de que el CNC termine de cargar la leva. • Se ha intentado activar la leva antes de que el CNC termine de cargarla." .

ex:Parametro_V_G_CAM
    a ex:Parametro ;
    rdfs:label "Variable (V.)G.CAM" ;
    ex:textoExtracto "variable (V.)G.CAM" ;
    ex:valor "G.CAM" .

ex:AvisoSeguridad_7047
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7047: Memoria insuficiente para herramientas" ;
    ex:identificador "7047" ;
    ex:textoExtracto "Memoria insuficiente para el número total de herramientas definido en los almacenes. DETECCIÓN Durante la ejecución. CAUSA El número de herramientas definido en los almacenes excede el máximo permitido." .

ex:AvisoSeguridad_7048
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7048: Error en sentencia ROTATEMZ" ;
    ex:identificador "7048" ;
    ex:textoExtracto "Error en la Sentencia ROTATEMZ. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un cambio de herramienta en una torreta y la sentencia #ROTATEMZ ha dado error." .

ex:Parametro_ROTATEMZ
    a ex:Parametro ;
    rdfs:label "Sentencia #ROTATEMZ" ;
    ex:textoExtracto "sentencia #ROTATEMZ" ;
    ex:valor "ROTATEMZ" .

ex:AvisoSeguridad_7049
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 7049: ROTATEMZ con MZPOS=0" ;
    ex:identificador "7049" ;
    ex:textoExtracto "ROTATEMZ: el registro MZPOS del PLC no puede ser 0. DETECCIÓN Durante la ejecución. CAUSA La sentencia #ROTATEMZ está forzando la posición 0 del almacén." .

ex:Parametro_MZPOS
    a ex:Parametro ;
    rdfs:label "Registro MZPOS del PLC" ;
    ex:textoExtracto "registro MZPOS del PLC" ;
    ex:valor "MZPOS" .