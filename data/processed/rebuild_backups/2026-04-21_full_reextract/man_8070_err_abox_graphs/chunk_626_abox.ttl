@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8007
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando programa de la COMPCI" ;
    ex:textoExtracto "8007 'Error cargando programa de la COMPCI' [...] CAUSA Error durante el proceso de carga de la COMPCI." ;
    ex:identificador "8007" ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de COMPCI" ;
        ex:textoExtracto "Verificar el reconocimiento y correcta instalación de la COMPCI. Póngase en contacto con el servicio de asistencia técnica."
    ] .

ex:Error_8008
    a ex:DiagnosticoFallo ;
    rdfs:label "Error almacenado configuración del sistema" ;
    ex:textoExtracto "8008 'Error almacenado configuración del sistema' [...] CAUSA Error en la configuración CAN durante el proceso de carga." ;
    ex:identificador "8008" ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Comprobación de configuración CAN" ;
        ex:textoExtracto "Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos."
    ] .

ex:Error_8009
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de los nodos IO" ;
    ex:textoExtracto "8009 'Error cargando software de los nodos IO' [...] CAUSA Error durante el proceso de carga de los nodos de I/Os." ;
    ex:identificador "8009" ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de nodos IO" ;
        ex:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos."
    ] .

ex:Error_8010
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclado" ;
    ex:textoExtracto "8010 'Error cargando software de teclado' [...] CAUSA Error durante el proceso de carga del nodo del teclado de 12\"" ;
    ex:identificador "8010" ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de teclado" ;
        ex:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos."
    ] .

ex:Error_8011
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ex:textoExtracto "8011 'Error cargando software de las contadoras' [...] CAUSA Error durante el proceso de carga de los nodos contadora." ;
    ex:identificador "8011" ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificación de nodos contadoras" ;
        ex:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos."
    ] .

ex:COMPCI
    a ex:ComponenteElectrico ;
    rdfs:label "COMPCI" ;
    ex:textoExtracto "Verificar el reconocimiento de la COMPCI, el valor del parámetro CANMODE y la instalación del driver de comunicaciones." .

ex:Parametro_CANMODE
    a ex:Parametro ;
    rdfs:label "CANMODE" ;
    ex:textoExtracto "Verificar el reconocimiento de la COMPCI, el valor del parámetro CANMODE y la instalación del driver de comunicaciones." ;
    ex:valor "configuración_CAN" .

ex:Nodos_IO
    a ex:ComponenteElectrico ;
    rdfs:label "Nodos de I/O" ;
    ex:textoExtracto "Error durante el proceso de carga de los nodos de I/Os." .

ex:Nodo_Teclado_12
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de 12\"" ;
    ex:textoExtracto "Error durante el proceso de carga del nodo del teclado de 12\"" .

ex:Nodos_Contadoras
    a ex:ComponenteElectrico ;
    rdfs:label "Nodos contadoras" ;
    ex:textoExtracto "Error durante el proceso de carga de los nodos contadora." .

ex:Modo_Diagnosis
    a ex:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ex:textoExtracto "Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos." .