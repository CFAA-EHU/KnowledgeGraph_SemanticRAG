@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error8012_CargaSoftwareContadoras
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error 8012: Error cargando software de las contadoras" ;
    ex:identificador    "8012" ;
    ex:textoExtracto    "'Error cargando software de las contadoras' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora." .

ex:SistemaContadoras
    a                   ex:Sistema ;
    ex:textoExtracto    "proceso de carga de los nodos contadora" ;
    ex:tieneComponente  ex:NodosContadora .

ex:NodosContadora
    a                   ex:ComponenteElectrico ;
    ex:textoExtracto    "nodos contadora" .

ex:ConfiguracionCAN
    a                   ex:Parametro ;
    ex:textoExtracto    "Verificar la configuración CAN" ;
    ex:monitoreaParametro  ex:SistemaContadoras .