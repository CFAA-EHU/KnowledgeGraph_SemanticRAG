@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8012
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ex:identificador "8012" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ex:Error_8013
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclados compactos" ;
    ex:identificador "8013" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga del nodo del teclado de 10\". SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ex:Error_8014
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de RIOS" ;
    ex:identificador "8014" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos RIOS (I/Os CANopen). SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ex:Error_8015
    a ex:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Eje en movimiento o en sincronización" ;
    ex:identificador "8015" ;
    ex:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ex:Error_8016
    a ex:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en marcha" ;
    ex:identificador "8016" ;
    ex:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ex:Error_8017
    a ex:DiagnosticoFallo ;
    rdfs:label "Cierre no permitido: Cabezal en sincronización" ;
    ex:identificador "8017" ;
    ex:textoExtracto "DETECCIÓN Al intentar cerrar el CNC. CAUSA El usuario ha intentado apagar el CNC mientras hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ex:Error_8018
    a ex:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC mientras se encuentre en ejecución o interrumpido" ;
    ex:identificador "8018" ;
    ex:textoExtracto "DETECCIÓN Al intentar compilar el PLC." .