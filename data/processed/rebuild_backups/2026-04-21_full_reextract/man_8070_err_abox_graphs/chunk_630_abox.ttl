@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8019
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8019: No se permite generar el PLC mientras algún canal se encuentre en ejecución o interrumpido" ;
    ex:identificador "8019" ;
    ex:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si algún canal se encuentra en ejecución o interrumpido. SOLUCIÓN Detener los programas en ejecución." .

ex:Error_8020
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8020: No se permite generar el PLC: Eje en movimiento o en sincronización" ;
    ex:identificador "8020" ;
    ex:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún eje algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ex:Error_8021
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8021: No se permite generar el PLC: Cabezal en marcha" ;
    ex:identificador "8021" ;
    ex:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ex:Error_8022
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8022: No se permite generar el PLC: Cabezal en sincronización" ;
    ex:identificador "8022" ;
    ex:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ex:Error_8023
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8023: Memoria en disco por debajo del mínimo recomendado" ;
    ex:identificador "8023" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ex:Error_8024
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8024: CNC trabajando en Modo Puesta a Punto" ;
    ex:identificador "8024" ;
    ex:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ex:ModoPuestaPunto
    a ex:ModoOperacion ;
    rdfs:label "Modo Puesta a Punto" ;
    ex:textoExtracto "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ex:Error_8024 ex:documentadoEn ex:ModoPuestaPunto .