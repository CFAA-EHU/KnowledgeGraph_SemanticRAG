@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8025 a ex:Alarma ;
    rdfs:label "Alarma 8025: Cambio de fecha detectado"@es ;
    ex:identificador "8025" ;
    ex:textoExtracto "'Se ha detectado un cambio de fecha y ha sido necesario restaurarla' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un cambio de fecha u hora y los ha restaurado a sus valores esperados."@es .

ex:Alarma_8026 a ex:Alarma ;
    rdfs:label "Alarma 8026: Protección OEM activada"@es ;
    ex:identificador "8026" ;
    ex:textoExtracto "'Protección de OEM activada:Los cambios tendrán carácter temporal' DETECCIÓN Durante la edición de programas, programa PLC o parámetros máquina. CAUSA El CNC está en modo usuario, con la protección de OEM activada, por lo que todo cambio tendrá carácter temporal y se perderá al apagar el CNC."@es .

ex:Alarma_8027 a ex:Alarma ;
    rdfs:label "Alarma 8027: Error en kernel"@es ;
    ex:identificador "8027" ;
    ex:textoExtracto "'Error arrancando Kernel' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel está arrancado pero no está activado."@es .

ex:Alarma_8028 a ex:Alarma ;
    rdfs:label "Alarma 8028: Compilador PLC no disponible"@es ;
    ex:identificador "8028" ;
    ex:textoExtracto "'Compilador no disponible' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentra instalado el compilador de PLC."@es .

ex:Alarma_8029 a ex:Alarma ;
    rdfs:label "Alarma 8029: Includes PLC no disponibles"@es ;
    ex:identificador "8029" ;
    ex:textoExtracto "'Includes del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instalados los includes necesarios para compilar el PLC."@es .

ex:Alarma_8030 a ex:Alarma ;
    rdfs:label "Alarma 8030: Librerías PLC no disponibles"@es ;
    ex:identificador "8030" ;
    ex:textoExtracto "'Librerias del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC."@es .

ex:Utilidad_DiskMonitor a ex:Herramienta ;
    rdfs:label "DiskMonitor"@es ;
    ex:textoExtracto "utilice la utilidad DiskMonitor para pasar a modo usuario y trabajar con el disco protegido. Volver a arrancar el CNC."@es .

ex:ModoOperacion_PuestaAPunto a ex:ModoOperacion ;
    rdfs:label "Modo puesta a punto"@es ;
    ex:textoExtracto "Apagar el CNC y utilizar la utilidad DiskMonitor para pasar a modo puesta a punto."@es .

ex:ModoOperacion_Usuario a ex:ModoOperacion ;
    rdfs:label "Modo usuario"@es ;
    ex:textoExtracto "El CNC está en modo usuario, con la protección de OEM activada"@es .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ex:textoExtracto "CNC"@es ;
    ex:tieneComponente ex:Utilidad_DiskMonitor ;
    ex:activaAlarma ex:Alarma_8025, ex:Alarma_8026, ex:Alarma_8027, ex:Alarma_8028, ex:Alarma_8029, ex:Alarma_8030 .