@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8041
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8041: Memoria por debajo del mínimo recomendado"@es ;
    ex:identificador "8041" ;
    ex:textoExtracto "8041 'Memoria por debajo del mínimo recomendado para la ejecución' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco."@es .

ex:Solucion_8041
    a ex:TareaMantenimiento ;
    rdfs:label "Liberar memoria en disco para el CNC"@es ;
    ex:textoExtracto "Hay que liberar memoria en disco para poder arrancar el CNC. • Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo"@es ;
    ex:solucionaFallo ex:Error_8041 .

ex:Parametro_MemoriaLibre
    a ex:Parametro ;
    rdfs:label "Memoria libre en disco (CNC)"@es ;
    ex:valor "50" ;
    ex:textoExtracto "menos de 50 MB de memoria libre en disco"@es ;
    ex:monitoreaParametro ex:Error_8041 .