@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8052
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8052: Límite de ejes y cabezales superado" ;
    ex:textoExtracto "La suma de ejes y cabezales no debe superar el valor máximo. [...] La configuración supera el límite de ejes más cabezales." ;
    ex:identificador "8052" .

ex:Error_8053
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8053: Licencia temporal a punto de expirar" ;
    ex:textoExtracto "El periodo de servicio esta a punto de expirar. [...] El CNC tiene activa la licencia de uso temporal y quedan siete días para que la licencia expire." ;
    ex:identificador "8053" .

ex:Error_8054
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8054: Licencia temporal expirada" ;
    ex:textoExtracto "El periodo de servicio ha expirado. [...] La licencia de uso temporal ha expirado. El CNC no acepta la tecla [START]." ;
    ex:identificador "8054" .

ex:Error_8055
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8055: CNC bloqueado por violación de términos" ;
    ex:textoExtracto "El CNC ha sido bloqueado debido a una violación de los términos de uso. [...] El CNC está bloqueado porque ha detectado un cambio de fecha no permitido." ;
    ex:identificador "8055" .

ex:Error_8051
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8051: Datos de CNC corruptos o inaccesibles" ;
    ex:textoExtracto "usuario no es accesible o está corrupto. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc pueden haberse perdido." ;
    ex:identificador "8051" .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Fagor Automation)" ;
    ex:textoExtracto "El CNC tiene limitado el número de máximo de ejes, de cabezales y la suma de ambos. [...] Póngase en contacto con Fagor Automation." ;
    ex:activaAlarma ex:Error_8051, ex:Error_8052, ex:Error_8053, ex:Error_8054, ex:Error_8055 .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation." .

ex:Empresa_OEM
    a ex:Empresa ;
    rdfs:label "OEM (Fabricante de Equipo Original)" ;
    ex:textoExtracto "Contacte con el OEM para obtener un código de actualización. [...] Solicite al OEM el código que modifica o anula la fecha final de la licencia." .