@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8056
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén" ;
    ex:identificador "8056" ;
    ex:textoExtracto "8056 Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido recuperar la información de las posiciones de las herramientas en el almacén. SOLUCIÓN Definir manualmente las herramientas en las posiciones del almacén." .

ex:Error_8057
    a ex:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la posición de la herramienta activa en el almacén" ;
    ex:identificador "8057" ;
    ex:textoExtracto "8057 Inconsistencia en la recuperación de la posición de la herramienta activa en el almacén. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido recuperar la información de la herramienta activa en el almacén. SOLUCIÓN Definir manualmente cual es la herramientas activa." .

ex:Error_8058
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de memoria" ;
    ex:identificador "8058" ;
    ex:textoExtracto "8058 Error de memoria. Es necesario reiniciar el CNC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La memoria se encuentra debajo del mínimo recomendado para el correcto funcionamiento del CNC. SOLUCIÓN Reiniciar el CNC. El CNC puede tener problemas para funcionar correctamente." .

ex:Error_8059
    a ex:DiagnosticoFallo ;
    rdfs:label "Vida restante del disco por debajo del 25%" ;
    ex:identificador "8059" ;
    ex:textoExtracto "8059 Vida restante del disco por debajo del 25%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El disco se acerca al fin de su vida útil. SOLUCIÓN Póngase en contacto con Fagor Automation. El CNC puede tener problemas para funcionar correctamente." .

ex:Error_8060
    a ex:DiagnosticoFallo ;
    rdfs:label "Vida restante del disco por debajo del 10%" ;
    ex:identificador "8060" ;
    ex:textoExtracto "8060 Vida restante del disco por debajo del 10%. Cierre el CNC y póngase en contacto con Fagor Automation S. Coop. para obtener asistencia técnica. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El disco está a punto de terminar su vida útil. SOLUCIÓN Póngase en contacto con Fagor Automation. El CNC puede tener problemas para funcionar correctamente." .

ex:Error_8127
    a ex:DiagnosticoFallo ;
    rdfs:label "Error cargando software de RIOR-ETHERCAT" ;
    ex:identificador "8127" ;
    ex:textoExtracto "8127 Error cargando software de RIOR-ETHERCAT. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga de los nodos RIOR-ETHERCAT. SOLUCIÓN Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos." .

ex:Error_8128
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en recuperación de datos de FRAM" ;
    ex:identificador "8128" ;
    ex:textoExtracto "8128 No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "CNC" ;
    ex:tieneComponente ex:DiscoAlmacenamiento .

ex:DiscoAlmacenamiento
    a ex:ComponenteElectrico ;
    rdfs:label "Disco de almacenamiento" ;
    ex:textoExtracto "El disco se acerca al fin de su vida útil", "El disco está a punto de terminar su vida útil" .

ex:MemoriaCNC
    a ex:ComponenteElectrico ;
    rdfs:label "Memoria del CNC" ;
    ex:textoExtracto "La memoria se encuentra debajo del mínimo recomendado para el correcto funcionamiento del CNC" .

ex:FRAM
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo FRAM" ;
    ex:textoExtracto "Error durante el proceso de recuperación de datos de FRAM" .

ex:RIOR_ETHERCAT
    a ex:Sistema ;
    rdfs:label "Sistema RIOR-ETHERCAT" ;
    ex:textoExtracto "Error durante el proceso de carga de los nodos RIOR-ETHERCAT" .

ex:Error_8059 ex:mitigaRiesgo ex:AvisoSeguridad_8059 .
ex:AvisoSeguridad_8059
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Vida restante del disco por debajo del 25%" ;
    ex:textoExtracto "El CNC puede tener problemas para funcionar correctamente" .

ex:Error_8060 ex:mitigaRiesgo ex:AvisoSeguridad_8060 .
ex:AvisoSeguridad_8060
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Vida restante del disco por debajo del 10%" ;
    ex:textoExtracto "Cierre el CNC y póngase en contacto con Fagor Automation S. Coop. para obtener asistencia técnica. El CNC puede tener problemas para funcionar correctamente." .

ex:Error_8058 ex:mitigaRiesgo ex:AvisoSeguridad_8058 .
ex:AvisoSeguridad_8058
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Error de memoria" ;
    ex:textoExtracto "El CNC puede tener problemas para funcionar correctamente" .