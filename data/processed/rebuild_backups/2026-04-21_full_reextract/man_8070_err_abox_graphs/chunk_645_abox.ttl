@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_8128
    a               ex:Alarma ;
    rdfs:label      "Error 8128: Fallo en recuperación de datos FRAM"@es ;
    ex:identificador "8128" ;
    ex:textoExtracto "No se han podido recuperar los datos de FRAM. [...] Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM."@es .

ex:DiagnosticoFallo_8128
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Diagnóstico para alarma 8128: Verificación EtherCAT y nodos remotos"@es ;
    ex:textoExtracto "SOLUCIÓN Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos."@es ;
    ex:solucionaFallo ex:Alarma_8128 .

ex:ComponenteElectrico_FRAM
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo FRAM"@es ;
    ex:textoExtracto "datos de FRAM"@es ;
    ex:activaAlarma  ex:Alarma_8128 .

ex:ComponenteElectrico_RAM
    a               ex:ComponenteElectrico ;
    rdfs:label      "Memoria RAM de respaldo"@es ;
    ex:textoExtracto "Se arranca con los datos de RAM"@es .