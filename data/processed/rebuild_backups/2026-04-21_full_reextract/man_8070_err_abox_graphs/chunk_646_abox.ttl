@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:FalloRecuperacionDatosFRAM_8128
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Fallo recuperación datos FRAM (8128)" ;
    ex:identificador     "8128" ;
    ex:textoExtracto    "No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM. SOLUCIÓN Reiniciar el CNC." .

ex:FalloLexerEnteros_8200
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "'Fallo del lexer al reconocer enteros' (8200)" ;
    ex:identificador     "8200" ;
    ex:textoExtracto    "'Fallo del lexer al reconocer enteros' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto. SOLUCIÓN Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable." .

ex:FalloLexerFlotantes_8201
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "'Fallo del lexer al reconocer flotantes' (8201)" ;
    ex:identificador     "8201" ;
    ex:textoExtracto    "'Fallo del lexer al reconocer flotantes' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto. SOLUCIÓN Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable." .

ex:FaltaAperturaComentarios_8203
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "'Falta apertura de comentarios' (8203)" ;
    ex:identificador     "8203" ;
    ex:textoExtracto    "'Falta apertura de comentarios' DETECCIÓN Durante la edición. CAUSA Programado el carácter de cierre de comentario sin haber programado antes el carácter de comienzo. SOLUCIÓN Comprobar que los comentarios tienen tanto el carácter de apertura '(' como el de cierre ')'. DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Programada una sentencia sin el carácter '#' o una instrucción de control de flujo sin el carácter '$'. SOLUCIÓN Toda sentencia debe comenzar por el carácter '#' y toda instrucción de control de flujo debe comenzar por el carácter '$'." .

ex:FaltaCaracterDolar_8205
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "'Falta '$'' (8205)" ;
    ex:identificador     "8205" ;
    ex:textoExtracto    "'Falta '$'' DETECCIÓN Durante la edición. CAUSA Programada una instrucción de control sin el carácter de inicio '$'. SOLUCIÓN Programar '$' antes del nombre de la instrucción de control." .

ex:FaltaCaracterAlmohadilla_8206
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "'Falta '#'' (8206)" ;
    ex:identificador     "8206" ;
    ex:textoExtracto    "'Falta '#'' DETECCIÓN Durante la edición. CAUSA Programada una sentencia sin el carácter de inicio '#'. SOLUCIÓN Programar '#' antes del nombre de la sentencia." .