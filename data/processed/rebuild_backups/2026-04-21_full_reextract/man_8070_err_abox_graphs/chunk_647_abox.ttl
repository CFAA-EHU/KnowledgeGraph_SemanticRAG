@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error8206
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8206: Falta '#'" ;
    ex:textoExtracto "8206 'Falta '#'' DETECCIÓN Durante la edición. CAUSA Programada una sentencia sin el carácter de inicio \"#\"." ;
    ex:identificador "8206" .

ex:Error8207
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8207: Nombre de programa o subrutina demasiado largo" ;
    ex:textoExtracto "8207 'Nombre de programa o subrutina demasiado largo' DETECCIÓN Durante la edición. CAUSA Superado el máximo número de caracteres" ;
    ex:identificador "8207" .

ex:SolucionError8206
    a ex:AccionProhibida ;
    rdfs:label "Solución para Error 8206: Programar '#' antes del nombre de la sentencia" ;
    ex:textoExtracto "SOLUCIÓN Programar \"#\" antes del nombre de la sentencia." ;
    ex:solucionaFallo ex:Error8206 .

ex:SolucionError8207
    a ex:AccionProhibida ;
    rdfs:label "Solución para Error 8207: No exceder el máximo de caracteres en nombre de programa/subrutina" ;
    ex:textoExtracto "Superado el máximo número de caracteres" ;
    ex:solucionaFallo ex:Error8207 .