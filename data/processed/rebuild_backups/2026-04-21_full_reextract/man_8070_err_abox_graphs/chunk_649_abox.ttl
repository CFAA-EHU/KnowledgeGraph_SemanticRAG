ex:Error_8215
    a ex:DiagnosticoFallo ;
    rdfs:label "Excedido formato para función" ;
    ex:textoExtracto "'Excedido formato para función' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8215" .

ex:Error_8217
    a ex:DiagnosticoFallo ;
    rdfs:label "Excedidos límites para flotantes" ;
    ex:textoExtracto "'Excedidos límites para flotantes' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8217" .

ex:Error_8218
    a ex:DiagnosticoFallo ;
    rdfs:label "Carácter no válido" ;
    ex:textoExtracto "'Carácter no" ;
    ex:identificador "8218" .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8215 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8217 ex:solucionaFallo ex:ManualProgramacion .