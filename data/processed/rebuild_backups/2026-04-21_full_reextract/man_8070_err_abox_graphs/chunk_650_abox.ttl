@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8218
    a ex:AvisoSeguridad ;
    rdfs:label "Carácter no válido" ;
    ex:identificador "8218" ;
    ex:textoExtracto "8218 'Carácter no válido' DETECCIÓN Durante la edición. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque." .

ex:Error_8219
    a ex:AvisoSeguridad ;
    rdfs:label "Cadena de error vacía" ;
    ex:identificador "8219" ;
    ex:textoExtracto "8219' Cadena de error vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8220
    a ex:AvisoSeguridad ;
    rdfs:label "Cadena de Warning vacía" ;
    ex:identificador "8220" ;
    ex:textoExtracto "8220 'Cadena de Warning vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8221
    a ex:AvisoSeguridad ;
    rdfs:label "Error sintáctico" ;
    ex:identificador "8221" ;
    ex:textoExtracto "8221 'Error sintáctico' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia o variable programada no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable." .

ex:Error_8222
    a ex:AvisoSeguridad ;
    rdfs:label "Función M inexistente" ;
    ex:identificador "8222" ;
    ex:textoExtracto "8222 'Función M inexistente' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ex:Error_8223
    a ex:AvisoSeguridad ;
    rdfs:label "Exclusividad mutua o funciones M iguales" ;
    ex:identificador "8223" ;
    ex:textoExtracto "8223 'Exclusividad mutua o funciones M iguales' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Hay una función M programada más de una vez en el mismo bloque o hay dos funciones M incompatibles en el mismo bloque. SOLUCIÓN Una función M sólo debe programarse una vez en el bloque. Revisar el manual de programación para comprobar la exclusividad mutua de las funciones M." .

ex:Error_8224
    a ex:AvisoSeguridad ;
    rdfs:label "Función M fuera de rango" ;
    ex:identificador "8224" ;
    ex:textoExtracto "8224 'Función M fuera de rango' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ex:Error_8225
    a ex:AvisoSeguridad ;
    rdfs:label "Función G fuera de rango" ;
    ex:identificador "8225" ;
    ex:textoExtracto "8225 'Función G fuera de rango' DETECCIÓN Durante la edición y ejecución en MDI." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8218 ex:solucionaFallo ex:ManualProgramacion .
