@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Alarma_8226
    a ex:Alarma ;
    rdfs:label "Función H fuera de rango" ;
    ex:identificador "8226" ;
    ex:textoExtracto "8226 'Función H fuera de rango' DETECCIÓN Durante la edición. CAUSA La función H programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones H existentes." .

ex:Alarma_8227
    a ex:Alarma ;
    rdfs:label "Sólo se permite una S negativa con G63" ;
    ex:identificador "8227" ;
    ex:textoExtracto "8227 'Sólo se permite una S negativa con G63' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de cabezal negativa sin haber programado la función G63 en el bloque. SOLUCIÓN La velocidad de cabezal debe ser positiva; sólo se permite un valor negativo si se programa en el mismo bloque que la función G63." .

ex:Alarma_8228
    a ex:Alarma ;
    rdfs:label "Número de herramienta fuera de rango" ;
    ex:identificador "8228" ;
    ex:textoExtracto "8228 'Número de herramienta fuera de rango' DETECCIÓN Durante la edición. CAUSA Programado un número de herramienta negativo. SOLUCIÓN El número de herramienta ha de ser siempre positivo o nulo." .

ex:Alarma_8229
    a ex:Alarma ;
    rdfs:label "F o E fuera de rango" ;
    ex:identificador "8229" ;
    ex:textoExtracto "8229 'F o E fuera de rango' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Alarma_8230
    a ex:Alarma ;
    rdfs:label "Velocidad F doblemente programada" ;
    ex:identificador "8230" ;
    ex:textoExtracto "8230 'Velocidad F doblemente programada' DETECCIÓN Durante la edición. CAUSA La función F está programada más de una vez en el bloque. SOLUCIÓN Programar la función F una sola vez en el bloque." .

ex:Alarma_8232
    a ex:Alarma ;
    rdfs:label "A doblemente programada" ;
    ex:identificador "8232" ;
    ex:textoExtracto "8232 'A doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje A más de una vez en el bloque. SOLUCIÓN Programar el eje A una sola vez en el bloque." .

ex:Alarma_8233
    a ex:Alarma ;
    rdfs:label "B doblemente programada" ;
    ex:identificador "8233" ;
    ex:textoExtracto "8233 'B doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje B más de una vez en el bloque. SOLUCIÓN Programar el eje B una sola vez en el bloque." .

ex:Alarma_8234
