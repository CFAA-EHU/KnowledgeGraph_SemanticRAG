ex:Error_8275
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de funciones M en un mismo bloque sobrepasado"@es ;
    ex:identificador "8275" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones M permitidas en un mismo bloque. SOLUCIÓN El número máximo de funciones M permitidas en un mismo bloque es 7."@es .

ex:Error_8276
    a ex:DiagnosticoFallo ;
    rdfs:label "Límite de funciones H en un mismo bloque sobrepasado"@es ;
    ex:identificador "8276" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Superado el número máximo de funciones H permitidas en un mismo bloque. SOLUCIÓN El número máximo de funciones H permitidas en un mismo bloque es 7."@es .

ex:Error_8279
    a ex:DiagnosticoFallo ;
    rdfs:label "Imagen espejo repetida"@es ;
    ex:identificador "8279" ;
    ex:textoExtracto "DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque. La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque."@es .

ex:FuncionesMatematicas a ex:Tabla ;
     a ex:InterfazUsuario ;
    rdfs:label "Funciones matemáticas (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)"@es ;
    ex:textoExtracto "Funciones matemáticas: LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN."@es .

ex:FuncionesG10_G14 a ex:Tabla ;
