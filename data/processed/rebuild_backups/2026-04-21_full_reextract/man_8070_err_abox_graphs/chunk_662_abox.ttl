@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8280
    a ex:AvisoSeguridad ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ex:identificador "8280" ;
    ex:textoExtracto "8280 'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de posicionamiento negativa en M19. SOLUCIÓN La velocidad de posicionamiento \"Sn. POS\" debe ser positiva." .

ex:AvisoSeguridad_8281
    a ex:AvisoSeguridad ;
    rdfs:label "Velocidad de posicionamiento del cabezal doblemente programada" ;
    ex:identificador "8281" ;
    ex:textoExtracto "8281 'Velocidad de posicionamiento del cabezal doblemente programada' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA En un mismo bloque hay programado más de una vez la velocidad de posicionamiento del cabezal en M19. SOLUCIÓN Programar una única vez la velocidad de posicionamiento del cabezal \"Sn. POS\"." .

ex:AvisoSeguridad_8282
    a ex:AvisoSeguridad ;
    rdfs:label "Parámetro de ciclo fijo repetido" ;
    ex:identificador "8282" ;
    ex:textoExtracto "8282 'Parámetro de ciclo fijo repetido' DETECCIÓN Durante la edición. CAUSA Algún parámetro del ciclo fijo está programado más de una vez en el bloque. SOLUCIÓN Cada parámetro del ciclo fijo sólo se puede programar una vez en el bloque." .

ex:AvisoSeguridad_8283
    a ex:AvisoSeguridad ;
    rdfs:label "Parámetro no válido en ciclo fijo" ;
    ex:identificador "8283" ;
    ex:textoExtracto "8283 'Parámetro no válido en ciclo fijo' DETECCIÓN Durante la edición. CAUSA Programado un parámetro no válido para ese ciclo fijo. SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ex:AvisoSeguridad_8284
    a ex:AvisoSeguridad ;
    rdfs:label "Variable de PLC sin permiso de escritura" ;
    ex:identificador "8284" ;
    ex:textoExtracto "8284 'Variable de plc sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ex:AvisoSeguridad_8285
    a ex:AvisoSeguridad ;
    rdfs:label "G20: solo se admite signo negativo en el eje longitudinal" ;
    ex:identificador "8285" ;
    ex:textoExtracto "8285 'G20: sólo se admite signo negativo en el eje longitudinal' DETECCIÓN Durante la edición. CAUSA En la función G20 hay programado un eje con signo negativo y no es el longitudinal. SOLUCIÓN En la función G20 sólo el eje longitudinal puede tener signo negativo." .

ex:AvisoSeguridad_8287
    a ex:AvisoSeguridad ;
    rdfs:label "Excedidos límites para parte entera" ;
    ex:identificador "8287" ;
    ex:textoExtracto "8287 'Excedidos límites para parte entera' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Parametro_Sn_POS
    a ex:Parametro ;
    rdfs:label "Sn. POS (velocidad de posicionamiento del cabezal)" ;
    ex:textoExtracto "La velocidad de posicionamiento \"Sn. POS\" debe ser positiva." .

ex:Funcion_G20 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "G20 (función de programación)" ;
    ex:textoExtracto "En la función G20 sólo el eje longitudinal puede tener signo negativo." .