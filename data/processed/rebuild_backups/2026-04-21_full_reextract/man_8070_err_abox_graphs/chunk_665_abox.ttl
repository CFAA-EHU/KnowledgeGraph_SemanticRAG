@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_8300
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8300: 'Se precisa al menos un eje para G170, G171 o G157'"@es ;
    ex:identificador "8300" ;
    ex:textoExtracto "8300 'Se precisa al menos un eje para G170, G171 o G157' DETECCIÓN Durante la edición. CAUSA No se ha programado ningún eje con la función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157."@es .

ex:DiagnosticoFallo_8302
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8302: 'La coordenada X mínima debe ser menor que la máxima'"@es ;
    ex:identificador "8302" ;
    ex:textoExtracto "8302 'La coordenada X mínima debe ser menor que la máxima' DETECCIÓN Durante la"@es .

ex:DiagnosticoFallo_SintaxisParametros
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis: parámetros entre corchetes"@es ;
    ex:textoExtracto "CAUSA La sentencia programada exige que su lista de parámetros se programe entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .