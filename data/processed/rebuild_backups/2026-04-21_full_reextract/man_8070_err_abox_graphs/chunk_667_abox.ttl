@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_8309
    a ex:DiagnosticoFallo ;
    rdfs:label "Demasiados ejes programados" ;
    ex:identificador "8309" ;
    ex:textoExtracto "8309 'Demasiados ejes programados' [...] CAUSA Demasiados ejes programados en la sentencia #POLY. SOLUCIÓN El número máximo de ejes que se pueden programar es 3." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Límite de ejes en #POLY" ;
        ex:valor "3" ;
        ex:textoExtracto "El número máximo de ejes que se pueden programar es 3."
    ] .

ex:Fallo_8310
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta parámetro obligatorio" ;
    ex:identificador "8310" ;
    ex:textoExtracto "8310 'Falta parámetro obligatorio' [...] CAUSA Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE" ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Parámetros obligatorios en #POLY, #CS, #ACS, #PROBE" ;
        ex:textoExtracto "Revisar en el manual de programación la sintaxis de las sentencias #POLY, #CS, #ACS o #PROBE."
    ] .

ex:Fallo_G4
    a ex:DiagnosticoFallo ;
    rdfs:label "Función G4 mal programada" ;
    ex:textoExtracto "CAUSA Función G4 mal programada. SOLUCIÓN La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera." ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Sintaxis de G4" ;
        ex:valor "<time>" ;
        ex:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera."
    ] .