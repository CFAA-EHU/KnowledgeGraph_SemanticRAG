@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8316
    a ex:Alarma ;
    rdfs:label "Alarma 8316: 'Parámetro no permitido'"@es ;
    ex:identificador "8316" ;
    ex:textoExtracto "'Parámetro no permitido' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Algún parámetro del ciclo o la sentencia no es válido. SOLUCIÓN Revisar en el manual de programación los parámetros válidos para cada ciclo y sentencia."@es ;
    ex:monitoreaParametro ex:Parametro_CicloSentencia_8316 .

ex:Parametro_CicloSentencia_8316
    a ex:Parametro ;
    rdfs:label "Parámetro de ciclo o sentencia (Alarma 8316)"@es ;
    ex:textoExtracto "parámetro del ciclo o la sentencia"@es .

ex:Alarma_8317
    a ex:Alarma ;
    rdfs:label "Alarma 8317: 'Función D negativa'"@es ;
    ex:identificador "8317" ;
    ex:textoExtracto "'Función D negativa' DETECCIÓN Durante la edición. CAUSA Corrector de herramienta negativo. SOLUCIÓN El corrector de herramienta debe ser positivo."@es ;
    ex:monitoreaParametro ex:Parametro_CorrectorHerramienta_8317 .

ex:Parametro_CorrectorHerramienta_8317
    a ex:Parametro ;
    rdfs:label "Corrector de herramienta (Función D, Alarma 8317)"@es ;
    ex:textoExtracto "Corrector de herramienta"@es ;
    ex:valor "negativo"@es .

ex:Alarma_8318
    a ex:Alarma ;
    rdfs:label "Alarma 8318: 'Sólo se permite un eje activo 1 por bloque'"@es ;
    ex:identificador "8318" ;
    ex:textoExtracto "'Sólo se permite un eje activo 1 por bloque' DETECCIÓN Durante la edición. CAUSA El eje @1 está programado más de una vez en el bloque."@es ;
    ex:monitoreaParametro ex:Parametro_EjeActivo_8318 .

ex:Parametro_EjeActivo_8318
    a ex:Parametro ;
    rdfs:label "Eje activo @1 (Alarma 8318)"@es ;
    ex:textoExtracto "eje @1"@es .