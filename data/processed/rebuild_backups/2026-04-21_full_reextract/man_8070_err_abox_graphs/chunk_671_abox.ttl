@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_8326 a ex:DiagnosticoFallo ;
    rdfs:label "Error 8326: 'No se esperaba espacio'"@es ;
    ex:textoExtracto "8326 'No se esperaba espacio' [...] CAUSA Hay un espacio en blanco incorrecto. SOLUCIÓN Eliminar el espacio en blanco."@es ;
    ex:identificador "8326" .

ex:Fallo_8327 a ex:DiagnosticoFallo ;
    rdfs:label "Error 8327: 'Falta algún paréntesis'"@es ;
    ex:textoExtracto "8327 'Falta algún paréntesis' [...] CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre. SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre."@es ;
    ex:identificador "8327" .

ex:Fallo_8328 a ex:DiagnosticoFallo ;
    rdfs:label "Error 8328: '#SET AX: sólo se permite posición cero'"@es ;
    ex:textoExtracto "8328 '#SET AX: sólo se permite posición cero' [...] CAUSA En la sentencia #SET AX se ha programado un valor"@es ;
    ex:identificador "8328" .

ex:Tarea_EliminarSaltoLinea a ex:TareaMantenimiento ;
    rdfs:label "Eliminar salto de línea incorrecto"@es ;
    ex:textoExtracto "SOLUCIÓN Eliminar el salto de línea."@es ;
    ex:solucionaFallo ex:Fallo_8326 .

ex:Tarea_EliminarEspacioBlanco a ex:TareaMantenimiento ;
    rdfs:label "Eliminar espacio en blanco incorrecto"@es ;
    ex:textoExtracto "SOLUCIÓN Eliminar el espacio en blanco."@es ;
    ex:solucionaFallo ex:Fallo_8326 .

ex:Tarea_ComprobarParentesis a ex:TareaMantenimiento ;
    rdfs:label "Comprobar paréntesis de apertura/cierre"@es ;
    ex:textoExtracto "SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre."@es ;
    ex:solucionaFallo ex:Fallo_8327 .