@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8343
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en '#INCJOG[[valorIncremento, valorAvance],..., [...]] nombreEje'" ;
    ex:identificador "8343" ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8343 '#INCJOG[[valorIncremento, valorAvance],..., [...]] nombreEje' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8344
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en '#SET OFFSET[inferior, superior]eje'" ;
    ex:identificador "8344" ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8344 '#SET OFFSET[inferior, superior]eje' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8345
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en '#LINK[maestro, esclavo <,error>]...[...]'" ;
    ex:identificador "8345" ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8345 '#LINK[maestro, esclavo <,error>]...[...]' DETECCIÓN Durante" .