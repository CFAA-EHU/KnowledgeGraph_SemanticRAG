@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8345 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#LINK[maestro, esclavo <,error>]...[...]'" ;
    ex:identificador "8345" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8345 '#LINK[maestro, esclavo <,error>]...[...]'" .

ex:Error_8346 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#ROUNDPAR[param, …]'" ;
    ex:identificador "8346" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8346 '#ROUNDPAR[param, …]: error de sintaxis'" .

ex:Error_8347 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#ASPLINE MODE [<inicial> <, final>]'" ;
    ex:identificador "8347" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8347 '#ASPLINE MODE [<inicial> <, final>]: error de sintaxis'" .

ex:Error_8348 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#ASPLINE STARTTANG/ENDTANG ejes'" ;
    ex:identificador "8348" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8348 '#ASPLINE STARTTANG/ENDTANG ejes: error de sintaxis'" .

ex:Error_8349 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#SLOPE[tipo <,jerk> <,acel> <,mov>]'" ;
    ex:identificador "8349" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8349 '#SLOPE[tipo <,jerk> <,acel> <,mov>]: error de sintaxis'" .

ex:Error_8350 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TLC ON[n]'" ;
    ex:identificador "8350" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8350 '#TLC ON[n]': error de sintaxis'" .

ex:Error_8351 a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#KIN ID <[cinemática]>'" ;
    ex:identificador "8351" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8351 '#KIN ID <[cinemática]>: error de sintaxis'" .

ex:ManualProgramacion a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8345 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8346 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8347 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8348 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8349 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8350 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8351 ex:solucionaFallo ex:ManualProgramacion .