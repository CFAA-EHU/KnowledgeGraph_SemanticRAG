@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8360 a ex:DiagnosticoFallo ;
    ex:identificador "8360" ;
    ex:textoExtracto "#DGWZ[Eje1min, Eje1max, Eje2min, Eje2max <, Eje3min, Eje3max>] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8361 a ex:DiagnosticoFallo ;
    ex:identificador "8361" ;
    ex:textoExtracto "#CD ON <[horizonte]> [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8362 a ex:DiagnosticoFallo ;
    ex:identificador "8362" ;
    ex:textoExtracto "#PATH[\"path\"] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:ManualProgramacion a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .