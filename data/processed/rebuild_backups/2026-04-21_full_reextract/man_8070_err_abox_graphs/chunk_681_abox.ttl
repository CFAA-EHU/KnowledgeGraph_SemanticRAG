@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8369
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8369: Sintaxis incorrecta en #EXEC" ;
    ex:identificador "8369" ;
    ex:textoExtracto "#EXEC[\"path\" <,canal>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8370
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8370: Sintaxis incorrecta en #WAIT/#MEET" ;
    ex:identificador "8370" ;
    ex:textoExtracto "#WAIT/#MEET [marca, canal, ...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8371
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8371: Sintaxis incorrecta en #SIGNAL" ;
    ex:identificador "8371" ;
    ex:textoExtracto "#SIGNAL[marca, ...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8369 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8370 ex:solucionaFallo ex:ManualProgramacion .
ex:Error_8371 ex:solucionaFallo ex:ManualProgramacion .