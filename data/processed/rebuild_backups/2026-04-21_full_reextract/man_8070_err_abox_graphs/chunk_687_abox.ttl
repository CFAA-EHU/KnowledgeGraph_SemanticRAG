@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error8397
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8397: Sintaxis incorrecta en '#MASTER nombre_cabezal'"@es ;
    ex:identificador "8397" ;
    ex:textoExtracto "#MASTER nombre_cabezal' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Error8398
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8398: Sintaxis incorrecta en '#FREE SP/#CALL SP/#SET SP[nombre_cabezal, ...]'"@es ;
    ex:identificador "8398" ;
    ex:textoExtracto "#FREE SP/#CALL SP/#SET SP[nombre_cabezal, ...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Error8399
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8399: Sintaxis incorrecta en '#RENAME SP[nombre_cabezal_anterior, nombre_cabezal_nuevo]'"@es ;
    ex:identificador "8399" ;
    ex:textoExtracto "#RENAME SP[nombre_cabezal_anterior, nombre_cabezal_nuevo][...][...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .