@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagnosticoFallo_8414
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#UNSYNC[cabezal_esclavo <, cabezal_esclavo...]'" ;
    ex:identificador "8414" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8414 '#UNSYNC[cabezal_esclavo <, cabezal_esclavo...]'" ;
    ex:solucionaFallo ex:AccionProhibida_8414 .

ex:AccionProhibida_8414
    a ex:AccionProhibida ;
    rdfs:label "Sintaxis incorrecta en sentencia #UNSYNC" ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta" .

ex:DiagnosticoFallo_8415
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de parámetros en '#FOLLOW ON' y '#SYNC'" ;
    ex:identificador "8415" ;
    ex:textoExtracto "8415 'Numerador/denominador: programar ambos o ninguno' [...] En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede" ;
    ex:solucionaFallo ex:AccionProhibida_8415 .

ex:AccionProhibida_8415
    a ex:AccionProhibida ;
    rdfs:label "Programación parcial de parámetros D/N en #FOLLOW ON o #SYNC" ;
    ex:textoExtracto "falta programar uno de los parámetros D o N. [...] no se puede [programar solo uno]" .

ex:Parametro_D
    a ex:Parametro ;
    rdfs:label "Parámetro D (denominador)" ;
    ex:textoExtracto "parámetros D o N" ;
    ex:monitoreaParametro ex:Sistema_ControlProgramable .

ex:Parametro_N
    a ex:Parametro ;
    rdfs:label "Parámetro N (numerador)" ;
    ex:textoExtracto "parámetros D o N" ;
    ex:monitoreaParametro ex:Sistema_ControlProgramable .

ex:Sistema_ControlProgramable
    a ex:Sistema ;
    rdfs:label "Sistema de control programable" ;
    ex:textoExtracto "#UNSYNC, #FOLLOW ON, #SYNC" ;
    ex:tieneComponente ex:Parametro_D, ex:Parametro_N .