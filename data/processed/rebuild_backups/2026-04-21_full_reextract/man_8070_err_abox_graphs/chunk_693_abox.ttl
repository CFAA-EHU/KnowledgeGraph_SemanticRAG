@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8423
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8423: Sintaxis incorrecta en '#OSC eje1 eje2 ...'"@es ;
    ex:identificador "8423" ;
    ex:textoExtracto "8423 '#OSC eje1 eje2 ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:solucionaFallo ex:FalloSintaxis8423 .

ex:FalloSintaxis8423
    a ex:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#OSC eje1 eje2 ...'"@es ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ex:Error8424
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8424: Sintaxis incorrecta en '#CLEAR<[marca, ...]>'"@es ;
    ex:identificador "8424" ;
    ex:textoExtracto "8424 '#CLEAR<[marca, ...]>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:solucionaFallo ex:FalloSintaxis8424 .

ex:FalloSintaxis8424
    a ex:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#CLEAR<[marca, ...]>'"@es ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ex:Error8425
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8425: Sintaxis incorrecta en '#HSC OFF'"@es ;
    ex:identificador "8425" ;
    ex:textoExtracto "8425 '#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es ;
    ex:solucionaFallo ex:FalloSintaxis8425 .

ex:FalloSintaxis8425
    a ex:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en '#HSC OFF'"@es ;
    ex:textoExtracto "La sintaxis de la sentencia no es correcta."@es .