@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8055" .

ex:DiagnosticoFallo_8440
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8440: Sintaxis incorrecta en PCALL/MCALL/PROBE"@es ;
    ex:textoExtracto "'(PCALL/MCALL/PROBE expresión <,param>)' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8440" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8441
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8441: Sentencia MDOFF mal programada"@es ;
    ex:textoExtracto "'(MDOFF)' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque"@es ;
    ex:identificador "8441" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8442
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8442: Sintaxis incorrecta en EXEC P(expresión)"@es ;
    ex:textoExtracto "'(EXEC P(expresión) <,directorio>)' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8442" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8443
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8443: Acción no permitida en sentencia IF"@es ;
    ex:textoExtracto "'Acción no permitida en sentencia IF' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8443" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8444
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8444: Función G mal programada"@es ;
    ex:textoExtracto "Función G mal programada. [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8444" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8445
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8445: Número de ejes programado incorrecto"@es ;
    ex:textoExtracto "'Número de ejes programado incorrecto' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8445" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:DiagnosticoFallo_8446
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8446: Bloque G2/G3 con parámetros I,J,K no admitidos"@es ;
    ex:textoExtracto "'El bloque G2/G3 programado no admite parámetros I, J, K' [...] SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta"@es ;
    ex:identificador "8446" ;
    ex:solucionaFallo ex:Manual_8055 .

ex:Parametro_I
    a ex:Parametro ;
    rdfs:label "Parámetro I (centro de interpolación)"@es ;
    ex:textoExtracto "parámetros I, J, K para definir el centro de la interpolación"@es ;
    ex:identificador "I" .

ex:Parametro_J
    a ex:Parametro ;
    rdfs:label "Parámetro J (centro de interpolación)"@es ;
    ex:textoExtracto "parámetros I, J, K para definir el centro de la interpolación"@es ;
    ex:identificador "J" .

ex:Parametro_K
    a ex:Parametro ;
    rdfs:label "Parámetro K (centro de interpolación)"@es ;
    ex:textoExtracto "parámetros I, J, K para definir el centro de la interpolación"@es ;
    ex:identificador "K" .