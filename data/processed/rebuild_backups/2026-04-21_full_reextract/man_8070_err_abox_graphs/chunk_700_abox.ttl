@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8448
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de parámetros I,J,K"@es ;
    ex:identificador "8448" ;
    ex:textoExtracto "Programación incorrecta de parámetros I,J,K. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "parámetros I,J,K"@es ;
        ex:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es
    ] .

ex:Error8449
    a ex:DiagnosticoFallo ;
    rdfs:label "Mezcla de coordenadas cartesianas y polares"@es ;
    ex:identificador "8449" ;
    ex:textoExtracto "No se permite mezclar coordenadas cartesianas y polares en el mismo bloque. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:Error8450
    a ex:DiagnosticoFallo ;
    rdfs:label "Función G sin soporte para programación helicoidal"@es ;
    ex:identificador "8450" ;
    ex:textoExtracto "La función G programada no admite programación helicoidal. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:Error8451
    a ex:DiagnosticoFallo ;
    rdfs:label "Función G sin soporte para programación de rosca"@es ;
    ex:identificador "8451" ;
    ex:textoExtracto "La función G programada no admite programación de rosca. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:Error8452
    a ex:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de rosca (G33/G34)"@es ;
    ex:identificador "8452" ;
    ex:textoExtracto "'Programación incorrecta de la rosca' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G33/G34. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "función G33/G34"@es ;
        ex:textoExtracto "Programación incorrecta de la función G33/G34"@es
    ] .

ex:Error8453
    a ex:DiagnosticoFallo ;
    rdfs:label "Término desconocido en programación"@es ;
    ex:identificador "8453" ;
    ex:textoExtracto "Palabra desconocida o incompleta tras bloque correcto. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Se ha programado un termino desconocido. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ex:Error8454
    a ex:DiagnosticoFallo ;
    rdfs:label "Valor incorrecto del parámetro E (G49)"@es ;
    ex:identificador "8454" ;
    ex:textoExtracto "'Valor de parámetro E incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro E en la función G49."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "parámetro E (función G49)"@es ;
        ex:textoExtracto "Valor incorrecto del parámetro E en la función G49"@es
    ] .

ex:ParametroI
    a ex:Parametro ;
    rdfs:label "parámetro I"@es ;
    ex:textoExtracto "parámetros I, J, K"@es .

ex:ParametroJ
    a ex:Parametro ;
    rdfs:label "parámetro J"@es ;
    ex:textoExtracto "parámetros I, J, K"@es .

ex:ParametroK
    a ex:Parametro ;
    rdfs:label "parámetro K"@es ;
    ex:textoExtracto "parámetros I, J, K"@es .

ex:FuncionG9 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "función G9"@es ;
    ex:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .