@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8469
    a ex:DiagnosticoFallo ;
    ex:identificador "8469" ;
    ex:textoExtracto "'(DW expresión1 = expresión2 <expresión3 = expresión4><...>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    rdfs:label "Error de sintaxis DW en programación 8055" .

ex:Error8470
    a ex:DiagnosticoFallo ;
    ex:identificador "8470" ;
    ex:textoExtracto "'(SK expresión1 = \"texto1\" <expresión2 = \"texto2\"><...>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    rdfs:label "Error de sintaxis SK en programación 8055" .

ex:Error8471
    a ex:DiagnosticoFallo ;
    ex:identificador "8471" ;
    ex:textoExtracto "'(WKEY)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola" ;
    rdfs:label "Error de sintaxis WKEY en programación 8055" .

ex:Manual8055
    a ex:Manual ;
    ex:identificador "8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." ;
    rdfs:label "Manual de programación 8055" .

ex:Error8469 ex:solucionaFallo ex:Manual8055 .
ex:Error8470 ex:solucionaFallo ex:Manual8055 .