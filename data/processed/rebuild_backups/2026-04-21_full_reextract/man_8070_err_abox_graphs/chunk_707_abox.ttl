ex:Fallo_8477
    a ex:DiagnosticoFallo ;
    rdfs:label "Minúsculas no permitidas en 8055" ;
    ex:identificador "8477" ;
    ex:textoExtracto "8477 'Minúsculas no permitidas en 8055' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El lenguaje del 8055 no permite el uso de minúsculas. SOLUCIÓN Programar las palabras reservadas en mayúsculas." .

ex:Fallo_8478
