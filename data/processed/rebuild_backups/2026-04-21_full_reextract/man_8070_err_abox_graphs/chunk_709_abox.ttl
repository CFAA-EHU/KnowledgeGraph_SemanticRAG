@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8484
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 8484: Orden de datos incorrecto" ;
    ex:textoExtracto "'8484 'Orden de datos incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El orden de los datos en el bloque no es correcto. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." ;
    ex:identificador "8484" ;
    ex:documentadoEn ex:Manual_8055 .

ex:AvisoSeguridad_8485
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 8485: #DGSPDL nombre_cabezal" ;
    ex:textoExtracto "'8485 '#DGSPDL nombre_cabezal' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ex:identificador "8485" ;
    ex:documentadoEn ex:Manual_8055 .

ex:AvisoSeguridad_8486
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 8486: Programación no válida en fresadora" ;
    ex:textoExtracto "'8486 'Programación no válida en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G15 en" ;
    ex:identificador "8486" ;
    ex:documentadoEn ex:Manual_8055 .

ex:Manual_8055
    a ex:Manual ;
    rdfs:label "Manual de programación 8055" ;
    ex:textoExtracto "Manual del 8055 (referenciado en avisos 8484, 8485 y 8486)" ;
    ex:identificador "8055" .