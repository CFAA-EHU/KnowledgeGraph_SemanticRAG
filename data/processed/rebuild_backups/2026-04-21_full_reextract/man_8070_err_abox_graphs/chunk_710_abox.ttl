@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8486
    a ex:Alarma ;
    rdfs:label "Programación no válida en fresadora" ;
    ex:identificador "8486" ;
    ex:textoExtracto "8486 'Programación no válida en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G15 en fresadora. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

