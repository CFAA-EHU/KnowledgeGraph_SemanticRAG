ex:Alarma_8488
    a ex:Alarma ;
    rdfs:label "No se admite número de repeticiones" ;
    ex:identificador "8488" ;
    ex:textoExtracto "8488 'No se admite número de repeticiones' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Sólo se permite programar el número de repeticiones en un bloque de movimiento. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ex:Alarma_8489
