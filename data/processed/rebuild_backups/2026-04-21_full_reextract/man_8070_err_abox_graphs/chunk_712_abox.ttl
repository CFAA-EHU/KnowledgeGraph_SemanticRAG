@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8495 a ex:DiagnosticoFallo ;
    ex:identificador "8495" ;
    rdfs:label "Error de sintaxis en sentencia $WHILE" ;
    ex:textoExtracto "$WHILE condición [...] SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Error8496 a ex:DiagnosticoFallo ;
    ex:identificador "8496" ;
    rdfs:label "Orden o dato incorrecto en programación" ;
    ex:textoExtracto "Orden o dato incorrecto. [...] Error al programar en lenguaje del 8055. Se ha programado un término desconocido en el bloque o bien el orden de los términos programados no es correcto."@es .

ex:Error8497 a ex:DiagnosticoFallo ;
    ex:identificador "8497" ;
    rdfs:label "Valor de parámetro K incorrecto" ;
    ex:textoExtracto "'Valor de parámetro K incorrecto' [...] Valor incorrecto del parámetro K para la función G programada."@es .

ex:ParametroK a ex:Parametro ;
    ex:identificador "K" ;
    ex:textoExtracto "parámetro K para la función G programada"@es .

ex:Error8498 a ex:DiagnosticoFallo ;
    ex:identificador "8498" ;
    rdfs:label "Sobra parámetro en función G24/G27" ;
    ex:textoExtracto "'Sobra parámetro' [...] Hay un parámetro de más en la función G24/G27."@es .

ex:FuncionG24 a ex:Parametro ;
    ex:identificador "G24" ;
    ex:textoExtracto "función G24"@es .

ex:FuncionG27 a ex:Parametro ;
    ex:identificador "G27" ;
    ex:textoExtracto "función G27"@es .

ex:Error8499 a ex:DiagnosticoFallo ;
    ex:identificador "8499" ;
    rdfs:label "Parámetros incorrectos en función G" ;
    ex:textoExtracto "'Parámetros incorrectos en función' [...] Hay parámetros inválidos en función G programada"@es .

ex:Error8501 a ex:DiagnosticoFallo ;
    ex:identificador "8501" ;
    rdfs:label "Función o sentencia aislada en bloque" ;
    ex:textoExtracto "La función o sentencia va sola en el bloque. [...] Se ha programado en el bloque algún término no relacionado con la sentencia o función."@es .

ex:Error8502 a ex:DiagnosticoFallo ;
    ex:identificador "8502" ;
    rdfs:label "Interpolación circular en polares sin radio" ;
    ex:textoExtracto "'La interpolación circular en polares no admite radio' [...] Error al programar en lenguaje del 8055."@es .

ex:Lenguaje8055 a ex:Sistema ;
    ex:identificador "8055" ;
    rdfs:label "Lenguaje de programación 8055" ;
    ex:textoExtracto "Error al programar en lenguaje del 8055"@es .

ex:ManualProgramacion8055 a ex:Manual ;
    rdfs:label "Manual de programación del 8055" ;
    ex:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es .

ex:Error8495 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8496 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8497 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8498 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8499 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8501 ex:solucionaFallo ex:ManualProgramacion8055 .
ex:Error8502 ex:solucionaFallo ex:ManualProgramacion8055 .

ex:ParametroK ex:monitoreaParametro ex:FuncionG24 .
ex:ParametroK ex:monitoreaParametro ex:FuncionG27 .