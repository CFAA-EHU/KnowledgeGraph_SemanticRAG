@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8520
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8520: Sintaxis incorrecta en #DELETE"@es ;
    ex:identificador "8520" ;
    ex:textoExtracto "#DELETE nombreVariableUsuario <, nombreVariableUsuario, ...>. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Error8521
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8521: G174 solo permite programar un eje"@es ;
    ex:identificador "8521" ;
    ex:textoExtracto "8521 G174 sólo permite programar un eje. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

