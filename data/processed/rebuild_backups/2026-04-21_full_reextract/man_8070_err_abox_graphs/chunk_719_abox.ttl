@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8527
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #REPOS"@es ;
    ex:identificador "8527" ;
    ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8527 '#REPOS <INT/INI> nombreEje/nombreCabezal …' DETECCIÓN Durante la edición. CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:Fallo_8528
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #VOLCOMP"@es ;
    ex:identificador "8528" ;
    ex:textoExtracto "8528 #VOLCOMP ON/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:Fallo_8529
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #RENAME AX OFF"@es ;
    ex:identificador "8529" ;
    ex:textoExtracto "8529 #RENAME AX OFF"@es ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta."@es .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación"@es ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ex:Fallo_8527 ex:documentadoEn ex:ManualProgramacion .
ex:Fallo_8528 ex:documentadoEn ex:ManualProgramacion .
ex:Fallo_8529 ex:documentadoEn ex:ManualProgramacion .