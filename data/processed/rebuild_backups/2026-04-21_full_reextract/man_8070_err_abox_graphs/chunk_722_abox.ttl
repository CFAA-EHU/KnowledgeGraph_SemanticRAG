@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8537
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #DEFROT" ;
    ex:identificador "8537" ;
    ex:textoExtracto "#DEFROT[ERROR/WARNING/NONE, criterio, Q valorÁngulo] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8538
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en criterios #DEFROT" ;
    ex:identificador "8538" ;
    ex:textoExtracto "Criterio: LOW(F/S)/DPOS(F/S)/DNEG(F/S)/VPOS(F/S)/VNEG(F/S). [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8539
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #DEFGRAPH" ;
    ex:identificador "8539" ;
    ex:textoExtracto "#DEFGRAPH[\"path\\fichero\"] [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8540
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #RETDSBLK" ;
    ex:identificador "8540" ;
    ex:textoExtracto "#RETDSBLK [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8541
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #COMP3D OFF" ;
    ex:identificador "8541" ;
    ex:textoExtracto "#COMP3D OFF [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8542
    a ex:AvisoSeguridad ;
    rdfs:label "Error de sintaxis en #COMP3D ON" ;
    ex:identificador "8542" ;
    ex:textoExtracto "#COMP3D <ON> <[PARAX/NORMAL]> [...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:Error_8543
    a ex:AvisoSeguridad ;
    rdfs:label "Incompatibilidad entre funciones G y T" ;
    ex:identificador "8543" ;
    ex:textoExtracto "Funciones G y T incompatibles. [...] SOLUCIÓN La función T no puede programarse en el mismo bloque que G801 a G813, G820, G821, G8331 a G833, G840 a G842, G850 o G851." .

ex:Error_8544
    a ex:AvisoSeguridad ;
    rdfs:label "Límite de puntos en función G820" ;
    ex:identificador "8544" ;
    ex:textoExtracto "La función G820 admite como máximo tres puntos." .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ex:Error_8537 ex:solucionaFallo ex:ManualProgramacion .
