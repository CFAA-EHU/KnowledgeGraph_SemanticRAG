@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8544 a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación en G820 (máximo 3 puntos)"@es ;
    ex:textoExtracto "La función G820 admite como máximo tres puntos. [...] Se han programado más de tres puntos en la función G820."@es ;
    ex:identificador "8544" .

ex:Fallo_8545 a ex:DiagnosticoFallo ;
    rdfs:label "Error de programación de radio de arco (G802/803/832/833)"@es ;
    ex:textoExtracto "G802/803/832/833: El radio del arco se programa con I1. [...] Se ha programado incorrectamente el radio del arco en la función G802, G803, G832 o 833."@es ;
    ex:identificador "8545" .

ex:Parametro_I1 a ex:Parametro ;
    rdfs:label "I1 (radio de arco)"@es ;
    ex:textoExtracto "El radio del arco se programa con I1"@es ;
    ex:valor "I1" .

ex:AccionProhibida_ProgramacionConjunta a ex:AccionProhibida ;
    rdfs:label "Programación conjunta de T con G801-G851"@es ;
    ex:textoExtracto "La función T no puede programarse en el mismo bloque que G801 a G813, G820, G821, G8331 a G833, G840 a G842, G850 o G851."@es .