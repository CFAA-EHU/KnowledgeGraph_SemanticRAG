@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8546
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8546: Radio de arco programado incorrectamente" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se ha programado incorrectamente el radio del arco en la función G802, G803, G832 o 833. SOLUCIÓN Programar el radio del arco con \"I1\". 8546 Sólo G802/803/832/833 permiten programar el radio del arco con I1." ;
    ex:identificador "8546" .

ex:Error_8547
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8547: Entidad geométrica no válida" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se ha programado un ente geométrico \"En\" no válido. SOLUCIÓN El rango de valores válidos para un ente geométrico es de 1 a 30. 8547" ;
    ex:identificador "8547" .

ex:Error_8548
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8548: Función G no válida en definición de entidad geométrica" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se ha programado una función G no válida en la definición de un ente geométrico. SOLUCIÓN Las funciones G válidas en la definición de un ente geométrico son G801 a G803, G808 a G811, G813, G820, G821, G831 a G833, G841, G842 y G851. 8548" ;
    ex:identificador "8548" .

ex:Error_8549
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8549: Demasiados elementos en definición de entidad geométrica" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA Se han indicado demasiados elementos en la definición del ente geométrico. SOLUCIÓN El número máximo de elementos a utilizar en la definición de un ente geométrico es 6. 8549" ;
    ex:identificador "8549" .

ex:Error_8550
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8550: Sintaxis incorrecta en sentencia #SELECT" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8550 #SELECT ORI[HEAD1-2/TABLE1-2, HEAD1-2/TABLE1-2]" ;
    ex:identificador "8550" .

ex:Error_8551
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8551: Sintaxis incorrecta en sentencia #KINORG" ;
    ex:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. 8551 #KINORG" ;
    ex:identificador "8551" .

ex:Funcion_G802 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G802" ;
    ex:textoExtracto "Sólo G802/803/832/833 permiten programar el radio del arco con I1." ;
    ex:identificador "G802" .

ex:Funcion_G803 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G803" ;
    ex:textoExtracto "Sólo G802/803/832/833 permiten programar el radio del arco con I1." ;
    ex:identificador "G803" .

ex:Funcion_G832 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G832" ;
    ex:textoExtracto "Sólo G802/803/832/833 permiten programar el radio del arco con I1." ;
    ex:identificador "G832" .

ex:Funcion_G833 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G833" ;
    ex:textoExtracto "Sólo G802/803/832/833 permiten programar el radio del arco con I1." ;
    ex:identificador "G833" .

ex:Parametro_I1
    a ex:Parametro ;
    rdfs:label "Parámetro I1 (radio de arco)" ;
    ex:textoExtracto "Programar el radio del arco con \"I1\"." ;
    ex:identificador "I1" .

ex:Error_8546 ex:solucionaFallo ex:Parametro_I1 .
ex:Error_8546 ex:solucionaFallo ex:Funcion_G802 .
ex:Error_8546 ex:solucionaFallo ex:Funcion_G803 .
ex:Error_8546 ex:solucionaFallo ex:Funcion_G832 .
ex:Error_8546 ex:solucionaFallo ex:Funcion_G833 .