@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8551
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8551: #KINORG" ;
    ex:identificador "8551" ;
    ex:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8551 #KINORG DETECCIÓN Durante la edición y ejecución." .

ex:Error8552
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8552: Parámetro D no permitido en el bloque" ;
    ex:identificador "8552" ;
    ex:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA No se permite programar el parámetro D en el bloque. SOLUCIÓN Corregir la programación." .

ex:Error8553
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8553: Sintaxis incorrecta en #DGWZ" ;
    ex:identificador "8553" ;
    ex:textoExtracto "8553 #DGWZ<CYL>[limInfEje1,limSupEje1,radio/diamInterno,radio/diamExterno]<Pi,Ci,...> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ex:ParametroD
    a ex:Parametro ;
    rdfs:label "Parámetro D" ;
    ex:textoExtracto "Parámetro D no permitido en el bloque." ;
    ex:valor "D" .

ex:ManualProgramacion
    a ex:Manual ;
    rdfs:label "Manual de programación" ;
    ex:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .