@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8569
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8569: Sintaxis incorrecta en #OPEN" ;
    ex:identificador "8569" ;
    ex:textoExtracto "#OPEN[\"fichero\" <, A/D> <, KEEPLINE> <, FhandleFichero>] [...] CAUSA La sintaxis de la sentencia no es correcta." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Revisión de sintaxis en manual de programación" ;
        ex:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."
    ] .

