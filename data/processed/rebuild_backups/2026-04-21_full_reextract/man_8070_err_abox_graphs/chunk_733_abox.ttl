@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_8584
    a ex:Alarma ;
    rdfs:label "Alarma 8584: Programación no permitida con compensación activa"@es ;
    ex:textoExtracto "8584 Programación no permitida con compensación activa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activa la compensación de radio (G41/G42)."@es ;
    ex:identificador "8584" .

ex:Alarma_8585
    a ex:Alarma ;
    rdfs:label "Alarma 8585: Programación no permitida sin movimiento independiente activo"@es ;
    ex:textoExtracto "8585 Programación no permitida sin movimiento independiente activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida"@es ;
    ex:identificador "8585" .

ex:AccionProhibida_8584
    a ex:AccionProhibida ;
    rdfs:label "Programación de sentencia o función G no permitida con compensación de radio activa (G41/G42)"@es ;
    ex:textoExtracto "Se ha programado una sentencia o función G no permitida cuando está activa la compensación de radio (G41/G42)."@es ;
    ex:activaAlarma ex:Alarma_8584 .

ex:AccionProhibida_8585
    a ex:AccionProhibida ;
    rdfs:label "Programación de sentencia o función G no permitida sin movimiento independiente activo"@es ;
    ex:textoExtracto "Se ha programado una sentencia o función G no permitida"@es ;
    ex:activaAlarma ex:Alarma_8585 .