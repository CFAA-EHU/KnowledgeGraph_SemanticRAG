@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8704
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8704: 'Se esperaba recurso o número en lugar de símbolo'"@es ;
    ex:textoExtracto "'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos símbolos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"."@es ;
    ex:identificador "8704" .

ex:AvisoSeguridad_8705
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8705: 'No se puede redefinir recursos'"@es ;
    ex:textoExtracto "'No se puede redefinir recursos' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos recursos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"."@es ;
    ex:identificador "8705" .

ex:AvisoSeguridad_8706
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8706: 'No se puede redefinir números'"@es ;
    ex:textoExtracto "'No se puede redefinir números' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos números. SOLUCIÓN Programar \"DEF/PDEF símbolo"@es ;
    ex:identificador "8706" .