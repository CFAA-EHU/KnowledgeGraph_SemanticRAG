@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8706
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8706: 'No se puede redefinir números'"@es ;
    ex:textoExtracto """
    8706 'No se puede redefinir números'
    DETECCIÓN Durante la edición.
    CAUSA Comando DEF o PDEF. Hay programados dos números.
    SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\".""" ;
    ex:identificador "8706" .

ex:AvisoSeguridad_8707
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8707: 'Falta símbolo seguido de recurso o número'"@es ;
    ex:textoExtracto """
    8707 'Falta símbolo seguido de recurso o número'
    DETECCIÓN Durante la edición.
    CAUSA Comando DEF o PDEF. Falta programar el símbolo y el recurso o el número.
    SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\".""" ;
    ex:identificador "8707" .

ex:AvisoSeguridad_8708
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8708: 'Falta período de módulo periódico'"@es ;
    ex:textoExtracto """
    8708 'Falta período de módulo periódico'
    DETECCIÓN Durante la edición.
    CAUSA Falta programar el periodo del módulo periódico PE.
    SOLUCIÓN Programar \"PE período\".""" ;
    ex:identificador "8708" .

