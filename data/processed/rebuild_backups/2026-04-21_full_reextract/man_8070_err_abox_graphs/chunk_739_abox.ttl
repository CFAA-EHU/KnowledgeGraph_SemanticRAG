@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8724
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta operador y segundo operando del CPS" ;
    ex:textoExtracto "8724 'Falta operador y segundo operando del CPS' [...] CAUSA Falta el operador y el segundo recurso del comando CPS." ;
    ex:identificador "8724" .

ex:Fallo_8725
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta primer operando del CPS" ;
    ex:textoExtracto "8725 'Falta primer operando del CPS' [...] CAUSA Falta el primer" ;
    ex:identificador "8725" .

ex:Comando_CPS
    a ex:Parametro ;
    rdfs:label "Comando CPS (Compare Parameter Set)" ;
    ex:textoExtracto "Programar 'CPS recurso operación recurso'. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ex:Operacion_GT
    a ex:Parametro ;
    rdfs:label "Operación GT (Greater Than)" ;
    ex:textoExtracto "GT" .

ex:Operacion_GE
    a ex:Parametro ;
    rdfs:label "Operación GE (Greater or Equal)" ;
    ex:textoExtracto "GE" .

ex:Operacion_EQ
    a ex:Parametro ;
    rdfs:label "Operación EQ (Equal)" ;
    ex:textoExtracto "EQ" .

ex:Operacion_NE
    a ex:Parametro ;
    rdfs:label "Operación NE (Not Equal)" ;
    ex:textoExtracto "NE" .

ex:Operacion_LE
    a ex:Parametro ;
    rdfs:label "Operación LE (Less or Equal)" ;
    ex:textoExtracto "LE" .

ex:Operacion_LT
    a ex:Parametro ;
    rdfs:label "Operación LT (Less Than)" ;
    ex:textoExtracto "LT" .

ex:Fallo_8724 ex:solucionaFallo ex:Comando_CPS .
ex:Fallo_8725 ex:solucionaFallo ex:Comando_CPS .