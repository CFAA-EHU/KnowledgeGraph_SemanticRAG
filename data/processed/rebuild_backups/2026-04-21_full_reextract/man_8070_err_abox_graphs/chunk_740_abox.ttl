@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridad_8725
    a ex:AvisoSeguridad ;
    rdfs:label "Falta primer operando del CPS" ;
    ex:identificador "8725" ;
    ex:textoExtracto "8725 'Falta primer operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el primer recurso del comando CPS. SOLUCIÓN Programar \"CPS recurso operación recurso\". Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ex:AvisoSeguridad_8726
    a ex:AvisoSeguridad ;
    rdfs:label "Falta primer operando, operador y segundo operando del CPS" ;
    ex:identificador "8726" ;
    ex:textoExtracto "8726 'Falta primer operando, operador y segundo operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el operador y los dos recursos del comando CPS. SOLUCIÓN Programar \"CPS recurso operación recurso\". Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ex:AvisoSeguridad_8727
    a ex:AvisoSeguridad ;
    rdfs:label "Operador de comparación no válido" ;
    ex:identificador "8727" ;
    ex:textoExtracto "8727 'Operador de comparación no válido' DETECCIÓN Durante la edición. CAUSA La operación programada en el comando CPS no es válida. SOLUCIÓN Programar \"CPS recurso operación recurso\". Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ex:AvisoSeguridad_8728
    a ex:AvisoSeguridad ;
    rdfs:label "Falta índice de temporizador en TEN" ;
    ex:identificador "8728" ;
    ex:textoExtracto "8728 'Falta índice de temporizador en TEN' DETECCIÓN Durante la edición. CAUSA Falta el temporizador en el comando TEN. SOLUCIÓN Programar \"TEN temporizador\"." .

ex:AvisoSeguridad_8729
    a ex:AvisoSeguridad ;
    rdfs:label "Falta índice de temporizador en TRS" ;
    ex:identificador "8729" ;
    ex:textoExtracto "8729 'Falta índice de temporizador en TRS' DETECCIÓN Durante la edición. CAUSA Falta el temporizador en el comando TRS. SOLUCIÓN Programar \"TRS temporizador\"." .

ex:AvisoSeguridad_8730
    a ex:AvisoSeguridad ;
    rdfs:label "Falta preselección en TG" ;
    ex:identificador "8730" ;
    ex:textoExtracto "8730 'Falta preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando TG. SOLUCIÓN Programar \"TG temporizador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número." .