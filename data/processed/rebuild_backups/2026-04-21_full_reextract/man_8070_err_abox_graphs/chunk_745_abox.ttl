@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FaltaEtiquetaJMP_8748
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Falta origen o destino en el MOV (Código 8748)"@es ;
    ex:identificador    "8748" ;
    ex:textoExtracto    "8748 Falta origen o destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar 'JMP etiqueta'."@es ;
    ex:solucionaFallo   ex:Accion_ProgramarJMP_8748 .

ex:FaltaEtiquetaJMP_8749
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Falta origen y destino en el MOV (Código 8749)"@es ;
    ex:identificador    "8749" ;
    ex:textoExtracto    "8749 Falta origen y destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar 'JMP etiqueta'."@es ;
    ex:solucionaFallo   ex:Accion_ProgramarJMP_8749 .

ex:FaltaArgumentoADS_8750
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Falta un argumento en la operación ADS (Código 8750)"@es ;
    ex:identificador    "8750" ;
    ex:textoExtracto    "8750 Falta un argumento en la operación ADS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación ADS. SOLUCIÓN Programar 'ADS operando operando resultado'."@es ;
    ex:solucionaFallo   ex:Accion_ProgramarADS_8750 .

ex:Accion_ProgramarJMP_8748
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Programar 'JMP etiqueta' para el fallo 8748"@es ;
    ex:textoExtracto    "SOLUCIÓN Programar 'JMP etiqueta'."@es .

ex:Accion_ProgramarJMP_8749
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Programar 'JMP etiqueta' para el fallo 8749"@es ;
    ex:textoExtracto    "SOLUCIÓN Programar 'JMP etiqueta'."@es .

ex:Accion_ProgramarADS_8750
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Programar 'ADS operando operando resultado' para el fallo 8750"@es ;
    ex:textoExtracto    "SOLUCIÓN Programar 'ADS operando operando resultado'."@es .