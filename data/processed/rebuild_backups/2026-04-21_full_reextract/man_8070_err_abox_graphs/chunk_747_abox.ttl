@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8758
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8758: Faltan todos los argumentos en la operación MLS"@es ;
    ex:identificador "8758" ;
    ex:textoExtracto "8758 Faltan todos los argumentos en la operación MLS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación MLS. SOLUCIÓN Programar \"MLS operando operando resultado\"."@es .

ex:Error_8759
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8759: Falta un argumento en la operación DVS"@es ;
    ex:identificador "8759" ;
    ex:textoExtracto "8759 Falta un argumento en la operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación DVS. SOLUCIÓN Programar \"DVS operando operando resultado\"."@es .

ex:SistemaPLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC (Programmable Logic Controller)"@es ;
    ex:textoExtracto "Durante la edición del programa PLC"@es ;
    ex:activaAlarma ex:Error_8758, ex:Error_8759 .