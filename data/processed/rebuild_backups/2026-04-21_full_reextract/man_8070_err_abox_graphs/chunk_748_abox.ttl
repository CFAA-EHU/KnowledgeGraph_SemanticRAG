ex:Error_8760
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8760: Faltan dos argumentos en la operación DVS" ;
    ex:textoExtracto "8760 Faltan dos argumentos en la operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación DVS. SOLUCIÓN Programar \"DVS operando operando resultado\"." ;
    ex:identificador "8760" .

ex:Error_8761
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8761: Faltan todos los argumentos en la operación DVS" ;
    ex:textoExtracto "8761 Faltan todos los argumentos la en operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación DVS. SOLUCIÓN Programar \"DVS operando operando resultado\"." ;
    ex:identificador "8761" .

