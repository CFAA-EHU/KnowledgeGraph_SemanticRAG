@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorPLC_8777
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8777: Faltan dos argumentos en la operación RR1" ;
    ex:textoExtracto "8777 Faltan dos argumentos en la operación RR1. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación RR1. SOLUCIÓN Programar \"RR1 origen rotaciones destino\"." ;
    ex:identificador "8777" .

ex:ErrorPLC_8778
    a ex:AvisoSeguridad ;
    rdfs:label "Error 8778: Faltan todos los argumentos en la operación RR1" ;
    ex:textoExtracto "8778 Faltan todos argumentos en la operación RR1. DETECCIÓN Durante la edición" ;
    ex:identificador "8778" .

ex:Operacion_RR1
    a ex:Parametro ;
    rdfs:label "Operación RR1 (PLC)" ;
    ex:textoExtracto "Programar \"RR1 origen rotaciones destino\"." .

ex:SistemaPLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "Durante la edición del programa PLC" ;
    ex:tieneComponente ex:Operacion_RR1 ;
    ex:activaAlarma ex:ErrorPLC_8777, ex:ErrorPLC_8778 .