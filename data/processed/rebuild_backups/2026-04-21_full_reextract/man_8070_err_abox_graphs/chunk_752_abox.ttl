@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorPLC_8777
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8777: Faltan dos argumentos en la operación RR1" ;
    ex:identificador "8777" ;
    ex:textoExtracto "Faltan dos argumentos en la operación RR1. SOLUCIÓN Programar \"RR1 origen rotaciones destino\"." ;
    ex:solucionaFallo [
        a ex:InterfazUsuario ;
        rdfs:label "Operación RR1 en programa PLC" ;
        ex:textoExtracto "Programar \"RR1 origen rotaciones destino\"."
    ] .

