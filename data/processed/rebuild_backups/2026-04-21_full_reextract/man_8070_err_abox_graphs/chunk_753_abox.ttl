@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8785 a ex:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación RL2"@es ;
    ex:textoExtracto "8785 Falta un argumento en la operación RL2. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación RL2. SOLUCIÓN Programar \"RL2 origen rotaciones destino\"."@es ;
    ex:identificador "8785" .

ex:Fallo_8786 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan dos argumentos en la operación RL2"@es ;
    ex:textoExtracto "8786 Faltan dos argumentos en la operación RL2. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación RL2. SOLUCIÓN Programar \"RL2 origen rotaciones destino\"."@es ;
    ex:identificador "8786" .

ex:Fallo_8787 a ex:DiagnosticoFallo ;
    rdfs:label "Faltan todos los argumentos en la operación RL2"@es ;
    ex:textoExtracto "8787 Faltan todos argumentos en la operación RL2. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan"@es ;
    ex:identificador "8787" .

ex:Operacion_RL2 a ex:Parametro ;
    rdfs:label "Operación RL2 (PLC)"@es ;
    ex:textoExtracto "operación RL2"@es ;
    ex:valor "RL2 origen rotaciones destino"@es .