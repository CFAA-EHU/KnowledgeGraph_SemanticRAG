@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_8795 a ex:DiagnosticoFallo ;
    rdfs:label "Error sintáctico 8795" ;
    ex:identificador "8795" ;
    ex:textoExtracto "Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La instrucción programada no admite el argumento indicado. SOLUCIÓN Corregir la sintaxis de la línea." .

ex:Error_8796 a ex:DiagnosticoFallo ;
    rdfs:label "Cadena de warning vacía 8796" ;
    ex:identificador "8796" ;
    ex:textoExtracto "Cadena de warning vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un warning sin texto. SOLUCIÓN Definir el texto de warning." .

ex:Error_8797 a ex:DiagnosticoFallo ;
    rdfs:label "Error de índice en ERA 8797" ;
    ex:identificador "8797" ;
    ex:textoExtracto "El segundo argumento debe ser un índice en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA El segundo argumento debe ser un número. SOLUCIÓN El segundo argumento debe ser un número; no hay que programar el tipo de recurso." .

ex:Error_8798 a ex:DiagnosticoFallo ;
    rdfs:label "Período inválido 8798" ;
    ex:identificador "8798" ;
    ex:textoExtracto "El período debe ser mayor que cero. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA En la directiva \"PE\" se ha programado un periodo menor o igual que cero. SOLUCIÓN Programar en la directiva \"PE\" un valor mayor que cero." .

ex:Error_8799 a ex:DiagnosticoFallo ;
    rdfs:label "Símbolo faltante 8799" ;
    ex:identificador "8799" ;
    ex:textoExtracto "Falta el símbolo. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA En las directivas \"DEF/PDEF\" no se ha programado el símbolo del recurso. SOLUCIÓN Programar el símbolo." .

ex:Error_8800 a ex:DiagnosticoFallo ;
    rdfs:label "Exceso de caracteres en símbolo 8800" ;
    ex:identificador "8800" ;
    ex:textoExtracto "Excedido número de caracteres en símbolo. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido. SOLUCIÓN Revisar la programación del bloque. La longitud máxima permitida para el símbolo programado en estas directivas es 46 caracteres." .

ex:Error_8802 a ex:DiagnosticoFallo ;
    rdfs:label "Eje faltante en sentencia 8802" ;
    ex:identificador "8802" ;
    ex:textoExtracto "Falta eje en sentencia. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error_8808 a ex:DiagnosticoFallo ;
    rdfs:label "Operandos OR idénticos 8808" ;
    ex:identificador "8808" ;
    ex:textoExtracto "Los operandos de la expresión OR son iguales. DETECCIÓN Durante la edición o compilación del programa PLC." .

ex:Directiva_PE a ex:Parametro ;
    rdfs:label "Directiva PE (período)" ;
    ex:identificador "PE" ;
    ex:textoExtracto "En la directiva \"PE\" se ha programado un periodo menor o igual que cero." ;
    ex:valor ">0" .

ex:Directiva_DEF a ex:Parametro ;
    rdfs:label "Directiva DEF" ;
    ex:identificador "DEF" ;
    ex:textoExtracto "En las directivas \"DEF/PDEF\" no se ha programado el símbolo del recurso." .

ex:Directiva_PDEF a ex:Parametro ;
    rdfs:label "Directiva PDEF" ;
    ex:identificador "PDEF" ;
    ex:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ex:Directiva_CAL a ex:Parametro ;
    rdfs:label "Directiva CAL" ;
    ex:identificador "CAL" ;
    ex:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ex:Directiva_SUB a ex:Parametro ;
    rdfs:label "Directiva SUB" ;
    ex:identificador "SUB" ;
    ex:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ex:Directiva_EXTERN a ex:Parametro ;
    rdfs:label "Directiva EXTERN" ;
    ex:identificador "EXTERN" ;
    ex:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ex:Comando_CAM a ex:Parametro ;
    rdfs:label "Comando CAM" ;
    ex:identificador "CAM" ;
    ex:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo." .

ex:Comando_FOLLOWOFF a ex:Parametro ;
    rdfs:label "Comando FOLLOWOFF" ;
    ex:identificador "FOLLOWOFF" ;
    ex:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo." .

ex:InterfazUsuario_PLC a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación PLC" ;
    ex:textoExtracto "Durante la edición o compilación del programa PLC." ;
    ex:activaAlarma ex:Error_8795, ex:Error_8796, ex:Error_8797, ex:Error_8798, ex:Error_8799, ex:Error_8800, ex:Error_8802, ex:Error_8808 .