@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8816
    a ex:DiagnosticoFallo ;
    rdfs:label "Salida fuera de rango permitido"@es ;
    ex:identificador "8816" ;
    ex:textoExtracto "8816 Salida fuera de rango permitido. [...] Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8."@es ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Rango válido de salidas digitales"@es ;
        ex:valor "O1-O1024 (globales), O1-O8 (locales)" ;
        ex:textoExtracto "Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8."@es
    ] ;
    ex:solucionaFallo [
        a ex:Parametro ;
        rdfs:label "Rango válido de entradas digitales"@es ;
        ex:valor "I1-I1024 (globales), LI1-LI16 (locales)" ;
        ex:textoExtracto "Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16."@es
    ] .

ex:Fallo_8817
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas"@es ;
    ex:identificador "8817" ;
    ex:textoExtracto "8817 Fallo del lexer al reconocer entradas."@es .