@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_8817
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas" ;
    ex:textoExtracto "8817 Fallo del lexer al reconocer entradas. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." ;
    ex:identificador "8817" .

ex:Fallo_8818
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer salidas" ;
    ex:textoExtracto "8818 Fallo del lexer al reconocer salidas. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a salidas. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." ;
    ex:identificador "8818" .

ex:Fallo_8819
    a ex:DiagnosticoFallo ;
    rdfs:label "Bit de registro fuera de rango" ;
    ex:textoExtracto "8819 Bit de registro fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA El bit programado no es válido. SOLUCIÓN Los bits deben estar estar dentro del rango B0 a B31." ;
    ex:identificador "8819" .

ex:Fallo_8820
    a ex:DiagnosticoFallo ;
    rdfs:label "Mensaje fuera de rango" ;
    ex:textoExtracto "8820 Mensaje fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA El mensaje programado no es válido. SOLUCIÓN Los mensajes deben estar dentro del rango MSG1 a MSG1024." ;
    ex:identificador "8820" .

ex:Fallo_8821
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer mensajes" ;
    ex:textoExtracto "8821 Fallo del lexer al reconocer mensajes. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a mensajes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." ;
    ex:identificador "8821" .

ex:Fallo_8822
    a ex:DiagnosticoFallo ;
    rdfs:label "Error fuera de rango" ;
    ex:textoExtracto "8822 Error fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA El error programado no es válido. SOLUCIÓN Los errores deben estar dentro del rango ERR1 a ERR1024." ;
    ex:identificador "8822" .

ex:Fallo_8823
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer errores" ;
    ex:textoExtracto "8823 Fallo del lexer al reconocer errores. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a errores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." ;
    ex:identificador "8823" .

ex:Fallo_8824
    a ex:DiagnosticoFallo ;
    rdfs:label "Pantalla fuera de rango" ;
    ex:textoExtracto "8824 Pantalla fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA La pantalla programada no es válida." ;
    ex:identificador "8824" .

ex:Fallo_SalidaDigitalInvalida
    a ex:DiagnosticoFallo ;
    rdfs:label "Salida digital no válida" ;
    ex:textoExtracto "PLC. CAUSA El número de la salida digital no es válido. SOLUCIÓN Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8." ;
    ex:valor "Rango salidas digitales: O1-O1024; Rango salidas locales: O1-O8" .

ex:SistemaPLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "PLC" ;
    ex:tieneComponente ex:InterfazProgramacionPLC .

ex:InterfazProgramacionPLC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de programación PLC" ;
    ex:textoExtracto "Durante la edición o compilación del programa PLC" .

ex:Fallo_8817 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8818 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8819 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8820 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8821 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8822 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8823 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_8824 ex:solucionaFallo ex:InterfazProgramacionPLC .
ex:Fallo_SalidaDigitalInvalida ex:solucionaFallo ex:InterfazProgramacionPLC .