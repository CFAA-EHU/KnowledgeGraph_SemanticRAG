ex:Fallo_8831 a ex:DiagnosticoFallo ;
    rdfs:label "Marca fuera de rango permitido (8831)"@es ;
    ex:identificador "8831" ;
    ex:textoExtracto "8831 Marca fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La marca programada no es válida. SOLUCIÓN Las marcas deben estar dentro del rango M1 a M8192."@es .

ex:Fallo_8832 a ex:DiagnosticoFallo ;
    rdfs:label "Registro fuera de rango permitido (8832)"@es ;
    ex:identificador "8832" ;
    ex:textoExtracto "8832 Registro fuera de rango permitido."@es .

ex:Fallo_ProgramacionPLC a ex:DiagnosticoFallo ;
    rdfs:label "Carácter programado incorrecto"@es ;
    ex:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .