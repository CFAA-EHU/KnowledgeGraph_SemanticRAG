@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8832
    a ex:DiagnosticoFallo ;
    rdfs:label "Marca fuera de rango permitido" ;
    ex:identificador "8832" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La marca programada no es válida. SOLUCIÓN Las marcas deben estar dentro del rango M1 a M8192." .

ex:Error8833
    a ex:DiagnosticoFallo ;
    rdfs:label "Registro fuera de rango permitido" ;
    ex:identificador "8833" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El registro programado no es válido. SOLUCIÓN Los registros deben estar dentro del rango R1 a R1024." .

ex:Error8834
    a ex:DiagnosticoFallo ;
    rdfs:label "Temporizador fuera de rango permitido" ;
    ex:identificador "8834" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El temporizador programado no es válido. SOLUCIÓN Los temporizador deben estar dentro del rango T1 a T512." .

ex:Error8835
    a ex:DiagnosticoFallo ;
    rdfs:label "Contador fuera de rango permitido" ;
    ex:identificador "8835" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El contador programado no es válido. SOLUCIÓN Los contador deben estar dentro del rango C1 a C256." .

ex:Error8836
    a ex:DiagnosticoFallo ;
    rdfs:label "Reloj fuera de rango" ;
    ex:identificador "8836" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El reloj programado no es válido. SOLUCIÓN Consultar en el manual de instalación los relojes válidos." .

ex:Error8837
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer relojes" ;
    ex:identificador "8837" ;
    ex:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a relojes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error8838
    a ex:DiagnosticoFallo ;
    rdfs:label "Entrada de arranque fuera de rango permitido" ;
    ex:identificador "8838" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Las entradas de arranque deben estar dentro del rango TG1 a TG4." .

ex:Error8839
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas de arranque" ;
    ex:identificador "8839" ;
    ex:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas de arranque. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ex:Error8840
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ex:identificador "8840" ;
    ex:textoExtracto "DETECCIÓN Durante la edición del programa PLC. Suponemos TG1." .