@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_8847
    a ex:AvisoSeguridad ;
    rdfs:label "Demasiados símbolos de usuario (8847)"@es ;
    ex:textoExtracto "8847 Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definidos más de 100 símbolos PDEF. SOLUCIÓN Programar algunos símbolos PDEF como símbolos DEF. El PLC permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF."@es ;
    ex:identificador "8847" .

ex:AvisoSeguridad_8848
    a ex:AvisoSeguridad ;
    rdfs:label "Demasiados errores (8848)"@es ;
    ex:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores y"@es ;
    ex:identificador "8848" .

ex:Sistema_CompilacionPLC
    a ex:Sistema ;
    rdfs:label "Sistema de compilación del programa PLC"@es ;
    ex:textoExtracto "Durante la compilación del programa PLC"@es ;
    ex:activaAlarma ex:AvisoSeguridad_8847 ;
    ex:activaAlarma ex:AvisoSeguridad_8848 .