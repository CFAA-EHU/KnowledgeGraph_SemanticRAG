@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error8863
    a ex:DiagnosticoFallo ;
    rdfs:label "Etiqueta indefinida" ;
    ex:identificador "8863" ;
    ex:textoExtracto "8863 Etiqueta indefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida un salto a una etiquete pero ésta no existe (=JMP etiqueta). SOLUCIÓN Revisar el nombre de las etiquetas y los saltos a las etiquetas." .

ex:Error8864
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta salto de línea tras fin de módulo" ;
    ex:identificador "8864" ;
    ex:textoExtracto "8864 Falta salto de linea tras fin de módulo. DETECCIÓN Durante la compilación" .

ex:ErrorExcesoSubrutinas
    a ex:DiagnosticoFallo ;
    rdfs:label "Exceso de subrutinas definidas" ;
    ex:textoExtracto "CAUSA Hay demasiadas subrutinas definidas en el programa. SOLUCIÓN Utilizar saltos a etiquetas en lugar de subrutinas, o agrupar varias subrutinas en una sola." .