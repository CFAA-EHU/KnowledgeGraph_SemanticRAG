@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error8870
    a               ex:AvisoSeguridad ;
    rdfs:label      "Etiqueta definida pero no llamada (Error 8870)"@es ;
    ex:identificador "8870" ;
    ex:textoExtracto "8870 Etiqueta definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una etiqueta en el programa pero no hay ninguna instrucción de salto a ella (=JMP etiqueta)."@es .

ex:TareaRevisionSaltos
    a               ex:TareaMantenimiento ;
    rdfs:label      "Revisión de instrucciones de salto en programa PLC"@es ;
    ex:textoExtracto "Revisar las instrucciones de salto o borrar la etiqueta si no se [utiliza]."@es ;
    ex:solucionaFallo ex:Error8870 .

ex:AccionBorradoEtiqueta
    a               ex:AccionProhibida ;
    rdfs:label      "Borrado de etiqueta no utilizada en PLC"@es ;
    ex:textoExtracto "borrar la etiqueta si no se [utiliza]."@es ;
    ex:mitigaRiesgo  ex:Error8870 .