@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_8894
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8894: 'Instrucción anterior incorrecta'"@es ;
    ex:identificador "8894" ;
    ex:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador, antes de su conversión a C, ha detectado una instrucción incorrecta. La salida de errores señala la instrucción siguiente a la incorrecta. SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "No ignorar errores de compilación PLC"@es ;
        ex:textoExtracto "SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta."@es
    ] .

ex:Error_8895
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 8895: 'Instrucción incorrecta'"@es ;
    ex:identificador "8895" ;
    ex:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador..."@es .

ex:SintaxisIncorrecta_General
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción PLC"@es ;
    ex:textoExtracto "CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "No usar sintaxis no documentada en PLC"@es ;
        ex:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es
    ] .