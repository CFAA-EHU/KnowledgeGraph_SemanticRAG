# Relaciones entre diagnósticos y parámetros/soluciones
ex:Error9014 ex:solucionaFallo ex:ModuloCY1, ex:ModuloPRG .
ex:Error9015 ex:solucionaFallo ex:RangoTG .
ex:Error9016 ex:solucionaFallo ex:Error9016_soluciona_EntradasI, ex:Error9016_soluciona_SalidasO,
                     ex:Error9016_soluciona_EntradasLocalesLI, ex:Error9016_soluciona_SalidasLocalesLO,
                     ex:Error9016_soluciona_MarcasM, ex:Error9016_soluciona_MensajesMSG,
                     ex:Error9016_soluciona_ErroresERR, ex:Error9016_soluciona_RelojesCLK,
                     ex:Error9016_soluciona_RegistrosR, ex:Error9016_soluciona_BitsRegistrosBR,
                     ex:Error9016_soluciona_TemporizadoresT, ex:Error9016_soluciona_ContadoresC .
ex:Error9017 ex:solucionaFallo ex:InstruccionMOV .
ex:Error9018 ex:solucionaFallo ex:InstruccionDFU .