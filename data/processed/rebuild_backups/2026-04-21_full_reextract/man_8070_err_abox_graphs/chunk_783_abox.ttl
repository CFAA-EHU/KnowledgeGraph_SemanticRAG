    a ex:Parametro ;
    rdfs:label "Rango de marcas (M1-M8192)" ;
    ex:textoExtracto "Marcas (M1-M8192)" ;
    ex:valor "M1-M8192" .

ex:Error9016_soluciona_MensajesMSG
    a ex:Parametro ;
    rdfs:label "Rango de mensajes (MSG1-MSG1024)" ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024)" ;
    ex:valor "MSG1-MSG1024" .

ex:Error9016_soluciona_ErroresERR
    a ex:Parametro ;
    rdfs:label "Rango de errores (ERR1-ERR1024)" ;
    ex:textoExtracto "Errores (ERR1-ERR1024)" ;
    ex:valor "ERR1-ERR1024" .

ex:Error9016_soluciona_RelojesCLK
    a ex:Parametro ;
    rdfs:label "Rango de relojes (CLK)" ;
    ex:textoExtracto "Relojes (CLK)" ;
    ex:valor "CLK" .

ex:Error9016_soluciona_RegistrosR
    a ex:Parametro ;
    rdfs:label "Rango de registros (R1-R1024)" ;
    ex:textoExtracto "Registros (R1-R1024)" ;
