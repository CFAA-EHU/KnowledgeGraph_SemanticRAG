@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error9014
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9014: Módulo duplicado o no permitido" ;
    ex:textoExtracto "9014 Error fatal. Módulo duplicado o no permitido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Los módulos CY1 y PRG están repetidos, o hay dos módulos periódicos con el mismo periodo. SOLUCIÓN Los módulos CY1 y PRG sólo se pueden programar una vez. Un proyecto puede tener varios módulos periódicos, pero con diferente periodo. Si dos módulos deben tener el mismo periodo, programarlos en un único módulo." ;
    ex:identificador "9014" .

ex:Error9015
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9015: TG fuera del rango permitido" ;
    ex:textoExtracto "9015 TG fuera del rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4." ;
    ex:identificador "9015" .

ex:Error9016
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9016: Recurso fuera del rango permitido" ;
    ex:textoExtracto "9016 Recurso fuera del rango permitido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Algún recurso programado está fuera del rango permitido. SOLUCIÓN El rango válido para cada recurso es el siguiente. • Entradas (I1-I1024). • Salidas (O1-O1024). • Entradas locales (LI1-LI16). • Salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Bit de registros (B0-B31 R1-R1024). • Estado de los temporizadores (T1-T512). • Estado de los contadores (C1-C256)." ;
    ex:identificador "9016" .

ex:Error9017
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9017: Número de bits fuera del rango permitido en MOV" ;
    ex:textoExtracto "9017 Numero de bits fuera del rango permitido en MOV. DETECCIÓN Durante la compilación del programa PLC. CAUSA El número de bits programado en la instrucción MOV es erróneo. SOLUCIÓN El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32." ;
    ex:identificador "9017" .

ex:Error9018
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9018: Demasiados DFUs en una única consulta" ;
    ex:textoExtracto "9018 Demasiados DFUs en una única consulta. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas instrucciones DFU. SOLUCIÓN Analizar las instrucciones DFU en grupos, guardando el resultado en una marca." ;
    ex:identificador "9018" .

ex:ModuloCY1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo CY1" ;
    ex:textoExtracto "Los módulos CY1 y PRG están repetidos" ;
    ex:identificador "CY1" .

ex:ModuloPRG
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo PRG" ;
    ex:textoExtracto "Los módulos CY1 y PRG están repetidos" ;
    ex:identificador "PRG" .

ex:RangoTG
    a ex:Parametro ;
    rdfs:label "Rango de entradas de arranque TG1-TG4" ;
    ex:textoExtracto "Programar una entrada de arranque dentro del rango TG1 a TG4" ;
    ex:valor "TG1-TG4" .

ex:InstruccionMOV
    a ex:Parametro ;
    rdfs:label "Instrucción MOV (rango de bits válido)" ;
    ex:textoExtracto "El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32" ;
    ex:valor "4,8,12,16,20,24,28,32" .

ex:InstruccionDFU
    a ex:Parametro ;
    rdfs:label "Instrucción DFU (límite por consulta)" ;
    ex:textoExtracto "La proposición ejecutable tiene demasiadas instrucciones DFU" .

