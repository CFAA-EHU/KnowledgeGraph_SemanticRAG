ex:Error9016_soluciona_BitsRegistrosBR
    a ex:Parametro ;
    rdfs:label "Rango de bits de registros (B0-B31 R1-R1024)" ;
    ex:textoExtracto "Bit de registros (B0-B31 R1-R1024)" ;
    ex:valor "B0-B31 R1-R1024" .

ex:Error9016_soluciona_TemporizadoresT
    a ex:Parametro ;
    rdfs:label "Rango de temporizadores (T1-T512)" ;
    ex:textoExtracto "Estado de los temporizadores (T1-T512)" ;
    ex:valor "T1-T512" .

ex:Error9016_soluciona_ContadoresC
    a ex:Parametro ;
