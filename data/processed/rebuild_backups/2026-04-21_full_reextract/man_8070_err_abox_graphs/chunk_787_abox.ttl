@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_9034
    a ex:Alarma ;
    rdfs:label "Alarma 9034: No se puede abrir el fichero de recursos con símbolo"@es ;
    ex:textoExtracto "9034 No se puede abrir el fichero de recursos con símbolo. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation."@es ;
    ex:identificador "9034" .

ex:Alarma_9035
    a ex:Alarma ;
    rdfs:label "Alarma 9035: No hay eje físico correspondiente al eje lógico"@es ;
    ex:textoExtracto "9035 No hay eje físico correspondiente al eje lógico. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa contiene una referencia a un eje que no existe. SOLUCIÓN Revisar la programación."@es ;
    ex:identificador "9035" .

ex:Alarma_9036
    a ex:Alarma ;
    rdfs:label "Alarma 9036: Símbolo desconocido"@es ;
    ex:textoExtracto "9036 Símbolo desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa utiliza un símbolo que está definido. SOLUCIÓN Utilizar la directiva DEF o PDEF para definir los símbolos."@es ;
    ex:identificador "9036" .

ex:Alarma_9037
    a ex:Alarma ;
    rdfs:label "Alarma 9037: Marca o registro de sistema obsoleto"@es ;
    ex:textoExtracto "9037 Marca o registro de sistema obsoleto. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Eliminar la marca o registro del programa PLC."@es ;
    ex:identificador "9037" .

ex:Alarma_9038
    a ex:Alarma ;
    rdfs:label "Alarma 9038: Marca o registro de sistema obsoleto (usar %)"@es ;
    ex:textoExtracto "9038 Marca o registro de sistema obsoleto. En su lugar use %. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro ya no existe. SOLUCIÓN Utilice la marca la marca o registro sugerida."@es ;
    ex:identificador "9038" .

ex:Alarma_9039
    a ex:Alarma ;
    rdfs:label "Alarma 9039: Marca o registro de sistema pendiente de implementar"@es ;
    ex:textoExtracto "9039 Marca o registro de sistema pendiente de ser implementado. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro todavía no ha sido implementada. SOLUCIÓN No se puede usar la marca o registro."@es ;
    ex:identificador "9039" .

ex:Alarma_9040
    a ex:Alarma ;
    rdfs:label "Alarma 9040: Línea de comentarios demasiado larga"@es ;
    ex:textoExtracto "9040 Linea de comentarios demasiado larga. DETECCIÓN Durante la compilación del programa PLC. CAUSA El comentario es demasiado largo. SOLUCIÓN Escribir un comentario mas corto o dividir el comentario en dos."@es ;
    ex:identificador "9040" .

ex:Alarma_9041
    a ex:Alarma ;
    rdfs:label "Alarma 9041: Marca o registro sustituido por %"@es ;
    ex:textoExtracto "9041 Marca o registro de sistema sustituido por %. DETECCIÓN Durante la compilación del programa PLC. CAUSA La marca o registro es incorrecto; el PLC lo ha sustituido en el programa compilado por el recurso sugerido. SOLUCIÓN Sustituir la marca o registro por el recurso sugerido."@es ;
    ex:identificador "9041" .

ex:Alarma_9042
    a ex:Alarma ;
    rdfs:label "Alarma 9042: '/' sustituido por '_'"@es ;
    ex:textoExtracto "9042 '/' sustituido por '_' DETECCIÓN Durante la compilación del programa PLC."@es ;
    ex:identificador "9042" .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC (compilación de programas)"@es ;
    ex:textoExtracto "DETECCIÓN Durante la compilación del programa PLC."@es ;
    ex:activaAlarma ex:Alarma_9034, ex:Alarma_9035, ex:Alarma_9036, ex:Alarma_9037, ex:Alarma_9038, ex:Alarma_9039, ex:Alarma_9040, ex:Alarma_9041, ex:Alarma_9042 .