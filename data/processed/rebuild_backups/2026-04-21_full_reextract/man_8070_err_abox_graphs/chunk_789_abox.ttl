ex:FalloCompilacion_9043
    a ex:DiagnosticoFallo ;
    rdfs:label "Carácter '/' sustituido por '_' en compilación PLC" ;
    ex:identificador "9043" ;
    ex:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"/\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"/\" por \"_\" en el programa de PLC." .

ex:FalloCompilacion_9044
    a ex:DiagnosticoFallo ;
    rdfs:label "Carácter '+' sustituido por 'POS' en compilación PLC" ;
    ex:identificador "9044" ;
    ex:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"+\" es incorrecto; el PLC lo ha sustituido por \"POS\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"+\" por \"POS\" en el programa de PLC." .

