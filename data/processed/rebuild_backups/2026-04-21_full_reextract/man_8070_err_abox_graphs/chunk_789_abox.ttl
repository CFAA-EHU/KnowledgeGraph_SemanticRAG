ex:FalloCompilacion_9048
    a ex:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente para recursos binarios nuevos en PLC" ;
    ex:identificador "9048" ;
    ex:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

