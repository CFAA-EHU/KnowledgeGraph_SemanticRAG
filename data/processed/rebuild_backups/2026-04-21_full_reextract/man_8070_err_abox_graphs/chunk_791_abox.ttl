@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9050 a ex:DiagnosticoFallo ;
    ex:identificador "9050" ;
    rdfs:label "No hay memoria para recursos registros de sistema nuevos"@es ;
    ex:textoExtracto "9050 No hay memoria para recursos registros de sistema nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Contactar con Fagor Automation"@es ;
        ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es
    ] .

