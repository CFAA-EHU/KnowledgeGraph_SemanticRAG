ex:Fallo_9054 a ex:DiagnosticoFallo ;
    ex:identificador "9054" ;
    rdfs:label "No se puede abrir el puerto COM para MODBUSSVRRS"@es ;
    ex:textoExtracto "9054 No se puede abrir el puerto COM para MODBUSSVRRS. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falla la conexión al puerto serie para el servidor de MODBUS. SOLUCIÓN Revisar la conexión y parametrización del puerto serie."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisar conexión y parametrización del puerto serie MODBUS"@es ;
        ex:textoExtracto "SOLUCIÓN Revisar la conexión y parametrización del puerto serie."@es
    ] .

ex:Fallo_9301 a ex:DiagnosticoFallo ;
    ex:identificador "9301" ;
    rdfs:label "'Los ejes maestro y esclavo deben tener igual REFFEED1 y REFFEED2'"@es ;
    ex:textoExtracto "9301 'Los ejes maestro y esclavo deben tener igual REFFEED1 y REFFEED2' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente velocidad de búsqueda de cero en algún set (parámetros REFFEED1 y REFFEED2). SOLUCIÓN Revisar los parámetros máquina. La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisar parámetros REFFEED1 y REFFEED2 en ejes gantry/tándem"@es ;
        ex:textoExtracto "SOLUCIÓN Revisar los parámetros máquina. La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es
    ] .

ex:Fallo_9302 a ex:DiagnosticoFallo ;
    ex:identificador "9302" ;
    rdfs:label "'Para asumir el nuevo valor es necesario rearrancar windows'"@es ;
    ex:textoExtracto "9302 'Para asumir el nuevo valor es necesario rearrancar windows' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto. SOLUCIÓN Rearrancar windows."@es ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Reiniciar sistema Windows"@es ;
        ex:textoExtracto "SOLUCIÓN Rearrancar windows."@es
    ] .

ex:Parametro_REFFEED1 a ex:Parametro ;
    ex:identificador "REFFEED1" ;
    rdfs:label "Velocidad de búsqueda de referencia máquina (rápida/lenta)"@es ;
    ex:textoExtracto "parámetros REFFEED1 y REFFEED2 [...] velocidad rápida y lenta de búsqueda de referencia máquina"@es .

ex:Parametro_REFFEED2 a ex:Parametro ;
    ex:identificador "REFFEED2" ;
    rdfs:label "Velocidad de búsqueda de referencia máquina (rápida/lenta)"@es ;
    ex:textoExtracto "parámetros REFFEED1 y REFFEED2 [...] velocidad rápida y lenta de búsqueda de referencia máquina"@es .

ex:Empresa_FagorAutomation a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation."@es .