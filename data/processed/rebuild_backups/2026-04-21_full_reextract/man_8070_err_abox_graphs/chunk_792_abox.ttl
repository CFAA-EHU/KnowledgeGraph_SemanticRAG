@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AvisoSeguridad_9302
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 9302: Reinicio requerido para parámetros máquina"@es ;
    ex:identificador "9302" ;
    ex:textoExtracto "'Para asumir el nuevo valor es necesario rearrancar windows' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto. SOLUCIÓN Rearrancar windows."@es ;
    ex:mitigaRiesgo ex:Parametro_Maquina_Reinicio .

ex:Parametro_Maquina_Reinicio
    a ex:Parametro ;
    rdfs:label "Parámetros máquina que requieren reinicio de Windows"@es ;
    ex:textoExtracto "parámetros máquina [...] exige rearrancar windows para tener efecto"@es .

ex:AvisoSeguridad_9303
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso 9303: Asociación de palpador a entrada digital Fagor"@es ;
    ex:identificador "9303" ;
    ex:textoExtracto "'El palpador debe asociarse a entrada digital de nodo Fagor'"@es .