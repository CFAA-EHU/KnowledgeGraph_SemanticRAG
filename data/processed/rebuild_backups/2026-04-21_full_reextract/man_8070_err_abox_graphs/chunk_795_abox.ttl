@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9308
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9308" ;
    rdfs:label            "No se permiten posiciones de compensación fuera del rango del módulo"@es ;
    ex:textoExtracto      "Durante la validación de los parámetros máquina. La tabla de compensación de husillo o de compensación cruzada del eje tiene definidas posiciones fuera de los límites del módulo. SOLUCIÓN Definir todas las posiciones dentro de los límites de módulo."@es ;
    ex:solucionaFallo     ex:Parametro_CHTYPE .

ex:Error_9309
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9309" ;
    rdfs:label            "Si el número de almacenes es 0, se deben permitir herramienta de tierra"@es ;
    ex:textoExtracto      "Durante la validación de los parámetros máquina. La máquina no tiene ningún almacén y no admite herramientas de tierra. SOLUCIÓN Para poder cambiar de herramienta en una máquina sin almacenes, la máquina debe admitir herramientas de tierra (parámetro GROUND)."@es ;
    ex:solucionaFallo     ex:Parametro_GROUND .

ex:Error_9310
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9310" ;
    rdfs:label            "No se permite variar override de cabezal durante roscado si feedforward < 90%"@es ;
    ex:textoExtracto      "Durante la validación de los parámetros máquina o la ejecución de un roscado G33. No se permite modificar el override del cabezal durante el roscado si el feedforward es menor del 90%, para evitar dañar la rosca. SOLUCIÓN Aumentar el feedforward del cabezal."@es .

ex:Error_9311
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9311" ;
    rdfs:label            "Un eje TANDEM no puede estar en un grupo MULTIAXIS"@es ;
    ex:textoExtracto      "Durante la validación de los parámetros máquina o el arranque del CNC. Uno de los ejes forma parte de una pareja tandem y de un grupo MULTIAXIS. SOLUCIÓN Corregir la tabla de ejes tandem y multieje. Un eje sólo puede estar en una de las dos configuraciones."@es .

ex:Error_9312
    a                     ex:DiagnosticoFallo ;
    ex:identificador      "9312" ;
    rdfs:label            "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es ;
    ex:textoExtracto      "Durante la validación de los parámetros máquina o el arranque del CNC. Uno de los ejes forma parte de una pareja gantry y de un grupo MULTIAXIS."@es .

ex:Parametro_CHTYPE
    a                     ex:Parametro ;
    ex:identificador      "CHTYPE" ;
    ex:textoExtracto      "En el modelo MC, todos los canales deben ser de PLC (parámetro CHTYPE)."@es .

ex:Parametro_GROUND
    a                     ex:Parametro ;
    ex:identificador      "GROUND" ;
    ex:textoExtracto      "La máquina debe admitir herramientas de tierra (parámetro GROUND)."@es .