@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:alarma_9312
    a ex:Alarma ;
    rdfs:label "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es ;
    ex:identificador "9312" ;
    ex:textoExtracto "9312 'Un eje GANTRY no puede estar en un grupo MULTIAXIS' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Uno de los ejes forma parte de una pareja gantry y de un grupo MULTIAXIS. SOLUCIÓN Corregir la tabla de ejes gantry y multieje. Un eje sólo puede estar en una de las dos configuraciones."@es ;
    ex:detalladoEnEsquema ex:tabla_ejes_gantry_multieje .

ex:alarma_9313
    a ex:Alarma ;
    rdfs:label "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema"@es ;
    ex:identificador "9313" ;
    ex:textoExtracto "9313 'DRIVEID del eje del grupo MULTIAXIS no válido en el sistema' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC."@es .

ex:tabla_ejes_gantry_multieje
    a ex:Tabla ;
    rdfs:label "Tabla de ejes gantry y multieje"@es ;
    ex:textoExtracto "Corregir la tabla de ejes gantry y multieje."@es .