@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_9313
    a ex:Alarma ;
    rdfs:label "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema" ;
    ex:identificador "9313" ;
    ex:textoExtracto "9313 'DRIVEID del eje del grupo MULTIAXIS no válido en el sistema' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No hay ningún eje en el sistema que tenga el mismo DRIVEID que el indicado al definir un grupo MULTIAXIS. SOLUCIÓN Asignar un DRIVEID dentro de los grupos MULTIAXIS que esté asociado a ejes del sistema." .

ex:Alarma_9314
    a ex:Alarma ;
    rdfs:label "Eje SERCOS del grupo multiaxis tiene diferente DRIVEID" ;
    ex:identificador "9314" ;
    ex:textoExtracto "9314 'Eje SERCOS del grupo multiaxis tiene diferente DRIVEID' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No todos los ejes de un grupo MULTIAXIS están asociados al mismo regulador (parámetro DRIVEID). SOLUCIÓN Todos los ejes Sercos de un grupo MULTIAXIS deben estar asociados al mismo regulador y por lo tanto deben tener igual el parámetro DRIVEID." .

ex:Alarma_9315
    a ex:Alarma ;
    rdfs:label "El número de Sets del grupo supera el número de Sets del regulador" ;
    ex:identificador "9315" ;
    ex:textoExtracto "9315 'El número de Sets del grupo supera el número de Sets del regulador' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El regulador admite 8 gamas y el número total de sets de parámetros definidos en un grupo MULTIAXIS supera este valor. SOLUCIÓN Reducir el número de ejes del grupo MULTIAXIS o reducir el número de sets de parámetros de los ejes del grupo." .

ex:Alarma_9316
    a ex:Alarma ;
    rdfs:label "Los ejes del grupo no tienen igual OPMODEP: todos velocidad o todos posición" ;
    ex:identificador "9316" ;
    ex:textoExtracto "9316 'Los ejes del grupo no tienen igual OPMODEP: todos velocidad o todos posición' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Hay algún grupo multieje cuyos ejes tienen diferente parámetro OPMODEP. SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo multieje deben tener el parámetro OPMODEP igual." .

ex:Alarma_9317
    a ex:Alarma ;
    rdfs:label "Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad" ;
    ex:identificador "9317" ;
    ex:textoExtracto "9317 'Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay algún grupo multieje cuyos ejes tienen diferente parámetro COUNTERID y los ejes no son Sercos velocidad." .

ex:Parametro_DRIVEID
    a ex:Parametro ;
    rdfs:label "DRIVEID" ;
    ex:textoExtracto "parámetro DRIVEID" .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP" ;
    ex:textoExtracto "parámetro OPMODEP" .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "parámetro COUNTERID" .

ex:Sistema_MULTIAXIS
    a ex:Sistema ;
    rdfs:label "Grupo MULTIAXIS" ;
    ex:textoExtracto "grupo MULTIAXIS" ;
    ex:tieneComponente ex:Parametro_DRIVEID, ex:Parametro_OPMODEP, ex:Parametro_COUNTERID .

ex:Alarma_9313 ex:monitoreaParametro ex:Parametro_DRIVEID .
ex:Alarma_9314 ex:monitoreaParametro ex:Parametro_DRIVEID .
ex:Alarma_9316 ex:monitoreaParametro ex:Parametro_OPMODEP .
ex:Alarma_9317 ex:monitoreaParametro ex:Parametro_COUNTERID .