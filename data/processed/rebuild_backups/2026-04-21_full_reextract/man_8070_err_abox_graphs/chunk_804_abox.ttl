@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9332 a ex:DiagnosticoFallo ;
    rdfs:label "COUNTERTYPE remoto y COUNTERID 0 incompatibles"@es ;
    ex:textoExtracto "'COUNTERTYPE remoto y COUNTERID 0 incompatibles' DETECCIÓN Durante la validación de los parámetros máquina o el arranque"@es ;
    ex:identificador "9332" .

ex:Parametro_MLINK a ex:Parametro ;
    rdfs:label "MLINK (configuración Mechatrolink II)"@es ;
    ex:textoExtracto "configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)"@es ;
    ex:valor "Mechatrolink II" .

ex:Parametro_DATASIZE a ex:Parametro ;
    rdfs:label "DATASIZE (tamaño datos Mechatrolink II)"@es ;
    ex:textoExtracto "configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)"@es ;
    ex:valor "32 bytes" .

ex:Sistema_MechatrolinkII a ex:Sistema ;
    rdfs:label "Bus Mechatrolink II"@es ;
    ex:textoExtracto "configurar el bus como Mechatrolink II a 32 bytes"@es ;
    ex:monitoreaParametro ex:Parametro_MLINK ;
    ex:monitoreaParametro ex:Parametro_DATASIZE .

ex:Accion_ConfiguracionBus a ex:AccionProhibida ;
    rdfs:label "Configuración incorrecta de Mechatrolink II"@es ;
    ex:textoExtracto "Sólo es posible enviar los subcomandos que resuelven las variables y parámetros en Mechatrolink II a 32 bytes. SOLUCIÓN Para poder acceder a las variables y parámetros del regulador (DRV) hay que configurar el bus como Mechatrolink II a 32 bytes"@es ;
    ex:solucionaFallo ex:Fallo_9332 .