@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9337
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9337: Sercos posición no funciona con LOOPTIME superior a 8 ms" ;
    ex:textoExtracto "9337 Sercos posición no funciona con LOOPTIME superior a 8 ms. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Los reguladores Sercos posición tienen limitado a 8 ms el tiempo de ciclo. SOLUCIÓN Asignar al parámetro máquina LOOPTIME un valor igual o inferior a 8 ms o usar los reguladores en velocidad (OPMODE = Velocidad)." ;
    ex:identificador "9337" .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "parámetro máquina LOOPTIME" ;
    ex:valor "8"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_OPMODE
    a ex:Parametro ;
    rdfs:label "OPMODE" ;
    ex:textoExtracto "OPMODE = Velocidad" ;
    ex:valor "Velocidad" .

ex:Error_9338
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9338: Memoria insuficiente" ;
    ex:textoExtracto "9338 Memoria insuficiente. Reducir el valor del parámetro. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA No se ha podido alocar la memoria para el número de puntos indicados por el parámetro NPOINTS de Fagor > Diagnosis. SOLUCIÓN Reducir el valor de parámetro máquina NPOINTS de Fagor > Diagnosis." ;
    ex:identificador "9338" .

ex:Parametro_NPOINTS
    a ex:Parametro ;
    rdfs:label "NPOINTS" ;
    ex:textoExtracto "parámetro NPOINTS de Fagor > Diagnosis" .

ex:Error_9339
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9339: SWTDELAY demasiado grande para LOOPTIME actual" ;
    ex:textoExtracto "9339 No se admite un SWTDELAY tan grande con LOOPTIME actual. DETECCIÓN Durante la ejecución. CAUSA El valor de SWTDELAY es demasiado grande para el tiempo de ciclo definido. SOLUCIÓN Reducir el valor de parámetro SWTDELAY o aumentar el tiempo de ciclo." ;
    ex:identificador "9339" .

ex:Parametro_SWTDELAY
    a ex:Parametro ;
    rdfs:label "SWTDELAY" ;
    ex:textoExtracto "parámetro SWTDELAY" .

ex:Error_9340
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9340: Parámetros inconsistentes en contadora Sercos" ;
    ex:textoExtracto "9340 Contadora Sercos: sets con igual COUNTERID deben tener igual el\\los parámetro(s): DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA Varios sets que con la misma entrada de captación de un módulo RCS-S (parámetro COUNTERID), no tienen el mismo valor en alguno de los siguientes parámetros: FEEDBACKTYPE, SSITYPE, SSI, I0TYPE, ABSOFF, EXTMULT, REFPULSE, I0CODDI1, I0CODDI2, NPULSES y FBACKAL. SOLUCIÓN En los sets con igual COUNTERID, definir los parámetros indicados con el mismo valor." ;
    ex:identificador "9340" .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "parámetro COUNTERID" .

ex:Parametro_FEEDBACKTYPE
    a ex:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ex:textoExtracto "parámetro FEEDBACKTYPE" .

ex:Parametro_SSITYPE
    a ex:Parametro ;
    rdfs:label "SSITYPE" ;
    ex:textoExtracto "parámetro SSITYPE" .

ex:Parametro_SSI
    a ex:Parametro ;
    rdfs:label "SSI" ;
    ex:textoExtracto "parámetro SSI" .

ex:Parametro_I0TYPE
    a ex:Parametro ;
    rdfs:label "I0TYPE" ;
    ex:textoExtracto "parámetro I0TYPE" .

ex:Parametro_ABSOFF
    a ex:Parametro ;
    rdfs:label "ABSOFF" ;
    ex:textoExtracto "parámetro ABSOFF" .

ex:Parametro_EXTMULT
    a ex:Parametro ;
    rdfs:label "EXTMULT" ;
    ex:textoExtracto "parámetro EXTMULT" .

ex:Parametro_REFPULSE
    a ex:Parametro ;
    rdfs:label "REFPULSE" ;
    ex:textoExtracto "parámetro REFPULSE" .

ex:Parametro_I0CODDI1
    a ex:Parametro ;
    rdfs:label "I0CODDI1" ;
    ex:textoExtracto "parámetro I0CODDI1" .

ex:Parametro_I0CODDI2
    a ex:Parametro ;
    rdfs:label "I0CODDI2" ;
    ex:textoExtracto "parámetro I0CODDI2" .

ex:Parametro_NPULSES
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "parámetro NPULSES" .

ex:Parametro_FBACKAL
    a ex:Parametro ;
    rdfs:label "FBACKAL" ;
    ex:textoExtracto "parámetro FBACKAL" .

