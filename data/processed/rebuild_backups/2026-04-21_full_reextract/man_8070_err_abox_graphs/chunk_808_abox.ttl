@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_9341 a ex:DiagnosticoFallo ;
    rdfs:label "Contadora Sercos: set activo de varios ejes con ANAOUTID duplicado"@es ;
    ex:identificador "9341" ;
    ex:textoExtracto "Contadora Sercos: set activo de varios ejes no pueden tener igual el parámetro ANAOUTID. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El set activo en varios ejes está utilizando la misma salida analógica de un módulo RCS-S (parámetro"@es .

ex:Parametro_ANAOUTID a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "parámetro ANAOUTID"@es ;
    ex:valor "identificador_de_salida_analógica"@es .

ex:Modulo_RCS_S a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S"@es ;
    ex:textoExtracto "módulo RCS-S"@es ;
    ex:monitoreaParametro ex:Parametro_ANAOUTID .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "arranque del CNC"@es ;
    ex:tieneComponente ex:Modulo_RCS_S ;
    ex:controla ex:Parametro_ANAOUTID .

ex:Solucion_9341 a ex:AvisoSeguridad ;
    rdfs:label "Solución para fallo 9341: Unificar ANAOUTID en sets con igual COUNTERID"@es ;
    ex:textoExtracto "SOLUCIÓN En los sets con igual COUNTERID, definir los parámetros indicados con el mismo valor."@es ;
    ex:solucionaFallo ex:Fallo_9341 .