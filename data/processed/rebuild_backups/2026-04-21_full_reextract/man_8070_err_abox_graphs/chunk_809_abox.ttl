@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_ANAOUTID
    a ex:Alarma ;
    rdfs:label "Alarma ANAOUTID: Detección de salida analógica compartida" ;
    ex:textoExtracto "ANAOUTID' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El set activo en varios ejes está utilizando la misma salida analógica de un módulo RCS-S (parámetro ANAUOTID). SOLUCIÓN Dos set activos no pueden compartir la misma salida analógica. Activar un set diferente en algún eje o configurar una salida analógica diferente en el set." ;
    ex:identificador "ANAOUTID" .

ex:Alarma_9342
    a ex:Alarma ;
    rdfs:label "Alarma 9342: Offset de cinemática fuera de rango" ;
    ex:textoExtracto "9342 'Offset de la cinemática fuera del rango permitido por el valor máximo' DETECCIÓN Durante la validación de parámetros máquina o escritura de una variable. CAUSA El offset definido para la cinemática está fuera del rango permitido por el parámetro máquina. SOLUCIÓN Asignar a la variable V.MPK.OFTDATAkin[nb] de la cinemática un valor que esté comprendido entre \"- MAX OFFSET\" y \"+ MAX OFFSET\" (rango definido por el parámetro máquina de la cinemática correspondiente)." ;
    ex:identificador "9342" .

ex:Alarma_9343
    a ex:Alarma ;
    rdfs:label "Alarma 9343: Variable DRV duplicada" ;
    ex:textoExtracto "9343 Variable DRV ya existente. DETECCIÓN Durante la validación de los parámetros máquina o la definición de variables del regulador. CAUSA La variable DRV ya existe en los parámetros máquina OEM. SOLUCIÓN Revisar la definición de la variable." ;
    ex:identificador "9343" .

ex:Alarma_9344
    a ex:Alarma ;
    rdfs:label "Alarma 9344: Mnemónico DRV duplicado" ;
    ex:textoExtracto "9344 Variables DRV de eje y de nodo no pueden tener el mismo MNEMONIC. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Dos variables diferentes no pueden tener el mismo mnemónico. SOLUCIÓN Definir las variables DRV con diferente mnemónico." ;
    ex:identificador "9344" .

ex:Alarma_9345
    a ex:Alarma ;
    rdfs:label "Alarma 9345: Inconsistencia en mnemónico DRV (MLINK)" ;
    ex:textoExtracto "9345 MLINK: Variables DRV con igual ID y TYPE no pueden tener diferente MNEMÓNIC. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID) y del mismo tipo de acceso (TYPE), pero diferente mnemónico. SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo mnemónico." ;
    ex:identificador "9345" .

ex:Alarma_9346
    a ex:Alarma ;
    rdfs:label "Alarma 9346: Inconsistencia en modo DRV (MLINK)" ;
    ex:textoExtracto "9346 MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE. DETECCIÓN Durante la validación de los parámetros máquina." ;
    ex:identificador "9346" .

ex:Parametro_ANAUOTID
    a ex:Parametro ;
    rdfs:label "Parámetro ANAUOTID (salida analógica RCS-S)" ;
    ex:textoExtracto "parámetro ANAUOTID" ;
    ex:identificador "ANAUOTID" .

ex:Parametro_MAX_OFFSET
    a ex:Parametro ;
    rdfs:label "Parámetro MAX OFFSET (rango cinemática)" ;
    ex:textoExtracto "rango definido por el parámetro máquina de la cinemática correspondiente: \"- MAX OFFSET\" y \"+ MAX OFFSET\"" ;
    ex:identificador "MAX OFFSET" .

ex:Parametro_V_MPK_OFTDATAkin
    a ex:Parametro ;
    rdfs:label "Variable V.MPK.OFTDATAkin[nb] (offset cinemática)" ;
    ex:textoExtracto "variable V.MPK.OFTDATAkin[nb] de la cinemática" ;
    ex:identificador "V.MPK.OFTDATAkin[nb]" .

ex:Sistema_RCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S (salidas analógicas)" ;
    ex:textoExtracto "módulo RCS-S (parámetro ANAUOTID)" .