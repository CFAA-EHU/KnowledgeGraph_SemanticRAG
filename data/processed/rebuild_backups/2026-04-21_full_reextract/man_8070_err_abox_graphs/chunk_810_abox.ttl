@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9346_MLINK a ex:AvisoSeguridad ;
    rdfs:label "MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE"@es ;
    ex:identificador "9346" ;
    ex:textoExtracto "MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE. [...] En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID), Durante la validación de los parámetros máquina."@es .

ex:Parametro_DRV a ex:Parametro ;
    ex:textoExtracto "variables de regulador (DRV) con el mismo identificador (ID)"@es ;
    ex:identificador "DRV" .

ex:Sistema_ValidacionParametros a ex:Sistema ;
    ex:textoExtracto "Durante la validación de los parámetros máquina"@es ;
    ex:monitoreaParametro ex:Parametro_DRV ;
    ex:activaAlarma ex:Error_9346_MLINK .