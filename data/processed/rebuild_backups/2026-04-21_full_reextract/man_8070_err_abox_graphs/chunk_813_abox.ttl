@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagnósticos de fallo (Alarmas)
ex:Fallo_9352
    a ex:DiagnosticoFallo ;
    rdfs:label "CAXSET no coincide con M41SET..M44SET en cabezales" ;
    ex:identificador "9352" ;
    ex:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ex:Fallo_9353
    a ex:DiagnosticoFallo ;
    rdfs:label "SYNCSET no coincide con M41SET..M44SET en cabezales" ;
    ex:identificador "9353" ;
    ex:textoExtracto "SYNCSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ex:Fallo_9355
    a ex:DiagnosticoFallo ;
    rdfs:label "Ejes maestro/esclavo con OPMODE distinto" ;
    ex:identificador "9355" ;
    ex:textoExtracto "Los ejes maestro y esclavo deben tener el mismo OPMODE. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En un eje gantry, el eje maestro y esclavo no tiene el parámetro OPMODE igual. SOLUCIÓN El parámetro OPMODE debe ser igual en ambos ejes." .

ex:Fallo_9356
    a ex:DiagnosticoFallo ;
    rdfs:label "Compensación de husillo doblemente definida" ;
    ex:identificador "9356" ;
    ex:textoExtracto "Compensación de husillo doblemente definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay asignadas dos compensaciones de husillo iguales (parámetros MOVAXIS y COMPAXIS iguales) a un mismo eje. SOLUCIÓN Asignar al eje una única compensación de husillo." .

ex:Fallo_9357
    a ex:DiagnosticoFallo ;
    rdfs:label "Eje COMPAXIS de compensación no válido" ;
    ex:identificador "9357" ;
    ex:textoExtracto "El eje COMPAXIS de la compensación seleccionada no es válido. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje tiene asignada una compensación cuyo eje compensado no coincide con el eje. SOLUCIÓN Asignar a COMPTABLEID un valor adecuado." .

ex:Fallo_9358
    a ex:DiagnosticoFallo ;
    rdfs:label "Compensación no definida" ;
    ex:identificador "9358" ;
    ex:textoExtracto "Compensación no definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada." .

### Parámetros críticos (relacionados con los fallos)
ex:Parametro_DEFAULTSET
    a ex:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ex:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." ;
    ex:monitoreaParametro ex:Fallo_9352, ex:Fallo_9353 .

ex:Parametro_M41SET
    a ex:Parametro ;
    rdfs:label "M41SET" ;
    ex:textoExtracto "valores definidos en M41SET a M44SET" ;
    ex:monitoreaParametro ex:Fallo_9352, ex:Fallo_9353 .

ex:Parametro_M42SET
    a ex:Parametro ;
    rdfs:label "M42SET" ;
    ex:textoExtracto "valores definidos en M41SET a M44SET" ;
    ex:monitoreaParametro ex:Fallo_9352, ex:Fallo_9353 .

ex:Parametro_M43SET
    a ex:Parametro ;
    rdfs:label "M43SET" ;
    ex:textoExtracto "valores definidos en M41SET a M44SET" ;
    ex:monitoreaParametro ex:Fallo_9352, ex:Fallo_9353 .

ex:Parametro_M44SET
    a ex:Parametro ;
    rdfs:label "M44SET" ;
    ex:textoExtracto "valores definidos en M41SET a M44SET" ;
    ex:monitoreaParametro ex:Fallo_9352, ex:Fallo_9353 .

ex:Parametro_CAXSET
    a ex:Parametro ;
    rdfs:label "CAXSET" ;
    ex:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales" ;
    ex:monitoreaParametro ex:Fallo_9352 .

ex:Parametro_SYNCSET
    a ex:Parametro ;
    rdfs:label "SYNCSET" ;
    ex:textoExtracto "SYNCSET debe coincidir con M41SET..M44SET en cabezales" ;
    ex:monitoreaParametro ex:Fallo_9353 .

ex:Parametro_OPMODE
    a ex:Parametro ;
    rdfs:label "OPMODE" ;
    ex:textoExtracto "El parámetro OPMODE debe ser igual en ambos ejes (maestro/esclavo)" ;
    ex:monitoreaParametro ex:Fallo_9355 .

ex:Parametro_MOVAXIS
    a ex:Parametro ;
    rdfs:label "MOVAXIS" ;
    ex:textoExtracto "parámetros MOVAXIS y COMPAXIS iguales" ;
    ex:monitoreaParametro ex:Fallo_9356 .

ex:Parametro_COMPAXIS
    a ex:Parametro ;
    rdfs:label "COMPAXIS" ;
    ex:textoExtracto "parámetros MOVAXIS y COMPAXIS iguales" ;
    ex:monitoreaParametro ex:Fallo_9356, ex:Fallo_9357 .

ex:Parametro_COMPTABLEID
    a ex:Parametro ;
    rdfs:label "COMPTABLEID" ;
    ex:textoExtracto "El parámetro COMPTABLEID tiene un valor que ya no existe" ;
    ex:monitoreaParametro ex:Fallo_9357, ex:Fallo_9358 .