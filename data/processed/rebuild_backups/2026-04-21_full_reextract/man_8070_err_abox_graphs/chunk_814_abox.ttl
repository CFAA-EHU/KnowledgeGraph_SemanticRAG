@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9358 a ex:DiagnosticoFallo ;
    rdfs:label "Compensación no definida" ;
    ex:identificador "9358" ;
    ex:textoExtracto "Compensación no definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada. SOLUCIÓN Asignar a COMPTABLEID un valor que exista." .

ex:Fallo_9360 a ex:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros bloqueada por cambio de gama" ;
    ex:identificador "9360" ;
    ex:textoExtracto "No es posible validar parámetros de un eje con un cambio de gama en proceso. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Se ha intentado validar la tabla de parámetros máquina durante un cambio" .

ex:Parametro_COMPTABLEID a ex:Parametro ;
    rdfs:label "Parámetro COMPTABLEID" ;
    ex:textoExtracto "El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada." ;
    ex:monitoreaParametro ex:Fallo_9358 .

ex:Tabla_ParametrosMaquina a ex:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ex:textoExtracto "Se ha intentado validar la tabla de parámetros máquina durante un cambio" ;
    ex:documentadoEn ex:Manual_9000_9999 .