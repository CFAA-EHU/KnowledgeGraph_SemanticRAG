@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9513
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD" ;
    ex:identificador "9513" ;
    ex:textoExtracto "Error en la actualización de versión CPLD. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión del CPDL en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Verificar conexionado y contactar con soporte" ;
        ex:textoExtracto "Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation."
    ] .

ex:Error_9514
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal A" ;
    ex:identificador "9514" ;
    ex:textoExtracto "Captación: Cable roto señal A. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La entrada de captación del regulador no recibe la señal A. El cable de la señal A y/o /A puede estar roto o desconectado. SOLUCIÓN Revisar el nivel de las señales proporcionadas por el captador." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisar nivel de señales del captador (señal A)" ;
        ex:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador."
    ] .

