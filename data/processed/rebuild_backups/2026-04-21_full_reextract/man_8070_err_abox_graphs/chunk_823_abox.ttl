ex:FPGA_Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "FPGA en regulador o RPS" ;
    ex:textoExtracto "FPGA en algún regulador o RPS." .

ex:CPLD_Regulador
    a ex:ComponenteElectrico ;
    rdfs:label "CPLD en regulador o RPS" ;
    ex:textoExtracto "El CNC no puede actualizar la versión del CPDL en algún regulador o RPS." .

