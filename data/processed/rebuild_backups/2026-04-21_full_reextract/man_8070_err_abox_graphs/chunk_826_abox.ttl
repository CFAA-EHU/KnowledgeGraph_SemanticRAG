@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_ABSIND_9523
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error de sincronismo ABSIND 9523" ;
    ex:identificador    "9523" ;
    ex:textoExtracto    "9523 ABSIND: Error de sincronismo. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta." .

ex:Modulo_ABSIND
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Módulo ABSIND" ;
    ex:textoExtracto    "El regulador ha perdido la sincronización con el módulo ABSIND" .

ex:Sensor_Captador
    a                   ex:Sensor ;
    rdfs:label          "Captador" ;
    ex:textoExtracto    "El error puede deberse a un problema en el captador." .

ex:Empresa_FagorAutomation
    a                   ex:Empresa ;
    rdfs:label          "Fagor Automation" ;
    ex:textoExtracto    "Si el error persiste, póngase en contacto con Fagor Automation." .

ex:Error_ABSIND_9523
    ex:solucionaFallo    ex:Modulo_ABSIND ;
    ex:solucionaFallo    ex:Sensor_Captador .