@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloEncoder_9538
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo en encóder o cabeza de regla (código 9538)"@es ;
    ex:identificador "9538" ;
    ex:textoExtracto "CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode). [...] 9538 Captación digital Fagor. Tensión de alimentación fuera de rango."@es ;
    ex:solucionaFallo ex:TareaMantenimiento_LimpiezaEncoder_9538,
                     ex:TareaMantenimiento_ReemplazoEncoder_9538 .

ex:TareaMantenimiento_LimpiezaEncoder_9538
    a               ex:TareaMantenimiento ;
    rdfs:label      "Limpieza de cristal o cinta de acero del encóder"@es ;
    ex:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ex:TareaMantenimiento_ReemplazoEncoder_9538
    a               ex:TareaMantenimiento ;
    rdfs:label      "Reemplazo de encóder o cabeza de regla"@es ;
    ex:textoExtracto "Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es .

ex:ComponenteElectrico_Encoder_9538
    a               ex:ComponenteElectrico ;
    rdfs:label      "Encóder o cabeza de regla (CCD/LED)"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)."@es ;
    ex:requiereMantenimiento ex:TareaMantenimiento_LimpiezaEncoder_9538,
                             ex:TareaMantenimiento_ReemplazoEncoder_9538 .

ex:AvisoSeguridad_ContactoFagor_9538
    a               ex:AvisoSeguridad ;
    rdfs:label      "Contactar con Fagor Automation para reemplazo de encóder"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation."@es ;
    ex:mitigaRiesgo ex:TareaMantenimiento_ReemplazoEncoder_9538 .