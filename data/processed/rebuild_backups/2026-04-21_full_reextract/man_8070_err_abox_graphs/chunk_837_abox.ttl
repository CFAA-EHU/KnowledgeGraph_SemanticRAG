@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

### Diagnósticos de fallo (encoder y sistema)
ex:Fallo_9543
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Alimentación del encoder fuera de valores deseables" ;
    ex:textoExtracto "9543 Captación digital Fagor: Alimentación del encoder fuera de valores deseables. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." ;
    ex:identificador "9543" ;
    ex:solucionaFallo ex:EncoderFagor .

ex:Fallo_9544
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Velocidad excesiva en el eje" ;
    ex:textoExtracto "9544 Captación digital Fagor: Velocidad excesiva en el eje. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." ;
    ex:identificador "9544" ;
    ex:solucionaFallo ex:EncoderFagor .

ex:Fallo_9545
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Temperatura interna fuera de rango" ;
    ex:textoExtracto "9545 Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Sobretemperatura en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." ;
    ex:identificador "9545" ;
    ex:solucionaFallo ex:EncoderFagor .

ex:Fallo_9546
    a ex:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Pérdida de sincronización" ;
    ex:textoExtracto "9546 Captación digital Fagor: Pérdida de sincronización SOL. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error de comunicación del encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." ;
    ex:identificador "9546" ;
    ex:solucionaFallo ex:EncoderFagor .

ex:Fallo_9547
    a ex:DiagnosticoFallo ;
    rdfs:label "Pulso de I0 no detectado" ;
    ex:textoExtracto "9547 Pulso de I0 no detectado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador no ha recibido la señal de I0. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." ;
    ex:identificador "9547" ;
    ex:solucionaFallo ex:EncoderFagor .

ex:Fallo_9548
    a ex:DiagnosticoFallo ;
    rdfs:label "Falta fase en la tarjeta sense" ;
    ex:textoExtracto "9548 Falta fase en la tarjeta sense. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Una fase de red no llega correctamente a la tarjeta sense. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:identificador "9548" ;
    ex:solucionaFallo ex:TarjetaSense .

ex:Fallo_9549
    a ex:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 80%" ;
    ex:textoExtracto "9549 Nivel de tensión por debajo del 80%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:identificador "9549" ;
    ex:solucionaFallo ex:TarjetaSense .

### Componentes afectados
ex:EncoderFagor
    a ex:Sensor ;
    rdfs:label "Encoder digital Fagor" ;
    ex:textoExtracto "Captación digital Fagor: Alimentación del encoder fuera de valores deseables... Error interno en el encoder... Revisar el conexionado e integridad del encoder." .

ex:TarjetaSense
    a ex:ComponenteElectrico ;
    rdfs:label "Tarjeta sense" ;
    ex:textoExtracto "Falta fase en la tarjeta sense... Revisar tensiones de red y cableado hasta la tarjeta sense." .

### Tareas de mantenimiento (implícitas en soluciones)
ex:Tarea_RevisarConexionadoEncoder
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar conexionado e integridad del encoder" ;
    ex:textoExtracto "SOLUCIÓN Revisar el conexionado e integridad del encoder." ;
    ex:requiereMantenimiento ex:EncoderFagor .

ex:Tarea_RevisarParametrizacionEncoder
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar parametrización y conexionado del encoder" ;
    ex:textoExtracto "SOLUCIÓN Revisar la parametrización y el conexionado del encoder." ;
    ex:requiereMantenimiento ex:EncoderFagor .

ex:Tarea_RevisarTensionesTarjetaSense
    a ex:TareaMantenimiento ;
    rdfs:label "Revisar tensiones de red y cableado hasta la tarjeta sense" ;
    ex:textoExtracto "SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:requiereMantenimiento ex:TarjetaSense .