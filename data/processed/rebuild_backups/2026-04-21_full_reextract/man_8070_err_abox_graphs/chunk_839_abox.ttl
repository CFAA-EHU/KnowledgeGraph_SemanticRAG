@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_9550
    a ex:DiagnosticoFallo ;
    ex:identificador "9550" ;
    rdfs:label "Nivel de tensión por debajo del 70%" ;
    ex:textoExtracto "9550 Nivel de tensión por debajo del 70%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 70 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de tensiones de red y cableado hasta la tarjeta sense" ;
        ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."
    ] ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Nivel de tensión de red" ;
        ex:valor "70%"^^<http://www.w3.org/2001/XMLSchema#string> ;
        ex:textoExtracto "Nivel de tensión por debajo del 70%."
    ] .

ex:Fallo_9551
    a ex:DiagnosticoFallo ;
    ex:identificador "9551" ;
    rdfs:label "Nivel de tensión por debajo del 40%" ;
    ex:textoExtracto "9551 Nivel de tensión por debajo del 40%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 40 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de tensiones de red y cableado hasta la tarjeta sense" ;
        ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."
    ] ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Nivel de tensión de red" ;
        ex:valor "40%"^^<http://www.w3.org/2001/XMLSchema#string> ;
        ex:textoExtracto "Nivel de tensión por debajo del 40%."
    ] .

ex:Fallo_9552
    a ex:DiagnosticoFallo ;
    ex:identificador "9552" ;
    rdfs:label "Nivel de tensión cerca del 0%" ;
    ex:textoExtracto "9552 Nivel de tensión cerca del 0%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red ha sido cercana a 0 V. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de tensiones de red y cableado hasta la tarjeta sense" ;
        ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."
    ] ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Nivel de tensión de red" ;
        ex:valor "0%"^^<http://www.w3.org/2001/XMLSchema#string> ;
        ex:textoExtracto "Nivel de tensión cerca del 0%."
    ] .

ex:Fallo_9553
    a ex:DiagnosticoFallo ;
    ex:identificador "9553" ;
    rdfs:label "Alcanzado límite de velocidad en regulador -MDU" ;
    ex:textoExtracto "9553 Alcanzado límite de velocidad. DETECCIÓN Durante la ejecución. CAUSA Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar la velocidad programada. SOLUCIÓN Los reguladores incluidos en la lista de productos doble uso (identificados con el texto -MDU) no pueden superar los 550 Hz. No es posible alcanzar esa velocidad." ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Frecuencia máxima en regulador -MDU" ;
        ex:valor "550 Hz" ;
        ex:textoExtracto "550 Hz para alcanzar la velocidad programada."
    ] .

ex:Fallo_9555
    a ex:DiagnosticoFallo ;
    ex:identificador "9555" ;
    rdfs:label "Apagado inesperado del regulador" ;
    ex:textoExtracto "9555 Apagado inesperado del regulador. DETECCIÓN Durante el arranque del sistema. CAUSA Apagado inesperado del regulador. SOLUCIÓN Revisar la alimentación de los reguladores." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de alimentación de reguladores" ;
        ex:textoExtracto "Revisar la alimentación de los reguladores."
    ] .

ex:Fallo_9557
    a ex:DiagnosticoFallo ;
    ex:identificador "9557" ;
    rdfs:label "Cortocircuito en resistencia de Ballast" ;
    ex:textoExtracto "9557 Cortocicuito en la resistencia de Ballast. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Límite de corriente en la resistencia de Ballast. SOLUCIÓN Revisar el conexionado e integridad de la resistencia de Ballast." ;
    ex:solucionaFallo [
        a ex:TareaMantenimiento ;
        rdfs:label "Revisión de conexionado e integridad de resistencia de Ballast" ;
        ex:textoExtracto "Revisar el conexionado e integridad de la resistencia de Ballast."
    ] ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Corriente en resistencia de Ballast" ;
        ex:textoExtracto "Límite de corriente en la resistencia de Ballast."
    ] .

ex:Fallo_9558
    a ex:DiagnosticoFallo ;
    ex:identificador "9558" ;
    rdfs:label "Sobrecarga de resistencia de Ballast" ;
    ex:textoExtracto "9558 Sobrecarga de la resistencia de Ballast. DETECCIÓN Durante el funcionamiento habitual del sistema." ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        rdfs:label "Carga en resistencia de Ballast" ;
        ex:textoExtracto "Sobrecarga de la resistencia de Ballast."
    ] .

ex:TarjetaSense
    a ex:ComponenteElectrico ;
    rdfs:label "Tarjeta sense" ;
    ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense." .

ex:ResistenciaBallast
    a ex:ComponenteElectrico ;
    rdfs:label "Resistencia de Ballast" ;
    ex:textoExtracto "Cortocicuito en la resistencia de Ballast. [...] Sobrecarga de la resistencia de Ballast." .

ex:Regulador_MDU
    a ex:ComponenteElectrico ;
    ex:identificador "-MDU" ;
    rdfs:label "Regulador de productos doble uso (-MDU)" ;
    ex:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar la velocidad programada." .