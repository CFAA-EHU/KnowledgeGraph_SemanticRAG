@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_9623
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Captación: Cable roto señal B"@es ;
    ex:identificador      "9623" ;
    ex:textoExtracto      "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal B de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es ;
    ex:solucionaFallo      ex:TareaMantenimiento_RevisarCableado_9623 .

ex:Fallo_9624
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Captación: Cable roto señal I0"@es ;
    ex:identificador      "9624" ;
    ex:textoExtracto      "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal I0 del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es ;
    ex:solucionaFallo      ex:TareaMantenimiento_RevisarCableado_9624 .

ex:Fallo_9625
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Captación: Cable roto señal AL"@es ;
    ex:identificador      "9625" ;
    ex:textoExtracto      "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal AL del contaje del regulador. El regulador no recibe la señal A de la captación. SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es ;
    ex:solucionaFallo      ex:TareaMantenimiento_RevisarCableado_9625 .

ex:Fallo_9626
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Captación: Sobrecorriente o cortocircuito"@es ;
    ex:identificador      "9626" ;
    ex:textoExtracto      "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador. SOLUCIÓN Revisar el conexionado y el nivel de las señales proporcionadas por el captador."@es ;
    ex:solucionaFallo      ex:TareaMantenimiento_RevisarConexionado_9626 .

ex:Fallo_9627
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Captación: Recibida señal de alarma"@es ;
    ex:identificador      "9627" ;
    ex:textoExtracto      "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo. SOLUCIÓN Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado."@es ;
    ex:solucionaFallo      ex:TareaMantenimiento_RevisarEncoder_9627 .

ex:TareaMantenimiento_RevisarCableado_9623
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar cable y conexión de entradas de captación (Fallo 9623)"@es ;
    ex:textoExtracto      "Revisar el cable y la conexión de las entradas de captación."@es .

ex:TareaMantenimiento_RevisarCableado_9624
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar cable y conexión de entradas de captación (Fallo 9624)"@es ;
    ex:textoExtracto      "Revisar el cable y la conexión de las entradas de captación."@es .

ex:TareaMantenimiento_RevisarCableado_9625
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar cable y conexión de entradas de captación (Fallo 9625)"@es ;
    ex:textoExtracto      "Revisar el cable y la conexión de las entradas de captación."@es .

ex:TareaMantenimiento_RevisarConexionado_9626
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar conexionado y nivel de señales del captador (Fallo 9626)"@es ;
    ex:textoExtracto      "Revisar el conexionado y el nivel de las señales proporcionadas por el captador."@es .

ex:TareaMantenimiento_RevisarEncoder_9627
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Revisar documentación del encóder y conexionado (Fallo 9627)"@es ;
    ex:textoExtracto      "Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado."@es .

ex:SistemaCaptacion
    a                     ex:Sistema ;
    rdfs:label            "Sistema de captación de señales"@es ;
    ex:textoExtracto      "El lazo ha detectado cable roto en la señal [...] del contaje del regulador. El regulador no recibe la señal [...] de la captación."@es ;
    ex:tieneComponente     ex:ComponenteElectrico_Regulador ,
                           ex:ComponenteElectrico_Captador ,
                           ex:ComponenteElectrico_Encoder .

ex:ComponenteElectrico_Regulador
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Regulador del sistema de captación"@es ;
    ex:textoExtracto      "El regulador no recibe la señal [...] de la captación."@es .

ex:ComponenteElectrico_Captador
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Captador de señales"@es ;
    ex:textoExtracto      "Se ha producido un cortocircuito o se está sobrealimentando el captador."@es .

ex:ComponenteElectrico_Encoder
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Encóder del sistema de captación"@es ;
    ex:textoExtracto      "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo."@es .