@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9632_ABSIND
    a                   ex:AvisoSeguridad ;
    rdfs:label          "Error 9632 ABSIND" ;
    ex:identificador    "9632" ;
    ex:textoExtracto    "9632 ABSIND: Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema."@es .

ex:Modulo_ABSIND
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Módulo ABSIND" ;
    ex:textoExtracto    "módulo ABSIND"@es ;
    ex:activaAlarma     ex:Error_9632_ABSIND .

ex:Sistema_Control
    a                   ex:Sistema ;
    rdfs:label          "Sistema de control" ;
    ex:textoExtracto    "arranque o funcionamiento habitual del sistema"@es ;
    ex:controla        ex:Modulo_ABSIND ;
    ex:activaAlarma     ex:Error_9632_ABSIND .

ex:Accion_ComprobarConexion
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Comprobar conexión y cableado" ;
    ex:textoExtracto    "SOLUCIÓN Comprobar que la conexión y el cableado son satisfactorios."@es ;
    ex:solucionaFallo   ex:Error_9632_ABSIND .

ex:Accion_ContactarSoporte
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Contactar con Fagor Automation" ;
    ex:textoExtracto    "Si el error persiste, póngase en contacto con Fagor Automation."@es ;
    ex:solucionaFallo   ex:Error_9632_ABSIND .

ex:Empresa_FagorAutomation
    a                   ex:Empresa ;
    rdfs:label          "Fagor Automation" ;
    ex:textoExtracto    "Fagor Automation"@es .