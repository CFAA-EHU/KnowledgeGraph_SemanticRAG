@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9635_Inductosyn
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9635: INDUCTOSYN - señal GRAY no presente"@es ;
    ex:identificador "9635" ;
    ex:textoExtracto "9635 INDUCTOSYN: señal GRAY no presente. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal GRAY del transductor inductosyn/resolver ausente."@es .

ex:Sistema_Inductosyn
    a ex:Sistema ;
    ex:textoExtracto "transductor inductosyn/resolver"@es ;
    ex:activaAlarma ex:Error_9635_Inductosyn .

ex:Senal_GRAY
    a ex:Parametro ;
    rdfs:label "Señal GRAY"@es ;
    ex:textoExtracto "señal GRAY"@es ;
    ex:monitoreaParametro ex:Sistema_Inductosyn .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ex:textoExtracto "póngase en contacto con Fagor Automation"@es .