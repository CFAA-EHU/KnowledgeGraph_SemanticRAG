@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_9638
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9638: INDUCTOSYN - Error desconocido" ;
    ex:textoExtracto "9638 INDUCTOSYN: Error desconocido. [...] Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND." ;
    ex:identificador "9638" .

ex:Error_9639
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9639: INDUCTOSYN - Inconsistencia parámetro SSITYPE" ;
    ex:textoExtracto "9639 INDUCTOSYN: Inconsistencia parámetro SSITYPE con captador conectado. [...] El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC y con el tipo de captador (inductosyn/resolver) conectado al módulo ABSIND." ;
    ex:identificador "9639" .

ex:Error_9640
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9640: INDUCTOSYN - Nivel de tensión 24 Vdc/15 Vdc bajo" ;
    ex:textoExtracto "9640 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado bajo. [...] Fallo en la alimentación del módulo." ;
    ex:identificador "9640" .

ex:Error_9641
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9641: INDUCTOSYN - Nivel de tensión 24 Vdc/15 Vdc alto" ;
    ex:textoExtracto "9641 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado alto. [...] Fallo en la alimentación del módulo." ;
    ex:identificador "9641" .

ex:Error_9642
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9642: Captación digital Fagor - Error en pista absoluta" ;
    ex:textoExtracto "9642 Captación digital Fagor. Error en la pista absoluta. [...] Pérdida de contaje. La señal analógica < 0,20 Vpp." ;
    ex:identificador "9642" .

ex:Modulo_ABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ex:textoExtracto "módulo ABSIND ha generado un error desconocido. [...] sustituir el módulo ABSIND asociado a esa captación. [...] dipswitch S50 del módulo ABSIND. [...] alimentación del módulo ABSIND." .

ex:Parametro_SSITYPE
    a ex:Parametro ;
    rdfs:label "Parámetro SSITYPE" ;
    ex:textoExtracto "El valor del parámetro SSITYPE del CNC no coincide con el valor seleccionado en el dipswitch S50 del módulo ABSIND." ;
    ex:identificador "SSITYPE" .

ex:Dipswitch_S50
    a ex:ComponenteElectrico ;
    rdfs:label "Dipswitch S50" ;
    ex:textoExtracto "dipswitch S50 del módulo ABSIND. El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC." ;
    ex:identificador "S50" .

ex:Alimentacion_24V_15V
    a ex:ComponenteElectrico ;
    rdfs:label "Alimentación 24 Vdc/15 Vdc" ;
    ex:textoExtracto "Nivel de tensión 24 Vdc/15 Vdc demasiado bajo/alto. [...] Fallo en la alimentación del módulo." .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "póngase en contacto con Fagor Automation." .

# Relaciones
ex:Error_9638 ex:solucionaFallo ex:Modulo_ABSIND .
ex:Error_9639 ex:solucionaFallo ex:Parametro_SSITYPE , ex:Dipswitch_S50 .
ex:Error_9640 ex:solucionaFallo ex:Alimentacion_24V_15V .
ex:Error_9641 ex:solucionaFallo ex:Alimentacion_24V_15V .
ex:Modulo_ABSIND ex:tieneComponente ex:Dipswitch_S50 .
ex:Modulo_ABSIND ex:alimenta ex:Alimentacion_24V_15V .