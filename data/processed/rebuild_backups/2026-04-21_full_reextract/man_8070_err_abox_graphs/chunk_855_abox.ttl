@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error9643
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 9643 - Captación digital Fagor. Error en la CPU"@es ;
    ex:textoExtracto "9643 Captación digital Fagor. Error en la CPU. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es ;
    ex:identificador "9643" ;
    ex:solucionaFallo ex:Encoder_Regla_Danado .

ex:Error9644
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 9644 - Captación digital Fagor. Error de los potenciómetros de ajuste"@es ;
    ex:textoExtracto "9644 Captación digital Fagor. Error de los potenciómetros de ajuste. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla."@es ;
    ex:identificador "9644" ;
    ex:solucionaFallo ex:Encoders_Potenciometros_Danados .

ex:Error9645
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 9645 - Captación digital Fagor. Error del captador de imagen (CCD)"@es ;
    ex:textoExtracto "9645 Captación digital Fagor. Error del captador de imagen (CCD). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)."@es ;
    ex:identificador "9645" ;
    ex:solucionaFallo ex:Encoder_CCD_LED_Danado .

ex:Error9646
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error 9646 - Captación digital Fagor. Tensión de alimentación fuera de rango"@es ;
    ex:textoExtracto "9646 Captación digital Fagor. Tensión de alimentación fuera de rango. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es ;
    ex:identificador "9646" ;
    ex:solucionaFallo ex:TensionAlimentacion_FueraRango .

ex:Encoder_Regla_Danado
    a               ex:ComponenteElectrico ;
    rdfs:label      "Encóder o cabeza de regla dañado"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado."@es .

ex:Encoders_Potenciometros_Danados
    a               ex:ComponenteElectrico ;
    rdfs:label      "Encóder o potenciómetros de ajuste dañados"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado [relacionado con potenciómetros de ajuste]."@es .

ex:Encoder_CCD_LED_Danado
    a               ex:ComponenteElectrico ;
    rdfs:label      "Encóder, CCD o LED dañado"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)."@es .

ex:TensionAlimentacion_FueraRango
    a               ex:Parametro ;
    rdfs:label      "Tensión de alimentación fuera de rango (4.1V-5.3V)"@es ;
    ex:textoExtracto "La tensión de alimentación debe estar entre 5,3 V y 4,1 V."@es ;
    ex:valor         "4.1-5.3 V" .

ex:FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation"@es ;
    ex:textoExtracto "Póngase en contacto con Fagor Automation."@es .

ex:TareaMantenimiento_ReemplazoEncoder
    a               ex:TareaMantenimiento ;
    rdfs:label      "Reemplazar encóder o cabeza de regla"@es ;
    ex:textoExtracto "Reemplazar el encóder o la cabeza de la regla."@es ;
    ex:requiereMantenimiento ex:Encoder_Regla_Danado ;
    ex:requiereMantenimiento ex:Encoders_Potenciometros_Danados ;
    ex:requiereMantenimiento ex:Encoder_CCD_LED_Danado .

ex:TareaMantenimiento_LimpiezaRegla
    a               ex:TareaMantenimiento ;
    rdfs:label      "Limpiar cristal o cinta de acero de la regla"@es ;
    ex:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ex:TareaMantenimiento_ComprobacionTolerancias
    a               ex:TareaMantenimiento ;
    rdfs:label      "Comprobar tolerancias de montaje"@es ;
    ex:textoExtracto "Comprobar las tolerancias de montaje."@es .

ex:TareaMantenimiento_ComprobacionCableAlimentacion
    a               ex:TareaMantenimiento ;
    rdfs:label      "Comprobar cable de alimentación del encóder"@es ;
    ex:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado."@es .