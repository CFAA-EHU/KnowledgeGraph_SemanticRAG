@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Fallo_9659
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Nivel de tensión por debajo del 40%"@es ;
    ex:identificador "9659" ;
    ex:textoExtracto "Nivel de tensión por debajo del 40%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 40 % del valor esperado."@es ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Revisión de tensiones de red y cableado hasta la tarjeta sense"@es ;
        ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."@es
    ] .

ex:Fallo_9660
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Nivel de tensión cerca del 0%"@es ;
    ex:identificador "9660" ;
    ex:textoExtracto "Nivel de tensión cerca del 0%. DETECCIÓN Durante el"@es ;
    ex:solucionaFallo [
        a               ex:TareaMantenimiento ;
        rdfs:label      "Revisión de tensiones de red y cableado hasta la tarjeta sense"@es ;
        ex:textoExtracto "Revisar tensiones de red y cableado hasta la tarjeta sense."@es
    ] .

ex:TarjetaSense
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tarjeta sense"@es ;
    ex:textoExtracto "cableado hasta la tarjeta sense"@es .