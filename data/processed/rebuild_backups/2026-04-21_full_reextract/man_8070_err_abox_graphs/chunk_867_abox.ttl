@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9725 a ex:DiagnosticoFallo ;
    rdfs:label "Diferencia excesiva de posición real" ;
    ex:textoExtracto "9725 Diferencia excesiva de la posición real. [...] SOLUCIÓN Revisar la parametrización de las captaciones del eje." ;
    ex:identificador "9725" .

ex:Error_9726 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el regulador (I²t)" ;
    ex:textoExtracto "9726 Sobrecarga en el regulador. [...] SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un regulador de más potencia." ;
    ex:identificador "9726" ;
    ex:solucionaFallo ex:Regulador .

ex:Error_9727 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el regulador (I²t)" ;
    ex:textoExtracto "9727 Sobrecarga en el regulador. [...] SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un regulador de más potencia." ;
    ex:identificador "9727" ;
    ex:solucionaFallo ex:Regulador .

ex:Error_9728 a ex:DiagnosticoFallo ;
    rdfs:label "Sobrevelocidad" ;
    ex:textoExtracto "9728 Sobrevelocidad. [...] SOLUCIÓN Revisar parametrización y/o ajuste del sistema." ;
    ex:identificador "9728" .

ex:Error_9729 a ex:DiagnosticoFallo ;
    rdfs:label "OverRun" ;
    ex:textoExtracto "9729 OverRun. [...] SOLUCIÓN Revisar los parámetros INVERT y LOOPCH." ;
    ex:identificador "9729" .

ex:Error_9730 a ex:DiagnosticoFallo ;
    rdfs:label "Error en la RPS" ;
    ex:textoExtracto "9730 Error en la RPS. [...] SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "9730" .

ex:Error_9731 a ex:DiagnosticoFallo ;
    rdfs:label "Alarma de captación en volante" ;
    ex:textoExtracto "9731 Alarma de captación en volante. [...] SOLUCIÓN Revisar el conexionado y la alimentación del volante." ;
    ex:identificador "9731" ;
    ex:solucionaFallo ex:Volante .

ex:Regulador a ex:ComponenteElectrico ;
    rdfs:label "Regulador del sistema" ;
    ex:textoExtracto "Protección I²t del regulador. El ciclo de trabajo es demasiado exigente para el regulador." .

ex:Volante a ex:ComponenteMecanico ;
    rdfs:label "Volante de entrada de captación" ;
    ex:textoExtracto "Alarma de captación en el volante de la entrada de captación del regulador." .

ex:Parametro_FBACKDIFF a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:textoExtracto "La diferencia de posición entre la captación interna y externa es mayor que el parámetro FBACKDIFF." ;
    ex:identificador "FBACKDIFF" .

ex:Parametro_INVERT a ex:Parametro ;
    rdfs:label "INVERT" ;
    ex:textoExtracto "Revisar los parámetros INVERT y LOOPCH." ;
    ex:identificador "INVERT" .

ex:Parametro_LOOPCH a ex:Parametro ;
    rdfs:label "LOOPCH" ;
    ex:textoExtracto "Revisar los parámetros INVERT y LOOPCH." ;
    ex:identificador "LOOPCH" .

ex:Motor a ex:ComponenteElectrico ;
    rdfs:label "Motor del sistema" ;
    ex:textoExtracto "reducir el par aplicado al motor" .