@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloComunicacion_9733
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación double AT Miss (9733)" ;
    ex:identificador "9733" ;
    ex:textoExtracto "Fallo en la comunicación double AT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador. SOLUCIÓN Revisar la conexión Sercos III." ;
    ex:solucionaFallo ex:SistemaBusSercosIII .

ex:FalloComunicacion_9734
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación AT (9734)" ;
    ex:identificador "9734" ;
    ex:textoExtracto "Fallo en la comunicación AT. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador. SOLUCIÓN Revisar la conexión Sercos III." ;
    ex:solucionaFallo ex:SistemaBusSercosIII .

ex:FalloComunicacion_9735
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación MDT Miss (9735)" ;
    ex:identificador "9735" ;
    ex:textoExtracto "Fallo en la comunicación MDT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. Un regulador no ha respondido a los datos cíclicos enviados por el CNC. SOLUCIÓN Revisar la conexión Sercos III." ;
    ex:solucionaFallo ex:SistemaBusSercosIII .

ex:FalloComunicacion_9736
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la comunicación MDT (9736)" ;
    ex:identificador "9736" ;
    ex:textoExtracto "Fallo en la comunicación MDT. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de inicialización del bus Sercos III. Un regulador no ha respondido a los datos cíclicos enviados por el CNC. SOLUCIÓN Revisar la conexión Sercos III." ;
    ex:solucionaFallo ex:SistemaBusSercosIII .

ex:FalloSincronizacion_9737
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en la sincronización (9737)" ;
    ex:identificador "9737" ;
    ex:textoExtracto "Fallo en la sincronización. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC envía un mensaje de sincronismo en cada ciclo (4 ms, normalmente) que hace que los reguladores se sincronicen. Si en algún momento los reguladores no pueden sincronizarse o pierden la sincronización, se origina este error. SOLUCIÓN Posiblemente el CNC no ha enviado este mensaje o si lo ha hecho no ha sido en el momento exacto." ;
    ex:solucionaFallo ex:SistemaBusSercosIII .

ex:SistemaBusSercosIII
    a ex:Sistema ;
    rdfs:label "Bus Sercos III" ;
    ex:textoExtracto "Error de inicialización del bus Sercos III. El CNC no ha recibido los datos cíclicos de un regulador." .

ex:FalloConexionVolante
    a ex:DiagnosticoFallo ;
    rdfs:label "Fallo en conexionado y alimentación del volante" ;
    ex:textoExtracto "SOLUCIÓN Revisar el conexionado y la alimentación del volante." ;
    ex:solucionaFallo ex:ComponenteElectrico_Volante .

ex:ComponenteElectrico_Volante
    a ex:ComponenteElectrico ;
    rdfs:label "Volante (alimentación y conexionado)" ;
    ex:textoExtracto "Revisar el conexionado y la alimentación del volante." .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .