@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_9738_DataLink_No_Presente
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9738: DataLink no presente" ;
    ex:textoExtracto "9738 DataLink no presente. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado. SOLUCIÓN Revisar la conexión EtherCAT. Conectar el cable EtherCAT." ;
    ex:identificador "9738" .

ex:Error_9739_Paquete_Perdido
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9739: Paquete perdido" ;
    ex:textoExtracto "9739 Paquete perdido. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado o algún nodo no funciona correctamente. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." ;
    ex:identificador "9739" .

ex:Error_9740_CRC_Incorrecto
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9740: CRC incorrecto" ;
    ex:textoExtracto "9740 CRC incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. El cable está desconectado o hay interferencias en el bus. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." ;
    ex:identificador "9740" .

ex:Error_9741_Working_Counter_Error
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9741: Working Counter error" ;
    ex:textoExtracto "9741 Working Counter error. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus EtherCAT. Funcionamiento incorrecto de alguno de los nodos. SOLUCIÓN Revisar la conexión EtherCAT y el estado de los nodos." ;
    ex:identificador "9741" .

ex:Error_9742_Regulador_RPS
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9742: Error en el regulador RPS" ;
    ex:textoExtracto "9742 Error en el regulador RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La RPS ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." ;
    ex:identificador "9742" .

ex:Error_9743_Sobrecarga_RPS
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9743: Sobrecarga en el regulador RPS" ;
    ex:textoExtracto "9743 Sobrecarga en el regulador RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error I²t en la RPS. El ciclo de trabajo de devolución es demasiado exigente para la potencia de la RPS. SOLUCIÓN Devolución/frenada del sistema más suave. Utilizar una RPS más potente." ;
    ex:identificador "9743" .

ex:Error_9744_Sobrecarga_RPS
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 9744: Sobrecarga en el regulador RPS" ;
    ex:textoExtracto "9744 Sobrecarga en el regulador RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error I²t en la RPS. El ciclo de trabajo de devolución es demasiado exigente para la potencia de la RPS. SOLUCIÓN Devolución/frenada del sistema más suave. Utilizar una RPS más potente." ;
    ex:identificador "9744" .

ex:Bus_EtherCAT
    a ex:ComponenteElectrico ;
    rdfs:label "Bus EtherCAT" ;
    ex:textoExtracto "Error en el bus EtherCAT. El cable está desconectado o algún nodo no funciona correctamente." .

ex:Regulador_RPS
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador RPS" ;
    ex:textoExtracto "Error en el regulador RPS. La RPS ha generado un error sin determinar." .

ex:Error_9738_DataLink_No_Presente ex:solucionaFallo ex:Bus_EtherCAT .
ex:Error_9739_Paquete_Perdido ex:solucionaFallo ex:Bus_EtherCAT .
ex:Error_9740_CRC_Incorrecto ex:solucionaFallo ex:Bus_EtherCAT .
ex:Error_9741_Working_Counter_Error ex:solucionaFallo ex:Bus_EtherCAT .
ex:Error_9742_Regulador_RPS ex:solucionaFallo ex:Regulador_RPS .
ex:Error_9743_Sobrecarga_RPS ex:solucionaFallo ex:Regulador_RPS .
ex:Error_9744_Sobrecarga_RPS ex:solucionaFallo ex:Regulador_RPS .