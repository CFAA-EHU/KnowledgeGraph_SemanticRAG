@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_20001 a ex:Alarma ;
    ex:identificador "20001" ;
    rdfs:label "Esperando AUXEND de PLC"@es ;
    ex:textoExtracto "20001 Esperando AUXEND de PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN El PLC debe responder cuando se cumplan las condiciones adecuadas o pulsar [RESET]."@es .

ex:Alarma_20002 a ex:Alarma ;
    ex:identificador "20002" ;
    rdfs:label "Esperando cabezal %x parado"@es ;
    ex:textoExtracto "20002 Esperando cabezal %x parado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ex:Alarma_20003 a ex:Alarma ;
    ex:identificador "20003" ;
    rdfs:label "Esperando carga de programa"@es ;
    ex:textoExtracto "20003 Esperando carga de programa. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ex:Alarma_20004 a ex:Alarma ;
    ex:identificador "20004" ;
    rdfs:label "Esperando señal REVOK del cabezal %x para iniciar G33/G34"@es ;
    ex:textoExtracto "20004 Esperando señal REVOK del cabezal %x para iniciar G33/G34. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ex:Alarma_20005 a ex:Alarma ;
    ex:identificador "20005" ;
    rdfs:label "Esperando confirmación de gama por el regulador"@es ;
    ex:textoExtracto "20005 Esperando confirmación de gama por el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ex:Alarma_20006 a ex:Alarma ;
    ex:identificador "20006" ;
    rdfs:label "Esperando final de maniobra #PARK en el regulador"@es ;
    ex:textoExtracto "20006 Esperando final de maniobra #PARK en el regulador. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ex:Alarma_20007 a ex:Alarma ;
    ex:identificador "20007" ;
    rdfs:label "Esperando canal disponible para #EXEC/#EXBLK"@es ;
    ex:textoExtracto "20007 Esperando canal disponible para #EXEC/#EXBLK. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El canal debe quedar libre cuando finaliza la ejecución."@es .

ex:InterfazUsuario_Reset a ex:InterfazUsuario ;
    rdfs:label "[RESET]"@es ;
    ex:textoExtracto "pulsar [RESET]"@es .

ex:Alarma_20001 ex:solucionaFallo ex:InterfazUsuario_Reset .
