@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Alarma_20015 a ex:Alarma ;
    rdfs:label "Alarma 20015: G33/G34/G95 con cabezal parado"@es ;
    ex:identificador "20015" ;
    ex:textoExtracto "20015 G33/G34/G95 con cabezal %x parado. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal debe ponerse en marcha para ejecutar G33/G34/G95."@es .

ex:Alarma_20016 a ex:Alarma ;
    rdfs:label "Alarma 20016: Esperando finalizar petición de ejes"@es ;
    ex:identificador "20016" ;
    ex:textoExtracto "20016 Esperando finalizar petición de ejes. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El eje solicitado debe llegar al canal o ser liberado por otro."@es .

ex:Alarma_20017 a ex:Alarma ;
    rdfs:label "Alarma 20017: Esperando finalizar petición de cabezal"@es ;
    ex:identificador "20017" ;
    ex:textoExtracto "20017 Esperando finalizar petición de cabezal. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal solicitado debe llegar al canal o ser liberado por otro."@es .

ex:Alarma_20018 a ex:Alarma ;
    rdfs:label "Alarma 20018: Esperando finalizar forzar cota (G174) del eje %x"@es ;
    ex:identificador "20018" ;
    ex:textoExtracto "20018 Esperando finalizar forzar cota (G174) del eje %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. La función G174 debe finalizar."@es .

ex:Alarma_20019 a ex:Alarma ;
    rdfs:label "Alarma 20019: Esperando señal XFERINH del PLC"@es ;
    ex:identificador "20019" ;
    ex:textoExtracto "20019 Esperando señal XFERINH del PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe activar la señal _XFERINH."@es .

ex:Alarma_20020 a ex:Alarma ;
    rdfs:label "Alarma 20020: Esperando ejes en posición"@es ;
    ex:identificador "20020" ;
    ex:textoExtracto "20020 Esperando ejes en posición. DETECCIÓN Durante el funcionamiento habitual del sistema. justificada o bloqueo."@es .

ex:InterfazUsuario_Reset a ex:InterfazUsuario ;
    rdfs:label "Botón [RESET]"@es ;
    ex:textoExtracto "Pulsar [RESET] y analizar las causas del retraso."@es .