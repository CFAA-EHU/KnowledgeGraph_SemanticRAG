@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_20020
    a ex:DiagnosticoFallo ;
    rdfs:label "Espera de ejes en posición"@es ;
    ex:identificador "20020" ;
    ex:textoExtracto "20020 Esperando ejes en posición. [...] SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. Los ejes deben llegar a posición."@es ;
    ex:solucionaFallo ex:Accion_Reset_20020 .

ex:Fallo_20021
    a ex:DiagnosticoFallo ;
    rdfs:label "Espera de inicialización de captaciones"@es ;
    ex:identificador "20021" ;
    ex:textoExtracto "20021 Esperando inicialización de captaciones. DETECCIÓN Durante el funcionamiento"@es .

ex:Accion_Reset_20020
    a ex:TareaMantenimiento ;
    rdfs:label "Pulsar [RESET] para fallo 20020"@es ;
    ex:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso."@es .

ex:Senal_XFERINH
    a ex:Parametro ;
    rdfs:label "Señal _XFERINH"@es ;
    ex:identificador "_XFERINH" ;
    ex:textoExtracto "El PLC debe activar la señal _XFERINH."@es ;
    ex:monitoreaParametro ex:SistemaControlPLC .

ex:SistemaControlPLC
    a ex:Sistema ;
    rdfs:label "Sistema de control PLC"@es ;
    ex:textoExtracto "El PLC debe activar la señal _XFERINH."@es ;
    ex:controla ex:Senal_XFERINH .

ex:InterfazUsuario_Reset
    a ex:InterfazUsuario ;
    rdfs:label "Botón [RESET]"@es ;
    ex:identificador "RESET" ;
    ex:textoExtracto "Pulsar [RESET] y analizar las causas del retraso."@es ;
    ex:habilitadoPor ex:SistemaControlPLC .