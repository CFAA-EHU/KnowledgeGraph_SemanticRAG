ex:_20027_AvisoSeguridad
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando pasar a lazo abierto el cabezal %x"@es ;
    ex:textoExtracto "20027 Esperando pasar a lazo abierto el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es ;
    ex:identificador "20027" .

ex:_20028_AvisoSeguridad
    a ex:AvisoSeguridad ;
    rdfs:label "Esperando pasar a lazo cerrado"@es ;
    ex:textoExtracto "20028 Esperando pasar a lazo cerrado el"@es ;
    ex:identificador "20028" .

ex:InterfazUsuario_Reset
    a ex:InterfazUsuario ;
    rdfs:label "[RESET]"@es ;
    ex:textoExtracto "Pulsar [RESET] y analizar las causas del retraso."@es .

ex:_20027_AvisoSeguridad ex:solucionaFallo ex:InterfazUsuario_Reset .
ex:_20028_AvisoSeguridad ex:solucionaFallo ex:InterfazUsuario_Reset .