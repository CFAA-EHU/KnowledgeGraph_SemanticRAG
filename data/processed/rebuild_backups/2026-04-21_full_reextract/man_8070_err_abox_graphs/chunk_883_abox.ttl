@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23008
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría"@es ;
    ex:identificador "23008" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo de la compensación volumétrica no son correctos. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:ParametroCompensacionVolumetrica .

ex:Error23009
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: los parámetros de 'SQUARENESS' no tienen puntos contiguos"@es ;
    ex:identificador "23009" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: los parámetros de 'SQUARENESS' no tienen puntos contiguos. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo de la compensación volumétrica no son correctos. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:ParametroSquareness .

ex:Error23010
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación"@es ;
    ex:identificador "23010" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera del límite inferior del volumen de compensación. SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación."@es ;
    ex:monitoreaParametro ex:ParametroCoordenadaVolumen .

ex:Error23011
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación"@es ;
    ex:identificador "23011" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera del límite superior del volumen de compensación. SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación."@es ;
    ex:monitoreaParametro ex:ParametroCoordenadaVolumen .

ex:Error23012
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo"@es ;
    ex:identificador "23012" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El valor mínimo definido en el archivo de la compensación es mayor que el máximo. SOLUCIÓN Modificar el valor mínimo o máximo del archivo de compensación"@es ;
    ex:monitoreaParametro ex:ParametroRangoCompensacion .

ex:ParametroCompensacionVolumetrica
    a ex:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica"@es ;
    ex:textoExtracto "puntos de la volumetría"@es ;
    ex:valor "Puntos de compensación volumétrica"@es .

ex:ParametroSquareness
    a ex:Parametro ;
    rdfs:label "Parámetro SQUARENESS"@es ;
    ex:textoExtracto "parámetros de 'SQUARENESS'"@es ;
    ex:valor "Puntos contiguos de SQUARENESS"@es .

ex:ParametroCoordenadaVolumen
    a ex:Parametro ;
    rdfs:label "Parámetro de coordenada del volumen de compensación"@es ;
    ex:textoExtracto "coordenada [...] del volumen de compensación"@es .

ex:ParametroRangoCompensacion
    a ex:Parametro ;
    rdfs:label "Parámetro de rango de compensación (mínimo/máximo)"@es ;
    ex:textoExtracto "valor mínimo [...] mayor que el máximo"@es ;
    ex:valor "Rango de compensación (mínimo ≤ máximo)"@es .

ex:SistemaValidacionParametros
    a ex:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ex:textoExtracto "arranque del sistema o validación de los parámetros máquina"@es ;
    ex:controla ex:ParametroCompensacionVolumetrica , ex:ParametroSquareness , ex:ParametroCoordenadaVolumen , ex:ParametroRangoCompensacion .