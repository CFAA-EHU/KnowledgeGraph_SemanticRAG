@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23013
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: los puntos del fichero están en orden inverso" ;
    ex:identificador "23013" ;
    ex:textoExtracto "23013 Error en el fichero de compensación volumétrica: los puntos del fichero están en orden inverso. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo están en orden inverso. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica." .

ex:Error23014
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera de los bordes de interpolación" ;
    ex:identificador "23014" ;
    ex:textoExtracto "23014 Error en el fichero de compensación volumétrica: la coordenada está fuera de los bordes de interpolación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera de los bordes de interpolación. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica." .

ex:Error23015
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el análisis del fichero de definición de la compensación volumétrica" ;
    ex:identificador "23015" ;
    ex:textoExtracto "23015 Error en el análisis del fichero de definición de la compensación volumétrica. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica no contiene los datos adecuados. SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ex:Error23016
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: no se permite el sistema de coordenadas máquina \"MACHINE\"" ;
    ex:identificador "23016" ;
    ex:textoExtracto "23016 Error en el fichero de compensación volumétrica: no se permite el sistema de coordenadas máquina \"MACHINE\". DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA No se permite el sistema de coordenadas \"MACHINE\". SOLUCIÓN Modificar el archivo de la compensación volumétrica para que esté en el sistema de coordenadas KINEMATIC." .

ex:Error23017
    a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el sistema de coordenadas es incorrecto" ;
    ex:identificador "23017" ;
    ex:textoExtracto "23017 Error en el fichero de compensación volumétrica: el sistema de coordenadas es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El sistema de coordenadas definido en el archivo es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ex:ParametroCompensacionVolumetrica
    a ex:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica" ;
    ex:textoExtracto "validación de los parámetros máquina" ;
    ex:monitoreaParametro ex:Error23013, ex:Error23014, ex:Error23015, ex:Error23016, ex:Error23017 .