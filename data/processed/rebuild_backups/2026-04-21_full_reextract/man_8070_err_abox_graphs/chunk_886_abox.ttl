@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23018
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (SQUARENESS_IS_POSITIVE)"@es ;
    ex:identificador "23018" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"SQUARENESS_IS_POSITIVE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"SQUARENESS_IS_POSITIVE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:Parametro_SQUARENESS_IS_POSITIVE .

ex:Error23019
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (INTERVAL_TYPE)"@es ;
    ex:identificador "23019" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"INTERVAL_TYPE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"INTERVAL_TYPE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:Parametro_INTERVAL_TYPE .

ex:Error23020
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (VALUE_TYPE)"@es ;
    ex:identificador "23020" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"VALUE_TYPE\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"VALUE_TYPE\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es ;
    ex:monitoreaParametro ex:Parametro_VALUE_TYPE .

ex:Error23021
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (límite inferior primer eje)"@es ;
    ex:identificador "23021" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del primer eje está fuera del límite inferior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del primer eje está fuera del límite inferior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ex:Error23022
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (límite superior primer eje)"@es ;
    ex:identificador "23022" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del primer eje está fuera del límite superior del volumen. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada del primer eje está fuera del límite superior del volumen. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica."@es .

ex:Error23023
    a ex:AvisoSeguridad ;
    rdfs:label "Error en fichero de compensación volumétrica (límite inferior segundo eje)"@es ;
    ex:identificador "23023" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite inferior del volumen."@es .

ex:Parametro_SQUARENESS_IS_POSITIVE
    a ex:Parametro ;
    rdfs:label "SQUARENESS_IS_POSITIVE" ;
    ex:textoExtracto "parámetro del fichero \"SQUARENESS_IS_POSITIVE\""@es .

ex:Parametro_INTERVAL_TYPE
    a ex:Parametro ;
    rdfs:label "INTERVAL_TYPE" ;
