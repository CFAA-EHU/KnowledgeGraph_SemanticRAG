ex:SistemaCompensacionVolumetrica
    a ex:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es ;
    ex:textoExtracto "arranque del sistema o validación de los parámetros máquina"@es ;
    ex:tieneComponente ex:Parametro_SQUARENESS_IS_POSITIVE , ex:Parametro_INTERVAL_TYPE , ex:Parametro_VALUE_TYPE ;
    ex:activaAlarma ex:Error23018 , ex:Error23019 , ex:Error23020 , ex:Error23021 , ex:Error23022 , ex:Error23023 .