@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_23028 a ex:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ex:identificador "23028" ;
    ex:textoExtracto "23028 Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son válidas. SOLUCIÓN Modificar el archivo de la compensación"@es .

ex:Parametro_UnidadesVolumetria a ex:Parametro ;
    rdfs:label "unidades del fichero de volumetría"@es ;
    ex:textoExtracto "error en las unidades del fichero de volumetría"@es ;
    ex:monitoreaParametro ex:Error_23028 .

ex:Sistema_Arranque a ex:Sistema ;
    rdfs:label "Sistema de arranque y validación de parámetros máquina"@es ;
    ex:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina"@es ;
    ex:controla ex:Parametro_UnidadesVolumetria .