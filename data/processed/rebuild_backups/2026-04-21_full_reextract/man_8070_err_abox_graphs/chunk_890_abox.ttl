@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23029
    a ex:DiagnosticoFallo ;
    ex:identificador "23029" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"HEADER:COUNT\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro \"HEADER:COUNT\" es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica." ;
    rdfs:label "Error 23029: HEADER:COUNT incorrecto" .

ex:Error23030
    a ex:DiagnosticoFallo ;
    ex:identificador "23030" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: error en las unidades del fichero de volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Las unidades del archivo no son válidas. SOLUCIÓN Modificar el archivo de la compensación volumétrica." ;
    rdfs:label "Error 23030: Unidades de volumetría inválidas" .

ex:Error23031
    a ex:DiagnosticoFallo ;
    ex:identificador "23031" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: los intervalos de los puntos no son constantes. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los intervalos de los puntos no son constantes. SOLUCIÓN Modificar el archivo de la compensación volumétrica." ;
    rdfs:label "Error 23031: Intervalos no constantes" .

ex:Error23032
    a ex:DiagnosticoFallo ;
    ex:identificador "23032" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: los puntos del fichero de volumetría no están en el orden esperado. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos no están en el orden esperado. SOLUCIÓN Modificar el archivo de la compensación volumétrica." ;
    rdfs:label "Error 23032: Puntos desordenados" .

ex:Error23033
    a ex:DiagnosticoFallo ;
    ex:identificador "23033" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el intervalo es negativo. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El intervalo es negativo. SOLUCIÓN Modificar el archivo de la compensación volumétrica." ;
    rdfs:label "Error 23033: Intervalo negativo" .

ex:Error23034
    a ex:DiagnosticoFallo ;
    ex:identificador "23034" ;
    ex:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina." ;
    rdfs:label "Error 23034: AXIS_BEGIN incorrecto" .

ex:Parametro_HEADER_COUNT
    a ex:Parametro ;
    ex:identificador "HEADER:COUNT" ;
    ex:textoExtracto "parámetro del fichero \"HEADER:COUNT\"" ;
    rdfs:label "HEADER:COUNT" .

ex:Parametro_AXIS_BEGIN
    a ex:Parametro ;
    ex:identificador "AXIS_BEGIN" ;
    ex:textoExtracto "parámetro del fichero \"AXIS_BEGIN\"" ;
    rdfs:label "AXIS_BEGIN" .

ex:ArchivoCompensacionVolumetrica
    a ex:InterfazUsuario ;
    ex:identificador "compensación volumétrica" ;
    ex:textoExtracto "archivo de la compensación volumétrica" ;
    rdfs:label "Archivo de compensación volumétrica" .

ex:Error23029 ex:solucionaFallo ex:Parametro_HEADER_COUNT .
ex:Error23034 ex:solucionaFallo ex:Parametro_AXIS_BEGIN .
ex:Error23029 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .
ex:Error23030 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .
ex:Error23031 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .
ex:Error23032 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .
ex:Error23033 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .
ex:Error23034 ex:documentadoEn ex:ArchivoCompensacionVolumetrica .