@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error23034 a ex:DiagnosticoFallo ;
    ex:identificador "23034" ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ex:textoExtracto "23034 Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto."@es ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Modificación no autorizada del archivo de compensación volumétrica"@es ;
        ex:textoExtracto "SOLUCIÓN Modificar el archivo de la compensación volumétrica."@es
    ] ;
    ex:monitoreaParametro [
        a ex:Parametro ;
        ex:identificador "AXIS_BEGIN" ;
        ex:textoExtracto "El parámetro \"AXIS_BEGIN\" es incorrecto."@es
    ] .

ex:ParametroAXIS_BEGIN a ex:Parametro ;
    ex:identificador "AXIS_BEGIN" ;
    ex:textoExtracto "valor del parámetro del fichero \"AXIS_BEGIN\""@es ;
    ex:monitoreaParametro ex:Error23034 .