@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "El fichero definido en VCOMPFILE no es correcto. [...] El fichero definido en VCOMPFILE no tiene definidos todos los puntos."@es ;
    ex:identificador "VCOMPFILE" .

ex:Parametro_NPOINTSAX1
    a ex:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es ;
    ex:identificador "NPOINTSAX1" .

ex:Parametro_NPOINTSAX2
    a ex:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es ;
    ex:identificador "NPOINTSAX2" .

ex:Parametro_NPOINTSAX3
    a ex:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3"@es ;
    ex:identificador "NPOINTSAX3" .

ex:DiagnosticoFallo_FormatoVCOMPFILE
    a ex:DiagnosticoFallo ;
    rdfs:label "Error de formato en VCOMPFILE" ;
    ex:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto."@es ;
    ex:solucionaFallo ex:Parametro_VCOMPFILE .

ex:DiagnosticoFallo_PuntosFaltantesVCOMPFILE
    a ex:DiagnosticoFallo ;
    rdfs:label "Faltan puntos en VCOMPFILE" ;
    ex:textoExtracto "El fichero definido en VCOMPFILE no tiene definidos todos los puntos."@es ;
    ex:solucionaFallo ex:Parametro_VCOMPFILE ;
    ex:monitoreaParametro ex:Parametro_NPOINTSAX1 , ex:Parametro_NPOINTSAX2 , ex:Parametro_NPOINTSAX3 .