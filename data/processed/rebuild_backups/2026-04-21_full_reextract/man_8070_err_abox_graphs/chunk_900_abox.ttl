@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fallo_24020_EtherCAT_FicheroRutadoInexistente
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Fallo 24020: Fichero de rutado EtherCAT no existe"@es ;
    ex:identificador      "24020" ;
    ex:textoExtracto      "EtherCAT: Fichero de rutado no existe. [...] No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor."@es .

ex:Fallo_24021_EtherCAT_Generico
    a                     ex:DiagnosticoFallo ;
    rdfs:label            "Código de fallo 24021 (EtherCAT)"@es ;
    ex:identificador      "24021" ;
    ex:textoExtracto      "24021"@es .

ex:Sistema_CNC_PLC_Fagor
    a                     ex:Sistema ;
    rdfs:label            "Sistema CNC-PLC Fagor"@es ;
    ex:textoExtracto      "sistema CNC-PLC Fagor"@es ;
    ex:tieneComponente     ex:Bus_EtherCAT_Fagor .

ex:Bus_EtherCAT_Fagor
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Bus EtherCAT"@es ;
    ex:textoExtracto      "bus EtherCAT"@es ;
    ex:monitoreaParametro ex:Parametro_Rutado_EtherCAT .

ex:Parametro_Rutado_EtherCAT
    a                     ex:Parametro ;
    rdfs:label            "Parámetro de rutado EtherCAT"@es ;
    ex:textoExtracto      "fichero de rutado (mapeo)"@es ;
    ex:valor               "resourceRouterConf.xml" ;
    ex:documentadoEn       ex:Fallo_24020_EtherCAT_FicheroRutadoInexistente .

ex:Aplicacion_Fagor_EtherCAT_Mapper
    a                     ex:Herramienta ;
    rdfs:label            "Fagor EtherCAT Mapper"@es ;
    ex:textoExtracto      "aplicación Fagor EtherCAT Mapper"@es ;
    ex:solucionaFallo      ex:Fallo_24020_EtherCAT_FicheroRutadoInexistente .

ex:Archivo_ResourceRouterConf
    a                     ex:Componente ;
    rdfs:label            "resourceRouterConf.xml" ;
    ex:identificador      "resourceRouterConf.xml" ;
    ex:textoExtracto      "El archivo se debe llamar resourceRouterConf.xml"@es ;
    ex:requiereMantenimiento ex:Fallo_24020_EtherCAT_FicheroRutadoInexistente .