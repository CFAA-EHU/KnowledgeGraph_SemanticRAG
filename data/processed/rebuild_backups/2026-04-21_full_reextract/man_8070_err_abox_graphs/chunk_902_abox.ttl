@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloBus_24500
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo del bus corregido (24500)"@es ;
    ex:identificador "24500" ;
    ex:textoExtracto "Se ha quitado el fallo del bus. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo del bus corregida. SOLUCIÓN No requiere ninguna acción."@es .

ex:FalloTensionUM_24501
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Tensión de alimentación UM defectuosa (24501)"@es ;
    ex:identificador "24501" ;
    ex:textoExtracto "Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT"@es .

ex:ModoDiagnosis_CNC
    a               ex:ModoOperacion ;
    rdfs:label      "Modo diagnosis del CNC"@es ;
    ex:textoExtracto "Consultar el modo diagnosis para obtener más información."@es ;
    ex:mitigaRiesgo  ex:FalloBus_24500 ;
    ex:mitigaRiesgo  ex:FalloTensionUM_24501 .

ex:InterfazDiagnosis_CNC
    a               ex:InterfazUsuario ;
    rdfs:label      "Pantalla de diagnosis del CNC"@es ;
    ex:textoExtracto "En la pantalla de diagnosis, durante la ejecución."@es ;
    ex:ilustradoEn   ex:ModoDiagnosis_CNC .