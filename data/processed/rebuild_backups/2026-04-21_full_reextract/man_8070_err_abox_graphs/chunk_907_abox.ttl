@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error24522 a ex:DiagnosticoFallo ;
    ex:identificador "24522" ;
    rdfs:label "Error periférico en el módulo %u"@es ;
    ex:textoExtracto "24522 Error periférico en el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:activaAlarma ex:Alarma24522 .

ex:Alarma24522 a ex:Alarma ;
    ex:identificador "24522" ;
    rdfs:label "Alarma por error periférico en módulo %u"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:SistemaEtherCAT .

ex:Error24523 a ex:DiagnosticoFallo ;
    ex:identificador "24523" ;
    rdfs:label "Error periférico en el módulo %u se ha quitado"@es ;
    ex:textoExtracto "24523 Error periférico en el módulo %u se ha quitado. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es .

ex:Error24524 a ex:DiagnosticoFallo ;
    ex:identificador "24524" ;
    rdfs:label "Configuración del módulo localbus no coincide con el módulo %u"@es ;
    ex:textoExtracto "24524 La configuración del módulo localbus no coincide con el módulo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:activaAlarma ex:Alarma24524 .

ex:Alarma24524 a ex:Alarma ;
    ex:identificador "24524" ;
    rdfs:label "Alarma por configuración incorrecta en módulo %u"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:SistemaEtherCAT .

ex:Error24525 a ex:DiagnosticoFallo ;
    ex:identificador "24525" ;
    rdfs:label "Comenzar con el sistema restante no permitido"@es ;
    ex:textoExtracto "24525 Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:activaAlarma ex:Alarma24525 .

ex:Alarma24525 a ex:Alarma ;
    ex:identificador "24525" ;
    rdfs:label "Alarma por inicio no permitido con sistema parcial"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:SistemaEtherCAT .

ex:Error24526 a ex:DiagnosticoFallo ;
    ex:identificador "24526" ;
    rdfs:label "Aplicación solicitó reconfiguración del bus local"@es ;
    ex:textoExtracto "24526 La aplicación solicitó una reconfiguración del bus local. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:activaAlarma ex:Alarma24526 .

ex:Alarma24526 a ex:Alarma ;
    ex:identificador "24526" ;
    rdfs:label "Alarma por reconfiguración de bus local"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:SistemaEtherCAT .

ex:Error24527 a ex:DiagnosticoFallo ;
    ex:identificador "24527" ;
    rdfs:label "Comenzar con el sistema restante"@es ;
    ex:textoExtracto "24527 Comenzar con el sistema restante, %u módulos esperados, encontrados %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda"@es ;
    ex:activaAlarma ex:Alarma24527 .

ex:Alarma24527 a ex:Alarma ;
    ex:identificador "24527" ;
    rdfs:label "Alarma por inicio con sistema parcial (%u módulos)"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:SistemaEtherCAT .

ex:SistemaEtherCAT a ex:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:InterfazDiagnostico a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ex:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es ;
    ex:monitoreaParametro ex:Error24522, ex:Error24523, ex:Error24524, ex:Error24525, ex:Error24526, ex:Error24527 .