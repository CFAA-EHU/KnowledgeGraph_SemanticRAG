@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24555 a ex:DiagnosticoFallo ;
    ex:identificador "24555" ;
    rdfs:label "Módulo con versión de chip no soportada"@es ;
    ex:textoExtracto "Se encontró un módulo con una versión de chip no soportada. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24556 a ex:DiagnosticoFallo ;
    ex:identificador "24556" ;
    rdfs:label "Módulo de fabricante no soportado"@es ;
    ex:textoExtracto "Encontró un módulo del fabricante del dispositivo no soportado. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24557 a ex:DiagnosticoFallo ;
    ex:identificador "24557" ;
    rdfs:label "Error grave en módulo localbus"@es ;
    ex:textoExtracto "Error grave en el módulo localbus. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24558 a ex:DiagnosticoFallo ;
    ex:identificador "24558" ;
    rdfs:label "Error de hardware o firmware"@es ;
    ex:textoExtracto "Se produjo un error de hardware o firmware. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:Error_24559 a ex:DiagnosticoFallo ;
    ex:identificador "24559" ;
    rdfs:label "Error de hardware o firmware"@es ;
    ex:textoExtracto "Se produjo un error de hardware o firmware. [...] Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ex:InterfazDiagnostico a ex:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ex:textoExtracto "En la pantalla de diagnosis, durante la ejecución."@es ;
    ex:monitoreaParametro ex:Error_24555 ;
    ex:monitoreaParametro ex:Error_24556 ;
    ex:monitoreaParametro ex:Error_24557 ;
    ex:monitoreaParametro ex:Error_24558 ;
    ex:monitoreaParametro ex:Error_24559 .

ex:SistemaEtherCAT a ex:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:activaAlarma ex:Error_24555 ;
    ex:activaAlarma ex:Error_24556 ;
    ex:activaAlarma ex:Error_24557 ;
    ex:activaAlarma ex:Error_24558 ;
    ex:activaAlarma ex:Error_24559 .