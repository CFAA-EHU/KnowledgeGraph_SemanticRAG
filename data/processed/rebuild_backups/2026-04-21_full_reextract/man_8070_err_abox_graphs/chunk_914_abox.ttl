ex:Error_24579 a ex:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Suministro de actuador no presente"@es ;
    ex:textoExtracto "24579 Módulo %u: Suministro de actuador no presente. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:identificador "24579" ;
    ex:solucionaFallo ex:Actuador_NoPresente_24579 .

ex:Actuador_NoPresente_24579 a ex:Actuador ;
    ex:textoExtracto "Suministro de actuador no presente"@es .

