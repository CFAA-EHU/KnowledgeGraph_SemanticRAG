ex:ErrorCodificador_24589
    a ex:AvisoSeguridad ;
    rdfs:label "Error de codificador (Canal %u)"@es ;
    ex:identificador "24589" ;
    ex:textoExtracto "Módulo %u: Error de codificador Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:mitigaRiesgo ex:DiagnosticoFallo_EtherCAT_24589 .

