@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24595
    a ex:DiagnosticoFallo ;
    ex:identificador "24595" ;
    ex:textoExtracto "Módulo %u: Canal de sobrecarga %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    rdfs:label "Error 24595: Canal de sobrecarga"@es .

ex:Error_24596
    a ex:DiagnosticoFallo ;
