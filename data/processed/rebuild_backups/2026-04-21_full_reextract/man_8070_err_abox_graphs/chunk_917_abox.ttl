    rdfs:label "Error 24596: Canal Subterráneo"@es .

ex:Error_24597
    a ex:DiagnosticoFallo ;
    ex:identificador "24597" ;
    ex:textoExtracto "La configuración del módulo Localbus no coincide en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." ;
    rdfs:label "Error 24597: Configuración Localbus no coincide"@es .

ex:Error_24600
    a ex:DiagnosticoFallo ;
    ex:identificador "24600" ;
    ex:textoExtracto "El fallo de bus se ha quitado. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo del bus corregida. SOLUCIÓN No requiere ninguna acción." ;
    rdfs:label "Error 24600: Fallo de bus corregido"@es .

ex:Error_24601
