PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:_24602 a ex:AvisoSeguridad ;
    ex:identificador "24602" ;
    rdfs:label "Tensión de alimentación UM OK"@es ;
    ex:textoExtracto "24602 Tensión de alimentación UM OK. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es ;
    ex:monitoreaParametro ex:TensionAlimentacion_UM .

ex:_24603 a ex:Alarma ;
    ex:identificador "24603" ;
    rdfs:label "Tensión de alimentación de US defectuosa"@es ;
    ex:textoExtracto "24603 Tensión de alimentación de US defectuosa. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es ;
    ex:monitoreaParametro ex:TensionAlimentacion_US ;
    ex:requiereMantenimiento ex:ConsultaManualNodo_EtherCAT .

