@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error24620 a ex:AvisoSeguridad ;
    rdfs:label "Error de hardware en el módulo %u"@es ;
    ex:identificador "24620" ;
    ex:textoExtracto "24620 Error de hardware en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:Error24621 a ex:AvisoSeguridad ;
    rdfs:label "Error de firmware en el módulo %u"@es ;
    ex:identificador "24621" ;
    ex:textoExtracto "24621 Error de firmware en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:Error24622 a ex:AvisoSeguridad ;
    rdfs:label "Error periférico en el módulo %u"@es ;
    ex:identificador "24622" ;
    ex:textoExtracto "24622 Error periférico en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:Error24623 a ex:AvisoSeguridad ;
    rdfs:label "Error periférico en el módulo %u se ha quitado"@es ;
    ex:identificador "24623" ;
    ex:textoExtracto "24623 Error periférico en el módulo %u se ha quitado. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es .

ex:Error24624 a ex:AvisoSeguridad ;
    rdfs:label "La configuración del módulo Localbus no coincide en el módulo %u"@es ;
    ex:identificador "24624" ;
    ex:textoExtracto "24624 La configuración del módulo Localbus no coincide en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:Error24625 a ex:AvisoSeguridad ;
    rdfs:label "Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados"@es ;
    ex:identificador "24625" ;
    ex:textoExtracto "24625 Comenzar con el sistema restante no permitido, %u módulos esperados, encontrados. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que"@es .

ex:SistemaEtherCAT a ex:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ex:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:tieneComponente ex:ModuloEtherCAT .

ex:ModuloEtherCAT a ex:ComponenteElectrico ;
    rdfs:label "Módulo EtherCAT"@es ;
    ex:textoExtracto "módulo %u"@es ;
    ex:activaAlarma ex:Error24620, ex:Error24621, ex:Error24622, ex:Error24623, ex:Error24624, ex:Error24625 .