@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_24653_SyncManagerDireccionInvalida
    a ex:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d dirección inválida (%d)"@es ;
    ex:textoExtracto "24653 Sync Manager %d dirección inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:identificador "24653" .

ex:Error_24654_SyncManagerTamanoInvalido
    a ex:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d tamaño inválido (%d)"@es ;
    ex:textoExtracto "24654 Sync Manager %d tamaño inválido (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:identificador "24654" .

ex:Error_24655_SyncManagerConfiguracionInvalida
    a ex:DiagnosticoFallo ;
    rdfs:label "Sync Manager %d configuración inválida (%d)"@es ;
    ex:textoExtracto "24655 Sync Manager %d configuración inválida (%d). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:identificador "24655" .

ex:Error_24656_RegistroActivacionDCInvalido
    a ex:DiagnosticoFallo ;
    rdfs:label "Registro de activación DC inválido"@es ;
    ex:textoExtracto "24656 Registro de activación DC inválido. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:identificador "24656" .

ex:Error_24657_ConfiguracionSyncTypeNoSoportada
    a ex:DiagnosticoFallo ;
    rdfs:label "Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada"@es ;
    ex:textoExtracto "24657 Configuración de SyncType (0x1C32.1 or 0x1C33.1) no soportada. Compruebe los registros DC registers y SyncTypes soportados(0x1C32.4 and 0x1C33.4). DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ex:identificador "24657" ;
    ex:valor "0x1C32.1, 0x1C33.1"@es .

ex:Parametro_RegistroDC_0x1C32
    a ex:Parametro ;
    rdfs:label "Registro DC 0x1C32"@es ;
    ex:textoExtracto "Compruebe los registros DC registers y SyncTypes soportados(0x1C32.4 and 0x1C33.4)"@es ;
    ex:identificador "0x1C32" .

ex:Parametro_RegistroDC_0x1C33
    a ex:Parametro ;
    rdfs:label "Registro DC 0x1C33"@es ;
    ex:textoExtracto "Compruebe los registros DC registers y SyncTypes soportados(0x1C32.4 and 0x1C33.4)"@es ;
    ex:identificador "0x1C33" .

ex:Error_24657_ConfiguracionSyncTypeNoSoportada
    ex:monitoreaParametro ex:Parametro_RegistroDC_0x1C32 ;
    ex:monitoreaParametro ex:Parametro_RegistroDC_0x1C33 .