@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Error_24668
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Identificador de placa analógica incorrecto"@es ;
    ex:identificador    "24668" ;
    ex:textoExtracto    "24668 Identificador de placa analógica incorrecto. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ex:Error_24669
    a                   ex:DiagnosticoFallo ;
    rdfs:label          "Error de firmware en RIOR-E, BOOT mode"@es ;
    ex:identificador    "24669" ;
    ex:textoExtracto    "24669 Error de firmware en RIOR-E, BOOT mode. DETECCIÓN Durante la ejecución. CAUSA Se ha detectado un nodo RIOR-E en BOOT mode. SOLUCIÓN Volver a cargar el firmware de aplicación."@es .

ex:Nodo_RIOR_E
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Nodo RIOR-E"@es ;
    ex:textoExtracto    "nodo RIOR-E"@es ;
    ex:activaAlarma      ex:Error_24669 .

ex:Nodo_EtherCAT
    a                   ex:ComponenteElectrico ;
    rdfs:label          "Nodo EtherCAT"@es ;
    ex:textoExtracto    "Un nodo EtherCAT ha enviado una emergencia"@es ;
    ex:activaAlarma      ex:Error_24668 .