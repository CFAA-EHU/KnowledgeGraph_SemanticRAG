@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_80030
    a ex:DiagnosticoFallo ;
    rdfs:label "Error 80030: Parámetro U no permitido" ;
    ex:identificador "80030" ;
    ex:textoExtracto "G%D U%D: Parámetro U no permitido. DETECCIÓN Durante la ejecución. CAUSA En la subrutina indicada, no está permitido el parámetro U. SOLUCIÓN Revisar la programación." ;
    ex:solucionaFallo [
        a ex:AccionProhibida ;
        rdfs:label "Uso no permitido del parámetro U en subrutina" ;
        ex:textoExtracto "En la subrutina indicada, no está permitido el parámetro U."
    ] .

