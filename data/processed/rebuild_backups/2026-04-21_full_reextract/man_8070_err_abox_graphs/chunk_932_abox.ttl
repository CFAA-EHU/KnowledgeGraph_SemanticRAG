@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_85850 a ex:AvisoSeguridad ;
    rdfs:label "Error 85850: G8585 no permitida con origen temporal G92 activo" ;
    ex:identificador "85850" ;
    ex:textoExtracto "85850 G8585 no permitida con origen temporal G92 activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la función G8585 y hay una preselección de cotas activa (G92). SOLUCIÓN Anular la preselecciona de cotas antes de ejecutar la función G8585." .

ex:Error_85851 a ex:AvisoSeguridad ;
    rdfs:label "Error 85851: G8585 no permitida con programación simultánea D y R, ni I y J" ;
    ex:identificador "85851" ;
    ex:textoExtracto "85851 G8585 no permitida con programación simultánea D y R, ni I y J. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el radio y el diámetro exterior, o el radio y el diámetro interior. SOLUCIÓN Revisar la programación. Programar cada dimensión una sola vez, con el radio o el diámetro." .

ex:Error_85852 a ex:AvisoSeguridad ;
    rdfs:label "Error 85852: G8585 con I>D (diámetro interno > diámetro externo)" ;
    ex:identificador "85852" ;
    ex:textoExtracto "85852 G8585 con I>D, que es diámetro interno > diámetro externo. DETECCIÓN Durante la ejecución. CAUSA El diámetro interior es mayor que el exterior. SOLUCIÓN Programar el diámetro exterior mayor que el interior." .

ex:Error_85860 a ex:AvisoSeguridad ;
    rdfs:label "Error 85860: Configuración errónea de G8585 (parámetro MPA.LONGAXIS.%D=No)" ;
    ex:identificador "85860" ;
    ex:textoExtracto "85860 G8585 configuración errónea: poner parámetro MPA.LONGAXIS.%D=No. DETECCIÓN Durante la ejecución. CAUSA El eje indicado está definido como longitudinal. SOLUCIÓN Definir el parámetro LONGAXIS del eje con valor \"No\"." .

ex:Error_85861 a ex:AvisoSeguridad ;
    rdfs:label "Error 85861: Configuración errónea de G8585 (parámetro MPA.FACEAXIS.%D=No)" ;
    ex:identificador "85861" ;
    ex:textoExtracto "85861 G8585 configuración errónea: poner parámetro MPA.FACEAXIS.%D=No. DETECCIÓN Durante la ejecución. CAUSA El eje indicado está definido como frontal. SOLUCIÓN Definir el parámetro FACEAXIS del eje con valor \"No\"." .

ex:Error_85862 a ex:AvisoSeguridad ;
    rdfs:label "Error 85862: Configuración errónea de G8585 (AXISNAME=%D no existe)" ;
    ex:identificador "85862" ;
    ex:textoExtracto "85862 G8585 configuración errónea: AXISNAME=%D no existe. DETECCIÓN Durante la ejecución. CAUSA La subrutina G8585 intenta utilizar un eje que no existe. SOLUCIÓN Revisar la subrutina G8585 y la asignación de datos a la variable V.S.G84585CFG." .

ex:Error_85863 a ex:AvisoSeguridad ;
    rdfs:label "Error 85863: Configuración errónea de G8585 (valor incorrecto de V.S.G84585CFG=%D)" ;
    ex:identificador "85863" ;
    ex:textoExtracto "85863 G8585 configuración errónea: valor incorrecto de la variable V.S.G84585CFG=%D. DETECCIÓN Durante la ejecución. CAUSA El valor asignado a la variable no es válido." .

ex:Parametro_LONGAXIS a ex:Parametro ;
    rdfs:label "Parámetro LONGAXIS" ;
    ex:identificador "MPA.LONGAXIS" ;
    ex:valor "No" ;
    ex:textoExtracto "Definir el parámetro LONGAXIS del eje con valor \"No\"." .

ex:Parametro_FACEAXIS a ex:Parametro ;
    rdfs:label "Parámetro FACEAXIS" ;
    ex:identificador "MPA.FACEAXIS" ;
    ex:valor "No" ;
    ex:textoExtracto "Definir el parámetro FACEAXIS del eje con valor \"No\"." .

ex:Variable_G84585CFG a ex:Parametro ;
    rdfs:label "Variable V.S.G84585CFG" ;
    ex:identificador "V.S.G84585CFG" ;
    ex:textoExtracto "Revisar la subrutina G8585 y la asignación de datos a la variable V.S.G84585CFG." .