ex:Alarma_E137
    a               ex:Alarma ;
    rdfs:label      "Señal de alarma en captación E21A (E137)" ;
    ex:textoExtracto "E137 Recibida señal de alarma en captación E21A. El encoder ha generado una señal de alarma por un mal funcionamiento del mismo."@es ;
    ex:identificador "E137" .

