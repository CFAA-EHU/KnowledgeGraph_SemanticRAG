@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_RCS_S
    a               ex:Sistema ;
    rdfs:label      "Módulo RCS-S" ;
    ex:textoExtracto "Revisar el conexionado. Revisar el nivel de las señales proporcionadas por el captador."@es .

ex:Sensor_E21A
    a               ex:Sensor ;
    rdfs:label      "Captación E21A" ;
    ex:textoExtracto "E134 Cable roto, señal B de la captación E21A. [...] E137 Recibida señal de alarma en captación E21A."@es ;
    ex:identificador "E21A" ;
    ex:activaAlarma  ex:Alarma_E137 .

