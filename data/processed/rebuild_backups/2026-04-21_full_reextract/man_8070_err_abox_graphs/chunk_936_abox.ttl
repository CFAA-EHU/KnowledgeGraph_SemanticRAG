ex:Modulo_RCS_S
    ex:tieneComponente ex:Sensor_E21A, ex:Sensor_E21B, ex:Sensor_E21C, ex:Sensor_E21D ;
    ex:tieneComponente ex:ComponenteElectrico_CableB_E21A, ex:ComponenteElectrico_CableB_E21B,
                       ex:ComponenteElectrico_CableB_E21C, ex:ComponenteElectrico_CableB_E21D ;
