@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorE243 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21B (CRC incorrecto)"@es ;
    ex:textoExtracto "E243 Error de comunicación en captación E21B. CRC incorrecto."@es ;
    ex:identificador "E243" .

ex:ErrorE343 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21C (CRC incorrecto)"@es ;
    ex:textoExtracto "E343 Error de comunicación en captación E21C. CRC incorrecto."@es ;
    ex:identificador "E343" .

ex:ErrorE443 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21D (CRC incorrecto)"@es ;
    ex:textoExtracto "E443 Error de comunicación en captación E21D. CRC incorrecto."@es ;
    ex:identificador "E443" .

ex:ErrorCotaAbsoluta_CRC a ex:AvisoSeguridad ;
    rdfs:label "Error en lectura de cota absoluta (CRC incorrecto)"@es ;
    ex:textoExtracto "Error en la lectura de la cota absoluta; CRC incorrecto. Compruebe el cable y el conexionado con la regla ó el encoder. Verifique la correcta parametrización del captador."@es .

ex:ErrorE144 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21A (no acknowledge)"@es ;
    ex:textoExtracto "E144 Error de comunicación en captación E21A. No se recibió acknowledge."@es ;
    ex:identificador "E144" .

ex:ErrorE244 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21B (no acknowledge)"@es ;
    ex:textoExtracto "E244 Error de comunicación en captación E21B. No se recibió acknowledge."@es ;
    ex:identificador "E244" .

ex:ErrorE344 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21C (no acknowledge)"@es ;
    ex:textoExtracto "E344 Error de comunicación en captación E21C. No se recibió acknowledge."@es ;
    ex:identificador "E344" .

ex:ErrorE444 a ex:AvisoSeguridad ;
    rdfs:label "Error de comunicación en captación E21D (no acknowledge)"@es ;
    ex:textoExtracto "E444 Error de comunicación en captación E21D. No se recibió acknowledge."@es ;
    ex:identificador "E444" .

ex:ErrorCotaAbsoluta_Ack a ex:AvisoSeguridad ;
    rdfs:label "Error en lectura de cota absoluta (no acknowledge)"@es ;
    ex:textoExtracto "Error en la lectura de la cota absoluta; no se recibió acknowledge. Compruebe el cable y el conexionado con el captador. El error puede deberse a un problema en el captador."@es .

ex:ErrorE145 a ex:AvisoSeguridad ;
    rdfs:label "Error de sincronismo en captación E21A (ABSIND)"@es ;
    ex:textoExtracto "E145 ABSIND: Error de sincronismo en captación E21A."@es ;
    ex:identificador "E145" .

ex:ErrorE245 a ex:AvisoSeguridad ;
    rdfs:label "Error de sincronismo en captación E21B (ABSIND)"@es ;
    ex:textoExtracto "E245 ABSIND: Error de sincronismo en captación E21B."@es ;
    ex:identificador "E245" .

ex:ErrorE345 a ex:AvisoSeguridad ;
    rdfs:label "Error de sincronismo en captación E21C (ABSIND)"@es ;
    ex:textoExtracto "E345 ABSIND: Error de sincronismo en captación E21C."@es ;
    ex:identificador "E345" .

ex:ErrorE445 a ex:AvisoSeguridad ;
    rdfs:label "Error de sincronismo en captación E21D (ABSIND)"@es ;
    ex:textoExtracto "E445 ABSIND: Error de sincronismo en captación E21D."@es ;
    ex:identificador "E445" .

ex:ErrorSincronismoABSIND a ex:AvisoSeguridad ;
    rdfs:label "Pérdida de sincronización entre contadora Sercos y módulo ABSIND"@es ;
    ex:textoExtracto "Se ha perdido la sincronización entre la contadora Sercos y el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación."@es .

ex:ModuloRCS_S a ex:Sistema ;
    rdfs:label "Módulo RCS-S"@es ;
    ex:textoExtracto "MÓDULO RCS-S"@es .

ex:ModuloABSIND a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ex:textoExtracto "módulo ABSIND"@es .

ex:ContadoraSercos a ex:ComponenteElectrico ;
    rdfs:label "Contadora Sercos"@es ;
    ex:textoExtracto "contadora Sercos"@es .

ex:ErrorE243 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE343 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE443 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorCotaAbsoluta_CRC ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE144 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE244 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE344 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE444 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorCotaAbsoluta_Ack ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE145 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE245 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE345 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorE445 ex:activaAlarma ex:ModuloRCS_S .
ex:ErrorSincronismoABSIND ex:activaAlarma ex:ModuloRCS_S .

ex:ModuloABSIND ex:tieneComponente ex:ModuloRCS_S .
ex:ContadoraSercos ex:tieneComponente ex:ModuloRCS_S .