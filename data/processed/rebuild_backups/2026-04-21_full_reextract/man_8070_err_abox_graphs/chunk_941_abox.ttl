    ex:textoExtracto "E446 ABSIND: Error leyendo información en captación E21D" .

ex:DiagnosticoFallo_ABSIND_Arranque
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo de identificación del módulo ABSIND en arranque" ;
    ex:textoExtracto "No se ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema" ;
    ex:solucionaFallo ex:Modulo_ABSIND .