@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_ABSIND
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo ABSIND" ;
    ex:textoExtracto "mal funcionamiento del módulo ABSIND", "Error leyendo información en captación E21A", "Error leyendo información en captación E21B", "Error leyendo información en captación E21C", "Error leyendo información en captación E21D", "No se ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema" .

ex:Contadora_Sercos
    a               ex:ComponenteElectrico ;
    rdfs:label      "Contadora Sercos" ;
    ex:textoExtracto "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación" .

ex:Empresa_FagorAutomation
    a               ex:Empresa ;
    rdfs:label      "Fagor Automation" ;
    ex:textoExtracto "Si el problema persiste, contacte con Fagor Automation" .

ex:AvisoSeguridad_E146
    a               ex:AvisoSeguridad ;
    rdfs:label      "E146 ABSIND: Error leyendo información en captación E21A" ;
    ex:identificador "E146" ;
    ex:textoExtracto "E146 ABSIND: Error leyendo información en captación E21A" .

