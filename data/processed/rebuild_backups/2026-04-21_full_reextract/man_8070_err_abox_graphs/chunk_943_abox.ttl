@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_E185
    a ex:DiagnosticoFallo ;
    rdfs:label "E185 INDUCTOSYN: GRAY signal absent en captación E21A" ;
    ex:textoExtracto "E185 INDUCTOSYN: GRAY signal absent en captación E21A" ;
    ex:identificador "E185" .

ex:Error_E285
    a ex:DiagnosticoFallo ;
    rdfs:label "E285 INDUCTOSYN: GRAY signal absent en captación E21B" ;
    ex:textoExtracto "E285 INDUCTOSYN: GRAY signal absent en captación E21B" ;
    ex:identificador "E285" .

ex:Error_E385
    a ex:DiagnosticoFallo ;
    rdfs:label "E385 INDUCTOSYN: GRAY signal absent en captación E21C" ;
    ex:textoExtracto "E385 INDUCTOSYN: GRAY signal absent en captación E21C" ;
    ex:identificador "E385" .

ex:Error_E485
    a ex:DiagnosticoFallo ;
    rdfs:label "E485 INDUCTOSYN: GRAY signal absent en captación E21D" ;
    ex:textoExtracto "E485 INDUCTOSYN: GRAY signal absent en captación E21D" ;
    ex:identificador "E485" .

ex:Modulo_ABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ex:textoExtracto "sustituir el módulo ABSIND" ;
    ex:solucionaFallo ex:Error_E185, ex:Error_E285, ex:Error_E385, ex:Error_E485 .

ex:Cable_Captacion_Inductosyn
    a ex:ComponenteElectrico ;
    rdfs:label "Cable asociado a captación INDUCTOSYN" ;
    ex:textoExtracto "cable asociado a esa captación" ;
    ex:solucionaFallo ex:Error_E185, ex:Error_E285, ex:Error_E385, ex:Error_E485 .

ex:Empresa_FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "contacte con Fagor Automation" .

ex:Parametro_SenalGray
    a ex:Parametro ;
    rdfs:label "Nivel de la señal GRAY del transductor INDUCTOSYN/resolver" ;
    ex:textoExtracto "Nivel de la señal GRAY del transductor inductosyn/resolver" .