@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorE188INDUCTOSYN
    a ex:DiagnosticoFallo ;
    rdfs:label "Error E188 INDUCTOSYN" ;
    ex:textoExtracto "E188 INDUCTOSYN: Error desconocido en captación E21A." ;
    ex:identificador "E188" .

ex:ErrorE288INDUCTOSYN
    a ex:DiagnosticoFallo ;
    rdfs:label "Error E288 INDUCTOSYN" ;
    ex:textoExtracto "E288 INDUCTOSYN:" ;
    ex:identificador "E288" .

ex:ModuloABSIND
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ex:textoExtracto "pruebe a sustituir el módulo ABSIND asociado a esa captación" ;
    ex:solucionaFallo ex:ErrorE188INDUCTOSYN .

ex:FagorAutomation
    a ex:Empresa ;
    rdfs:label "Fagor Automation" ;
    ex:textoExtracto "contacte con Fagor Automation" .