@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_ABSIND
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Módulo ABSIND" ;
    ex:textoExtracto       "pruebe a sustituir el módulo ABSIND asociado a esa captación. [...] El módulo ABSIND ha generado un error desconocido. Es probable que el error pueda deberse a un mal funcionamiento del mismo."@es ;
    ex:monitoreaParametro ex:Parametro_SSITYPE ;
    ex:monitoreaParametro ex:Parametro_REFPULSE ;
    ex:tieneComponente    ex:Dipswitch_S50 .

ex:Parametro_SSITYPE
    a               ex:Parametro ;
    rdfs:label      "SSITYPE" ;
    ex:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND. El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC y con el tipo de captador (inductosyn/resolver) conectado al módulo ABSIND."@es .

ex:Parametro_REFPULSE
    a               ex:Parametro ;
    rdfs:label      "REFPULSE" ;
    ex:textoExtracto "El valor del parámetro máquina REFPULSE es incoherente con el tipo de captador conectado. Pruebe a modificar su valor."@es .

ex:Dipswitch_S50
    a               ex:ComponenteElectrico ;
    rdfs:label      "Dipswitch S50" ;
    ex:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND."@es .

