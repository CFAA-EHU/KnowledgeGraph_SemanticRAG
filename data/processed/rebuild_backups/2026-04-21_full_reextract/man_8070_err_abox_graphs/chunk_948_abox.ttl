    ex:identificador "E395" ;
    rdfs:label "Error en potenciómetros de ajuste (Captación E21C)"@es ;
    ex:textoExtracto "E395 Captación digital Fagor. Error en los potenciómetros de ajuste. Captación E21C."@es .

