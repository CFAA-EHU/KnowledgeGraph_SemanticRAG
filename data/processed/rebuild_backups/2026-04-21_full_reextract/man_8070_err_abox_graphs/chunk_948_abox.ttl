@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_E21C a ex:AvisoSeguridad ;
    ex:identificador "E21C" ;
    rdfs:label "Error en la pista absoluta E21C"@es ;
    ex:textoExtracto "en la pista absoluta E21C. E493 Captación digital Fagor. Error en la pista absoluta E21D."@es ;
    ex:mitigaRiesgo ex:Diagnostico_E21C .

ex:Error_E21D a ex:AvisoSeguridad ;
    ex:identificador "E21D" ;
    rdfs:label "Error en la pista absoluta E21D"@es ;
    ex:textoExtracto "Error en la pista absoluta E21D. No puede calcular la posición absoluta. Pérdida de contaje. La señal analógica < 0,20 Vpp."@es ;
    ex:mitigaRiesgo ex:Diagnostico_E21D .

