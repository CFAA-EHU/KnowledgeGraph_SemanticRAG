ex:Diagnostico_E21C a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error E21C/E493"@es ;
    ex:textoExtracto "Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla. Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es ;
    ex:solucionaFallo ex:Error_E21C .

ex:Diagnostico_E21D a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error E21D"@es ;
    ex:textoExtracto "Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla. Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es ;
    ex:solucionaFallo ex:Error_E21D .

ex:Diagnostico_EncoderDanado a ex:DiagnosticoFallo ;
    rdfs:label "Reemplazo de encóder o cabeza de regla"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado. Reemplazar el encóder o la cabeza de la regla."@es ;
    ex:solucionaFallo ex:Error_E494, ex:Error_E495 .

ex:Diagnostico_CCD a ex:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para errores de captador CCD (E196-E496)"@es ;
    ex:textoExtracto "Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla."@es ;
    ex:solucionaFallo ex:Error_E196, ex:Error_E296, ex:Error_E396, ex:Error_E496 .

ex:SistemaCaptacionDigital a ex:Sistema ;
    rdfs:label "Sistema de captación digital Fagor"@es ;
    ex:textoExtracto "Captación digital Fagor"@es ;
    ex:tieneComponente ex:Encoder_Regla, ex:CPU_Captacion, ex:PotenciometrosAjuste, ex:CCD_Captador ;
    ex:activaAlarma ex:Error_E21C, ex:Error_E21D, ex:Error_E194, ex:Error_E294, ex:Error_E394, ex:Error_E494, ex:Error_E195, ex:Error_E295, ex:Error_E395, ex:Error_E495, ex:Error_E196, ex:Error_E296, ex:Error_E396, ex:Error_E496 .

ex:Encoder_Regla a ex:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de regla"@es ;
    ex:textoExtracto "encóder o la cabeza de la regla"@es .

ex:CPU_Captacion a ex:ComponenteElectrico ;
    rdfs:label "CPU de captación"@es ;
    ex:textoExtracto "Error en la CPU"@es .

ex:PotenciometrosAjuste a ex:ComponenteElectrico ;
    rdfs:label "Potenciómetros de ajuste"@es ;
    ex:textoExtracto "Error en los potenciómetros de ajuste"@es .

ex:CCD_Captador a ex:Sensor ;
    rdfs:label "Captador de imagen (CCD)"@es ;
    ex:textoExtracto "Error en el captador de imagen (CCD)"@es .