@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorE21C
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en el captador de imagen (CCD) - Captación E21C"@es ;
    ex:textoExtracto "Error en el captador de imagen (CCD). Captación E21C."@es ;
    ex:identificador "E21C" .

ex:ErrorE496
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Error E496"@es ;
    ex:textoExtracto "E496 Captación digital Fagor."@es ;
    ex:identificador "E496" .

ex:ErrorE21D
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Error en el captador de imagen (CCD) - Captación E21D"@es ;
    ex:textoExtracto "Error en el captador de imagen (CCD). Captación E21D."@es ;
    ex:identificador "E21D" .

ex:ErrorE197
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Tensión fuera de rango - Error E197"@es ;
    ex:textoExtracto "E197 Captación digital Fagor. Tensión de alimentación fuera de rango."@es ;
    ex:identificador "E197" .

ex:ErrorE21A
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Tensión fuera de rango - Error E21A"@es ;
    ex:textoExtracto "Captación E21A. E197 Captación digital Fagor. Tensión de alimentación fuera de rango."@es ;
    ex:identificador "E21A" .

ex:ErrorE297
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Tensión fuera de rango - Error E297"@es ;
    ex:textoExtracto "E297 Captación digital Fagor. Tensión de alimentación fuera de rango."@es ;
    ex:identificador "E297" .

ex:ErrorE21B
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Tensión fuera de rango - Error E21B"@es ;
    ex:textoExtracto "Captación E21B. E297 Captación digital Fagor. Tensión de alimentación fuera de rango."@es ;
    ex:identificador "E21B" .

ex:ErrorE397
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Captación digital Fagor - Error E397"@es ;
    ex:textoExtracto "E397 Captación digital Fagor."@es ;
    ex:identificador "E397" .

ex:SensorCCD
    a               ex:Sensor ;
    rdfs:label      "Captador de imagen (CCD)"@es ;
    ex:textoExtracto "captador de imagen (CCD)"@es .

ex:SensorEncodificador
    a               ex:Sensor ;
    rdfs:label      "Encóder o cabeza de la regla"@es ;
    ex:textoExtracto "Encóder o cabeza de la regla dañado"@es .

ex:ComponenteLED
    a               ex:ComponenteElectrico ;
    rdfs:label      "LED (Light-Emitting Diode)"@es ;
    ex:textoExtracto "el CCD (Charge-Coupled Device) o el LED (Light-Emitting Diode)"@es .

ex:TareaLimpiezaCristal
    a               ex:TareaMantenimiento ;
    rdfs:label      "Limpiar el cristal de la regla"@es ;
    ex:textoExtracto "Limpiar el cristal o la cinta de acero de la regla"@es .

ex:TareaReemplazoEncodificador
    a               ex:TareaMantenimiento ;
    rdfs:label      "Reemplazar el encóder o la cabeza de la regla"@es ;
    ex:textoExtracto "Reemplazar el encóder o la cabeza de la regla"@es .

ex:TareaComprobacionTolerancias
    a               ex:TareaMantenimiento ;
    rdfs:label      "Comprobar las tolerancias de montaje"@es ;
    ex:textoExtracto "Comprobar las tolerancias de montaje"@es .

ex:SistemaCaptacionDigitalFagor
    a               ex:Sistema ;
    rdfs:label      "Sistema de captación digital Fagor"@es ;
    ex:textoExtracto "Captación digital Fagor"@es ;
    ex:tieneComponente ex:SensorCCD, ex:SensorEncodificador, ex:ComponenteLED .

ex:TareaLimpiezaCristal
    ex:solucionaFallo ex:ErrorE21C, ex:ErrorE21D .

ex:TareaReemplazoEncodificador
    ex:solucionaFallo ex:ErrorE21C, ex:ErrorE21D .

ex:TareaComprobacionTolerancias
    ex:solucionaFallo ex:ErrorE21C, ex:ErrorE21D .