@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:modulo_RCS_S
    a ex:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "del bus interno entran ruidos que resetean el SerCon pero no el VeCon2." .

ex:alarma_E411
    a ex:Alarma ;
    rdfs:label "E411 - Error de recepción de telegramas" ;
    ex:identificador "E411" ;
    ex:textoExtracto "E411 Error de recepción de telegramas. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." ;
    ex:activaAlarma ex:modulo_RCS_S .

ex:alarma_E412
    a ex:Alarma ;
    rdfs:label "E412 - Mensaje de sincronismo retrasado" ;
    ex:identificador "E412" ;
    ex:textoExtracto "E412 Mensaje de sincronismo retrasado. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." ;
    ex:activaAlarma ex:modulo_RCS_S .

ex:alarma_E413
    a ex:Alarma ;
    rdfs:label "E413 - Error de handshake en la contadora Sercos" ;
    ex:identificador "E413" ;
    ex:textoExtracto "E413 Error de handshake en la contadora Sercos. El elemento master (CNC) envía un mensaje de sincronismo en cada ciclo (4ms, normalmente) que hace que los reguladores se sincronicen. Si en algún momento no pueden sincronizarse o pierden sincronización se origina este error. Posiblemente el CNC no ha enviado este mensaje o si lo ha hecho no ha sido en el momento exacto. Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión." ;
    ex:activaAlarma ex:modulo_RCS_S .

ex:anillo_fibra_optica
    a ex:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica" ;
    ex:textoExtracto "Problemas en la comunicación a través del **anillo de fibra óptica**. Verifíquense las conexiones en el anillo y la identificación de cada módulo." ;
    ex:tieneComponente ex:modulo_RCS_S .

ex:cable_transmision
    a ex:ComponenteElectrico ;
    rdfs:label "Cable de transmisión" ;
    ex:textoExtracto "Revisar el **cable de transmisión** o comprobar que no hay presencia de ruido en la transmisión." ;
    ex:tieneComponente ex:modulo_RCS_S .