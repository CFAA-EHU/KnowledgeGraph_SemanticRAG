@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FalloHerramientaEnCabezal
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo: Herramienta en cabezal"@es ;
    ex:textoExtracto "No se puede poner en el cabezal la herramienta del brazo cambiador' DETECCIÓN Al forzar una herramienta como herramienta de cabezal. CAUSA La herramienta está en el brazo cambiador 1. SOLUCIÓN Quitar la herramienta del brazo cambiador 1."@es ;
    ex:identificador "DETECCIÓN: Herramienta en brazo cambiador 1"@es .

ex:FalloPosicionInexistente
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Fallo: Posición de almacén inexistente"@es ;
    ex:textoExtracto "'La posición no existe' DETECCIÓN En carga o descarga de una herramienta del almacén, con o sin maniobra. CAUSA La posición del almacén no existe. SOLUCIÓN Elegir una posición existente"@es ;
    ex:identificador "DETECCIÓN: Posición no existe"@es .

ex:HerramientaBrazoCambiador1
    a               ex:Herramienta ;
    rdfs:label      "Herramienta en brazo cambiador 1"@es ;
    ex:textoExtracto "La herramienta está en el brazo cambiador 1"@es .

ex:AlmacenHerramientas
    a               ex:Sistema ;
    rdfs:label      "Almacén de herramientas"@es ;
    ex:textoExtracto "carga o descarga de una herramienta del almacén"@es .

ex:BrazoCambiador1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Brazo cambiador 1"@es ;
    ex:textoExtracto "brazo cambiador 1"@es ;
    ex:tieneComponente ex:HerramientaBrazoCambiador1 .