@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorEjePlano_961
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error en eje del plano"@es ;
    ex:textoExtracto
        "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido. ' Error en eje del plano' CAUSA Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC."@es ;
    ex:identificador
        "ErrorEjePlano" .

ex:DiagnosticoFallo_EjesPlano_961
    a               ex:DiagnosticoFallo ;
    rdfs:label      "Ejes del plano no válidos o duplicados"@es ;
    ex:textoExtracto
        "Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC."@es ;
    ex:solucionaFallo
        ex:ErrorEjePlano_961 .

ex:InterfazUsuario_EditorPerfiles_961
    a               ex:InterfazUsuario ;
    rdfs:label      "Editor de perfiles (CNC)"@es ;
    ex:textoExtracto
        "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido."@es ;
    ex:activaAlarma
        ex:ErrorEjePlano_961 .