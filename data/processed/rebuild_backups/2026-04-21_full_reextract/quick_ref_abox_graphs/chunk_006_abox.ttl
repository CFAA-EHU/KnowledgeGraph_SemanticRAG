@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TecladoAlfanumerico a ex:ComponenteElectrico ;
    ex:textoExtracto "The [ESC] key may be used to cancel the operation at any time. | Keyboard." ;
    rdfs:label "Keyboard"@en .

ex:TeclaESC a ex:ComponenteElectrico ;
    ex:textoExtracto "The [ESC] key may be used to cancel the operation at any time." ;
    rdfs:label "ESC key"@en .

ex:TeclaENTER a ex:ComponenteElectrico ;
    ex:textoExtracto "Press [ENTER] to assume the entered value." ;
    rdfs:label "ENTER key"@en .

ex:InterfazUsuarioPreseleccion a ex:InterfazUsuario ;
    ex:textoExtracto "1 Select the axis to be preset (on alphanumeric keyboard). The CNC will highlight the coordinate of that axis. | 2 Key in the desired preset value. | 3 Press [ENTER] to assume the entered value." ;
    ex:compuestoPor ex:TecladoAlfanumerico, ex:TeclaESC, ex:TeclaENTER .

ex:MenuSoftkey a ex:InterfazUsuario ;
    ex:textoExtracto "1 Press the softkey for presetting axes to show the list of axes of the channel and select an axis. The CNC will highlight the coordinate of that axis. | 2 Key in the desired preset value. | 3 Press [ENTER] to assume the entered value." ;
    ex:compuestoPor ex:TeclaENTER .