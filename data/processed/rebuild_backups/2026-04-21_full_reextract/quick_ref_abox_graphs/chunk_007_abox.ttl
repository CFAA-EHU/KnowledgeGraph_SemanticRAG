@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TeclaESC a ex:Sensor ;
    rdfs:label "ESC" ;
    ex:textoExtracto "The [ESC] key may be used to cancel the operation at any time." .

ex:TecladoAlfanumerico a ex:InterfazUsuario ;
    ex:textoExtracto "Select the axis to be moved (on alphanumeric keyboard)." .

ex:TeclaSTART a ex:Sensor ;
    rdfs:label "START" ;
    ex:textoExtracto "Press [START] to make the move." .

ex:MenuSoftkey a ex:InterfazUsuario ;
    ex:textoExtracto "Press the softkey for presetting axes to show the list of axes of the channel and select an axis." .

ex:SistemaCNC a ex:Maquina ;
    ex:textoExtracto "The CNC will highlight the coordinate of that axis." ;
    ex:compuestoPor ex:TeclaESC, ex:TecladoAlfanumerico, ex:TeclaSTART, ex:MenuSoftkey .