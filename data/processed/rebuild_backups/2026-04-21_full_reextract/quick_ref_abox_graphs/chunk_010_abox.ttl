@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CalibracionManual a ex:TareaMantenimiento ;
    rdfs:label "manual calibration"@en ;
    ex:textoExtracto "If there is no tabletop probe, only manual calibration is available."@en .

ex:CalibracionConSondaDeMesa a ex:TareaMantenimiento ;
    rdfs:label "table-top probe calibration"@en ;
    ex:textoExtracto "All types of calibration are available when using a table-top probe."@en .

ex:MenuDeCalibracionVertical a ex:InterfazUsuario ;
    rdfs:label "vertical softkey menu"@en ;
    ex:textoExtracto "The different calibration methods may be selected from the vertical softkey menu."@en .

ex:SondaDeMesa a ex:Sensor ;
    rdfs:label "tabletop probe"@en ;
    ex:textoExtracto "If there is no tabletop probe, only manual calibration is available. All types of calibration are available when using a table-top probe."@en .