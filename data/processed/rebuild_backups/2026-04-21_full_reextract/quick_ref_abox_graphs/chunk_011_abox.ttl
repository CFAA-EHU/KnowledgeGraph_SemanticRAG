@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ManualCalibrationMode a ex:ModoOperacion ;
    ex:textoExtracto "Manual calibration. In this mode, only the active tool can be calibrated. Since there (Calibration without probe). is no probe, a reference part is required to calibrate the tool. All the movements are carried out manually." ;
    rdfs:label "Manual calibration mode" .

ex:SemiAutomaticCalibrationMode a ex:ModoOperacion ;
    ex:textoExtracto "Semi-automatic calibration. The positioning movements are carried out manually and the CNC executes the probing movements." ;
    rdfs:label "Semi-automatic calibration mode" .

ex:AutomaticCalibrationMode a ex:ModoOperacion ;
    ex:textoExtracto "Automatic calibration. The CNC executes all the movements using the calibration (Calibration with probe). canned cycle #PROBE." ;
    rdfs:label "Automatic calibration mode" .

ex:ProbeSelectionInstruction a ex:TareaMantenimiento ;
    ex:textoExtracto "# SELECT PROBE [1] #SELECT PROBE [2]" ;
    rdfs:label "Probe selection instruction" .

ex:ReferencePart a ex:PiezaRecambio ;
    ex:textoExtracto "a reference part is required to calibrate the tool" ;
    rdfs:label "Reference part" .

ex:ToolTable a ex:Tabla ;
    ex:textoExtracto "the new values are saved in the tool table" ;
    rdfs:label "Tool table" .

ex:ToolChangeStep a ex:TareaMantenimiento ;
    ex:textoExtracto "press [START] to execute the tool change (if [ENTER] is pressed, the CNC will only show the tool data)" ;
    rdfs:label "Tool change step" .

ex:CalibrationValidationStep a ex:TareaMantenimiento ;
    ex:textoExtracto "validate the calibration using the softkey menu" ;
    rdfs:label "Calibration validation step" .

ex:MillingModelCalibration a ex:TareaMantenimiento ;
    ex:textoExtracto "Calibrate the length of the endmills and the offsets of the lathe tools." ;
    rdfs:label "Milling model calibration" .

ex:LatheModelPlaneCalibration a ex:TareaMantenimiento ;
    ex:textoExtracto "Calibrate the offset of any tool." ;
    rdfs:label "Lathe model (plane) calibration" .

ex:LatheModelTrihedronCalibration a ex:TareaMantenimiento ;
    ex:textoExtracto "Calibrate the length or offsets of the endmills and the offsets of the lathe tools." ;
    rdfs:label "Lathe model (trihedron) calibration" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "The CNC executes all the movements" ;
    rdfs:label "CNC" .

ex:Probe a ex:Sensor ;
    ex:textoExtracto "The CNC uses the active probe for calibration." ;
    rdfs:label "Probe" .