@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EXBLK_softkey a ex:Sensor ;
    rdfs:label "EXBLK softkey" ;
    ex:textoExtracto "Press the “EXBLK” softkey of the horizontal menu." .

ex:START_key a ex:Sensor ;
    rdfs:label "START key" ;
    ex:textoExtracto "every time the [START] key is pressed" .

ex:BlockSelection a ex:InterfazUsuario ;
    rdfs:label "Block selection interface" ;
    ex:textoExtracto "it only executes the block selected in the active program" .

ex:M_function a ex:Parametro ;
    rdfs:label "M function" ;
    ex:textoExtracto "Blocks executed like this change the history of the M and G functions." .

ex:G_function a ex:Parametro ;
    rdfs:label "G function" ;
    ex:textoExtracto "Blocks executed like this change the history of the M and G functions." .