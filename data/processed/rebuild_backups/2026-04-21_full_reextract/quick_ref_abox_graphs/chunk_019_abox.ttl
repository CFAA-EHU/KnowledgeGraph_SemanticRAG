@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoOperacion_19_1 a ex:ModoOperacion ;
    ex:textoExtracto "repositioning of axes. Select the axes with the relevant softkey and press [START]. Repositioning may be interrupted (using the [STOP] key) to select other axes." .

ex:ModoOperacion_19_2 a ex:ModoOperacion ;
    ex:textoExtracto "Changing the machining conditions. After positioning the axes and before resuming execution, tool inspection may be accessed to change the machining conditions." .

ex:InterfazUsuario_19_1 a ex:InterfazUsuario ;
    ex:textoExtracto "[START]" .

ex:InterfazUsuario_19_2 a ex:InterfazUsuario ;
    ex:textoExtracto "[STOP]" .

ex:InterfazUsuario_19_3 a ex:InterfazUsuario ;
    ex:textoExtracto "softkey" .

ex:Sistema_19_1 a ex:Sistema ;
    ex:textoExtracto "tool inspection" ;
    ex:compuestoPor ex:InterfazUsuario_19_1, ex:InterfazUsuario_19_2, ex:InterfazUsuario_19_3 ;
    ex:tieneComponente ex:ModoOperacion_19_1, ex:ModoOperacion_19_2 .

ex:Parametro_19_1 a ex:Parametro ;
    ex:textoExtracto "feedrate" ;
    ex:valor "feedrate" .

ex:Parametro_19_2 a ex:Parametro ;
    ex:textoExtracto "spindle speed" ;
    ex:valor "spindle speed" .

ex:ModoOperacion_19_3 a ex:ModoOperacion ;
    ex:textoExtracto "MDI/MDA mode" .

ex:AccionProhibida_19_1 a ex:AccionProhibida ;
    ex:textoExtracto "activate M and H functions" .