@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:START_simulation ex:textoExtracto """START (simulation). Starts program simulation or resume it if it was interrupted.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "START (simulation)" .

ex:STOP_simulation ex:textoExtracto """STOP (simulation). Interrupt program simulation. Simulation will resume by pressing the START icon.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "STOP (simulation)" .

ex:RESET_simulation ex:textoExtracto """RESET (simulation). Cancel program simulation. If an error occurs during simulation, reset eliminates the error status and returns the simulation mode to its initial conditions.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "RESET (simulation)" .

ex:Change_channel ex:textoExtracto """Change the channel being displayed for editing and simulation. It does not affect the active channel at the CNC. ( This icon will only be available when the CNC has channels).""" ;
    a ex:InterfazUsuario ;
    rdfs:label "Change channel" .

ex:Single_block_mode ex:textoExtracto """Select the “single block” or “continuous” execution mode. When "single block" mode is active (the icon will appear pressed), program simulation will be interrupted at the end of each block.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "Single block mode" .

ex:Syntax_check ex:textoExtracto """Analyze the program looking for syntax errors. The syntax check is not available for programs written in 8055 CNC language.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "Syntax check" .

ex:Execution_time_estimate ex:textoExtracto """Offer an estimate of the total execution time at 100% of the programmed feedrate. The result will appear at the statistics window.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "Execution time estimate" .

ex:Simulation_options ex:textoExtracto """Configuring simulation options.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "Simulation options" .