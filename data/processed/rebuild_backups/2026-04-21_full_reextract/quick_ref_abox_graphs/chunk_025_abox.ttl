@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EXBLK_softkey a ex:InterfazUsuario ;
    ex:textoExtracto "Press the “EXBLK” softkey of the horizontal menu." .

ex:START_icon_key a ex:InterfazUsuario ;
    ex:textoExtracto "the START icon key is pressed" .

ex:SimulacionBloque a ex:AccionProhibida ;
    ex:textoExtracto "it only simulates the block selected in the active program" .

ex:SeleccionBloque a ex:TareaMantenimiento ;
    ex:textoExtracto "another block may be simulated by selecting it with the cursor and pressing [START] again and so on." .