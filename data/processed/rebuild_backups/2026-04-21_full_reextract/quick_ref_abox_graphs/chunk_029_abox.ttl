@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ProgrammingCommandsTable a ex:Tabla ;
    ex:textoExtracto "Command. | Meaning. | Format. | / | Block skip condition. |  | # | Programming instructions. |  | $ | Flow controlling instructions. |  | % | Program header. | 14 characters. ( 1) | ; (semi-colon) | Block comment . |  | [ ] | Text type block label. | 14 characters. ( 1) | N | Number type block label. | 0 - 4294967295 | G | Preparatory functions. | 1 - 999 | X~C | Position of the axes. | ±99999.9999 mm ±9999.99999 inches | F | Feedrate of the axes. |  | S | Spindle speed. |  | T | Tool number. | 0 - 4294967295 | D | Tool offset number. |  | M | Auxiliary functions. | 0 - 65535 | H | Auxiliary functions. | 0 - 65535 | NR | Number of block repetitions. |  | ( ) | Block comment . |  (1) The format admits upper and lower case letters and numbers (no blank spaces)." .

ex:Command_Slash a ex:Parametro ;
    ex:identificador "/" ;
    ex:textoExtracto "/" ;
    ex:valor "Block skip condition" .

ex:Command_Hash a ex:Parametro ;
    ex:identificador "#" ;
    ex:textoExtracto "#" ;
    ex:valor "Programming instructions" .

ex:Command_Dollar a ex:Parametro ;
    ex:identificador "$" ;
    ex:textoExtracto "$" ;
    ex:valor "Flow controlling instructions" .

ex:Command_Percent a ex:Parametro ;
    ex:identificador "%" ;
    ex:textoExtracto "%" ;
    ex:valor "Program header" ;
    ex:valor "14 characters" .

ex:Command_SemiColon a ex:Parametro ;
    ex:identificador ";" ;
    ex:textoExtracto "; (semi-colon)" ;
    ex:valor "Block comment" .

ex:Command_Brackets a ex:Parametro ;
    ex:identificador "[]" ;
    ex:textoExtracto "[ ]" ;
    ex:valor "Text type block label" ;
    ex:valor "14 characters" .

ex:Command_N a ex:Parametro ;
    ex:identificador "N" ;
    ex:textoExtracto "N" ;
    ex:valor "0 - 4294967295" .

ex:Command_G a ex:Parametro ;
    ex:identificador "G" ;
    ex:textoExtracto "G" ;
    ex:valor "Preparatory functions" ;
    ex:valor "1 - 999" .

ex:Command_XC a ex:Parametro ;
    ex:identificador "X~C" ;
    ex:textoExtracto "X~C" ;
    ex:valor "Position of the axes" ;
    ex:valor "±99999.9999 mm ±9999.99999 inches" .

ex:Command_F a ex:Parametro ;
    ex:identificador "F" ;
    ex:textoExtracto "F" ;
    ex:valor "Feedrate of the axes" .

ex:Command_S a ex:Parametro ;
    ex:identificador "S" ;
    ex:textoExtracto "S" ;
    ex:valor "Spindle speed" .

ex:Command_T a ex:Parametro ;
    ex:identificador "T" ;
    ex:textoExtracto "T" ;
    ex:valor "Tool number" ;
    ex:valor "0 - 4294967295" .

ex:Command_D a ex:Parametro ;
    ex:identificador "D" ;
    ex:textoExtracto "D" ;
    ex:valor "Tool offset number" .

ex:Command_M a ex:Parametro ;
    ex:identificador "M" ;
    ex:textoExtracto "M" ;
    ex:valor "Auxiliary functions" ;
    ex:valor "0 - 65535" .

ex:Command_H a ex:Parametro ;
    ex:identificador "H" ;
    ex:textoExtracto "H" ;
    ex:valor "Auxiliary functions" ;
    ex:valor "0 - 65535" .

ex:Command_NR a ex:Parametro ;
    ex:identificador "NR" ;
    ex:textoExtracto "NR" ;
    ex:valor "Number of block repetitions" .

ex:Command_Parentheses a ex:Parametro ;
    ex:identificador "()" ;
    ex:textoExtracto "( )" ;
    ex:valor "Block comment" .