@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoOperacion_G93 a ex:ModoOperacion ;
    ex:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)" .

ex:ModoOperacion_G94 a ex:ModoOperacion ;
    ex:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)" .

ex:ModoOperacion_G95 a ex:ModoOperacion ;
    ex:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)" .

ex:Parametro_F_code a ex:Parametro ;
    ex:identificador "F" ;
    ex:textoExtracto "The machining feedrate may be selected by programmed using the \"F\" code which remains active until another value is programmed." .

ex:Parametro_T_code a ex:Parametro ;
    ex:identificador "T" ;
    ex:textoExtracto "The \"T\" code identifies the tool to be selected." .

ex:Sistema_CNC a ex:Sistema ;
    ex:textoExtracto "The tools may be in a magazine managed by the CNC or in a manual magazine (referred to as ground tools)." .

ex:Tabla_Herramientas a ex:Tabla ;
    ex:textoExtracto "The CNC offers a section of the tool table where several offsets may be defined." .

ex:Parametro_G96 a ex:Parametro ;
    ex:identificador "G96" ;
    ex:textoExtracto "If G96 is active, the programming units will be m/min." .