@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:G81 a ex:ModoOperacion ;
    ex:textoExtracto "G81" .

ex:G8x a ex:ModoOperacion ;
    ex:textoExtracto "G8x" .

ex:G99 a ex:ModoOperacion ;
    ex:textoExtracto "G99" .

ex:G1 a ex:ModoOperacion ;
    ex:textoExtracto "G1" .

ex:G99_G1_G81_Block a ex:Esquema ;
    ex:textoExtracto "It is also possible to add the definition of the canned cycle (calling function and parameters) at the end of any block. [ G functions] G8x [Machining point] cycle parameters [F S T D M] N10 G99 G1 G81 X60 Y0 Z2 I-20 F1000 S2000 M4 N10 G99 G1 X60 Y0 F1000 S2000 M4 G81 Z2 I-20" ;
    ex:compuestoPor ex:G99_G1_G81_Block_Line1, ex:G99_G1_G81_Block_Line2 .

ex:G99_G1_G81_Block_Line1 a ex:Tabla ;
    ex:textoExtracto "N10 G99 G1 G81 X60 Y0 Z2 I-20 F1000 S2000 M4" ;
    ex:detalladoEnEsquema ex:G99_G1_G81_Block .

ex:G99_G1_G81_Block_Line2 a ex:Tabla ;
    ex:textoExtracto "N10 G99 G1 X60 Y0 F1000 S2000 M4 G81 Z2 I-20" ;
    ex:detalladoEnEsquema ex:G99_G1_G81_Block .