@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla44 a ex:Tabla ;
    ex:textoExtracto """| Instruction. |  | Meaning. |
| --- | --- | --- |
| $GOTO |  | Block skip. |
| $IF $ENDIF
$ELSEIF $ELSE |  | Conditional execution. |
| $SWITCH $CASE $ENDSWITCH
$BREAK $DEFAULT |  | Conditional execution. |
| $FOR $ENDFOR
$BREAK $CONTINUE |  | Block repetition. |
| $WHILE $ENDWHILE
$BREAK $CONTINUE |  | Conditional block repetition. |
| $DO $ENDDO
$BREAK $CONTINUE |  | Conditional block repetition. |
| Instruction. | Meaning. |  |
| L | Call to a global subroutine. |  |
| LL | Call to a local subroutine. |  |
| #ABORT | Abort the execution of the program and resume it in another block or program. |  |
| #ACS | Fixture coordinate system. |  |
| #ANGAX OFF | Turn angular transformation off. |  |
| #ANGAX ON | Turn angular transformation on. |  |
| #ANGAX SUSP | Freeze angular transformation. |  |
| #ASPLINE ENDTANG | Akima splines. Type of final tangent. |  |
| #ASPLINE MODE | Akima splines. Selection of tangent type. |  |
| #ASPLINE STARTTANG | Akima splines. Type of starting tangent. |  |
| #AXIS | Axis upon which the additive manual intervention is applied. |  |
| #CALL | Call to a global or local subroutine. |  |
| #CALL AX | Add a new axis to the configuration of the channel. |  |
| #CALL SP | Add a spindle to the configuration of the channel. |  |
| #CAM ON | Activate the electronic cam (real coordinates). |  |
| #CAM OFF | Cancel the electronic cam. |  |
| #CAX | "C" axis. Activating the spindle as ·C· axis. |  |
| #CD OFF | Cancel collision detection. |  |
| #CD ON | Activating collision detection. |  |
| #CLEAR | Channels. It clears the synchronism marks of the channel. |  |
| #CONTJOG | Manual intervention. Feedrate in continuous jog. | 
| #COMMENT BEGIN | Beginning of comment. |  |
| #COMMENT END | End of comment.""" .

ex:Instruccion_GOTO a ex:Parametro ;
    ex:textoExtracto "$GOTO" ;
    rdfs:label "Block skip"@en .

ex:Instruccion_IF a ex:Parametro ;
    ex:textoExtracto "$IF $ENDIF"@en ;
    rdfs:label "Conditional execution"@en .

ex:Instruccion_ELSEIF a ex:Parametro ;
    ex:textoExtracto "$ELSEIF $ELSE"@en ;
    rdfs:label "Conditional execution"@en .

ex:Instruccion_SWITCH a ex:Parametro ;
    ex:textoExtracto "$SWITCH $CASE $ENDSWITCH"@en ;
    rdfs:label "Conditional execution"@en .

ex:Instruccion_FOR a ex:Parametro ;
    ex:textoExtracto "$FOR $ENDFOR"@en ;
    rdfs:label "Block repetition"@en .

ex:Instruccion_WHILE a ex:Parametro ;
    ex:textoExtracto "$WHILE $ENDWHILE"@en ;
    rdfs:label "Conditional block repetition"@en .

ex:Instruccion_DO a ex:Parametro ;
    ex:textoExtracto "$DO $ENDDO"@en ;
    rdfs:label "Conditional block repetition"@en .

ex:Instruccion_L a ex:Parametro ;
    ex:textoExtracto "L"@en ;
    rdfs:label "Call to a global subroutine"@en .

ex:Instruccion_LL a ex:Parametro ;
    ex:textoExtracto "LL"@en ;
    rdfs:label "Call to a local subroutine"@en .

ex:Instruccion_ABORT a ex:Parametro ;
    ex:textoExtracto "#ABORT"@en ;
    rdfs:label "Abort the execution of the program and resume it in another block or program"@en .

ex:Instruccion_ACS a ex:Parametro ;
    ex:textoExtracto "#ACS"@en ;
    rdfs:label "Fixture coordinate system"@en .

ex:Instruccion_ANGAX_OFF a ex:Parametro ;
    ex:textoExtracto "#ANGAX OFF"@en ;
    rdfs:label "Turn angular transformation off"@en .

ex:Instruccion_ANGAX_ON a ex:Parametro ;
    ex:textoExtracto "#ANGAX ON"@en ;
    rdfs:label "Turn angular transformation on"@en .

ex:Instruccion_ANGAX_SUSP a ex:Parametro ;
    ex:textoExtracto "#ANGAX SUSP"@en ;
    rdfs:label "Freeze angular transformation"@en .

ex:Instruccion_ASPLINE_ENDTANG a ex:Parametro ;
    ex:textoExtracto "#ASPLINE ENDTANG"@en ;
    rdfs:label "Akima splines. Type of final tangent"@en .

ex:Instruccion_ASPLINE_MODE a ex:Parametro ;
    ex:textoExtracto "#ASPLINE MODE"@en ;
    rdfs:label "Akima splines. Selection of tangent type"@en .

ex:Instruccion_ASPLINE_STARTTANG a ex:Parametro ;
    ex:textoExtracto "#ASPLINE STARTTANG"@en ;
    rdfs:label "Akima splines. Type of starting tangent"@en .

ex:Instruccion_AXIS a ex:Parametro ;
    ex:textoExtracto "#AXIS"@en ;
    rdfs:label "Axis upon which the additive manual intervention is applied"@en .

ex:Instruccion_CALL a ex:Parametro ;
    ex:textoExtracto "#CALL"@en ;
    rdfs:label "Call to a global or local subroutine"@en .

ex:Instruccion_CALL_AX a ex:Parametro ;
    ex:textoExtracto "#CALL AX"@en ;
    rdfs:label "Add a new axis to the configuration of the channel"@en .

ex:Instruccion_CALL_SP a ex:Parametro ;
    ex:textoExtracto "#CALL SP"@en ;
    rdfs:label "Add a spindle to the configuration of the channel"@en .

ex:Instruccion_CAM_ON a ex:Parametro ;
    ex:textoExtracto "#CAM ON"@en ;
    rdfs:label "Activate the electronic cam (real coordinates)"@en .

ex:Instruccion_CAM_OFF a ex:Parametro ;
    ex:textoExtracto "#CAM OFF"@en ;
    rdfs:label "Cancel the electronic cam"@en .

ex:Instruccion_CAX a ex:Parametro ;
    ex:textoExtracto "#CAX"@en ;
    rdfs:label "\"C\" axis. Activating the spindle as ·C· axis"@en .

ex:Instruccion_CD_OFF a ex:Parametro ;
    ex:textoExtracto "#CD OFF"@en ;
    rdfs:label "Cancel collision detection"@en .

ex:Instruccion_CD_ON a ex:Parametro ;
    ex:textoExtracto "#CD ON"@en ;
    rdfs:label "Activating collision detection"@en .

ex:Instruccion_CLEAR a ex:Parametro ;
    ex:textoExtracto "#CLEAR"@en ;
    rdfs:label "Channels. It clears the synchronism marks of the channel"@en .

ex:Instruccion_CONTJOG a ex:Parametro ;
    ex:textoExtracto "#CONTJOG"@en ;
    rdfs:label "Manual intervention. Feedrate in continuous jog"@en .

ex:Instruccion_COMMENT_BEGIN a ex:Parametro ;
    ex:textoExtracto "#COMMENT BEGIN"@en ;
    rdfs:label "Beginning of comment"@en .

ex:Instruccion_COMMENT_END a ex:Parametro ;
    ex:textoExtracto "#COMMENT END"@en ;
    rdfs:label "End of comment"@en .