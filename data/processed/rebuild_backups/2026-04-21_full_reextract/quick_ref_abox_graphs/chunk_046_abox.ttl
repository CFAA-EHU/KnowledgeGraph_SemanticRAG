@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CS a ex:ModoOperacion ;
    rdfs:label "#CS" ;
    ex:textoExtracto "Machining coordinate system." .

ex:CSROT_ON a ex:ModoOperacion ;
    rdfs:label "#CSROT ON" ;
    ex:textoExtracto "Activate tool orientation in the part coordinate system." .

ex:CSROT_OFF a ex:ModoOperacion ;
    rdfs:label "#CSROT OFF" ;
    ex:textoExtracto "Cancel tool orientation in the part coordinate system." .

ex:CYL a ex:ModoOperacion ;
    rdfs:label "#CYL" ;
    ex:textoExtracto "\"C\" axis. Machining of the turning side of the part." .

ex:DEF a ex:ModoOperacion ;
    rdfs:label "#DEF" ;
    ex:textoExtracto "Macros. Define a macro." .