@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_51_1 a ex:ModoOperacion ;
    rdfs:label "#SERVO OFF" ;
    ex:textoExtracto "| #SERVO OFF | Activate the open loop mode. |" .

ex:ModoOperacion_51_2 a ex:ModoOperacion ;
    rdfs:label "#SET AX" ;
    ex:textoExtracto "| #SET AX | Set a new axes configuration. |" .

ex:ModoOperacion_51_3 a ex:ModoOperacion ;
    rdfs:label "#SET OFFSET" ;
    ex:textoExtracto "| #SET OFFSET | Manual intervention. Moving limits. |" .

ex:ModoOperacion_51_4 a ex:ModoOperacion ;
    rdfs:label "#SET SP" ;
    ex:textoExtracto "| #SET SP | Set a new spindle configuration. |" .

ex:ModoOperacion_51_5 a ex:ModoOperacion ;
    rdfs:label "#SIGNAL" ;
    ex:textoExtracto "| #SIGNAL | Channels. Activate the mark in its own channel. |" .

ex:ModoOperacion_51_6 a ex:ModoOperacion ;
    rdfs:label "#SLOPE" ;
    ex:textoExtracto "| #SLOPE | Acceleration control. |" .

ex:ModoOperacion_51_7 a ex:ModoOperacion ;
    rdfs:label "#SPLINE OFF" ;
    ex:textoExtracto "| #SPLINE OFF | Akima splines. Cancels spline adaptation. |" .

ex:ModoOperacion_51_8 a ex:ModoOperacion ;
    rdfs:label "#SPLINE ON" ;
    ex:textoExtracto "| #SPLINE ON | Akima splines. Activate spline adaptation. |" .

ex:ModoOperacion_51_9 a ex:ModoOperacion ;
    rdfs:label "#SWTOUT ON" ;
    ex:textoExtracto "| #SWTOUT ON | Activate synchronized switching. |" .

ex:ModoOperacion_51_10 a ex:ModoOperacion ;
    rdfs:label "#SWTOUT OFF" ;
    ex:textoExtracto "| #SWTOUT OFF | Cancel synchronized switching. |" .