@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SplineOn a ex:ModoOperacion ;
    rdfs:label "#SPLINE ON" ;
    ex:textoExtracto "Activate spline adaptation." .

ex:SwtoutOn a ex:ModoOperacion ;
    rdfs:label "#SWTOUT ON" ;
    ex:textoExtracto "Activate synchronized switching." .

ex:SwtoutOff a ex:ModoOperacion ;
    rdfs:label "#SWTOUT OFF" ;
    ex:textoExtracto "Cancel synchronized switching." .

ex:Sync a ex:ModoOperacion ;
    rdfs:label "#SYNC" ;
    ex:textoExtracto "Spindle synchronization based on the real (actual) coordinate." .

ex:SyncPos a ex:ModoOperacion ;
    rdfs:label "#SYNC POS" ;
    ex:textoExtracto "Manual intervention. Coordinate synchronization." .

ex:TangctrlOff a ex:ModoOperacion ;
    rdfs:label "#TANGCTRL OFF" ;
    ex:textoExtracto "Cancel tangential control." .

ex:TangctrlOn a ex:ModoOperacion ;
    rdfs:label "#TANGCTRL ON" ;
    ex:textoExtracto "Activate tangential control." .

ex:TangctrlSusp a ex:ModoOperacion ;
    rdfs:label "#TANGCTRL SUSP" ;
    ex:textoExtracto "Freeze tangential control." .