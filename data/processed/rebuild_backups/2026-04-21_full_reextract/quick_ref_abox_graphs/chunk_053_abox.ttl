@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:UNLINK a ex:AccionProhibida ;
    ex:textoExtracto "Cancel the electronic coupling (slaving) of axes." ;
    rdfs:label "#UNLINK" .

ex:UNPARK a ex:AccionProhibida ;
    ex:textoExtracto "Unpark an axis or spindle." ;
    rdfs:label "#UNPARK" .

ex:UNSYNC a ex:AccionProhibida ;
    ex:textoExtracto "Cancel the spindle synchronization." ;
    rdfs:label "#UNSYNC" .

ex:WARNING a ex:AvisoSeguridad ;
    ex:textoExtracto "Display a warning on the screen." ;
    rdfs:label "#WARNING" .

ex:WARNINGSTOP a ex:AvisoSeguridad ;
    ex:textoExtracto "Display a warning on the screen and interrupt the program." ;
    rdfs:label "#WARNINGSTOP" .

ex:SistemaControlNumerico a ex:Sistema ;
    ex:textoExtracto "Spindle synchronization based on the theoretical coordinate." ;
    rdfs:label "Sistema de control numérico" .

ex:EjeVirtual a ex:ComponenteMecanico ;
    ex:textoExtracto "Activate the virtual tool axis." ;
    rdfs:label "Eje virtual" .

ex:EjeLongitudinal a ex:ComponenteMecanico ;
    ex:textoExtracto "Select the longitudinal axis of the tool." ;
    rdfs:label "Eje longitudinal" .