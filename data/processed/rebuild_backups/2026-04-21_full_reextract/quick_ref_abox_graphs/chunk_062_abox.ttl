@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G163 a ex:ModoOperacion ;
    rdfs:label "G163. Multiple machining in a full circle" ;
    ex:textoExtracto "Corona circular con puntos equiangularmente espaciados; el centro y radio se obtienen desde el punto de partida (X,Y), con paso angular “I” o número total “K” y tipo de movimiento “C”." .

ex:G164 a ex:ModoOperacion ;
    rdfs:label "G164. Multiple machining in arc pattern" ;
    ex:textoExtracto "Arco con puntos distribuidos entre ángulo “B” y paso “I” (o total “K”). Se muestran vectores desde el origen (X,Y) al centro." .

ex:G165 a ex:ModoOperacion ;
    rdfs:label "G165. Machining programmed with an arc-chord" ;
    ex:textoExtracto "Construcción de cuerda con mediatriz a ángulo “A” y longitud “I”; flechas indican interpolación entre puntos sobre el arco." .

ex:G66 a ex:ModoOperacion ;
    rdfs:label "G66. Pattern repeat canned cycle" ;
    ex:textoExtracto "Perfil torneado en sección longitudinal con pasadas repetitivas; se destacan exceso “I”, pasada “C”, ejes principales y bloques S–E que delimitan la geometría." .

ex:G68 a ex:ModoOperacion ;
    rdfs:label "G68. Stock removal cycle along X axis" ;
    ex:textoExtracto "Desbaste por capas en eje X con retirada “D” tras cada pasada; se rotulan existencias de acabado “L/M” y avances “K/F/H”." .

ex:G69 a ex:ModoOperacion ;
    rdfs:label "G69. Stock removal canned cycle along Z axis" ;
    ex:textoExtracto "Desbaste por capas en eje Z." .