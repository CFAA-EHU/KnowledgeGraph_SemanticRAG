@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:G87 a ex:ModoOperacion ;
    ex:identificador "G87" ;
    ex:textoExtracto "Rosca longitudinal con penetraciones escalonadas “B/E” y ángulo de penetración “A”. Se marcan inicio/fin (Q/R) y posición angular “W”." .

ex:G88 a ex:ModoOperacion ;
    ex:identificador "G88" ;
    ex:textoExtracto "Ranurado axial con varias penetraciones “C”, seguridad “D” y demora “K”; el esquema muestra los escalones en X con fin en (Q,R)." .

ex:G89 a ex:ModoOperacion ;
    ex:identificador "G89" ;
    ex:textoExtracto "Ranurado frontal con penetraciones en Z; idéntica representación de pasadas y retirada." .

ex:G160 a ex:ModoOperacion ;
    ex:identificador "G160" ;
    ex:textoExtracto "Cilindro en cara con múltiples taladros repartidos angularmente (Q/A/J). Iconografía de herramienta motorizada (S/N) y seguridad “D/H/C/R”." .

ex:G161 a ex:ModoOperacion ;
    ex:identificador "G161" ;
    ex:textoExtracto "Taladrado radial en el lateral del cilindro; distribución angular y parámetros análogos con seguridad a lo largo de X." .

ex:G162 a ex:ModoOperacion ;
    ex:identificador "G162" ;
    ex:textoExtracto "Fresado ranura lateral: longitud “L”, profundidad “I” y reparto angular (Q/A/J); se ilustra herramienta motorizada y sentido." .