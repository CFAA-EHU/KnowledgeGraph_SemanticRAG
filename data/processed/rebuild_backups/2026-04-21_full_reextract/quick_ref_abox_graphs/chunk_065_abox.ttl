@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FresadoRanuraLateral rdfs:label "Fresado ranura lateral" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Slot milling along the side of the part. --- Fresado ranura lateral: longitud “L”, profundidad “I” y reparto angular (Q/A/J); se ilustra herramienta motorizada y sentido." ;
    ex:tieneComponente ex:HerramientaMotorizada .

ex:HerramientaMotorizada rdfs:label "Herramienta motorizada" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "se ilustra herramienta motorizada y sentido." .

ex:FresadoEnCara rdfs:label "Fresado en cara" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Fresado en cara con parámetros equivalentes y seguridad “D” en Z; esquema con pieza en vista frontal." .

ex:CalibracionHerramienta rdfs:label "Calibración de herramienta" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Tool calibration (dimensions and wear). --- Tres viñetas (sonda en eje y contactos laterales) con cotas de seguridad “B”, velocidades de palpado y posiciones relativas; flechas muestran la trayectoria de la sonda respecto a herramienta y mesa." .

ex:Sonda rdfs:label "Sonda" ;
    a ex:Sensor ;
    ex:textoExtracto "Tres viñetas (sonda en eje y contactos laterales)" .

ex:CalibracionSonda rdfs:label "Calibración de sonda" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Probe calibration. --- Palpado de un orificio patrón: plano XY con centro (X,Y), profundidad Z y retirada “E”; se ven dos velocidades de palpado y distancias de seguridad." .

ex:MedicionPlanitud rdfs:label "Medición de planitud" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Surfacing measuring. --- Medición de planitud con sonda recorriendo una cara; se señalan tolerancia “L”, eje de palpado “K” y correcciones de desgaste (T/D)." .

ex:MedicionEsquinaExterior rdfs:label "Medición de esquina exterior" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Outside corner measuring. --- Palpado de esquina exterior con flechas hacia caras X/Y; se destaca distancia de seguridad “B” y avance de palpado “F”." .

ex:MedicionEsquinaInterior rdfs:label "Medición de esquina interior" ;
    a ex:TareaMantenimiento ;
    ex:textoExtracto "Inside corner measuring. ---" .

ex:EsquemaCalibracion rdfs:label "Esquema de calibración" ;
    a ex:Esquema ;
    ex:textoExtracto "esquema con pieza en vista frontal." ;
    ex:ilustradoEn ex:FresadoEnCara .

ex:EsquemaMedicion rdfs:label "Esquema de medición" ;
    a ex:Esquema ;
    ex:textoExtracto "flechas muestran la trayectoria de la sonda respecto a herramienta y mesa." ;
    ex:ilustradoEn ex:CalibracionHerramienta .

ex:ParametroSeguridadD rdfs:label "Parámetro de seguridad D" ;
    a ex:Parametro ;
    ex:textoExtracto "seguridad “D” en Z" ;
    ex:valor "D" .

ex:ParametroSeguridadB rdfs:label "Parámetro de seguridad B" ;
    a ex:Parametro ;
    ex:textoExtracto "cotas de seguridad “B”" ;
    ex:valor "B" .

ex:ParametroSeguridadE rdfs:label "Parámetro de seguridad E" ;
    a ex:Parametro ;
    ex:textoExtracto "retirada “E”" ;
    ex:valor "E" .

ex:ParametroToleranciaL rdfs:label "Parámetro de tolerancia L" ;
    a ex:Parametro ;
    ex:textoExtracto "tolerancia “L”" ;
    ex:valor "L" .

ex:ParametroEjeK rdfs:label "Parámetro eje K" ;
    a ex:Parametro ;
    ex:textoExtracto "eje de palpado “K”" ;
    ex:valor "K" .