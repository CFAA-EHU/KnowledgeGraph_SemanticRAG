{
  "policy_name": "rate-limit-drain",
  "max_concurrency": 1,
  "retryable_errors": [
    "rate_limit",
    "429",
    "timeout",
    "network_error",
    "api_error"
  ],
  "max_retries": 6,
  "backoff_strategy": "exponential_seconds_[15,30,60,120,240,480]",
  "jitter_strategy": "uniform_multiplier_0.85_to_1.15",
