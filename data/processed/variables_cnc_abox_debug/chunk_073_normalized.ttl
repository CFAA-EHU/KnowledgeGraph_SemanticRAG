@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ParametroSPDLNAME a ex:Parametro ;
    rdfs:label "Tabla de parámetros máquina" ;
    ex:identificador "SPDLNAME" ;
    ex:textoExtracto "definidos en la tabla de parámetros máquina (SPDLNAME). El primer cabezal de la tabla tendrá índice ·1· y así sucesivamente." .

ex:SistemaMulticanal a ex:Sistema ;
    rdfs:label "Sistema multicanal" ;
    ex:textoExtracto "definidos en la tabla de parámetros máquina (SPDLNAME). El primer cabezal de la tabla tendrá índice ·1· y así sucesivamente." .