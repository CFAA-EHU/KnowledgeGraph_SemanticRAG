ex:ParametroVGA NASO3 a ex:Parametro ;
    rdfs:label "Tensión de la salida analógica 3" ;
    ex:identificador "V.G.ANASO[3]" ;
    ex:textoExtracto "V.G.ANASO[3] | Tensión de la salida analógica ·3·." .

ex:ParametroG ANASOn a ex:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz; de escritura desde el programa y PLC" ;
    ex:identificador "G.ANASO[n]" ;
    ex:textoExtracto "(V.)G.ANASO[n] Variable de lectura desde el interfaz; de escritura desde el programa y PLC. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .