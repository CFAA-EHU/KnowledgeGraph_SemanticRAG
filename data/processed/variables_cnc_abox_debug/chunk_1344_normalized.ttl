ex:ParametroVACNCMMODEZ a ex:Parametro ;
    rdfs:label "Eje Z" ;
    ex:identificador "V.A.CNCMMODE.Z" ;
    ex:textoExtracto "V.A.CNCMMODE.Z | Eje Z." .

ex:ParametroVACNCMMODE4 a ex:Parametro ;
    rdfs:label "Eje con número lógico ·4·" ;
    ex:identificador "V.A.CNCMMODE.4" ;
    ex:textoExtracto "V.A.CNCMMODE.4 | Eje con número lógico ·4·." .

ex:ParametroVA2CNCMMODE1 a ex:Parametro ;
    rdfs:label "Eje con índice ·1· en el canal ·2·" ;
    ex:identificador "V.[2].A.CNCMMODE.1" ;
    ex:textoExtracto "V.[2].A.CNCMMODE.1 | Eje con índice ·1· en el canal ·2·." .

ex:ParametroPLCMMODE a ex:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ex:identificador "V.A.PLCMMODE.xn" ;
    ex:textoExtracto "(V.)[ch].A.PLCMMODE.xn Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz." .

ex:ParametroPLCMMODE valor "1" ;
    rdfs:label "Modo volante" ;
    ex:textoExtracto "1 | Modo volante." .

ex:ParametroPLCMMODE valor "2" ;
    rdfs:label "Modo jog continuo" ;
    ex:textoExtracto "2 | Modo jog continuo." .

ex:ParametroPLCMMODE valor "3" ;
    rdfs:label "Modo jog incremental" ;
    ex:textoExtracto "3 | Modo jog incremental." .