ex:ParametroGPRBST a ex:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·1·"@es ;
    ex:identificador "G.PRBST" ;
    ex:textoExtracto "\"(V.)G.PRBST (V.)G.PRBST1 Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·1·.\"@es .  ex:ParametroGPRBST1 a ex:Parametro ;     rdfs:label \"Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·1·"@es ;     ex:identificador "G.PRBST1" ;     ex:textoExtracto "\"(V.)G.PRBST (V.)G.PRBST1 Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·1·.\"@es .

ex:ParametroGPRBST2 a ex:Parametro ;
    rdfs:label \"Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·2·"@es ;
    ex:identificador "G.PRBST2" ;
    ex:textoExtracto "\"(V.)G.PRBST2 Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado del palpador ·2·.\"@es .  ex:ParametroValor0 a ex:Parametro ;     rdfs:label \"El palpador no está haciendo contacto o está sin inicializar."@es ;     ex:identificador "0" ;     ex:textoExtracto "\"0 El palpador no está haciendo contacto o está sin inicializar.\"@es .

