@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametroPLCR nb a ex:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa e interfaz" ;
    ex:identificador "PLC.R[nb]" ;
    ex:textoExtracto "\"(V.)PLC.R[nb] Variable de lectura y escritura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Valor del registro [nb] del PLC.\"".

