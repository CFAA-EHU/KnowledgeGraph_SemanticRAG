@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DuplicacionOUsoNoAutorizadoDelSoftware a ns1:AccionProhibida ;
    rdfs:label "duplicación o uso no autorizado del software" ;
    ns1:textoExtracto "Se prohíbe cualquier duplicación o uso no autorizado del software, ya sea en su conjunto o parte del mismo." .

ns1:ManualBrochadoraA218 a ns1:DocumentoTecnico ;
    rdfs:label "MANUAL ORIGINAL" ;
    ns1:identificador "MANUAL ORIGINAL" ;
    ns1:textoExtracto "Este manual, así como los documentos que deriven del mismo, han sido redactados en español." .

