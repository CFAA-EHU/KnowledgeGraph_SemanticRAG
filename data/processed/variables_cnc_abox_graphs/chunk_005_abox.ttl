@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_dfe80c2e62 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre uso diferente" ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC si éste se utiliza de manera diferente a la explicada en la documentación relacionada." .

ns1:AvisoSeguridad_effe21c1aa a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre errores involuntarios" ;
    ns1:textoExtracto "Se comprueba regularmente la información contenida en el documento y se procede a realizar las correcciones necesarias que quedarán incluidas en una posterior edición." .

ns1:ManualBrochadoraElectromecanicaExteriorA218 a ns1:DocumentoTecnico ;
    rdfs:label "Manual de la Brochadora Electromecánica Exterior A218" ;
    ns1:documenta ns1:CNC8070_268e8c2e46 ;
    ns1:textoExtracto "Se ha contrastado el contenido de este manual y su validez para el producto descrito. Aún así, es posible que se haya cometido algún error involuntario y es por ello que no se garantiza una coincidencia absoluta." .

ns1:CNC8070_268e8c2e46 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En cualquier caso, Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC si éste se utiliza de manera diferente a la explicada en la documentación relacionada." .

