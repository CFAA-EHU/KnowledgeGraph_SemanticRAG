ns1:CNC8070_96e666b1d5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "OPCIONES Algunas de las prestaciones descritas en este Las opciones de software activas en el CNC se la ventana de tareas, pulsando [CTRL][A]), Consulte el ordering handbook para conocer las SOFT ADDIT AXES Eje adicional. Añade ejes a la configuración por defecto." .

ns1:CabezalAdicional a ns1:Parametro ;
    rdfs:label "Cabezal adicional" ;
    ns1:identificador "SOFT ADDIT SPINDLES" ;
    ns1:textoExtracto "SOFT ADDIT SPINDLES Cabezal adicional. Añade cabezales a la configuración por defecto." .

ns1:EjeAdicional a ns1:Parametro ;
    rdfs:label "Eje adicional" ;
    ns1:identificador "SOFT ADDIT AXES" ;
    ns1:textoExtracto "SOFT ADDIT AXES Eje adicional. Añade ejes a la configuración por defecto." .

ns1:Industry40 a ns1:Parametro ;
    rdfs:label "Industry 4.0" ;
    ns1:identificador "SOFT i4.0 CONNECTIVITY PACK" ;
    ns1:textoExtracto "SOFT i4.0 CONNECTIVITY PACK Industry 4.0. Esta opción permite utilizar y realizar captura de datos a través de FSYS." .

ns1:LimitacionDe4EjesInterpolados a ns1:Parametro ;
    rdfs:label "Limitación de 4 ejes interpolados" ;
    ns1:identificador "SOFT 4 AXES INTERPOLATION LIMIT" ;
    ns1:textoExtracto "SOFT 4 AXES INTERPOLATION LIMIT Limitación de 4 ejes interpolados. Limita a 4 el número de ejes que el CNC puede interpolar al mismo tiempo." .

ns1:Parametro_02eeefee45 a ns1:Parametro ;
    rdfs:label "Canal adicional" ;
    ns1:identificador "SOFT ADDIT CHANNELS" ;
    ns1:textoExtracto "SOFT ADDIT CHANNELS Canal adicional. Añade canales a la configuración por defecto." .

ns1:Parametro_f941e37318 a ns1:Parametro ;
    rdfs:label "Almacén adicional" ;
    ns1:identificador "SOFT ADDIT TOOL MAGAZ" ;
    ns1:textoExtracto "SOFT ADDIT TOOL MAGAZ Almacén adicional. Añade almacenes a la configuración por defecto." .

ns1:SistemaAbierto a ns1:Parametro ;
    rdfs:label "Sistema abierto" ;
    ns1:identificador "SOFT OPEN SYSTEM" ;
    ns1:textoExtracto "SOFT OPEN SYSTEM Sistema abierto. El CNC es un sistema cerrado que ofrece todas las características necesarias para mecanizar piezas." .

