@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_267b63a2be a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:requiereMantenimiento ns1:InstalacionDeAplicaciones ;
    ns1:textoExtracto "Esta prestación debe estar activa cuando se instala este tipo de aplicaciones, incluso si se trata de archivos de Office." ;
    ns1:tieneComponente ns1:SoftwareEdicionSimul .

ns1:InstalacionDeAplicaciones a ns1:TareaMantenimiento ;
    rdfs:label "Instalación de Aplicaciones" ;
    ns1:textoExtracto "Una vez instalada la aplicación, se recomienda cerrar el CNC para evitar que los usuarios instalen otro tipo de aplicaciones que podrían ralentizar el sistema y afectar al mecanizado." .

ns1:SoftwareEdicionSimul a ns1:Componente ;
    rdfs:label "Modo Edisimu (edición y simulación)" ;
    ns1:textoExtracto "SOFT EDIT/SIMUL Modo edisimu (edición y simulación). Permite editar, modificar y simular programas pieza." .

