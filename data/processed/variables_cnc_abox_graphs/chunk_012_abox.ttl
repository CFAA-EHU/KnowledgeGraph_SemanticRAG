@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_47917184b7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Con esta prestación, el PLC puede ser programado en el lenguaje Fagor habitual o en el formato IEC 61131." .

ns1:CompensacionDeRadio_6c46c581af a ns1:Parametro ;
    rdfs:label "Compensación de radio" ;
    ns1:identificador "SOFT TOOL RADIUS COMP" ;
    ns1:textoExtracto "La compensación de la herramienta permite programar el contorno a mecanizar en función de las dimensiones de las piezas y sin tener en cuenta las dimensiones de la herramienta que se utilizará posteriormente." .

ns1:EditorDePerfiles_972da352de a ns1:Parametro ;
    rdfs:label "Editor de perfiles" ;
    ns1:identificador "SOFT PROFILE EDITOR" ;
    ns1:textoExtracto "Permite editar perfiles de pieza gráficamente e importar archivos dxf." .

ns1:EjeC_64138189f5 a ns1:Parametro ;
    rdfs:label "Eje C" ;
    ns1:identificador "SOFT C AXIS" ;
    ns1:textoExtracto "Activa la cinemática para trabajar con eje C y sus ciclos." .

ns1:RTCPDinamicoRotatingToolCenterPoint_39f9f8bf5a a ns1:Parametro ;
    rdfs:label "RTCP dinámico (Rotating Tool Center Point)" ;
    ns1:identificador "SOFT RTCP" ;
    ns1:textoExtracto "La opción RTCP dinámico es una necesidad para el mecanizado con interpolación de 4, 5 o 6 ejes." .

