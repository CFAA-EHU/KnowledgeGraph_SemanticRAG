@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8e200ee2d6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "de 4, 5 o 6 ejes. SOFT C AXIS Eje C. Activa la cinemática para trabajar con eje C y sus ciclos fijos asociados." ;
    ns1:tieneComponente ns1:EjeTandem .

ns1:SistemaSincronismo a ns1:Sistema ;
    rdfs:label "Sistema Sincronización" ;
    ns1:textoExtracto "Los ejes y los husillos pueden sincronizarse de dos" .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ns1:ComponenteElectrico_a0d9a5220d a ns1:ComponenteElectrico ;
    rdfs:label "Motor 1",
        "Motor 2" ;
    ns1:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ns1:EjeTandem a ns1:ComponenteMecanico ;
    rdfs:label "Eje Tándem" ;
    ns1:compuestoPor ns1:ComponenteElectrico_a0d9a5220d ;
    ns1:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

