@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_26b9b1f5b5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "SYNCHRONISM Sincronización de ejes y cabezales. Los ejes y los husillos pueden sincronizarse de dos maneras, en velocidad o en posición." ;
    ns1:tieneComponente ns1:AlgoritmoHSSAIIHighSpeedSurfaceAccuracy,
        ns1:SincronizacionDeEjesYCabezales .

ns1:SistemaHSSAII a ns1:Sistema ;
    rdfs:label "High Speed Surface Accuracy II" ;
    ns1:textoExtracto "SOFT HSSA II MACHINING SYSTEM High Speed Surface Accuracy II. Opción para habilitar el algoritmo HSSA-II (High Speed Surface Accuracy) para el mecanizado de alta velocidad (HSC)" .

ns1:AlgoritmoHSSAIIHighSpeedSurfaceAccuracy a ns1:Parametro ;
    rdfs:label "Algoritmo HSSA-II (High Speed Surface Accuracy)" ;
    ns1:textoExtracto "Opción para habilitar el algoritmo HSSA-II (High Speed Surface Accuracy) para el mecanizado de alta velocidad (HSC)" .

ns1:SincronizacionDeEjesYCabezales a ns1:Parametro ;
    rdfs:label "Sincronización de ejes y cabezales" ;
    ns1:textoExtracto "Los ejes y los husillos pueden sincronizarse de dos maneras, en velocidad o en posición." .

