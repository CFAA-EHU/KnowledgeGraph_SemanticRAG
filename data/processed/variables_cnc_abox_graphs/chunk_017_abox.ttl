@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0113ef6dc9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La compensación volumétrica FVC viene para complementar las herramientas de ajuste de la máquina." .

ns1:FVCTipoStandard a ns1:AccionProhibida ;
    rdfs:label "FVC STANDARD" ;
    ns1:textoExtracto "FVC STANDARD: Compensación de 25 puntos en cada eje. Rápida de calibrar (tiempo) pero menos precisa que las otras dos, aunque es suficiente para las tolerancias deseadas." .

ns1:FVCUPTO10m3 a ns1:AccionProhibida ;
    rdfs:label "FVC UP TO 10m3" ;
    ns1:textoExtracto "FVC UP TO 10m3: Compensación de volúmenes hasta 10 m³. Mas precisa que FVC STANDARD, pero requiere de una" .

ns1:Herramienta_9d7a5b0dca a ns1:Herramienta ;
    rdfs:label "Herramienta CNC" ;
    ns1:textoExtracto "La compensación volumétrica FVC viene para complementar las herramientas de ajuste de la máquina." .

ns1:MaquinaCNC8070 a ns1:Maquina ;
    rdfs:label "Máquina CNC 8070" ;
    ns1:textoExtracto "La precisión de las piezas está limitada por las tolerancias de fabricación de la máquina y por el efecto de la temperatura durante el mecanizado." .

