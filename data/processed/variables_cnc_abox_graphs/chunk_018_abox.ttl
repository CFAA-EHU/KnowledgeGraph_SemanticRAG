@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1b076bb708 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:MaquinaLaserCorteChapaGruesa ;
    ns1:textoExtracto "donde el CNC genera una serie de impulsos PWM para controlar la potencia del láser al perforar el punto de partida." .

ns1:Parametro_2bf5a3387e a ns1:Parametro ;
    rdfs:label "Función SOFT 60 PWM CONTROL" ;
    ns1:identificador "SOFT 60 PWM CONTROL" ;
    ns1:textoExtracto "SOFT 60 PWM CONTROL Pulse-Width Modulation. Esta función sólo está disponible en sistemas de regulación con bus Sercos." .

ns1:SistemaRegulacionSercos a ns1:Sistema ;
    rdfs:label "Sistema de regulación con bus Sercos" ;
    ns1:textoExtracto "Esta función sólo está disponible en sistemas de regulación con bus Sercos." .

ns1:MaquinaLaserCorteChapaGruesa a ns1:Maquina ;
    rdfs:label "Máquina láser para el corte de chapa muy gruesa" ;
    ns1:textoExtracto "Está orientada principalmente a máquinas láser para el corte de chapa muy gruesa, donde el CNC genera una serie de impulsos PWM para controlar la potencia del láser al perforar el punto de partida." .

