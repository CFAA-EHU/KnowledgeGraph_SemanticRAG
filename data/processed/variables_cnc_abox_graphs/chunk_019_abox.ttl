@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_dad9caeb7e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:Sensor_0932b75995 ;
    ns1:monitoreaParametro ns1:ControlDeGap,
        ns1:DynamicMachiningControl,
        ns1:FagorMachiningCalculator ;
    ns1:textoExtracto "El CNC, de manera que el CNC compensará las variaciones del sensor sobre la distancia programada con movimientos adicionales en el eje programado para el gap." .

ns1:ControlDeGap a ns1:Parametro ;
    rdfs:label "Control de gap" ;
    ns1:identificador "SOFT60GAPCONTROL" ;
    ns1:textoExtracto "SOFT 60 GAP CONTROL Control de gap. Está orientada principalmente a máquinas láser." .

ns1:DynamicMachiningControl a ns1:Parametro ;
    rdfs:label "Dynamic Machining Control" ;
    ns1:identificador "SOFTDMC" ;
    ns1:textoExtracto "SOFT DMC Dynamic Machining Control. El DMC adapta el avance durante el mecanizado para mantener la potencia de corte lo más cercana posible a las condiciones idóneas de mecanizado." .

ns1:FagorMachiningCalculator a ns1:Parametro ;
    rdfs:label "Fagor Machining Calculator" ;
    ns1:identificador "SOFTFMC" ;
    ns1:textoExtracto "SOFT FMC Fagor Machining Calculator. La aplicación FMC consiste en una base de datos de materiales a mecanizar y operaciones de mecanizado (fresado y torneado), junto a un interface que permite elegir las condiciones de corte adecuadas" .

ns1:Sensor_0932b75995 a ns1:Sensor ;
    rdfs:label "sensor del gap" ;
    ns1:textoExtracto "Esta distancia la calcula un sensor conectado al CNC, de manera que el CNC compensará las variaciones del sensor sobre la distancia programada con movimientos adicionales en el eje programado para el gap." .

