@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DocumentoTecnicoCondicionesGarantia a ns1:DocumentoTecnico ;
    rdfs:label "Condiciones generales de venta-Garantía" ;
    ns1:textoExtracto "Las condiciones de garantía del CNC están disponibles en la zona de descargas del sitio web corporativo de FAGOR. ( Tipo de fichero: Condiciones generales de venta-Garantía)." .

ns1:DocumentoTecnicoDeclaracionConformidad a ns1:DocumentoTecnico ;
    rdfs:label "Declaración de conformidad" ;
    ns1:textoExtracto "La declaración de conformidad del CNC está disponible en la zona de descargas del sitio web corporativo de FAGOR. ( Tipo de fichero: Declaración de conformidad)." .

