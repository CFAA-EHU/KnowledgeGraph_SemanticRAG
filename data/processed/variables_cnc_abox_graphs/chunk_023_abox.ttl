ns1:CNC8070_5499ba7680 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Ref. 1704 | Software V05.50.51 | Control del gap. El parámetro máquina GAPSENSORDELAY ya no es funcional." ;
    ns1:tieneComponente ns1:ControlDelGap_9a1cae3533,
        ns1:GapSensorDelay,
        ns1:Parametro_482bdbe6b3,
        ns1:RespuestaDinamicaDuranteLaParteFinalDelMovimientoDeAproximacionALaChapa,
        ns1:VariableAsociadaAlComandoTIMEDeLaSentenciaLEAP .

ns1:ControlDelGap_9a1cae3533 a ns1:Parametro ;
    rdfs:label "Control del gap" ;
    ns1:identificador "GAPSENSORDELAY" ;
    ns1:textoExtracto "El parámetro máquina GAPSENSORDELAY ya no es funcional." .

ns1:GapSensorDelay a ns1:Parametro ;
    rdfs:label "Gap Sensor Delay" ;
    ns1:identificador "MPG.GAPSENSORDELAY" ;
    ns1:textoExtracto "Variables: (V.)MPG.GAPSENSORDELAY" .

ns1:Parametro_482bdbe6b3 a ns1:Parametro ;
    rdfs:label "Marca de PLC para habilitar o deshabilitar el leapfrog activo" ;
    ns1:identificador "PLC.ENABLELEAP" ;
    ns1:textoExtracto "Variables: (V.)PLC.ENABLELEAP" .

ns1:RespuestaDinamicaDuranteLaParteFinalDelMovimientoDeAproximacionALaChapa a ns1:Parametro ;
    rdfs:label "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa" ;
    ns1:identificador "MPG.GAPAPPROACHDYN" ;
    ns1:textoExtracto "Variables: (V.)MPG.GAPAPPROACHDYN" .

ns1:VariableAsociadaAlComandoTIMEDeLaSentenciaLEAP a ns1:Parametro ;
    rdfs:label "Variable asociada al comando TIME de la sentencia #LEAP" ;
    ns1:identificador "G.LEAPTIME" ;
    ns1:textoExtracto "Variables: (V.)G.LEAPTIME" .

