@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableAsociadaAlCicloFijoActivo a ns1:Parametro ;
    rdfs:label "Variable asociada al ciclo fijo activo" ;
    ns1:identificador "G.ACTIVECYLE" ;
    ns1:textoExtracto "(V.)G.ACTIVECYLE" .

ns1:VariableAsociadaAlEspesorDeLaChapa a ns1:Parametro ;
    rdfs:label "Variable asociada al espesor de la chapa" ;
    ns1:identificador "TT.THICKNESS" ;
    ns1:textoExtracto "(V.)TT.THICKNESS" .

ns1:VariableAsociadaAlPLCENABLELEAP a ns1:Parametro ;
    rdfs:label "Variable asociada al PLC ENABLE LEAP" ;
    ns1:identificador "PLC.ENABLELEAP" ;
    ns1:textoExtracto "(V.)PLC.ENABLELEAP" .

