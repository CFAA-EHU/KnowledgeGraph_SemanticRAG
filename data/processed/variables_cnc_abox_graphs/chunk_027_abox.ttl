@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelCNCDuranteElProcesoDeEncendidoYApagado a ns1:Parametro ;
    rdfs:label "Estado del CNC durante el proceso de encendido y apagado" ;
    ns1:identificador "G.CNCDISSTAT" ;
    ns1:textoExtracto "Estado del CNC durante el proceso de encendido y apagado." .

ns1:EstadoDelCNCEnElRegistro a ns1:Parametro ;
    rdfs:label "Estado del CNC en el registro" ;
    ns1:identificador "E.CNCLOGST" ;
    ns1:textoExtracto "Variables: (V.)E.CNCLOGST" .

