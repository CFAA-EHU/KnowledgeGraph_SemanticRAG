@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_89a14d739d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de Seguridad" ;
    ns1:mitigaRiesgo ns1:CNC8070_57d4d72048,
        ns1:NoManipularElInteriorDelAparatoDuranteReparaciones,
        ns1:NoManipularElInteriorDelAparato_90fda0c0d6,
        ns1:NoManipularLosConectoresConElAparatoAlimentado ;
    ns1:textoExtracto "Leer las siguientes medidas de seguridad con objeto de evitar lesiones a personas y prevenir daños a este producto y a los productos conectados a él." .

ns1:CNC8070_57d4d72048 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "antes de la puesta en marcha, comprobar que la máquina donde se incorpora el CNC cumple lo especificado en la Directiva 2006/42/EC." .

ns1:NoManipularElInteriorDelAparatoDuranteReparaciones a ns1:AccionProhibida ;
    rdfs:label "No manipular el interior del aparato durante reparaciones" ;
    ns1:textoExtracto "En caso de mal funcionamiento o fallo del aparato, desconectarlo y llamar al servicio de asistencia técnica. No manipular el interior del aparato." .

ns1:NoManipularElInteriorDelAparato_90fda0c0d6 a ns1:AccionProhibida ;
    rdfs:label "No manipular el interior del aparato" ;
    ns1:textoExtracto "No manipular el interior del aparato. Sólo personal autorizado de Fagor Automation puede manipular el interior del aparato." .

ns1:NoManipularLosConectoresConElAparatoAlimentado a ns1:AccionProhibida ;
    rdfs:label "No manipular los conectores con el aparato alimentado" ;
    ns1:textoExtracto "No manipular los conectores (entradas/salidas, captación, etc) con el aparato conectado a la red eléctrica." .

