@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConectarLasBornasATierra a ns1:AvisoSeguridad ;
    rdfs:label "Conectar las bornas a tierra" ;
    ns1:textoExtracto "Con objeto de evitar descargas eléctricas, conectar las bornas." .

ns1:NoManipularElInteriorDelAparato a ns1:AvisoSeguridad ;
    rdfs:label "No manipular el interior del aparato" ;
    ns1:textoExtracto "Sólo personal autorizado de Fagor Automation puede manipular el interior del aparato. No manipular los conectores con el aparato conectado a la red eléctrica." .

ns1:UtilizarCableDeAlimentacionDeTresConductores a ns1:AvisoSeguridad ;
    rdfs:label "Utilizar cable de alimentación de tres conductores" ;
    ns1:textoExtracto "Para prevenir riesgos de choque eléctrico en la unidad central, utilizar el conector apropiado (el suministrado por Fagor); usar cable de alimentación de tres conductores (uno de ellos de tierra)." .

