@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarConexionATierra a ns1:AvisoSeguridad ;
    rdfs:label "Comprobar conexión a tierra" ;
    ns1:textoExtracto "antes de encender el aparato, que se ha efectuado la conexión de tierras." .

ns1:ConectarLasBornasDeTierra a ns1:AvisoSeguridad ;
    rdfs:label "Conectar las bornas de tierra" ;
    ns1:textoExtracto "conectar las bornas de tierra de todos los módulos al punto central de tierras." .

ns1:NoTrabajarEnAmbientesExplosivos a ns1:AvisoSeguridad ;
    rdfs:label "No trabajar en ambientes explosivos" ;
    ns1:textoExtracto "no trabajar en ambientes explosivos. Con objeto de evitar riesgos, lesiones o daños, no trabajar en ambientes explosivos." .

ns1:NoTrabajarEnAmbientesHumedos a ns1:AvisoSeguridad ;
    rdfs:label "No trabajar en ambientes húmedos" ;
    ns1:textoExtracto "No trabajar en ambientes húmedos. Para evitar descargas eléctricas, trabajar siempre en ambientes con humedad relativa dentro del rango 10%-90% sin condensación." .

