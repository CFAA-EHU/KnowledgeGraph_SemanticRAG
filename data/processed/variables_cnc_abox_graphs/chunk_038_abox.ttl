@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponentesESD a ns1:AvisoSeguridad ;
    rdfs:label "Componentes ESD" ;
    ns1:textoExtracto "Este símbolo identifica las tarjetas con componentes ESD (componentes sensibles a cargas electrostáticas)." .

ns1:SimboloDeDocumentacionAdicional a ns1:AvisoSeguridad ;
    rdfs:label "Símbolo de documentación adicional" ;
    ns1:textoExtracto "Este símbolo indica que hay otro documento con información más específica o detallada." .

ns1:SimboloDeInformacion a ns1:AvisoSeguridad ;
    rdfs:label "Símbolo de información" ;
    ns1:textoExtracto "i Este símbolo indica notas, avisos y consejos." .

ns1:SimboloDeObligacion a ns1:AvisoSeguridad ;
    rdfs:label "Símbolo de obligación" ;
    ns1:textoExtracto "Este símbolo indica acciones y operaciones que hay que realizar obligatoriamente." .

ns1:SimboloDeTierra a ns1:AvisoSeguridad ;
    rdfs:label "Símbolo de tierra" ;
    ns1:textoExtracto "Este símbolo indica que dicho punto puede estar bajo tensión eléctrica." .

