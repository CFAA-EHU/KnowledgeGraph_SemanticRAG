@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aparato a ns1:Componente ;
    rdfs:label "Aparato" ;
    ns1:textoExtracto "Adjunte una etiqueta al aparato indicando el dueño del aparato y la información de contacto..." .

ns1:AparatoCentralMonitor a ns1:Componente ;
    rdfs:label "Unidad central con monitor" ;
    ns1:textoExtracto "Si va a enviar una unidad central con monitor, proteja especialmente la pantalla." .

ns1:AvisoSeguridad_18d44b6a1f a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de reenvío del módulo" ;
    ns1:textoExtracto "Empaquete el módulo en su cartón original, con su material de empaque original. Si no dispone del material de empaque original, empaquételo de la siguiente manera..." .

ns1:CajaDeCarton a ns1:Componente ;
    rdfs:label "Caja de cartón" ;
    ns1:textoExtracto "1 Consiga una caja de cartón cuyas 3 dimensiones internas sean al menos 15 cm (6 pulgadas) mayores que las del aparato." .

ns1:CintaEmpacar a ns1:Componente ;
    rdfs:label "Cinta para empacar" ;
    ns1:textoExtracto "Selle la caja de cartón con cinta para empacar o grapas." .

ns1:EspumaPoliuretano a ns1:Consumible ;
    rdfs:label "Espuma de poliuretano" ;
    ns1:textoExtracto "Acolche el aparato en la caja de cartón rellenándola con espuma de poliuretano por todos lados." .

ns1:EtiquetaContacto a ns1:Componente ;
    rdfs:label "Etiqueta de contacto" ;
    ns1:textoExtracto "Adjunte una etiqueta al aparato indicando el dueño del aparato y la información de contacto (dirección, número de teléfono, email, nombre de la persona a contactar, tipo de aparato, número de serie, etc)." .

ns1:MaterialPolietileno a ns1:Componente ;
    rdfs:label "Rollo de polietileno" ;
    ns1:textoExtracto "Envuelva el aparato con un rollo de polietileno o con un material similar para protegerlo." .

