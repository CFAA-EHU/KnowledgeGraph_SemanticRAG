@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteMineral a ns1:Consumible ;
    rdfs:label "Aceite Mineral" ;
    ns1:textoExtracto "Los plásticos utilizados en la parte frontal de los aparatos son resistentes a grasas y aceites minerales, bases y lejías," .

ns1:Alcohol a ns1:Consumible ;
    rdfs:label "Alcohol" ;
    ns1:textoExtracto "Para la limpieza del panel de mando y del monitor se recomienda el empleo de una bayeta suave empapada con agua desionizada y/o detergentes lavavajillas caseros no abrasivos (líquidos, nunca en polvos), o bien con alcohol al 75%." .

ns1:BayetaSuave a ns1:Consumible ;
    rdfs:label "Bayeta Suave" ;
    ns1:textoExtracto "Para la limpieza del panel de mando y del monitor se recomienda el empleo de una bayeta suave empapada con agua desionizada y/o detergentes lavavajillas caseros no abrasivos (líquidos, nunca en polvos), o bien con alcohol al 75%." .

ns1:CNC8070_81655fa872 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:requiereMantenimiento ns1:LimpiezaDelCNC ;
    ns1:textoExtracto "La acumulación de suciedad en el aparato puede actuar como pantalla que impida la correcta disipación de calor generado por los circuitos electrónicos internos, con el consiguiente riesgo de sobrecalentamiento y avería del aparato." .

ns1:DetergenteLavavajillas a ns1:Consumible ;
    rdfs:label "Detergente Lavavajillas" ;
    ns1:textoExtracto "Para la limpieza del panel de mando y del monitor se recomienda el empleo de una bayeta suave empapada con agua desionizada y/o detergentes lavavajillas caseros no abrasivos (líquidos, nunca en polvos), o bien con alcohol al 75%." .

ns1:UsoDeAireComprimidoParaLimpieza a ns1:AccionProhibida ;
    rdfs:label "Uso de aire comprimido para limpieza" ;
    ns1:textoExtracto "No utilizar aire comprimido a altas presiones para la limpieza del aparato, pues ello puede ser causa de acumulación de cargas que a su vez den lugar a descargas electrostáticas." .

ns1:LimpiezaDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Limpieza del CNC" ;
    ns1:textoExtracto "La acumulación de suciedad en el aparato puede actuar como pantalla que impida la correcta disipación de calor generado por los circuitos electrónicos internos, con el consiguiente riesgo de sobrecalentamiento y avería del aparato." .

