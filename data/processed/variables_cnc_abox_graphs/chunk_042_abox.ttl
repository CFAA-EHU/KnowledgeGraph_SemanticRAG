@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_c4099ba3db a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre manipulación del interior" ;
    ns1:mitigaRiesgo ns1:CNC8070_cbbe0ecd07 ;
    ns1:textoExtracto "• No manipular el interior del aparato. Sólo personal autorizado de Fagor Automation puede manipular el interior del aparato." .

ns1:AvisoSeguridad_ef56505110 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre manipulación de conectores" ;
    ns1:mitigaRiesgo ns1:CNC8070_cbbe0ecd07 ;
    ns1:textoExtracto "• No manipular los conectores con el aparato alimentado. Antes de manipular los conectores (entradas/salidas, captación, etc) cerciorarse que el aparato no está alimentado." .

ns1:CNC8070_cbbe0ecd07 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Evitar la acción de disolventes como clorohidrocarburos, benzol, ésteres y éteres porque pueden dañar los plásticos con los que está realizado el frontal del aparato." .

