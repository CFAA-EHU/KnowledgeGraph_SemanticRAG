@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_eae3811798 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "A las variables internas del CNC se puede acceder desde el programa pieza, modo MDI/MDA, el PLC y una aplicación o interfaz externa." .

ns1:InterfazUsuarioFGUIM a ns1:InterfazUsuario ;
    rdfs:label "FGUIM" ;
    ns1:textoExtracto "una aplicación o interfaz externa (por ejemplo, FGUIM)." .

ns1:ModoMDI a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA" ;
    ns1:textoExtracto "modo MDI/MDA" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "el PLC y una aplicación o interfaz externa (por ejemplo, FGUIM)." .

ns1:VariablesDeEjecucion a ns1:Parametro ;
    rdfs:label "Variables de ejecución" ;
    ns1:textoExtracto "Las variables que utilizan el valor de ejecución detienen temporalmente la preparación de bloques, la cuál se reanuda cuando finaliza la lectura/escritura de la variable." .

