@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariablesDeLaHerramientaParaEscrituraAsincrona a ns1:Parametro ;
    rdfs:label "Variables de la herramienta para escritura asíncrona" ;
    ns1:textoExtracto "Serán de escritura asíncrona las variables de la herramienta, sea ésta la activa o no." .

ns1:VariablesDeLaHerramientaParaLecturaAsincrona a ns1:Parametro ;
    rdfs:label "Variables de la herramienta para lectura asíncrona" ;
    ns1:textoExtracto "Serán de lectura asíncrona las variables de la herramienta cuando ésta no sea la activa ni esté en el almacén." .

