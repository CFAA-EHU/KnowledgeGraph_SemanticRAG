@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_89302d1a86 a ns1:Parametro ;
    rdfs:label "Marca que indica inicio y fin de operación" ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "El PLC activa la marca M11 cuando comienza la operación y la mantiene activa hasta que finaliza la operación." .

ns1:RadioDelCorrectorDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Radio del corrector de la herramienta" ;
    ns1:identificador "TM.TORT.[9][1]" ;
    ns1:textoExtracto "Lectura del valor del radio del corrector ·1· de la herramienta ·9· cuando ésta no está en el almacén." .

ns1:ValorDeRespuestaDeConsulta a ns1:Parametro ;
    rdfs:label "Valor de respuesta de consulta" ;
    ns1:identificador "R11" ;
    ns1:textoExtracto "Esperar a que finalice la consulta para evaluar los datos." .

