@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceReal a ns1:Parametro ;
    rdfs:label "Avance real" ;
    ns1:identificador "G.FREAL" ;
    ns1:textoExtracto "Lectura del avance real. <condición> = CNCRD (G.FREAL, R12, M12)" .

ns1:CNC8070_64d4e5ba21 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Lectura del avance real. <condición> = CNCRD (G.FREAL, R12, M12)" .

ns1:Parametro_e3c996b893 a ns1:Parametro ;
    rdfs:label "Marca 12" ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "El PLC activa la marca M12 cuando comienza la operación y la mantiene activa hasta que finaliza la operación." .

ns1:Registro12 a ns1:Parametro ;
    rdfs:label "Registro 12" ;
    ns1:identificador "R12" ;
    ns1:textoExtracto "Lectura del avance real. <condición> = CNCRD (G.FREAL, R12, M12)" .

ns1:Registro13 a ns1:Parametro ;
    rdfs:label "Registro 13" ;
    ns1:identificador "R13" ;
    ns1:textoExtracto "Inicializa el reloj habilitado por el PLC con el valor que contiene el registro R13. <condición> = CNCWR (R13, PLC.TIMER, M13)" .

