@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaEnGrados a ns1:Parametro ;
    rdfs:label "Avance de eje en grados/minuto",
        "Avance de eje en milímetros/minuto",
        "Cota en grados",
        "Cota en milímetros",
        "Velocidad del cabezal" ;
    ns1:identificador "10000" ;
    ns1:textoExtracto "El avance de los ejes vendrá expresado en diezmilésimas si son milímetros o cienmilésimas si son pulgadas.",
        "La velocidad del cabezal vendrá expresada en diezmilésimas.",
        "Las cotas vendrán expresadas en diezmilésimas si son milímetros o cienmilésimas si son pulgadas." .

ns1:CotaEnPulgadas a ns1:Parametro ;
    rdfs:label "Avance de eje en pulgadas/minuto",
        "Cota en pulgadas" ;
    ns1:identificador "100000" ;
    ns1:textoExtracto "El avance de los ejes vendrá expresado en diezmilésimas si son milímetros o cienmilésimas si son pulgadas.",
        "Las cotas vendrán expresadas en diezmilésimas si son milímetros o cienmilésimas si son pulgadas." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Cuando el PLC accede a variables numéricas que pueden tener decimales, los valores vendrán expresados de la siguiente manera." .

