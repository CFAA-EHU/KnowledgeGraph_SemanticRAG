@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:UnidadesDe1GradoMinuto a ns1:Parametro ;
    rdfs:label "Unidades de 1 grado/minuto" ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "M19. 1 grado/minuto." ;
    ns1:valor "10000" .

ns1:UnidadesDe1PieMinuto a ns1:Parametro ;
    rdfs:label "Unidades de 1 metro/minuto",
        "Unidades de 1 pie/minuto" ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "G96. 1 metro/minuto.",
        "G96. 1 pie/minuto." ;
    ns1:valor "10000" .

ns1:UnidadesDe1Rpm a ns1:Parametro ;
    rdfs:label "Unidades de 1 rpm" ;
    ns1:identificador "G192" ;
    ns1:textoExtracto "G192. 1 rpm." ;
    ns1:valor "10000" .

ns1:UnidadesDe1Rpm_a44fc53185 a ns1:Parametro ;
    rdfs:label "Unidades de 1 rpm" ;
    ns1:identificador "G97" ;
    ns1:textoExtracto "G97. 1 rpm." ;
    ns1:valor "10000" .

ns1:ValorDeLaTensionEnMilivoltios a ns1:Parametro ;
    rdfs:label "Valor de la tensión en milivoltios" ;
    ns1:identificador "mV" ;
    ns1:textoExtracto "Las variables asociadas a la tabla de parámetros máquina devuelven el valor real (en milivoltios)." .

ns1:ValorDeLaTensionEnVoltios a ns1:Parametro ;
    rdfs:label "Valor de la tensión en voltios" ;
    ns1:identificador "V" ;
    ns1:textoExtracto "Para el resto de las variables (en voltios), la lectura vendrá expresada en diezmilésimas." .

ns1:ValorDelPorcentajeEnCentesimas a ns1:Parametro ;
    rdfs:label "Valor del porcentaje en centésimas" ;
    ns1:identificador "% (x100)" ;
    ns1:textoExtracto "Los porcentajes vendrán expresados con el valor real, en décimas o en centésimas dependiendo de la variable." ;
    ns1:valor "100" .

ns1:ValorDelPorcentajeEnDecimas a ns1:Parametro ;
    rdfs:label "Valor del porcentaje en décimas" ;
    ns1:identificador "% (x10)" ;
    ns1:textoExtracto "Los porcentajes vendrán expresados con el valor real, en décimas o en centésimas dependiendo de la variable." ;
    ns1:valor "10" .

ns1:ValorDelTiempoEnMilesimas a ns1:Parametro ;
    rdfs:label "Valor del tiempo en milésimas" ;
    ns1:identificador "segundo" ;
    ns1:textoExtracto "El tiempo vendrá expresado en milésimas." ;
    ns1:valor "1000" .

ns1:ValorRealDelPorcentaje a ns1:Parametro ;
    rdfs:label "Valor real del porcentaje" ;
    ns1:identificador "%" ;
    ns1:textoExtracto "Los porcentajes vendrán expresados con el valor real, en décimas o en centésimas dependiendo de la variable." ;
    ns1:valor "1" .

