@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LecturaDesdeElPLCPara1Voltio a ns1:Parametro ;
    rdfs:label "Lectura desde el PLC para 1 voltio" ;
    ns1:textoExtracto "10000." ;
    ns1:valor "10000" .

ns1:UnidadVoltio a ns1:Parametro ;
    rdfs:label "Unidad Voltio" ;
    ns1:identificador "voltio" ;
    ns1:textoExtracto "1 voltio." .

