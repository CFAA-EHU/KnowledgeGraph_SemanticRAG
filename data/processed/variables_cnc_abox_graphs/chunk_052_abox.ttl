@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioProgramacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de programación" ;
    ns1:textoExtracto "Para acceder a las variables desde el programa pieza o el modo MDI/MDA, el mnemónico comienza con el distintivo –V.–." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "En todos los mnemónicos de este manual, este distintivo aparece representado de la manera (V.), indicando así que sólo se debe programar cuando sea necesario." .

ns1:NumeroDeEjesDelCabezal a ns1:Parametro ;
    rdfs:label "Número de ejes del cabezal" ;
    ns1:identificador "MPG.NAXIS" ;
    ns1:textoExtracto "(V.)MPG.NAXIS | V.MPG.NAXIS | MPG.NAXIS" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Para acceder a las variables desde el PLC o una interfaz, se debe omitir el distintivo –V.–." .

