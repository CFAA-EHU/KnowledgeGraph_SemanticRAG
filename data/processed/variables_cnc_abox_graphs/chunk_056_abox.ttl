@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableQueIndicaElMovimientoDelEjeOCabezal a ns1:Parametro ;
    rdfs:label "Variable que indica el movimiento del eje o cabezal" ;
    ns1:textoExtracto "En variables con prefijo –A.– y –MPA.–, los ejes y cabezales se identifican mediante su nombre" .

