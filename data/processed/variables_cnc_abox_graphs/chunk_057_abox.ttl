@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Master" ;
    ns1:textoExtracto "Si en las variables con prefijo –SP.– no se selecciona un cabezal, la variable hace referencia al cabezal master." .

ns1:VariableQueIdentificaElCabezalMedianteSuNombreOIndiceDeCabezal a ns1:Parametro ;
    rdfs:label "Variable que identifica el cabezal mediante su nombre o índice de cabezal" ;
    ns1:textoExtracto "En variables con prefijo –SP.–, los cabezales se identifican mediante su nombre o índice de cabezal." .

ns1:VariableQueIdentificaElEjeOCabezalMedianteSuNombreONumeroLogico a ns1:Parametro ;
    rdfs:label "Variable que identifica el eje o cabezal mediante su nombre o número lógico" ;
    ns1:textoExtracto "En variables con prefijo –A.– y –MPA.–, los ejes y cabezales se identifican mediante su nombre o número lógico." .

