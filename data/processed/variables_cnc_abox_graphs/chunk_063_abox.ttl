@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionDelCanal a ns1:Parametro ;
    rdfs:label "Programación del canal" ;
    ns1:documentadoEn ns1:TablaProgramacionCanal ;
    ns1:identificador "MPG.NAXIS" ;
    ns1:textoExtracto "La programación del canal permite acceder, desde un canal, a las variables del propio canal o de cualquier otro." .

ns1:SistemaMulticanal a ns1:Sistema ;
    rdfs:label "Sistema multicanal" ;
    ns1:textoExtracto "Las variables en un sistema multicanal." .

ns1:TablaProgramacionCanal a ns1:Tabla ;
    ns1:ilustradoEn ns1:SistemaMulticanal ;
    ns1:textoExtracto "La programación del canal permite acceder, desde un canal, a las variables del propio canal o de cualquier otro. La siguiente tabla no se aplica a las variables de eje y cabezal." .

