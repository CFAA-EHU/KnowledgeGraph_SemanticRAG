@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PrefijosDeLasVariables a ns1:Parametro ;
    rdfs:label "Prefijos de las variables" ;
    ns1:textoExtracto "Los prefijos de las variables. La programación del prefijo es obligatoria." .

ns1:SistemaMulticanalInterfazExterna a ns1:Sistema ;
    rdfs:label "Sistema Multicanal Interfaz Externa" ;
    ns1:textoExtracto "Interfaz externa. Canal activo." .

