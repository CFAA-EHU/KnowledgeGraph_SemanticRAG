@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMulticanal a ns1:Sistema ;
    rdfs:label "Sistema multicanal" ;
    ns1:textoExtracto "Variables de eje y cabezal. Las variables de eje y cabezal se identifican con el prefijo –A.–." ;
    ns1:tieneComponente ns1:VariablesDeEjeYCabezal,
        ns1:VariablesDeParametrosMaquinaDeLosEjes .

ns1:VariablesDeEjeYCabezal a ns1:Parametro ;
    rdfs:label "Variables de eje y cabezal" ;
    ns1:textoExtracto "Las variables de eje y cabezal se identifican con el prefijo –A.–." .

ns1:VariablesDeParametrosMaquinaDeLosEjes a ns1:Parametro ;
    rdfs:label "Variables de parámetros máquina de los ejes" ;
    ns1:textoExtracto "Las variables de los parámetros máquina de los ejes (prefijo –MPA.–)" .

