@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableQueIdentificaElCabezalMedianteSuNombreIndiceEnElCanalOIndiceDeCabezal a ns1:Parametro ;
    rdfs:label "Variable que identifica el cabezal mediante su nombre, índice en el canal o índice de cabezal" ;
    ns1:identificador "SP.variable" ;
    ns1:textoExtracto "En variables con prefijo –SP.–, los cabezales se identifican mediante su nombre, índice en el canal o índice de cabezal." .

ns1:VariableQueIdentificaElEjeOCabezalMedianteSuNombreNumeroLogicoOIndiceEnElCanal a ns1:Parametro ;
    rdfs:label "Variable que identifica el eje o cabezal mediante su nombre, número lógico o índice en el canal" ;
    ns1:identificador "MPA.VMOVAXIS1" ;
    ns1:textoExtracto "En variables con prefijo –A.– y –MPA.–, los ejes y cabezales se identifican mediante su nombre, número lógico o índice en el canal." .

