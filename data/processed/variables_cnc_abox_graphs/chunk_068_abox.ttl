@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Master" ;
    ns1:textoExtracto "la variable hace referencia al cabezal master." .

ns1:VariableSinCabezalSeleccionadoHaceReferenciaAlCabezalMaster a ns1:Parametro ;
    rdfs:label "Variable sin cabezal seleccionado hace referencia al cabezal master" ;
    ns1:identificador "SP.VariableMaster" ;
    ns1:textoExtracto "Si en las variables con prefijo –SP.– no se selecciona un cabezal, la variable hace referencia al cabezal master." .

