@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMulticanal a ns1:Sistema ;
    rdfs:label "Sistema multicanal" ;
    ns1:textoExtracto "Al referirnos al eje o cabezal por su nombre, la programación del canal donde se encuentren no es un factor determinante; por lo tanto, su programación en este caso es irrelevante." ;
    ns1:tieneComponente ns1:CabezalLogico6_dff69e61b1,
        ns1:EjeLogico1_96a7b05f47 .

ns1:TablaDeParametrosMaquinaParaCabezales a ns1:Parametro ;
    rdfs:label "Tabla de parámetros máquina para cabezales" ;
    ns1:textoExtracto "El número lógico de los cabezales viene establecido por el orden en el que han sido definidos en la tabla de parámetros máquina (NAXIS + SPDLNAME)." .

ns1:TablaDeParametrosMaquinaParaEjes a ns1:Parametro ;
    rdfs:label "Tabla de parámetros máquina para ejes" ;
    ns1:textoExtracto "El número lógico de los ejes viene establecido por el orden en el que han sido definidos en la tabla de parámetros máquina (AXISNAME)." .

ns1:CabezalLogico6_dff69e61b1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Lógico 6" ;
    ns1:textoExtracto "en un sistema con 5 ejes, el primer cabezal de la tabla será el cabezal lógico ·6· y así sucesivamente." .

ns1:EjeLogico1_96a7b05f47 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Lógico 1" ;
    ns1:textoExtracto "El primer eje de la tabla será el eje lógico ·1· y así sucesivamente." .

