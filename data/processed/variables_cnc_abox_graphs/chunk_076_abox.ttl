@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaVelocidadDelCabezalMasterIndice1 a ns1:Parametro ;
    rdfs:label "Nombre de la velocidad del cabezal master (índice 1)" ;
    ns1:documentadoEn ns1:SistemaMulticanal ;
    ns1:identificador "CHSPDLNAME1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | Índice 1." .

ns1:NombreDeLaVelocidadDelCabezalMasterIndice2 a ns1:Parametro ;
    rdfs:label "Nombre de la velocidad del cabezal master (índice 2)" ;
    ns1:documentadoEn ns1:SistemaMulticanal ;
    ns1:identificador "CHSPDLNAME2" ;
    ns1:textoExtracto "CHSPDLNAME 2 | Índice 2." .

ns1:NombreDelEjeDelCabezalMaster a ns1:Parametro ;
    rdfs:label "Nombre del eje del cabezal master" ;
    ns1:documentadoEn ns1:SistemaMulticanal ;
    ns1:identificador "CHAXISNAME3" ;
    ns1:textoExtracto "CHAXISNAME 3 | Índice 3." .

ns1:SistemaMulticanal a ns1:Sistema ;
    rdfs:label "Sistema Multicabezal" ;
    ns1:textoExtracto "En un sistema multicabezal, se denomina cabezal master al cabezal principal del canal..." .

