@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMulticanalVariables a ns1:Sistema ;
    rdfs:label "Sistema multicanal variables" ;
    ns1:textoExtracto "Lugar de ejecución. Significado cuando no hay canal programado." ;
    ns1:tieneComponente ns1:VariableEjecucionInterfazExterna,
        ns1:VariableEjecucionPLC,
        ns1:VariableEjecucionProgramaPieza .

ns1:VariableEjecucionInterfazExterna a ns1:Parametro ;
    rdfs:label "Variable en interfaz externa" ;
    ns1:identificador "InterfazExterna" ;
    ns1:textoExtracto "Lugar de ejecución: Interfaz externa." .

ns1:VariableEjecucionPLC a ns1:Parametro ;
    rdfs:label "Variable en modo PLC" ;
    ns1:identificador "PLC" ;
    ns1:textoExtracto "Lugar de ejecución: PLC" .

ns1:VariableEjecucionProgramaPieza a ns1:Parametro ;
    rdfs:label "Variable en modo Programa pieza / MDI/MDA" ;
    ns1:identificador "ProgramaPiezaMDIMDA" ;
    ns1:textoExtracto "Lugar de ejecución: Programa pieza. Modo MDI/MDA." .

