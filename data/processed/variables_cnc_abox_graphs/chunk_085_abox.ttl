ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Pareja tándem [nb]. Tiempo del filtro para aplicar la precarga. Este filtro establece el tiempo durante el cual se aplica la precarga de forma progresiva." ;
    ns1:tieneComponente ns1:SegundaParejaTandem_9c64fa948a,
        ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_82984a1372 .

ns1:SegundaParejaTandem_9c64fa948a a ns1:Parametro ;
    rdfs:label "Segunda pareja tándem" ;
    ns1:identificador "MPG.PRELOAD[2]" ;
    ns1:textoExtracto "V.MPG.PRELOAD[2] Segunda pareja tándem." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_82984a1372 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.PRELFITI[nb]" ;
    ns1:textoExtracto "V.)MPG.PRELFITI[nb] Variable de lectura desde el programa, PLC e interfaz." .

