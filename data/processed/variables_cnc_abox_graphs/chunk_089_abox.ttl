@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeLaParejaTandem a ns1:Parametro ;
    rdfs:label "Número de la pareja tándem."@es ;
    ns1:identificador "nb" ;
    ns1:textoExtracto "Pareja tándem [nb]. Modo de control de par. Sintaxis. · nb· Número de la pareja tándem." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazModoDeControlDePar a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Modo de control de par."@es ;
    ns1:identificador "MPG.TORQMODE[nb]" ;
    ns1:textoExtracto "V.)MPG.TORQMODE[nb] Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno del osciloscopio y de puesta a punto.." .

