@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioConfiguracionMultieje a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para configuración de un grupo multieje" ;
    ns1:ilustra ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_548d8dd8de ;
    ns1:textoExtracto "\"Valores de la variable. Los valores que devuelve esta variable están codificados de la siguiente forma.\"" .

ns1:ValorX1 a ns1:Parametro ;
    rdfs:label "Valor X1" ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "\"X1=11\"" ;
    ns1:valor "11" .

ns1:ValorY4 a ns1:Parametro ;
    rdfs:label "Valor Y4" ;
    ns1:identificador "Y4" ;
    ns1:textoExtracto "\"Y4=24\"" ;
    ns1:valor "24" .

ns1:ValorZ9 a ns1:Parametro ;
    rdfs:label "Valor Z9" ;
    ns1:identificador "Z9" ;
    ns1:textoExtracto "\"Z9=39\"" ;
    ns1:valor "39" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_548d8dd8de a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.KEEPPOSxn" ;
    ns1:textoExtracto "\"(V.)MPG.KEEPPOSxn[nb] Variable de lectura desde el programa, PLC e interfaz.\"" .

