@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d268ce6871 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Número de cabezales que gobierna el CNC." ;
    ns1:tieneComponente ns1:TablaParametrosMaquina .

ns1:CabezalConNumeroLogico2 a ns1:Parametro ;
    rdfs:label "Cabezal con número lógico 2" ;
    ns1:identificador "MPG.SPDLNAME2" ;
    ns1:textoExtracto "Nombre del cabezal lógico n. Sustituir el carácter n por el número lógico del cabezal." .

ns1:NombreDelCabezalLogicoN a ns1:Parametro ;
    rdfs:label "Nombre del cabezal lógico n" ;
    ns1:identificador "MPG.SPDLNAMEn" ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Nombre del cabezal lógico n." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_20707dde59 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.NSPDL" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Número de cabezales que gobierna el CNC." .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 5 ejes, el primer cabezal de la tabla será el cabezal lógico ·6· y así sucesivamente." .

