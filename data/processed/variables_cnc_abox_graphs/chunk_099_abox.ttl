@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PeriodicidadDelModuloPRGDelPLCEnCiclos a ns1:Parametro ;
    rdfs:label "Periodicidad del módulo PRG del PLC (en ciclos)" ;
    ns1:identificador "MPG.PRGFREQ" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Periodicidad del módulo PRG del PLC (en ciclos)." .

ns1:TiempoDeCicloDelCNCEnMilisegundos a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo del CNC (en milisegundos)" ;
    ns1:identificador "MPG.LOOPTIME" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Tiempo de ciclo del CNC (en milisegundos)." .

