@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7ab0e937f6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC. V.G.NCTIMERATE Esta variable sirve para evaluar la carga del sistema y el tiempo que la interrupción periódica que controla el movimiento de los ejes deja al sistema operativo para gestionar otras aplicaciones que puedan ejecutarse en paralelo al CNC." .

ns1:Parametro_c5c0e9a422 a ns1:Parametro ;
    rdfs:label "Parámetro PREPFREQ" ;
    ns1:identificador "PREPFREQ" ;
    ns1:textoExtracto "Si el tiempo libre para las aplicaciones es insuficiente, se puede optar por disminuir el parámetro PREPFREQ." .

ns1:Parametro_e71834e406 a ns1:Parametro ;
    rdfs:label "Parámetro LOOPTIME" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Si el tiempo libre para las aplicaciones es insuficiente, se puede optar por aumentar el parámetro LOOPTIME." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_61c560c12e a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.NCTIMERATE" ;
    ns1:textoExtracto "V.G.NCTIMERATE Esta variable sirve para evaluar la carga del sistema y el tiempo que la interrupción periódica que controla el movimiento de los ejes deja al sistema operativo para gestionar otras aplicaciones que puedan ejecutarse en paralelo al CNC." .

