@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDelPrograma a ns1:Parametro ;
    rdfs:label "Frecuencia del programa" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "se puede optar por aumentar el parámetro PRGFREQ o LOOPTIME." .

ns1:TiempoDeBucle a ns1:Parametro ;
    rdfs:label "Tiempo de bucle" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "se puede optar por aumentar el parámetro PRGFREQ o LOOPTIME." .

ns1:TiempoDeCicloQueUtilizaElPLC a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo que utiliza el PLC" ;
    ns1:identificador "V.G.PLCTIMERATE" ;
    ns1:textoExtracto "de tiempo de ciclo que utiliza el PLC. V.G.PLCTIMERATE" .

