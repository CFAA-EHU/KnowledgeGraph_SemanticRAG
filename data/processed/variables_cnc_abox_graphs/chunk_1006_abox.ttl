@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeEstadoDeLaEntradaDeContajeParaCabezales a ns1:Parametro ;
    rdfs:label "Variable de estado de la entrada de contaje para cabezales" ;
    ns1:identificador "SP.COUNTERST.sn" ;
    ns1:textoExtracto "Estado de la entrada de contaje. Para que una entrada de contaje esté activa, debe tener asociada un eje analógico." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaCabezales_f506c58349 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para cabezales" ;
    ns1:identificador "V.ch.A.COUNTERST.sn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEjesRotativosLinealesYCabezales_3c393cb93d a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para ejes rotativos, lineales y cabezales" ;
    ns1:identificador "V.ch.A.COUNTERST.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

