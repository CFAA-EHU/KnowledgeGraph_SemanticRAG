@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PotenciaOpticaDeSercos a ns1:Parametro ;
    rdfs:label "Potencia óptica de Sercos" ;
    ns1:identificador "MPG.SERPOWSE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Potencia óptica de Sercos." .

ns1:VelocidadDeTransmisionDeSercos a ns1:Parametro ;
    rdfs:label "Velocidad de transmisión de Sercos" ;
    ns1:identificador "MPG.SERBRATE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Velocidad de transmisión de Sercos." .

