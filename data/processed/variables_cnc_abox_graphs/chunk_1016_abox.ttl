@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElInterfazDeEscrituraDesdeElProgramaYPLC a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz; de escritura desde el programa y PLC" ;
    ns1:identificador "G.ANAO[n]" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Tensión en voltios de la salida [n]." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_511b47db5b a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.ANAI[n]" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100." .

