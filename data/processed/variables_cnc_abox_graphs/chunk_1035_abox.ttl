@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaTeoricaALaEntradaDelLazoDePosicion a ns1:Parametro ;
    rdfs:label "Cota teórica a la entrada del lazo de posición" ;
    ns1:textoExtracto "Cota teórica a la entrada del lazo de posición." .

ns1:VariableEje a ns1:Parametro ;
    rdfs:label "Variable válida para ejes rotativos, lineales y cabezales" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

