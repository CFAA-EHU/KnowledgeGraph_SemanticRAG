@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaConfiguracionCAN a ns1:Tabla ;
    rdfs:label "Tabla Configuración del bus CAN" ;
    ns1:ilustra ns1:FrecuenciaDeComunicacionDelBusCANopen ;
    ns1:textoExtracto "Valor. Significado. Valor. Significado. 0 Hasta 20 metros. 7 Hasta 90 metros. 1 Hasta 30 metros. 8 Hasta 100 metros. 2 Hasta 40 metros. 9 Hasta 110 metros. 3 Hasta 50 metros. 10 Hasta 120 metros. 4 Hasta 60 metros. 11 Hasta 130 metros. 5 Hasta 70 metros. 12 Más de 130 metros. 6 Hasta 80 metros." .

ns1:FrecuenciaDeComunicacionDelBusCANopen a ns1:Parametro ;
    rdfs:label "Frecuencia de comunicación del bus CANopen" ;
    ns1:identificador "MPG.CANOPENFREQ" ;
    ns1:textoExtracto "V.MPG.CANOPENFREQ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

