    ns1:identificador "SP.PREVPOSINC.2" ;
    ns1:textoExtracto "V.SP.PREVPOSINC.2 | Cabezal con índice ·2· en el sistema." .

ns1:IncrementoDePosicionPreviaParaElCabezalMasterSP a ns1:Parametro ;
