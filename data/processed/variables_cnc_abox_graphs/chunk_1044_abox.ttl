@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IncrementoDePosicionPreviaParaElCabezalConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Incremento de posición previa para el cabezal con índice 1 en el canal 2" ;
    ns1:identificador "[2].SP.PREVPOSINC.1" ;
    ns1:textoExtracto "V.[2].SP.PREVPOSINC.1 | Cabezal con índice ·1· en el canal ·2·." .

ns1:IncrementoDePosicionPreviaParaElCabezalConIndice2EnElSistema a ns1:Parametro ;
