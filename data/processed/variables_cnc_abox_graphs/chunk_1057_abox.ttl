@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElPLCDevuelveElValorDeEjecucion a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el PLC; devuelve el valor de ejecución" ;
    ns1:identificador "SP.PLCFFGAIN.sn" ;
    ns1:textoExtracto "\"(V.)[ch].SP.PLCFFGAIN.sn\" Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfa_b44340ad94 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz para ejes rotativos, lineales" ;
    ns1:identificador "A.PLCFFGAIN.xn" ;
    ns1:textoExtracto "\"(V.)[ch].A.PLCFFGAIN.xn\" Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz. Variable válida para ejes rotativos, lineales y cabezales." .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfa_b8afd798b5 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz para cabezales" ;
    ns1:identificador "A.PLCFFGAIN.sn" ;
    ns1:textoExtracto "\"(V.)[ch].A.PLCFFGAIN.sn\" Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz. Variable válida para ejes rotativos, lineales y cabezales." .

