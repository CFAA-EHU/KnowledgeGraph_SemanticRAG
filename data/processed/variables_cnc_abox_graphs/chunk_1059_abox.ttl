@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperativoSercos a ns1:Parametro ;
    rdfs:label "Modo operativo Sercos" ;
    ns1:textoExtracto "parámetro OPMODEP si Sercos" .

ns1:TipoDeReguladorParaFeedForward a ns1:Parametro ;
    rdfs:label "Tipo de regulador para feed-forward" ;
    ns1:textoExtracto "mediante el parámetro máquina FFWTYPE si regulador analógico o simulado" .

ns1:VariablePLCACFGAINsn a ns1:Parametro ;
    rdfs:label "Ganancia de control AC desde PLC para eje S" ;
    ns1:identificador "A.PLCACFGAIN.sn" ;
    ns1:textoExtracto "(V.)[ch].A.PLCACFGAIN.sn Variable de lectura y escritura desde el PLC" .

ns1:VariablePLCACFGAINxn a ns1:Parametro ;
    rdfs:label "Ganancia de control AC desde PLC para eje X" ;
    ns1:identificador "A.PLCACFGAIN.xn" ;
    ns1:textoExtracto "(V.)[ch].A.PLCACFGAIN.xn Variable de lectura y escritura desde el PLC" .

ns1:VariableSPPLCACFGAINsn a ns1:Parametro ;
    rdfs:label "Ganancia de control AC desde PLC para eje S (programa)" ;
    ns1:identificador "SP.PLCACFGAIN.sn" ;
    ns1:textoExtracto "(V.)[ch].SP.PLCACFGAIN.sn Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" .

