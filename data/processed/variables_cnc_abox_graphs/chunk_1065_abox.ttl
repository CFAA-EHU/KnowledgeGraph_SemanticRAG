@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GananciaProporcionalProgramadaDesdeElPLC a ns1:Parametro ;
    rdfs:label "Ganancia proporcional programada desde el PLC" ;
    ns1:textoExtracto "Ganancia proporcional programada desde el PLC." .

ns1:VariableEjecucion a ns1:Parametro ;
    rdfs:label "variable de ejecución" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

