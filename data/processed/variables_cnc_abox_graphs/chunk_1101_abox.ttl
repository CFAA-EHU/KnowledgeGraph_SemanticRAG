ns1:ObservacionTruncamiento a ns1:AvisoSeguridad ;
    rdfs:label "En la lectura por PLC se trunca la parte decimal" ;
    ns1:textoExtracto "En la lectura por PLC de esta variable se trunca la parte decimal. Si el parámetro tiene el valor 54.9876, la lectura desde el PLC devolverá el valor 54." .

