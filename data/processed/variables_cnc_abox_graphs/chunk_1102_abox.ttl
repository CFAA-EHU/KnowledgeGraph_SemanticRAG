@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDelParametroAritmeticoLocal14 a ns1:Parametro ;
    rdfs:label "Valor del parámetro aritmético local 14" ;
    ns1:identificador "P14" ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "P14 = 23.1234" .

ns1:ValorDelParametroAritmeticoLocal22 a ns1:Parametro ;
    rdfs:label "Valor del parámetro aritmético local 22" ;
    ns1:identificador "P22" ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "P22 =-12.0987" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Lectura desde el PLC." .

