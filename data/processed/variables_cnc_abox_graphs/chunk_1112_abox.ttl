@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DutyDePreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Duty de preparación de bloques" ;
    ns1:identificador "V.TTPIR.DUTY" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Hercios. Frecuencia. V.TTPIR.FREQUENCY (V.)TTPIR.DUTY Variable de lectura desde" .

ns1:FrecuenciaDePreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Frecuencia de preparación de bloques" ;
    ns1:identificador "V.TTPIR.FREQUENCY" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Hercios. Frecuencia. V.TTPIR.FREQUENCY (V.)TTPIR.DUTY Variable de lectura desde" .

