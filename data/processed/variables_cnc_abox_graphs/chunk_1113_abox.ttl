@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloDeTrabajoDuty a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo (duty)" ;
    ns1:identificador "V.TTPIR.DUTY" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Porcentaje." .

ns1:DuracionDelPiercing a ns1:Parametro ;
    rdfs:label "Duración del piercing" ;
    ns1:identificador "V.TTPIR.PIERCINGTIME" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Milisegundos." .

ns1:Parametro_17aa812d16 a ns1:Parametro ;
    rdfs:label "Frecuencia" ;
    ns1:identificador "V.TTPIR.FREQUENCY" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Hercios." .

ns1:PresionDelGas a ns1:Parametro ;
    rdfs:label "Presión del gas" ;
    ns1:identificador "V.TTPIR.GASPRESSURE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Bar o psi." .

ns1:TipoDeGas a ns1:Parametro ;
    rdfs:label "Tipo de gas" ;
    ns1:identificador "V.TTPIR.GASTYPE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Valor enumerado." .

