@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeTrabajo a ns1:Parametro ;
    rdfs:label "Avance de trabajo" ;
    ns1:identificador "TTPIR.FEEDRATE" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros/minuto o pulgadas/minuto." .

ns1:DiametroDeLaBoquilla a ns1:Parametro ;
    rdfs:label "Diámetro de la boquilla" ;
    ns1:identificador "TTPIR.NOZZLEDIAM" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros o pulgadas." .

ns1:RadioDelLaser_f279a93bac a ns1:Parametro ;
    rdfs:label "Radio del láser" ;
    ns1:identificador "TTPIR.CUTRADIUS" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros o pulgadas." .

ns1:TiempoDeEsperaDespuesDeActivarElGas a ns1:Parametro ;
    rdfs:label "Tiempo de espera después de activar el gas" ;
    ns1:identificador "TTPIR.GASTIME" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milisegundos." .

