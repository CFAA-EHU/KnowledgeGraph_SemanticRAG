ns1:CicloDeTrabajo a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo" ;
    ns1:identificador "V.TTCUT.DUTY" ;
    ns1:textoExtracto "Unidades: Porcentaje. Ciclo de trabajo (duty). V.TTCUT.DUTY (V.)TTCUT.PWROVRMIN Variable de lectura desde el programa, PLC e interfaz." .

ns1:Parametro_9ce67ce809 a ns1:Parametro ;
    rdfs:label "Frecuencia" ;
    ns1:identificador "V.TTCUT.FREQUENCY" ;
    ns1:textoExtracto "Unidades: Hercios. Frecuencia. V.TTCUT.FREQUENCY (V.)TTCUT.DUTY Variable de lectura desde el programa, PLC e interfaz." .

ns1:PorcentajeMaximoDePotenciaParaElControlDePotencia_0ef5a5f3a3 a ns1:Parametro ;
    rdfs:label "Porcentaje máximo de potencia para el control de potencia" ;
    ns1:identificador "V.TTCUT.PWROVRMAX" ;
    ns1:textoExtracto "Unidades: Porcentaje. Porcentaje máximo de potencia para el control de potencia. Porcentaje de potencia para un avance mayor o igual que el máximo (PWRFMAX)." .

ns1:PorcentajeMinimoDePotenciaParaElControlDePotencia a ns1:Parametro ;
    rdfs:label "Porcentaje mínimo de potencia para el control de potencia" ;
    ns1:identificador "V.TTCUT.PWROVRMIN" ;
    ns1:textoExtracto "Unidades: Porcentaje. Porcentaje mínimo de potencia para el control de potencia. Porcentaje de potencia para un avance menor o igual que el mínimo (PWRFMIN)." .

