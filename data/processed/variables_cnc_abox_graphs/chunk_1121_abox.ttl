@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeMaximoDePotenciaParaElControlDePotencia a ns1:Parametro ;
    rdfs:label "Porcentaje máximo de potencia para el control de potencia" ;
    ns1:identificador "V.TTCUT.PWOVRMAX" ;
    ns1:textoExtracto "Porcentaje máximo de potencia para el control de potencia. Porcentaje de potencia para un avance mayor o igual que el máximo (PWRFMAX). V.TTCUT.PWOVRMAX" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_2b9bd973a2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.TTCUT.PWRFMIN" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. V.TTCUT.PWRFMIN Variable de lectura desde el programa, PLC e interfaz." .

