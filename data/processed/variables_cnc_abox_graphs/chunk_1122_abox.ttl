@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceMaximoParaElControlDePotencia a ns1:Parametro ;
    rdfs:label "Avance máximo para el control de potencia" ;
    ns1:identificador "TTCUT.PWRFMAX" ;
    ns1:textoExtracto "V.TTCUT.PWRFMAX (V.)TTCUT.GASPRESSURE Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros/minuto o pulgadas/minuto. Avance máximo para el control de potencia." .

ns1:AvanceMinimoParaElControlDePotencia a ns1:Parametro ;
    rdfs:label "Avance mínimo para el control de potencia" ;
    ns1:identificador "TTCUT.PWRFMIN" ;
    ns1:textoExtracto "V.TTCUT.PWRFMIN (V.)TTCUT.PWRFMAX Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros/minuto o pulgadas/minuto. Avance mínimo para el control de potencia." .

ns1:PresionDelGas_72a33539b0 a ns1:Parametro ;
    rdfs:label "Presión del gas" ;
    ns1:identificador "TTCUT.GASPRESSURE" ;
    ns1:textoExtracto "V.TTCUT.PWRFMAX (V.)TTCUT.GASPRESSURE Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Bar o psi." .

