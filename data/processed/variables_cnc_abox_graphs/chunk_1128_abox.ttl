@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionDelFocoDelLaser a ns1:Parametro ;
    rdfs:label "Posición del foco del láser" ;
    ns1:identificador "V.TTCUT.FOCALPOS" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros o pulgadas. Posición del foco del láser, respecto la superficie de la chapa." .

