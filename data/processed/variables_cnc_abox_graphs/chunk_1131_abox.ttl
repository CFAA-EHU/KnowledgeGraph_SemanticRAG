@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_645530e45b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El valor leído por programa será la cota programada mientras que el valor leído desde el PLC o interfaz será la cota real teniendo en cuenta la compensación de radio y el redondeo de la arista matada." ;
    ns1:tieneComponente ns1:InterfazDelSistemaCNC .

ns1:PosicionProgramadaEnElEjeX a ns1:Parametro ;
    rdfs:label "Posición programada en el eje X" ;
    ns1:identificador "V.A.PPOS.X" ;
    ns1:textoExtracto "G1 X10 | V.A.PPOS.X = 10" .

ns1:PosicionProgramadaEnElEjeY a ns1:Parametro ;
    rdfs:label "Posición programada en el eje Y" ;
    ns1:identificador "V.A.PPOS.Y" ;
    ns1:textoExtracto """G73 Q90
G1 X10 | Giro del sistema de coordenadas. V.A.PPOS.Y = 20""" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_6f74f03efa a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.)[ch].G.PLPPOS1" ;
    ns1:textoExtracto "( V.)[ch].G.PLPPOS1 Variable de lectura desde el programa, PLC e interfaz." .

ns1:InterfazDelSistemaCNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del sistema CNC" ;
    ns1:textoExtracto "El valor leído desde el PLC o interfaz será la cota real teniendo en cuenta la compensación de radio y el redondeo de la arista matada." .

