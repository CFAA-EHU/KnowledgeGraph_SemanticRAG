@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazCanal1 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Canal 1." ;
    ns1:identificador "V.PLPPOS1" ;
    ns1:textoExtracto "(V.)[ch].G.PLPPOS1 Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cota programada en el segundo eje del canal (punta de la herramienta). Sintaxis. · ch· Número de canal." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazCanal2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Canal 2." ;
    ns1:identificador "V.PLPPOS2" ;
    ns1:textoExtracto "(V.)[ch].G.PLPPOS2 Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cota programada en el segundo eje del canal (punta de la herramienta). Sintaxis. · ch· Número de canal." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazCanal3 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Canal 3." ;
    ns1:identificador "V.PLPPOS3" ;
    ns1:textoExtracto "(V.)[ch].G.PLPPOS3 Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cota programada en el tercer eje del canal (punta de la herramienta). Sintaxis. · ch· Número de canal." .

