@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_327d475b5f a ns1:Parametro ;
    rdfs:label "Parámetro que indica si el CNC lee la posición real desde la captación interna o externa" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Si no hay mezcla de captaciones, el CNC lee la posición real desde la captación interna o externa (parámetro FBACKSRC)." .

ns1:Parametro_ffbf27a619 a ns1:Parametro ;
    rdfs:label "Parámetro que indica si está activa la mezcla de captaciones" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "Si la mezcla de captaciones está activa (parámetro FBMIXTIME), el CNC calcula el error de seguimiento utilizando la mezcla de captaciones." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_64853fa8a2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "FLWE" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableLecturaEje a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para ejes rotativos y lineales" ;
    ns1:identificador "A.FLWE.xn" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

