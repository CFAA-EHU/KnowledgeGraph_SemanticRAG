ns1:CotaReal_8576fd0d14 a ns1:Parametro ;
    rdfs:label "cota real" ;
    ns1:textoExtracto "y cota real a la que en realidad está ocupando" .

ns1:CotaTeorica_36c3f0ec8e a ns1:Parametro ;
    rdfs:label "cota teórica" ;
    ns1:textoExtracto "Se denomina cota teórica a la posición que debe ocupar el cabezal en cada momento," .

ns1:ErrorDeSeguimiento_dfe51b5d13 a ns1:Parametro ;
    rdfs:label "error de seguimiento" ;
    ns1:textoExtracto "a la diferencia entre ambas se denomina error de seguimiento." .

