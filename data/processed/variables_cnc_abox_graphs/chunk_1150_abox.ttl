@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionProgramadaDelCabezalConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Posición programada del cabezal con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].SP.PPOS.1" ;
    ns1:textoExtracto "V.[2].SP.PPOS.1 | Cabezal con índice ·1· en el canal ·2·." .

ns1:PosicionProgramadaDelCabezalConIndice2EnElSistema a ns1:Parametro ;
    rdfs:label "Posición programada del cabezal con índice 2 en el sistema" ;
    ns1:identificador "V.SP.PPOS.2" ;
    ns1:textoExtracto "V.SP.PPOS.2 | Cabezal con índice ·2· en el sistema." .

ns1:PosicionProgramadaDelCabezalConNumeroLogico5 a ns1:Parametro ;
    rdfs:label "Posición programada del cabezal con número lógico 5" ;
    ns1:identificador "V.A.PPOS.5" ;
    ns1:textoExtracto "V.A.PPOS.5 | Cabezal con número lógico ·5·." .

ns1:PosicionProgramadaDelCabezalMaster a ns1:Parametro ;
    rdfs:label "Posición programada del cabezal master" ;
    ns1:identificador "V.SP.PPOS" ;
    ns1:textoExtracto "V.SP.PPOS | Cabezal master." .

