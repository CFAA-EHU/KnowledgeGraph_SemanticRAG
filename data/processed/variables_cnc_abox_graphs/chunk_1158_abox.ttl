@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_6305b9aca8 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de detección de problemas de ajuste" ;
    ns1:solucionaFallo ns1:ProblemaDeAjusteDetectado ;
    ns1:textoExtracto "Comparando en el osciloscopio el avance real con el teórico a lo largo de la trayectoria se pueden detectar problemas de ajuste si ambos divergen en puntos concretos." .

ns1:VGFREAL a ns1:Parametro ;
    rdfs:label "Canal ·2·. Avance activo en el canal" ;
    ns1:documentadoEn ns1:SistemaHidraulico ;
    ns1:identificador "V.G.FREAL" ;
    ns1:textoExtracto "Esta variable tiene en cuenta el override y las aceleraciones y deceleraciones de la máquina." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_0ba61c30a9 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.G.FREALPR" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:ProblemaDeAjusteDetectado a ns1:DiagnosticoFallo ;
    rdfs:label "Problema de ajuste detectado" ;
    ns1:textoExtracto "Problema de ajuste detectado" .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico" ;
    ns1:textoExtracto "En máquinas de corte por láser se aconseja utilizar esta variable para que la potencia del láser sea proporcional al avance." .

