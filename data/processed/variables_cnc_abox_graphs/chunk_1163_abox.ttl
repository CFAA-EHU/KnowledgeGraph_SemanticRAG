@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_6305b9aca8 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de detección de problemas de ajuste" ;
    ns1:textoExtracto "Comparando en el osciloscopio el avance real con el teórico a lo largo de la trayectoria se pueden detectar problemas de ajuste si ambos divergen en puntos concretos." .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_b2f7ddee82 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ns1:documentadoEn ns1:SistemaHidraulico ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "V.)[ch].PLC.G00FEED Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico" ;
    ns1:textoExtracto "En máquinas de corte por láser se aconseja utilizar esta variable para que la potencia del láser sea proporcional al avance." .

