@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceMaximoPermitidoEnElCanal a ns1:Parametro ;
    rdfs:label "Avance máximo permitido en el canal" ;
    ns1:textoExtracto "Esta variable permite limitar, en un momento dado y en tiempo real, el avance" .

ns1:ValorDeEjecucion a ns1:Parametro ;
    rdfs:label "Valor de ejecución" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

