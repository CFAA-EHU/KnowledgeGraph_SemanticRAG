@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceActivoEnElCanal2 a ns1:Parametro ;
    rdfs:label "Avance activo en el canal 2" ;
    ns1:identificador "PLC.G00FEED[2]" ;
    ns1:textoExtracto "Canal ·2·." .

ns1:AvanceActivoEnElCanal3 a ns1:Parametro ;
    rdfs:label "Avance activo en el canal 3" ;
    ns1:identificador "PLC.G00FEED[3]" ;
    ns1:textoExtracto "(V.)[ch].PLC.G00FEED" .

ns1:AvanceActivoEnElCanal4 a ns1:Parametro ;
    rdfs:label "Avance activo en el canal 4" ;
    ns1:identificador "PLC.G00FEED[4]" ;
    ns1:textoExtracto "(V.)[ch].PLC.G00FEED" .

ns1:LimiteDeAvanceRapidoG00 a ns1:Parametro ;
    rdfs:label "Límite de avance rápido G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "el avance nunca superará los límites fijados por los parámetros G00FEED y MAXFEED." .

ns1:LimiteMaximoDeAvance a ns1:Parametro ;
    rdfs:label "Límite máximo de avance" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "el avance nunca superará los límites fijados por los parámetros G00FEED y MAXFEED." .

