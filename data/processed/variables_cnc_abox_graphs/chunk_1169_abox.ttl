@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeAlimentacion a ns1:Parametro ;
    rdfs:label "Avance de alimentación" ;
    ns1:identificador "G.FEED" ;
    ns1:textoExtracto "(V.)[ch].G.FEED" .

ns1:AvanceDefinidoEnElProgramaG94 a ns1:Parametro ;
    rdfs:label "Avance definido en el programa G94" ;
    ns1:identificador "G.PRGF" ;
    ns1:textoExtracto "(V.)[ch].G.PRGF" .

ns1:AvanceDefinidoPorPLC a ns1:Parametro ;
    rdfs:label "Avance definido por PLC" ;
    ns1:identificador "PLC.F" ;
    ns1:textoExtracto "(V.)[ch].PLC.F" .

