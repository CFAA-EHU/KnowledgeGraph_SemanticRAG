@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorACompensarEnLosDesplazamientosEnSentidoNegativo a ns1:Parametro ;
    rdfs:label "Error a compensar en los desplazamientos en sentido negativo" ;
    ns1:identificador "MPG.NEGERROR[tbl][pt]" ;
    ns1:textoExtracto "(V.)MPG.NEGERROR[tbl][pt] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:ErrorACompensarEnLosDesplazamientosEnSentidoPositivo a ns1:Parametro ;
    rdfs:label "Error a compensar en los desplazamientos en sentido positivo" ;
    ns1:identificador "MPG.POSERROR[3][14]" ;
    ns1:textoExtracto "V.MPG.POSERROR[3][14] | Punto 14 de la tercera tabla de compensación cruzada." .

ns1:Punto14DeLaTerceraTablaDeCompensacionCruzada_2c99ab38a9 a ns1:Parametro ;
    rdfs:label "Punto 14 de la tercera tabla de compensación cruzada" ;
    ns1:identificador "MPG.POSITION[3][14]" ;
    ns1:textoExtracto "V.MPG.POSITION[3][14] | Punto 14 de la tercera tabla de compensación cruzada." .

