@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCanalParaAvancePorPLCEnG94 a ns1:Parametro ;
    rdfs:label "Número de canal para avance por PLC en G94."@es ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "\"Canal [ch]. Avance por PLC en G94. El avance programado por PLC prevalece sobre el programado por programa o MDI.\""@es .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_14bedce01e a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz."@es ;
    ns1:identificador "PLC.F" ;
    ns1:monitoreaParametro ns1:CNC8070_da13ad31cf ;
    ns1:textoExtracto "\"(V.)[ch].PLC.F Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\""@es .

ns1:CNC8070_da13ad31cf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "\"Para anular el avance por PLC, definir la variable con valor ·0·; el CNC aplica el avance activo por programa.\""@es .

