@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeDeAvanceFeedOverride a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override)"@es ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "Esta variable permite fijar un porcentaje de avance desde el programa; para anularlo, definir la variable con valor 0 (cero)." .

