@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioControlNumerico a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de control numérico" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Canal [ch]. Porcentaje de avance (feed override) seleccionado en el conmutador del panel de mando." .

ns1:Parametro_6d62a7078f a ns1:Parametro ;
    rdfs:label "Canal de porcentaje de avance fijado por PLC" ;
    ns1:identificador "V.PLC.FRO" ;
    ns1:textoExtracto "V.[2].PLC.FRO | Canal ·2·." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazParaPorcentajeDeAvance a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz para porcentaje de avance" ;
    ns1:identificador "G.CNCFRO" ;
    ns1:textoExtracto "V.)[ch].G.CNCFRO Variable de lectura y escritura desde el interfaz (escritura asíncrona); de lectura desde el programa y PLC." .

