    rdfs:label "Canal ·2·" ;
    ns1:identificador "V.2.G.CNCFRO" ;
    ns1:textoExtracto "V.[2].G.CNCFRO | Canal ·2·." .

ns1:PorcentajeDeAvanceFijadoEnElConmutadorDelPanelDeMando a ns1:AccionProhibida ;
    rdfs:label "Porcentaje de avance fijado en el conmutador del panel de mando" ;
    ns1:textoExtracto "El porcentaje fijado en el conmutador del panel de mando es menos prioritario que el fijado por PLC o por programa." .

ns1:PorcentajeFijadoPorDMC a ns1:AccionProhibida ;
    rdfs:label "Porcentaje fijado por DMC" ;
    ns1:textoExtracto "Cuando el DMC está activo, el porcentaje fijado por el DMC afecta al porcentaje fijado desde el conmutador." .

