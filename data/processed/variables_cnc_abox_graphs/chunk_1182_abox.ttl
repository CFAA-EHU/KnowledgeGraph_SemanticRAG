@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Esta variable permite fijar un porcentaje de avance desde el PLC para los movimientos en G00." ;
    ns1:tieneComponente ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_ec0eb99536 .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_ec0eb99536 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ns1:identificador "PLC.G00FRO" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

