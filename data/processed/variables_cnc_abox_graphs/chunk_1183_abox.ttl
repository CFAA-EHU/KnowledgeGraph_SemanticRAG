@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_5408e7e7f2 a ns1:Parametro ;
    rdfs:label "Parámetro que define la máxima aceleración permitida sobre la trayectoria de mecanizado." ;
    ns1:identificador "MAXACCEL" ;
    ns1:textoExtracto "La máxima aceleración permitida sobre la trayectoria de mecanizado viene definida por el parámetro MAXACCEL y esta variable permite modificar temporalmente, en un momento dado y en tiempo real, este valor." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazQueModificaLaAc_63c9c0fb14 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz que modifica la aceleración máxima permitida sobre la trayectoria de mecanizado." ;
    ns1:identificador "V.C.G.MAXACCEL" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Canal [ch]. Modificar la aceleración máxima permitida sobre la trayectoria de mecanizado." .

