@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "aceleración sobre la trayectoria" ;
    ns1:textoExtracto "El CNC siempre respeta la dinámica de los ejes implicados en la trayectoria, es decir, independientemente de cuál sea la máxima aceleración permitida sobre la trayectoria, el movimiento respeta la aceleración definida en cada" .

