@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c7c75703e2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .

ns1:MaximoJerkPermitidoSobreLaTrayectoriaDeMecanizado a ns1:Parametro ;
    rdfs:label "Máximo jerk permitido sobre la trayectoria de mecanizado" ;
    ns1:identificador "MAXJERK" ;
    ns1:textoExtracto "El máximo jerk permitido sobre la trayectoria de mecanizado viene definido por el parámetro MAXJERK y esta variable permite modificar temporalmente, en un momento dado y en tiempo real, este valor." .

ns1:VariableGMAXJERK a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.G.MAXJERK" ;
    ns1:textoExtracto "(V.)[ch].G.MAXJERK Variable de lectura y escritura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

