@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_53b638abf7 a ns1:Parametro ;
    rdfs:label "Canal ·2·" ;
    ns1:identificador "V.2.G.PERFRATE" ;
    ns1:textoExtracto "Esta variable debe devolver un valor próximo a 100; si el porcentaje de bloques es inferior al 100 %, puede que el HSC esté perdiendo espacio para aumentar el avance." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_de031ee1ee a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.G.DROPRATE" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Porcentaje de reducción del avance máximo alcanzable." .

