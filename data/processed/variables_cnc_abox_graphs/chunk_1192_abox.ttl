@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VGDROPRATE a ns1:Parametro ;
    rdfs:label "Canal ·2·" ;
    ns1:identificador "V.G.DROPRATE" ;
    ns1:textoExtracto "Esta variable debe devolver un valor próximo a 100; si el valor es inferior al 100 %, es posible que el CNC pueda aumentar el avance si tuviera más bloques." .

ns1:VariableParaAnalizarLaPreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Variable para analizar la preparación de bloques" ;
    ns1:identificador "V.G.PERFRATE" ;
    ns1:textoExtracto "Para saber si el CNC puede suministrar más bloques, será necesario analizar la variable V.G.PERFRATE." .

ns1:VariableParaConsultarElPorcentajeDeTiempoDeCiclo a ns1:Parametro ;
    rdfs:label "Variable para consultar el porcentaje de tiempo de ciclo" ;
    ns1:identificador "V.G.NCTIMERATE" ;
    ns1:textoExtracto "Esta información se puede consultar en la variable V.G.NCTIMERATE." .

