ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_c85a8c85e7 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:documentadoEn ns1:CNC8070_708b2cc769 ;
    ns1:identificador "G.ACTROUND" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Error programado en el modo HSC." .

ns1:CNC8070_708b2cc769 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Esta variable permite optimizar las subrutinas de fabricante desactivando el modo HSC y activando G5 con otro error para ganar tiempo, y recuperar después el modo de ejecución anterior." .

