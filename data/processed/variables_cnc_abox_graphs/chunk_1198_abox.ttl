@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionDebidaALaCurvatura a ns1:Parametro ;
    rdfs:label "Aceleración debida a la curvatura" ;
    ns1:identificador "CURVACC" ;
    ns1:textoExtracto "La aceleración debida a la curvatura (parámetro CURVACC)." .

ns1:JerkDebidoALaCurvatura a ns1:Parametro ;
    rdfs:label "Jerk debido a la curvatura" ;
    ns1:identificador "CURVJERK" ;
    ns1:textoExtracto "El jerk debido a la curvatura (parámetro CURVJERK)." .

