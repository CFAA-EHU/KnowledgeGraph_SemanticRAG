ns1:CNC8070_b153f9492c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaDinamicaEjes ;
    ns1:textoExtracto "Si ambos parámetros se definen con valor 100 %, el CNC no muestra la barra y no será posible cambiar en tiempo real la dinámica del mecanizado." .

ns1:LimiteMaximoDeLaDinamicaDelMecanizado a ns1:Parametro ;
    rdfs:label "Límite máximo de la dinámica del mecanizado" ;
    ns1:identificador "MAXDYNOVR" ;
    ns1:textoExtracto "Los límites máximo y mínimo entre los que puede variar el valor depende de los parámetros máquina MINDYNOVR y MAXDYNOVR." .

ns1:LimiteMinimoDeLaDinamicaDelMecanizado a ns1:Parametro ;
    rdfs:label "Límite mínimo de la dinámica del mecanizado" ;
    ns1:identificador "MINDYNOVR" ;
    ns1:textoExtracto "Los límites máximo y mínimo entre los que puede variar el valor depende de los parámetros máquina MINDYNOVR y MAXDYNOVR." .

