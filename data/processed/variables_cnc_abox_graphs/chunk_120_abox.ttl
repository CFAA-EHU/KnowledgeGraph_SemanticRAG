@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeTablaDeCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Número de tabla de compensación volumétrica" ;
    ns1:identificador "tbl" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Intervalo entre puntos de la compensación volumétrica básica en cada eje. Sintaxis. · tbl· Número de tabla." .

