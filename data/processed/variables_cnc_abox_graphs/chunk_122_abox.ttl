@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoDeDefinicionDeLaPrimeraCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Archivo de definición de la primera compensación volumétrica" ;
    ns1:identificador "V.MPG.VCOMPFILE[1]" ;
    ns1:textoExtracto "V.MPG.VCOMPFILE[1] | Archivo de definición de la primera compensación volumétrica." .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica" ;
    ns1:textoExtracto "Tabla [tbl] de compensación volumétrica. Archivo con los datos de la compensación volumétrica." .

