@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelGestorDeHerramientas a ns1:Parametro ;
    rdfs:label "Estado del gestor de herramientas" ;
    ns1:identificador "TM.MZSTATUS" ;
    ns1:textoExtracto "Variable de lectura desde el PLC e interfaz. Estado del gestor de herramientas." .

ns1:GestorDeHerramientasEnFuncionamiento a ns1:Parametro ;
    rdfs:label "Gestor de herramientas en funcionamiento" ;
    ns1:identificador "TM.MZRUN" ;
    ns1:textoExtracto "Variable de lectura desde el PLC e interfaz. Gestor de herramientas en funcionamiento." .

ns1:ValorEmergenciaHerramientas a ns1:Parametro ;
    rdfs:label "Emergencia en el gestor de herramientas" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 4 | Emergencia en el gestor de herramientas." ;
    ns1:valor "4" .

ns1:ValorErrorHerramientas a ns1:Parametro ;
    rdfs:label "Error en el gestor de herramientas" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 1 | Error en el gestor de herramientas." ;
    ns1:valor "1" .

ns1:ValorEsperandoManiobra a ns1:Parametro ;
    rdfs:label "Error en el gestor de herramientas; esperando a finalizar la maniobra en marcha" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 2 | Error en el gestor de herramientas; esperando a finalizar la maniobra en marcha." ;
    ns1:valor "2" .

ns1:ValorEstadoNormal a ns1:Parametro ;
    rdfs:label "Funcionamiento normal" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 0 | Funcionamiento normal." ;
    ns1:valor "0" .

