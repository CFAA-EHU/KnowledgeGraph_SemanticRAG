ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazNumeroDeCorrectorActivo a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Número de corrector activo."@es ;
    ns1:identificador "V.ch.TM.TOD" ;
    ns1:textoExtracto "\"(V.)[ch].TM.TOD Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Número de corrector activo.\""@es .

