@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCanalParaHerramientaActiva a ns1:ComponenteElectrico ;
    rdfs:label "Número de canal para herramienta activa" ;
    ns1:textoExtracto "Número de canal. | [2].TM.REMLIFE | Canal ·2·." .

ns1:VidaRestanteDeLaHerramientaActiva a ns1:Parametro ;
