@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaSintaxisParametroTMCTOR a ns1:Tabla ;
    rdfs:label "Tabla Sintaxis Parametro TM.TOR" ;
    ns1:ilustradoEn ns1:CorrectorDeLaHerramientaActiva,
        ns1:NumeroDeCanal_657b8b6883,
        ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEscrituraAsincronaEInterfaz_026f247184 ;
    ns1:textoExtracto "(V.)[ch].TM.TOR[ofd] Variable de lectura y escritura desde el programa, PLC (escritura asíncrona) e interfaz." .

ns1:CorrectorDeLaHerramientaActiva a ns1:Parametro ;
    rdfs:label "Corrector de la herramienta activa" ;
    ns1:identificador "ofd" ;
    ns1:textoExtracto "· ofd· Corrector de la herramienta; si se omite, el corrector activo." .

ns1:NumeroDeCanal_657b8b6883 a ns1:Parametro ;
    rdfs:label "Número de canal" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "· ch· Número de canal." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEscrituraAsincronaEInterfaz_026f247184 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC (escritura asíncrona) e interfaz" ;
    ns1:identificador "TM.TOR" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Corrector [ofd] de la herramienta activa. Radio. Esta variable no es válida para herramientas de tornear." .

