@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoEstimadoParaEjecutarUnaFuncionT a ns1:Parametro ;
    rdfs:label "Tiempo estimado para ejecutar una función T" ;
    ns1:identificador "V.MPG.TTIME" ;
    ns1:textoExtracto "devuelve el valor de la preparación de bloques. Tiempo estimado para ejecutar una función T (en milisegundos). V.MPG.TTIME" .

