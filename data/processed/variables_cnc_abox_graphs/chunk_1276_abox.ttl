ns1:CNC8070_5d452210d6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En herramientas de fresado se utiliza para definir la posición de la herramienta cuando se emplea un portaherramientas o un utillaje intermedio." ;
