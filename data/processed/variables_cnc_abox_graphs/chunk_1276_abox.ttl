ns1:Herramienta_197906728b a ns1:Herramienta ;
    rdfs:label "Herramienta de tornear" ;
    ns1:textoExtracto "En herramientas de tornear se utiliza para definir la longitud de la herramienta en cada uno de los ejes." .

