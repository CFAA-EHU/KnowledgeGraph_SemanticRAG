ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_e14e7ba04f a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Número total de módulos de salidas digitales."@es ;
    ns1:identificador "MPG.NDOMOD" ;
    ns1:textoExtracto "V.MPG.NDOMOD Esta variable indica la cantidad de estos módulos conectados en el mismo bus CAN." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_e1dd2e6f5c a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Dirección base de los módulos de salidas digitales."@es ;
