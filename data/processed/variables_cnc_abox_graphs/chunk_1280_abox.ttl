@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SentidoDeGiroM03 a ns1:Parametro ;
    rdfs:label "Sentido de giro M03" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "\"| 1 | Sentido de giro M03. |\"" .

ns1:SentidoDeGiroM04 a ns1:Parametro ;
    rdfs:label "Sentido de giro M04" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "\"| 2 | Sentido de giro M04. |\"" .

ns1:SinSentidoDeGiroPredeterminado a ns1:Parametro ;
    rdfs:label "Sin sentido de giro predeterminado" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "\"| 0 | Sin sentido de giro predeterminado. |\"" .

ns1:VariableDeLecturaYEscrituraParaElSentidoDeGiroPredeterminadoDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura para el sentido de giro predeterminado de la herramienta" ;
    ns1:documentadoEn ns1:InterfazUsuarioGSPDLTURDIR ;
    ns1:identificador "G.SPDLTURDIR" ;
    ns1:textoExtracto "\"(V.)G.SPDLTURDIR Variable de lectura y escritura desde el programa; de lectura desde PLC (asíncrona) e interfaz.\"" .

ns1:InterfazUsuarioGSPDLTURDIR a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para la variable G.SPDLTURDIR" ;
    ns1:textoExtracto "\"La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\"" .

