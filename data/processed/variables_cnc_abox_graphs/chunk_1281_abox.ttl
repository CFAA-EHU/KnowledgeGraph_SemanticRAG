@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeEscrituraAsincronaParaCualquierHerramienta a ns1:Parametro ;
    rdfs:label "Variable de escritura asíncrona para cualquier herramienta" ;
    ns1:textoExtracto "La escritura de estas variables siempre es asíncrona, sea para la herramienta activa o no." .

ns1:VariableDeLecturaAsincronaParaHerramientasFueraDelAlmacen a ns1:Parametro ;
    rdfs:label "Variable de lectura asíncrona para herramientas fuera del almacén" ;
    ns1:textoExtracto "Las variables referidas a otra herramienta diferente de la activa serán de lectura síncrona si la herramienta está en el almacén y de lectura asíncrona en caso contrario." .

ns1:VariableDeLecturaSincronaParaHerramientasEnElAlmacen a ns1:Parametro ;
    rdfs:label "Variable de lectura síncrona para herramientas en el almacén" ;
    ns1:textoExtracto "Las variables referidas a otra herramienta diferente de la activa serán de lectura síncrona si la herramienta está en el almacén y de lectura asíncrona en caso contrario." .

