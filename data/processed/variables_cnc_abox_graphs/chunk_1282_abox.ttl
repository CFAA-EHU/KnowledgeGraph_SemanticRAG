@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorEstadoHerramientaDisponible a ns1:Parametro ;
    rdfs:label "Herramienta disponible" ;
    ns1:solucionaFallo ns1:FalloHerramientaGastada,
        ns1:FalloHerramientaRechazada ;
    ns1:textoExtracto "0 | Herramienta disponible." ;
    ns1:valor "0" .

ns1:ValorEstadoHerramientaGastada a ns1:Parametro ;
    rdfs:label "Herramienta gastada" ;
    ns1:textoExtracto "2 | Herramienta gastada." ;
    ns1:valor "2" .

ns1:ValorEstadoHerramientaRechazada a ns1:Parametro ;
    rdfs:label "Herramienta rechazada" ;
    ns1:textoExtracto "1 | Herramienta rechazada." ;
    ns1:valor "1" .

ns1:VariableDeLecturaDesdeElPLCEInterfaz a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el PLC e interfaz" ;
    ns1:identificador "TM.TSTATUST" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores." .

