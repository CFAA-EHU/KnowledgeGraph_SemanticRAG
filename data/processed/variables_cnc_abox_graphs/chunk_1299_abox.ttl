@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorrectorDeLaHerramienta_38f0e83edb a ns1:Parametro ;
    rdfs:label "Corrector de la herramienta" ;
    ns1:identificador "VTM.TORT.ofd" ;
    ns1:textoExtracto "· ofd· Corrector de la herramienta; si se omite, el corrector activo." .

ns1:NumeroDeHerramienta_fcff724c4f a ns1:Parametro ;
    rdfs:label "Número de herramienta" ;
    ns1:identificador "VTM.TORT.tl" ;
    ns1:textoExtracto "· tl· Número de herramienta." .

ns1:TablaGeometriaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de geometría de las herramientas" ;
    ns1:ilustra ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEscrituraAsincronaEInterfaz_bfa470dc11 ;
    ns1:textoExtracto """| Valor. | Significado. |
| --- | --- |
| 0 | Sentido no definido. |
| 1 | Sentido de mecanizado a derechas. |
| 2 | Sentido de mecanizado a izquierdas.""" .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEscrituraAsincronaEInterfaz_bfa470dc11 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC (escritura asíncrona) e interfaz" ;
    ns1:identificador "VTM.TORT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Corrector [ofd] de la herramienta [tl]. Radio. Esta variable no es válida para herramientas de tornear." .

