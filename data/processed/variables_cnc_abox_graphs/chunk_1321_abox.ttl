@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaParaLaPreparacionDeBloquesCanal2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa para la preparación de bloques (canal 2)" ;
    ns1:identificador "V.2.G.TLFR" ;
    ns1:textoExtracto "(V.)[ch].G.TLFR Variable de lectura desde el programa. La variable devuelve el valor de la preparación de bloques. Corrector en preparación. Vida real. Sintaxis. · ch· Número de canal." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaParaLaPreparacionDeBloquesCanal2 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa para la preparación de bloques (canal 2)" ;
    ns1:identificador "V.2.G.REMLIFE" ;
    ns1:textoExtracto "(V.)[ch].G.REMLIFE Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Corrector en preparación. Vida restante. Sintaxis. · ch· Número de canal." .

