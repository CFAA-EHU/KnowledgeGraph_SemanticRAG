ns1:DesgasteDelRadioDeLaHerramientaEnPreparacionLecturaYEscritura a ns1:Parametro ;
    rdfs:label "Desgaste del radio de la herramienta en preparación (lectura y escritura)" ;
    ns1:identificador "V.ch.G.TOI" ;
    ns1:textoExtracto "(V.)[ch].G.TOI Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Desgaste del radio." .

