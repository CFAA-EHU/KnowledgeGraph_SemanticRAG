@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesgasteDelRadioDeLaPuntaDeHerramientaEnPreparacion a ns1:Parametro ;
    rdfs:label "Desgaste del radio de la punta de herramienta en preparación" ;
    ns1:textoExtracto "(V.)[ch].G.TOWTIPR Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Desgaste del radio de la punta." .

ns1:LongitudDeCorteDeHerramientaEnPreparacion a ns1:Parametro ;
    rdfs:label "Longitud de corte de herramienta en preparación" ;
    ns1:textoExtracto "(V.)[ch].G.TOCUTL Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Longitud de corte." .

ns1:Parametro_178ec8247a a ns1:Parametro ;
    rdfs:label "Canal de preparación de bloques" ;
    ns1:textoExtracto "(V.)[ch].G.TOAN Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Radio de la punta." .

ns1:RadioDeLaPuntaDeHerramientaEnPreparacion a ns1:Parametro ;
    rdfs:label "Radio de la punta de herramienta en preparación" ;
    ns1:textoExtracto "(V.)[ch].G.TOTIPR Variable de lectura y escritura desde el programa. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Radio de la punta." .

