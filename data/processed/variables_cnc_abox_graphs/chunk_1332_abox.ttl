@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaPreparacionDeBloquesEnElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques en el eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].A.TOFL.1" ;
    ns1:textoExtracto "Eje con índice ·1· en el canal ·2·." .

ns1:ValorDeLaPreparacionDeBloquesEnElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques en el eje con número lógico 4" ;
    ns1:identificador "V.A.TOFL.4" ;
    ns1:textoExtracto "Eje con número lógico ·4·." .

ns1:ValorDeLaPreparacionDeBloquesEnElEjeZ a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques en el eje Z" ;
    ns1:identificador "V.A.TOFL.Z" ;
    ns1:textoExtracto "Eje Z." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaParaLaPreparacionDeBloquesEnElEjeXn a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa para la preparación de bloques en el eje xn" ;
    ns1:identificador "V.A.TOFLW.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques. Herramienta en preparación. Desgaste del offset (longitud) de la herramienta en el eje xn." .

