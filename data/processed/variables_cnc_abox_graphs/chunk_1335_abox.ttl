@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeDientesEnPreparacion a ns1:Parametro ;
    rdfs:label "Número de dientes en preparación" ;
    ns1:identificador "V.G.NCUTTERS" ;
    ns1:textoExtracto "Variable de lectura y escritura desde el programa; de lectura desde el PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Dientes." .

ns1:TercerEjeDelCanal a ns1:Parametro ;
    rdfs:label "Tercer eje del canal" ;
    ns1:identificador "V.2.G.TOFLW3" ;
    ns1:textoExtracto "Segundo eje del canal. V.[2].G.TOFLW3 Canal ·2·. Tercer eje del canal." .

