@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeMovimientoActivoEnElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Tipo de movimiento activo en el eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].A.PLCMMODE.1" ;
    ns1:textoExtracto "V.[2].A.PLCMMODE.1 | Eje con índice ·1· en el canal ·2·." .

ns1:TipoDeMovimientoActivoEnElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Tipo de movimiento activo en el eje con número lógico 4" ;
    ns1:identificador "V.A.PLCMMODE.4" ;
    ns1:textoExtracto "V.A.PLCMMODE.4 | Eje con número lógico ·4·." .

ns1:TipoDeMovimientoActivoEnElEjeZ a ns1:Parametro ;
    rdfs:label "Tipo de movimiento activo en el eje Z" ;
    ns1:identificador "V.A.PLCMMODE.Z" ;
    ns1:textoExtracto "V.A.PLCMMODE.Z | Eje Z." .

ns1:ValorParametroPLCMMODE0 a ns1:Parametro ;
    rdfs:label "No hay selección desde el PLC" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 | No hay selección desde el PLC." .

ns1:ValorParametroPLCMMODE1 a ns1:Parametro ;
    rdfs:label "Modo volante" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "1 | Modo volante." .

ns1:ValorParametroPLCMMODE2 a ns1:Parametro ;
    rdfs:label "Modo jog continuo" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "2 | Modo jog continuo." .

ns1:ValorParametroPLCMMODE3 a ns1:Parametro ;
    rdfs:label "Modo jog incremental" ;
    ns1:identificador "3" ;
    ns1:textoExtracto "3 | Modo jog incremental." .

