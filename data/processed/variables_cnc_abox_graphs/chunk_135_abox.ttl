    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para palpador 1" ;
    ns1:identificador "MPG.PRBDI1" ;
    ns1:textoExtracto "V.MPG.PRBDI1 Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Número de entrada asociada al palpador 1." .

