@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeEsclavoFisico a ns1:ComponenteMecanico ;
    rdfs:label "Eje Esclavo Físico" ;
    ns1:textoExtracto "sincronizar un eje esclavo 'físico' o 'real'" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:EjeVirtual ;
    ns1:textoExtracto "El PLC puede actualizar/escribir en cada ciclo el contenido de la variable A.ACCUDIST.xn del eje virtual" .

ns1:AccumulatedDistance a ns1:Parametro ;
    rdfs:label "Accumulated Distance" ;
    ns1:identificador "A.ACCUDIST.xn" ;
    ns1:textoExtracto "la variable A.ACCUDIST.xn del eje virtual" .

ns1:EjeVirtual a ns1:ComponenteMecanico ;
    rdfs:label "Eje Virtual" ;
    ns1:textoExtracto "Al tratarse de un eje virtual, no físico" ;
    ns1:tieneComponente ns1:AccumulatedDistance .

