@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SeguimientoDeEjeMedianteLevaDePosicion a ns1:Parametro ;
    rdfs:label "Seguimiento de eje mediante leva de posición" ;
    ns1:identificador "CAM ON" ;
    ns1:textoExtracto "#CAM ON, #TCAM ON" .

ns1:SeguimientoDeEjeMedianteMovimientoDeSincronizacion a ns1:Parametro ;
    rdfs:label "Seguimiento de eje mediante movimiento de sincronización" ;
    ns1:identificador "FOLLOW ON" ;
    ns1:textoExtracto "#FOLLOW ON, #TFOLLOW ON" .

