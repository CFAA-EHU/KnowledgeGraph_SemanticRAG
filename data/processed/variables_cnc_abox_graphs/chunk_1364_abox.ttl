@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeSeguimientoDelEjeX a ns1:Parametro ;
    rdfs:label "Variable de seguimiento del eje X" ;
    ns1:identificador "ACCUX" ;
    ns1:textoExtracto "En estos ejemplos, el eje Y realiza el seguimiento del eje X a través de la variable V.A.ACCUDIST.X." .

ns1:VariableDeSincronizacionDelEjeX a ns1:Parametro ;
    rdfs:label "Variable de sincronización del eje X" ;
    ns1:identificador "V.A.ACCUDIST.X" ;
    ns1:textoExtracto "En estos ejemplos, el eje Y realiza el seguimiento del eje X a través de la variable V.A.ACCUDIST.X." .

