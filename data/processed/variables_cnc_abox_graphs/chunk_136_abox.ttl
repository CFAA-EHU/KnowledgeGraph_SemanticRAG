@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz PLC" ;
    ns1:textoExtracto "PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:NivelLogicoDeActivacionDelPalpador1 a ns1:Parametro ;
    rdfs:label "Nivel lógico de activación del palpador 1" ;
    ns1:identificador "MPG.PRBPULSE1" ;
    ns1:textoExtracto "V.MPG.PRBPULSE1 Valores de la variable. Esta variable devuelve uno de los siguientes valores." .

