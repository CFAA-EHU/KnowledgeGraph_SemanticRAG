@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaDireccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para dirección de herramienta" ;
    ns1:documentadoEn ns1:InterfazUsuarioEjes ;
    ns1:identificador "V.1.G.TOOLDIR" ;
    ns1:textoExtracto "V.[1].G.TOOLDIR = 2" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEjeLongitudinal a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para eje longitudinal" ;
    ns1:documentadoEn ns1:InterfazUsuarioEjes ;
    ns1:identificador "V.1.G.LONGAX" ;
    ns1:textoExtracto "V.[1].G.LONGAX = 30" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaPlanoPrincipal a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para plano principal" ;
    ns1:documentadoEn ns1:InterfazUsuarioEjes ;
    ns1:identificador "V.1.G.PLANE" ;
    ns1:textoExtracto "V.[1].G.PLANE = 1020" .

ns1:InterfazUsuarioEjes a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario para lectura de variables de ejes y planos de trabajo" ;
    ns1:textoExtracto "Lectura de la variable. (V.)[ch].G.LONGAX Variable de lectura desde el programa, PLC e interfaz." .

