@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceEnElCanalDelEjeQueTieneLaHerramienta a ns1:Parametro ;
    rdfs:label "Índice en el canal del eje que tiene la herramienta" ;
    ns1:identificador "G.PLANELONG" ;
    ns1:textoExtracto "[2].G.PLANELONG | Canal ·2·." .

ns1:NombreDelEjeDeAbscisasDelCanal a ns1:Parametro ;
    rdfs:label "Nombre del eje de abscisas del canal" ;
    ns1:identificador "G.PLAXNAME1" ;
    ns1:textoExtracto "[2].G.PLAXNAME1 | Canal ·2·. Eje de abscisas." .

ns1:NombreDelEjeDeOrdenadasDelCanal a ns1:Parametro ;
    rdfs:label "Nombre del eje de ordenadas del canal" ;
    ns1:identificador "G.PLAXNAME2" ;
    ns1:textoExtracto "[2].G.PLAXNAME2 | Canal ·2·. Eje de ordenadas." .

ns1:NombreDelTercerEjePrincipalDelCanal a ns1:Parametro ;
    rdfs:label "Nombre del tercer eje principal del canal" ;
    ns1:identificador "G.PLAXNAME3" ;
    ns1:textoExtracto "[2].G.PLAXNAME3 | Canal ·2·. Tercer eje principal." .

