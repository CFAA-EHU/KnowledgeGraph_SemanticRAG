@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCanalDelPlanoDeTrabajo a ns1:Parametro ;
    rdfs:label "Número de canal del plano de trabajo" ;
    ns1:identificador "G.PLANELONG" ;
    ns1:textoExtracto "En esta variable, el índice en el canal del primer eje será el ·0·, del segundo eje será el ·1·, y así sucesivamente." .

