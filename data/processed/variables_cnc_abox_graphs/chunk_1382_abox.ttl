@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesG a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones 'G'" ;
    ns1:documentadoEn ns1:TablaFuncionesGM ;
    ns1:identificador "G.HGS" ;
    ns1:textoExtracto "Esta variable devuelve un valor binario. Cada función dispone de un bit que indica si debe visualizarse (=1) o no (=0) la función correspondiente." .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezalMaster a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones 'M' del cabezal master" ;
    ns1:documentadoEn ns1:TablaFuncionesGM ;
    ns1:identificador "G.HMS" ;
    ns1:textoExtracto "Esta variable devuelve un valor hexadecimal, con el siguiente significado. Cada bit representa una función M, e indica si debe visualizarse (bit=1) o no (bit=0) dicha función." .

ns1:InterfazUsuarioFunciones a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para funciones 'G' y 'M'" ;
    ns1:documentadoEn ns1:TablaFuncionesGM ;
    ns1:textoExtracto "Funciones 'G' y 'M' a visualizar en la historia" .

ns1:TablaFuncionesGM a ns1:Tabla ;
    rdfs:label "Tabla de funciones 'G' y 'M'" ;
    ns1:ilustra ns1:InterfazUsuarioFunciones ;
    ns1:textoExtracto "Esta variable devuelve un valor binario. Cada función dispone de un bit que indica si debe visualizarse (=1) o no (=0) la función correspondiente." .

