@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioFuncionesM a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para funciones M de los cabezales" ;
    ns1:ilustra ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal1,
        ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal2,
        ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal3,
        ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal4 ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Funciones \"M\" del cabezal 1 a 4 a visualizar en la historia." .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal1 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones M del cabezal 1" ;
    ns1:identificador "G.HMS1" ;
    ns1:textoExtracto "\"(V.)[ch].G.HMS1\" Variable de lectura desde el interfaz." .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones M del cabezal 2" ;
    ns1:identificador "G.HMS2" ;
    ns1:textoExtracto "\"(V.)[ch].G.HMS2\" Canal ·2·. Cabezal ·2·." .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal3 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones M del cabezal 3" ;
    ns1:identificador "G.HMS3" ;
    ns1:textoExtracto "\"(V.)[ch].G.HMS3\" Variable de report (para uso desde los scripts)." .

ns1:VariableDeLecturaDesdeElInterfazParaFuncionesMDelCabezal4 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para funciones M del cabezal 4" ;
    ns1:identificador "G.HMS4" ;
    ns1:textoExtracto "\"(V.)[ch].G.HMS4\" Funciones \"M\" del cabezal 1 a 4 a visualizar en la historia." .

