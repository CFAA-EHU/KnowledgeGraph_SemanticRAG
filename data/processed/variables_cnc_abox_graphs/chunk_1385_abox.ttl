@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazCicloFijoActivo a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Ciclo fijo activo."@es ;
    ns1:identificador "V.G.ACTIVECYCLE" ;
    ns1:textoExtracto "\"(V.)[ch].G.ACTIVECYCLE Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Ciclo fijo activo.\""@es .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazTipoDeCicloFijoActivo a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Tipo de ciclo fijo activo."@es ;
    ns1:identificador "V.G.CYCLETYPEON" ;
    ns1:textoExtracto "\"(V.)[ch].G.CYCLETYPEON Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Tipo de ciclo fijo activo.\""@es .

