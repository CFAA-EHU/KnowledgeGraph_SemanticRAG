@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValoresDeLaVariableParaCiclosISO a ns1:Parametro ;
    rdfs:label "Valores de la variable para ciclos ISO" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. • Ciclos de fresadora: Ciclos ISO (1 - 99)." .

ns1:ValoresDeLaVariableParaEditorDeCiclos a ns1:Parametro ;
    rdfs:label "Valores de la variable para editor de ciclos" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. • Ciclos de fresadora: Editor de ciclos (100 - 199)." .

