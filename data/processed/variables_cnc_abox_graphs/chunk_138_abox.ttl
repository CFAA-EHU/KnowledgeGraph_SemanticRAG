@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TamanoDeLaZonaDeDatosCompartidaDelPLCEnBytes a ns1:Parametro ;
    rdfs:label "Tamaño de la zona de datos compartida del PLC (en bytes)"@es ;
