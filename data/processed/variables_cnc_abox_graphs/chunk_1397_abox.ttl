@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValoresDeLaVariableQueDevuelveUnValorCodificadoEnBits a ns1:Parametro ;
    rdfs:label "Valores de la variable que devuelve un valor codificado en bits" ;
    ns1:identificador "V.G.CALLP" ;
    ns1:textoExtracto "La variable devuelve un valor codificado en bits, donde cada bit representa un parámetro; el bit de menos peso (bit 0) corresponde al parámetro P0, el bit 1 al parámetro P1 y así sucesivamente." .

ns1:VariableDeLecturaDesdeElPrograma_0ce8bf2ceb a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa" ;
    ns1:identificador "V.C.PCALLP_A" ;
    ns1:textoExtracto "V.C.PCALLP_A = 1" .

