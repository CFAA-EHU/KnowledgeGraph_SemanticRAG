@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeProgramacionDelParametro a ns1:Parametro ;
    rdfs:label "Estado de programación del parámetro" ;
    ns1:textoExtracto "Cada uno de estos bits indica si el parámetro está programado (bit=1) o no (bit=0)." .

