@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazNumeroDeRepeticionesPendientesConNR a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Número de repeticiones pendientes con NR" ;
    ns1:identificador "V.G.PENDNR" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Número de repeticiones pendientes con NR." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazNumeroDeRepeticionesPendientesConRPT a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Número de repeticiones pendientes con #RPT" ;
    ns1:identificador "V.G.PENDRPT" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Número de repeticiones pendientes con #RPT." .

