@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_afaa660b4c a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:documentadoEn ns1:InterfazUsuarioPalpacion,
        ns1:SistemaPLC ;
    ns1:identificador "A.MEASOK.xn" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Palpación finalizada en el eje." .

ns1:InterfazUsuarioPalpacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de palpación" ;
    ns1:textoExtracto "lectura desde el PLC o interface seguirá mostrando valor 1." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "lectura desde el PLC o interface seguirá mostrando valor 1." .

