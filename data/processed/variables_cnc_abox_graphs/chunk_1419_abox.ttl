@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaParaEjeXEstado a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa para eje X (estado)" ;
    ns1:identificador "V.A.MEASOK.X" ;
    ns1:textoExtracto "V.A.MEASOK.X = 1" .

ns1:VariableDeLecturaDesdeElProgramaParaEjeXOffset a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa para eje X (offset)" ;
    ns1:identificador "V.A.MEASOF.X" ;
    ns1:textoExtracto "V.A.MEASOF.X = -5" .

ns1:VariableDeLecturaDesdeElProgramaParaEjeX_f022cdf655 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa para eje X" ;
    ns1:identificador "V.A.MEAS.X" ;
    ns1:textoExtracto "V.A.MEAS.X = 95" .

