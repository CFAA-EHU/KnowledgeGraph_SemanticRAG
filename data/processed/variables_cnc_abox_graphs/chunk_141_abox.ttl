@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceRapidoEnG0 a ns1:Parametro ;
    rdfs:label "Avance rápido en G0" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)." .

ns1:ComportamientoDeConmutacionSincronizada a ns1:Parametro ;
    rdfs:label "Comportamiento de conmutación sincronizada" ;
    ns1:identificador "SWTOUT" ;
    ns1:textoExtracto "#SWTOUT modifica el comportamiento de la conmutación sincronizada." .

