ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaDistanciaMovidaConG200OG201 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la distancia movida con G200 o G201" ;
