@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDePosicionamientoParaElControlTangencial a ns1:Parametro ;
    rdfs:label "Avance de posicionamiento para el control tangencial" ;
    ns1:identificador "V.G.TANGFEED" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Avance de posicionamiento para el control tangencial." .

ns1:SistemaControlTangencial a ns1:Sistema ;
    rdfs:label "Sistema Control Tangencial" ;
    ns1:textoExtracto "Avance de posicionamiento para el control tangencial." .

