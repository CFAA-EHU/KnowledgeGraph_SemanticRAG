@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEstadoDeMarcaMEETEnCanal2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para estado de marca MEET en canal 2" ;
    ns1:identificador "V.2.G.MEETST4" ;
    ns1:textoExtracto "\"(V.)[ch].G.MEETST[mk] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado de la marca [mk] de tipo MEET en el canal [ch]. Sintaxis. · ch· Número de canal. · mk· Número de la marca de sincronización.\" | V.[2].G.MEETST[4] | Canal ·2·. Marca ·4·." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEstadoDeMarcaWAITEnCanalCh a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para estado de marca WAIT en canal ch" ;
    ns1:identificador "V.ch.G.WAITSTmk" ;
    ns1:textoExtracto "\"(V.)[ch].G.WAITST[mk] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado de la marca [mk] de tipo WAIT en el canal [ch]. Sintaxis. · ch· Número de canal. · mk· Número de la marca de sincronización.\"" .

