@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_de191e3ee1 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.G.RIGIER" ;
    ns1:monitoreaParametro ns1:Cabezal,
        ns1:EjeLongitudinal ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura desde el programa detiene la preparación de bloques." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Desfase en milímetros o pulgadas entre la proyección del error de seguimiento del cabezal sobre el eje longitudinal y el error de seguimiento del eje longitudinal." .

ns1:EjeLongitudinal a ns1:ComponenteMecanico ;
    rdfs:label "Eje Longitudinal" ;
    ns1:textoExtracto "Desfase en milímetros o pulgadas entre la proyección del error de seguimiento del cabezal sobre el eje longitudinal y el error de seguimiento del eje longitudinal." .

