@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaPreparacionDeBloques_43290a2122 a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques" ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:textoExtracto "La distancia de seguridad se define por eje, el cual tendrá la misma distancia de seguridad en todas las zonas. En el arranque del CNC, esta variable tomará el valor del parámetro ZONELIMITTOL." .

ns1:VariableLecturaEscritura a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa y PLC" ;
    ns1:identificador "(V.)[ch].A.ZONELIMITTOL.xn" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]. Distancia de seguridad de los límites de las zonas de trabajo." .

