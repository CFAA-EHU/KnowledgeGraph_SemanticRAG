@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDelLimiteInferiorDeLaZona1ParaElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Valor del límite inferior de la zona 1 para el eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].A.ZONELOWLIM[1].1" ;
    ns1:textoExtracto "V.[2].A.ZONELOWLIM[1].1 | Eje con índice ·1· en el canal ·2·. Zona 1." .

ns1:ValorDelLimiteInferiorDeLaZona1ParaElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Valor del límite inferior de la zona 1 para el eje con número lógico 4" ;
    ns1:identificador "V.A.ZONELOWLIM[1].4" ;
    ns1:textoExtracto "V.A.ZONELOWLIM[1].4 | Eje con número lógico ·4·. Zona 1." .

ns1:ValorDelLimiteInferiorDeLaZona1ParaElEjeZ a ns1:Parametro ;
    rdfs:label "Valor del límite inferior de la zona 1 para el eje Z" ;
    ns1:identificador "V.A.ZONELOWLIM[1].Z" ;
    ns1:textoExtracto "V.A.ZONELOWLIM[1].Z | Eje Z. Zona 1." .

ns1:ValorDelLimiteSuperiorDeLaZonaParaEjesRotativosYLineales a ns1:Parametro ;
    rdfs:label "Valor del límite superior de la zona para ejes rotativos y lineales" ;
    ns1:identificador "V.A.ZONEUPLIM[k].xn" ;
    ns1:textoExtracto "(V.)[ch].A.ZONEUPLIM[k].xn Variable de lectura y escritura desde el PLC; de lectura desde el programa. Variable válida para ejes rotativos y lineales." .

