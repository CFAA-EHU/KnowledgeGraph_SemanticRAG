@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeSalidaAnalogicaEnModulosRemotos a ns1:Parametro ;
    rdfs:label "Número de salida analógica en módulos remotos" ;
    ns1:identificador "1-60" ;
    ns1:textoExtracto "La entrada analógica está en los módulos remotos. La variable devuelve el número de salida analógica." .

ns1:NumeroYDireccionLogicaDelReguladorSercosRango132 a ns1:Parametro ;
    rdfs:label "Número y dirección lógica del regulador Sercos (rango 1-32)" ;
    ns1:identificador "101-132" ;
    ns1:textoExtracto "La entrada analógica está en un regulador Sercos. El primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." .

ns1:NumeroYDireccionLogicaDelReguladorSercosRango132_391656252b a ns1:Parametro ;
    rdfs:label "Número y dirección lógica del regulador Sercos (rango 1-32)" ;
    ns1:identificador "201-232" ;
    ns1:textoExtracto "La entrada analógica está en un regulador Sercos. El primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." .

