@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_73e25d3dce a ns1:Parametro ;
    rdfs:label "Canal 2. Zona 1."@es ;
    ns1:identificador "G.ZONECIRAX2" ;
    ns1:textoExtracto "\"(V.)[ch].G.ZONECIRAX2[k] Variable de lectura y escritura desde el PLC; de lectura desde el programa. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cota del centro de la zona [k], según el primer eje que define la zona circular.\""@es .

