@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaLaVariab_531459d135 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa. La variable devuelve el valor de la preparación de bloques."@es ;
    ns1:identificador "G.ZONETOOLWATCH" ;
    ns1:textoExtracto "\"(V.)[ch].G.ZONETOOLWATCH[k] Variable de lectura y escritura desde el PLC; de lectura desde el programa. La variable devuelve el valor de la preparación de bloques.\""@es .

ns1:VariableParaVigilarLaPuntaOLaBaseDeLaHerramientaEnLaZonaDeTrabajo a ns1:Parametro ;
    rdfs:label "Variable para vigilar la punta o la base de la herramienta en la zona de trabajo."@es ;
    ns1:identificador "V.[2].G.ZONETOOLWATCH[1]" ;
    ns1:textoExtracto "\"| V.[2].G.ZONETOOLWATCH[1] | Canal ·2·. Zona 1. |\""@es .

ns1:VigilarLaBaseDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Vigilar la base de la herramienta."@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "\"| 1 | Vigilar la base de la herramienta. |\""@es .

ns1:VigilarLaPuntaDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Vigilar la punta de la herramienta."@es ;
    ns1:identificador "0" ;
    ns1:textoExtracto "\"| 0 | Vigilar la punta de la herramienta. |\""@es .

ns1:VigilarTantoLaPuntaComoLaBaseDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Vigilar tanto la punta como la base de la herramienta."@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "\"| 2 | Vigilar tanto la punta como la base de la herramienta. |\""@es .

