@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorMaximoDeAvancePermitidoParaElDMC a ns1:Parametro ;
    rdfs:label "Valor máximo de avance permitido para el DMC" ;
    ns1:identificador "V.2.G.DMCOVRMAX" ;
    ns1:textoExtracto "\"(V.)[ch].G.DMCOVRMAX Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Porcentaje. Máximo porcentaje de avance (feed override) permitido para el DMC.\"" .

ns1:ValorMinimoDeAvancePorDientePermitidoDuranteElDMC a ns1:Parametro ;
    rdfs:label "Valor mínimo de avance por diente permitido durante el DMC" ;
    ns1:identificador "V.2.G.DMCFZMIN" ;
    ns1:textoExtracto "\"(V.)[ch].G.DMCFZMIN Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros/diente o pulgadas/diente. Mínimo avance por diente permitido durante el DMC.\"" .

