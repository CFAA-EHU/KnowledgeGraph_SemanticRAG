@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GDMCOVR a ns1:Parametro ;
    rdfs:label "Canal de avance por diente calculado por el DMC" ;
    ns1:identificador "G.DMCOVR" ;
    ns1:textoExtracto "\"V.[2].G.DMCFZ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Unidades: Milímetros/diente o pulgadas/diente. Avance por diente calculado por el DMC.\"" .

ns1:Parametro_10a9ea4844 a ns1:Parametro ;
    rdfs:label "Canal de potencia del cabezal en vacío medida por el DMC" ;
    ns1:identificador "G.DMCNOLOADPWR" ;
    ns1:textoExtracto "\"V.[2].G.DMCNOLOADPWR Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Unidades: Kilowatios. Potencia del cabezal en vacío medida por el DMC.\"" .

ns1:Parametro_579385bd14 a ns1:Parametro ;
    rdfs:label "Canal de avance por diente calculado por el DMC" ;
    ns1:identificador "G.DMCFZ" ;
    ns1:textoExtracto "\"V.[2].G.DMCFZ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Unidades: Milímetros/diente o pulgadas/diente. Avance por diente calculado por el DMC.\"" .

