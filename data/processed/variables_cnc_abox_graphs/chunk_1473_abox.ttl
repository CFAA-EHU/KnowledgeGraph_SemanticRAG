@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioDMC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz DMC" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_c307809123 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.DMCSAVEDTIME" ;
    ns1:textoExtracto "V.[2].G.DMCSAVEDTIME Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

