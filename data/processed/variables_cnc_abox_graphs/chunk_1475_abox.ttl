@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioFCAS a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de FCAS" ;
    ns1:documentadoEn ns1:SistemaFCAS ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz." .

ns1:SistemaFCAS a ns1:Sistema ;
    rdfs:label "Fagor Collision Avoidance System" ;
    ns1:monitoreaParametro ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazEstadoDelControlDeColisiones,
        ns1:VariableDeReportParaUsoDesdeLosScriptsEstadoDelControlDeColisionesParaElCanal2 ;
    ns1:textoExtracto "Estado del control de colisiones." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazEstadoDelControlDeColisiones a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Estado del control de colisiones." ;
    ns1:identificador "V.G.COLLISIONPERF" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeReportParaUsoDesdeLosScriptsEstadoDelControlDeColisionesParaElCanal2 a ns1:Parametro ;
    rdfs:label "Variable de report (para uso desde los scripts). Estado del control de colisiones para el canal 2." ;
    ns1:identificador "V.2.G.COLLISIONPERF" ;
    ns1:textoExtracto "Canal ·2·." .

