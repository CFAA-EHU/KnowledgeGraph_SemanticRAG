@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_27296f196e a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.CAMST[cam]" ;
    ns1:monitoreaParametro ns1:SistemaElectronicaLeva ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Estado de la leva." .

ns1:SistemaElectronicaLeva a ns1:Sistema ;
    rdfs:label "Sistema Electrónico de Leva" ;
    ns1:textoExtracto "Utilizar esta variable en la maniobra del PLC para condicionar las operaciones de la leva al estado adecuado, y evitar así errores de ejecución." .

