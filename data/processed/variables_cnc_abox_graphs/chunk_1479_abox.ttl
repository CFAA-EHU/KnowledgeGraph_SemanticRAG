@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaLevaActivaYEnEjecucionDentroDelRangoDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Estado de la leva activa y en ejecución dentro del rango del eje maestro" ;
    ns1:identificador "CAM_RUNNING_INSIDE" ;
    ns1:textoExtracto "La leva está activa y en ejecución dentro del rango del eje maestro. Si el CNC o el PLC desactivan la leva, ésta pasará al estado CAM_FINISH." .

ns1:EstadoDeLaLevaActivaYEnEjecucionFueraDelRangoDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Estado de la leva activa y en ejecución fuera del rango del eje maestro" ;
    ns1:identificador "CAM_RUNNING_OUTSIDE" ;
    ns1:textoExtracto "La leva está activa y en ejecución fuera del rango del eje maestro. En este estado, la leva ha estado dentro del rango del eje maestro al menos una vez." .

ns1:EstadoDeLaLevaDesactivadaPeroConEjecucionContinuaHastaSalirDelRangoDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Estado de la leva desactivada pero con ejecución continua hasta salir del rango del eje maestro" ;
    ns1:identificador "CAM_FINISH" ;
    ns1:textoExtracto "El CNC o el PLC ha desactivado la leva, pero la ejecución continúa hasta que la leva salga del rango del eje maestro." .

