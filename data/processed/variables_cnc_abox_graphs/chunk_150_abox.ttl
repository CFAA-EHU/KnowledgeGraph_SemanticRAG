@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnulacionDelErrorDeGap a ns1:Parametro ;
    rdfs:label "Anulación del error de gap" ;
    ns1:identificador "MPG.GAPERRORCANCEL" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:FrecuenciaDelSensor a ns1:Parametro ;
    rdfs:label "Frecuencia del sensor" ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:RetardoDelSensor a ns1:Parametro ;
    rdfs:label "Retardo del sensor" ;
    ns1:identificador "MPG.GAPSENSORDELAY" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

