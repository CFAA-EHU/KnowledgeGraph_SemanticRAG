@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaVariablesCinematicas a ns1:Tabla ;
    rdfs:label "Variables relacionadas con la cinemática activa" ;
    ns1:ilustra ns1:CabezalAngularXZ,
        ns1:CabezalAngularYZ,
        ns1:CabezalOrtogonalOEsfericoXY,
        ns1:CabezalOrtogonalOEsfericoYX,
        ns1:CabezalOrtogonalOEsfericoZX,
        ns1:CabezalOrtogonalOEsfericoZY,
        ns1:CabezalOrtogonalTresEjesAba,
        ns1:CabezalOrtogonalTresEjesAca,
        ns1:CabezalOrtogonalTresEjesAcab,
        ns1:CabezalOrtogonalTresEjesBab,
        ns1:CabezalOrtogonalTresEjesBca,
        ns1:CabezalOrtogonalTresEjesBcb,
        ns1:CabezalOrtogonalTresEjesCab,
        ns1:CabezalOrtogonalTresEjesCba,
        ns1:MesaRotativaAB ;
    ns1:textoExtracto "Valor. Significado." .

ns1:CabezalAngularXZ a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular XZ" ;
    ns1:textoExtracto "5 Cabezal angular XZ." .

ns1:CabezalAngularYZ a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ" ;
    ns1:textoExtracto "6 Cabezal angular YZ." .

ns1:CabezalOrtogonalOEsfericoXY a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal o esférico XY" ;
    ns1:textoExtracto "3 Cabezal ortogonal o esférico XY." .

ns1:CabezalOrtogonalOEsfericoYX a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal o esférico YX" ;
    ns1:textoExtracto "1 Cabezal ortogonal o esférico YX." .

ns1:CabezalOrtogonalOEsfericoZX a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal o esférico ZX" ;
    ns1:textoExtracto "2 Cabezal ortogonal o esférico ZX." .

ns1:CabezalOrtogonalOEsfericoZY a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal o esférico ZY" ;
    ns1:textoExtracto "4 Cabezal ortogonal o esférico ZY." .

ns1:CabezalOrtogonalTresEjesAba a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos ABA" ;
    ns1:textoExtracto "17 Cabezal ortogonal de tres ejes rotativos ABA." .

ns1:CabezalOrtogonalTresEjesAca a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos ACA" ;
    ns1:textoExtracto "18 Cabezal ortogonal de tres ejes rotativos ACA." .

ns1:CabezalOrtogonalTresEjesAcab a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos ACB" ;
    ns1:textoExtracto "19 Cabezal ortogonal de tres ejes rotativos ACB." .

ns1:CabezalOrtogonalTresEjesBab a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos BAB" ;
    ns1:textoExtracto "20 Cabezal ortogonal de tres ejes rotativos BAB." .

ns1:CabezalOrtogonalTresEjesBca a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos BCA" ;
    ns1:textoExtracto "21 Cabezal ortogonal de tres ejes rotativos BCA." .

ns1:CabezalOrtogonalTresEjesBcb a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos BCB" ;
    ns1:textoExtracto "22 Cabezal ortogonal de tres ejes rotativos BCB." .

ns1:CabezalOrtogonalTresEjesCab a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos CAB" ;
    ns1:textoExtracto "23 Cabezal ortogonal de tres ejes rotativos CAB." .

ns1:CabezalOrtogonalTresEjesCba a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal de tres ejes rotativos CBA" ;
    ns1:textoExtracto "24 Cabezal ortogonal de tres ejes rotativos CBA." .

ns1:MesaRotativaAB a ns1:ComponenteMecanico ;
    rdfs:label "Mesa rotativa AB" ;
    ns1:textoExtracto "9 Mesa rotativa AB." .

