@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OffsetDelParametroTDATA13ParaLaCinematica2 a ns1:Parametro ;
    rdfs:label "Offset del parámetro TDATA13 para la cinemática 2" ;
    ns1:identificador "G.OFTDATA2[13]" ;
    ns1:textoExtracto "Cinemática ·2·. Offset del parámetro TDATA13." .

ns1:OffsetDelParametroTDATAParaLaCinematica a ns1:Parametro ;
    rdfs:label "Offset del parámetro TDATA para la cinemática" ;
    ns1:identificador "G.OFTDATAkin[nb]" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Cinemática [kin]. Offset del parámetro TDATA [nb]." .

ns1:OffsetDelParametroTDATAValorX10000ParaLaCinematica a ns1:Parametro ;
    rdfs:label "Offset del parámetro TDATA (valor x10000) para la cinemática" ;
    ns1:identificador "G.OFTDATAFkin[nb]" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Cinemática [kin]. Offset del parámetro TDATA [nb] (valor x10000)." .

