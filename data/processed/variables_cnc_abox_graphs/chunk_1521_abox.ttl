@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionActualDelEjeRotativoDeLaCinematicaF a ns1:Parametro ;
    rdfs:label "Posición actual del eje rotativo de la cinemática F" ;
    ns1:identificador "G.POSROTF" ;
    ns1:textoExtracto "\"(V.)[ch].G.POSROTF\" Variable de lectura y escritura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

