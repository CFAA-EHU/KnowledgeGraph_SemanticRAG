ns1:NoElSentidoPositivoDelEjeZEsHaciaAbajoYElNegativoHaciaArribaEjeZInver_30fb0d085b a ns1:Parametro ;
    rdfs:label "Control del gap",
        "No. El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap.",
        "Sí. El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap." ;
    ns1:identificador "GAPSENSORDELAY" ;
    ns1:textoExtracto "0. No. El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap.",
        "1. Sí. El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap.",
        "Valor. Significado." ;
    ns1:valor "0",
        "1" .

