@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCanalParaCSROT a ns1:Parametro ;
    rdfs:label "Número de canal para CSROT" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "Sintaxis. · ch· Número de canal." .

ns1:VariableRelacionadaConLaOpcionCSROT a ns1:Parametro ;
    rdfs:label "Variable relacionada con la opción CSROT" ;
    ns1:identificador "CSROT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

