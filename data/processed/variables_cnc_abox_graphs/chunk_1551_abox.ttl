@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableConNombreMyvar a ns1:Parametro ;
    rdfs:label "Variable con nombre 'myvar'" ;
    ns1:identificador "V.P.myvar" ;
    ns1:textoExtracto "\"V.P.myvar\" Variable con nombre \"myvar\"." .

