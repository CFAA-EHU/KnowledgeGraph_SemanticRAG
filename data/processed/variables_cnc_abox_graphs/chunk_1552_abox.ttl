@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SentenciaParaEliminarVariablesDeUsuario a ns1:Parametro ;
    rdfs:label "Sentencia para eliminar variables de usuario"@es ;
    ns1:identificador "# DELETE V.S.myvar1 V.S.myvar2" ;
    ns1:textoExtracto "\"# DELETE V.S.myvar1 V.S.myvar2\""@es .

ns1:VariableConNombreMyvar_20c883dd3f a ns1:Parametro ;
    rdfs:label "Variable con nombre 'myvar'"@es ;
    ns1:identificador "V.S.myvar" ;
    ns1:textoExtracto "\"V.S.myvar | Variable con nombre 'myvar'.\""@es .

