@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarAlCuartoElementoDelArrayElValor100 a ns1:Parametro ;
    rdfs:label "Asignar al cuarto elemento del array el valor 100",
        "Variable de usuario para el programa y las subrutinas locales" ;
    ns1:identificador "V.P.myvar[4]" ;
    ns1:textoExtracto "Definir la variable (primera vez que se usa). • Variable con nombre \"myvar\". • Variable de array de cuatro elementos.",
        "Una vez que la variable está definida. • Variable con nombre \"myvar\". • Asignar al cuarto elemento del array el valor 100." .

