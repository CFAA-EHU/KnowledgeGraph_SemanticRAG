@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CuartoElementoDelArrayDeLaVariableMyvar a ns1:Parametro ;
    rdfs:label "Cuarto elemento del array de la variable myvar" ;
    ns1:identificador "myvar[4]" ;
    ns1:textoExtracto "Asignar al cuarto elemento del array el valor 100." .

ns1:SentenciaDelete a ns1:AccionProhibida ;
    rdfs:label "#DELETE" ;
    ns1:textoExtracto "Las variables se eliminan cuando se apaga el CNC, o también se pueden eliminar desde el programa pieza mediante la sentencia #DELETE. # DELETE V.S.myvar1 V.S.myvar2" .

ns1:VariableDeUsuarioParaLaSesionDeCNC a ns1:Parametro ;
    rdfs:label "Variable de usuario para la sesión de CNC" ;
    ns1:identificador "myvar" ;
    ns1:textoExtracto "Definir la variable (primera vez que se usa). • Variable con nombre \"myvar\"." .

