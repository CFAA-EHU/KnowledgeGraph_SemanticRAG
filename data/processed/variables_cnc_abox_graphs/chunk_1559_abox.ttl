@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReleAbierto a ns1:Parametro ;
    rdfs:label "Relé abierto" ;
    ns1:identificador "G.ERELAYST=0" ;
    ns1:textoExtracto "Valor 0 significa Relé abierto." .

ns1:ReleCerrado a ns1:Parametro ;
    rdfs:label "Relé cerrado" ;
    ns1:identificador "G.ERELAYST=1" ;
    ns1:textoExtracto "Valor 1 significa Relé cerrado." .

ns1:VariableDeLecturaDesdeElProgramaPLCAsincronaEInterfaz a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC (asíncrona) e interfaz" ;
    ns1:identificador "G.ERELAYST" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

