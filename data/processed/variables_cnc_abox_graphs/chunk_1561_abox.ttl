@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveLaFecha_02523627b9 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve la fecha en formato año-mes-día."@es ;
    ns1:identificador "G.DATE" ;
    ns1:textoExtracto "V.G.DATE Valores de la variable. Si la fecha es \"25 de Abril de 1999\", el valor devuelto será 990425."@es .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveLaHoraE_63b38b42aa a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve la hora en formato horas-minutos-segundos."@es ;
    ns1:identificador "G.TIME" ;
    ns1:textoExtracto "V.G.TIME Valores de la variable. Si la hora es \"18h 22min 34seg\", el valor devuelto será 182234."@es .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveLosSegu_afa3163f38 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve los segundos desde que se encendió el CNC."@es ;
    ns1:identificador "G.CLOCK" ;
    ns1:textoExtracto "V.G.CLOCK Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Segundos desde que se encendió el CNC." .

