@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_ea3ba71e6f a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ns1:identificador "G.KEY" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Código de la última tecla aceptada por el CNC." .

ns1:VariableQuePermiteLeerElCodigoDeLaUltimaTeclaQueHaSidoAceptadaPorElCN_12685bf106 a ns1:Parametro ;
    rdfs:label "Variable que permite leer el código de la última tecla que ha sido aceptada por el CNC o bien simular el teclado desde el PLC escribiendo en ella el código de la tecla deseada" ;
    ns1:identificador "V.G.KEY" ;
    ns1:textoExtracto "Esta variable permite leer el código de la última tecla que ha sido aceptada por el CNC o bien simular el teclado desde el PLC escribiendo en ella el código de la tecla deseada." .

