@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelCNC_647497d1d2 a ns1:Parametro ;
    rdfs:label "Estado del CNC" ;
    ns1:identificador "V.2.G.FULLSTATUS" ;
    ns1:textoExtracto "V.[2].G.FULLSTATUS | Canal ·2·." ;
    ns1:tieneComponente ns1:InformacionDeEstado,
        ns1:SubestadoDelCNC .

ns1:InformacionDeEstado a ns1:Parametro ;
    rdfs:label "Información de estado" ;
    ns1:identificador "STATUS" ;
    ns1:textoExtracto "La variable contiene en su parte alta la información de la variable STATUS y en la parte baja el subestado del CNC;" .

ns1:SubestadoDelCNC a ns1:Parametro ;
    rdfs:label "Subestado del CNC" ;
    ns1:identificador "subestado" ;
    ns1:textoExtracto "La variable contiene en su parte alta la información de la variable STATUS y en la parte baja el subestado del CNC;" .

