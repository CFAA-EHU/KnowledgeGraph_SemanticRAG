@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnEjecucionBusquedaDeBloque a ns1:Parametro ;
    rdfs:label "En ejecución. Búsqueda de bloque." ;
    ns1:identificador "522" ;
    ns1:textoExtracto "522 | $20A | $200 En ejecución. | $0A Búsqueda de bloque." .

ns1:EnEjecucionChequeoSintactico a ns1:Parametro ;
    rdfs:label "En ejecución. Chequeo sintáctico." ;
    ns1:identificador "521" ;
    ns1:textoExtracto "521 | $209 | $200 En ejecución. | $09 Chequeo sintáctico." .

ns1:EnEjecucionEnPrograma a ns1:Parametro ;
    rdfs:label "En ejecución. En programa." ;
    ns1:identificador "515" ;
    ns1:textoExtracto "515 | $203 | $200 En ejecución. | $03 En programa." .

ns1:EnEjecucionEnSimulacion a ns1:Parametro ;
    rdfs:label "En ejecución. En simulación." ;
    ns1:identificador "525" ;
    ns1:textoExtracto "525 | $20D | $200 En ejecución. | $0D En simulación." .

ns1:EnEjecucionEstimacionDelTiempoDeEjecucion a ns1:Parametro ;
    rdfs:label "En ejecución. Estimación del tiempo de ejecución." ;
    ns1:identificador "524" ;
    ns1:textoExtracto "524 | $20C | $200 En ejecución. | $0C Estimación del tiempo de ejecución." .

ns1:EstadoDelCNC a ns1:Parametro ;
    rdfs:label "Estado del CNC" ;
    ns1:textoExtracto "Ejemplo de algunos valores de la variable FULLSTATUS." .

