@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValoresDeLaVariableGSELECTEDAXIS a ns1:Parametro ;
    rdfs:label "Valores de la variable G.SELECTEDAXIS" ;
    ns1:identificador "V.G.SELECTEDAXIS" ;
    ns1:textoExtracto "La variable devuelve un valor codificado en 32 bits, donde cada bit representa un eje; el bit de menos peso corresponde al eje con menor número lógico." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_f2fb4e8ebf a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.SELECTEDAXIS" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

