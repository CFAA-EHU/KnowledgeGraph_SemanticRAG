@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaConSubrutina a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia con subrutina" ;
    ns1:identificador "$10" ;
    ns1:textoExtracto "$10 Búsqueda de referencia con subrutina. La variable toma este valor al pulsar la tecla [ZERO] y lo mantiene hasta que el CNC vuelve al estado READY tras la búsqueda de referencia." .

ns1:BusquedaDeReferenciaDeUnEje a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia de un eje" ;
    ns1:identificador "$20" ;
    ns1:textoExtracto "$20 Búsqueda de referencia de un eje. La variable toma este valor al pulsar la tecla [ZERO] con un eje seleccionado y lo mantiene hasta que el CNC vuelve al estado READY tras la búsqueda de referencia." .

ns1:CalibracionManualDeHerramienta a ns1:Parametro ;
    rdfs:label "Calibración manual de herramienta" ;
    ns1:identificador "$4" ;
    ns1:textoExtracto "$4 Calibración manual de herramienta." .

ns1:CampoFSeleccionado a ns1:Parametro ;
    rdfs:label "Campo \"F\" seleccionado" ;
    ns1:identificador "$80" ;
    ns1:textoExtracto "$80 Campo \"F\" seleccionado. La variable quita el bit cuando el CNC vuelve al estado READY tras pulsar [START]." .

ns1:CampoSSeleccionado_c78128aaa3 a ns1:Parametro ;
    rdfs:label "Campo \"S\" seleccionado" ;
    ns1:identificador "$100" ;
    ns1:textoExtracto "$100 Campo \"S\" seleccionado." .

ns1:CampoTSeleccionado a ns1:Parametro ;
    rdfs:label "Campo \"T\" seleccionado" ;
    ns1:identificador "$40" ;
    ns1:textoExtracto "$40 Campo \"T\" seleccionado. La variable quita el bit cuando el CNC vuelve al estado READY tras pulsar [START]." .

ns1:CentradoDePiezaModeloFresadora a ns1:Parametro ;
    rdfs:label "Centrado de pieza (modelo fresadora)" ;
    ns1:identificador "$8" ;
    ns1:textoExtracto "$8 Centrado de pieza (modelo fresadora)." .

ns1:ModoManual a ns1:Parametro ;
    rdfs:label "Modo manual" ;
    ns1:identificador "$1" ;
    ns1:textoExtracto "$1 Modo manual." .

ns1:MovimientoEnJogOVolantes a ns1:Parametro ;
    rdfs:label "Movimiento en jog o volantes" ;
    ns1:identificador "$2" ;
    ns1:textoExtracto "$2 Movimiento en jog o volantes." .

