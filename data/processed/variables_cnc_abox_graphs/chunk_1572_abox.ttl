@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoCNCEX a ns1:Parametro ;
    rdfs:label "estado CNCEX" ;
    ns1:identificador "$20000000" ;
    ns1:textoExtracto "$20000000 | CNCEX." .

ns1:EstadoCNCReady a ns1:Parametro ;
    rdfs:label "estado READY" ;
    ns1:identificador "$0" ;
    ns1:textoExtracto "La variable quita el bit cuando el CNC vuelve al estado READY tras pulsar [START]." .

ns1:EstadoEjePreparado a ns1:Parametro ;
    rdfs:label "eje preparado para preselección de cotas o movimiento a una cota" ;
    ns1:identificador "$200" ;
    ns1:textoExtracto "$200 | Eje preparado para preselección de cotas o movimiento a una cota. Eje seleccionado y cota definida, a la espera de [ENTER] ó [START]." .

ns1:EstadoModoConversacionalCampoD a ns1:Parametro ;
    rdfs:label "modo conversacional, campo 'D' seleccionado" ;
    ns1:identificador "$400" ;
    ns1:textoExtracto "$400 | Modo conversacional. Campo \"D\" seleccionado." .

ns1:EstadoModoConversacionalCicloSeleccionado a ns1:Parametro ;
    rdfs:label "modo conversacional, ciclo seleccionado" ;
    ns1:identificador "$2000" ;
    ns1:textoExtracto "$2000 | Modo conversacional. Ciclo seleccionado." .

ns1:EstadoModoConversacionalEditorCiclos a ns1:Parametro ;
    rdfs:label "modo conversacional, editor de ciclos" ;
    ns1:identificador "$4000" ;
    ns1:textoExtracto "$4000 | Modo conversacional. Modo editor de ciclos." .

ns1:EstadoModoConversacionalGeneral a ns1:Parametro ;
    rdfs:label "modo conversacional general" ;
    ns1:identificador "$40000000" ;
    ns1:textoExtracto "$40000000 | CNC en modo conversacional." .

ns1:EstadoModoConversacionalProgramaSeleccionado a ns1:Parametro ;
    rdfs:label "modo conversacional, programa seleccionado" ;
    ns1:identificador "$1000" ;
    ns1:textoExtracto "$1000 | Modo conversacional. Programa seleccionado." .

ns1:EstadoModoConversacionalSoftkeyEjecutarCiclo a ns1:Parametro ;
    rdfs:label "modo conversacional, softkey 'Ejecutar Ciclo' pulsada" ;
    ns1:identificador "$8000" ;
    ns1:textoExtracto "$8000 | Modo conversacional. Softkey \"Ejecutar Ciclo\" pulsada." .

ns1:EstadoModoMDIMDA a ns1:Parametro ;
    rdfs:label "modo MDI/MDA" ;
    ns1:identificador "$10000000" ;
    ns1:textoExtracto "$10000000 | Modo MDI/MDA." .

ns1:VariableQueIndicaElEstadoDelCNCEnModoManual a ns1:Parametro ;
    rdfs:label "variable que indica el estado del CNC en modo manual" ;
    ns1:identificador "variable" ;
    ns1:textoExtracto "La variable quita el bit cuando el CNC vuelve al estado READY tras pulsar [START]." .

