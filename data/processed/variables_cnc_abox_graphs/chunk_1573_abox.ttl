@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5caf68dec1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC está ejecutando un bloque en MDI/MDA desde el modo manual." .

ns1:EstadoDelCNCEnModoManual a ns1:Parametro ;
    rdfs:label "Estado del CNC en modo manual",
        "Estado del CNC en modo manual - Búsqueda de referencia",
        "Estado del CNC en modo manual - Búsqueda interrumpida",
        "Estado del CNC en modo manual - Ejecución MDI/MDA" ;
    ns1:identificador "V.G.CNCMANSTATUS" ;
    ns1:textoExtracto "El CNC está ejecutando un bloque en MDI/MDA desde el modo manual. V.G.CNCMANSTATUS=$10000001",
        "Está activa la pantalla de calibración de herramienta. V.G.CNCMANSTATUS = $5",
        "Hay un proceso de búsqueda de referencia de un eje en marcha. V.G.CNCMANSTATUS = $21",
        "La búsqueda de referencia de un eje está interrumpida. V.G.CNCMANSTATUS = $21" .

ns1:EstadoGeneralDelCNC a ns1:Parametro ;
    rdfs:label "Estado general del CNC" ;
    ns1:identificador "V.G.STATUS" ;
    ns1:textoExtracto "Hay seleccionado un eje para la búsqueda de cero, pero no se ha pulsado [START]. V.G.STATUS = $1 (READY)" .

