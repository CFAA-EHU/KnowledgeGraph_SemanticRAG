@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueInicialSeleccionado a ns1:Parametro ;
    rdfs:label "Bloque inicial seleccionado" ;
    ns1:identificador "$2" ;
    ns1:textoExtracto "$2 | Bloque inicial seleccionado." .

ns1:BusquedaDeBloqueSeleccionada a ns1:Parametro ;
    rdfs:label "Búsqueda de bloque seleccionada" ;
    ns1:identificador "$10" ;
    ns1:textoExtracto "$10 | Está seleccionada la búsqueda de bloque." .

ns1:CNCEjecutandoUnaSubrutinaDeInterrupcion a ns1:Parametro ;
    rdfs:label "CNC ejecutando una subrutina de interrupción" ;
    ns1:identificador "$800" ;
    ns1:textoExtracto "$800 | El CNC está ejecutando una subrutina de interrupción." .

ns1:CondicionDeParadaSeleccionada a ns1:Parametro ;
    rdfs:label "Condición de parada seleccionada" ;
    ns1:identificador "$4" ;
    ns1:textoExtracto "$4 | Condición de parada seleccionada." .

ns1:EjeSeleccionadoParaLaReposicionDeEjes a ns1:Parametro ;
    rdfs:label "Eje seleccionado para la reposición de ejes" ;
    ns1:identificador "$400" ;
    ns1:textoExtracto "$400 | Hay algún eje seleccionado para la reposición de ejes." .

ns1:EjecucionSimuladaActivaRecorridoTeorico a ns1:Parametro ;
    rdfs:label "Ejecución simulada activa. Recorrido teórico" ;
    ns1:identificador "$1000" ;
    ns1:textoExtracto "$1000 | Está activa la ejecución simulada. Recorrido teórico." .

ns1:InspeccionDeHerramientaSeleccionada a ns1:Parametro ;
    rdfs:label "Inspección de herramienta seleccionada" ;
    ns1:identificador "$80" ;
    ns1:textoExtracto "$80 | Está seleccionada la inspección de herramienta." .

ns1:ModoAutomaticoOModoMDIMDASobreElModoAutomatico a ns1:Parametro ;
    rdfs:label "Modo automático o modo MDI/MDA sobre el modo automático" ;
    ns1:identificador "$1" ;
    ns1:textoExtracto "$1 | Modo automático o modo MDI/MDA sobre el modo automático." .

ns1:OpcionCancelarYContinuarActiva a ns1:Parametro ;
    rdfs:label "Opción cancelar y continuar activa" ;
    ns1:identificador "$100" ;
    ns1:textoExtracto "$100 | Está activa la opción cancelar y continuar." .

ns1:OpcionDeEjecutarLosBloquesDelProgramaDeFormaIndependienteSoftkeyEXBLK a ns1:Parametro ;
    rdfs:label "Opción de ejecutar los bloques del programa de forma independiente (softkey EXBLK)" ;
    ns1:identificador "$8" ;
    ns1:textoExtracto "$8 | Está activa la opción de ejecutar los bloques del programa de forma independiente (softkey EXBLK)." .

ns1:ReposicionDeEjesSeleccionadaParaBusquedaDeBloqueOInspeccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Reposición de ejes seleccionada (para búsqueda de bloque o inspección de herramienta)" ;
    ns1:identificador "$200" ;
    ns1:textoExtracto "$200 | Está seleccionada la reposición de ejes (para la búsqueda de bloque o la inspección de herramienta)." .

ns1:SeleccionDeFuncionesMHFSDuranteLaInspeccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Selección de funciones M H F S durante la inspección de herramienta" ;
    ns1:identificador "$40" ;
    ns1:textoExtracto "$40 | Está activa la selección de funciones M H F S (durante la inspección de herramienta)." .

ns1:VisualizacionDeFuncionesMHFSDuranteLaBusquedaDeBloqueOInspeccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Visualización de funciones M H F S durante la búsqueda de bloque o inspección de herramienta" ;
    ns1:identificador "$20" ;
    ns1:textoExtracto "$20 | Está seleccionada la visualización de funciones M H F S (durante la búsqueda de bloque o la inspección de herramienta)." .

