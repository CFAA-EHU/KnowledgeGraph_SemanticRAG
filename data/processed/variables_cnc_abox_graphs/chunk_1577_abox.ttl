@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EditorDeCiclosEjecutandoUnCiclo a ns1:Parametro ;
    rdfs:label "Editor de ciclos ejecutando un ciclo." ;
    ns1:identificador "40000" ;
    ns1:textoExtracto "$40000 | El editor de ciclos está ejecutando un ciclo." .

ns1:EditorDeCiclosSimulandoUnCiclo a ns1:Parametro ;
    rdfs:label "Editor de ciclos simulando un ciclo." ;
    ns1:identificador "80000" ;
    ns1:textoExtracto "$80000 | El editor de ciclos está simulando un ciclo." .

ns1:EjecucionSimuladaFuncionesG a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Funciones G." ;
    ns1:identificador "2000" ;
    ns1:textoExtracto "$2000 | Está activa la ejecución simulada. Funciones G." .

ns1:EjecucionSimuladaFuncionesGMST a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Funciones GMST." ;
    ns1:identificador "4000" ;
    ns1:textoExtracto "$4000 | Está activa la ejecución simulada. Funciones GMST." .

ns1:EjecucionSimuladaPlanoPrincipal a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Plano principal." ;
    ns1:identificador "8000" ;
    ns1:textoExtracto "$8000 | Está activa la ejecución simulada. Plano principal." .

ns1:EjecucionSimuladaRapido a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Rápido." ;
    ns1:identificador "10000" ;
    ns1:textoExtracto "$10000 | Está activa la ejecución simulada. Rápido." .

ns1:EjecucionSimuladaRapidoS0 a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Rápido S=0." ;
    ns1:identificador "20000" ;
    ns1:textoExtracto "$20000 | Está activa la ejecución simulada. Rápido S=0." .

ns1:EjecucionSimuladaRecorridoTeorico a ns1:Parametro ;
    rdfs:label "Ejecución simulada. Recorrido teórico." ;
    ns1:identificador "1000" ;
    ns1:textoExtracto "$1000 | Está activa la ejecución simulada. Recorrido teórico." .

ns1:ModoMDIMDAActivoSobreElModoAutomatico a ns1:Parametro ;
    rdfs:label "Modo MDI/MDA activo sobre el modo automático." ;
    ns1:identificador "10000000" ;
    ns1:textoExtracto "$10000000 | Modo MDI/MDA activo sobre el modo automático." .

ns1:PLCEjecutandoUnComandoCNCEX a ns1:Parametro ;
    rdfs:label "PLC ejecutando un comando CNCEX." ;
    ns1:identificador "20000000" ;
    ns1:textoExtracto "$20000000 | El PLC está ejecutando un comando CNCEX." .

ns1:RetiradaDeRoscaDesdeSTOPHastaSTARTParaContinuar a ns1:Parametro ;
    rdfs:label "Retirada de rosca (desde [STOP] hasta [START] para continuar)." ;
    ns1:identificador "100000" ;
    ns1:textoExtracto "$100000 | Retirada de rosca (desde [STOP] hasta [START] para continuar)." .

