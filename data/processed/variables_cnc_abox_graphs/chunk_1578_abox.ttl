@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelCNCEnModoAutomatico a ns1:Parametro ;
    rdfs:label "Estado del CNC en modo automático" ;
    ns1:identificador "V.G.CNCAUTSTATUS" ;
    ns1:textoExtracto "$1, $81, $681" .

ns1:EstadoGeneralDeEjecucion a ns1:Parametro ;
    rdfs:label "Estado general de ejecución" ;
    ns1:identificador "V.G.STATUS" ;
    ns1:textoExtracto "$2 (EN EJECUCIÓN), $4 (INTERRUMPIDO)" .

ns1:EstadoManualDelCNC a ns1:Parametro ;
    rdfs:label "Estado manual del CNC" ;
    ns1:identificador "V.G.CNCMANSTATUS" ;
    ns1:textoExtracto "$2" .

