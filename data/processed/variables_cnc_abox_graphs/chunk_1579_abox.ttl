@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeEjecucionDelBloqueMDIMDA a ns1:Parametro ;
    rdfs:label "Estado de ejecución del bloque MDI/MDA",
        "Estado de interrupción del bloque MDI/MDA" ;
    ns1:identificador "V.G.STATUS" ;
    ns1:textoExtracto "V.G.STATUS = $2 (EN EJECUCIÓN)",
        "V.G.STATUS = $4 (INTERRUMPIDO)" ;
    ns1:valor "$2",
        "$4" .

ns1:EstadoDetalladoDelCNCEnElModoAutomatico a ns1:Parametro ;
    rdfs:label "Estado detallado del CNC en el modo automático" ;
    ns1:identificador "V.G.CNCAUTSTATUS" ;
    ns1:textoExtracto "V.G.CNCAUTSTATUS = $10000001" .

