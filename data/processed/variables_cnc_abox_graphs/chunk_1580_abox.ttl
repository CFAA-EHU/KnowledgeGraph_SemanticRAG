@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelProgramaEnEjecucion_c34ae49567 a ns1:Parametro ;
    rdfs:label "Nombre del programa en ejecución" ;
    ns1:identificador "G.FILENAME" ;
    ns1:textoExtracto "\"(V.)[ch].G.FILENAME Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Nombre del programa en ejecución.\"" .

ns1:NumeroDeLineaSobreLaQueSeEncuentraElCursor_ed3ca717bf a ns1:Parametro ;
    rdfs:label "Número de línea sobre la que se encuentra el cursor" ;
    ns1:identificador "G.CURSORLINE" ;
    ns1:textoExtracto "\"(V.)[ch].G.CURSORLINE Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Número de línea sobre la que se encuentra el cursor.\"" .

ns1:PathDelProgramaEnEjecucion_d315342571 a ns1:Parametro ;
    rdfs:label "Path del programa en ejecución" ;
    ns1:identificador "G.PRGPATH" ;
    ns1:textoExtracto "\"(V.)[ch].G.PRGPATH Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Path del programa en ejecución.\"" .

ns1:ValorDeLaPreparacionDeBloques_73b84004a3 a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques" ;
    ns1:identificador "G.FILEOFFSET" ;
    ns1:textoExtracto "\"(V.)[ch].G.FILEOFFSET Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques.\"" .

