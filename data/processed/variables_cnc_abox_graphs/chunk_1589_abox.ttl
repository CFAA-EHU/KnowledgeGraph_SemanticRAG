@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoDeEjecucionDelPrograma a ns1:Parametro ;
    rdfs:label "Tiempo de ejecución del programa" ;
    ns1:identificador "V[2].G.CYTIME" ;
    ns1:textoExtracto "Esta variable toma valor 0 con cada nueva ejecución, incluso del mismo programa. No cuenta el tiempo que dicha ejecución pudo estar detenida." .

