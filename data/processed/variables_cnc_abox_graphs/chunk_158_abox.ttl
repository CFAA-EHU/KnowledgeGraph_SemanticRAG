@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DimensionesDeLaHerramienta a ns1:Herramienta ;
    rdfs:label "Dimensiones de la herramienta" ;
    ns1:textoExtracto "Las dimensiones de las herramientas de tornear se definen mediante estos offsets; para las dimensiones del resto de las herramientas se pueden utilizar bien estos offsets o bien la longitud y el radio." .

ns1:ValoresDeLaVariableMPGTOOLOFSG a ns1:Parametro ;
    rdfs:label "Valores de la variable MPG.TOOLOFSG" ;
    ns1:identificador "V.MPG.TOOLOFSG" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_ebc044501e a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:documentadoEn ns1:InterfazUsuarioOffsets ;
    ns1:identificador "MPG.TOOLOFSG" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Criterio de signos a aplicar a los offsets y al desgaste de herramienta." .

ns1:InterfazUsuarioOffsets a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para offsets y desgaste de herramienta" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Criterio de signos a aplicar a los offsets y al desgaste de herramienta." .

