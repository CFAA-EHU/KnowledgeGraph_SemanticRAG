@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeLaFuncionBloqueABloque a ns1:TareaMantenimiento ;
    rdfs:label "Activación de la función bloque a bloque" ;
    ns1:textoExtracto "La función bloque a bloque se puede activar y desactivar desde el teclado o desde el PLC (marca SBLOCK)." .

ns1:SistemaInterfaz a ns1:Sistema ;
    rdfs:label "Interfaz" ;
    ns1:documentadoEn ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_33d5ff5c72 ;
    ns1:textoExtracto "Variable de lectura y escritura desde el interfaz;" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:documentadoEn ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPLC_feede6f366 ;
    ns1:textoExtracto "La función bloque a bloque se puede activar y desactivar desde el teclado o desde el PLC (marca SBLOCK)." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_33d5ff5c72 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.SBOUT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPLC_feede6f366 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC" ;
    ns1:identificador "G.SBLOCK" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

