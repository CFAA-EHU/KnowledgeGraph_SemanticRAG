@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_5347861eee a ns1:Parametro ;
    rdfs:label "Marca MANRAPID para función avance rápido" ;
    ns1:identificador "MANRAPID" ;
    ns1:textoExtracto "La función avance rápido se selecciona desde el PLC mediante la marca MANRAPID." .

ns1:Parametro_c5ed9c2cf3 a ns1:Parametro ;
    rdfs:label "Marca M01STOP para función parada condicional" ;
    ns1:identificador "M01STOP" ;
    ns1:textoExtracto "La función parada condicional se activa desde el PLC mediante la marca M01STOP." .

ns1:VariableDeLecturaYEscrituraParaAvanceRapido a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura para avance rápido" ;
    ns1:identificador "RAPID" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

