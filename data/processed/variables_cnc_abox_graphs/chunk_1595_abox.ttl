@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaInterfaz a ns1:Sistema ;
    rdfs:label "Interfaz" ;
    ns1:textoExtracto "\"Variable de lectura y escritura desde el programa, PLC e interfaz.\"" ;
    ns1:tieneComponente ns1:VariableDeLecturaDesdeElInterfazModoEnElQueSeEncuentraElInterfaz,
        ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazNombreDelProgra_5a311a78f3 .

ns1:VariableDeLecturaDesdeElInterfazModoEnElQueSeEncuentraElInterfaz a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz. Modo en el que se encuentra el interfaz" ;
    ns1:identificador "E.MMCMODE" ;
    ns1:textoExtracto "\"(V.)[ch].E.MMCMODE Variable de lectura desde el interfaz. Modo en el que se encuentra el interfaz.\"" .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazNombreDelProgra_5a311a78f3 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz. Nombre del programa seleccionado en automático" ;
    ns1:identificador "E.PROGSELECT" ;
    ns1:textoExtracto "\"(V.)[ch].E.PROGSELECT Variable de lectura y escritura desde el programa, PLC e interfaz.\"" .

