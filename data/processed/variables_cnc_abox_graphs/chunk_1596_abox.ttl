@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDeOperacionDelCNC a ns1:Parametro ;
    rdfs:label "Modo de operación del CNC" ;
    ns1:identificador "E.MMCMODE" ;
    ns1:textoExtracto "[2].E.MMCMODE Canal ·2·." .

ns1:ModoManualExclusivoActivo a ns1:Parametro ;
    rdfs:label "Modo manual exclusivo activo" ;
    ns1:identificador "E.MANUALMODE" ;
    ns1:textoExtracto "(V.)[ch].E.MANUALMODE Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Modo manual exclusivo activo." .

ns1:NumeroDeErroresEnElCNC a ns1:Parametro ;
    rdfs:label "Número de errores en el CNC" ;
    ns1:identificador "E.NERRORS" ;
    ns1:textoExtracto "(V.)E.NERRORS Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Número de errores en el CNC." .

ns1:PrioridadDelError a ns1:Parametro ;
    rdfs:label "Prioridad del error" ;
    ns1:identificador "E.ERRORPRI" ;
    ns1:textoExtracto "(V.)E.ERRORPRI Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Prioridad del error." .

