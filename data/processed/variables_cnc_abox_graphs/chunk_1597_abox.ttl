ns1:NumeroDePanelesDeJog a ns1:Parametro ;
    rdfs:label "Número de paneles de jog" ;
    ns1:identificador "E.NUMJOGPANELS" ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Número de paneles de jog." .

ns1:Parametro_c55d198c7b a ns1:Parametro ;
    rdfs:label "Marca del fichero de ayuda que corresponde a la página de ayuda" ;
    ns1:identificador "E.HELPDATA" ;
    ns1:textoExtracto "Variable de lectura y escritura desde el interfaz. Variable de report (para uso desde los scripts). Marca del fichero de ayuda que corresponde a la página de ayuda." .

ns1:PathDelProgramaSeleccionadoEnAutomatico_a012f5f95a a ns1:Parametro ;
    rdfs:label "Path del programa seleccionado en automático" ;
    ns1:identificador "E.PATHSELECT" ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Path del programa seleccionado en automático." .

ns1:ResultadoDeLaCalculadora a ns1:Parametro ;
    rdfs:label "Resultado de la calculadora" ;
    ns1:identificador "E.CALCRESULT" ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Variable de report (para uso desde los scripts). Resultado de la calculadora." .

ns1:TextoDelMensajeProgramadoEnLaSentenciaMSG_373fc9b348 a ns1:Parametro ;
