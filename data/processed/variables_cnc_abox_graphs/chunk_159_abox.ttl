@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiElCNCCancelaLaSincronizacionDeCabezales a ns1:Parametro ;
    rdfs:label "Indica si el CNC cancela la sincronización de cabezales" ;
    ns1:identificador "V.MPG.SYNCCANCEL" ;
    ns1:textoExtracto "V.MPG.SYNCCANCEL Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_2c749ded2d a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.SYNCCANCEL" ;
    ns1:textoExtracto "V.MPG.SYNCCANCEL Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." .

