ns1:CNC8070_08b289010a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address). El primer panel de jog será el de numeración más baja y así sucesivamente." .

