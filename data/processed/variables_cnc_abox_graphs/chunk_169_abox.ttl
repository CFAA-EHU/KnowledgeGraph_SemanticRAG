@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionGeometricaDeLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Configuración geométrica de los ejes del canal" ;
    ns1:identificador "MPG.GEOCONFIG" ;
    ns1:textoExtracto "V.[2].MPG.GEOCONFIG | Canal ·2·." .

ns1:EjeConIndice1EnElCanal_29a083dce3 a ns1:Parametro ;
    rdfs:label "Eje con índice 1 en el canal" ;
    ns1:identificador "MPG.CHAXISNAME4" ;
    ns1:textoExtracto "[2].MPG.CHAXISNAME4 | Eje con índice ·1· en el canal ·2·." .

ns1:TablaConfiguracionEjes a ns1:Tabla ;
    rdfs:label "Valores de la variable MPG.GEOCONFIG" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores. | Valor. | Significado." ;
    ns1:tieneComponente ns1:ConfiguracionDeEjesTipoPlano_44c9ce801b,
        ns1:ConfiguracionDeEjesTipoTriedro_cc52a8b99a .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_d76c316d51 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.MPG.GEOCONFIG" ;
    ns1:textoExtracto "(V.)[ch].MPG.GEOCONFIG Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:ConfiguracionDeEjesTipoPlano_44c9ce801b a ns1:Parametro ;
    rdfs:label "Configuración de ejes tipo 'plano'" ;
    ns1:identificador "MPG.GEOCONFIG=0" ;
    ns1:textoExtracto "0 | Configuración de ejes tipo 'plano'." .

ns1:ConfiguracionDeEjesTipoTriedro_cc52a8b99a a ns1:Parametro ;
    rdfs:label "Configuración de ejes tipo 'triedro'" ;
    ns1:identificador "MPG.GEOCONFIG=1" ;
    ns1:textoExtracto "1 | Configuración de ejes tipo 'triedro'." .

