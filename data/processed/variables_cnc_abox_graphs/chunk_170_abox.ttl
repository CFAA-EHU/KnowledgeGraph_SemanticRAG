@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaConfiguracionPlano a ns1:Sistema ;
    rdfs:label "Tipo plano" ;
    ns1:textoExtracto "En esta configuración se dispone de dos ejes formando el habitual plano de trabajo." .

ns1:SistemaConfiguracionTriedro a ns1:Sistema ;
    rdfs:label "Tipo triedro" ;
    ns1:textoExtracto "En esta configuración se dispone de tres ejes formando un triedro cartesiano tipo XYZ como en una fresadora." .

