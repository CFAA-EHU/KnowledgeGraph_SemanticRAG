@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelCabezal1DelCanal a ns1:Parametro ;
    rdfs:label "Nombre del cabezal 1 del canal" ;
    ns1:identificador "MPG.CHSPDLNAME1" ;
    ns1:textoExtracto "Cabezal con índice ·1· en el canal ·2·." .

ns1:SistemaInterfazUsuario a ns1:Sistema ;
    rdfs:label "Interfaz de usuario para configuración de cabezales del canal" ;
    ns1:textoExtracto "Variable de lectura desde el interfaz. Canal [ch]." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_2fc32a3733 a ns1:Parametro ;
