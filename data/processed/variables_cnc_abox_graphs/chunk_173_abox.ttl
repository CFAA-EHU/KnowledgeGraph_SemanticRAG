@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlineamientoDelEjeCParaMecanizadoDiametral a ns1:Parametro ;
    rdfs:label "Alineamiento del eje C para mecanizado diametral" ;
    ns1:identificador "MPG.ALIGNC" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.ALIGNC Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques.\"" .

ns1:NombreDelEjeQueTrabajaraComoEjeC a ns1:Parametro ;
    rdfs:label "Nombre del eje que trabajará como eje C" ;
    ns1:identificador "MPG.CAXNAME" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.CAXNAME Variable de lectura desde el interfaz. Canal [ch]. Nombre del eje que trabajará como eje C (por defecto).\"" .

