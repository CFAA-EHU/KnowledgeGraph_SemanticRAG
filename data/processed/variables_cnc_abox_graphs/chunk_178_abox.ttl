@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDelFiltroEnModoCONTERROR a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro en modo CONTERROR" ;
    ns1:identificador "V.[2].MPG.HSCFILTFREQ" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.HSCFILTFREQ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Frecuencia del filtro (modo CONTERROR). Sintaxis. · ch· Número de canal.\"" .

ns1:Parametro_9eecf1d194 a ns1:Parametro ;
    rdfs:label "Canal de configuración del modo HSC" ;
    ns1:identificador "V.[2].MPG.CORNER" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.HSCFILTFREQ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Frecuencia del filtro (modo CONTERROR). Sintaxis. · ch· Número de canal.\"" .

