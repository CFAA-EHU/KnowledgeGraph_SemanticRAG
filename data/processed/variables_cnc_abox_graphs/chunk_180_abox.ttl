@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacionDelCanal a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación del canal" ;
    ns1:identificador "V.2.MPG.FSMOOTHFREQ" ;
    ns1:textoExtracto "(V.)[ch].MPG.FSMOOTHFREQ Variable de lectura desde el programa, PLC e interfaz." .

ns1:FrecuenciaDelFiltroRapidoDelCanal a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro rápido del canal" ;
    ns1:identificador "V.2.MPG.FASTFILTFREQ" ;
    ns1:textoExtracto "(V.)[ch].MPG.FASTFILTFREQ Variable de lectura desde el programa, PLC e interfaz." .

ns1:TiempoLimiteDelCanal a ns1:Parametro ;
    rdfs:label "Tiempo límite del canal" ;
    ns1:identificador "V.2.MPG.FTIMELIM" ;
    ns1:textoExtracto "V.[2].MPG.FTIMELIM | Canal ·2·." .

ns1:VelocidadMinimaEnLasEsquinasDelCanal a ns1:Parametro ;
    rdfs:label "Velocidad mínima en las esquinas del canal" ;
    ns1:identificador "V.2.MPG.MINCORFEED" ;
    ns1:textoExtracto "(V.)[ch].MPG.MINCORFEED Variable de lectura desde el programa, PLC e interfaz." .

