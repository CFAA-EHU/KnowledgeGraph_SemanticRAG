@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionRedondeoHSC a ns1:Parametro ;
    rdfs:label "Configuración redondeo HSC" ;
    ns1:identificador "V.MPG.HSCROUND" ;
    ns1:textoExtracto "(V.)[ch].MPG.HSCROUND Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]." .

ns1:FrecuenciaDeResonanciaDelCanal a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia del canal" ;
    ns1:identificador "V.MPG.FREQRES" ;
    ns1:textoExtracto "(V.)[ch].MPG.FREQRES Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]." .

ns1:FrecuenciaDelFiltroDeTrayectoriaParaPerfilesDeAceleracionLineal a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal" ;
    ns1:identificador "V.MPG.SOFTFREQ" ;
    ns1:textoExtracto "(V.)[ch].MPG.SOFTFREQ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Frecuencia del filtro de trayectoria para perfiles de aceleración lineal." .

ns1:PrimeraFrecuenciaDeResonanciaDeLaMaquina a ns1:Parametro ;
    rdfs:label "Primera frecuencia de resonancia de la máquina" ;
    ns1:identificador "V.MPG.FASTFILTFREQ" ;
    ns1:textoExtracto "(V.)[ch].MPG.FASTFILTFREQ Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Canal [ch]. Primera frecuencia de resonancia de la máquina." .

