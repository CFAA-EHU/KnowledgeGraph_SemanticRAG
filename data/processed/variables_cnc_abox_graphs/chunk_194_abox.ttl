@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_286ebb57d7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:InterfazUsuarioCanalMPG ;
    ns1:textoExtracto "El CNC aplica siempre la aceleración lineal en modo manual." .

ns1:TipoDeAceleracionPorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto" ;
    ns1:identificador "MPG.SLOPETYPE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto." .

ns1:TipoDeAceleracionPorDefectoDelCanal2 a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto del canal 2" ;
    ns1:identificador "V.2.MPG.SLOPETYPE" ;
    ns1:textoExtracto "Canal ·2·." .

ns1:InterfazUsuarioCanalMPG a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de canal MPG" ;
    ns1:textoExtracto "Variable modificable desde el entorno de puesta a punto. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

