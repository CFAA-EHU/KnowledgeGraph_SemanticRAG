@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCanalPorDefecto a ns1:Parametro ;
    rdfs:label "Número de canal por defecto" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "El canal asume el valor por defecto en el momento de encendido, después de ejecutarse M02, M30 o después de reset." .

ns1:TipoDeAvance a ns1:Parametro ;
    rdfs:label "Tipo de avance" ;
    ns1:textoExtracto "Para cambiar el tipo de avance desde el programa pieza utilizar las funciones G93, G94 ó G95." .

