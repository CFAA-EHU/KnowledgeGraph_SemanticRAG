@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDeAlimentacionPorMinutoG94 a ns1:Parametro ;
    rdfs:label "Modo de alimentación por minuto (G94)" ;
    ns1:identificador "V.2.MPG.IFEED=0" ;
    ns1:textoExtracto "0 | G94." .

ns1:ModoDeAlimentacionPorRevolucionG95 a ns1:Parametro ;
    rdfs:label "Modo de alimentación por revolución (G95)" ;
    ns1:identificador "V.2.MPG.IFEED=1" ;
    ns1:textoExtracto "1 | G95." .

ns1:Parametro_f855f97c79 a ns1:Parametro ;
    rdfs:label "Canal de función para la lectura del modo de alimentación" ;
    ns1:identificador "V.2.MPG.IFEED" ;
    ns1:textoExtracto "Valores de la variable. Esta variable devuelve uno de los siguientes valores." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaPreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la preparación de bloques" ;
    ns1:identificador "V.2.MPG.FPRMAN" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaMantenerElEjeLongitud_4c5b40115a a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para mantener el eje longitudinal al cambiar de plano" ;
    ns1:identificador "V.2.MPG.LCOMPTYP" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

