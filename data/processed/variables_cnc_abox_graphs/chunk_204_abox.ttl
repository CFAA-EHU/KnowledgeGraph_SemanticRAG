@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_39bffbda64 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC mantiene el plano principal activo después de ejecutar M02 ó M30, y después de un reset." .

ns1:PlanoDefinidoEnElParametroIPLANE a ns1:Parametro ;
    rdfs:label "Plano definido en el parámetro IPLANE" ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "En el momento del encendido, el CNC asume el plano definido en el parámetro IPLANE." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_3230854e20 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.ICORNER" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]. Tipo de arista (G5/G7/G50) por defecto." .

