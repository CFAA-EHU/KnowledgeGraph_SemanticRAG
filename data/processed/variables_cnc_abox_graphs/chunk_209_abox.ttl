@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDelTipoDeRedondeo a ns1:TareaMantenimiento ;
    rdfs:label "Configuración del tipo de redondeo" ;
    ns1:solucionaFallo ns1:ErrorEnLaConfiguracionDelRedondeo ;
    ns1:textoExtracto "Para cambiar el tipo de redondeo desde el programa utilizar la sentencia #ROUNDPAR." .

ns1:ErrorCordal a ns1:Parametro ;
    rdfs:label "Error cordal" ;
    ns1:identificador "ROUNDPAR [1]" ;
    ns1:textoExtracto "El error cordal (#ROUNDPAR [1]) define la desviación máxima permitida entre el punto programado y el perfil resultante." .

ns1:Parametro_3493085cd3 a ns1:Parametro ;
    rdfs:label "Avance" ;
    ns1:identificador "ROUNDPAR [2]" ;
    ns1:textoExtracto "El avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado." .

ns1:SistemaInterfazUsuario a ns1:Sistema ;
    rdfs:label "Interfaz de usuario" ;
    ns1:documentadoEn ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_77d0fdc146 ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]." .

ns1:ErrorEnLaConfiguracionDelRedondeo a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la configuración del redondeo" ;
    ns1:textoExtracto "Error en la configuración del redondeo" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_77d0fdc146 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.ROUNDTYPE" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

