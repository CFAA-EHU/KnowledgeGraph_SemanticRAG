ns1:NoElAvanceProgramadoSoloSeAplicaALosEjesPrincipales a ns1:Parametro ;
    rdfs:label "No. El avance programado sólo se aplica a los ejes principales." ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 | No. El avance programado sólo se aplica a los ejes principales." .

ns1:SiElAvanceProgramadoSeAplicaATodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Sí. El avance programado se aplica a todos los ejes del canal." ;
    ns1:identificador "1" ;
    ns1:textoExtracto "1 | Sí. El avance programado se aplica a todos los ejes del canal." .

