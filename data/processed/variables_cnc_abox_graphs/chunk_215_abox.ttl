ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_73020b5dbd a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.FEEDND" ;
