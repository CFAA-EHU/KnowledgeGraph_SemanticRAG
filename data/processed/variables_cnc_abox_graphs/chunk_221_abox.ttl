@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElInterfazParaSubrutinaAsociadaAlComandoCUTTINGOFF a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para subrutina asociada al comando #CUTTING OFF" ;
    ns1:identificador "MPG.CUTTINGOFF" ;
    ns1:textoExtracto "(V.)[ch].MPG.CUTTINGOFF Variable de lectura desde el interfaz. Unidades: Texto." .

ns1:VariableDeLecturaDesdeElInterfazParaSubrutinaAsociadaAlComandoCUTTINGON a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para subrutina asociada al comando #CUTTING ON" ;
    ns1:identificador "MPG.CUTTINGON" ;
    ns1:textoExtracto "(V.)[ch].MPG.CUTTINGON Variable de lectura desde el interfaz. Unidades: Texto." .

