    ns1:identificador "MPG.FINALSUB" ;
    ns1:textoExtracto "(V.)[ch].MPG.FINALSUB Variable de lectura desde el interfaz. Unidades: Texto." .

ns1:VariableDeLecturaDesdeElInterfazParaSubrutinaAsociadaAlComandoPIERCING a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el interfaz para subrutina asociada al comando #PIERCING" ;
