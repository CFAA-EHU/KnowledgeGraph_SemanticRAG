@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaAsociadaAFuncionesG180 a ns1:Parametro ;
    rdfs:label "Subrutina asociada a funciones G180" ;
    ns1:identificador "MPG.OEMSUB1" ;
    ns1:textoExtracto "(V.)[ch].MPG.OEMSUB1 (V.)[ch].MPG.OEMSUB10 Variable de lectura desde el interfaz. Canal [ch]." .

ns1:SubrutinaAsociadaAFuncionesG189 a ns1:Parametro ;
    rdfs:label "Subrutina asociada a funciones G189" ;
    ns1:identificador "MPG.OEMSUB10" ;
    ns1:textoExtracto "(V.)[ch].MPG.OEMSUB1 (V.)[ch].MPG.OEMSUB10 Variable de lectura desde el interfaz. Canal [ch]." .

ns1:SubrutinaAsociadaAlComandoFINALSUB a ns1:Parametro ;
