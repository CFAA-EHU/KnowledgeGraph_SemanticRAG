@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivacionDelAvanceRapidoEnModoAutomatico a ns1:AccionProhibida ;
    rdfs:label "Desactivación del avance rápido en modo automático" ;
    ns1:documentadoEn ns1:ConfiguracionDeAvanceRapido ;
    ns1:textoExtracto "El avance rápido no está disponible para el modo automático." .

ns1:InterfazUsuarioJogPanel a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog" ;
    ns1:textoExtracto "tecla \"rápido\" del panel de jog." .

ns1:Parametro_9237f6b4e9 a ns1:Parametro ;
    rdfs:label "Parámetro de avance rápido" ;
    ns1:identificador "RAPIDEN" ;
    ns1:textoExtracto "Si el parámetro se define con valor ·0·, no se limita el avance. Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "activar la marca EXRAPID de PLC" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_04b80717bd a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPG.FRAPIDEN" ;
    ns1:textoExtracto "Canal [ch]. Avance rápido en el canal, cuando está activo el avance rápido para el modo automático (parámetro RAPIDEN)." .

ns1:ConfiguracionDeAvanceRapido a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de avance rápido" ;
    ns1:textoExtracto "Para activar el avance rápido sólo es necesario activar la marca EXRAPID de PLC o pulsar la tecla \"rápido\" del panel de jog." .

