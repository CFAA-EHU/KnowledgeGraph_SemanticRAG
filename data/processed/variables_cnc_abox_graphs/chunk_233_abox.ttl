@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceParaDesplazamientosProgramadosEnG00 a ns1:Parametro ;
    rdfs:label "Avance para desplazamientos programados en G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED." .

ns1:AvanceRapidoParaElModoAutomatico a ns1:Parametro ;
    rdfs:label "Avance rápido para el modo automático" ;
    ns1:textoExtracto "Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados." .

