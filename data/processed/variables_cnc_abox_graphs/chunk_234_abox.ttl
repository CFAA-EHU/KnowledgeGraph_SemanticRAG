@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceActivoDefinidoPorPLC a ns1:Parametro ;
    rdfs:label "Avance activo definido por PLC" ;
    ns1:identificador "PLC.F" ;
    ns1:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)." .

ns1:AvanceMaximoFijadoPorPLC a ns1:Parametro ;
    rdfs:label "Avance máximo fijado por PLC" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." .

ns1:AvanceRapidoDefinidoEnElParametroMPGFRAPIDEN a ns1:Parametro ;
    rdfs:label "Avance rápido definido en el parámetro MPG.FRAPIDEN" ;
    ns1:identificador "MPG.FRAPIDEN" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." .

