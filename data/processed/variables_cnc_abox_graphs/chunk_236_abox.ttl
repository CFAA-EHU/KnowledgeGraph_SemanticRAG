@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximaFrecuenciaGeneradaSobreLaTrayectoriaDeMecanizado a ns1:Parametro ;
    rdfs:label "Máxima frecuencia generada sobre la trayectoria de mecanizado" ;
    ns1:identificador "MPG.MAXFREQ" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]. Máxima frecuencia generada sobre la trayectoria de mecanizado." .

ns1:MaximaFrecuenciaGeneradaSobreLaTrayectoriaDeMecanizadoParaElCanal2 a ns1:Parametro ;
    rdfs:label "Máxima frecuencia generada sobre la trayectoria de mecanizado para el canal 2" ;
    ns1:identificador "V.2.MPG.MAXFREQ" ;
    ns1:textoExtracto "| V.[2].MPG.MAXFREQ | Canal ·2·. |" .

