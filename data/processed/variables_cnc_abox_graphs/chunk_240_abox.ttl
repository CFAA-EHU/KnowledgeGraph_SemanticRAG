@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloCancelacionM05 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M05 cancela la función retrace" ;
    ns1:textoExtracto "La función M05 cancela la función retrace; el CNC no detiene el cabezal." .

ns1:FalloEjecucionM00 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M00 no se ejecuta" ;
    ns1:textoExtracto "Las funciones M00 y M01 se ejecutan siempre; se envían al PLC y es necesario pulsar [START] para continuar la ejecución en retrace." .

ns1:FalloEjecucionM01 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M01 no se ejecuta" ;
    ns1:textoExtracto "Las funciones M00 y M01 se ejecutan siempre; se envían al PLC y es necesario pulsar [START] para continuar la ejecución en retrace." .

ns1:FalloIgnoracionM03 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M03 ignorada" ;
    ns1:textoExtracto "Las funciones M03 y M04 se ignoran siempre; el CNC no arranca el cabezal ni cambia el sentido de giro." .

ns1:FalloIgnoracionM04 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M04 ignorada" ;
    ns1:textoExtracto "Las funciones M03 y M04 se ignoran siempre; el CNC no arranca el cabezal ni cambia el sentido de giro." .

ns1:Parametro_6c53a5975e a ns1:Parametro ;
    rdfs:label "Función retrace" ;
    ns1:identificador "RETRACE_FUNCTION" ;
    ns1:textoExtracto "Valor. Significado. 0 Ignorar la función M y continuar. 1 Cancelar la función retrace." .

