@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_02f0d38ae3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC retira los ejes de la pieza." .

ns1:EstadoDelParametroG233 a ns1:Parametro ;
    rdfs:label "Estado del parámetro G233" ;
    ns1:identificador "G233" ;
    ns1:textoExtracto "Si G233 no está activa, los ejes se detienen al final de la pasada." .

ns1:RetirarLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Retirar la herramienta" ;
    ns1:textoExtracto "Si G233 no está activa, los ejes se detienen al final de la pasada. En los ciclos fijos de roscado (modelo -T-), tanto ISO como conversacional, el CNC retira los ejes de la pieza." .

