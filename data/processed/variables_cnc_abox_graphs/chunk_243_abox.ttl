@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioCabezalMaster a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del Cabezal Master" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cabezal master mantenido." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_a70aa7b6e3 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:documentadoEn ns1:CNC8070_c6f7ec44bf ;
    ns1:identificador "MPG.MASTERSPDL" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Canal [ch]. Cabezal master mantenido." .

ns1:CNC8070_c6f7ec44bf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Este parámetro indica si el cabezal master de un canal mantiene su condición de master tras ejecutar M02, M30, después de una emergencia o reset y tras reiniciar el CNC." .

