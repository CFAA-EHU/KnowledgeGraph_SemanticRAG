@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazVariableModificableDesdeE_d00c245dd2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto."@es ;
    ns1:identificador "MPA.DRIVETYPE" ;
    ns1:ilustradoEn ns1:TablaTiposRegulador ;
    ns1:textoExtracto "\"(V.)[ch].MPA.DRIVETYPE.xn (V.)[ch].MPA.DRIVETYPE.sn\" Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto."@es .

ns1:VariableValidaParaEjesRotativosLinealesYCabezalesVariableValidaParaRe_b0c758779c a ns1:Parametro ;
    rdfs:label "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición, Sercos velocidad y Mechatrolink."@es ;
    ns1:identificador "SP.DRIVETYPE" ;
    ns1:ilustradoEn ns1:TablaTiposRegulador ;
    ns1:textoExtracto "\"(V.)[ch].SP.DRIVETYPE.sn\" Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición, Sercos velocidad y Mechatrolink."@es .

ns1:TablaTiposRegulador a ns1:Tabla ;
    rdfs:label "Tabla de tipos de regulador" ;
    ns1:textoExtracto """| Valor. | Significado. |
| --- | --- |
| 1 | Eje lineal. |
| 2 | Eje rotativo. |
| 4 | Cabezal. |""" .

