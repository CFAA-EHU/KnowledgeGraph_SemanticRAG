ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEjesRotativosLinealesYCabezales_7c66f38795 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para ejes rotativos, lineales y cabezales" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "MPA.FBACKDIFF.xn" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.FBACKDIFF.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales.\"" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaReguladorSercosPosicion a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para regulador Sercos posición" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "SP.FBACKDIFF.sn" ;
    ns1:textoExtracto "\"(V.)[ch].SP.FBACKDIFF.sn Variable válida para regulador Sercos posición. La variable devuelve el valor de la preparación de bloques.\"" .

ns1:TablaConfiguracionReguladorSercos a ns1:Tabla ;
    rdfs:label "Tabla de configuración del regulador Sercos" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.FBACKDIFF.xn (V.)[ch].SP.FBACKDIFF.sn Variable válida para regulador Sercos posición. La variable devuelve el valor de la preparación de bloques.\"" .

