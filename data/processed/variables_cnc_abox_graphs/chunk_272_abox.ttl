ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazVariableModificableDesdeE_d0fa5c0f2b a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto. Variable válida para ejes rotativos."@es ;
    ns1:identificador "MPA.SHORTESTWAY" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.SHORTESTWAY.xn Variable de lectura desde el programa, PLC e interfaz.\""@es .

ns1:VariableValidaParaEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Variable válida para eje con índice 1 en el canal 2."@es ;
    ns1:identificador "MPA.SHORTESTWAY.1" ;
    ns1:textoExtracto "\"| V.[2].MPA.SHORTESTWAY.1 | Eje con índice ·1· en el canal ·2·. |\""@es .

ns1:VariableValidaParaEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Variable válida para eje con número lógico 4."@es ;
    ns1:identificador "MPA.SHORTESTWAY.4" ;
    ns1:textoExtracto "\"| V.MPA.SHORTESTWAY.4 | Eje con número lógico ·4·. |\""@es .

ns1:VariableValidaParaEjeZ a ns1:Parametro ;
