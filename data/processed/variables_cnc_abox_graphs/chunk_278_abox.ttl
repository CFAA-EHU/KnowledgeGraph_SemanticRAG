@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaNombreNumeroLogicoOIn_de25580e60 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para nombre, número lógico o índice del cabezal" ;
    ns1:identificador "MPA.CAXSET.sn" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.CAXSET.sn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y cabezales.\"" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaNombreNumeroLogicoOIndiceDelEje a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para nombre, número lógico o índice del eje" ;
    ns1:identificador "MPA.CAXSET.xn" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.CAXSET.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y cabezales.\"" .

ns1:VariableQueDevuelveElValorDeLaPreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Variable que devuelve el valor de la preparación de bloques" ;
    ns1:identificador "SP.CAXSET.sn" ;
    ns1:textoExtracto "\"(V.)[ch].SP.CAXSET.sn Variable válida para regulador analógico, Sercos posición y Sercos velocidad. La variable devuelve el valor de la preparación de bloques.\"" .

