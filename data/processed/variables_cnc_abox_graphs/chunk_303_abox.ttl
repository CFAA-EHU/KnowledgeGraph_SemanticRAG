@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaHidraulicoSincronizacion a ns1:Sistema ;
    rdfs:label "Sistema de sincronización en velocidad" ;
    ns1:textoExtracto "Canal [ch]. Ventana de sincronización en velocidad." ;
    ns1:tieneComponente ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaSincronizacionEnVelocidad,
        ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaSincronizacionEnVelocidad_b821104d21 .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaSincronizacionEnVelocidad a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para sincronización en velocidad" ;
    ns1:identificador "MPA.DSYNCVELW" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaSincronizacionEnVelocidad_b821104d21 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para sincronización en velocidad" ;
    ns1:identificador "SP.DSYNCVELW" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

