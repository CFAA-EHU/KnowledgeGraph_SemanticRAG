@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteDeSoftwareNegativoDelEje a ns1:Parametro ;
    rdfs:label "Límite de software negativo del eje" ;
    ns1:identificador "MPA.NEGLIMIT.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos y lineales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:LimiteDeSoftwareNegativoDelEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Límite de software negativo del eje con índice 1 en el canal 2" ;
    ns1:identificador "MPA.POSLIMIT.1" ;
    ns1:textoExtracto "V.[2].MPA.POSLIMIT.1 | Eje con índice ·1· en el canal ·2·." .

ns1:LimiteDeSoftwareNegativoDelEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Límite de software negativo del eje con número lógico 4" ;
    ns1:identificador "MPA.POSLIMIT.4" ;
    ns1:textoExtracto "V.MPA.POSLIMIT.4 | Eje con número lógico ·4·." .

ns1:LimiteDeSoftwareNegativoDelEjeZ a ns1:Parametro ;
    rdfs:label "Límite de software negativo del eje Z" ;
    ns1:identificador "MPA.POSLIMIT.Z" ;
    ns1:textoExtracto "V.MPA.POSLIMIT.Z | Eje Z." .

