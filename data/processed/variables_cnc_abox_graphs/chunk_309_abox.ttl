@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteNegativoDelEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Límite negativo del eje con índice 1 en el canal 2" ;
    ns1:identificador "MPA.NEGLIMIT.1" ;
    ns1:textoExtracto "V.[2].MPA.NEGLIMIT.1 | Eje con índice ·1· en el canal ·2·." .

ns1:LimiteNegativoDelEjeConNumeroLogico4 a ns1:Parametro ;
