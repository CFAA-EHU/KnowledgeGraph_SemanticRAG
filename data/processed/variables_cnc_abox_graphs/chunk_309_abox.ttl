    ns1:identificador "MPA.NEGLIMIT.4" ;
    ns1:textoExtracto "V.MPA.NEGLIMIT.4 | Eje con número lógico ·4·." .

ns1:LimiteNegativoDelEjeZ a ns1:Parametro ;
    rdfs:label "Límite negativo del eje Z" ;
    ns1:identificador "MPA.NEGLIMIT.Z" ;
    ns1:textoExtracto "V.MPA.NEGLIMIT.Z | Eje Z." .

ns1:ToleranciaDeLosLimitesDeSoftwareDelEjeConNumeroLogico4 a ns1:Parametro ;
