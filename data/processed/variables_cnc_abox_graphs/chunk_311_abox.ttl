@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaDeSeguridadParaElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Distancia de seguridad para el eje con índice 1 en el canal 2" ;
    ns1:identificador "MPA.ZONELIMITTOL.21" ;
    ns1:textoExtracto "V.[2].MPA.ZONELIMITTOL.1 | Eje con índice ·1· en el canal ·2·." .

ns1:DistanciaDeSeguridadParaElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Distancia de seguridad para el eje con número lógico 4" ;
    ns1:identificador "MPA.ZONELIMITTOL.4" ;
    ns1:textoExtracto "V.MPA.ZONELIMITTOL.4 | Eje con número lógico ·4·." .

ns1:DistanciaDeSeguridadParaElEjeZ a ns1:Parametro ;
    rdfs:label "Distancia de seguridad para el eje Z" ;
    ns1:identificador "MPA.ZONELIMITTOL.Z" ;
    ns1:textoExtracto "V.MPA.ZONELIMITTOL.Z | Eje Z." .

ns1:DistanciaDeSeguridadQueAplicaElCNCAlEjeRespectoElLimiteDeLaZonaDeTrabajo a ns1:Parametro ;
    rdfs:label "Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo" ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:textoExtracto "Canal [ch]. Distancia de seguridad (definida en el parámetro ZONELIMITTOL) que aplica el CNC al eje respecto el límite de la zona de trabajo." .

