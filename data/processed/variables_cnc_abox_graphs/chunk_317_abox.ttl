ns1:NombreNumeroLogicoOIndiceDelCabezal_0f60bd6d0a a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal" ;
    ns1:identificador "sn" ;
    ns1:textoExtracto "· sn· Nombre, número lógico o índice del cabezal." .

ns1:NumeroDeCanal_657b8b6883 a ns1:Parametro ;
    rdfs:label "Número de canal" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "Canal [ch]. Tiempo para detectar el embalamiento del eje." .

ns1:ValorDeEjecucionParaEjeRotativoLinealOCabezal a ns1:Parametro ;
    rdfs:label "Valor de ejecución para eje rotativo, lineal o cabezal" ;
    ns1:identificador "xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

