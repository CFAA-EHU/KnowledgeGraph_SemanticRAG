@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaModoDeBusquedaDeCero a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para modo de búsqueda de cero" ;
    ns1:identificador "MPA.REFMODE.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales." ;
    ns1:tieneComponente ns1:MovimientoEnSentidoNegativo,
        ns1:MovimientoEnSentidoPositivo .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaModoDeBusquedaDeCero_7adcdd27ca a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para modo de búsqueda de cero" ;
    ns1:identificador "SP.REFMODE.sn" ;
    ns1:textoExtracto "Variable válida para regulador Sercos posición." ;
    ns1:tieneComponente ns1:MovimientoEnSentidoNegativo,
        ns1:MovimientoEnSentidoPositivo .

ns1:MovimientoEnSentidoNegativo a ns1:Parametro ;
    rdfs:label "Movimiento en sentido negativo" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Movimiento en sentido negativo." .

ns1:MovimientoEnSentidoPositivo a ns1:Parametro ;
    rdfs:label "Movimiento en sentido positivo" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Movimiento en sentido positivo." .

