@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceMaximoDePalpado a ns1:Parametro ;
    rdfs:label "Avance máximo de palpado" ;
    ns1:textoExtracto "Variable válida para regulador analógico, Sercos posición y Sercos velocidad. La variable devuelve el valor de la preparación de bloques." .

ns1:NombreNumeroLogicoOIndiceDelEje a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del eje" ;
    ns1:textoExtracto "· xn· Nombre, número lógico o índice del eje." .

ns1:NumeroDeCanal_94c9ef1af5 a ns1:Parametro ;
    rdfs:label "Número de canal" ;
    ns1:textoExtracto "Canal [ch]. Avance máximo de palpado. Sintaxis. · ch· Número de canal." .

