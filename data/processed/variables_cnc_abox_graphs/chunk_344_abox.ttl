ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_dfbc021d9f a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:documentadoEn ns1:SistemaInterfazUsuario ;
    ns1:identificador "MPA.JOGFEED.xn" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto." .

