@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaPosicion1 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la posición 1" ;
    ns1:identificador "MPA.MPGRESOL1" ;
    ns1:textoExtracto "pos=1 corresponde a la posición ·1·." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaPosicion10 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la posición 10" ;
    ns1:identificador "MPA.MPGRESOL2" ;
    ns1:textoExtracto "pos=2 corresponde a la posición ·10·." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaPosicion100 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la posición 100" ;
    ns1:identificador "MPA.MPGRESOL3" ;
    ns1:textoExtracto "pos=3 corresponde a la posición ·100·." .

