@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaPreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para preparación de bloques" ;
    ns1:identificador "MPA.MANPOSSW" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.MANPOSSW.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad.\"" .

