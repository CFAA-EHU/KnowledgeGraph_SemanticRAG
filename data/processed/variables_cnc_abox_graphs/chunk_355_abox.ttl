    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPA.MANNEGSW" ;
    ns1:textoExtracto "\"(V.)[ch].MPA.MANNEGSW.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad.\"" .

