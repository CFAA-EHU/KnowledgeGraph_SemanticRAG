@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreNumeroLogicoOIndiceDelCabezal a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal" ;
    ns1:textoExtracto "sn· Nombre, número lógico o índice del cabezal." .

ns1:NombreNumeroLogicoOIndiceDelEje a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del eje" ;
    ns1:textoExtracto "xn· Nombre, número lógico o índice del eje." .

ns1:NumeroDeGradosPorVueltaDeEncoder a ns1:Parametro ;
    rdfs:label "Número de grados por vuelta de encoder" ;
    ns1:textoExtracto "En eje rotativo define el número de grados por vuelta de encóder." .

