@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Variable válida para cabezales." .

ns1:ReguladorMechatrolink a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Mechatrolink" ;
    ns1:textoExtracto "Variable válida para regulador Mechatrolink." .

ns1:VelocidadMaximaDeAvanceRapidoG00 a ns1:Parametro ;
    rdfs:label "Velocidad máxima de avance rápido G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Frecuencia que debe proporcionar el CNC para que el cabezal alcance la velocidad definida en el parámetro G00FEED." .

