@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDefinidoEnElParametroG00FEED a ns1:Parametro ;
    rdfs:label "Avance definido en el parámetro G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED." .

ns1:AvanceRapidoDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Avance rápido del eje" ;
    ns1:solucionaFallo ns1:LimitacionDeAvance ;
    ns1:textoExtracto "Avance rápido del eje, cuando está activo el avance rápido para el modo automático (parámetro RAPIDEN)." .

ns1:Parametro_9237f6b4e9 a ns1:Parametro ;
    rdfs:label "Parámetro de avance rápido" ;
    ns1:identificador "RAPIDEN" ;
    ns1:textoExtracto "Si el parámetro se define con valor ·0·, no se limita el avance." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_a5ff2717c6 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPA.FRAPIDEN" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:LimitacionDeAvance a ns1:DiagnosticoFallo ;
    rdfs:label "Limitación de avance" ;
    ns1:textoExtracto "Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados. Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED." .

