ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazVariableModificableDesdeE_5fccf2ebbc a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno del osciloscopio y de puesta a punto."@es ;
    ns1:identificador "MPA.PROGAIN" ;
    ns1:textoExtracto "V.[ch].MPA.PROGAIN[set].xn (V.)[ch].MPA.PROGAIN[set].sn Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno del osciloscopio y de puesta a punto." .

ns1:VariableQueDevuelveElValorDeEjecucionSuLecturaDetieneLaPreparacionDeB_78935b22c1 a ns1:Parametro ;
    rdfs:label "Variable que devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Ganancia proporcional. Fija el error de seguimiento (diferencia entre la cota teórica instantánea y la posición real del eje) que se desea obtener para un determinado avance."@es ;
    ns1:identificador "MPA.PROGAIN[set]" ;
    ns1:textoExtracto "V.[ch].MPA.PROGAIN[set].xn (V.)[ch].MPA.PROGAIN[set].sn Variable que devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Ganancia proporcional. Fija el error de seguimiento (diferencia entre la cota teórica instantánea y la posición real del eje) que se desea obtener para un determinado avance." .

ns1:VariableValidaParaEjesRotativosLinealesYCabezalesVariableValidaParaRe_0c284387d2 a ns1:Parametro ;
    rdfs:label "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad."@es ;
    ns1:identificador "SP.PROGAIN" ;
    ns1:textoExtracto "V.[ch].SP.PROGAIN[set].sn Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

