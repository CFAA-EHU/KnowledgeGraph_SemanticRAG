@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteDeGananciasDelCabezalEnElCanal a ns1:Parametro ;
    rdfs:label "Ajuste de ganancias del cabezal en el canal" ;
    ns1:identificador "V.2.SP.PROGAIN[3].1" ;
    ns1:textoExtracto "V.[2].SP.PROGAIN[3].1 | Cabezal con índice ·1· en el canal ·2·." .

ns1:TipoDePreControlDesdeElProgramaPLCEInterfaz a ns1:Parametro ;
    rdfs:label "Tipo de pre-control desde el programa, PLC e interfaz" ;
    ns1:identificador "V.ch.MPA.FFWTYPE[set].xn" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno de puesta a punto." .

ns1:TipoDePreControlDesdeLaInterfaz a ns1:Parametro ;
    rdfs:label "Tipo de pre-control desde la interfaz" ;
    ns1:identificador "V.ch.SP.FFWTYPE[set].sn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

