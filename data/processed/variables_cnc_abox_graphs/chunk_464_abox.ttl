    rdfs:label "Porcentaje de feed forward en manual" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:identificador "MPA.MANFFGAIN" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno del osciloscopio y de puesta a punto." .

ns1:PorcentajeDeFeedForwardEnManual_fb0c491e10 a ns1:Parametro ;
    rdfs:label "Porcentaje de feed forward en manual" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:identificador "SP.MANFFGAIN" ;
