@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioLecturaParametros a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para la lectura de parámetros" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable modificable desde el entorno del osciloscopio y de puesta a punto." .

