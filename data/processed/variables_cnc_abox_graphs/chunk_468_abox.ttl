@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempoDeAceleracion a ns1:Parametro ;
    rdfs:label "Constante de tiempo de aceleración" ;
    ns1:textoExtracto "Constante de tiempo de aceleración." .

ns1:ValorDeEjecucionParaReguladorAnalogicoYSercosVelocidad a ns1:Parametro ;
    rdfs:label "Valor de ejecución para regulador analógico y Sercos velocidad" ;
    ns1:textoExtracto "Variable válida para regulador analógico y Sercos velocidad. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

