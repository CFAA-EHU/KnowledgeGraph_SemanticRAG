@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLinealMovimientosEnG0ParaElCabezalMaster a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0) para el cabezal master" ;
    ns1:identificador "SP.LACC1G0[3]" ;
    ns1:textoExtracto "V.SP.LACC1G0[3] | Cabezal master." .

ns1:AceleracionLinealMovimientosEnG0ParaElCabezalS a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0) para el cabezal S" ;
    ns1:identificador "MPA.LACC1G0[3].S" ;
    ns1:textoExtracto "V.MPA.LACC1G0[3].S | Cabezal S." .

ns1:AceleracionLinealMovimientosEnG0ParaElEjeZ a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0) para el eje Z" ;
    ns1:identificador "MPA.LACC1G0[3].Z" ;
    ns1:textoExtracto "V.MPA.LACC1G0[3].Z | Eje Z." .

