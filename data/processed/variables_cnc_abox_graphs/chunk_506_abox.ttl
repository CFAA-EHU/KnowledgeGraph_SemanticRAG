ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazVariableValidaParaEjesRot_d0de1c67c7 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad. La variable devuelve el valor de la preparación de bloques. Aceleración máxima permitida en las esquinas."@es ;
    ns1:identificador "MPA.CORNERACC" ;
    ns1:textoExtracto "(V.)[ch].MPA.CORNERACC[set].xn (V.)[ch].MPA.CORNERACC[set].sn Variable de lectura desde el programa, PLC e interfaz." .

