@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSeguimientoMaximoEnParado a ns1:Parametro ;
    rdfs:label "Error de seguimiento máximo en parado" ;
    ns1:identificador "MPA.MINFLWE" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:ErrorDeSeguimientoMaximoEnParado_e028ebc5dc a ns1:Parametro ;
    rdfs:label "Error de seguimiento máximo en parado" ;
    ns1:identificador "SP.MINFLWE" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:TablaMonitorizacion a ns1:Tabla ;
    rdfs:label "Tabla de Monitorización" ;
    ns1:textoExtracto """| Valor. | Significado. |
| --- | --- |
| 0 | Sin monitorización. |
| 1 | Monitorización estándar. |
| 2 | Monitorización lineal.""" .

