@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeLaSalidaAnalogicaAsociadaAlEjeEnElPrograma a ns1:Parametro ;
    rdfs:label "Número de la salida analógica asociada al eje en el programa" ;
    ns1:identificador "SP.ANAOUTID" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico con módulos remotos y regulador Sercos" ;
    ns1:textoExtracto "La salida analógica está en los módulos remotos. La salida analógica está en un regulador Sercos." .

ns1:SistemaRCS a ns1:Sistema ;
    rdfs:label "Sistema RCS-S" ;
    ns1:textoExtracto "La salida analógica está en un módulo RCS-S." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaLaSalidaAnalogicaAsociadaAlEje a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para la salida analógica asociada al eje" ;
    ns1:identificador "MPA.ANAOUTID" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador analógico." .

