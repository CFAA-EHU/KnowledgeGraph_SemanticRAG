@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeSalidaAnalogicaParaModuloRCSS_baaa0823d0 a ns1:Parametro ;
    rdfs:label "Número de salida analógica para módulo RCS-S" ;
    ns1:identificador "1-32" ;
    ns1:textoExtracto "La consigna analógica se toma de un módulo RCS-S. La variable devuelve el número de salida analógica." .

ns1:NumeroDeSalidaAnalogicaParaModulosRemotos_f3c9647390 a ns1:Parametro ;
    rdfs:label "Número de salida analógica para módulos remotos" ;
    ns1:identificador "1-16" ;
    ns1:textoExtracto "La consigna analógica se toma de los módulos remotos. La variable devuelve el número de salida analógica." .

ns1:NumeroDeSalidaAnalogicaParaReguladorSercos_8f826bb42f a ns1:Parametro ;
    rdfs:label "Número de salida analógica para regulador Sercos" ;
    ns1:identificador "101-132, 201-232" ;
    ns1:textoExtracto "La consigna analógica se toma de un regulador Sercos. El primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." .

