@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeEntradaDeCaptacionDelEje a ns1:Parametro ;
    rdfs:label "Tipo de entrada de captación del eje" ;
    ns1:identificador "SP.COUNTERTYPE" ;
    ns1:textoExtracto "Variable válida para regulador analógico y Sercos velocidad. La variable devuelve el valor de la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_40be3940fd a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPA.COUNTERTYPE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales." .

