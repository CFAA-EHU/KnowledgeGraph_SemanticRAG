@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaPreparacionDeBloquesE_0624de944c a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para preparación de bloques en regulador Sercos posición y velocidad" ;
    ns1:documentadoEn ns1:InterfazUsuarioMultieje ;
    ns1:identificador "SP.DRIVESET" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. En los ejes que pertenecen a un grupo multieje, el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC (G112 y M41 a M44)." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaPreparacionDeBloquesE_6e3317096f a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para preparación de bloques en regulador Sercos posición y velocidad" ;
    ns1:documentadoEn ns1:InterfazUsuarioMultieje ;
    ns1:identificador "MPA.DRIVESET" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. En los ejes que pertenecen a un grupo multieje, el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC (G112 y M41 a M44)." .

ns1:InterfazUsuarioMultieje a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para configuración del regulador asociado a los ejes de un grupo multieje" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. Variable válida para regulador Sercos posición y Sercos velocidad." .

