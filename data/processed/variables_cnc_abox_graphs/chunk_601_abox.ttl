    ns1:textoExtracto "V.[2].SP.SSICLKFREQ[3].1 | Cabezal con índice ·1· en el canal ·2·." .

ns1:NumeroDeBitsDeLaTransmisionSSIQueConstituyenLaCota a ns1:Parametro ;
    rdfs:label "Número de bits de la transmisión SSI que constituyen la cota" ;
    ns1:documentadoEn ns1:InterfazUsuarioSSI ;
    ns1:identificador "V.ch.MPA.SSIDATALENGTH.set.sn" ;
    ns1:textoExtracto "(V.)[ch].MPA.SSIDATALENGTH[set].sn Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de la preparación de bloques." .

ns1:InterfazUsuarioSSI a ns1:InterfazUsuario ;
    rdfs:label "Interfaz SSI" ;
    ns1:textoExtracto "Variable válida para regulador Sercos velocidad. La variable devuelve el valor de la preparación de bloques. Número de bits de la transmisión SSI que constituyen la cota." .

