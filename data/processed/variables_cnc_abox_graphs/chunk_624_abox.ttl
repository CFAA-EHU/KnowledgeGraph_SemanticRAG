@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstimacionDelRetardoDelRegulador a ns1:Parametro ;
    rdfs:label "Estimación del retardo del regulador" ;
    ns1:identificador "AXDELAY" ;
    ns1:textoExtracto "El parámetro AXDELAY es una estimación del retardo del regulador a la hora de aplicar la consigna enviada por el CNC." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaCabezales_411403c62a a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para cabezales" ;
    ns1:identificador "SP.AXDELAY[set].sn" ;
    ns1:textoExtracto "Variable válida para regulador analógico, Sercos posición y Sercos velocidad." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaEjes_502746ca08 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para ejes" ;
    ns1:identificador "MPA.AXDELAY[set].xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales." .

