@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_64ae13e8ff a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPMAN.JOGTYPE" ;
    ns1:textoExtracto "V.)MPMAN.JOGTYPE Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:InterfazUsuarioConfiguracionTeclasJog a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para configurar las teclas de jog" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina ;
    ns1:textoExtracto "La tecla está asignada al movimiento en sentido negativo. El número lógico de los ejes viene establecido por el orden en el que los ejes han sido definidos en la tabla de parámetros máquina." .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:ilustra ns1:InterfazUsuarioConfiguracionTeclasJog ;
    ns1:textoExtracto "El primer eje de la tabla será el eje lógico ·1· y así sucesivamente." .

