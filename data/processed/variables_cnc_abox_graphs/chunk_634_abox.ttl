@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeTeclasDeJogEjePulsado a ns1:Parametro ;
    rdfs:label "Configuración de teclas de jog - Eje pulsado" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Eje pulsado. El eje se desplazará mientras se mantengan pulsadas ambas teclas, la del eje y la del sentido." .

ns1:ConfiguracionDeTeclasDeJogEjeSeleccionado a ns1:Parametro ;
    rdfs:label "Configuración de teclas de jog - Eje seleccionado" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Eje seleccionado. Cuando se pulsa la tecla del eje, éste se selecciona. El eje se desplazará mientras se mantenga pulsada la tecla del sentido." .

