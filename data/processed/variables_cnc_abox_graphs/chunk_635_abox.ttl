@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioConfiguracionTeclas a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para configurar las teclas de usuario como teclas de jog" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:TeclaDeUsuario7DelPrimerTeclado a ns1:Parametro ;
    rdfs:label "Tecla de usuario 7 del primer teclado" ;
    ns1:identificador "MPMAN.USERKEYDEF[7]" ;
    ns1:textoExtracto "V.MPMAN.USERKEYDEF[7] | Tecla de usuario ·7· del primer teclado." .

ns1:TeclaDeUsuario7DelTercerTeclado a ns1:Parametro ;
    rdfs:label "Tecla de usuario 7 del tercer teclado" ;
    ns1:identificador "MPMAN.USERKEYBD3DEF[7]" ;
    ns1:textoExtracto "V.MPMAN.USERKEYBD3DEF[7] | Tecla de usuario ·7· del tercer teclado." .

