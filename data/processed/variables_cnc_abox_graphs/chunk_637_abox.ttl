@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValoresDeLaVariableVMPMANHBLS a ns1:Parametro ;
    rdfs:label "Valores de la variable V.MPMAN.HBLS" ;
    ns1:identificador "V.MPMAN.HBLS" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_a5ec6d1e93 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "MPMAN.HBLS" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Este parámetro indica si hay un panel portátil HBLS conectado al CNC a través de la línea serie." .

