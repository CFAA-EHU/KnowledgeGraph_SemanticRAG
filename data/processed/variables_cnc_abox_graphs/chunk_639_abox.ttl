@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaVariablesFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a las funciones M" ;
    ns1:ilustra ns1:Posicion12DeLaTablaDeFuncionesM_7e3c12f220,
        ns1:TipoDeSincronizacionParaFuncionesM ;
    ns1:textoExtracto "Valores de la variable. Esta variable devuelve uno de los siguientes valores." .

ns1:Posicion12DeLaTablaDeFuncionesM_7e3c12f220 a ns1:Parametro ;
    rdfs:label "Posición 12 de la tabla de funciones M" ;
    ns1:identificador "V.MPM.SYNCHTYPE[12]" ;
    ns1:textoExtracto "Posición ·12· de la tabla de funciones M." .

ns1:TipoDeSincronizacionParaFuncionesM a ns1:Parametro ;
    rdfs:label "Tipo de sincronización para funciones M" ;
    ns1:identificador "MPM.SYNCHTYPE" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

