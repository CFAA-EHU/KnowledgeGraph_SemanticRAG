@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaSubrutinaAsociadaEnLaTablaDeFuncionesM a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada en la tabla de funciones M" ;
    ns1:identificador "MPM.MPROGNAME[pos]" ;
    ns1:textoExtracto "(V.)MPM.MPROGNAME[pos] Variable de lectura desde el interfaz. Posición [pos] de la tabla de funciones 'M'. Nombre de la subrutina asociada." .

ns1:TiempoEstimadoDeEjecucionEnLaTablaDeFuncionesM a ns1:Parametro ;
    rdfs:label "Tiempo estimado de ejecución en la tabla de funciones M" ;
    ns1:identificador "MPM.MTIME[pos]" ;
    ns1:textoExtracto "(V.)MPM.MTIME[pos] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Posición [pos] de la tabla de funciones 'M'. Tiempo estimado de ejecución (en milisegundos)." .

