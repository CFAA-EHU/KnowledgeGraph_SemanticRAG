@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoOffsetPermitidoParaElParametroTDATA a ns1:Parametro ;
    rdfs:label "Máximo offset permitido para el parámetro TDATA" ;
    ns1:identificador "MPK.MAXOFTDATAkin[nb]" ;
    ns1:textoExtracto "(V.)MPK.MAXOFTDATAkin[nb] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:ValorDelParametroTDATA34 a ns1:Parametro ;
    rdfs:label "Valor del parámetro TDATA34" ;
    ns1:identificador "MPK.TDATAF2[34]" ;
    ns1:textoExtracto "V.MPK.TDATAF2[34] | Cinemática ·2·. Valor del parámetro TDATA34." .

ns1:ValorDelParametroTDATAI23 a ns1:Parametro ;
    rdfs:label "Valor del parámetro TDATA_I23" ;
    ns1:identificador "MPK.TDATA_I2[23]" ;
    ns1:textoExtracto "V.MPK.TDATA_I2[23] | Cinemática ·2·. Valor del parámetro TDATA_I23." .

