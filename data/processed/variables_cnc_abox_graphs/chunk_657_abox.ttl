ns1:Parametro_37958f5222 a ns1:Parametro ;
    rdfs:label "Almacén 2." ;
    ns1:identificador "V.TM.MZRANDOM[2]" ;
    ns1:textoExtracto "\"V.TM.MZRANDOM[2] | Almacén ·2·.\"" .

ns1:TablaValoresTMZRANDOM a ns1:Tabla ;
    ns1:ilustra ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_5337c0eb5e ;
    ns1:textoExtracto "\"Valores de la variable. Esta variable devuelve uno de los siguientes valores.\"" ;
    ns1:tieneComponente ns1:NoEsUnAlmacenRandom,
        ns1:SiEsUnAlmacenRandom .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_b6e3030130 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Tipo de almacén." ;
    ns1:identificador "TM.MZTYPE" ;
    ns1:textoExtracto "\"(V.)TM.MZTYPE[mz] Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Almacén [mz]. Tipo de almacén.\"" .

ns1:NoEsUnAlmacenRandom a ns1:Parametro ;
    rdfs:label "No es un almacén random." ;
    ns1:textoExtracto "\"0 | No es un almacén random.\"" ;
    ns1:valor "0" .

ns1:SiEsUnAlmacenRandom a ns1:Parametro ;
    rdfs:label "Sí es un almacén random." ;
    ns1:textoExtracto "\"1 | Sí es un almacén random.\"" ;
    ns1:valor "1" .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_5337c0eb5e a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Almacén random." ;
