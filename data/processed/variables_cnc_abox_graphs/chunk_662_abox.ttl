ns1:ElCNCMuestraUnError a ns1:Parametro ;
    rdfs:label "El CNC muestra un error" ;
    ns1:textoExtracto "Valores de la variable. Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 2 | El CNC muestra un error." ;
    ns1:valor "2" .

ns1:ElCNCMuestraUnWarning a ns1:Parametro ;
    rdfs:label "El CNC muestra un warning" ;
    ns1:textoExtracto "Valores de la variable. Esta variable devuelve uno de los siguientes valores. | Valor. | Significado. | 1 | El CNC muestra un warning." ;
    ns1:valor "1" .

ns1:NoSeRealizaNingunaAccion a ns1:Parametro ;
    rdfs:label "No se realiza ninguna acción" ;
