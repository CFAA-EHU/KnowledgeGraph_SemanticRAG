@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRegulador a ns1:Sistema ;
    rdfs:label "Sistema Regulador" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables del regulador. El acceso a las variables podrá ser solo lectura o de lectura y escritura." ;
    ns1:tieneComponente ns1:NombreDelEjeParaDRVNameXn,
        ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_b773cda2bb,
        ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazParaDRVNameSn,
        ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfaz_7966a69d00 .

ns1:NombreDelEjeParaDRVNameXn a ns1:Parametro ;
    rdfs:label "Nombre del eje para DRV.name.xn" ;
    ns1:identificador "DRV.name.xn" ;
    ns1:textoExtracto "xn· Nombre del eje." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_b773cda2bb a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "DRV.SIZE" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Número de variables a consultar en el regulador." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazParaDRVNameSn a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz para DRV.name.sn" ;
    ns1:identificador "DRV.name.sn" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfaz_7966a69d00 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz" ;
    ns1:identificador "DRV.name" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

