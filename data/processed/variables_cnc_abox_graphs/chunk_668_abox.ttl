@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaVariableDefinidaComoAXISFEEDParaElCabezalS a ns1:Parametro ;
    rdfs:label "Valor de la variable definida como AXISFEED para el cabezal S" ;
    ns1:identificador "V.DRV.AXISFEED.S" ;
    ns1:textoExtracto "V.DRV.AXISFEED.S | Valor de la variable definida como AXISFEED para el cabezal S." .

ns1:ValorDeLaVariableDefinidaComoAXISFEEDParaElEjeZ a ns1:Parametro ;
    rdfs:label "Valor de la variable definida como AXISFEED para el eje Z" ;
    ns1:identificador "V.DRV.AXISFEED.Z" ;
    ns1:textoExtracto "V.DRV.AXISFEED.Z | Valor de la variable definida como AXISFEED para el eje Z." .

ns1:ValorDeLaVariableDefinidaComoFEED a ns1:Parametro ;
    rdfs:label "Valor de la variable definida como FEED" ;
    ns1:identificador "V.DRV.FEED" ;
    ns1:textoExtracto "V.DRV.FEED | Valor de la variable definida como FEED." .

