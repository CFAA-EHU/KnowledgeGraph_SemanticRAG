@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelPLC a ns1:Parametro ;
    rdfs:label "Estado del PLC" ;
    ns1:identificador "PLC.STATUS" ;
    ns1:textoExtracto "Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:EstadoDelPLC_6a11bb1814 a ns1:Parametro ;
    rdfs:label "Estado del PLC" ;
    ns1:identificador "V.PLC.STATUS" ;
    ns1:textoExtracto "Esta variable devuelve uno de los siguientes valores." .

