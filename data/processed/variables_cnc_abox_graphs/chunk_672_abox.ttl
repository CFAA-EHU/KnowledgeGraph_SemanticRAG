@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaEntradaDigitalLocal a ns1:Parametro ;
    rdfs:label "Estado de la entrada digital local" ;
    ns1:identificador "nb" ;
    ns1:textoExtracto "Estado de la entrada digital local [nb] del PLC." .

ns1:VariableQueDevuelveElValorDeEjecucion a ns1:Parametro ;
    rdfs:label "variable que devuelve el valor de ejecución" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

