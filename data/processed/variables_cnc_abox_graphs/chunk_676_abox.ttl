@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelMensaje87 a ns1:Parametro ;
    rdfs:label "Estado del mensaje 87" ;
    ns1:documentadoEn ns1:InterfazUsuarioPLCMensajes ;
    ns1:identificador "V.PLC.MSG[87]" ;
    ns1:textoExtracto "V.PLC.MSG[87] Estado del mensaje 87." .

ns1:InterfazUsuarioPLCMensajes a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de mensajes PLC" ;
    ns1:textoExtracto "Variable de lectura y escritura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

