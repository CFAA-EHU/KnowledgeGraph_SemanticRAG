@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelError62 a ns1:Parametro ;
    rdfs:label "Estado del error 62" ;
    ns1:identificador "PLC.ERR[62]" ;
    ns1:textoExtracto "\"V.PLC.ERR[62] | Estado del error 62.\"" .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaEInterfaz_e620d21c4d a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa e interfaz" ;
    ns1:identificador "PLC.ERR" ;
    ns1:textoExtracto "\"(V.)PLC.ERR[err] Variable de lectura y escritura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\"" .

ns1:VariableDeReportParaUsoDesdeLosScripts_d8df847290 a ns1:Parametro ;
    rdfs:label "Variable de report (para uso desde los scripts)" ;
    ns1:identificador "PLC.PRIORERR" ;
    ns1:textoExtracto "\"(V.)PLC.PRIORERR Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\"" .

