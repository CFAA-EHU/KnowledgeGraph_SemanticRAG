@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelReloj128DelPLC a ns1:Parametro ;
    rdfs:label "Estado del reloj 128 del PLC" ;
    ns1:identificador "PLC.CLK128" ;
    ns1:textoExtracto "V.PLC.CLK128 Valores de la variable. Esta variable devuelve uno de los siguientes valores." .

ns1:LecturaQueDetieneLaPreparacionDeBloques_83f07d0691 a ns1:AccionProhibida ;
    rdfs:label "Lectura que detiene la preparación de bloques" ;
    ns1:mitigaRiesgo ns1:SistemaPLC ;
    ns1:textoExtracto "su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfaz_676e8a49b0 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz" ;
    ns1:identificador "PLC.TIMER" ;
    ns1:textoExtracto "V.PLC.TIMER Con esta variable se puede consultar y/o modificar la cuenta del reloj. Valor en segundos." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El reloj del PLC \"TIMER\" se habilita y deshabilita con la marca TIMERON del PLC. El reloj está contando con TIMERON=1." .

