ns1:VariableDeLecturaDesdeElProgramaEInterfazQueReflejaElEstadoDeLaMarcaSTARTDelPLC a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz que refleja el estado de la marca START del PLC" ;
    ns1:identificador "V.PLC.START" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca START del PLC. El canal activa la marca cuando se ha pulsado la tecla [START]." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazQueReflejaElEstadoDeLaMar_1f421e6412 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz que refleja el estado de la marca SERCOSREADY del PLC" ;
    ns1:identificador "V.PLC.SERCOSRDY" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca SERCOSREADY del PLC. El CNC activa la marca cuando el anillo Sercos se ha inicializado correctamente." .

