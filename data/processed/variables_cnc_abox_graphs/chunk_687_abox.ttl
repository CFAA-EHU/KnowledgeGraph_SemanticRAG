@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaEInterfaz a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz" ;
    ns1:identificador "V.PLC.AUTOMAT" ;
    ns1:textoExtracto "V.PLC.AUTOMAT Canal ·1·." .

