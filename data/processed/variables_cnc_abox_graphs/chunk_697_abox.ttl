ns1:VariableDeLecturaDesdeElProgramaEInterfaz_6ef2d6adc0 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz" ;
    ns1:identificador "PLC.INTEREND" ;
    ns1:textoExtracto "V.PLC.INTEREND Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

