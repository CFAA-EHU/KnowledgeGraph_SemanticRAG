ns1:Parametro_0b3cb0b4fa a ns1:Parametro ;
    rdfs:label "Marca para cada canal de la función M09" ;
    ns1:identificador "DM09" ;
    ns1:textoExtracto "Cada una de las funciones M00, M01, M02, M06, M08, M09, M30 dispone de una marca para cada canal." .

