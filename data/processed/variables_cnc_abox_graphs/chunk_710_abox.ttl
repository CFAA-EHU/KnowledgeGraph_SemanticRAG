@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaFuncionM03DelCabezal a ns1:Parametro ;
    rdfs:label "Estado de la función M03 del cabezal" ;
    ns1:identificador "DM03" ;
    ns1:textoExtracto "El CNC indica en estas marcas el estado de las funciones M del cabezal. La marca está activa si la función M está activa." .

