ns1:CicloDesbaste a ns1:AccionProhibida ;
    rdfs:label "Operación de desbaste del ciclo" ;
    ns1:textoExtracto "Durante la operación de desbaste del ciclo, el canal del CNC activa estas marcas para indicar cuál es el canal en el que está programado el ciclo y cuales" .

