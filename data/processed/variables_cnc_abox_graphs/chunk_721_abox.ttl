@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9d7c2d87b5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC activa estas marcas para indicar cuál es el canal en el que está programado el ciclo y cuales son los canales implicados en el reparto de las pasadas." .

ns1:CanalCNC a ns1:ComponenteElectrico ;
    rdfs:label "Canal CNC" ;
    ns1:textoExtracto "Durante la operación de acabado, el canal de CNC desactiva todas estas marcas." .

ns1:CicloProgramado a ns1:ModoOperacion ;
    rdfs:label "Ciclo Programado" ;
    ns1:textoExtracto "Durante la operación de acabado, el canal de CNC desactiva todas estas marcas." .

