ns1:VariableDeLecturaDesdeElProgramaEInterfazQueDevuelveElValorDeEjecucio_33db6bab28 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz que devuelve el valor de ejecución y detiene la preparación de bloques" ;
    ns1:identificador "PLC.SERPLCAC" ;
    ns1:monitoreaParametro ns1:CNC8070_2bfb0013ec ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaEInterfazQueIndicaElEstadoDeLaTemperaturaDelCNC a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz que indica el estado de la temperatura del CNC" ;
    ns1:identificador "PLC.OVERTEMP" ;
    ns1:monitoreaParametro ns1:CNC8070_2bfb0013ec ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca OVERTEMP del PLC. Esta marca indica el estado de la temperatura del CNC." .

ns1:CNC8070_2bfb0013ec a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca para indicar que está realizando el cambio solicitado." .

