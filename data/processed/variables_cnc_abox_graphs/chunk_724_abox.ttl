@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeInicializacionMechatrolink a ns1:Parametro ;
    rdfs:label "Estado de inicialización Mechatrolink" ;
    ns1:identificador "V.PLC.MLINKRDY" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:InterfazUsuarioPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del PLC" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz." .

ns1:TemperaturaMaximaDelCNC a ns1:Parametro ;
    rdfs:label "Temperatura máxima del CNC" ;
    ns1:identificador "V.PLC.OVERTEMP" ;
    ns1:textoExtracto "la temperatura del CNC supera la máxima permitida, el CNC activa esta marca y muestra un warning avisando de esta circunstancia." .

