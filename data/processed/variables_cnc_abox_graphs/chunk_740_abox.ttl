@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElementoSeguridad_e97426d41f a ns1:ElementoSeguridad ;
    rdfs:label "Marca REVOK del PLC" ;
    ns1:mitigaRiesgo ns1:CabezalActivo ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca REVOK del PLC." .

ns1:VariableDeLecturaDesdeElProgramaEInterfaz_a8a6282af3 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz" ;
    ns1:identificador "PLC.REVOK" ;
    ns1:parametroMonitoradoPor ns1:CabezalActivo ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:CabezalActivo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal activo" ;
    ns1:textoExtracto "El cabezal activa la marca cuando alcanza las revoluciones programadas." .

