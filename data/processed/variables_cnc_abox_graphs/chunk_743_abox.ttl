@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeSincronizacionParaElCabezal1 a ns1:Parametro ;
    rdfs:label "Variable de sincronización para el cabezal 1" ;
    ns1:identificador "PLC.SYNCHRON1" ;
    ns1:textoExtracto "V.PLC.SYNCHRON1 | Cabezal ·1·." .

