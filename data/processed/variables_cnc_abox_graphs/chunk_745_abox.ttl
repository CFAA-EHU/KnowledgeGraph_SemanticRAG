@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeSincronizacionDelCabezal4 a ns1:Parametro ;
    rdfs:label "Variable de sincronización del cabezal 4" ;
    ns1:identificador "PLC.SYNCHRONP4" ;
    ns1:textoExtracto "V.PLC.SYNCHRONP4 | Cabezal ·4·." .

ns1:VariableDeSincronizacionDelCabezal5 a ns1:Parametro ;
    rdfs:label "Variable de sincronización del cabezal 5" ;
    ns1:identificador "PLC.SYNCHRONP5" ;
    ns1:textoExtracto "V.PLC.SYNCHRONP5 | Cabezal ·5·." .

ns1:VariableDeSincronizacionDelCabezal6 a ns1:Parametro ;
    rdfs:label "Variable de sincronización del cabezal 6" ;
