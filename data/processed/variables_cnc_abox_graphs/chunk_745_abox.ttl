    ns1:textoExtracto "V.PLC.SYNCHRONP6 | Cabezal ·6·." .

ns1:VariableDeVelocidadSincronizadaDelCabezalEsclavo a ns1:Parametro ;
    rdfs:label "Variable de velocidad sincronizada del cabezal esclavo" ;
    ns1:identificador "PLC.SYNSPEED" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Esta variable refleja el estado de la marca SYNSPEED del PLC." .

