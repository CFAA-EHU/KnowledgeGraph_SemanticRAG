@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeSincronizacionDePosicionDelCabezalEsclavo a ns1:Parametro ;
    rdfs:label "Variable de sincronización de posición del cabezal esclavo" ;
    ns1:identificador "PLC.SYNCPOSI" ;
    ns1:textoExtracto "(V.)PLC.SYNCPOSI Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

