@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaEInterfazQueReflejaElEstadoDeLaMarcaGEAROKDelPLC a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz que refleja el estado de la marca GEAROK del PLC" ;
    ns1:identificador "PLC.GEAROK" ;
    ns1:textoExtracto "(V.)PLC.GEAROK Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeSincronizacionDelEstadoGEAROKParaElCabezal1 a ns1:Parametro ;
    rdfs:label "Variable de sincronización del estado GEAROK para el cabezal 1" ;
    ns1:identificador "PLC.GEAROK1" ;
    ns1:textoExtracto "V.PLC.GEAROK1 | Cabezal ·1·." .

