@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_46a91603f9 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "PLC.IBUSYxn" ;
    ns1:ilustradoEn ns1:InterfazUsuarioPLC ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:InterfazUsuarioPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz Usuario PLC" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca IBUSYxn del PLC. El interpolador activa esta marca cuando hay alguna sentencia pendiente de ejecución." .

