@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaElEjeConNumeroLogico3_a35171bc94 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para el eje con número lógico 3" ;
    ns1:identificador "PLC.INSYNC3" ;
    ns1:textoExtracto "V.PLC.INSYNC3 Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Variable de report (para uso desde los scripts). Esta variable refleja el estado de la marca INSYNC3 del PLC." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazParaElEjeX_efe463237d a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz para el eje X" ;
    ns1:identificador "PLC.INSYNCX" ;
    ns1:textoExtracto "V.PLC.INSYNCX Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Variable de report (para uso desde los scripts). Esta variable refleja el estado de la marca INSYNCX del PLC." .

