@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_89d9a132fc a ns1:Parametro ;
    rdfs:label "Marca de activación de parámetros comunes" ;
    ns1:identificador "PLC.COMVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros comunes de la tabla de piercing o cutting activa." .

ns1:VariableDeLecturaYEscrituraParaCutting a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura para cutting" ;
    ns1:identificador "PLC.CUTVARACT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraParaPiercing a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura para piercing" ;
    ns1:identificador "PLC.PIRVARACT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

