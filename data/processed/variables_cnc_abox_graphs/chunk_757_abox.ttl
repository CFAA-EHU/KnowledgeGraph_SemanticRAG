@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:parametroMonitoradoPor ns1:VariableDeReportParaSincronizacionConElPLC ;
    ns1:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:CNC8070_b6792d4813 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

ns1:VariableDeReportParaSincronizacionConElPLC a ns1:Parametro ;
    rdfs:label "Variable de report para sincronización con el PLC" ;
    ns1:identificador "V.PLC.PIRVARACT" ;
    ns1:monitoreaParametro ns1:CNC8070_b6792d4813 ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

