@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_01d5ee6099 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:VariableDeLecturaYEscrituraDesdeElProgramaEInterfaz_0ea87d55a7 ;
    ns1:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando el salto programado con un #LEAP alcanza el punto más alto (comando POSLIMIT). El CNC desactiva esta marca (cambio de 1 a 0) cuando el salto empieza a bajar de dicho punto." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaEInterfaz_0ea87d55a7 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa e interfaz" ;
    ns1:identificador "PLC.INPOSLIMIT" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

