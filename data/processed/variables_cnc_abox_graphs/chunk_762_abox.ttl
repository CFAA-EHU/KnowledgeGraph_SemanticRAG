@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del PLC" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ns1:controla ns1:VariableDeLecturaDesdeElProgramaEInterfaz_5d37731abc ;
    ns1:textoExtracto "El gestor activa esta marca para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ns1:VariableDeLecturaDesdeElProgramaEInterfaz_5d37731abc a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz" ;
    ns1:identificador "PLC.TMOPSTROBE" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

