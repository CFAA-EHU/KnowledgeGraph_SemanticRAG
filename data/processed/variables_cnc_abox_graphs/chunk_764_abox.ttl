@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaEInterfaz_2698647bd1 a ns1:Parametro ;
    rdfs:label "Estado de la marca TAKEPOS del PLC",
        "Posición de la herramienta que hay que coger",
        "Variable de lectura desde el programa e interfaz",
        "Variable de report (para uso desde los scripts)" ;
    ns1:documentadoEn ns1:InterfazUsuarioGestorHerramientas ;
    ns1:identificador "PLC.TAKEPOS" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca TAKEPOS del PLC. El gestor indica en este registro la posición de la herramienta que hay que coger." .

ns1:InterfazUsuarioGestorHerramientas a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del gestor de herramientas" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

