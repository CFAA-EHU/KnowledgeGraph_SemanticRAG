@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaEInterfazParaKEYBD1 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz para KEYBD1" ;
    ns1:documentadoEn ns1:InterfazUsuarioTeclas ;
    ns1:identificador "PLC.KEYBD1" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaEInterfazParaKEYBD2 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz para KEYBD2" ;
    ns1:documentadoEn ns1:InterfazUsuarioTeclas ;
    ns1:identificador "PLC.KEYBD2" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaDesdeElProgramaEInterfazParaKEYBD3 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz para KEYBD3" ;
    ns1:documentadoEn ns1:InterfazUsuarioTeclas ;
    ns1:identificador "PLC.KEYBD3" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:InterfazUsuarioTeclas a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclas del PLC" ;
    ns1:textoExtracto "Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado. Estos registros indican qué tecla se ha pulsado (bit=1)." .

