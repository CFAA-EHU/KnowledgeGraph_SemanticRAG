@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaDesdeElProgramaEInterfaz_2c0ac81564 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa e interfaz" ;
    ns1:identificador "PLC.KEYBD1_1" ;
    ns1:ilustradoEn ns1:InterfazUsuarioTeclas ;
    ns1:textoExtracto "V.PLC.KEYBD1_1 Variable de lectura desde el programa e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

