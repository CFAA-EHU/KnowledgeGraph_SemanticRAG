@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "PLC._EMERGEN" ;
    ns1:solucionaFallo ns1:ProhibicionDeEjecucionDeProgramasYMovimientoDeEjes ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:ProhibicionDeEjecucionDeProgramasYMovimientoDeEjes a ns1:AccionProhibida ;
    rdfs:label "Prohibición de ejecución de programas y movimiento de ejes" ;
    ns1:textoExtracto "Mientras la marca este desactivada, el canal prohíbe la ejecución de programas y aborta cualquier intento de mover los ejes o arrancar el cabezal." .

