@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaMarcaRESETINDelPLC a ns1:Parametro ;
    rdfs:label "Estado de la marca RESETIN del PLC" ;
    ns1:identificador "RESETIN" ;
    ns1:monitoreaParametro ns1:ComponenteElectrico_44f8ad6f19 ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca RESETIN del PLC." .

ns1:ComponenteElectrico_44f8ad6f19 a ns1:ComponenteElectrico ;
    rdfs:label "Canal de preparación" ;
    ns1:textoExtracto "Si el PLC activa la marca, el canal asume las condiciones iniciales." .

