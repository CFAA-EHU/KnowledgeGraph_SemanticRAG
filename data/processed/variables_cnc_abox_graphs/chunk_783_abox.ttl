ns1:VariableDeEstadoAUXENDDelPLC a ns1:Parametro ;
    rdfs:label "Variable de estado AUXEND del PLC" ;
    ns1:identificador "PLC.AUXEND" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Esta variable refleja el estado de la marca AUXEND del PLC." .

