@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeEjecucion_e514b562a7 a ns1:Parametro ;
    rdfs:label "variable de ejecución" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:textoExtracto "variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:Parametro_5e35f94897 a ns1:Parametro ;
    rdfs:label "marca NOWAIT del PLC" ;
    ns1:identificador "NOWAIT" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca NOWAIT del PLC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:parametroMonitoradoPor ns1:Parametro_5e35f94897 ;
    ns1:textoExtracto "El PLC activa la marca para anular las sincronizaciones del canal programadas con #WAIT." .

