@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_868c867b83 a ns1:Parametro ;
    rdfs:label "Canal ·4·" ;
    ns1:identificador "V.PLC.PRGABORTC4" ;
    ns1:textoExtracto "\"V.PLC.PRGABORTC4 | Canal ·4·.\"" .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_1e2c9a232b a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "V.PLC.INHIBITMPG12" ;
    ns1:textoExtracto "\"(V.)PLC.INHIBITMPG12 Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Variable de report (para uso desde los scripts). Estas variables reflejan el estado de las marcas INHIBITMPG1 a INHIBITMPG12 del PLC. Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente.\"" .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_29100b6800 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "V.PLC.INHIBITMPG1" ;
    ns1:textoExtracto "\"(V.)PLC.INHIBITMPG1 Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Variable de report (para uso desde los scripts). Estas variables reflejan el estado de las marcas INHIBITMPG1 a INHIBITMPG12 del PLC. Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente.\"" .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_dbf019471b a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "V.PLC.CNCOFF" ;
    ns1:textoExtracto "\"(V.)PLC.CNCOFF Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Variable de report (para uso desde los scripts). Esta variable refleja el estado de la marca CNCOFF del PLC. Si el PLC activa la marca, el CNC comienza la secuencia de apagado.\"" .

