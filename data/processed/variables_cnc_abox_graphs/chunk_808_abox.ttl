@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeReportINT1 a ns1:Parametro ;
    rdfs:label "Variable de report INT1" ;
    ns1:identificador "INT1" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas INT1 a INT4 del PLC." .

ns1:VariableDeReportINT2 a ns1:Parametro ;
    rdfs:label "Variable de report INT2" ;
    ns1:identificador "INT2" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas INT1 a INT4 del PLC." .

ns1:VariableDeReportINT3 a ns1:Parametro ;
    rdfs:label "Variable de report INT3" ;
    ns1:identificador "INT3" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas INT1 a INT4 del PLC." .

ns1:VariableDeReportINT4 a ns1:Parametro ;
    rdfs:label "Variable de report INT4" ;
    ns1:identificador "INT4" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas INT1 a INT4 del PLC." .

