@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLCSenalesLogicas a ns1:Sistema ;
    rdfs:label "Sistema PLC Señales Lógicas" ;
    ns1:textoExtracto "El sistema permanece en espera hasta que se desactive la señal para reanudar la ejecución y el movimiento desde el punto en el que se detuvo." ;
    ns1:tieneComponente ns1:NombreONumeroLogicoDelCabezal,
        ns1:NombreONumeroLogicoDelEje .

ns1:NombreONumeroLogicoDelCabezal a ns1:Parametro ;
    rdfs:label "Nombre o número lógico del cabezal" ;
    ns1:textoExtracto "· sn· Nombre o número lógico del cabezal." .

ns1:NombreONumeroLogicoDelEje a ns1:Parametro ;
    rdfs:label "Nombre o número lógico del eje" ;
    ns1:textoExtracto "· xn· Nombre o número lógico del eje." .

