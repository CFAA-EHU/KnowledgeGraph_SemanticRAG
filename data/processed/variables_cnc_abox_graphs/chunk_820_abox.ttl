ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPL_53b9c8880b a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." ;
    ns1:identificador "PLC.AXISPOSxn" ;
    ns1:textoExtracto "(V.)PLC.AXISPOSxn (V.)PLC.AXISPOSsn Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC. Variable válida para ejes rotativos, lineales y cabezales." .

ns1:VariableDeReportParaUsoDesdeLosScriptsEstasVariablesReflejanElEstadoD_54e073606c a ns1:Parametro ;
