@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaMarcaPARKEDDelPLCParaElCabezalS a ns1:Parametro ;
    rdfs:label "Estado de la marca PARKED del PLC para el cabezal S" ;
    ns1:identificador "VPLCLIMSOFF" ;
    ns1:textoExtracto "V.PLC.LIMSOFF | Cabezal S." .

ns1:EstadoDeLaMarcaPARKEDDelPLCParaElCabezalSn a ns1:Parametro ;
    rdfs:label "Estado de la marca PARKED del PLC para el cabezal sn" ;
    ns1:identificador "PLCPARKEDsn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:EstadoDeLaMarcaPARKEDDelPLCParaElEjeOCabezalConNumeroLogico3 a ns1:Parametro ;
    rdfs:label "Estado de la marca PARKED del PLC para el eje o cabezal con número lógico 3" ;
    ns1:identificador "VPLCLIM3OFF" ;
    ns1:textoExtracto "V.PLC.LIM3OFF | Eje o cabezal con número lógico ·3·." .

ns1:EstadoDeLaMarcaPARKEDDelPLCParaElEjeX a ns1:Parametro ;
    rdfs:label "Estado de la marca PARKED del PLC para el eje X" ;
    ns1:identificador "VPLCLIMXOFF" ;
    ns1:textoExtracto "V.PLC.LIMXOFF | Eje X." .

ns1:EstadoDeLaMarcaPARKEDDelPLCParaElEjeXn a ns1:Parametro ;
    rdfs:label "Estado de la marca PARKED del PLC para el eje xn" ;
    ns1:identificador "PLCPARKEDxn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

