@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC activa esta marca para indicar que ha terminado de engrasar el eje." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPLCParaElEjeX a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC para el eje X" ;
    ns1:identificador "PLC.LUBRENAX" ;
    ns1:textoExtracto "V.PLC.LUBRENAX | Eje X." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPL_0c13d11476 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC para el eje o cabezal con número lógico 3" ;
    ns1:identificador "PLC.LUBRENA3" ;
    ns1:textoExtracto "V.PLC.LUBRENA3 | Eje o cabezal con número lógico ·3·." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaYPL_4efaa412f0 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa y PLC para el cabezal S" ;
    ns1:identificador "PLC.LUBRENAS" ;
    ns1:textoExtracto "V.PLC.LUBRENAS | Cabezal S." .

