@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDePLCParaDiferenciacionDelCabezalS a ns1:Parametro ;
    rdfs:label "Variable de PLC para diferenciación del cabezal S" ;
    ns1:identificador "PLC.DIFFCOMPS" ;
    ns1:textoExtracto "V.PLC.DIFFCOMPS | Cabezal S." .

ns1:VariableDePLCParaDiferenciacionDelEjeOCabezalConNumeroLogico3 a ns1:Parametro ;
    rdfs:label "Variable de PLC para diferenciación del eje o cabezal con número lógico 3" ;
    ns1:identificador "PLC.DIFFCOMP3" ;
    ns1:textoExtracto "V.PLC.DIFFCOMP3 | Eje o cabezal con número lógico ·3·." .

ns1:VariableDePLCParaDiferenciacionDelEjeX a ns1:Parametro ;
    rdfs:label "Variable de PLC para diferenciación del eje X" ;
    ns1:identificador "PLC.DIFFCOMPX" ;
    ns1:textoExtracto "V.PLC.DIFFCOMPX | Eje X." .

ns1:VariableDePLCParaSeleccionDeRetroalimentacion a ns1:Parametro ;
    rdfs:label "Variable de PLC para selección de retroalimentación" ;
    ns1:identificador "PLC.FBACKSELxn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

