@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Estas variables reflejan el estado de la marca SWITCH del PLC. Cuando el sistema dispone de grupos multieje, esta marca permite conmutar entre los diferentes ejes o cabezales del grupo." ;
    ns1:tieneComponente ns1:CabezalS_3846fbe191,
        ns1:EjeOCabezalConNumeroLogico3_6cb924cabf,
        ns1:EjeX_7231e754ce .

ns1:CabezalS_3846fbe191 a ns1:Parametro ;
    rdfs:label "Cabezal S" ;
    ns1:identificador "PLC.DEADS" ;
    ns1:textoExtracto "V.PLC.DEADS | Cabezal S." .

ns1:EjeOCabezalConNumeroLogico3_6cb924cabf a ns1:Parametro ;
    rdfs:label "Eje o cabezal con número lógico ·3·" ;
    ns1:identificador "PLC.DEAD3" ;
    ns1:textoExtracto "V.PLC.DEAD3 | Eje o cabezal con número lógico ·3·." .

ns1:EjeX_7231e754ce a ns1:Parametro ;
    rdfs:label "Eje X" ;
    ns1:identificador "PLC.DEADX" ;
    ns1:textoExtracto "V.PLC.DEADX | Eje X." .

