@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeReportParaUsoDesdeLosScriptsEstadoPLCM3 a ns1:Parametro ;
    rdfs:label "Variable de report para uso desde los scripts - estado PLCM3" ;
    ns1:identificador "PLCM3" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas PLCM3, PLCM4 y PLCM5 del PLC." .

ns1:VariableDeReportParaUsoDesdeLosScriptsEstadoPLCM4 a ns1:Parametro ;
    rdfs:label "Variable de report para uso desde los scripts - estado PLCM4" ;
    ns1:identificador "PLCM4" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas PLCM3, PLCM4 y PLCM5 del PLC." .

ns1:VariableDeReportParaUsoDesdeLosScriptsEstadoPLCM5 a ns1:Parametro ;
    rdfs:label "Variable de report para uso desde los scripts - estado PLCM5" ;
    ns1:identificador "PLCM5" ;
    ns1:textoExtracto "Estas variables reflejan el estado de las marcas PLCM3, PLCM4 y PLCM5 del PLC." .

