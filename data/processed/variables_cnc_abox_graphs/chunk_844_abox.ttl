ns1:LimiteDeSeguridadParaLaVelocidadEnElCabezal1 a ns1:Parametro ;
    rdfs:label "Límite de seguridad para la velocidad en el cabezal 1" ;
    ns1:identificador "V.PLC.SLIMITACSPDL1" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado. | V.PLC.SLIMITACSPDL1 | Cabezal ·1·." .

