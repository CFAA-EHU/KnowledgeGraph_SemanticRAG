@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaEInterfazDeLecturaDesdeElPLC a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa e interfaz; de lectura desde el PLC" ;
    ns1:identificador "PLC._IXFERINHxn" ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca IXFERINH del PLC. Si el PLC desactiva esta marca, los movimientos de eje independiente se quedan a la espera hasta que el PLC vuelva a activar la marca." .

