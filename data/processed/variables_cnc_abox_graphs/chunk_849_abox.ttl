@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableQueDevuelveElValorDeEjecucionYDetieneLaPreparacionDeBloques a ns1:Parametro ;
    rdfs:label "Variable que devuelve el valor de ejecución y detiene la preparación de bloques" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

