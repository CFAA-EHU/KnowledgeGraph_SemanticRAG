@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaMarcaLASERREADYDelPLC a ns1:Parametro ;
    rdfs:label "Estado de la marca LASERREADY del PLC" ;
    ns1:identificador "V.PLC.LASERREADY" ;
    ns1:textoExtracto "Variable de report (para uso desde los scripts). Unidades: - . Esta variable refleja el estado de la marca LASERREADY del PLC. El PLC activa está marca para indicar que el láser está preparado." .

