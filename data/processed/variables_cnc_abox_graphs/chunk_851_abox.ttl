@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaPWM a ns1:Frecuencia ;
    rdfs:label "Frecuencia del PWM, cuando el PWM ha sido activado desde el PLC."@es ;
    ns1:textoExtracto "\"Frecuencia del PWM, cuando el PWM ha sido activado desde el PLC. Esta variable sólo es funcional cuando el láser está activo por PLC.\""@es .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaLaV_92fd43ee8f a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques."@es ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "PLC.PWMON" ;
    ns1:textoExtracto "\"(V.)PLC.PWMON Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\""@es .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElProgramaLaV_d7fad06d66 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques."@es ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "PLC.PWMFREQ" ;
    ns1:textoExtracto "\"(V.)PLC.PWMFREQ Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\""@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "\"Esta marca permite activar y desactivar el PWM desde el PLC. La activación del PWM desde el PLC tiene prioridad sobre la activación desde el CNC.\""@es .

