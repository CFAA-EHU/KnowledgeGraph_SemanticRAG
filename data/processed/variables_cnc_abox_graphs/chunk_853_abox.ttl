@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloDeTrabajoDelPWMCuandoElPWMHaSidoActivadoDesdeElPLC_1b6865e8a0 a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo del PWM, cuando el PWM ha sido activado desde el PLC" ;
    ns1:identificador "PLC.PWMDUTY" ;
    ns1:textoExtracto "V.)PLC.PWMDUTY Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeReportParaUsoDesdeLosScripts_3095cfae3e a ns1:Parametro ;
    rdfs:label "Variable de report (para uso desde los scripts)" ;
    ns1:identificador "V.PLC.PWMDUTY" ;
    ns1:textoExtracto "V.PLC.PWMDUTY Observaciones. Los cambios desde la variable se actualizan en el siguiente lazo; no se consideraran los tiempos intermedios entre lazos." .

