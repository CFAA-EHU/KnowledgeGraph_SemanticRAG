ns1:Parametro_202b83458d a ns1:Parametro ;
    rdfs:label "Marca RESTMEM del PLC" ;
    ns1:textoExtracto "Esta variable refleja el estado de la marca RESTMEM del PLC." .

ns1:VariableDeEjecucion a ns1:Parametro ;
    rdfs:label "Variable de ejecución" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

