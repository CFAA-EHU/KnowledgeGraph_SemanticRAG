ns1:VariableDeReportParaRechazoDeHerramienta a ns1:Parametro ;
    rdfs:label "Variable de report para rechazo de herramienta" ;
    ns1:identificador "PLC.TREJECT" ;
    ns1:textoExtracto "(V.)PLC.TREJECT Variable de lectura y escritura desde el interfaz; de lectura desde el programa. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

