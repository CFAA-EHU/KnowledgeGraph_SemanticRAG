    rdfs:label "Variable que devuelve el valor de ejecución del almacén 1 para MZ1" ;
    ns1:identificador "PLC.SPDLTOCH1MZ1" ;
    ns1:textoExtracto "V.PLC.SPDLTOCH1MZ1 Almacén ·1·." .

