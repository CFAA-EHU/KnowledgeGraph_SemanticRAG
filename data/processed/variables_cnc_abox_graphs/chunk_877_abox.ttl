@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Estos registros controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." ;
    ns1:tieneComponente ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_8ac95a814c,
        ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_8e6ce20a57 .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_8ac95a814c a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "PLC.KEYLED2" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:VariableDeLecturaYEscrituraDesdeElInterfazDeLecturaDesdeElPrograma_8e6ce20a57 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el interfaz; de lectura desde el programa" ;
    ns1:identificador "PLC.KEYLED1" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

