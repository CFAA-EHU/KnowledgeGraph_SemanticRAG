@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Estos registros inhiben (bit=1) las teclas y los conmutadores en cada panel de mando." ;
    ns1:tieneComponente ns1:RegistroKEYDIS11,
        ns1:RegistroKEYDIS21,
        ns1:RegistroKEYDIS31,
        ns1:RegistroKEYDIS48 .

ns1:RegistroKEYDIS11 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS1_1" ;
    ns1:identificador "KEYDIS1_1" ;
    ns1:textoExtracto "Estas variables reflejan el valor de los registros KEYDIS1_1 A KEYDIS4_8 del PLC." .

ns1:RegistroKEYDIS21 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS2_1" ;
    ns1:identificador "KEYDIS2_1" ;
    ns1:textoExtracto "Estas variables reflejan el valor de los registros KEYDIS1_1 A KEYDIS4_8 del PLC." .

ns1:RegistroKEYDIS31 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS3_1" ;
    ns1:identificador "KEYDIS3_1" ;
    ns1:textoExtracto "Estas variables reflejan el valor de los registros KEYDIS1_1 A KEYDIS4_8 del PLC." .

ns1:RegistroKEYDIS48 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS4_8" ;
    ns1:identificador "KEYDIS4_8" ;
    ns1:textoExtracto "Estas variables reflejan el valor de los registros KEYDIS1_1 A KEYDIS4_8 del PLC." .

