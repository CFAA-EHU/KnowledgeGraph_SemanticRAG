@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelEjeCodificadoEnFormatoNumerico a ns1:Parametro ;
    rdfs:label "Nombre del eje, codificado en formato numérico" ;
    ns1:identificador "G.GAXISNAMEn" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

