@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2829fae9f9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema con 5 ejes" ;
    ns1:textoExtracto "en un sistema con 5 ejes, el primer cabezal de la tabla será el cabezal lógico ·6· y así sucesivamente." .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:ilustra ns1:CabezalLogico ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 5 ejes, el primer cabezal de la tabla será el cabezal lógico ·6· y así sucesivamente." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_8a64a15d00 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.Ch.G.AXISNAMEn" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques." .

ns1:CabezalLogico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Lógico" ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 5 ejes, el primer cabezal de la tabla será el cabezal lógico ·6· y así sucesivamente." ;
    ns1:valor "6" .

