@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaInterfazUsuario a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario para variables de configuración" ;
    ns1:documentadoEn ns1:NombreDelCabezalCodificadoEnFormatoNumericoNombreAPartirDeSuIndiceEnElCanal ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:documentadoEn ns1:NombreDelCabezalCodificadoEnFormatoNumericoNombreAPartirDeSuIndiceEnElCanal ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz." .

ns1:NombreDelCabezalCodificadoEnFormatoNumericoNombreAPartirDeSuIndiceEnElCanal a ns1:Parametro ;
    rdfs:label "Nombre del cabezal, codificado en formato numérico; nombre a partir de su índice en el canal" ;
    ns1:identificador "V.ch.G.SPDLNAMEn" ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

