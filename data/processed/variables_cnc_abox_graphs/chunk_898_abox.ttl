@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelEjeEnFormatoTextoGeneral a ns1:Parametro ;
    rdfs:label "Nombre del eje en formato texto (general)" ;
    ns1:identificador "V.ch.A.AXISNAME.xn" ;
    ns1:textoExtracto "Variable de lectura desde el programa e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques. Nombre del eje en formato texto." .

ns1:NombreDelEjeEnFormatoTexto_5cfb371a83 a ns1:Parametro ;
    rdfs:label "Nombre del eje en formato texto" ;
    ns1:identificador "V.2.G.SPDLNAME1" ;
    ns1:textoExtracto "Valores de la variable. Los valores que devuelve esta variable están codificados de la siguiente forma. S=100 S1=101 S2=102 S3=103 S4=104 ... S9=109" .

