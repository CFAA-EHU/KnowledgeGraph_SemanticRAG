ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_af01207312 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques."@es ;
    ns1:identificador "V.C.SOFTLIMIT" ;
    ns1:textoExtracto "\"(V.)[ch].G.SOFTLIMIT Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques.\""@es .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaDeLecturaDesdeElPLCEInterfa_3967f0543b a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa; de lectura desde el PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques."@es ;
    ns1:identificador "V.A.NEGLIMIT" ;
    ns1:textoExtracto "\"(V.)[ch].A.POSLIMIT.xn (V.)[ch].A.NEGLIMIT.xn Variable de lectura y escritura desde el programa; de lectura desde el PLC e interfaz. La variable devuelve el valor de la preparación de bloques.\""@es .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaDeLecturaDesdeElPLCEInterfa_adbc3e8195 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa; de lectura desde el PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de la preparación de bloques."@es ;
    ns1:identificador "V.A.POSLIMIT" ;
    ns1:textoExtracto "\"(V.)[ch].A.POSLIMIT.xn (V.)[ch].A.NEGLIMIT.xn Variable de lectura y escritura desde el programa; de lectura desde el PLC e interfaz. La variable devuelve el valor de la preparación de bloques.\""@es .

