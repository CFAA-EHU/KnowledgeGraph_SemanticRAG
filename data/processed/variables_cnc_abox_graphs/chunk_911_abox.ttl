@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_34457c2dff a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualBrochadoraA218 ;
    ns1:textoExtracto "Estas variables corresponden a los límites fijados por parámetro máquina. Si se modifican estas variables el CNC asume, en adelante, dichos valores como nuevos límites." .

ns1:LimiteDePosicionDelEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Límite de posición del eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].A.POSLIMIT.1" ;
    ns1:textoExtracto "V.[2].A.POSLIMIT.1 | Eje con índice ·1· en el canal ·2·." .

ns1:LimiteDePosicionDelEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Límite de posición del eje con número lógico 4" ;
    ns1:identificador "V.A.POSLIMIT.4" ;
    ns1:textoExtracto "V.A.POSLIMIT.4 | Eje con número lógico ·4·." .

ns1:LimiteDePosicionDelEjeZ a ns1:Parametro ;
    rdfs:label "Límite de posición del eje Z" ;
    ns1:identificador "V.A.POSLIMIT.Z" ;
    ns1:textoExtracto "V.A.POSLIMIT.Z | Eje Z." .

ns1:SegundoLimiteNegativoDeSoftware_de5892e680 a ns1:Parametro ;
    rdfs:label "Segundo límite negativo de software" ;
    ns1:identificador "V.[ch].A.RTNEGLIMIT.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:SegundoLimitePositivoDeSoftware_9b62d6f466 a ns1:Parametro ;
    rdfs:label "Segundo límite positivo de software" ;
    ns1:identificador "V.[ch].A.RTPOSLIMIT.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

