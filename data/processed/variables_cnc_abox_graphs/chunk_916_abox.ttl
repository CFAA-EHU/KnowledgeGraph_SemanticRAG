@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_25e92b0e65 a ns1:Parametro ;
    rdfs:label "Parámetro que define el sentido de giro del cabezal para M4" ;
    ns1:identificador "POLARM4" ;
    ns1:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4 del cabezal, los cuales definen el sentido de giro del cabezal para M3 y M4." .

ns1:Parametro_dcad92d93c a ns1:Parametro ;
    rdfs:label "Parámetro que define el sentido de giro del cabezal para M3" ;
    ns1:identificador "POLARM3" ;
    ns1:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4 del cabezal, los cuales definen el sentido de giro del cabezal para M3 y M4." .

ns1:VariableDeLecturaYEscrituraDesdeElProgramaPLCEInterfazParaInvertirElS_772fb9bcb0 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el programa, PLC e interfaz para invertir el sentido de giro del cabezal" ;
    ns1:identificador "A.POLARITY.sn" ;
    ns1:textoExtracto "V.[ch].A.POLARITY.sn Variable de lectura y escritura desde el programa, PLC e interfaz. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

