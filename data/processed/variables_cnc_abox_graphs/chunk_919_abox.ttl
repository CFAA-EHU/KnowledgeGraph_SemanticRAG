@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioVolante a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Volante" ;
    ns1:textoExtracto "Número de impulsos enviados por el volante desde el arranque del sistema. Mientras el volante está inhibido desde PLC (marca INHIBITMPG1 a INHIBITMPG12) la variable no guarda los impulsos que envía el volante." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:monitoreaParametro ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_52c38dc432,
        ns1:VariableDeLecturaParaVolante1 ;
    ns1:textoExtracto "El PLC puede utilizar estas variables para controlar el avance de mecanizado en función de lo rápido que gire el volante, por ejemplo para la primera vez que se mecaniza una pieza o para retroceder en el mecanizado cuando está activa la función retrace." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_52c38dc432 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.HANDP" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Número de impulsos enviados por el volante desde el arranque del sistema." .

ns1:VariableDeLecturaParaVolante1 a ns1:Parametro ;
    rdfs:label "Variable de lectura para Volante 1" ;
    ns1:identificador "G.HANDP[1]" ;
    ns1:textoExtracto "| (V.)G.HANDP[1] | Volante ·1·. |" .

