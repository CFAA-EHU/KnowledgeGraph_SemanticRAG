@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_a203090692 a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ns1:documentadoEn ns1:CNC8070_6fd4dcb213 ;
    ns1:identificador "PLC.SIMUSPEED" ;
    ns1:ilustradoEn ns1:InterfazUsuarioModificacionVelocidadSimulacion ;
    ns1:textoExtracto "V.PLC.SIMUSPEED Actualmente, la simulación muestra en pantalla una barra horizontal para modificar la velocidad de simulación. Esta variable permite modificar su valor desde el PLC." .

ns1:CNC8070_6fd4dcb213 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El OEM, desde el PLC y en determinados casos, podrá pasar el valor del feed-rate a esta variable para controlar la velocidad de simulación." .

ns1:InterfazUsuarioModificacionVelocidadSimulacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para modificar la velocidad de simulación" ;
    ns1:textoExtracto "Esta variable permite modificar su valor desde el PLC. El OEM, desde el PLC y en determinados casos, podrá pasar el valor del feed-rate a esta variable para controlar la velocidad de simulación." .

