@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaComunicacionYDeLosDispositivosMechatrolink a ns1:Parametro ;
    rdfs:label "Estado de la comunicación y de los dispositivos Mechatrolink" ;
    ns1:identificador "V.2.SP.MSTATUS.1" ;
    ns1:textoExtracto "Cabezal con índice ·1· en el canal ·2·." .

ns1:EstadoDeSubcomandoYDispositivoParaCabezal a ns1:Parametro ;
    rdfs:label "Estado de subcomando y dispositivo para cabezal" ;
    ns1:identificador "V.ch.A.MSUBSTAT.sn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales." .

ns1:EstadoDeSubcomandoYDispositivoParaCabezalDesdeElPrograma a ns1:Parametro ;
    rdfs:label "Estado de subcomando y dispositivo para cabezal desde el programa" ;
    ns1:identificador "V.ch.SP.MSUBSTAT.sn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales." .

ns1:EstadoDeSubcomandoYDispositivoParaEje a ns1:Parametro ;
    rdfs:label "Estado de subcomando y dispositivo para eje" ;
    ns1:identificador "V.ch.A.MSUBSTAT.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales." .

