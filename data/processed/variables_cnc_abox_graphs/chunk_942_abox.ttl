@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PotenciaDefinidaEnElPrograma a ns1:Parametro ;
    rdfs:label "Potencia definida en el programa" ;
    ns1:identificador "A.PRGS.sn" ;
    ns1:textoExtracto "Por programa; S5000. Por PLC; no hay." .

ns1:PotenciaDefinidaPorPLC a ns1:Parametro ;
    rdfs:label "Potencia definida por PLC" ;
    ns1:identificador "PLC.S.sn" ;
    ns1:textoExtracto "Por programa; S5000. Por PLC; no hay." .

ns1:VelocidadDePotenciaDefinidaEnElPrograma a ns1:Parametro ;
    rdfs:label "Velocidad de potencia definida en el programa" ;
    ns1:identificador "A.SPEED.sn" ;
    ns1:textoExtracto "Por programa; S5000. Por PLC; no hay." .

