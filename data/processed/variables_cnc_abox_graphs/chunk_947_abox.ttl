@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteDePotenciaDelCabezalConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Límite de potencia del cabezal con índice 1 en el canal 2" ;
    ns1:identificador "SLIMIT.1" ;
    ns1:textoExtracto "V.[2].SP.SLIMIT.1 | Cabezal con índice ·1· en el canal ·2·." .

ns1:LimiteDePotenciaDelCabezalConIndice2EnElSistema a ns1:Parametro ;
    rdfs:label "Límite de potencia del cabezal con índice 2 en el sistema" ;
    ns1:identificador "SLIMIT.2" ;
    ns1:textoExtracto "V.SP.SLIMIT.2 | Cabezal con índice ·2· en el sistema." .

ns1:LimiteDePotenciaDelCabezalConNumeroLogico5 a ns1:Parametro ;
    rdfs:label "Límite de potencia del cabezal con número lógico 5" ;
    ns1:identificador "SLIMIT.5" ;
    ns1:textoExtracto "V.A.SLIMIT.5 | Cabezal con número lógico ·5·." .

ns1:LimiteDePotenciaDelCabezalMaster a ns1:Parametro ;
    rdfs:label "Límite de potencia del cabezal master" ;
    ns1:identificador "SLIMIT" ;
    ns1:textoExtracto "V.SP.SLIMIT | Cabezal master." .

ns1:LimiteDePotenciaDelCabezalS a ns1:Parametro ;
    rdfs:label "Límite de potencia del cabezal S" ;
    ns1:identificador "SLIMIT.S" ;
    ns1:textoExtracto "V.A.SLIMIT.S | Cabezal S." .

ns1:VariableDeLecturaYEscrituraDesdePLCDeLecturaDesdeProgramaEInterfaz a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde PLC; de lectura desde programa e interfaz" ;
    ns1:identificador "PLC.SL.sn" ;
    ns1:textoExtracto "( V.)[ch].PLC.SL.sn Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz." .

