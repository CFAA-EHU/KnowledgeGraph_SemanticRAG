@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeDePotenciaPorPLC a ns1:Parametro ;
    rdfs:label "Porcentaje de potencia por PLC" ;
    ns1:textoExtracto "El porcentaje fijado por PLC es más prioritario que el fijado desde el panel de mando, pero menos prioritario que el fijado por programa." .

ns1:VariableAnulacionPLC a ns1:Parametro ;
    rdfs:label "Variable para anular valor fijado por PLC" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "Para anular el valor fijado por PLC, definir la variable con valor ·0·." .

ns1:VariableNombreCabezal a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal" ;
    ns1:identificador "sn" ;
    ns1:textoExtracto "sn Nombre, número lógico o índice del cabezal." .

