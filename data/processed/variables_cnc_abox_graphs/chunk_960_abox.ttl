@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDePWM a ns1:Parametro ;
    rdfs:label "Estado de PWM" ;
    ns1:documentadoEn ns1:TablaEstadoPWM ;
    ns1:textoExtracto "Estado de PWM." .

ns1:EstadoDelPWMDesdeElCNC a ns1:Parametro ;
    rdfs:label "Estado del PWM desde el CNC" ;
    ns1:documentadoEn ns1:TablaEstadoPWM ;
    ns1:textoExtracto "Estado del PWM desde el CNC." .

ns1:EstadoDelPWMDesdeElPLC a ns1:Parametro ;
    rdfs:label "Estado del PWM desde el PLC" ;
    ns1:documentadoEn ns1:TablaEstadoPWM ;
    ns1:textoExtracto "Estado del PWM desde el PLC." .

ns1:TablaEstadoPWM a ns1:Tabla ;
    rdfs:label "Tabla Estado PWM" ;
    ns1:textoExtracto "Estado del PWM desde el CNC. | Estado del PWM desde el PLC. | Estado de PWM." .

