@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelPWMTrasFinalizarElModoRafaga a ns1:Parametro ;
    rdfs:label "Estado del PWM tras finalizar el modo ráfaga" ;
    ns1:identificador "G.PWMBEND" ;
    ns1:textoExtracto "V.)G.PWMBEND Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Valor enumerado." .

ns1:TiempoEnMsRedondeadoAUnidadesDeLazoQuePermaneceActivoElPWMEnModoRafaga a ns1:Parametro ;
    rdfs:label "Tiempo (en ms redondeado a unidades de lazo) que permanece activo el PWM en modo ráfaga" ;
    ns1:identificador "G.PWMBTIME" ;
    ns1:textoExtracto "V.)G.PWMBTIME Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques. Unidades: Milisegundos." .

