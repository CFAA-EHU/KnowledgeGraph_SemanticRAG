    ns1:identificador "G.PWROUTOVRMAX" ;
    ns1:textoExtracto "Variable asociada al comando OVRMAX de la sentencia #PWRCTRL ON [OUT]. V.G.PWROUTOVRMAX" .

ns1:CNC8070_342d6f9b9e a ns1:Sistema ;
