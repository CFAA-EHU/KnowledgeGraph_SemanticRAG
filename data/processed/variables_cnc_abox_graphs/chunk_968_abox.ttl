ns1:AvancePorDebajoDelCualElCNCAplicaElPorcentajeOVRMINALaPotencia_282bca0e60 a ns1:Parametro ;
    rdfs:label "Avance por debajo del cual el CNC aplica el porcentaje OVRMIN a la potencia" ;
    ns1:documentadoEn ns1:CNC8070_342d6f9b9e ;
    ns1:identificador "G.PWROUTFMIN" ;
    ns1:textoExtracto "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz. La variable devuelve el valor de la preparación de bloques." .

ns1:PorcentajeMaximoDePotenciaAAplicar_013b74548c a ns1:Parametro ;
