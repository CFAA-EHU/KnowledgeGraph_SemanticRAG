ns1:AvancePorDebajoDelCualElCNCAplicaElPorcentajeOVRMINALaPotencia a ns1:Parametro ;
    rdfs:label "Avance por debajo del cual el CNC aplica el porcentaje OVRMIN a la potencia" ;
