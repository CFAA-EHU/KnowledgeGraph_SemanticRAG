ns1:VariableAsociadaAlComandoFMAXDeLaSentenciaPWRCTRLONOUT_04ad48e67e a ns1:Parametro ;
    rdfs:label "Variable asociada al comando FMAX de la sentencia #PWRCTRL ON [OUT]" ;
    ns1:identificador "G.PWROUTFMAX" ;
    ns1:textoExtracto "V.G.PWROUTFMAX Observaciones. • La variable devuelve el valor de la preparación de bloques." .

ns1:VariableAsociadaAlComandoFMINDeLaSentenciaPWRCTRLONOUT_e8c6afd65d a ns1:Parametro ;
    rdfs:label "Variable asociada al comando FMIN de la sentencia #PWRCTRL ON [OUT]" ;
    ns1:identificador "G.PWROUTFMIN" ;
    ns1:textoExtracto "V.G.PWROUTFMIN Observaciones. • La variable asume el valor programado en la sentencia #PWRCTRL durante la preparación de bloques." .

