@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ad0ecc48c3 a ns1:Parametro ;
    rdfs:label "Comando para activar el control de potencia desde el PLC" ;
    ns1:identificador "CNCEX" ;
    ns1:textoExtracto "Cuando el control de potencia se activa desde el PLC (comando CNCEX), esta variable no actualiza su valor." .

ns1:SentenciaParaProgramarElControlDePotencia a ns1:Parametro ;
    rdfs:label "Sentencia para programar el control de potencia" ;
    ns1:identificador "#PWRCTRL" ;
    ns1:textoExtracto "Esta variable se activa al programar el comando #PWRCTRL desde el programa." .

ns1:VariableQueAsumeElValorProgramadoEnLaSentenciaPWRCTRLDuranteLaPrepara_8d4b5e0ea7 a ns1:Parametro ;
    rdfs:label "Variable que asume el valor programado en la sentencia #PWRCTRL durante la preparación de bloques" ;
    ns1:identificador "V.G.PWROUTFMAX" ;
    ns1:textoExtracto "La variable asume el valor programado en la sentencia #PWRCTRL durante la preparación de bloques." .

