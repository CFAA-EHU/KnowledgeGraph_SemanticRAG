@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDePotencia a ns1:Parametro ;
    rdfs:label "Control de potencia" ;
    ns1:identificador "#PWRCTRL" ;
    ns1:textoExtracto "La variable asume el valor programado en la sentencia #PWRCTRL durante la preparación de bloques." .

ns1:PorcentajeMinimoDePotenciaAAplicar_350367bf21 a ns1:Parametro ;
    rdfs:label "Porcentaje mínimo de potencia a aplicar" ;
    ns1:documentadoEn ns1:CNC8070_342d6f9b9e ;
    ns1:identificador "V.G.PWRDUTYOVRMIN" ;
    ns1:ilustradoEn ns1:SistemaPLC ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Porcentaje. Porcentaje mínimo de potencia a aplicar." .

ns1:CNC8070_342d6f9b9e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC mantiene los valores calculados durante la preparación de bloques." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Si durante la ejecución de un programa, el PLC modifica estas variables" .

