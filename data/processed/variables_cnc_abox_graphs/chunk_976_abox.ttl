@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Cuando el control de potencia se activa desde el PLC (comando CNCEX), esta variable no actualiza su valor." .

ns1:VariableAsociadaAlComandoOVRMAXDeLaSentenciaPWRCTRLONDUTY a ns1:Parametro ;
    rdfs:label "Variable asociada al comando OVRMAX de la sentencia #PWRCTRL ON [DUTY]" ;
    ns1:documentadoEn ns1:CNC8070_65acb34615 ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "Variable asociada al comando OVRMAX de la sentencia #PWRCTRL ON [DUTY]." .

ns1:VariableDeLecturaYEscrituraDesdeElPLCDeLecturaDesdeElProgramaEInterfaz_c94a61158a a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz" ;
    ns1:documentadoEn ns1:CNC8070_65acb34615 ;
    ns1:identificador "G.PWRDUTYOVRMAX" ;
    ns1:textoExtracto "V.)G.PWRDUTYOVRMAX Variable de lectura y escritura desde el PLC; de lectura desde el programa e interfaz." .

ns1:CNC8070_65acb34615 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si durante la ejecución de un programa, el PLC modifica estas variables, el CNC mantiene los valores calculados durante la preparación de bloques." .

