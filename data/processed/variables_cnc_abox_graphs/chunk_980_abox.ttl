@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaPreparacionDeBloquesParaElControlDePotencia a ns1:Parametro ;
    rdfs:label "Valor de la preparación de bloques para el control de potencia" ;
    ns1:identificador "V.G.PWRDUTYFMAX" ;
    ns1:parametroMonitoradoPor ns1:CNC8070_043151ff3b ;
    ns1:textoExtracto "Variable asociada al comando FMAX de la sentencia #PWRCTRL ON [DUTY]. V.G.PWRDUTYFMAX" .

ns1:CNC8070_043151ff3b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ControlDePotenciaATravesDelCicloDeTrabajoDutyDelPWM_67649ebdc2 ;
    ns1:textoExtracto "el CNC aplica el porcentaje OVRMAX a la potencia." .

ns1:ControlDePotenciaATravesDelCicloDeTrabajoDutyDelPWM_67649ebdc2 a ns1:TareaMantenimiento ;
    rdfs:label "Control de potencia a través del ciclo de trabajo (duty) del PWM" ;
    ns1:textoExtracto "La variable devuelve el valor de la preparación de bloques. Unidades: Milímetros/minuto o pulgadas/minuto." .

