ns1:MaximaCotaAAlcanzarPorElEjeLongitudinalDuranteElSalto a ns1:Parametro ;
    rdfs:label "Máxima cota a alcanzar por el eje longitudinal durante el salto" ;
    ns1:identificador "V.ch.G.LEAPPOSLIMIT" ;
    ns1:textoExtracto "(V.)[ch].G.LEAPPOSLIMIT Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

