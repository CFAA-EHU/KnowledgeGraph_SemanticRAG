@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2fce1cc24b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El valor de estas variables es equivalente al programado en los parámetros de la sentencia #SWTOUT." ;
    ns1:tieneComponente ns1:SentenciaParaConfiguracionDeOffsets .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:ValoresDeOffsetParaConmutacionSincronizada ;
    ns1:textoExtracto "Si se modifican estas variables desde el PLC, los nuevos valores son asumidos al ejecutar la sentencia #SWTOUT." .

ns1:SentenciaParaConfiguracionDeOffsets a ns1:Parametro ;
    rdfs:label "Sentencia para configuración de offsets" ;
    ns1:identificador "SWTOUT" ;
    ns1:textoExtracto "Si se ejecuta la sentencia sin parámetros y las variables tienen algún valor asignado, el CNC asume estos últimos valores como activos." .

ns1:ValoresDeOffsetParaConmutacionSincronizada a ns1:Parametro ;
    rdfs:label "Valores de offset para conmutación sincronizada" ;
    ns1:identificador "offsets" ;
    ns1:textoExtracto "En el arranque del CNC, los offsets se inicializan a cero." .

