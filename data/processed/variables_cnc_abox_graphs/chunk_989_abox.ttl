@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioConmutacionSincronizada a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Conmutación Sincronizada" ;
    ns1:ilustradoEn ns1:TablaSintaxisCanal ;
    ns1:textoExtracto "Número de canal" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_946fff545f ;
    ns1:textoExtracto "Si al modificar los valores desde el PLC, la sentencia está activa, asume los nuevos valores." .

ns1:TablaSintaxisCanal a ns1:Tabla ;
    rdfs:label "Tabla Sintaxis Canal" ;
    ns1:textoExtracto "ch· Número de canal." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_946fff545f a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "G.LASEROTMON" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura/escritura detiene la preparación de bloques." .

