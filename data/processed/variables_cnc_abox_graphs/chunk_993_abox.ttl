@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_a47c1c0f03 a ns1:Parametro ;
    rdfs:label "variable" ;
    ns1:textoExtracto "En estos casos, tras alcanzar el eje esclavo la sincronización inicial, intenta seguir en cada lazo a los valores de la variable." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El eje sigue a la variable sin ningún proceso de filtrado, por lo que si no se filtran esos valores cuando el PLC los escribe, el eje esclavo podría ir brusco." .

