@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c3ba9473c7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_0e38afe269 ;
    ns1:textoExtracto "El CNC lo desactiva (la variable toma el valor 0). El CNC vuelve a activar el control del gap (la variable toma el valor 1) al finalizar la inspección, tras acabar de reposicionar el eje asociado al sensor." .

ns1:Sensor_fccbac0b38 a ns1:Sensor ;
    rdfs:label "Sensor de control del gap" ;
    ns1:parametroMonitoradoPor ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_0e38afe269 ;
    ns1:textoExtracto "Durante la inspección de herramienta con el control del gap activo, al mover el eje asociado al sensor (MDI o modo manual), el CNC lo desactiva." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfazLaVariableDevuelveElValor_0e38afe269 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques."@es ;
    ns1:identificador "G.GAPAXISPOS" ;
    ns1:textoExtracto "V.)[ch].G.GAPAXISPOS Variable de lectura desde el programa, PLC e interfaz. La variable devuelve el valor de la preparación de bloques." .

