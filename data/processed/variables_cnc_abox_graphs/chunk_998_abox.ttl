@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDelGapEnElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Control del gap en el eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].A.GAPCOMP.1" ;
    ns1:textoExtracto "V.[2].A.GAPCOMP.1 | Eje con índice ·1· en el canal ·2·." .

ns1:ControlDelGapEnElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Control del gap en el eje con número lógico 4" ;
    ns1:identificador "V.A.GAPCOMP.4" ;
    ns1:textoExtracto "V.A.GAPCOMP.4 | Eje con número lógico ·4·." .

ns1:ControlDelGapEnElEjeZ a ns1:Parametro ;
    rdfs:label "Control del gap en el eje Z" ;
    ns1:identificador "V.A.GAPCOMP.Z" ;
    ns1:textoExtracto "V.A.GAPCOMP.Z | Eje Z." .

