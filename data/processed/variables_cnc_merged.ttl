ns1:CNC8070_c63d99a6a4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Este estado permite desactivar la leva, desde el CNC o el PLC." .

ns1:CNC8070_c7c75703e2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .

ns1:CNC8070_c941c6170e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El factor de forma indica cuál es la punta calibrada de la herramienta y por lo tanto, el punto que controla el CNC para aplicar la compensación de radio." .

ns1:CNC8070_d268ce6871 a ns1:Sistema ;
