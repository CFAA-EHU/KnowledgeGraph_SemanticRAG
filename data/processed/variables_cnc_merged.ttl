    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El error cordal en la esquina (modo CONTERROR). Geometría de la esquina (modo FAST)." .

ns1:CNC8070_9c9621c248 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca cuando está desaparcando el eje o cabezal." .

ns1:CNC8070_9d7c2d87b5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC activa estas marcas para indicar cuál es el canal en el que está programado el ciclo y cuales son los canales implicados en el reparto de las pasadas." .

ns1:CNC8070_a57dbf27a2 a ns1:Sistema ;
